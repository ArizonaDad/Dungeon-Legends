json_object@ cached_inspect_data = null;

string room_game_type_label(string game_type) {
	game_type = normalize_character_profile(game_type);
	return game_type == "adventure" ? "Adventure" : "Sandbox";
}
// Check if a player name corresponds to a bot in the current room.
bool is_room_bot(string name) {
	for (uint i = 0; i < room_player_names.length(); i++) {
		if (string(room_player_names[i]) == name and i < room_player_bots.length()) return bool(room_player_bots[i]);
	}
	return false;
}
instance single_game("DungeonLegends");
void main()
{
	//chdir(spec::path(SCRIPT_CURRENT_FILE).make_parent());
	if (SCRIPT_COMPILED and single_game.is_already_running) {
		alert("Dungeon Legends", "Sorry, only one instance of the game can be run at a time.");
		exit();
	}
	show_window("Dungeon Legends");
	install_keyhook();
	check_for_update();
	set_sound_global_hrtf(true);
	pack_file@ sound_pack = pack_file();
	if (sound_pack.open("sounds.dat", "DL_aud10_k3y_2026!")) {
		set_sound_default_pack(sound_pack);
	}
	config.set_encryption("Libertos918!!!");
	config.setup("Libertos Gaming", "Dungeon Legends", false);
	if (!connect()) {
		pop_text("Unable to connect to server.");
		return;
	}
	if (!login()) return;
	wait(100);
	network_loop();
	// Clear any stale game state from a previous session or reconnect
	start_game_pending = false;
	battle_active = false;
	game = false;
	main_menu();
	config.close();
}
// Called when the server signals a game start.
bool launch_pending_game_if_needed()
{
	if (!start_game_pending) return false;
	start_game_pending = false;
	string profile = normalize_character_profile(current_room_game_type);
	set_active_character_profile(profile);
	if (!profile_has_character(profile)) {
		if (profile == "sandbox" and profile_has_character("adventure")) {
			set_active_character_profile("adventure");
		} else {
			speak("That " + room_game_type_label(profile) + " character is missing on this client. The lobby host needs everyone to create one before starting.", true);
			return false;
		}
	}
	music_stop();
	combat_game_loop();
	music_start("menu");
	return true;
}
string current_screen_name = "main_menu"; // Tracks current screen for F1 help.
void create_lobby_for_mode(string game_type) {
	string name, password;
	if (!create_room_form(name, password)) return;
	send({{"type", message_types::new_room}, {"name", name}, {"password", password}, {"game_type", game_type}});
	// Wait for server confirmation (join_room with host field) before entering host menu.
	timer room_wait;
	bool confirmed = false;
	while (room_wait.elapsed < 3000) {
		wait(50);
		network_loop();
		if (room_host_name == username and room_player_names.length() > 0) {
			confirmed = true;
			break;
		}
	}
	if (!confirmed) {
		speak("Failed to create room. Please try again.", true);
		return;
	}
	host_menu();
}

void show_upgrade_menu() {
	init_item_catalog();
	// Request fresh inventory
	send({{"type", message_types::inventory_list}});
	timer inv_wait;
	while (inv_wait.elapsed < 1500) {
		wait(10);
		network_loop();
		if (@cached_inventory != null) break;
	}
	if (@cached_inventory == null or cached_inventory.length() == 0) {
		speak("Your inventory is empty. Nothing to upgrade.", true);
		return;
	}

	// Count items by rarity
	int[] rarity_counts = {0, 0, 0, 0, 0};
	for (uint i = 0; i < cached_inventory.length(); i++) {
		json_object@ entry = cached_inventory[i];
		if (@entry == null or !entry.exists("id")) continue;
		item_def@ item = find_item(string(entry["id"]));
		if (@item != null and item.rarity >= 0 and item.rarity < 5) {
			rarity_counts[item.rarity]++;
		}
	}

	menu@ upgrade_menu = setup_sub_menu("Upgrade Items. Combine 3 items of the same rarity into 1 item of the next rarity.");
	int[] rarity_options;
	for (int r = 0; r < 4; r++) {
		if (rarity_counts[r] >= 3) {
			int cost = get_upgrade_glory_cost(r);
			string next_rarity = RARITY_NAMES[r + 1];
			upgrade_menu.add_item("Upgrade 3 " + RARITY_NAMES[r] + " items to 1 " + next_rarity + " item. Cost: " + cost + " Glory. You have " + rarity_counts[r] + " " + RARITY_NAMES[r] + " items.");
			rarity_options.insert_last(r);
		}
	}

	if (rarity_options.length() == 0) {
		speak("You need at least 3 items of the same rarity to upgrade. No upgrades available.", true);
		return;
	}

	int pick = upgrade_menu.run();
	if (pick < 0) return;
	if (pick >= int(rarity_options.length())) return;

	int selected_rarity = rarity_options[pick];

	// Auto-pick first 3 items of that rarity
	string[] picked_ids;
	string[] picked_names;
	for (uint i = 0; i < cached_inventory.length(); i++) {
		if (int(picked_ids.length()) >= 3) break;
		json_object@ entry = cached_inventory[i];
		if (@entry == null or !entry.exists("id")) continue;
		string item_id = string(entry["id"]);
		item_def@ item = find_item(item_id);
		if (@item != null and item.rarity == selected_rarity) {
			picked_ids.insert_last(item_id);
			picked_names.insert_last(item.name);
		}
	}

	if (int(picked_ids.length()) < 3) {
		speak("Not enough items of that rarity.", true);
		return;
	}

	int cost = get_upgrade_glory_cost(selected_rarity);
	string confirm_text = "Combine " + picked_names[0] + ", " + picked_names[1] + ", and " + picked_names[2] + " for " + cost + " Glory?";
	menu@ confirm_menu = setup_sub_menu(confirm_text);
	confirm_menu.add_item("Yes, upgrade them.");
	confirm_menu.add_item("No, cancel.");
	int confirm = confirm_menu.run();
	if (confirm != 0) {
		speak("Canceled.", false);
		return;
	}

	// Send upgrade request
	json_object upgrade_msg;
	upgrade_msg["type"] = message_types::upgrade_item;
	json_array ids_arr;
	for (uint i = 0; i < picked_ids.length(); i++) {
		ids_arr.add(picked_ids[i]);
	}
	upgrade_msg["item_ids"] = ids_arr;
	send(upgrade_msg);
	speak("Upgrading items...", false);
	// Wait for server response
	timer resp_wait;
	while (resp_wait.elapsed < 2000) {
		wait(10);
		network_loop();
	}
}

void show_inventory() {
	init_item_catalog();
	// Request inventory from server
	send({{"type", message_types::inventory_list}});
	// Wait briefly for response
	timer inv_wait;
	while (inv_wait.elapsed < 1500) {
		wait(10);
		network_loop();
		if (@cached_inventory != null) break;
	}
	if (@cached_inventory == null or cached_inventory.length() == 0) {
		speak("Your inventory is empty.", true);
		return;
	}
	while (true) {
		menu@ inv_menu = setup_sub_menu("Inventory. " + cached_inventory.length() + " of " + MAX_INVENTORY + " slots used.");
		int upgrade_opt = inv_menu.add_item("Upgrade Items. Combine 3 items of the same rarity into a higher rarity item.");
		for (uint i = 0; i < cached_inventory.length(); i++) {
			json_object@ entry = cached_inventory[i];
			if (@entry == null or !entry.exists("id")) continue;
			string item_id = string(entry["id"]);
			item_def@ item = find_item(item_id);
			string label = (i + 1) + ". ";
			if (@item != null) {
				label += item.name + ". " + RARITY_NAMES[item.rarity] + " " + SLOT_NAMES[item.slot] + ". " + item_stat_summary(item) + ".";
				// Check if equipped
				bool equipped = false;
				if (@cached_equipped != null) {
					for (uint s = 0; s < SLOT_NAMES.length(); s++) {
						string slot_key = SLOT_NAMES[s].lower();
						if (cached_equipped.exists(slot_key) and string(cached_equipped[slot_key]) == item_id) {
							equipped = true;
							break;
						}
					}
				}
				if (equipped) label += " Equipped.";
			} else {
				label += "Unknown item: " + item_id + ".";
			}
			inv_menu.add_item(label);
		}
		int pick = inv_menu.run();
		if (pick < 0) return;
		if (pick == upgrade_opt) {
			show_upgrade_menu();
			// Refresh inventory after upgrade
			send({{"type", message_types::inventory_list}});
			timer upg_wait;
			while (upg_wait.elapsed < 1500) {
				wait(10);
				network_loop();
				if (@cached_inventory != null) break;
			}
			continue;
		}
		int item_index = pick - 1; // Offset by 1 because of the Upgrade Items option at the top
		if (item_index < 0 or item_index >= int(cached_inventory.length())) continue;
		json_object@ selected_entry = cached_inventory[item_index];
		if (@selected_entry == null or !selected_entry.exists("id")) continue;
		string sel_item_id = string(selected_entry["id"]);
		item_def@ sel_item = find_item(sel_item_id);
		string item_name = @sel_item != null ? sel_item.name : sel_item_id;
		// Check if this item is currently equipped
		bool is_equipped = false;
		if (@cached_equipped != null and @sel_item != null) {
			string slot_key = SLOT_NAMES[sel_item.slot].lower();
			if (cached_equipped.exists(slot_key) and string(cached_equipped[slot_key]) == sel_item_id) {
				is_equipped = true;
			}
		}
		menu@ item_menu = setup_sub_menu(item_name + ". Choose an action.");
		int equip_opt = -1;
		int unequip_opt = -1;
		if (is_equipped) {
			unequip_opt = item_menu.add_item("Unequip " + item_name + ".");
		} else {
			equip_opt = item_menu.add_item("Equip " + item_name + ".");
		}
		int discard_opt = item_menu.add_item("Discard " + item_name + ".");
		int back_opt = item_menu.add_item("Back.");
		int action = item_menu.run();
		if (action < 0 or action == back_opt) continue;
		if (equip_opt >= 0 and action == equip_opt) {
			send({{"type", message_types::equip_item}, {"item_id", sel_item_id}});
			speak("Equipping " + item_name + ".", false);
			// Refresh inventory
			send({{"type", message_types::inventory_list}});
			wait(500);
			network_loop();
		}
		else if (unequip_opt >= 0 and action == unequip_opt) {
			send({{"type", message_types::equip_item}, {"item_id", sel_item_id}});
			speak("Unequipping " + item_name + ".", false);
			send({{"type", message_types::inventory_list}});
			wait(500);
			network_loop();
		}
		else if (action == discard_opt) {
			menu@ confirm_menu = setup_sub_menu("Are you sure you want to discard " + item_name + "? This cannot be undone.");
			confirm_menu.add_item("Yes, discard it.");
			confirm_menu.add_item("No, keep it.");
			int confirm = confirm_menu.run();
			if (confirm == 0) {
				send({{"type", message_types::discard_item}, {"item_id", sel_item_id}});
				speak("Discarded " + item_name + ".", false);
				send({{"type", message_types::inventory_list}});
				wait(500);
				network_loop();
			} else {
				speak("Canceled.", false);
			}
		}
	}
}

void show_shop() {
	init_consumable_catalog();
	send({{"type", message_types::shop_list}});
	wait(500);
	network_loop();
	int gold = @cached_stats != null and cached_stats.exists("gold") ? int(cached_stats["gold"]) : 0;
	menu@ m = setup_sub_menu("Item Shop. You have " + gold + " gold.");
	for (uint i = 0; i < CONSUMABLE_CATALOG.length(); i++) {
		consumable_def@ c = CONSUMABLE_CATALOG[i];
		string owned = "";
		// Check quantity from cached shop data if available
		if (@cached_shop_list != null) {
			for (uint j = 0; j < cached_shop_list.length(); j++) {
				json_object@ entry = cached_shop_list[j];
				if (@entry != null and entry.exists("id") and string(entry["id"]) == c.id) {
					int qty = entry.exists("qty") ? int(entry["qty"]) : 0;
					if (qty > 0) owned = " Owned: " + qty + ".";
					break;
				}
			}
		}
		m.add_item(c.name + ". " + c.gold_cost + " gold. " + c.description + owned);
	}
	int pick = m.run();
	if (pick < 0 or pick >= int(CONSUMABLE_CATALOG.length())) return;
	consumable_def@ selected = CONSUMABLE_CATALOG[pick];
	menu@ confirm = setup_sub_menu("Buy " + selected.name + " for " + selected.gold_cost + " gold?");
	confirm.add_item("Yes, buy it.");
	confirm.add_item("No, go back.");
	if (confirm.run() == 0) {
		send({{"type", message_types::shop_buy}, {"consumable_id", selected.id}});
		wait(300);
		network_loop();
	}
}

// ---- Settings Persistence ----
void save_settings() {
	config["master_volume"] = "" + master_volume_offset;
	config["tts_speed"] = "" + tts_rate;
}

void load_saved_settings() {
	string vol = config.read_string("master_volume");
	if (vol != "") {
		float parsed_vol = parse_float(vol);
		if (parsed_vol >= -30.0f and parsed_vol <= 12.0f) {
			master_volume_offset = parsed_vol;
			if (@current_music != null) current_music.volume = VOL_MUSIC + master_volume_offset;
		}
	}
	string spd = config.read_string("tts_speed");
	if (spd != "") {
		float parsed_spd = parse_float(spd);
		if (parsed_spd >= -10.0f and parsed_spd <= 10.0f) {
			tts_rate = parsed_spd;
			v.rate = int(tts_rate);
		}
	}
}

// ---- Character View Helpers ----
int get_class_spellcasting_ability(string class_name) {
	string c = class_name;
	if (c == "Bard" or c == "Paladin" or c == "Sorcerer" or c == "Warlock") return ABILITY_CHA;
	if (c == "Cleric" or c == "Druid" or c == "Ranger") return ABILITY_WIS;
	if (c == "Wizard" or c == "Artificer") return ABILITY_INT;
	// Subclass casters: Fighter (Eldritch Knight) and Rogue (Arcane Trickster) use INT
	if (c == "Fighter" or c == "Rogue") return ABILITY_INT;
	return -1;
}

bool is_class_caster(string class_name, string subclass_name) {
	string c = class_name;
	if (c == "Bard" or c == "Cleric" or c == "Druid" or c == "Paladin" or c == "Ranger" or c == "Sorcerer" or c == "Warlock" or c == "Wizard" or c == "Artificer") return true;
	if (c == "Fighter" and subclass_name == "Eldritch Knight") return true;
	if (c == "Rogue" and subclass_name == "Arcane Trickster") return true;
	return false;
}

string get_class_saving_throw_profs(string class_name) {
	string c = class_name;
	if (c == "Barbarian") return "Strength, Constitution";
	if (c == "Bard") return "Dexterity, Charisma";
	if (c == "Cleric") return "Wisdom, Charisma";
	if (c == "Druid") return "Intelligence, Wisdom";
	if (c == "Fighter") return "Strength, Constitution";
	if (c == "Monk") return "Strength, Dexterity";
	if (c == "Paladin") return "Wisdom, Charisma";
	if (c == "Ranger") return "Strength, Dexterity";
	if (c == "Rogue") return "Dexterity, Intelligence";
	if (c == "Sorcerer") return "Constitution, Charisma";
	if (c == "Warlock") return "Wisdom, Charisma";
	if (c == "Wizard") return "Intelligence, Wisdom";
	if (c == "Artificer") return "Constitution, Intelligence";
	return "None";
}

void main_menu()
{
	load_saved_settings();
	music_start("menu");
	if (is_new_account or !profile_has_character("adventure")) {
		speak("Welcome to Dungeon Legends! Let's create your first character.", true);
		int starting_level = cached_level > 0 ? cached_level : 1;
		character_creation_menu("adventure", starting_level);
		is_new_account = false;
		menu@ tut_menu = setup_sub_menu("Would you like to play a quick tutorial to learn the combat controls?");
		tut_menu.add_item("Yes, teach me how to play.");
		tut_menu.add_item("No, I already know how to play.");
		int tut_pick = tut_menu.run();
		if (tut_pick == 0) {
			tutorial_mode = true;
			tutorial_step = 0;
			// Create a tutorial room and start the game
			send({{"type", message_types::new_room}, {"name", "Tutorial"}, {"password", ""}, {"game_type", "sandbox"}});
			wait(500);
			network_loop();
			send({{"type", message_types::start_game}, {"mode", "wave"}, {"scenario", "tutorial"}, {"difficulty", "normal"}});
			// Wait for game to start
			timer tut_timer;
			while (!start_game_pending and tut_timer.elapsed < 5000) {
				wait(50);
				network_loop();
			}
			if (start_game_pending) {
				start_game_pending = false;
				set_active_character_profile("adventure");
				combat_game_loop();
			}
			tutorial_mode = false;
			// Leave the tutorial room
			send({{"type", message_types::leave_room}});
			wait(200);
			network_loop();
		}
	}
	while (true) {
		// Check if a trade was accepted and we need to open trade screen
		if (trade_active and !trade_pending) {
			show_trade_screen();
			continue;
		}
		if (room_closed_flag) { room_closed_flag = false; continue; }
		if (launch_pending_game_if_needed()) continue;
		string intro = "Main Menu.";
		if (cached_level > 0) intro += " Level " + cached_level + ".";
		int menu_gold = @cached_stats != null and cached_stats.exists("gold") ? int(cached_stats["gold"]) : 0;
		int menu_glory = @cached_stats != null and cached_stats.exists("glory") ? int(cached_stats["glory"]) : 0;
		if (menu_gold > 0 or menu_glory > 0) intro += " Gold: " + menu_gold + ". Glory: " + menu_glory + ".";
		menu@ m = setup_menu(intro);
		@m = main_screen;
		int play_btn = m.add_item("Play. 1 of 7");
		int char_btn = m.add_item("Character. 2 of 7");
		int social_btn = m.add_item("Social. 3 of 7");
		int shop_btn = m.add_item("Shop. 4 of 7");
		int challenges_btn = m.add_item("Challenges. 5 of 7");
		int settings_btn = m.add_item("Settings. 6 of 7");
		int quit_btn = m.add_item("Quit. 7 of 7");
		int res = m.run();
		if (res == play_btn) { show_play_menu(); }
		else if (res == char_btn) { show_character_menu(); }
		else if (res == social_btn) { show_social_menu(); }
		else if (res == shop_btn) { show_shop_menu(); }
		else if (res == challenges_btn) { show_challenges_menu(); }
		else if (res == settings_btn) { show_settings_menu(); }
		else if (res == quit_btn) {
			m.play("sounds/exit.wav");
			v.speak_wait("Thanks for playing.");
			return;
		}
	}
}

// ---- Sub-Menu: Play ----
void show_play_menu() {
	menu@ m = setup_sub_menu("Play. Choose a game mode.");
	m.add_item("Play Adventure. Create or join an adventure game with persistent progression. 1 of 2.");
	m.add_item("Play Sandbox Mode. Create or join a sandbox game with free-build characters. 2 of 2.");
	int pick = m.run();
	if (pick == 0) { show_adventure_play_menu(); }
	else if (pick == 1) { show_sandbox_play_menu(); }
}

void show_adventure_play_menu() {
	menu@ m = setup_sub_menu("Adventure Mode.");
	m.add_item("Create Game. Start a new adventure lobby. 1 of 2.");
	m.add_item("Join Game. Browse available lobbies. 2 of 2.");
	int pick = m.run();
	if (pick == 0) { create_lobby_for_mode("adventure"); }
	else if (pick == 1) { send({{"type", message_types::list_rooms}}); }
}

void show_sandbox_play_menu() {
	menu@ m = setup_sub_menu("Sandbox Mode.");
	m.add_item("Create Game. Start a new sandbox lobby. 1 of 2.");
	m.add_item("Join Game. Browse available lobbies. 2 of 2.");
	int pick = m.run();
	if (pick == 0) { create_lobby_for_mode("sandbox"); }
	else if (pick == 1) { send({{"type", message_types::list_rooms}}); }
}

// ---- Sub-Menu: Character ----
void show_character_menu() {
	while (true) {
		bool has_char = has_any_character_profile();
		bool show_prestige = (cached_level >= 20);
		int total = 3; // create, inventory, stats
		if (has_char) total++;
		if (show_prestige) total++;
		int n = 1;
		menu@ m = setup_sub_menu("Character.");
		int create_char = m.add_item("Create Character. " + n + " of " + total); n++;
		int view_char = -1;
		if (has_char) {
			view_char = m.add_item("View Character. " + n + " of " + total); n++;
		}
		int inventory_btn = m.add_item("Inventory. " + n + " of " + total); n++;
		int stats_btn = m.add_item("My Stats. " + n + " of " + total); n++;
		int prestige_btn = -1;
		if (show_prestige) {
			prestige_btn = m.add_item("Prestige. Reset to level 1 for permanent bonuses. " + n + " of " + total); n++;
		}
		int pick = m.run();
		if (pick < 0) return;
		if (pick == create_char) {
			menu@ profile_menu = setup_sub_menu("Choose which character profile to edit.");
			profile_menu.add_item("Adventure Character. Persistent progression. Uses your current Adventure level.");
			profile_menu.add_item("Sandbox Character. Free-build from level 1 through 20.");
			int profile_pick = profile_menu.run();
			if (profile_pick >= 0) {
				string profile = profile_pick == 0 ? "adventure" : "sandbox";
				int forced_level = profile == "adventure" ? cached_level : -1;
				character_creation_menu(profile, forced_level);
			}
		}
		else if (view_char >= 0 and pick == view_char) {
			string profile = "adventure";
			if (profile_has_character("adventure") and profile_has_character("sandbox")) {
				menu@ view_mode = setup_sub_menu("Choose which character list to view.");
				view_mode.add_item("Adventure Characters.");
				view_mode.add_item("Sandbox Characters.");
				int view_pick = view_mode.run();
				if (view_pick < 0) continue;
				profile = view_pick == 0 ? "adventure" : "sandbox";
			} else if (profile_has_character("sandbox") and !profile_has_character("adventure")) {
				profile = "sandbox";
			}
			show_character_list_menu(profile);
		}
		else if (pick == inventory_btn) {
			show_inventory();
		}
		else if (pick == stats_btn) {
			show_player_stats();
		}
		else if (prestige_btn >= 0 and pick == prestige_btn) {
			menu@ prestige_menu = setup_sub_menu("Prestige will reset your level to 1 but you keep your inventory, achievements, and dungeon completions. You gain plus 1 to all ability scores permanently and a unique title. This cannot be undone. Are you sure?");
			prestige_menu.add_item("Yes, prestige now.");
			prestige_menu.add_item("No, cancel.");
			int prestige_pick = prestige_menu.run();
			if (prestige_pick == 0) {
				send({{"type", message_types::prestige_action}});
				speak("Prestiging! Your level has been reset.", true);
			} else {
				speak("Prestige canceled.", false);
			}
		}
	}
}

