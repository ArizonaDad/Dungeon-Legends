// Client-side view of a combatant
class combat_entity {
	uint id;
	string name;
	bool is_player;
	int x;
	int y;
	int hp;
	int max_hp;
	int ac;
	int level;
	string class_name;
	string subclass;
	bool is_dead;
	bool is_stable;
	int initiative;
	string wild_shape_form;
	int[] conditions;

	combat_entity() {
		id = 0;
		is_player = false;
		x = 0;
		y = 0;
		hp = 0;
		max_hp = 0;
		ac = 0;
		level = 1;
		class_name = "";
		subclass = "";
		is_dead = false;
		is_stable = false;
		initiative = 0;
		wild_shape_form = "";
	}

	string health_status() {
		if (is_dead) return "dead";
		if (hp <= 0) return "unconscious";
		if (max_hp <= 0) return "unknown";
		int pct = (hp * 100) / max_hp;
		if (pct >= 90) return "full health";
		if (pct >= 60) return "healthy";
		if (pct >= 40) return "wounded";
		if (pct >= 20) return "badly wounded";
		return "critical";
	}

	bool has_condition(int cond_id) {
		for (uint i = 0; i < conditions.length(); i++) {
			if (conditions[i] == cond_id) return true;
		}
		return false;
	}
}

