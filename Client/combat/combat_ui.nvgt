void prompt_spell_choice(string text, string spell_id, string[]@ keys, string[]@ labels, string kind = "binary", int distribution_count = 0) {
	waiting_for_spell_choice_prompt = true;
	spell_choice_prompt_text = text;
	spell_choice_spell_id = spell_id;
	spell_choice_kind = kind;
	spell_choice_distribution_count = distribution_count;
	spell_choice_picks_collected.resize(0);
	spell_choice_option_keys.resize(0);
	spell_choice_option_labels.resize(0);
	if (@keys != null) {
		for (uint i = 0; i < keys.length(); i++) spell_choice_option_keys.insert_last(keys[i]);
	}
	if (@labels != null) {
		for (uint i = 0; i < labels.length(); i++) spell_choice_option_labels.insert_last(labels[i]);
	}
	next_spell_choice_reminder = ticks() + 4000;
	// For distribution prompts, also speak the option list so the player knows which key
	// maps to which target.
	speak(text, true);
	if (kind == "distribution" and spell_choice_option_labels.length() > 0) {
		string list_text = "Targets: ";
		for (uint i = 0; i < spell_choice_option_labels.length(); i++) {
			list_text += (i + 1) + " is " + spell_choice_option_labels[i];
			if (i < spell_choice_option_labels.length() - 1) list_text += ", ";
		}
		speak(list_text, false);
	}
}

bool check_roll_input() {
	if (!waiting_for_roll) return false;
	if (key_pressed(KEY_R) or key_pressed(KEY_RETURN)) {
		if (roll_target_player != "" and roll_target_player != username) {
			speak("It is not your turn to roll.", true);
			return false;
		}
		waiting_for_roll = false;
		next_roll_prompt_reminder = 0;
		roll_target_player = "";
		send({{"type", message_types::roll_result}, {"rolled", true}});
		speak("Rolling.", true);
		return true;
	}
	return false;
}

bool check_bardic_prompt_input() {
	if (!waiting_for_bardic_prompt) return false;
	if (key_pressed(KEY_RETURN) or key_pressed(KEY_R)) {
		waiting_for_bardic_prompt = false;
		next_bardic_prompt_reminder = 0;
		send({{"type", message_types::bardic_response}, {"use", true}});
		speak("Using Bardic Inspiration.", true);
		return true;
	}
	if (key_pressed(KEY_ESCAPE)) {
		waiting_for_bardic_prompt = false;
		next_bardic_prompt_reminder = 0;
		send({{"type", message_types::bardic_response}, {"use", false}});
		speak("Saving Bardic Inspiration.", true);
		return true;
	}
	return false;
}

