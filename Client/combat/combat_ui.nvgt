		speak("Dodge Roll.", true);
	}
	else if (blindfire_opt >= 0 and res == blindfire_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "blindfire"}});
		speak("Blindfire readied.", true);
	}
	else if (open_hand_opt >= 0 and res == open_hand_opt) {
		menu@ oh = setup_sub_menu("Choose Open Hand Technique effect:");
		oh.add_item("Knock Prone.");
		oh.add_item("Push target 15 feet.");
		oh.add_item("Prevent reactions until end of turn.");
		int ohr = oh.run();
		string effect = "prone";
		if (ohr == 1) effect = "push";
		else if (ohr == 2) effect = "no_reaction";
		if (current_target_id == 0) {
			speak("No target selected.", true);
			return;
		}
		send({{"type", message_types::bonus_action}, {"feature", "open_hand_technique"}, {"target_id", current_target_id}, {"effect", effect}});
		speak("Open Hand Technique: " + effect, true);
	}
	else if (mage_hand_legerdemain_opt >= 0 and res == mage_hand_legerdemain_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "mage_hand_legerdemain"}, {"target_id", current_target_id}});
		speak("Mage Hand Legerdemain commanded.", true);
	}
	else if (scout_skirmish_opt >= 0 and res == scout_skirmish_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "scout_skirmish"}});
		speak("Skirmisher movement.", true);
	}
	else if (unsettling_words_opt >= 0 and res == unsettling_words_opt) {
		if (current_target_id == 0) {
			speak("No target selected.", true);
			return;
		}
		send({{"type", message_types::bonus_action}, {"feature", "unsettling_words"}, {"target_id", current_target_id}});
		speak("Unsettling Words spoken.", true);
	}
	else if (orders_demand_opt >= 0 and res == orders_demand_opt) {
		if (current_target_id == 0) {
			speak("No target selected.", true);
			return;
		}
		send({{"type", message_types::bonus_action}, {"feature", "orders_demand"}, {"target_id", current_target_id}});
		speak("Order's Demand issued.", true);
	}
	else if (white_hat_protect_opt >= 0 and res == white_hat_protect_opt) {
		if (current_target_id == 0) {
			speak("Select an ally.", true);
			return;
		}
		send({{"type", message_types::bonus_action}, {"feature", "lay_down_the_law"}, {"target_id", current_target_id}});
		speak("Lay Down the Law.", true);
	}
	else if (focused_shot_opt >= 0 and res == focused_shot_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "focused_shot"}});
		speak("Focused Shot readied.", true);
	}
	else if (risky_business_opt >= 0 and res == risky_business_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "risky_business"}});
