}

bool check_smite_prompt_input() {
	if (!waiting_for_smite_prompt) return false;
	// Keys 1-5 select spell slot level
	for (int sl = 1; sl <= 5; sl++) {
		if (key_pressed(KEY_1 + sl - 1)) {
			waiting_for_smite_prompt = false;
			next_smite_prompt_reminder = 0;
			send({{"type", message_types::smite_response}, {"slot", sl}});
			speak("Divine Smite! Level " + sl + " slot.", true);
			return true;
		}
	}
	if (key_pressed(KEY_ESCAPE)) {
		waiting_for_smite_prompt = false;
		next_smite_prompt_reminder = 0;
		send({{"type", message_types::smite_response}, {"slot", 0}});
		speak("No smite.", true);
		return true;
	}
	// Reminder
	if (next_smite_prompt_reminder > 0 and ticks() >= next_smite_prompt_reminder) {
		speak(smite_prompt_text, true);
		next_smite_prompt_reminder = ticks() + 5000;
	}
	return false;
}

bool check_reaction_prompt_input() {
	if (!waiting_for_reaction_prompt) return false;
	// Parse options from CSV to build numbered choices
	string[] opts;
	string remaining = reaction_options_csv;
	while (remaining.length() > 0) {
		int comma = remaining.find(",");
		if (comma < 0) { opts.insert_last(remaining); remaining = ""; }
		else { opts.insert_last(remaining.substr(0, comma)); remaining = remaining.substr(comma + 1); }
	}
	// Keys 1-4 select a reaction option
	for (uint oi = 0; oi < opts.length() and oi < 4; oi++) {
		if (key_pressed(KEY_1 + oi)) {
			waiting_for_reaction_prompt = false;
			next_reaction_prompt_reminder = 0;
			send({{"type", message_types::reaction_response}, {"choice", opts[oi]}});
			string choice_name = opts[oi];
			if (choice_name == "shield") choice_name = "Shield";
			else if (choice_name == "cutting_words") choice_name = "Cutting Words";
			else if (choice_name == "warding_flare") choice_name = "Warding Flare";
			else if (choice_name == "defensive_duelist") choice_name = "Defensive Duelist";
			else if (choice_name == "restore_balance") choice_name = "Restore Balance";
			else if (choice_name == "spirit_shield") choice_name = "Spirit Shield";
			else if (choice_name == "entropic_ward") choice_name = "Entropic Ward";
			else if (choice_name == "arcane_deflection") choice_name = "Arcane Deflection";
			speak("Using " + choice_name + "!", true);
			return true;
		}
	}
	if (key_pressed(KEY_ESCAPE)) {
		waiting_for_reaction_prompt = false;
		next_reaction_prompt_reminder = 0;
		send({{"type", message_types::reaction_response}, {"choice", "none"}});
		speak("No reaction.", true);
		return true;
	}
	// Reminder
	if (next_reaction_prompt_reminder > 0 and ticks() >= next_reaction_prompt_reminder) {
		speak(reaction_prompt_text, true);
		next_reaction_prompt_reminder = ticks() + 5000;
	}
	return false;
}

void show_roll_result(int natural_roll, int total, string outcome) {
	string text = "Rolled " + natural_roll;
	if (natural_roll == 20) text = "Natural 20!";
	else if (natural_roll == 1) text = "Natural 1!";
	if (total != natural_roll) text += ", total " + total;
	text += ". " + outcome;
	if (natural_roll == 20 or natural_roll == 1) {
		sound@ cue = combat_audio_make_sweep(natural_roll == 20 ? 640.0f : 320.0f, natural_roll == 20 ? 1180.0f : 120.0f, natural_roll == 20 ? 260 : 320, -16.0f, 0.24f, 4.0f, 0.02f, 0.34f, 2.8f);
		if (@cue != null) {
			cue.spatialization_enabled = false;
			cue.play();
			combat_audio_track(cue);
		}
	}
	speak(text, true);
}

// ============================================================
// TURN ACTIONS MENU
// ============================================================

void show_action_menu() {
	if (!is_my_turn) {
		speak("It's not your turn.", true);
		return;
	}
	tutorial_check("action_menu");

	menu@ m = setup_sub_menu("Your turn. Choose an action.");
	combat_entity@ me = get_my_entity();
	string lc = current_class_name().lower();
	int level = current_character_level();
	string subclass = current_subclass_name();
	bool currently_wild_shaped = @me != null and me.wild_shape_form != "";
	string attack_label = "Attack. Strike a target with your weapon. Range " + my_weapon_range + " feet.";
	if (current_target_id > 0) {
		combat_entity@ action_target = get_entity(current_target_id);
		if (@me != null and @action_target != null) attack_label += " Current target " + action_target.name + ", " + describe_target_position(me, action_target) + ".";
	}
	int attack_opt = m.add_item(attack_label);
	int cast_opt = m.add_item("Cast a spell. Spell entries tell you casting time and concentration.");
	int dodge_opt = m.add_item("Dodge. Attacks against you have disadvantage.");
	int dash_opt = m.add_item("Dash. Double your movement this turn.");
	int disengage_opt = m.add_item("Disengage. Move without provoking opportunity attacks.");
	int help_opt = m.add_item("Help. Distract a nearby enemy so the next allied attack has advantage.");
	int hide_opt = m.add_item("Hide. Make a stealth check against enemy passive Perception.");
	int ready_opt = m.add_item("Ready attack. Spend your action to attack the selected target at the start of its next turn if it is in range.");
	int shove_opt = m.add_item("Shove. Push or knock prone a creature.");
	int grapple_opt = m.add_item("Grapple. Grab and restrain a creature.");
	// Class-specific actions
	int surge_opt = -1;
	int smite_opt = -1;
	int wild_shape_opt = -1;

	if (lc == "fighter") {
		if (my_action_surge_uses_remaining > 0) surge_opt = m.add_item("Action Surge. Gain another action this turn. Uses left: " + my_action_surge_uses_remaining + ".");
	}
	if (lc == "paladin") {
		smite_opt = m.add_item("Divine Smite. Spend spell slot for extra 2d8 radiant on next hit.");
	}
	if (lc == "druid" and level >= 2) {
		if (!currently_wild_shaped and subclass != "Circle of the Moon") wild_shape_opt = m.add_item("Wild Shape. Action. Transform into a beast.");
	}

	int end_opt = m.add_item("End turn.");
	int status_opt = m.add_item("Check status. Hear your current stats.");

	int res = m.run();

	if (res == attack_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
		combat_entity@ atk_target = get_entity(current_target_id);
		if (@atk_target != null) {
			combat_entity@ atk_me = get_entity(my_combatant_id);
			int atk_dist = 0;
			if (@atk_me != null) atk_dist = feet_distance(atk_me.x, atk_me.y, atk_target.x, atk_target.y);
			speak("Attacking " + atk_target.name + ", " + atk_dist + " feet away.", false);
		}
		send({{"type", message_types::action_attack}, {"target_id", current_target_id}});
	} else if (res == cast_opt) {
		show_spell_menu();
	} else if (res == dodge_opt) {
		send({{"type", message_types::action_dodge}});
		speak("You take the Dodge action. Attacks against you have disadvantage until your next turn.", true);
	} else if (res == dash_opt) {
		send({{"type", message_types::action_dash}});
		speak("You take the Dash action. Your movement is doubled.", true);
	} else if (res == disengage_opt) {
		send({{"type", message_types::action_disengage}});
		speak("You take the Disengage action. You can move without provoking opportunity attacks.", true);
	} else if (res == help_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
		send({{"type", message_types::action_help}, {"target_id", current_target_id}});
		speak("You distract the selected enemy for the next allied attack.", true);
	} else if (res == hide_opt) {
		send({{"type", message_types::action_hide}});
	} else if (res == ready_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
		combat_entity@ ready_target = get_entity(current_target_id);
		string ready_name = @ready_target != null ? ready_target.name : "that target";
		speak("You ready an attack against " + ready_name + ".", true);
		send({{"type", message_types::action_ready}, {"target_id", current_target_id}});
	} else if (res == shove_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
		send({{"type", message_types::action_shove}, {"target_id", current_target_id}});
	} else if (res == grapple_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
		send({{"type", message_types::action_grapple}, {"target_id", current_target_id}});
	} else if (res == end_opt) {
		send({{"type", message_types::turn_end}});
		speak("Turn ended.", true);
		is_my_turn = false;
	} else if (res == status_opt) {
		speak_my_status();
	}
	// Class feature handlers
	if (surge_opt >= 0 and res == surge_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "action_surge"}});
		speak("Action Surge! You gain an additional action.", true);
	}
	else if (wild_shape_opt >= 0 and res == wild_shape_opt) {
		show_wild_shape_menu(currently_wild_shaped);
	}
	else if (smite_opt >= 0 and res == smite_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "divine_smite"}});
		speak("Divine Smite prepared. Your next melee hit deals extra 2d8 radiant.", true);
	}
}

void show_bonus_action_menu() {
	if (!is_my_turn) {
		speak("It's not your turn.", true);
		return;
	}
	if (!my_has_bonus_action) {
		speak("No bonus action remaining.", true);
		return;
	}

	combat_entity@ me = get_my_entity();
	string lc = current_class_name().lower();
	int level = current_character_level();
	string subclass = current_subclass_name();
	bool currently_wild_shaped = @me != null and me.wild_shape_form != "";

	menu@ m = setup_sub_menu("Choose a bonus action.");
	int spell_opt = m.add_item("Cast a spell. Useful for bonus action spells such as Healing Word or Misty Step.");
	int rage_opt = -1;
	int second_wind_opt = -1;
	int cunning_opt = -1;
	int lay_hands_opt = -1;
	int flurry_opt = -1;
	int bardic_opt = -1;
	int wild_shape_opt = -1;
	int spiritual_weapon_opt = -1;
	// Subclass bonus action options
	int trip_opt = -1;
	int precision_opt = -1;
	int riposte_opt = -1;
	int psi_opt = -1;
	int frenzy_opt = -1;
	int psychic_blade_opt = -1;
	int sacred_opt = -1;
	int vow_opt = -1;
	int inspire_opt = -1;
	int nature_opt = -1;
	int preserve_opt = -1;
	int war_priest_opt = -1;
	int shadow_opt = -1;
	int mercy_opt = -1;
	int element_opt = -1;
	int heal_light_opt = -1;
	int fey_opt = -1;
	int mantle_opt = -1;
	int planar_warrior_opt = -1;
	int path_to_grave_opt = -1;
	int hexblades_curse_opt = -1;
	int fighting_spirit_opt = -1;
	int symbiotic_entity_opt = -1;
	int blade_flourish_opt = -1;
	int psychic_blades_bard_opt = -1;
	int cavalier_mark_opt = -1;
	int balm_summer_opt = -1;
	int guided_strike_opt = -1;
	int giants_might_opt = -1;
	int empowered_healing_opt = -1;
	int emboldening_bond_opt = -1;
	int twilight_sanctuary_opt = -1;
	int arcane_shot_opt = -1;
	int abjure_extraplanar_opt = -1;
	int insightful_fighting_opt = -1;
	int mastermind_help_opt = -1;
	int fast_hands_opt = -1;
	int sun_bolt_opt = -1;
	int kensei_weapon_opt = -1;
	int breath_dragon_opt = -1;
	int astral_arms_opt = -1;
	int tentacle_opt = -1;
	int genie_vessel_opt = -1;
	int form_of_dread_opt = -1;
	int starry_form_opt = -1;
	int wildfire_opt = -1;
	int echo_manifest_opt = -1;
	int rebuke_violent_opt = -1;
	int eldritch_cannon_opt = -1;
	int cannon_fire_opt = -1;
	int steel_defender_opt = -1;
	int experimental_elixir_opt = -1;
	int primal_companion_opt = -1;
	int drake_attack_opt = -1;
	int slayers_prey_opt = -1;
	int swarmkeeper_opt = -1;
	int chronal_shift_opt = -1;
	int critical_shot_opt = -1;
	int gut_shot_opt = -1;
	int dodge_roll_opt = -1;
	int blindfire_opt = -1;
	int open_hand_opt = -1;
	int mage_hand_legerdemain_opt = -1;
	int scout_skirmish_opt = -1;
	int unsettling_words_opt = -1;
	int orders_demand_opt = -1;
	int deadeye_stance_opt = -1;
	int liars_dice_opt = -1;
	int license_to_kill_opt = -1;
	int trick_shot_ricochet_opt = -1;
	int white_hat_protect_opt = -1;
	int jinx_target_opt = -1;
	int rune_tag_opt = -1;
	int blade_breaker_stance_opt = -1;
	int festus_blessing_opt = -1;
	int polearm_master_attack_opt = -1;
	int shield_master_shove_opt = -1;

	if (lc == "barbarian" and !my_is_raging and my_rage_uses_remaining > 0) rage_opt = m.add_item("Rage. Bonus action. Uses left: " + my_rage_uses_remaining + ". Damage bonus: " + my_rage_damage_bonus + ".");
	if (lc == "fighter" and my_second_wind_available) second_wind_opt = m.add_item("Second Wind. Bonus action. Heal 1d10 plus fighter level.");
	if (lc == "rogue" and level >= 2) cunning_opt = m.add_item("Cunning Action. Bonus action. Dash, Disengage, or Hide.");
	if (lc == "paladin" and my_lay_on_hands_pool > 0) lay_hands_opt = m.add_item("Lay on Hands. Bonus action. Pool: " + my_lay_on_hands_pool + ".");
	if (lc == "monk" and level >= 2) flurry_opt = m.add_item("Flurry of Blows. 1 Focus Point. Focus Points: " + my_focus_points + ".");
	if (lc == "bard" and my_bardic_inspiration_uses > 0) bardic_opt = m.add_item("Bardic Inspiration. Bonus action. Uses left: " + my_bardic_inspiration_uses + ".");
	if (lc == "druid" and level >= 2 and (currently_wild_shaped or subclass == "Circle of the Moon")) {
		if (currently_wild_shaped) wild_shape_opt = m.add_item("Wild Shape. Revert or choose a new beast form.");
		else wild_shape_opt = m.add_item("Wild Shape. Bonus action. Transform into a beast.");
	}
	if (my_spiritual_weapon_active) spiritual_weapon_opt = m.add_item("Spiritual Weapon. Strike a target within 60 feet with your summoned weapon.");

	// Subclass-specific bonus actions
	if (lc == "fighter") {
		if (subclass == "Battle Master") {
			trip_opt = m.add_item("Trip Attack. Use a superiority die. Your next hit knocks the target prone.");
			precision_opt = m.add_item("Precision Attack. Add a d8 to your next attack roll.");
			riposte_opt = m.add_item("Riposte. Ready a reaction attack when an enemy misses you.");
		}
		// Psi Warrior Strike auto-triggers on hit; no menu option needed.
	}
	if (lc == "barbarian") {
		if (subclass == "Berserker" and my_is_raging) {
			frenzy_opt = m.add_item("Frenzy Attack. Bonus action melee attack while raging.");
		}
	}
	if (lc == "rogue") {
		if (subclass == "Soulknife") {
			psychic_blade_opt = m.add_item("Psychic Blades. Bonus action. Strike with a psychic blade for 1d4 psychic damage.");
		}
	}
	if (lc == "paladin") {
		if (subclass == "Oath of Devotion") {
			sacred_opt = m.add_item("Sacred Weapon. Channel Divinity. Add Charisma to attack rolls for the battle.");
		}
		if (subclass == "Oath of Vengeance") {
			vow_opt = m.add_item("Vow of Enmity. Channel Divinity. Gain advantage on attacks against your target.");
		}
		if (subclass == "Oath of Glory") {
			inspire_opt = m.add_item("Inspiring Smite. After your next Divine Smite, grant temporary HP to nearby allies.");
		}
		if (subclass == "Oath of Ancients") {
			nature_opt = m.add_item("Nature's Wrath. Channel Divinity. Restrain a target. Strength or Dexterity save.");
		}
	}
	if (lc == "cleric") {
		if (subclass == "Life Domain") {
			preserve_opt = m.add_item("Preserve Life. Channel Divinity. Heal allies below half health.");
		}
		if (subclass == "War Domain") {
			war_priest_opt = m.add_item("War Priest. Bonus action weapon attack.");
		}
	}
	if (lc == "monk") {
		if (subclass == "Warrior of Shadow") {
			shadow_opt = m.add_item("Shadow Step. Bonus action. Teleport up to 60 feet.");
		}
		if (subclass == "Warrior of Mercy") {
			mercy_opt = m.add_item("Hands of Healing. 1 Focus Point. Heal a target for 1d6 plus Wisdom.");
		}
		if (subclass == "Warrior of the Elements") {
			element_opt = m.add_item("Elemental Burst. Spend Focus Points for 1d6 elemental damage per point.");
		}
	}
	if (lc == "warlock") {
		if (subclass == "Celestial Patron") {
			heal_light_opt = m.add_item("Healing Light. Bonus action. Heal a target using d6 dice from your pool.");
		}
		if (subclass == "Archfey Patron") {
			fey_opt = m.add_item("Fey Presence. Charm or frighten nearby creatures. Wisdom save.");
		}
	}
	if (lc == "bard") {
		if (subclass == "College of Glamour") {
			mantle_opt = m.add_item("Mantle of Inspiration. Grant temporary HP to all allies.");
		}
	}
	// New Xanathar's/Tasha's subclass bonus actions
	if (lc == "ranger" and subclass == "Horizon Walker") {
		planar_warrior_opt = m.add_item("Planar Warrior. Bonus action. Next weapon attack deals bonus force damage.");
	}
	if (lc == "cleric" and subclass == "Grave Domain") {
		path_to_grave_opt = m.add_item("Path to the Grave. Channel Divinity. Curse a target for bonus damage on next hit.");
	}
	if (lc == "warlock" and subclass == "The Hexblade") {
		hexblades_curse_opt = m.add_item("Hexblade's Curse. Bonus action. Mark a target for +Prof damage and expanded crits.");
	}
	if (lc == "fighter" and subclass == "Samurai") {
		fighting_spirit_opt = m.add_item("Fighting Spirit. Bonus action. Advantage on attacks + temp HP.");
	}
	if (lc == "druid" and subclass == "Circle of Spores") {
		symbiotic_entity_opt = m.add_item("Symbiotic Entity. Action. Gain temp HP and +1d6 necrotic on melee attacks.");
	}
	if (lc == "bard" and subclass == "College of Swords") {
		blade_flourish_opt = m.add_item("Blade Flourish. Bonus action. Next weapon attack gets bonus damage.");
	}
	if (lc == "bard" and subclass == "College of Whispers") {
		psychic_blades_bard_opt = m.add_item("Psychic Blades. Bonus action. Next weapon attack deals bonus psychic damage.");
	}
	if (lc == "fighter" and subclass == "Cavalier") {
		cavalier_mark_opt = m.add_item("Cavalier Mark. Bonus action. Mark a target for extra damage.");
	}
	if (lc == "druid" and subclass == "Circle of Dreams") {
		balm_summer_opt = m.add_item("Balm of the Summer Court. Bonus action. Heal a target from your pool.");
	}
	if (lc == "paladin" and subclass == "Oath of Conquest") {
		guided_strike_opt = m.add_item("Guided Strike. Channel Divinity. Add +10 to next attack roll.");
	}
	if (lc == "fighter" and subclass == "Rune Knight") {
		giants_might_opt = m.add_item("Giant's Might. Bonus action. Become Large with +1d6 damage.");
	}
	if (lc == "sorcerer" and subclass == "Divine Soul") {
		empowered_healing_opt = m.add_item("Empowered Healing. Reroll dice on next healing spell.");
	}
	if (lc == "cleric" and subclass == "Peace Domain") {
		emboldening_bond_opt = m.add_item("Emboldening Bond. Channel Divinity. Bond allies for bonus d4 on rolls.");
	}
	if (lc == "cleric" and subclass == "Twilight Domain") {
		twilight_sanctuary_opt = m.add_item("Twilight Sanctuary. Channel Divinity. Grant nearby allies temp HP each round.");
	}
	if (lc == "fighter" and subclass == "Arcane Archer") {
		arcane_shot_opt = m.add_item("Arcane Shot. Apply a magical effect to your next ranged attack.");
	}
	if (lc == "paladin" and subclass == "Oath of the Watchers") {
		abjure_extraplanar_opt = m.add_item("Abjure the Extraplanar. Channel Divinity. Frighten aberrations, fey, fiends, and celestials.");
	}
	if (lc == "rogue" and subclass == "Inquisitive") {
		insightful_fighting_opt = m.add_item("Insightful Fighting. Study a target to enable Sneak Attack without advantage.");
	}
	if (lc == "rogue" and subclass == "Mastermind") {
		mastermind_help_opt = m.add_item("Mastermind Help. Help an ally at 30 feet as a bonus action.");
	}
	if (lc == "rogue" and subclass == "Thief" and level >= 3) {
		fast_hands_opt = m.add_item("Fast Hands. Bonus action to use an object.");
	}
	if (lc == "monk" and subclass == "Way of the Sun Soul") {
		sun_bolt_opt = m.add_item("Radiant Sun Bolt. Bonus action ranged attack for radiant damage.");
	}
	if (lc == "monk" and subclass == "Way of the Kensei") {
		kensei_weapon_opt = m.add_item("Kensei Weapon. Choose your kensei weapon for this battle.");
	}
	if (lc == "monk" and subclass == "Way of the Ascendant Dragon") {
		breath_dragon_opt = m.add_item("Breath of the Dragon. Action + 1 Focus Point. 15ft cone of fire damage.");
	}
	if (lc == "monk" and subclass == "Way of the Astral Self") {
		astral_arms_opt = m.add_item("Astral Arms. Bonus action + 1 Focus Point. Extended reach unarmed strikes.");
	}
	if (lc == "warlock" and subclass == "The Fathomless") {
		tentacle_opt = m.add_item("Tentacle of the Deeps. Bonus action. Cold damage strike that slows target.");
	}
	if (lc == "warlock" and subclass == "The Genie") {
		genie_vessel_opt = m.add_item("Genie's Vessel. Bonus action. Retreat into vessel for temp HP.");
	}
	if (lc == "warlock" and subclass == "The Undead") {
		form_of_dread_opt = m.add_item("Form of Dread. Bonus action. Transform into undead visage for temp HP and fear.");
	}
	if (lc == "druid" and subclass == "Circle of the Stars") {
		starry_form_opt = m.add_item("Starry Form. Bonus action. Assume Chalice, Archer, or Dragon form.");
	}
	if (lc == "druid" and subclass == "Circle of Wildfire") {
		wildfire_opt = m.add_item("Wildfire Spirit. Action. Summon a wildfire spirit companion.");
	}
	if (lc == "fighter" and subclass == "Echo Knight") {
		echo_manifest_opt = m.add_item("Manifest Echo. Bonus action. Summon an echo from an alternate timeline.");
	}
	if (lc == "paladin" and subclass == "Oath of Redemption") {
		rebuke_violent_opt = m.add_item("Rebuke the Violent. Channel Divinity. Reaction damage reflection.");
	}
	if (lc == "artificer" and subclass == "Artillerist") {
		eldritch_cannon_opt = m.add_item("Eldritch Cannon. Action. Create an arcane cannon.");
		cannon_fire_opt = m.add_item("Command Cannon to Fire. Bonus action. Flamethrower attack.");
	}
	if (lc == "artificer" and subclass == "Battle Smith") {
		steel_defender_opt = m.add_item("Steel Defender Attack. Bonus action. Command your defender to strike.");
	}
	if (lc == "artificer" and subclass == "Alchemist") {
		experimental_elixir_opt = m.add_item("Experimental Elixir. Bonus action. Create a random elixir effect.");
	}
	if (lc == "ranger" and subclass == "Beast Master") {
		primal_companion_opt = m.add_item("Primal Companion Attack. Bonus action. Command your animal companion.");
	}
	if (lc == "ranger" and subclass == "Drakewarden") {
		drake_attack_opt = m.add_item("Drake Breath. Bonus action. Drake companion breathes fire at target.");
	}
	if (lc == "ranger" and subclass == "Monster Slayer") {
		slayers_prey_opt = m.add_item("Slayer's Prey. Bonus action. Mark a target for bonus damage.");
	}
	if (lc == "ranger" and subclass == "Swarmkeeper") {
		swarmkeeper_opt = m.add_item("Gathered Swarm. Bonus action. Command swarm for bonus force damage.");
	}
	if (lc == "wizard" and subclass == "Chronurgy Magic") {
		chronal_shift_opt = m.add_item("Chronal Shift. Force a roll to be rerolled.");
	}
	if (lc == "monk" and subclass == "Warrior of the Open Hand") {
		open_hand_opt = m.add_item("Open Hand Technique. Use on Flurry hit to push, knock prone, or prevent reactions.");
	}
	if (lc == "rogue" and subclass == "Arcane Trickster") {
		mage_hand_legerdemain_opt = m.add_item("Mage Hand Legerdemain. Bonus action. Command an invisible Mage Hand.");
	}
	if (lc == "rogue" and subclass == "Scout") {
		scout_skirmish_opt = m.add_item("Skirmisher. Reaction. Move half speed when enemy ends turn near you.");
	}
	if (lc == "bard" and subclass == "College of Eloquence" and level >= 3) {
		unsettling_words_opt = m.add_item("Unsettling Words. Bonus action. Spend Bardic Inspiration to subtract die roll from target's next save.");
	}
	if (lc == "cleric" and subclass == "Order Domain") {
		orders_demand_opt = m.add_item("Order's Demand. Bonus action. Channel Divinity to charm a target.");
	}
	// Gunslinger subclass features
	if (lc == "gunslinger" and subclass == "Deadeye" and level >= 3) {
		deadeye_stance_opt = m.add_item("Sharpshooter's Stance. Bonus action. Toggle precise stance.");
	}
	if (lc == "gunslinger" and subclass == "High Roller" and level >= 3) {
		liars_dice_opt = m.add_item("Liar's Dice. Bonus action. Gamble for temp HP and damage bonus.");
	}
	if (lc == "gunslinger" and subclass == "Secret Agent" and level >= 3) {
		license_to_kill_opt = m.add_item("License to Kill. Bonus action. Mark a target for bonus damage on first hit.");
	}
	if (lc == "gunslinger" and subclass == "Trick Shot" and level >= 3) {
		trick_shot_ricochet_opt = m.add_item("Ricochet. Bonus action. Prepare a bullet that bounces to a second target.");
	}
	if (lc == "gunslinger" and subclass == "White Hat" and level >= 3) {
		white_hat_protect_opt = m.add_item("Protect Ally. Bonus action. Stand ready to take a hit for an ally.");
	}
	// Setting subclass bonus actions
	if (lc == "rogue" and subclass == "Misfortune Bringer" and level >= 3) {
		jinx_target_opt = m.add_item("Jinx Target. Bonus action. Curse target with bonus damage on next hits.");
	}
	if (lc == "rogue" and subclass == "Runetagger" and level >= 3) {
		rune_tag_opt = m.add_item("Rune Tag. Bonus action. Mark target with magical rune for force damage.");
	}
	if (lc == "fighter" and subclass == "Blade Breaker" and level >= 3) {
		blade_breaker_stance_opt = m.add_item("Blade Breaker Stance. Bonus action. Toggle armor-crushing stance.");
	}
	if (lc == "cleric" and subclass == "Festus Domain" and level >= 1) {
		festus_blessing_opt = m.add_item("Festus Blessing. Bonus action. Channel Divinity to heal nearby allies.");
	}
	// Feat-based bonus actions (server validates feat ownership)
	polearm_master_attack_opt = m.add_item("Polearm Master Attack. Bonus action. Strike with the polearm butt for 1d4. (Requires Polearm Master feat)");
	shield_master_shove_opt = m.add_item("Shield Master Shove. Bonus action. Shove a target prone with your shield. (Requires Shield Master feat)");
	// Gunslinger class features
	if (lc == "gunslinger") {
		if (level >= 2) {
			critical_shot_opt = m.add_item("Critical Shot. Add bonus damage dice to your next weapon attack.");
		}
		if (level >= 5) {
			gut_shot_opt = m.add_item("Gut Shot. Spend a Risk Die for bonus damage on next attack.");
		}
		dodge_roll_opt = m.add_item("Dodge Roll. Bonus action. Spend a Risk Die to Dodge.");
		blindfire_opt = m.add_item("Blindfire. Spend a Risk Die to ignore disadvantage on next ranged attack.");
	}

	int options = 1;
	if (rage_opt >= 0) options++;
	if (second_wind_opt >= 0) options++;
	if (cunning_opt >= 0) options++;
	if (lay_hands_opt >= 0) options++;
	if (flurry_opt >= 0) options++;
	if (bardic_opt >= 0) options++;
	if (wild_shape_opt >= 0) options++;
	if (spiritual_weapon_opt >= 0) options++;
	if (trip_opt >= 0) options++;
	if (precision_opt >= 0) options++;
	if (riposte_opt >= 0) options++;
	if (frenzy_opt >= 0) options++;
	if (psychic_blade_opt >= 0) options++;
	if (sacred_opt >= 0) options++;
	if (vow_opt >= 0) options++;
	if (inspire_opt >= 0) options++;
	if (nature_opt >= 0) options++;
	if (preserve_opt >= 0) options++;
	if (war_priest_opt >= 0) options++;
	if (shadow_opt >= 0) options++;
	if (mercy_opt >= 0) options++;
	if (element_opt >= 0) options++;
	if (heal_light_opt >= 0) options++;
	if (fey_opt >= 0) options++;
	if (mantle_opt >= 0) options++;
	if (options == 1) {
		speak("No class bonus actions are available right now. You can still use a bonus action spell if you know one.", true);
	}

	int res = m.run();
	if (res == spell_opt) {
		show_spell_menu();
	}
	else if (rage_opt >= 0 and res == rage_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "rage"}});
	}
	else if (second_wind_opt >= 0 and res == second_wind_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "second_wind"}});
	}
	else if (cunning_opt >= 0 and res == cunning_opt) {
		menu@ cm = setup_sub_menu("Cunning Action. Choose:");
		cm.add_item("Dash. Double movement.");
		cm.add_item("Disengage. No opportunity attacks.");
		cm.add_item("Hide. Make stealth check.");
		int cp = cm.run();
		string action = "dash";
		if (cp == 1) action = "disengage";
		else if (cp == 2) action = "hide";
		send({{"type", message_types::bonus_action}, {"feature", "cunning_action"}, {"action", action}});
	}
	else if (lay_hands_opt >= 0 and res == lay_hands_opt) {
		use_lay_on_hands();
	}
	else if (flurry_opt >= 0 and res == flurry_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "flurry_of_blows"}, {"target_id", current_target_id}});
	}
	else if (bardic_opt >= 0 and res == bardic_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "bardic_inspiration"}, {"target_id", current_target_id}});
	}
	else if (wild_shape_opt >= 0 and res == wild_shape_opt) {
		show_wild_shape_menu(currently_wild_shaped);
	}
	else if (spiritual_weapon_opt >= 0 and res == spiritual_weapon_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
		send({{"type", message_types::bonus_action}, {"feature", "spiritual_weapon_attack"}, {"target_id", current_target_id}});
	}
	// Subclass bonus action handlers
	else if (trip_opt >= 0 and res == trip_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "trip_attack"}});
		speak("Trip Attack prepared. Your next hit knocks the target prone.", true);
	}
	else if (precision_opt >= 0 and res == precision_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "precision_attack"}});
		speak("Precision Attack. A d8 is added to your next attack roll.", true);
	}
	else if (riposte_opt >= 0 and res == riposte_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "riposte"}});
		speak("Riposte readied. You will counterattack when an enemy misses you.", true);
	}
	else if (frenzy_opt >= 0 and res == frenzy_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
		send({{"type", message_types::bonus_action}, {"feature", "frenzy_attack"}, {"target_id", current_target_id}});
		speak("Frenzy Attack! Bonus action melee strike.", true);
	}
	else if (psychic_blade_opt >= 0 and res == psychic_blade_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
		send({{"type", message_types::bonus_action}, {"feature", "psychic_blades"}, {"target_id", current_target_id}});
		speak("Psychic Blades. Striking with a psychic blade.", true);
	}
	else if (sacred_opt >= 0 and res == sacred_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "channel_sacred_weapon"}});
		speak("Sacred Weapon. Charisma added to your attack rolls.", true);
	}
	else if (vow_opt >= 0 and res == vow_opt) {
		if (current_target_id == 0) {
			speak("No target selected. Scan with I J K L and press Enter to lock a target.", true);
			return;
		}
