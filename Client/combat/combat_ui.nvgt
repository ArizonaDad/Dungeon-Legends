bool check_roll_input() {
	if (!waiting_for_roll) return false;
	if (key_pressed(KEY_R) or key_pressed(KEY_RETURN)) {
		if (roll_target_player != "" and roll_target_player != username) {
			speak("It is not your turn to roll.", true);
			return false;
		}
		waiting_for_roll = false;
		next_roll_prompt_reminder = 0;
		roll_target_player = "";
		send({{"type", message_types::roll_result}, {"rolled", true}});
		speak("Rolling.", true);
		return true;
	}
	return false;
}

bool check_bardic_prompt_input() {
	if (!waiting_for_bardic_prompt) return false;
	if (key_pressed(KEY_RETURN) or key_pressed(KEY_R)) {
		waiting_for_bardic_prompt = false;
		next_bardic_prompt_reminder = 0;
		send({{"type", message_types::bardic_response}, {"use", true}});
		speak("Using Bardic Inspiration.", true);
		return true;
	}
	if (key_pressed(KEY_ESCAPE)) {
		waiting_for_bardic_prompt = false;
		next_bardic_prompt_reminder = 0;
		send({{"type", message_types::bardic_response}, {"use", false}});
		speak("Saving Bardic Inspiration.", true);
		return true;
	}
	return false;
}

bool check_lucky_prompt_input() {
	if (!waiting_for_lucky_prompt) return false;
	if (key_pressed(KEY_L)) {
		waiting_for_lucky_prompt = false;
