	// PHB 2024 Warlock L2 Magical Cunning / L9 Contact Patron / L11+ Mystic Arcanum
	int magical_cunning_opt = -1;
	int contact_patron_opt = -1;
	int mystic_arcanum_opt = -1;

	if (lc == "barbarian" and !my_is_raging and my_rage_uses_remaining > 0) rage_opt = m.add_item("Rage. Bonus action. Uses left: " + my_rage_uses_remaining + ". Damage bonus: " + my_rage_damage_bonus + ".");
	if (lc == "fighter" and my_second_wind_uses_remaining > 0) second_wind_opt = m.add_item("Second Wind. Bonus action. Heal 1d10 plus fighter level. Uses left: " + my_second_wind_uses_remaining + " of " + my_second_wind_uses_max + ".");
	if (lc == "rogue" and level >= 2) cunning_opt = m.add_item("Cunning Action. Bonus action. Dash, Disengage, or Hide.");
	// PHB 2024 Rogue L3 Steady Aim (para 6550-6551): "As a Bonus Action, you give yourself
	// Advantage on your next attack roll on the current turn... You can use this Bonus Action
	// only if your Speed is 0 on this turn... your Speed is 0 until the end of the current turn."
	if (lc == "rogue" and level >= 3 and my_movement_remaining >= my_speed) steady_aim_opt = m.add_item("Steady Aim. Bonus action. Gain Advantage on your next attack this turn, but your Speed is 0 until end of turn.");
	// PHB 2024 Sorcerer L1 Innate Sorcery (para 6963-6967)
	if (lc == "sorcerer" and !my_innate_sorcery_active and (my_innate_sorcery_uses_remaining > 0 or (level >= 7 and my_sorcery_points >= 2))) {
		string label = "Innate Sorcery. Bonus action. Spell save DC plus 1 and Advantage on Sorcerer spell attacks for 1 minute. Uses left: " + my_innate_sorcery_uses_remaining + ".";
		if (my_innate_sorcery_uses_remaining == 0 and level >= 7) label += " Sorcery Incarnate: spend 2 Sorcery Points to use it anyway. Sorcery Points: " + my_sorcery_points + ".";
		innate_sorcery_opt = m.add_item(label);
	}
	// PHB 2024 Sorcerer L2 Font of Magic (para 6968-6993)
	if (lc == "sorcerer" and level >= 2 and my_sorcery_points >= 2) {
		font_of_magic_to_slot_opt = m.add_item("Font of Magic: convert Sorcery Points to a spell slot. Sorcery Points: " + my_sorcery_points + " of " + my_sorcery_points_max + ".");
	}
	if (lc == "sorcerer" and level >= 2 and my_sorcery_points < my_sorcery_points_max) {
		font_of_magic_to_sp_opt = m.add_item("Font of Magic: convert a spell slot to Sorcery Points. Sorcery Points: " + my_sorcery_points + " of " + my_sorcery_points_max + ".");
	}
	if (lc == "sorcerer" and level >= 2 and my_sorcery_points >= 1) {
		metamagic_opt = m.add_item("Metamagic: modify your next spell. Sorcery Points: " + my_sorcery_points + " of " + my_sorcery_points_max + ".");
	}
	// PHB 2024 Sorcerer Draconic Sorcery L14 Dragon Wings (paras 7561-7563): Bonus action,
	// dragon wings sprout, fly speed 60 ft for 1 hour. 1/Long Rest, or 3 Sorcery Points to refresh.
	if (lc == "sorcerer" and subclass == "Draconic Sorcery" and level >= 14 and !my_dragon_wings_active and !my_dragon_wings_used_this_rest) {
		dragon_wings_opt = m.add_item("Dragon Wings. Bonus action. Fly 60 feet for 1 hour. 1 per long rest.");
	}
	if (lc == "sorcerer" and subclass == "Draconic Sorcery" and level >= 14 and my_dragon_wings_used_this_rest and my_sorcery_points >= 3) {
		dragon_wings_restore_opt = m.add_item("Restore Dragon Wings. Spend 3 Sorcery Points. Sorcery Points: " + my_sorcery_points + ".");
	}
	// PHB 2024 Sorcerer Draconic Sorcery L18 Dragon Companion (paras 7564-7566): cast
	// Summon Dragon without a slot or material components. 1/Long Rest.
	if (lc == "sorcerer" and subclass == "Draconic Sorcery" and level >= 18 and !my_dragon_companion_used_this_rest) {
		summon_dragon_free_opt = m.add_item("Dragon Companion: cast Summon Dragon without a slot. 1 per long rest.");
	}
	// Xanathar's Divine Soul L14 Otherworldly Wings (para 2551-2553)
	if (lc == "sorcerer" and subclass == "Divine Soul" and level >= 14) {
		string wings_label = my_otherworldly_wings_active ? "Dismiss Otherworldly Wings. Bonus action." : "Otherworldly Wings. Bonus action. Fly 30 feet (permanent until dismissed).";
		otherworldly_wings_opt = m.add_item(wings_label);
	}
	// Xanathar's Divine Soul L18 Unearthly Recovery (para 2554-2556)
	if (lc == "sorcerer" and subclass == "Divine Soul" and level >= 18 and my_unearthly_recovery_available) {
		unearthly_recovery_opt = m.add_item("Unearthly Recovery. Bonus action. Below half HP: regain half max HP. 1 per long rest.");
	}
	// Xanathar's Shadow Magic L6 Hound of Ill Omen (para 2596-2602)
	if (lc == "sorcerer" and subclass == "Shadow Magic" and level >= 6) {
		hound_of_ill_omen_opt = m.add_item("Hound of Ill Omen. Bonus action. 3 SP: summon a shadow hound to stalk a target.");
	}
	// Xanathar's Shadow Magic L14 Shadow Walk (para 2603-2604)
	if (lc == "sorcerer" and subclass == "Shadow Magic" and level >= 14) {
		shadow_walk_opt = m.add_item("Shadow Walk. Bonus action. Teleport up to 120 feet (dim light/darkness).");
	}
	// Xanathar's Shadow Magic L18 Umbral Form (para 2605-2607)
	if (lc == "sorcerer" and subclass == "Shadow Magic" and level >= 18) {
		string umbral_label = my_shadow_umbral_active ? "Dismiss Umbral Form. Bonus action." : "Umbral Form. Bonus action. 6 SP: resistance to all except force/radiant for 1 minute.";
		shadow_umbral_form_opt = m.add_item(umbral_label);
	}
	// Tasha's Aberrant Mind L14 Revelation in Flesh (para 3942-3948)
	if (lc == "sorcerer" and subclass == "Aberrant Sorcery" and level >= 14) {
		revelation_in_flesh_opt = m.add_item("Revelation in Flesh. Bonus action. 1+ SP: see invisible 60ft, or fly speed = walk speed, or both (2 SP).");
	}
	// Tasha's Aberrant Mind L18 Warping Implosion (para 3949-3952)
	if (lc == "sorcerer" and subclass == "Aberrant Sorcery" and level >= 18) {
		string wi_label = my_warping_implosion_available ? "Warping Implosion. Action. Teleport 120ft + 30ft AoE 3d10 force. 1/LR." : "Warping Implosion. Action. 5 SP to reuse.";
		warping_implosion_opt = m.add_item(wi_label);
	}
	// Tasha's Clockwork Soul L6 Bastion of Law (para 3997-4000)
	if (lc == "sorcerer" and subclass == "Clockwork Sorcery" and level >= 6) {
		string bol_label = "Bastion of Law. Action. 1-5 SP: create d8 ward dice on self or ally to absorb damage.";
		if (my_bastion_of_law_dice > 0) bol_label += " (Current ward: " + my_bastion_of_law_dice + "d8)";
		bastion_of_law_opt = m.add_item(bol_label);
	}
	// Tasha's Clockwork Soul L14 Trance of Order (para 4001-4004)
	if (lc == "sorcerer" and subclass == "Clockwork Sorcery" and level >= 14 and !my_trance_of_order_active) {
		string trance_label = "Trance of Order. Bonus action. 1 min: no advantage vs you + d20 9- treated as 10.";
		if (my_trance_of_order_used) trance_label += " (5 SP to reuse)";
		trance_of_order_opt = m.add_item(trance_label);
	}
	// Tasha's Clockwork Soul L18 Clockwork Cavalcade (para 4005-4011)
	if (lc == "sorcerer" and subclass == "Clockwork Sorcery" and level >= 18) {
		string cc_label = my_clockwork_cavalcade_available ? "Clockwork Cavalcade. Action. Restore 100 HP among allies in 30ft cube. 1/LR." : "Clockwork Cavalcade. Action. 7 SP to reuse.";
		clockwork_cavalcade_opt = m.add_item(cc_label);
	}
	// PHB 2024 Wizard Evoker L14 Overchannel (paras 9265-9268): When you cast a Wizard
	// spell of levels 1-5 that deals damage, deal max damage. After first use per long
	// rest, take 2d12 necrotic per spell level (escalates +1d12 per use until long rest).
	if (lc == "wizard" and subclass == "Evoker" and level >= 14 and !my_overchannel_pending) {
		string oc_label = "Overchannel. Toggle: next Wizard spell level 1-5 you cast deals max damage.";
		if (my_overchannel_uses_this_rest >= 1) {
			int extra = 2 + (my_overchannel_uses_this_rest - 1);
			oc_label += " WARNING: you will take " + extra + "d12 necrotic per spell level after casting.";
		}
		overchannel_opt = m.add_item(oc_label);
	}
	// PHB 2024 Warlock L2 Magical Cunning (paras 7782-7783): Magic action; perform an
	// esoteric rite for 1 minute. Regain Pact Magic spell slots, no more than half max
	// (round up). 1/Long Rest. L20 Eldritch Master regains all instead.
	if (lc == "warlock" and level >= 2 and my_magical_cunning_available) {
		string mc_label = "Magical Cunning. Magic action. Perform a 1-minute rite to regain half your Pact Magic slots (round up). 1 per long rest.";
		if (level >= 20) mc_label = "Magical Cunning (Eldritch Master). Magic action. Perform a 1-minute rite to regain ALL your Pact Magic slots. 1 per long rest.";
		magical_cunning_opt = m.add_item(mc_label);
	}
	// PHB 2024 Warlock L9 Contact Patron (paras 7788-7790): cast Contact Other Plane
	// without a slot, automatic save success. 1/Long Rest.
	if (lc == "warlock" and level >= 9 and my_contact_patron_available) {
		contact_patron_opt = m.add_item("Contact Patron. Cast Contact Other Plane without a slot. Automatically succeed on the save. 1 per long rest.");
	}
	// PHB 2024 Warlock L11+ Mystic Arcanum (paras 7791-7795): cast a chosen 6th-9th
	// level Warlock spell once per long rest without expending a slot.
	if (lc == "warlock" and (my_mystic_arcanum_6_available or my_mystic_arcanum_7_available or my_mystic_arcanum_8_available or my_mystic_arcanum_9_available)) {
		string arc_label = "Mystic Arcanum. Cast one of your chosen high-level Warlock spells without a slot. 1 per long rest each. Available: ";
		string parts = "";
		if (my_mystic_arcanum_6_available) parts += "level 6";
		if (my_mystic_arcanum_7_available) { if (parts != "") parts += ", "; parts += "level 7"; }
		if (my_mystic_arcanum_8_available) { if (parts != "") parts += ", "; parts += "level 8"; }
		if (my_mystic_arcanum_9_available) { if (parts != "") parts += ", "; parts += "level 9"; }
		arc_label += parts + ".";
		mystic_arcanum_opt = m.add_item(arc_label);
	}
	if (lc == "paladin" and my_lay_on_hands_pool > 0) lay_hands_opt = m.add_item("Lay on Hands. Bonus action. Pool: " + my_lay_on_hands_pool + ".");
	if (lc == "monk" and level >= 2) flurry_opt = m.add_item("Flurry of Blows. 1 Focus Point. Focus Points: " + my_focus_points + ".");
	int patient_defense_opt = -1;
	int step_of_wind_opt = -1;
	int martial_arts_strike_opt = -1;
	int uncanny_metabolism_opt = -1;
	int superior_defense_opt = -1;
	if (lc == "monk") {
		// PHB 2024 Monk L1 Martial Arts Bonus Unarmed Strike (para 5319)
		martial_arts_strike_opt = m.add_item("Martial Arts: Bonus Unarmed Strike. Bonus action. Free.");
		if (level >= 2) {
			// PHB 2024 Monk L2 Patient Defense (para 5330)
			patient_defense_opt = m.add_item("Patient Defense. Bonus action. Disengage. Spend 1 Focus Point to also Dodge. Focus Points: " + my_focus_points + ".");
			// PHB 2024 Monk L2 Step of the Wind (para 5331)
			step_of_wind_opt = m.add_item("Step of the Wind. Bonus action. Dash. Spend 1 Focus Point to also Disengage. Focus Points: " + my_focus_points + ".");
			// PHB 2024 Monk L2 Uncanny Metabolism (para 5334-5336)
			if (my_uncanny_metabolism_available) uncanny_metabolism_opt = m.add_item("Uncanny Metabolism. Once per long rest. Regain all Focus Points and heal monk level plus Martial Arts die.");
		}
		if (level >= 18 and !my_superior_defense_active and my_focus_points >= 3) {
			// PHB 2024 Monk L18 Superior Defense (para 5372-5373)
			superior_defense_opt = m.add_item("Superior Defense. Spend 3 Focus Points. Resistance to all damage except Force for 1 minute.");
		}
	}
	if (lc == "bard" and my_bardic_inspiration_uses > 0) bardic_opt = m.add_item("Bardic Inspiration. Bonus action. Uses left: " + my_bardic_inspiration_uses + ".");
	// PHB 2024 Bard L5 Font of Inspiration (paras 2753-2755). No action; expend lowest
	// spell slot to regain one Bardic Inspiration use.
	if (lc == "bard" and my_font_of_inspiration_active) font_of_inspiration_opt = m.add_item("Font of Inspiration. No action. Expend lowest spell slot to regain one Bardic Inspiration use.");
	if (lc == "druid" and level >= 2 and (currently_wild_shaped or subclass == "Circle of the Moon")) {
		if (currently_wild_shaped) wild_shape_opt = m.add_item("Wild Shape. Revert or choose a new beast form.");
		else wild_shape_opt = m.add_item("Wild Shape. Bonus action. Transform into a beast.");
	}
	// PHB 2024 Druid L2 Wild Companion (para 4420). Action — expend a Wild Shape use OR
	// a spell slot to summon a fey familiar (Find Familiar without material components).
	if (lc == "druid" and level >= 2) {
		wild_companion_opt = m.add_item("Wild Companion. Action. Expend a Wild Shape use or spell slot to summon a fey familiar.");
	}
	// PHB 2024 Druid L5 Wild Resurgence (para 4427-4429). Two no-action options gated by
	// resource state — only show the one that's currently usable.
	if (lc == "druid" and level >= 5) {
		wild_resurgence_slot_to_use_opt = m.add_item("Wild Resurgence: spell slot to Wild Shape. No action. Once per turn. Burn a slot to recover one Wild Shape use (only if 0 uses left).");
		wild_resurgence_use_to_slot_opt = m.add_item("Wild Resurgence: Wild Shape to level 1 slot. No action. 1/long rest. Burn a Wild Shape use to recover a level 1 spell slot.");
	}
	if (my_spiritual_weapon_active) spiritual_weapon_opt = m.add_item("Spiritual Weapon. Strike a target within 60 feet with your summoned weapon.");

	// Subclass-specific bonus actions
	if (lc == "fighter") {
		if (subclass == "Battle Master") {
			trip_opt = m.add_item("Trip Attack. Use a superiority die. Your next hit knocks the target prone.");
			precision_opt = m.add_item("Precision Attack. Add a d8 to your next attack roll.");
			riposte_opt = m.add_item("Riposte. Ready a reaction attack when an enemy misses you.");
		}
		// Psi Warrior Strike auto-triggers on hit; no menu option needed.
	}
	if (lc == "barbarian") {
		if (subclass == "Berserker" and my_is_raging) {
			frenzy_opt = m.add_item("Frenzy Attack. Bonus action melee attack while raging.");
		}
	}
	if (lc == "rogue") {
		if (subclass == "Soulknife") {
			psychic_blade_opt = m.add_item("Psychic Blades. Bonus action. Strike with a psychic blade for 1d4 psychic damage.");
		}
	}
	if (lc == "paladin") {
		if (subclass == "Oath of Devotion") {
			sacred_opt = m.add_item("Sacred Weapon. Channel Divinity. Add Charisma to attack rolls for the battle.");
		}
		if (subclass == "Oath of Vengeance") {
			vow_opt = m.add_item("Vow of Enmity. Channel Divinity. Gain advantage on attacks against your target.");
		}
		if (subclass == "Oath of Glory") {
			inspire_opt = m.add_item("Inspiring Smite. After your next Divine Smite, grant temporary HP to nearby allies.");
		}
		if (subclass == "Oath of Ancients") {
			nature_opt = m.add_item("Nature's Wrath. Channel Divinity. Restrain a target. Strength or Dexterity save.");
		}
	}
	if (lc == "cleric") {
		if (subclass == "Life Domain") {
			preserve_opt = m.add_item("Preserve Life. Channel Divinity. Heal allies below half health.");
		}
		if (subclass == "War Domain") {
			war_priest_opt = m.add_item("War Priest. Bonus action weapon attack.");
		}
	}
	if (lc == "monk") {
		if (subclass == "Warrior of Shadow") {
			shadow_opt = m.add_item("Shadow Step. Bonus action. Teleport up to 60 feet.");
		}
		if (subclass == "Warrior of Mercy") {
			mercy_opt = m.add_item("Hands of Healing. 1 Focus Point. Heal a target for 1d6 plus Wisdom.");
		}
		if (subclass == "Warrior of the Elements") {
			element_opt = m.add_item("Elemental Burst. Spend Focus Points for 1d6 elemental damage per point.");
		}
	}
	if (lc == "warlock") {
		if (subclass == "Celestial Patron") {
			heal_light_opt = m.add_item("Healing Light. Bonus action. Heal a target using d6 dice from your pool.");
		}
		if (subclass == "Archfey Patron") {
			fey_opt = m.add_item("Fey Presence. Charm or frighten nearby creatures. Wisdom save.");
		}
	}
	if (lc == "bard") {
		if (subclass == "College of Glamour") {
			mantle_opt = m.add_item("Mantle of Inspiration. Grant temporary HP to all allies.");
		}
	}
	// New Xanathar's/Tasha's subclass bonus actions
	if (lc == "ranger" and subclass == "Horizon Walker") {
		planar_warrior_opt = m.add_item("Planar Warrior. Bonus action. Next weapon attack deals bonus force damage.");
	}
	if (lc == "cleric" and subclass == "Grave Domain") {
		path_to_grave_opt = m.add_item("Path to the Grave. Channel Divinity. Curse target — next attack deals double damage (vulnerability).");
	}
	if (lc == "warlock" and subclass == "The Hexblade") {
		hexblades_curse_opt = m.add_item("Hexblade's Curse. Bonus action. Mark a target for +Prof damage and expanded crits.");
	}
	if (lc == "fighter" and subclass == "Samurai") {
		fighting_spirit_opt = m.add_item("Fighting Spirit. Bonus action. Advantage on attacks + temp HP.");
	}
	if (lc == "druid" and subclass == "Circle of Spores") {
		symbiotic_entity_opt = m.add_item("Symbiotic Entity. Action. Gain temp HP and +1d6 necrotic on melee attacks.");
	}
	if (lc == "bard" and subclass == "College of Swords") {
		blade_flourish_opt = m.add_item("Blade Flourish. Bonus action. Next weapon attack gets bonus damage.");
	}
	if (lc == "bard" and subclass == "College of Whispers") {
		psychic_blades_bard_opt = m.add_item("Psychic Blades. Bonus action. Next weapon attack deals bonus psychic damage.");
	}
	if (lc == "fighter" and subclass == "Cavalier" and my_cavalier_retaliation_available and my_unwavering_mark_ba_uses > 0) {
		cavalier_retaliation_opt = m.add_item("Unwavering Mark Retaliation. Bonus action. Attack marked creature with advantage and +" + (level / 2) + " bonus damage. (" + my_unwavering_mark_ba_uses + "/" + my_unwavering_mark_ba_uses_max + " uses)");
	}
	if (lc == "druid" and subclass == "Circle of Dreams") {
		balm_summer_opt = m.add_item("Balm of the Summer Court. Bonus action. Heal target with d6s from fey pool.");
		if (level >= 10) {
			hidden_paths_opt = m.add_item("Hidden Paths. Bonus action. Teleport up to 60 feet.");
		}
	}
	int conquering_presence_opt = -1;
	int invincible_conqueror_opt = -1;
	if (lc == "paladin" and subclass == "Oath of Conquest") {
		guided_strike_opt = m.add_item("Guided Strike. Channel Divinity. Add +10 to next attack roll.");
		conquering_presence_opt = m.add_item("Conquering Presence. Channel Divinity action. Frighten enemies within 30 feet.");
		if (level >= 20) invincible_conqueror_opt = m.add_item("Invincible Conqueror. Action. Resistance to all damage, extra attack, crit 19 to 20. 1 minute.");
	}
	if (lc == "fighter" and subclass == "Rune Knight") {
		giants_might_opt = m.add_item("Giant's Might. Bonus action. Become Large with +1d6 damage.");
	}
	if (lc == "sorcerer" and subclass == "Divine Soul") {
		empowered_healing_opt = m.add_item("Empowered Healing. Reroll dice on next healing spell.");
	}
	if (lc == "cleric" and subclass == "Peace Domain") {
		emboldening_bond_opt = m.add_item("Emboldening Bond. Channel Divinity. Bond allies for bonus d4 on rolls.");
	}
	if (lc == "cleric" and subclass == "Twilight Domain") {
		twilight_sanctuary_opt = m.add_item("Twilight Sanctuary. Channel Divinity. Grant nearby allies temp HP each round.");
	}
	if (lc == "fighter" and subclass == "Arcane Archer") {
		arcane_shot_opt = m.add_item("Arcane Shot. Apply a magical effect to your next ranged attack.");
	}
	if (lc == "paladin" and subclass == "Oath of the Watchers") {
		abjure_extraplanar_opt = m.add_item("Abjure the Extraplanar. Channel Divinity. Frighten aberrations, fey, fiends, and celestials.");
	}
	if (lc == "rogue" and subclass == "Inquisitive") {
		insightful_fighting_opt = m.add_item("Insightful Fighting. Study a target to enable Sneak Attack without advantage.");
	}
	if (lc == "rogue" and subclass == "Mastermind") {
		mastermind_help_opt = m.add_item("Mastermind Help. Help an ally at 30 feet as a bonus action.");
	}
	if (lc == "rogue" and subclass == "Thief" and level >= 3) {
		fast_hands_opt = m.add_item("Fast Hands. Bonus action to use an object.");
	}
	if (lc == "monk" and subclass == "Way of the Sun Soul") {
		sun_bolt_opt = m.add_item("Radiant Sun Bolt. Bonus action ranged attack for radiant damage.");
	}
	if (lc == "monk" and subclass == "Way of the Kensei") {
		kensei_weapon_opt = m.add_item("Kensei Weapon. Choose your kensei weapon for this battle.");
		if (level >= 3) kensei_shot_opt = m.add_item("Kensei's Shot. Bonus action. Ranged kensei attacks deal +1d4 damage this turn.");
		if (level >= 11 and my_focus_points > 0 and my_sharpen_the_blade_bonus == 0) {
			int max_ki = my_focus_points > 3 ? 3 : my_focus_points;
			if (max_ki >= 1) sharpen_blade_1_opt = m.add_item("Sharpen the Blade (+1). Bonus action. 1 Focus Point. +1 attack and damage for 1 minute. Focus: " + my_focus_points + ".");
			if (max_ki >= 2) sharpen_blade_2_opt = m.add_item("Sharpen the Blade (+2). Bonus action. 2 Focus Points. +2 attack and damage for 1 minute. Focus: " + my_focus_points + ".");
			if (max_ki >= 3) sharpen_blade_3_opt = m.add_item("Sharpen the Blade (+3). Bonus action. 3 Focus Points. +3 attack and damage for 1 minute. Focus: " + my_focus_points + ".");
		}
	}
	if (lc == "monk" and subclass == "Way of the Ascendant Dragon") {
		breath_dragon_opt = m.add_item("Breath of the Dragon. Action + 1 Focus Point. 15ft cone of fire damage.");
	}
	if (lc == "monk" and subclass == "Way of the Astral Self") {
		astral_arms_opt = m.add_item("Astral Arms. Bonus action + 1 Focus Point. Extended reach unarmed strikes.");
	}
	if (lc == "warlock" and subclass == "The Fathomless") {
		tentacle_opt = m.add_item("Tentacle of the Deeps. Bonus action. Cold damage strike that slows target.");
	}
	if (lc == "warlock" and subclass == "The Genie") {
		genie_vessel_opt = m.add_item("Genie's Vessel. Bonus action. Retreat into vessel for temp HP.");
	}
	if (lc == "warlock" and subclass == "The Undead") {
		form_of_dread_opt = m.add_item("Form of Dread. Bonus action. Transform into undead visage for temp HP and fear.");
	}
	if (lc == "druid" and subclass == "Circle of the Stars") {
		starry_form_opt = m.add_item("Starry Form. Bonus action. Assume Chalice, Archer, or Dragon form.");
	}
	if (lc == "druid" and subclass == "Circle of Wildfire") {
		wildfire_opt = m.add_item("Wildfire Spirit. Action. Summon a wildfire spirit companion.");
	}
	if (lc == "fighter" and subclass == "Echo Knight") {
		echo_manifest_opt = m.add_item("Manifest Echo. Bonus action. Summon an echo 15ft away (AC 14+prof, 1 HP).");
		if (level >= 3) {
			unleash_incarnation_opt = m.add_item("Unleash Incarnation. Bonus action after Attack, extra melee attack from echo's space.");
		}
	}
	if (lc == "paladin" and subclass == "Oath of Redemption") {
		rebuke_violent_opt = m.add_item("Rebuke the Violent. Channel Divinity. Reaction damage reflection.");
	}
	if (lc == "artificer" and subclass == "Artillerist") {
		eldritch_cannon_opt = m.add_item("Eldritch Cannon. Action. Create an arcane cannon.");
		cannon_fire_opt = m.add_item("Command Cannon to Fire. Bonus action. Flamethrower attack.");
	}
	if (lc == "artificer" and subclass == "Battle Smith") {
		steel_defender_opt = m.add_item("Steel Defender Attack. Bonus action. Command your defender to strike.");
	}
	if (lc == "artificer" and subclass == "Alchemist") {
		experimental_elixir_opt = m.add_item("Experimental Elixir. Bonus action. Create a random elixir effect.");
	}
	if (lc == "ranger" and subclass == "Beast Master") {
		primal_companion_opt = m.add_item("Primal Companion Attack. Bonus action. Command your animal companion.");
	}
	// PHB 2024 Ranger L10 Tireless (para 6178-6180): "As a Magic action, you can give
	// yourself a number of Temporary Hit Points equal to 1d8 plus your Wisdom modifier."
	// Wis-mod uses per long rest.
	if (lc == "ranger" and level >= 10 and my_tireless_temp_hp_uses_remaining > 0) {
		tireless_temp_hp_opt = m.add_item("Tireless. Magic action. Gain 1d8 + WIS mod temporary hit points. Uses left: " + my_tireless_temp_hp_uses_remaining + ".");
	}
	// PHB 2024 Ranger L14 Nature's Veil (para 6184-6186): "As a Bonus Action, you can
	// give yourself the Invisible condition until the end of your next turn."
	// Wis-mod uses per long rest.
	if (lc == "ranger" and level >= 14 and my_natures_veil_uses_remaining > 0) {
		natures_veil_opt = m.add_item("Nature's Veil. Bonus action. Become Invisible until the end of your next turn. Uses left: " + my_natures_veil_uses_remaining + ".");
	}
	if (lc == "ranger" and subclass == "Drakewarden") {
		drake_attack_opt = m.add_item("Drake Breath. Bonus action. Drake companion breathes fire at target.");
	}
	if (lc == "ranger" and subclass == "Monster Slayer") {
		slayers_prey_opt = m.add_item("Slayer's Prey. Bonus action. Mark a target for bonus damage.");
	}
	if (lc == "ranger" and subclass == "Swarmkeeper") {
		swarmkeeper_opt = m.add_item("Gathered Swarm. Bonus action. Command swarm for bonus force damage.");
	}
	if (lc == "wizard" and subclass == "Chronurgy Magic") {
		chronal_shift_opt = m.add_item("Chronal Shift. Force a roll to be rerolled.");
		if (level >= 6) {
			momentary_stasis_opt = m.add_item("Momentary Stasis. Action. CON save or Incapacitated. INT mod per long rest.");
		}
	}
	if (lc == "wizard" and subclass == "Graviturgy Magic") {
		adjust_density_opt = m.add_item("Adjust Density. Action. Halve or double target density within 30ft.");
		if (level >= 14) {
			event_horizon_opt = m.add_item("Event Horizon. Action. 30ft aura, STR save or 2d10 force + speed 0. 1/LR.");
		}
	}
	if (lc == "paladin" and subclass == "Oath of Zeal" and level >= 3) {
		mark_of_heretic_opt = m.add_item("Mark of the Heretic. Channel Divinity. Mark target for crit 19+ range.");
		inquisitors_eye_opt = m.add_item("Inquisitor's Eye. Channel Divinity bonus action. Advantage on Investigation, Insight, Perception for 10 minutes; cannot be surprised.");
	}
	// Book of Ebon Tides: Shadow Domain Cleric
	if (lc == "cleric" and subclass == "Shadow Domain") {
		shadow_grasp_opt = m.add_item("Shadow Grasp. Channel Divinity action. Target STR save or restrained until end of next turn (grappled on success).");
		if (level >= 6) {
			fade_to_black_opt = m.add_item("Fade to Black. Bonus action in dim light/darkness. Become invisible for 1 minute. PB uses/LR.");
		}
	}
	// Book of Ebon Tides: Light Weaver Sorcerer
	if (lc == "sorcerer" and subclass == "Light Weaver") {
		flickering_aura_opt = m.add_item("Flickering Aura. Action toggle. Emit a 15-foot bright light or darkness aura.");
		if (level >= 6) {
			refraction_shield_opt = m.add_item("Refraction Shield. Bonus action, 3 SP. Melee attackers within 5ft take 2d8 radiant or necrotic damage.");
		}
	}
	// Book of Ebon Tides: College of Shadow Bard
	if (lc == "bard" and subclass == "College of Shadow" and level >= 3) {
		dancing_shadows_opt = m.add_item("Dancing Shadows. Bonus action, 1 BI. 20-foot half-cover sphere for allies, 1 minute.");
	}
	// Book of Ebon Tides: Mother of Sorrows Warlock
	if (lc == "warlock" and subclass == "Mother of Sorrows") {
		venomous_mark_opt = m.add_item("Venomous Mark. Bonus action. Curse a target within 30ft for 1 minute. +1d6 poison on spell attack hit.");
	}
	// Book of Ebon Tides: Circle of Shadows Druid
	if (lc == "druid" and subclass == "Circle of Shadows" and level >= 2) {
		umbral_form_opt = m.add_item("Umbral Form. Bonus action, expend Wild Shape. 10 minutes shadowy form: hide as bonus action in dim/dark, fit through 1-inch spaces, reaction PB cold damage on melee hit." + (level >= 10 ? " Shadow Mass adds fly speed and B/P/S resistance." : ""));
		if (level >= 14) {
			darkness_falls_opt = m.add_item("Darkness Falls. Action. 15-foot magical darkness sphere centered on you, 1 minute. Dispels light spells of L7 or lower. 1/SR or LR.");
		}
	}
	// Book of Ebon Tides: Shadow Arcane Tradition Wizard
	if (lc == "wizard" and subclass == "Shadow Arcane Tradition" and level >= 2) {
		dark_transfusion_opt = m.add_item("Dark Transfusion. Bonus action. Expend two spell slots to recover one of equal or lesser combined value.");
	}
	// Book of Ebon Tides: Keeper Domain Cleric
	if (lc == "cleric" and subclass == "Keeper Domain" and level >= 2) {
		divine_initiative_opt = m.add_item("Divine Initiative. Channel Divinity action. Grant up to WIS-mod allies within 60ft 5 to 14 temp HP (level scaling) and an immediate reaction weapon attack.");
	}
	// Book of Ebon Tides: Shadow Gnawer Barbarian
	if (lc == "barbarian" and subclass == "Shadow Gnawer") {
		if (level >= 6) {
			creeping_fog_opt = m.add_item("Creeping Fog. Action. Teleport up to 60ft to a visible space and make one melee attack.");
		}
		if (level >= 10) {
			consume_darkness_opt = m.add_item("Consume Darkness. Bonus action while raging. Heal 1d12+CON and 1 HP/turn for the rest of rage. 1/SR.");
		}
	}
	// Telekinetic feat (PHB para 7813) - bonus action shove available to anyone with the feat
	if (feat_selected("telekinetic")) {
		telekinetic_shove_opt = m.add_item("Telekinetic Shove. Bonus action. Push a creature within 30ft 5 feet (STR save vs DC 8 + PB + spellcasting mod).");
	}
	// Theros Piety Devotee trait (Mythic Odysseys of Theros paras 1328-1329) —
	// bonus action that casts the god's devotee spell for free, a number of
	// times equal to a relevant ability modifier per long rest. Available
	// whenever the character has a Piety god set and score >= 3.
	if (@me != null and me.piety_god != "" and me.piety_score >= 3 and me.piety_devotee_uses > 0) {
		piety_devotee_opt = m.add_item("Invoke " + me.piety_god + "'s favor. Bonus action. Cast your Devotee trait spell for free (" + me.piety_devotee_uses + " uses remaining this long rest).");
	}
	// Tasha's Group Patrons — Group Assistance (source para 4910) — a
	// once-per-long-rest d4 bonus on any one d20 roll granted by your party's
	// patron organization. Available whenever the character has a patron set
	// and hasn't used the benefit this rest.
	if (@me != null and me.group_patron != "" and !me.group_assistance_used_this_rest) {
		group_assistance_opt = m.add_item("Call on " + me.group_patron + " for Group Assistance. Bonus action. Gain +1d4 to your next d20 roll (1/long rest).");
	}
	// Companion summoning bonus actions (TODO §7C: minimum viable implementation)
	if (lc == "ranger" and subclass == "Beast Master" and level >= 3) {
		summon_primal_companion_opt = m.add_item("Summon Primal Companion. Bonus action. Land beast: HP 5+5*level, AC 13+PB, 1d8+PB slashing.");
	}
	if (lc == "artificer" and subclass == "Battle Smith" and level >= 3) {
		summon_steel_defender_opt = m.add_item("Activate Steel Defender. Bonus action. HP 2+5*level+INT, AC 15, 1d8+PB force.");
	}
	if (lc == "ranger" and subclass == "Drakewarden" and level >= 3) {
		summon_drake_companion_opt = m.add_item("Summon Drake Companion. Bonus action. HP 5+5*level, AC 14+PB, 1d6+PB elemental damage.");
	}
	if (lc == "druid" and subclass == "Circle of Wildfire" and level >= 2) {
		summon_wildfire_spirit_opt = m.add_item("Summon Wildfire Spirit. Action, expends Wild Shape. HP 5+5*level, AC 13, 1d6+PB fire ranged attack.");
	}
	if (lc == "artificer" and subclass == "Artillerist" and level >= 3) {
		create_eldritch_cannon_opt = m.add_item("Create Eldritch Cannon. Action. HP 5*level, AC 18, 2d8 force ranged attack (Force Ballista mode).");
	}
	// Xanathar's Storm Herald L3 Storm Aura (para 416-418): BA to reactivate aura each turn
	if (lc == "barbarian" and subclass == "Storm Herald" and my_is_raging) {
		storm_aura_opt = m.add_item("Storm Aura. Bonus action. Activate aura effect (desert: fire damage, sea: lightning, tundra: temp HP to allies).");
	}
	// Xanathar's Zealot L10 Zealous Presence (para 445-447): BA 1/LR, 10 allies gain adv on attacks+saves
	if (lc == "barbarian" and subclass == "Zealot" and level >= 10) {
		zealous_presence_opt = m.add_item("Zealous Presence. Bonus action, 1/long rest. Up to 10 allies within 60ft gain advantage on attacks and saves until start of your next turn.");
	}
	// Barbarian L2 Reckless Attack (PHB 2024 base class feature)
	if (lc == "barbarian" and level >= 2) {
		reckless_attack_opt = m.add_item("Reckless Attack. Declare on your first attack. Advantage on STR attacks until next turn, but enemies have advantage on attacks against you.");
	}
	// Barbarian L9 Brutal Strike (PHB 2024 para 2338)
	if (lc == "barbarian" and level >= 9) {
		brutal_strike_opt = m.add_item("Brutal Strike. Forgo Reckless advantage on next STR attack for +1d10 damage and a rider effect. Requires Reckless Attack active.");
	}
	// Rogue L5 Cunning Strike (PHB 2024 para 6553)
	if (lc == "rogue" and level >= 5) {
		cunning_strike_opt = m.add_item("Cunning Strike. Forgo SA dice on next Sneak Attack for a rider effect (Poison, Trip, Withdraw" + (level >= 14 ? ", Daze, Knock Out, Obscure" : "") + ").");
	}
	// Wizard L1 Arcane Recovery (PHB 2024 base class feature)
	if (lc == "wizard") {
		arcane_recovery_opt = m.add_item("Arcane Recovery. Bonus action, 1/day. Recover spell slots totaling up to half your level (rounded up), no slots of L6+.");
	}
	// Cleric L2 Channel Divinity Turn Undead (PHB 2024 base class feature)
	if (lc == "cleric" and level >= 2) {
		turn_undead_opt = m.add_item("Turn Undead. Channel Divinity action. Each undead within 30 ft makes WIS save or is Frightened + Incapacitated 1 minute (or until damaged). At L5+ also deals WIS-mod d8 radiant damage.");
		// PHB 2024 Cleric L2 Channel Divinity: Divine Spark (para 3608-3610). "Bonus Action,
		// you point your Holy Symbol at another creature you can see within 60 feet of yourself
		// and focus divine energy at it. Roll 2d8 and add your Wisdom modifier. You either
		// restore Hit Points to the creature equal to that total, or you force the creature
		// to make a Constitution saving throw. On a failed save, the creature takes Necrotic
		// or Radiant damage (your choice) equal to that total." Scales: 3d8 at L7, 4d8 at L13, 5d8 at L18.
		divine_spark_heal_opt = m.add_item("Divine Spark: Heal. Bonus action. Channel Divinity to heal a creature within 60 ft. 2d8+WIS HP (scales 3d8 L7, 4d8 L13, 5d8 L18).");
		divine_spark_radiant_opt = m.add_item("Divine Spark: Radiant. Bonus action. Channel Divinity force CON save vs target within 60 ft. 2d8+WIS radiant on fail (scales L7/13/18).");
		divine_spark_necrotic_opt = m.add_item("Divine Spark: Necrotic. Bonus action. Channel Divinity force CON save vs target within 60 ft. 2d8+WIS necrotic on fail (scales L7/13/18).");
	}
	// PHB 2024 Cleric L10 Divine Intervention (para 3621-3622). "you can call on your deity
	// to intervene on your behalf. As a Magic action, choose any Cleric spell of level 5 or
	// lower that doesn't require a Reaction to cast... The chosen spell occurs as an effect.
	// You don't need to meet the requirements to cast the spell, including costly components."
	// Once per long rest. Scales to "no roll needed" automatically at L10+.
	if (lc == "cleric" and level >= 10) {
		divine_intervention_opt = m.add_item("Divine Intervention. Bonus action. Once per long rest. Your next cast of any Cleric spell of level 5 or lower consumes no spell slot.");
	}
	if (lc == "bard" and subclass == "College of Mercantile" and level >= 3) {
		magic_coin_opt = m.add_item("Magic Coin. Action. Fling a coin at target for 1d12 thunder damage (scales).");
	}
	if (lc == "cleric" and subclass == "Astral Domain" and level >= 3) {
		create_void_opt = m.add_item("Create Void. Channel Divinity bonus action. 15ft sphere within 60ft, Dex save.");
	}
	if (lc == "monk" and subclass == "Way of the Ascendant Dragon" and level >= 3) {
		breath_of_dragon_opt = m.add_item("Breath of the Dragon. Replace attack with 20ft cone. PB/LR or 2 focus.");
		if (level >= 11) {
			aspect_of_wyrm_opt = m.add_item("Aspect of the Wyrm. Bonus action. 10ft aura, fire resistance to allies. 1/LR or 3 focus.");
		}
	}
	if (lc == "monk" and subclass == "Warrior of the Open Hand") {
		open_hand_opt = m.add_item("Open Hand Technique. Use on Flurry hit to push, knock prone, or prevent reactions.");
	}
	if (lc == "rogue" and subclass == "Arcane Trickster") {
		mage_hand_legerdemain_opt = m.add_item("Mage Hand Legerdemain. Bonus action. Command an invisible Mage Hand.");
	}
	if (lc == "rogue" and subclass == "Scout") {
		scout_skirmish_opt = m.add_item("Skirmisher. Reaction. Move half speed when enemy ends turn near you.");
	}
	if (lc == "bard" and subclass == "College of Eloquence" and level >= 3) {
		unsettling_words_opt = m.add_item("Unsettling Words. Bonus action. Spend Bardic Inspiration to subtract die roll from target's next save.");
	}
	if (lc == "cleric" and subclass == "Order Domain") {
		orders_demand_opt = m.add_item("Order's Demand. Action. Channel Divinity to charm enemies within 30ft (WIS save).");
	}
	// Gunslinger subclass bonus actions. Most Gunslinger subclass features are triggered maneuvers,
	// not standalone bonus actions, so only the explicit bonus-action toggles appear here.
	if (lc == "gunslinger" and subclass == "White Hat" and level >= 3) {
		white_hat_protect_opt = m.add_item("Lay Down the Law. Bonus action. Spend a Risk Die to grant an ally temp HP and retaliation.");
	}
	// Valda's Spire Gunslinger Deadeye L14 Focused Shot (paras 252-253)
	if (lc == "gunslinger" and subclass == "Deadeye" and level >= 14) {
		focused_shot_opt = m.add_item("Focused Shot. Toggle. Next ranged attack gains Advantage and is a Critical Hit on a hit.");
	}
	// Valda's Spire Gunslinger High Roller L6 Risky Business (paras 265-266)
	if (lc == "gunslinger" and subclass == "High Roller" and level >= 6) {
		risky_business_opt = m.add_item("Risky Business. Toggle. Next attack will be made with Disadvantage and refund a Risk Die. (1/turn)");
	}
	// Valda's Spire Gunslinger Secret Agent L14 License to Kill (paras 290-291)
	if (lc == "gunslinger" and subclass == "Secret Agent" and level >= 14) {
		license_to_kill_one_opt = m.add_item("License to Kill (1 Die). Toggle. Next ranged damage roll spends 1 Risk Die with explosions.");
		license_to_kill_two_opt = m.add_item("License to Kill (2 Dice). Toggle. Next ranged damage roll spends 2 Risk Dice with explosions.");
	}
	// Valda's Spire Gunslinger Spellslinger L3 Bang You're Dead (paras 423-426)
	if (lc == "gunslinger" and subclass == "Spellslinger" and level >= 3) {
		bang_youre_dead_opt = m.add_item("Bang You're Dead. Bonus action toggle. Next Finger Guns hit spends a Risk Die for bonus damage.");
	}
	// Setting subclass bonus actions
	if (lc == "rogue" and subclass == "Misfortune Bringer" and level >= 3) {
		jinx_target_opt = m.add_item("Jinx Target. Bonus action. Curse target with bonus damage on next hits.");
	}
	if (lc == "rogue" and subclass == "Runetagger" and level >= 3) {
		rune_tag_opt = m.add_item("Rune Tag. Bonus action. Mark target with magical rune for force damage.");
	}
	if (lc == "fighter" and subclass == "Blade Breaker" and level >= 3) {
		blade_breaker_stance_opt = m.add_item("Blade Breaker Stance. Bonus action. Toggle armor-crushing stance.");
	}
	if (lc == "cleric" and subclass == "Festus Domain" and level >= 1) {
		festus_blessing_opt = m.add_item("Festus Blessing. Bonus action. Channel Divinity to heal nearby allies.");
	}
	if (lc == "cleric" and subclass == "Trickery Domain" and level >= 3) {
		blessing_of_trickery_opt = m.add_item("Blessing of the Trickster. Action. Grant ally advantage on Stealth checks until long rest.");
	}
	if (lc == "druid" and subclass == "Circle of the Shepherd" and level >= 2) {
		spirit_totem_bear_opt = m.add_item("Bear Spirit Totem. Bonus action. Grant temp HP to nearby allies.");
		spirit_totem_hawk_opt = m.add_item("Hawk Spirit Totem. Bonus action. Enables reaction to grant attack advantage.");
		spirit_totem_unicorn_opt = m.add_item("Unicorn Spirit Totem. Bonus action. Healing spells also heal chosen creatures in aura.");
	}
	// Feat-based bonus actions (server validates feat ownership)
	polearm_master_attack_opt = m.add_item("Polearm Master Attack. Bonus action. Strike with the polearm butt for 1d4. (Requires Polearm Master feat)");
	// Shield Master Shove is automatic now (2024 rules: rider on melee hit with shield, not a bonus action)
	// Valda's Spire Gunslinger maneuvers (Critical Shot is now passive crit-range,
	// Gut Shot is now an automatic on-crit debuff — neither is a menu entry).
	// Grazing Shot fires automatically on miss; Maverick Spirit fires automatically on
	// failed INT/WIS/CHA saves and checks; Skin of Your Teeth needs reaction infrastructure.
	if (lc == "gunslinger") {
		bite_the_bullet_opt = m.add_item("Bite the Bullet. Bonus action. Spend a Risk Die to gain temporary HP equal to the roll plus your level.");
		dodge_roll_opt = m.add_item("Dodge Roll. Bonus action. Spend a Risk Die to gain 15 feet of extra movement.");
		blindfire_opt = m.add_item("Blindfire. Bonus action. Spend a Risk Die to gain Blindsight 30 feet until end of turn.");
	}

	int options = 1;
	if (rage_opt >= 0) options++;
	if (second_wind_opt >= 0) options++;
	if (cunning_opt >= 0) options++;
	if (steady_aim_opt >= 0) options++;
	if (innate_sorcery_opt >= 0) options++;
	if (font_of_magic_to_slot_opt >= 0) options++;
	if (font_of_magic_to_sp_opt >= 0) options++;
	if (metamagic_opt >= 0) options++;
	if (dragon_wings_opt >= 0) options++;
	if (dragon_wings_restore_opt >= 0) options++;
	if (summon_dragon_free_opt >= 0) options++;
	if (otherworldly_wings_opt >= 0) options++;
	if (unearthly_recovery_opt >= 0) options++;
	if (overchannel_opt >= 0) options++;
	if (magical_cunning_opt >= 0) options++;
	if (contact_patron_opt >= 0) options++;
	if (mystic_arcanum_opt >= 0) options++;
	if (lay_hands_opt >= 0) options++;
	if (flurry_opt >= 0) options++;
	if (bardic_opt >= 0) options++;
	if (font_of_inspiration_opt >= 0) options++;
	if (wild_shape_opt >= 0) options++;
	if (spiritual_weapon_opt >= 0) options++;
	if (trip_opt >= 0) options++;
	if (precision_opt >= 0) options++;
	if (riposte_opt >= 0) options++;
	if (frenzy_opt >= 0) options++;
	if (psychic_blade_opt >= 0) options++;
	if (sacred_opt >= 0) options++;
	if (vow_opt >= 0) options++;
	if (inspire_opt >= 0) options++;
	if (nature_opt >= 0) options++;
	if (preserve_opt >= 0) options++;
	if (war_priest_opt >= 0) options++;
	if (shadow_opt >= 0) options++;
	if (mercy_opt >= 0) options++;
	if (element_opt >= 0) options++;
	if (heal_light_opt >= 0) options++;
	if (fey_opt >= 0) options++;
	if (mantle_opt >= 0) options++;
	if (focused_shot_opt >= 0) options++;
	if (risky_business_opt >= 0) options++;
	if (license_to_kill_one_opt >= 0) options++;
	if (license_to_kill_two_opt >= 0) options++;
	if (bang_youre_dead_opt >= 0) options++;
	if (white_hat_protect_opt >= 0) options++;
	if (bite_the_bullet_opt >= 0) options++;
	if (dodge_roll_opt >= 0) options++;
	if (blindfire_opt >= 0) options++;
	if (options == 1) {
		speak("No class bonus actions are available right now. You can still use a bonus action spell if you know one.", true);
	}

	int res = m.run();
	if (res == spell_opt) {
		show_spell_menu();
	}
	else if (rage_opt >= 0 and res == rage_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "rage"}});
	}
	else if (second_wind_opt >= 0 and res == second_wind_opt) {
		send({{"type", message_types::bonus_action}, {"feature", "second_wind"}});
	}
	else if (cunning_opt >= 0 and res == cunning_opt) {
		menu@ cm = setup_sub_menu("Cunning Action. Choose:");
		cm.add_item("Dash. Double movement.");
		cm.add_item("Disengage. No opportunity attacks.");
		cm.add_item("Hide. Make stealth check.");
		int cp = cm.run();
		string action = "dash";
		if (cp == 1) action = "disengage";
		else if (cp == 2) action = "hide";
		send({{"type", message_types::bonus_action}, {"feature", "cunning_action"}, {"action", action}});
	}
	else if (steady_aim_opt >= 0 and res == steady_aim_opt) {
		// PHB 2024 Rogue L3 Steady Aim (para 6550-6551)
		send({{"type", message_types::bonus_action}, {"feature", "steady_aim"}});
	}
	else if (innate_sorcery_opt >= 0 and res == innate_sorcery_opt) {
		// PHB 2024 Sorcerer L1 Innate Sorcery (para 6963-6967)
		send({{"type", message_types::bonus_action}, {"feature", "innate_sorcery"}});
	}
	else if (font_of_magic_to_slot_opt >= 0 and res == font_of_magic_to_slot_opt) {
		// PHB 2024 Sorcerer L2 Font of Magic — Creating Spell Slots (para 6973-6993)
		menu@ fm = setup_sub_menu("Font of Magic: choose slot level to create:");
		fm.add_item("Level 1 spell slot. Cost: 2 Sorcery Points.");
		if (level >= 3) fm.add_item("Level 2 spell slot. Cost: 3 Sorcery Points.");
		if (level >= 5) fm.add_item("Level 3 spell slot. Cost: 5 Sorcery Points.");
		if (level >= 7) fm.add_item("Level 4 spell slot. Cost: 6 Sorcery Points.");
		if (level >= 9) fm.add_item("Level 5 spell slot. Cost: 7 Sorcery Points.");
		int fp = fm.run();
		if (fp < 0) return;
		int slot_level = fp + 1;
		send({{"type", message_types::bonus_action}, {"feature", "font_of_magic_to_slot"}, {"slot_level", slot_level}});
	}
	else if (font_of_magic_to_sp_opt >= 0 and res == font_of_magic_to_sp_opt) {
		// PHB 2024 Sorcerer L2 Font of Magic — Converting Spell Slots to Sorcery Points (para 6972)
		menu@ fm = setup_sub_menu("Font of Magic: choose slot level to convert to Sorcery Points:");
		for (int sl = 1; sl <= 9; sl++) {
			if (my_spell_slots_current[sl] > 0) fm.add_item("Level " + sl + " slot. Gain " + sl + " Sorcery Points. (You have " + my_spell_slots_current[sl] + " level " + sl + " slots.)");
		}
		int fp = fm.run();
		if (fp < 0) return;
		// Map back to actual slot level
		int picked_level = -1;
		int idx = 0;
		for (int sl = 1; sl <= 9; sl++) {
			if (my_spell_slots_current[sl] > 0) {
				if (idx == fp) { picked_level = sl; break; }
				idx++;
			}
		}
		if (picked_level < 1) return;
		send({{"type", message_types::bonus_action}, {"feature", "font_of_magic_to_sp"}, {"slot_level", picked_level}});
	}
	else if (metamagic_opt >= 0 and res == metamagic_opt) {
		// PHB 2024 Sorcerer L2 Metamagic (paras 6979-7020)
		menu@ mm = setup_sub_menu("Choose a Metamagic option. Sorcery Points: " + my_sorcery_points + ".");
		mm.add_item("Careful Spell. 1 SP. Allies auto-succeed on your spell's saves.");
		mm.add_item("Distant Spell. 1 SP. Double spell range or Touch becomes 30 feet.");
		mm.add_item("Empowered Spell. 1 SP. Reroll some damage dice.");
		mm.add_item("Extended Spell. 1 SP. Double spell duration, advantage on concentration.");
		mm.add_item("Heightened Spell. 2 SP. Target has disadvantage on saves vs your spell.");
		mm.add_item("Quickened Spell. 2 SP. Cast an action spell as a bonus action.");
		mm.add_item("Seeking Spell. 1 SP. Reroll a missed spell attack.");
		mm.add_item("Subtle Spell. 1 SP. Cast without verbal, somatic, or material components.");
		mm.add_item("Transmuted Spell. 1 SP. Change damage type to acid, cold, fire, lightning, poison, or thunder.");
		mm.add_item("Twinned Spell. 1 SP. Increase effective spell level by 1 for extra target.");
		int mm_res = mm.run();
		if (mm_res < 0) return;
		string[] mm_options = {"careful", "distant", "empowered", "extended", "heightened", "quickened", "seeking", "subtle", "transmuted", "twinned"};
		string chosen = mm_options[mm_res];
		if (chosen == "transmuted") {
			// Sub-menu for damage type choice
			menu@ dm = setup_sub_menu("Choose the new damage type for Transmuted Spell.");
			dm.add_item("Acid");
			dm.add_item("Cold");
			dm.add_item("Fire");
			dm.add_item("Lightning");
			dm.add_item("Poison");
			dm.add_item("Thunder");
			int dm_res = dm.run();
			if (dm_res < 0) return;
			int[] dmg_types = {DMG_ACID, DMG_COLD, DMG_FIRE, DMG_LIGHTNING, DMG_POISON, DMG_THUNDER};
			send({{"type", message_types::bonus_action}, {"feature", "metamagic"}, {"option", chosen}, {"damage_type", dmg_types[dm_res]}});
			speak("Metamagic: Transmuted Spell activated.", true);
		} else {
			send({{"type", message_types::bonus_action}, {"feature", "metamagic"}, {"option", chosen}});
			speak("Metamagic: " + chosen + " activated.", true);
		}
	}
