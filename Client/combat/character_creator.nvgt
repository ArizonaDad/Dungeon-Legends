    string[] class_desc = {
        "Barbarian. D 12 hit die. Rages in battle for extra damage and resistance.",
        "Bard. D 8 hit die. Charisma caster. Inspires allies with magic and music.",
        "Cleric. D 8 hit die. Wisdom caster. Divine magic, healing, and armor.",
        "Druid. D 8 hit die. Wisdom caster. Nature magic and wild shape.",
        "Fighter. D 10 hit die. Master of weapons. Action Surge and Extra Attacks.",
        "Monk. D 8 hit die. Martial artist with Focus Points for special techniques.",
        "Paladin. D 10 hit die. Holy warrior. Charisma caster with divine smite.",
        "Ranger. D 10 hit die. Wilderness warrior. Wisdom caster with favored enemies.",
        "Rogue. D 8 hit die. Stealthy striker. Sneak Attack for massive single-target damage.",
        "Sorcerer. D 6 hit die. Charisma caster. Innate magic with metamagic.",
        "Warlock. D 8 hit die. Pact magic with eldritch invocations.",
        "Wizard. D 6 hit die. Intelligence caster. Largest spell list. Arcane mastery.",
        "Artificer. D 8 hit die. Intelligence caster. Magical inventor with infusions."
    };
    for (uint i = 0; i < classes.length(); i++) class_menu.add_item(class_desc[i]);
    int class_pick = creation_menu_run(class_menu);
    if (class_pick < 0 or class_pick >= int(classes.length())) return false;
    created_char_class = classes[class_pick];
    speak("You chose " + created_char_class + ".", true);
    return true;
}

bool choose_level_step(string profile = "sandbox", int forced_level = -1) {
    if (profile == "adventure") {
        created_char_level = forced_level > 0 ? forced_level : 1;
        speak("Adventure characters use your current Adventure level of " + created_char_level + ".", true);
        return true;
    }
    menu@ level_menu = setup_sub_menu("Choose your level. 1 through 20.");
    for (int lv = 1; lv <= 20; lv++) level_menu.add_item("Level " + lv);
    int level_pick = creation_menu_run(level_menu);
    if (level_pick < 0 or level_pick >= 20) return false;
    created_char_level = level_pick + 1;
    speak("Level " + created_char_level + ".", true);
    return true;
}

bool assign_ability_scores_step() {
    int[] previous_scores = created_ability_scores;
    int[] standard = {15, 14, 13, 12, 10, 8};
    bool[] used = {false, false, false, false, false, false};
    speak("Assign ability scores using the standard array: 15, 14, 13, 12, 10, 8.", true);
    for (int a = 0; a < 6; a++) {
        string ability_name = ABILITY_NAMES[a];
        string available = "";
        menu@ score_menu = setup_sub_menu("Assign a score to " + ability_name + ".");
        int[] remaining_scores;
        for (uint s = 0; s < 6; s++) {
            if (used[s]) continue;
            if (available != "") available += ", ";
            available += standard[s];
            score_menu.add_item("" + standard[s]);
            remaining_scores.insert_last(standard[s]);
        }
        score_menu.intro_text = "Assign a score to " + ability_name + ". Available: " + available + ".";
        int pick = creation_menu_run(score_menu);
        if (pick < 0 or pick >= int(remaining_scores.length())) {
            created_ability_scores = previous_scores;
            return false;
        }
        created_ability_scores[a] = remaining_scores[pick];
        for (uint s = 0; s < 6; s++) {
            if (!used[s] and standard[s] == remaining_scores[pick]) {
                used[s] = true;
                break;
            }
        }
        speak(ability_name + " set to " + created_ability_scores[a] + ".", false);
    }
    created_pre_progression_ability_scores = created_ability_scores;
    return true;
}

