#include "../../common/combat_constants.nvgt"
#include "../../common/feat_data.nvgt"

string created_char_name = "";
string created_char_race = "";
string created_char_class = "";
string created_char_subclass = "";
string created_char_background = "";
int created_char_level = 1;
int[] created_ability_scores = {10,10,10,10,10,10};
string created_weapon = "Longsword";
int created_weapon_range = 5;
string[] created_cantrips;
string[] created_spells;
string[] created_bonus_cantrips;
string[] created_bonus_spells;
string[] created_char_feats;
string[] created_char_skill_proficiencies;
string[] created_char_tool_proficiencies;
string[] created_spellcasting_override_spells;
int[] created_spellcasting_override_abilities;
string[] created_free_cast_spells;
bool creation_back_requested = false;
int[] created_pre_progression_ability_scores = {10,10,10,10,10,10};

string active_character_profile = "sandbox";

string sandbox_char_name = "";
string sandbox_char_race = "";
string sandbox_char_class = "";
string sandbox_char_subclass = "";
int sandbox_char_level = 1;
int[] sandbox_ability_scores = {10,10,10,10,10,10};
string sandbox_weapon = "Longsword";
string[] sandbox_cantrips;
string[] sandbox_spells;

string adventure_char_name = "";
string adventure_char_race = "";
string adventure_char_class = "";
string adventure_char_subclass = "";
int adventure_char_level = 1;
int[] adventure_ability_scores = {10,10,10,10,10,10};
string adventure_weapon = "Longsword";
string[] adventure_cantrips;
string[] adventure_spells;

void add_text_pair(string[]@ names, string[]@ descriptions, string name, string description) {
    names.insert_last(name);
    descriptions.insert_last(description);
}

string normalize_character_profile(string profile) {
    string lc = profile.lower();
    if (lc == "adventure") return "adventure";
    return "sandbox";
}

string character_profile_display_name(string profile) {
    return normalize_character_profile(profile) == "adventure" ? "Adventure" : "Sandbox";
}

void copy_string_array(string[]@ source, string[]@ target) {
    target.resize(0);
    if (@source == null) return;
    for (uint i = 0; i < source.length(); i++) target.insert_last(source[i]);
}

void parse_spell_csv(string csv, string[]@ target) {
    target.resize(0);
    if (csv == "") return;
    string[]@ parts = csv.split(",");
    for (uint i = 0; i < parts.length(); i++) {
        if (parts[i] != "") target.insert_last(parts[i]);
    }
}

void clear_character_buffer() {
    created_char_name = "";
    created_char_race = "";
    created_char_class = "";
    created_char_subclass = "";
    created_char_background = "";
    created_char_level = 1;
    created_ability_scores = {10,10,10,10,10,10};
    created_pre_progression_ability_scores = {10,10,10,10,10,10};
    created_weapon = "Longsword";
    created_weapon_range = 5;
    created_cantrips.resize(0);
    created_spells.resize(0);
    created_bonus_cantrips.resize(0);
    created_bonus_spells.resize(0);
    created_char_feats.resize(0);
    created_char_skill_proficiencies.resize(0);
    created_char_tool_proficiencies.resize(0);
    created_spellcasting_override_spells.resize(0);
    created_spellcasting_override_abilities.resize(0);
    created_free_cast_spells.resize(0);
}

bool buffer_has_character() {
    return created_char_class != "";
}

void clear_profile_cache(string profile) {
    profile = normalize_character_profile(profile);
    if (profile == "adventure") {
        adventure_char_name = "";
        adventure_char_race = "";
        adventure_char_class = "";
        adventure_char_subclass = "";
        adventure_char_level = 1;
        adventure_ability_scores = {10,10,10,10,10,10};
        adventure_weapon = "Longsword";
        adventure_cantrips.resize(0);
        adventure_spells.resize(0);
        return;
    }
    sandbox_char_name = "";
    sandbox_char_race = "";
    sandbox_char_class = "";
    sandbox_char_subclass = "";
    sandbox_char_level = 1;
    sandbox_ability_scores = {10,10,10,10,10,10};
    sandbox_weapon = "Longsword";
    sandbox_cantrips.resize(0);
    sandbox_spells.resize(0);
}

bool profile_has_character(string profile) {
    profile = normalize_character_profile(profile);
    return profile == "adventure" ? adventure_char_class != "" : sandbox_char_class != "";
}

bool has_any_character_profile() {
    return profile_has_character("adventure") or profile_has_character("sandbox");
}

void load_profile_cache_to_buffer(string profile) {
    profile = normalize_character_profile(profile);
    clear_character_buffer();
    if (!profile_has_character(profile)) return;

    if (profile == "adventure") {
        created_char_name = adventure_char_name;
        created_char_race = adventure_char_race;
        created_char_class = adventure_char_class;
        created_char_subclass = adventure_char_subclass;
        created_char_level = adventure_char_level;
        created_ability_scores = adventure_ability_scores;
        created_weapon = adventure_weapon;
        copy_string_array(adventure_cantrips, created_cantrips);
        copy_string_array(adventure_spells, created_spells);
        return;
    }

    created_char_name = sandbox_char_name;
    created_char_race = sandbox_char_race;
    created_char_class = sandbox_char_class;
    created_char_subclass = sandbox_char_subclass;
    created_char_level = sandbox_char_level;
    created_ability_scores = sandbox_ability_scores;
    created_weapon = sandbox_weapon;
    copy_string_array(sandbox_cantrips, created_cantrips);
    copy_string_array(sandbox_spells, created_spells);
}

void store_buffer_to_profile_cache(string profile) {
    profile = normalize_character_profile(profile);
    clear_profile_cache(profile);
    if (!buffer_has_character()) return;

    if (profile == "adventure") {
        adventure_char_name = created_char_name;
        adventure_char_race = created_char_race;
        adventure_char_class = created_char_class;
        adventure_char_subclass = created_char_subclass;
        adventure_char_level = created_char_level;
        adventure_ability_scores = created_ability_scores;
        adventure_weapon = created_weapon;
        copy_string_array(created_cantrips, adventure_cantrips);
        copy_string_array(created_spells, adventure_spells);
        return;
    }

    sandbox_char_name = created_char_name;
    sandbox_char_race = created_char_race;
    sandbox_char_class = created_char_class;
    sandbox_char_subclass = created_char_subclass;
    sandbox_char_level = created_char_level;
    sandbox_ability_scores = created_ability_scores;
    sandbox_weapon = created_weapon;
    copy_string_array(created_cantrips, sandbox_cantrips);
    copy_string_array(created_spells, sandbox_spells);
}

void set_active_character_profile(string profile) {
    active_character_profile = normalize_character_profile(profile);
    load_profile_cache_to_buffer(active_character_profile);
}

void update_profile_level(string profile, int level) {
    profile = normalize_character_profile(profile);
    if (level < 1) level = 1;
    if (profile == "adventure") adventure_char_level = level;
    else sandbox_char_level = level;
    if (active_character_profile == profile and buffer_has_character()) created_char_level = level;
}

void apply_character_message_to_profile(string profile, json_object@ msg) {
    profile = normalize_character_profile(profile);
    clear_profile_cache(profile);
    if (@msg == null) return;

    string local_name = msg.exists("name") ? string(msg["name"]) : "";
    string local_race = msg.exists("race") ? string(msg["race"]) : "";
    string local_class = msg.exists("class") ? string(msg["class"]) : "";
    string local_subclass = msg.exists("subclass") ? string(msg["subclass"]) : "";
    int local_level = msg.exists("level") ? int(msg["level"]) : 1;
    int[] local_scores = {10,10,10,10,10,10};
    if (msg.exists("str")) local_scores[0] = int(msg["str"]);
    if (msg.exists("dex")) local_scores[1] = int(msg["dex"]);
    if (msg.exists("con")) local_scores[2] = int(msg["con"]);
    if (msg.exists("int")) local_scores[3] = int(msg["int"]);
    if (msg.exists("wis")) local_scores[4] = int(msg["wis"]);
    if (msg.exists("cha")) local_scores[5] = int(msg["cha"]);
    string local_weapon = msg.exists("weapon") ? string(msg["weapon"]) : "Longsword";
    string[] local_cantrips;
    string[] local_spells;
    if (msg.exists("cantrips")) parse_spell_csv(string(msg["cantrips"]), local_cantrips);
    if (msg.exists("spells")) parse_spell_csv(string(msg["spells"]), local_spells);

    if (profile == "adventure") {
        adventure_char_name = local_name;
        adventure_char_race = local_race;
        adventure_char_class = local_class;
        adventure_char_subclass = local_subclass;
        adventure_char_level = local_level;
        adventure_ability_scores = local_scores;
        adventure_weapon = local_weapon;
        copy_string_array(local_cantrips, adventure_cantrips);
        copy_string_array(local_spells, adventure_spells);
    } else {
        sandbox_char_name = local_name;
        sandbox_char_race = local_race;
        sandbox_char_class = local_class;
        sandbox_char_subclass = local_subclass;
        sandbox_char_level = local_level;
        sandbox_ability_scores = local_scores;
        sandbox_weapon = local_weapon;
        copy_string_array(local_cantrips, sandbox_cantrips);
        copy_string_array(local_spells, sandbox_spells);
    }

    if (active_character_profile == profile or !profile_has_character(active_character_profile)) {
        set_active_character_profile(profile);
    }
}

int progression_value(int[]@ values, int level) {
    if (@values == null or values.length() == 0) return 0;
    int index = level - 1;
    if (index < 0) index = 0;
    if (index >= int(values.length())) index = values.length() - 1;
    return values[index];
}

bool string_array_contains(string[]@ values, string needle) {
    if (@values == null) return false;
    for (uint i = 0; i < values.length(); i++) {
        if (values[i] == needle) return true;
    }
    return false;
}

void add_spell_id_once(string[]@ values, string spell_id) {
    if (@values == null or spell_id == "") return;
    if (!string_array_contains(values, spell_id)) values.insert_last(spell_id);
}

string join_spell_names(string[]@ spell_ids) {
    if (@spell_ids == null or spell_ids.length() == 0) return "";
    string result = "";
    for (uint i = 0; i < spell_ids.length(); i++) {
        if (i > 0) result += ", ";
        result += spell_display_name(spell_ids[i]);
    }
    return result;
}

string join_string_list(string[]@ values) {
    if (@values == null or values.length() == 0) return "";
    string result = "";
    for (uint i = 0; i < values.length(); i++) {
        if (i > 0) result += ", ";
        result += values[i];
    }
    return result;
}

string join_csv_list(string[]@ values) {
    if (@values == null or values.length() == 0) return "";
    string result = "";
    for (uint i = 0; i < values.length(); i++) {
        if (values[i] == "") continue;
        if (result != "") result += ",";
        result += values[i];
    }
    return result;
}

void parse_csv_into_string_array(string csv, string[]@ out_values) {
    out_values.resize(0);
    if (csv == "" or @out_values == null) return;
    string[]@ parts = csv.split(",");
    for (uint i = 0; i < parts.length(); i++) {
        if (parts[i] != "") out_values.insert_last(parts[i]);
    }
}

void clear_creation_back_request() {
    creation_back_requested = false;
}

bool creation_should_go_back() {
    return creation_back_requested;
}

int creation_menu_run(menu@ m) {
    if (@m == null) {
        creation_back_requested = true;
        return -1;
    }
    int back_item = m.add_item("Go back.");
    int pick = m.run();
    if (pick < 0 or pick == back_item) {
        creation_back_requested = true;
        return -1;
    }
    return pick;
}

string join_spell_override_specs() {
    if (created_spellcasting_override_spells.length() == 0) return "";
    string result = "";
    for (uint i = 0; i < created_spellcasting_override_spells.length(); i++) {
        if (i > 0) result += ",";
        result += created_spellcasting_override_spells[i] + ":" + ability_key_from_id(created_spellcasting_override_abilities[i]);
    }
    return result;
}

void add_tool_proficiency_once(string tool_name) {
    if (tool_name == "") return;
    if (!string_array_contains(created_char_tool_proficiencies, tool_name)) created_char_tool_proficiencies.insert_last(tool_name);
}

void add_skill_proficiency_once(string skill_name) {
    if (skill_name == "") return;
    if (!string_array_contains(created_char_skill_proficiencies, skill_name)) created_char_skill_proficiencies.insert_last(skill_name);
}

void add_spell_override_once(string spell_id, int ability_id) {
    if (spell_id == "" or ability_id < 0 or ability_id > 5) return;
    for (uint i = 0; i < created_spellcasting_override_spells.length(); i++) {
        if (created_spellcasting_override_spells[i] == spell_id) {
            created_spellcasting_override_abilities[i] = ability_id;
            return;
        }
    }
    created_spellcasting_override_spells.insert_last(spell_id);
    created_spellcasting_override_abilities.insert_last(ability_id);
}

bool feat_selected(string feat_id) {
    return string_array_contains(created_char_feats, feat_id);
}

int count_selected_feat(string feat_id) {
    int count = 0;
    for (uint i = 0; i < created_char_feats.length(); i++) {
        if (created_char_feats[i] == feat_id) count++;
    }
    return count;
}

bool character_has_spellcasting_feature_for_creation() {
    string lc = created_char_class.lower();
    if (lc == "bard" or lc == "cleric" or lc == "druid" or lc == "paladin" or lc == "ranger" or lc == "sorcerer" or lc == "warlock" or lc == "wizard" or lc == "artificer") return true;
    return is_third_caster_subclass_choice(created_char_class, created_char_subclass) and created_char_level >= 3;
}

bool character_has_fighting_style_feature() {
    if (created_char_class == "Fighter" and created_char_level >= 1) return true;
    if (created_char_class == "Paladin" and created_char_level >= 2) return true;
    if (created_char_class == "Ranger" and created_char_level >= 2) return true;
    return false;
}

int count_general_feat_slots(string class_name, int level) {
    int count = 0;
    if (level >= 4) count++;
    if (level >= 8) count++;
    if (level >= 12) count++;
    if (level >= 16) count++;
    if (level >= 19) count++;
    if (class_name == "Fighter") {
        if (level >= 6) count++;
        if (level >= 14) count++;
    } else if (class_name == "Rogue") {
        if (level >= 10) count++;
    }
    return count;
}

bool can_raise_ability_score(int ability_id, int cap = 20) {
    if (ability_id < 0 or ability_id >= int(created_ability_scores.length())) return false;
    return created_ability_scores[ability_id] < cap;
}

void apply_ability_increase(int ability_id, int amount, int cap = 20) {
    if (ability_id < 0 or ability_id >= int(created_ability_scores.length()) or amount <= 0) return;
    created_ability_scores[ability_id] += amount;
    if (created_ability_scores[ability_id] > cap) created_ability_scores[ability_id] = cap;
}

int choose_ability_from_ids(string prompt, int[]@ ability_ids) {
    menu@ m = setup_sub_menu(prompt);
    int[] options;
    for (uint i = 0; i < ability_ids.length(); i++) {
        int ability_id = ability_ids[i];
        if (ability_id < 0 or ability_id > 5) continue;
        m.add_item(ABILITY_NAMES[ability_id] + ". Current score " + created_ability_scores[ability_id] + ".");
        options.insert_last(ability_id);
    }
    int pick = m.run();
    if (pick < 0 or pick >= int(options.length())) return -1;
    return options[pick];
}

void choose_skill_proficiencies_step(int picks, string prompt) {
    if (picks <= 0) return;
    init_feat_data();
    for (int choice = 0; choice < picks; choice++) {
        menu@ m = setup_sub_menu(prompt + " " + (choice + 1) + " of " + picks + ".");
        string[] option_names;
        for (uint i = 0; i < SKILL_CHOICES.length(); i++) {
            if (string_array_contains(created_char_skill_proficiencies, SKILL_CHOICES[i].name)) continue;
            m.add_item(SKILL_CHOICES[i].name + ". " + SKILL_CHOICES[i].description);
            option_names.insert_last(SKILL_CHOICES[i].name);
        }
        if (option_names.length() == 0) {
            speak("No more skills are available to choose.", false);
            return;
        }
        int pick = creation_menu_run(m);
        if (pick < 0 or pick >= int(option_names.length())) return;
        add_skill_proficiency_once(option_names[pick]);
        speak(option_names[pick] + " proficiency gained.", false);
    }
}

void choose_skilled_proficiencies_step() {
    string[] tool_options = {
        "Artisan's Tools",
        "Calligrapher's Supplies",
        "Gaming Set",
        "Healer's Kit",
        "Musical Instrument",
        "Thieves' Tools"
    };
    for (int choice = 0; choice < 3; choice++) {
        menu@ m = setup_sub_menu("Choose Skilled proficiency " + (choice + 1) + " of 3.");
        string[] entry_types;
        string[] entry_values;
        for (uint i = 0; i < SKILL_CHOICES.length(); i++) {
            if (string_array_contains(created_char_skill_proficiencies, SKILL_CHOICES[i].name)) continue;
            m.add_item("Skill: " + SKILL_CHOICES[i].name + ". " + SKILL_CHOICES[i].description);
            entry_types.insert_last("skill");
            entry_values.insert_last(SKILL_CHOICES[i].name);
        }
        for (uint i = 0; i < tool_options.length(); i++) {
            if (string_array_contains(created_char_tool_proficiencies, tool_options[i])) continue;
            m.add_item("Tool: " + tool_options[i] + ".");
            entry_types.insert_last("tool");
            entry_values.insert_last(tool_options[i]);
        }
        if (entry_values.length() == 0) {
            speak("No more skills or tools are available to choose.", false);
            return;
        }
        int pick = creation_menu_run(m);
        if (pick < 0 or pick >= int(entry_values.length())) return;
        if (entry_types[pick] == "skill") {
            add_skill_proficiency_once(entry_values[pick]);
            speak(entry_values[pick] + " proficiency gained.", false);
        } else {
            add_tool_proficiency_once(entry_values[pick]);
            speak(entry_values[pick] + " proficiency gained.", false);
        }
    }
}

int choose_spellcasting_ability_for_magic_initiate() {
    int[] options = {ABILITY_INT, ABILITY_WIS, ABILITY_CHA};
    return choose_ability_from_ids("Choose the spellcasting ability for this Magic Initiate feat.", options);
}

void choose_magic_initiate_step(string feat_id) {
    string list_class = feat_magic_initiate_list_class(feat_id);
    if (list_class == "") return;
    int ability_id = choose_spellcasting_ability_for_magic_initiate();
    if (ability_id < 0) ability_id = ABILITY_INT;
    build_spell_list_for_character(list_class == "cleric" ? "Cleric" : (list_class == "druid" ? "Druid" : "Wizard"), "", 1);

    for (int pick_index = 0; pick_index < 2; pick_index++) {
        menu@ m = setup_sub_menu("Choose Magic Initiate cantrip " + (pick_index + 1) + " of 2 from the " + list_class + " list.");
        string[] spell_ids;
        for (uint i = 0; i < available_spells.length(); i++) {
            client_spell@ spell = available_spells[i];
            if (@spell == null or spell.level != 0) continue;
            if (string_array_contains(created_bonus_cantrips, spell.id)) continue;
            m.add_item(spell.name + ". " + spell.description);
            spell_ids.insert_last(spell.id);
        }
        int pick = creation_menu_run(m);
        if (pick < 0 or pick >= int(spell_ids.length())) return;
        add_spell_id_once(created_bonus_cantrips, spell_ids[pick]);
        add_spell_override_once(spell_ids[pick], ability_id);
        speak("Learned " + spell_display_name(spell_ids[pick]) + " from Magic Initiate.", false);
    }

    menu@ spell_menu = setup_sub_menu("Choose your Magic Initiate level 1 spell from the " + list_class + " list.");
    string[] spell_ids;
    for (uint i = 0; i < available_spells.length(); i++) {
        client_spell@ spell = available_spells[i];
        if (@spell == null or spell.level != 1) continue;
        if (string_array_contains(created_bonus_spells, spell.id)) continue;
        spell_menu.add_item(spell.name + ". " + spell.description);
        spell_ids.insert_last(spell.id);
    }
    int spell_pick = creation_menu_run(spell_menu);
    if (spell_pick < 0 or spell_pick >= int(spell_ids.length())) return;
    add_spell_id_once(created_bonus_spells, spell_ids[spell_pick]);
    add_spell_override_once(spell_ids[spell_pick], ability_id);
    add_spell_id_once(created_free_cast_spells, spell_ids[spell_pick]);
    speak("Prepared " + spell_display_name(spell_ids[spell_pick]) + " from Magic Initiate.", false);
}

void apply_asi_step(string reason, int cap = 20, int[]@ restricted_ids = null, bool allow_double = true) {
    int[] options;
    if (@restricted_ids != null and restricted_ids.length() > 0) {
        for (uint i = 0; i < restricted_ids.length(); i++) {
            if (restricted_ids[i] >= 0 and restricted_ids[i] <= 5) options.insert_last(restricted_ids[i]);
        }
    } else {
        options = {ABILITY_STR, ABILITY_DEX, ABILITY_CON, ABILITY_INT, ABILITY_WIS, ABILITY_CHA};
    }

    menu@ mode_menu = setup_sub_menu(reason + " Choose how to distribute the increase.");
    int plus_two_opt = mode_menu.add_item("Increase one ability score by 2.");
    int split_opt = mode_menu.add_item("Increase two ability scores by 1 each.");
    int mode = creation_menu_run(mode_menu);
    if (creation_should_go_back()) return;
    if (mode == plus_two_opt and allow_double) {
        int first = choose_ability_from_ids("Choose the ability score to increase by 2.", options);
        if (first >= 0) {
            apply_ability_increase(first, 2, cap);
            speak(ABILITY_NAMES[first] + " increased to " + created_ability_scores[first] + ".", false);
        }
        return;
    }

    int first = choose_ability_from_ids("Choose the first ability score to increase by 1.", options);
    if (first < 0) return;
    apply_ability_increase(first, 1, cap);
    int[] remaining;
    for (uint i = 0; i < options.length(); i++) {
        if (options[i] != first) remaining.insert_last(options[i]);
    }
    int second = choose_ability_from_ids("Choose the second ability score to increase by 1.", remaining);
    if (second >= 0) apply_ability_increase(second, 1, cap);
    speak("Updated scores: " + ABILITY_NAMES[first] + " " + created_ability_scores[first] + (second >= 0 ? ", " + ABILITY_NAMES[second] + " " + created_ability_scores[second] : "") + ".", false);
}

bool can_take_feat_now(string feat_id, bool origin_only = false, bool for_general_slot = false) {
    feat_choice_def@ feat = get_feat_choice(feat_id);
    if (@feat == null) return false;
    if (origin_only and feat.category != FEAT_CATEGORY_ORIGIN) return false;
    if (!feat.repeatable and feat_selected(feat_id)) return false;
    if (created_char_level < feat.min_level) return false;
    if (feat.requires_fighting_style_feature and !character_has_fighting_style_feature()) return false;
    if (feat.requires_spellcasting and !character_has_spellcasting_feature_for_creation()) return false;
    if (feat.id == "grappler" and created_ability_scores[ABILITY_STR] < 13 and created_ability_scores[ABILITY_DEX] < 13) return false;
    if (feat.id == "boon_of_irresistible_offense" and created_char_level < 19) return false;
    if (feat.id == "boon_of_combat_prowess" and created_char_level < 19) return false;
    if (feat.id == "boon_of_spell_recall" and (created_char_level < 19 or !character_has_spellcasting_feature_for_creation())) return false;
    if (feat.id == "boon_of_truesight" and created_char_level < 19) return false;
    if (feat_is_magic_initiate(feat_id) and feat_selected(feat_id)) return false;
    return true;
}

string feat_display_name(string feat_id) {
    feat_choice_def@ feat = get_feat_choice(feat_id);
    if (@feat == null) return feat_id;
    return feat.name;
}

string join_feat_names(string[]@ feat_ids) {
    if (@feat_ids == null or feat_ids.length() == 0) return "";
    string result = "";
    for (uint i = 0; i < feat_ids.length(); i++) {
        if (i > 0) result += ", ";
        result += feat_display_name(feat_ids[i]);
    }
    return result;
}

void gain_feat(string feat_id, bool announce = true) {
    feat_choice_def@ feat = get_feat_choice(feat_id);
    if (@feat == null) return;
    if (!feat.repeatable and feat_selected(feat_id)) return;
    created_char_feats.insert_last(feat_id);
    if (announce) speak("Gained feat: " + feat.name + ".", true);

    if (feat_id == "skilled") {
        choose_skilled_proficiencies_step();
    } else if (feat_is_magic_initiate(feat_id)) {
        choose_magic_initiate_step(feat_id);
    } else if (feat_id == "grappler") {
        int[] grapple_ids = {ABILITY_STR, ABILITY_DEX};
        int ability_id = choose_ability_from_ids("Grappler increases Strength or Dexterity by 1.", grapple_ids);
        if (ability_id >= 0) {
            apply_ability_increase(ability_id, 1, 20);
            speak(ABILITY_NAMES[ability_id] + " increased to " + created_ability_scores[ability_id] + ".", false);
        }
    } else if (feat_id == "ability_score_improvement") {
        apply_asi_step("Ability Score Improvement.", 20);
    } else if (feat_id == "boon_of_combat_prowess" or feat_id == "boon_of_truesight") {
        int[] any_ids = {ABILITY_STR, ABILITY_DEX, ABILITY_CON, ABILITY_INT, ABILITY_WIS, ABILITY_CHA};
        int ability_id = choose_ability_from_ids(feat.name + " increases one ability score by 1.", any_ids);
        if (ability_id >= 0) apply_ability_increase(ability_id, 1, 30);
    } else if (feat_id == "boon_of_irresistible_offense") {
        int[] offense_ids = {ABILITY_STR, ABILITY_DEX};
        int ability_id = choose_ability_from_ids("Boon of Irresistible Offense increases Strength or Dexterity by 1.", offense_ids);
        if (ability_id >= 0) apply_ability_increase(ability_id, 1, 30);
    } else if (feat_id == "boon_of_spell_recall") {
        int[] mental_ids = {ABILITY_INT, ABILITY_WIS, ABILITY_CHA};
        int ability_id = choose_ability_from_ids("Boon of Spell Recall increases Intelligence, Wisdom, or Charisma by 1.", mental_ids);
        if (ability_id >= 0) apply_ability_increase(ability_id, 1, 30);
    }
}

void choose_origin_feat_step(string prompt) {
    init_feat_data();
    menu@ m = setup_sub_menu(prompt);
    string[] feat_ids;
    for (uint i = 0; i < FEAT_CHOICES.length(); i++) {
        feat_choice_def@ feat = FEAT_CHOICES[i];
        if (@feat == null or feat.category != FEAT_CATEGORY_ORIGIN) continue;
        if (!can_take_feat_now(feat.id, true, false)) continue;
        m.add_item(feat.name + ". " + feat.description);
        feat_ids.insert_last(feat.id);
    }
    int pick = creation_menu_run(m);
    if (pick < 0 or pick >= int(feat_ids.length())) return;
    gain_feat(feat_ids[pick], true);
}

void choose_background_step() {
    init_feat_data();
    menu@ background_menu = setup_sub_menu("Choose your background. Backgrounds now provide your ability score increases and your starting feat.");
    string[] background_ids;
    for (uint i = 0; i < BACKGROUND_CHOICES.length(); i++) {
        background_choice_def@ bg = BACKGROUND_CHOICES[i];
        if (@bg == null) continue;
        background_menu.add_item(bg.description);
        background_ids.insert_last(bg.id);
    }
    int pick = creation_menu_run(background_menu);
    if (pick < 0 or pick >= int(background_ids.length())) return;
    created_char_background = background_ids[pick];
    background_choice_def@ selected = get_background_choice(created_char_background);
    if (@selected != null) speak("You chose the " + selected.name + " background.", true);
}

void apply_background_ability_scores_step() {
    background_choice_def@ bg = get_background_choice(created_char_background);
    if (@bg == null) return;
    string[]@ keys = bg.ability_csv.split(",");
    int[] options;
    string option_text = "";
    for (uint i = 0; i < keys.length(); i++) {
        int ability_id = ability_id_from_key(keys[i]);
        if (ability_id < 0) continue;
        options.insert_last(ability_id);
        if (option_text != "") option_text += ", ";
        option_text += ABILITY_NAMES[ability_id];
    }
    apply_asi_step("Background ability increases from " + bg.name + ". Choose from " + option_text + ".", 20, options, true);
}

void apply_background_training_and_feat_step() {
    background_choice_def@ bg = get_background_choice(created_char_background);
    if (@bg == null) return;
    for (uint i = 0; i < bg.skills.length(); i++) add_skill_proficiency_once(bg.skills[i]);
    add_tool_proficiency_once(bg.tool_name);
    speak(bg.name + " grants skills: " + join_string_list(bg.skills) + ".", false);
    if (bg.tool_name != "") speak(bg.name + " grants tool proficiency with " + bg.tool_name + ".", false);
    if (bg.feat_id != "") gain_feat(bg.feat_id, true);
}

void apply_human_species_step() {
    if (created_char_race != "Human") return;
    speak("Human traits: Skillful and Versatile. Choose one skill proficiency and one extra Origin feat.", true);
    choose_skill_proficiencies_step(1, "Choose your Human skill proficiency.");
    choose_origin_feat_step("Choose your extra Human Origin feat.");
}

void choose_fighting_style_step() {
    if (!character_has_fighting_style_feature()) return;
    menu@ m = setup_sub_menu("Choose your Fighting Style feat.");
    string[] feat_ids;
    string[] choices = {"archery", "defense", "great_weapon_fighting", "two_weapon_fighting"};
    for (uint i = 0; i < choices.length(); i++) {
        if (!can_take_feat_now(choices[i], false, false)) continue;
        feat_choice_def@ feat = get_feat_choice(choices[i]);
        if (@feat == null) continue;
        m.add_item(feat.name + ". " + feat.description);
        feat_ids.insert_last(choices[i]);
    }
    int pick = creation_menu_run(m);
    if (pick < 0 or pick >= int(feat_ids.length())) return;
    gain_feat(feat_ids[pick], true);
}

void choose_general_feat_steps() {
    int picks = count_general_feat_slots(created_char_class, created_char_level);
    if (picks <= 0) return;
    init_feat_data();
    for (int feat_pick = 0; feat_pick < picks; feat_pick++) {
        menu@ m = setup_sub_menu("Choose feat " + (feat_pick + 1) + " of " + picks + ".");
        string[] feat_ids;
        for (uint i = 0; i < FEAT_CHOICES.length(); i++) {
            feat_choice_def@ feat = FEAT_CHOICES[i];
            if (@feat == null) continue;
            if (!can_take_feat_now(feat.id, false, true)) continue;
            m.add_item(feat.name + ". " + feat.description);
            feat_ids.insert_last(feat.id);
        }
        int pick = creation_menu_run(m);
        if (pick < 0 or pick >= int(feat_ids.length())) return;
        gain_feat(feat_ids[pick], true);
    }
}

bool is_third_caster_subclass_choice(string class_name, string subclass_name) {
    return (class_name == "Fighter" and subclass_name == "Eldritch Knight") or (class_name == "Rogue" and subclass_name == "Arcane Trickster");
}

int get_cantrips_known(string class_name, string subclass_name, int level) {
    string lc = class_name.lower();
    if (lc == "bard") { if (level >= 10) return 4; if (level >= 4) return 3; return 2; }
    if (lc == "cleric") { if (level >= 10) return 5; if (level >= 4) return 4; return 3; }
    if (lc == "druid") { if (level >= 10) return 4; if (level >= 4) return 3; return 2; }
    if (lc == "sorcerer") { if (level >= 10) return 6; if (level >= 4) return 5; return 4; }
    if (lc == "warlock") { if (level >= 10) return 4; if (level >= 4) return 3; return 2; }
    if (lc == "wizard") { if (level >= 10) return 5; if (level >= 4) return 4; return 3; }
    if (lc == "artificer") { if (level >= 14) return 4; if (level >= 10) return 3; return 2; }
    if (is_third_caster_subclass_choice(class_name, subclass_name) and level >= 3) {
        if (level >= 10) return 3;
        return 2;
    }
    return 0;
}

int get_prepared_spells(string class_name, string subclass_name, int level) {
    string lc = class_name.lower();
    int[] bard_prepared = {4,5,6,7,9,10,11,12,14,15,16,16,17,17,18,18,19,20,21,22};
    int[] cleric_prepared = {4,5,6,7,9,10,11,12,14,15,16,16,17,17,18,18,19,20,21,22};
    int[] druid_prepared = {4,5,6,7,9,10,11,12,14,15,16,16,17,17,18,18,19,20,21,22};
    int[] sorcerer_prepared = {2,4,6,7,9,10,11,12,14,15,16,16,17,17,18,18,19,20,21,22};
    int[] warlock_prepared = {2,3,4,5,6,7,8,9,10,10,11,11,12,12,13,13,14,14,15,15};
    int[] wizard_prepared = {4,5,6,7,9,10,11,12,14,15,16,16,17,18,19,21,22,23,24,25};
    int[] half_caster_prepared = {2,3,4,5,6,6,7,7,9,9,10,10,11,11,12,12,14,14,15,15};
    int[] third_caster_known = {0,0,3,4,4,4,5,6,6,7,8,8,9,10,10,11,11,11,12,13};

    if (lc == "bard") return progression_value(bard_prepared, level);
    if (lc == "cleric") return progression_value(cleric_prepared, level);
    if (lc == "druid") return progression_value(druid_prepared, level);
    if (lc == "sorcerer") return progression_value(sorcerer_prepared, level);
    if (lc == "wizard") return progression_value(wizard_prepared, level);
    if (lc == "warlock") {
        return progression_value(warlock_prepared, level);
    }
    if (lc == "paladin" or lc == "ranger" or lc == "artificer") {
        return progression_value(half_caster_prepared, level);
    }
    if (is_third_caster_subclass_choice(class_name, subclass_name)) return progression_value(third_caster_known, level);
    return 0;
}

string get_restricted_school_csv(string class_name, string subclass_name) {
    if (class_name == "Fighter" and subclass_name == "Eldritch Knight") return "abjuration,evocation";
    if (class_name == "Rogue" and subclass_name == "Arcane Trickster") return "enchantment,illusion";
    return "";
}

int get_any_school_spell_allowance(string class_name, string subclass_name, int level) {
    if (!is_third_caster_subclass_choice(class_name, subclass_name)) return 0;
    if (level >= 20) return 4;
    if (level >= 14) return 3;
    if (level >= 8) return 2;
    if (level >= 3) return 1;
    return 0;
}

void choose_spell_group(string prompt, int picks, int min_level, int max_level, string school_filter, string[]@ selected_spells) {
    if (picks <= 0 or @selected_spells == null) return;

    for (int pick_index = 0; pick_index < picks; pick_index++) {
        menu@ spell_menu = setup_sub_menu(prompt + " " + (pick_index + 1) + " of " + picks + ".");
        string[] spell_ids;

        for (uint si = 0; si < available_spells.length(); si++) {
            client_spell@ spell = available_spells[si];
            if (@spell == null) continue;
            if (spell.level < min_level or spell.level > max_level) continue;
            if (!client_spell_has_any_school(spell, school_filter)) continue;
            if (string_array_contains(selected_spells, spell.id)) continue;
            spell_menu.add_item("Level " + spell.level + ": " + spell.name + ". " + spell.description);
            spell_ids.insert_last(spell.id);
        }

        if (spell_ids.length() == 0) {
            speak("No more spells are available for that choice.", false);
            break;
        }

        int pick = creation_menu_run(spell_menu);
        if (pick < 0 or pick >= int(spell_ids.length())) {
            speak("Selection finished early.", false);
            break;
        }

        selected_spells.insert_last(spell_ids[pick]);
        speak("Learned " + spell_display_name(spell_ids[pick]) + ".", false);
    }
}

void choose_cantrip_group(int picks) {
    if (picks <= 0) return;

    for (int pick_index = 0; pick_index < picks; pick_index++) {
        menu@ cantrip_menu = setup_sub_menu("Choose cantrip " + (pick_index + 1) + " of " + picks + ".");
        string[] cantrip_ids;

        for (uint si = 0; si < available_spells.length(); si++) {
            client_spell@ spell = available_spells[si];
            if (@spell == null or spell.level != 0) continue;
            if (string_array_contains(created_cantrips, spell.id)) continue;
            cantrip_menu.add_item(spell.name + ". " + spell.description);
            cantrip_ids.insert_last(spell.id);
        }

        if (cantrip_ids.length() == 0) {
            speak("No more cantrips are available.", false);
            break;
        }

        int pick = creation_menu_run(cantrip_menu);
        if (pick < 0 or pick >= int(cantrip_ids.length())) {
            speak("Cantrip selection finished early.", false);
            break;
        }

        created_cantrips.insert_last(cantrip_ids[pick]);
        speak("Learned " + spell_display_name(cantrip_ids[pick]) + ".", false);
    }
}

void append_auto_granted_cantrips() {
    if (created_char_race == "Tiefling") {
        add_spell_id_once(created_cantrips, "thaumaturgy");
        speak("Your Tiefling heritage grants you Thaumaturgy.", false);
    }
    if (created_char_class == "Rogue" and created_char_subclass == "Arcane Trickster") {
        add_spell_id_once(created_cantrips, "mage_hand");
        speak("Arcane Trickster grants you Mage Hand automatically.", false);
    }
}

void spell_selection_step() {
    int cantrips_to_pick = get_cantrips_known(created_char_class, created_char_subclass, created_char_level);
    int spells_to_pick = get_prepared_spells(created_char_class, created_char_subclass, created_char_level);
    int max_spell_level = get_max_spell_level_for_character(created_char_class, created_char_subclass, created_char_level);

    if (cantrips_to_pick == 0 and spells_to_pick == 0) {
        created_cantrips = created_bonus_cantrips;
        created_spells = created_bonus_spells;
        append_auto_granted_cantrips();
        if (created_cantrips.length() == 0 and created_spells.length() == 0) speak(created_char_class + " currently has no spell selection at this level.", false);
        return;
    }

    created_cantrips = created_bonus_cantrips;
    created_spells = created_bonus_spells;
    append_auto_granted_cantrips();

    build_spell_list_for_character(created_char_class, created_char_subclass, created_char_level);

    string intro = "Spell selection for " + created_char_class;
    if (created_char_subclass != "") intro += " " + created_char_subclass;
    intro += " at level " + created_char_level + ".";
    if (cantrips_to_pick > 0) intro += " Choose " + cantrips_to_pick + " cantrips.";
    if (spells_to_pick > 0) intro += " Choose " + spells_to_pick + " spells up to level " + max_spell_level + ".";
    speak(intro, true);

    if (created_bonus_cantrips.length() > 0 or created_bonus_spells.length() > 0) {
        string bonus_text = "";
        if (created_bonus_cantrips.length() > 0) bonus_text += "Bonus cantrips: " + join_spell_names(created_bonus_cantrips) + ". ";
        if (created_bonus_spells.length() > 0) bonus_text += "Bonus spells: " + join_spell_names(created_bonus_spells) + ".";
        speak(bonus_text, false);
    }
    if (created_cantrips.length() > created_bonus_cantrips.length()) {
        speak("Automatic cantrips: " + join_spell_names(created_cantrips) + ".", false);
    }

    choose_cantrip_group(cantrips_to_pick);

    if (spells_to_pick > 0) {
        string restricted_schools = get_restricted_school_csv(created_char_class, created_char_subclass);
        if (restricted_schools != "") {
            int any_school_allowance = get_any_school_spell_allowance(created_char_class, created_char_subclass, created_char_level);
            if (any_school_allowance > spells_to_pick) any_school_allowance = spells_to_pick;
            int restricted_picks = spells_to_pick - any_school_allowance;

            if (restricted_picks > 0) {
                string school_text = restricted_schools;
                if (restricted_schools == "abjuration,evocation") school_text = "abjuration or evocation";
                else if (restricted_schools == "enchantment,illusion") school_text = "enchantment or illusion";
                speak("First choose " + restricted_picks + " subclass spell" + (restricted_picks == 1 ? "" : "s") + " from " + school_text + ".", true);
                choose_spell_group("Choose restricted spell", restricted_picks, 1, max_spell_level, restricted_schools, created_spells);
            }
            if (any_school_allowance > 0) {
                speak("Now choose " + any_school_allowance + " spell" + (any_school_allowance == 1 ? "" : "s") + " from any school on the list.", true);
                choose_spell_group("Choose flexible spell", any_school_allowance, 1, max_spell_level, "", created_spells);
            }
        } else {
            choose_spell_group("Choose spell", spells_to_pick, 1, max_spell_level, "", created_spells);
        }
    }

    speak("You now have " + created_cantrips.length() + " cantrips and " + created_spells.length() + " prepared or known spells.", false);
}

void get_subclass_options(string class_name, string[]@ names, string[]@ descriptions) {
    names.resize(0);
    descriptions.resize(0);

    if (class_name == "Barbarian") {
        add_text_pair(names, descriptions, "Berserker", "Berserker. Unleash reckless fury and hit harder while raging.");
        add_text_pair(names, descriptions, "Wild Heart", "Wild Heart. Channel primal animal power while raging.");
        add_text_pair(names, descriptions, "World Tree", "World Tree. Draw on the roots of Yggdrasil to control the battlefield.");
        add_text_pair(names, descriptions, "Zealot", "Zealot. Fight with divine fury and relentless determination.");
    } else if (class_name == "Bard") {
        add_text_pair(names, descriptions, "College of Dance", "College of Dance. Turn movement and rhythm into magical performance.");
        add_text_pair(names, descriptions, "College of Glamour", "College of Glamour. Beguile and command with fey majesty.");
        add_text_pair(names, descriptions, "College of Lore", "College of Lore. Master wide-ranging knowledge and cutting words.");
        add_text_pair(names, descriptions, "College of Valor", "College of Valor. Support allies while fighting in the thick of battle.");
    } else if (class_name == "Cleric") {
        add_text_pair(names, descriptions, "Life Domain", "Life Domain. Restore, preserve, and protect life.");
        add_text_pair(names, descriptions, "Light Domain", "Light Domain. Wield radiant fire against darkness.");
        add_text_pair(names, descriptions, "Trickery Domain", "Trickery Domain. Use stealth, illusion, and deceit.");
        add_text_pair(names, descriptions, "War Domain", "War Domain. Lead the charge with martial divine power.");
    } else if (class_name == "Druid") {
        add_text_pair(names, descriptions, "Circle of the Land", "Circle of the Land. Draw deeper magic from a chosen environment.");
        add_text_pair(names, descriptions, "Circle of the Moon", "Circle of the Moon. Focus on stronger Wild Shape forms.");
        add_text_pair(names, descriptions, "Circle of the Sea", "Circle of the Sea. Command waves, storms, and flowing movement.");
        add_text_pair(names, descriptions, "Circle of the Stars", "Circle of the Stars. Read the heavens and take on stellar forms.");
    } else if (class_name == "Fighter") {
        add_text_pair(names, descriptions, "Battle Master", "Battle Master. Control combat with maneuvers and tactical superiority.");
        add_text_pair(names, descriptions, "Champion", "Champion. Focus on straightforward martial excellence and critical hits.");
        add_text_pair(names, descriptions, "Eldritch Knight", "Eldritch Knight. Blend weapon mastery with Wizard spellcasting.");
        add_text_pair(names, descriptions, "Psi Warrior", "Psi Warrior. Fight with disciplined psionic power.");
    } else if (class_name == "Monk") {
        add_text_pair(names, descriptions, "Warrior of Mercy", "Warrior of Mercy. Heal allies and harm foes with mystical medicine.");
        add_text_pair(names, descriptions, "Warrior of Shadow", "Warrior of Shadow. Move unseen and strike from darkness.");
        add_text_pair(names, descriptions, "Warrior of the Elements", "Warrior of the Elements. Channel elemental force through martial arts.");
        add_text_pair(names, descriptions, "Warrior of the Open Hand", "Warrior of the Open Hand. Perfect classic martial arts technique.");
    } else if (class_name == "Paladin") {
        add_text_pair(names, descriptions, "Oath of Devotion", "Oath of Devotion. Embody honesty, courage, and justice.");
        add_text_pair(names, descriptions, "Oath of Glory", "Oath of Glory. Pursue heroic achievement and inspiring deeds.");
        add_text_pair(names, descriptions, "Oath of the Ancients", "Oath of the Ancients. Preserve light, life, and beauty.");
        add_text_pair(names, descriptions, "Oath of Vengeance", "Oath of Vengeance. Hunt down the wicked with relentless purpose.");
    } else if (class_name == "Ranger") {
        add_text_pair(names, descriptions, "Beast Master", "Beast Master. Fight alongside a trusted animal companion.");
        add_text_pair(names, descriptions, "Fey Wanderer", "Fey Wanderer. Blend martial skill with beguiling fey magic.");
        add_text_pair(names, descriptions, "Gloom Stalker", "Gloom Stalker. Dominate darkness, ambushes, and the unseen hunt.");
        add_text_pair(names, descriptions, "Hunter", "Hunter. Specialize in techniques for bringing down dangerous foes.");
    } else if (class_name == "Rogue") {
        add_text_pair(names, descriptions, "Arcane Trickster", "Arcane Trickster. Mix stealth, legerdemain, and Wizard magic.");
        add_text_pair(names, descriptions, "Assassin", "Assassin. Strike decisively with disguise, poison, and precision.");
        add_text_pair(names, descriptions, "Soulknife", "Soulknife. Manifest psionic blades and uncanny mental talent.");
        add_text_pair(names, descriptions, "Thief", "Thief. Excel at speed, infiltration, and using objects expertly.");
    } else if (class_name == "Sorcerer") {
        add_text_pair(names, descriptions, "Aberrant Sorcery", "Aberrant Sorcery. Mutate your magic with psychic and alien influence.");
        add_text_pair(names, descriptions, "Clockwork Sorcery", "Clockwork Sorcery. Impose order and balance with lawful magic.");
        add_text_pair(names, descriptions, "Draconic Sorcery", "Draconic Sorcery. Carry the power and resilience of dragons.");
        add_text_pair(names, descriptions, "Wild Magic Sorcery", "Wild Magic Sorcery. Unpredictable surges twist your spellcasting.");
    } else if (class_name == "Warlock") {
        add_text_pair(names, descriptions, "Archfey Patron", "Archfey Patron. Gain beguiling power from a mighty fey being.");
        add_text_pair(names, descriptions, "Celestial Patron", "Celestial Patron. Channel radiant aid from a heavenly power.");
        add_text_pair(names, descriptions, "Fiend Patron", "Fiend Patron. Bargain with infernal might for destructive magic.");
        add_text_pair(names, descriptions, "Great Old One Patron", "Great Old One Patron. Draw unsettling power from a distant mind.");
    } else if (class_name == "Wizard") {
        add_text_pair(names, descriptions, "Abjurer", "Abjurer. Focus on wards, protection, and magical negation.");
        add_text_pair(names, descriptions, "Diviner", "Diviner. Read fate and twist probabilities.");
        add_text_pair(names, descriptions, "Evoker", "Evoker. Specialize in direct elemental and force magic.");
        add_text_pair(names, descriptions, "Illusionist", "Illusionist. Deceive the senses with convincing magical illusions.");
    } else if (class_name == "Artificer") {
        add_text_pair(names, descriptions, "Alchemist", "Alchemist. Solve problems with restorative and transformative concoctions.");
        add_text_pair(names, descriptions, "Armorer", "Armorer. Build a magical suit that changes how you fight.");
        add_text_pair(names, descriptions, "Artillerist", "Artillerist. Bring arcane firearms and eldritch artillery to battle.");
        add_text_pair(names, descriptions, "Battle Smith", "Battle Smith. Pair invention with martial skill and a steel companion.");
    }
}

void choose_subclass_step() {
    created_char_subclass = "";
    if (created_char_level < 3) {
        speak("Subclass selection unlocks at level 3.", false);
        return;
    }

    string[] subclass_names;
    string[] subclass_descriptions;
    get_subclass_options(created_char_class, subclass_names, subclass_descriptions);
    if (subclass_names.length() == 0) return;

    menu@ subclass_menu = setup_sub_menu("Choose your subclass.");
    for (uint i = 0; i < subclass_descriptions.length(); i++) subclass_menu.add_item(subclass_descriptions[i]);
    int pick = creation_menu_run(subclass_menu);
    if (pick < 0 or pick >= int(subclass_names.length())) return;
    created_char_subclass = subclass_names[pick];
    speak("You chose " + created_char_subclass + ".", true);

    if (created_char_subclass == "Eldritch Knight") {
        speak("Eldritch Knight uses the Wizard spell list and gains limited spellcasting.", false);
    } else if (created_char_subclass == "Arcane Trickster") {
        speak("Arcane Trickster uses the Wizard spell list, gains Mage Hand automatically, and focuses on enchantment and illusion spells.", false);
    }
}

int choose_subclass_step_profile() {
    created_char_subclass = "";
    if (created_char_level < 3) {
        speak("Subclass selection unlocks at level 3.", false);
        return 0;
    }

    string[] subclass_names;
    string[] subclass_descriptions;
    get_subclass_options(created_char_class, subclass_names, subclass_descriptions);
    if (subclass_names.length() == 0) return 0;

    menu@ subclass_menu = setup_sub_menu("Choose your subclass.");
    for (uint i = 0; i < subclass_descriptions.length(); i++) subclass_menu.add_item(subclass_descriptions[i]);
    int pick = subclass_menu.run();
    if (pick < 0) return -1;
    created_char_subclass = subclass_names[pick];
    speak("You chose " + created_char_subclass + ".", true);

    if (created_char_subclass == "Eldritch Knight") {
        speak("Eldritch Knight uses the Wizard spell list and gains limited spellcasting.", false);
    } else if (created_char_subclass == "Arcane Trickster") {
        speak("Arcane Trickster uses the Wizard spell list, gains Mage Hand automatically, and focuses on enchantment and illusion spells.", false);
    }
    return 0;
}

