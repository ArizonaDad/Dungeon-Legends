        weapon_menu.add_item("Mace. 1 d 6 bludgeoning. Range 5 feet. Sap mastery. 8 of 11");
        weapon_menu.add_item("Quarterstaff. 1 d 6 bludgeoning. Range 5 feet. Versatile 1 d 8. Topple mastery. 9 of 11");
        weapon_menu.add_item("Sickle. 1 d 4 slashing. Range 5 feet. Light. Nick mastery. 10 of 11");
        weapon_menu.add_item("Spear. 1 d 6 piercing. Range 5 feet, thrown 20 / 60. Versatile 1 d 8. Sap mastery. 11 of 11");
    } else if (cat_pick == 1) {
        @weapon_menu = setup_sub_menu("Choose a simple ranged weapon.");
        weapon_names = {"Dart", "Light Crossbow", "Shortbow", "Sling"};
        weapon_menu.add_item("Dart. 1 d 4 piercing. Range 20 / 60. Finesse. Vex mastery. 1 of 4");
        weapon_menu.add_item("Light Crossbow. 1 d 8 piercing. Range 80 / 320. Loading. Two-handed. Slow mastery. 2 of 4");
        weapon_menu.add_item("Shortbow. 1 d 6 piercing. Range 80 / 320. Two-handed. Vex mastery. 3 of 4");
        weapon_menu.add_item("Sling. 1 d 4 bludgeoning. Range 30 / 120. Slow mastery. 4 of 4");
    } else if (cat_pick == 2) {
        @weapon_menu = setup_sub_menu("Choose a martial melee weapon.");
        weapon_names = {"Battleaxe", "Flail", "Glaive", "Greataxe", "Greatsword", "Halberd", "Lance", "Longsword", "Maul", "Morningstar", "Pike", "Rapier", "Scimitar", "Shortsword", "Trident", "War Pick", "Warhammer", "Whip"};
        weapon_menu.add_item("Battleaxe. 1 d 8 slashing. Range 5 feet. Versatile 1 d 10. Topple mastery. 1 of 18");
        weapon_menu.add_item("Flail. 1 d 8 bludgeoning. Range 5 feet. Sap mastery. 2 of 18");
        weapon_menu.add_item("Glaive. 1 d 10 slashing. Range 10 feet. Heavy. Reach. Two-handed. Graze mastery. 3 of 18");
        weapon_menu.add_item("Greataxe. 1 d 12 slashing. Range 5 feet. Heavy. Two-handed. Cleave mastery. 4 of 18");
        weapon_menu.add_item("Greatsword. 2 d 6 slashing. Range 5 feet. Heavy. Two-handed. Graze mastery. 5 of 18");
        weapon_menu.add_item("Halberd. 1 d 10 slashing. Range 10 feet. Heavy. Reach. Two-handed. Cleave mastery. 6 of 18");
        weapon_menu.add_item("Lance. 1 d 10 piercing. Range 10 feet. Reach. Topple mastery. 7 of 18");
        weapon_menu.add_item("Longsword. 1 d 8 slashing. Range 5 feet. Versatile 1 d 10. Sap mastery. 8 of 18");
        weapon_menu.add_item("Maul. 2 d 6 bludgeoning. Range 5 feet. Heavy. Two-handed. Topple mastery. 9 of 18");
        weapon_menu.add_item("Morningstar. 1 d 8 piercing. Range 5 feet. Sap mastery. 10 of 18");
        weapon_menu.add_item("Pike. 1 d 10 piercing. Range 10 feet. Heavy. Reach. Two-handed. Push mastery. 11 of 18");
        weapon_menu.add_item("Rapier. 1 d 8 piercing. Range 5 feet. Finesse. Vex mastery. 12 of 18");
        weapon_menu.add_item("Scimitar. 1 d 6 slashing. Range 5 feet. Finesse. Light. Nick mastery. 13 of 18");
        weapon_menu.add_item("Shortsword. 1 d 6 piercing. Range 5 feet. Finesse. Light. Vex mastery. 14 of 18");
        weapon_menu.add_item("Trident. 1 d 8 piercing. Range 5 feet, thrown 20 / 60. Versatile 1 d 10. Topple mastery. 15 of 18");
        weapon_menu.add_item("War Pick. 1 d 8 piercing. Range 5 feet. Versatile 1 d 10. Sap mastery. 16 of 18");
        weapon_menu.add_item("Warhammer. 1 d 8 bludgeoning. Range 5 feet. Versatile 1 d 10. Push mastery. 17 of 18");
        weapon_menu.add_item("Whip. 1 d 4 slashing. Range 10 feet. Finesse. Reach. Slow mastery. 18 of 18");
    } else {
        @weapon_menu = setup_sub_menu("Choose a martial ranged weapon.");
        weapon_names = {"Blowgun", "Hand Crossbow", "Heavy Crossbow", "Longbow", "Musket", "Pistol"};
        weapon_menu.add_item("Blowgun. 1 piercing. Range 25 / 100. Loading. Vex mastery. 1 of 6");
        weapon_menu.add_item("Hand Crossbow. 1 d 6 piercing. Range 30 / 120. Light. Loading. Vex mastery. 2 of 6");
        weapon_menu.add_item("Heavy Crossbow. 1 d 10 piercing. Range 100 / 400. Heavy. Loading. Two-handed. Push mastery. 3 of 6");
        weapon_menu.add_item("Longbow. 1 d 8 piercing. Range 150 / 600. Heavy. Two-handed. Slow mastery. 4 of 6");
        weapon_menu.add_item("Musket. 1 d 12 piercing. Range 40 / 120. Loading. Two-handed. Slow mastery. 5 of 6");
        weapon_menu.add_item("Pistol. 1 d 10 piercing. Range 30 / 90. Loading. Vex mastery. 6 of 6");
    }

    int weapon_pick = creation_menu_run(weapon_menu);
    if (weapon_pick < 0 or weapon_pick >= int(weapon_names.length())) {
        speak("Going back to weapon category.", false);
        continue;
    }
    created_weapon = weapon_names[weapon_pick];
    speak("You chose " + created_weapon + ".", true);
    return true;
    } // end while
    return false; // Unreachable, satisfies compiler
}

void reset_progression_choices() {
    created_ability_scores = created_pre_progression_ability_scores;
    created_char_feats.resize(0);
    created_char_skill_proficiencies.resize(0);
    created_char_tool_proficiencies.resize(0);
    created_bonus_cantrips.resize(0);
    created_bonus_spells.resize(0);
    created_spellcasting_override_spells.resize(0);
    created_spellcasting_override_abilities.resize(0);
    created_free_cast_spells.resize(0);
}

bool apply_progression_choices_step() {
    while (true) {
        reset_progression_choices();
        clear_creation_back_request();
        apply_background_ability_scores_step();
        if (creation_should_go_back()) { reset_progression_choices(); return false; }

        clear_creation_back_request();
        apply_background_training_and_feat_step();
        if (creation_should_go_back()) { speak("Restarting progression choices.", false); continue; }

        clear_creation_back_request();
        apply_human_species_step();
        if (creation_should_go_back()) { speak("Restarting progression choices.", false); continue; }

        clear_creation_back_request();
        choose_fighting_style_step();
        if (creation_should_go_back()) { speak("Restarting progression choices.", false); continue; }

        clear_creation_back_request();
        choose_general_feat_steps();
        if (creation_should_go_back()) { speak("Restarting progression choices.", false); continue; }

        return true;
    }
    return false;
}

bool choose_spell_selection_step() {
    string[] previous_cantrips = created_cantrips;
    string[] previous_spells = created_spells;
    while (true) {
        clear_creation_back_request();
        spell_selection_step();
        if (creation_should_go_back()) {
            // Check if we had any spells to pick at all. If not, this step auto-skipped
            // and back should go to the previous main step.
            int cantrips_needed = get_cantrips_known(created_char_class, created_char_subclass, created_char_level);
            int spells_needed = get_prepared_spells(created_char_class, created_char_subclass, created_char_level);
            if (cantrips_needed == 0 and spells_needed == 0) {
                created_cantrips = previous_cantrips;
                created_spells = previous_spells;
                return false;
            }
            // Had spells to pick — restart spell selection instead of going back a whole step
            speak("Restarting spell selection.", false);
            created_cantrips = previous_cantrips;
            created_spells = previous_spells;
            continue;
        }
        return true;
    }
    return false;
}

bool confirm_character_summary_step() {
    clear_creation_back_request();
    string spell_summary = "";
    if (created_cantrips.length() > 0) {
        spell_summary += " Cantrips: ";
        spell_summary += join_spell_names(created_cantrips);
        spell_summary += ".";
    }
    if (created_spells.length() > 0) {
        spell_summary += " Spells: ";
        spell_summary += join_spell_names(created_spells);
        spell_summary += ".";
    }
    string feat_summary = created_char_feats.length() > 0 ? " Feats: " + join_feat_names(created_char_feats) + "." : "";
    string background_summary = "";
    if (created_char_background != "") {
        background_choice_def@ bg_summary = get_background_choice(created_char_background);
        if (@bg_summary != null) background_summary = " Background: " + bg_summary.name + ".";
    }
    string subclass_summary = created_char_subclass != "" ? " " + created_char_subclass : "";
    string gender_summary = created_char_gender != "" ? " " + created_char_gender + "." : "";
    // Build Phase 1 affiliation summary — only list fields that were set.
    string phase1_summary = "";
    if (created_piety_god != "") phase1_summary += " Theros god: " + created_piety_god + ".";
    if (created_group_patron != "") phase1_summary += " Group Patron: " + created_group_patron + ".";
    if (created_ravnica_guild != "") phase1_summary += " Ravnica Guild: " + created_ravnica_guild + ".";
    if (created_transformation != "") phase1_summary += " Transformation: " + created_transformation + " (stage " + created_transformation_stage + ").";
    if (created_fey_court != "") phase1_summary += " Fey Court: " + created_fey_court + ".";
    if (created_heroic_homeland != "") phase1_summary += " Homeland: " + created_heroic_homeland + ".";
    speak("Character summary. " + created_char_name + "." + gender_summary + " " + created_char_race + " " + created_char_class + subclass_summary + ", level " + created_char_level + "." + background_summary + " Strength " + created_ability_scores[0] + ". Dexterity " + created_ability_scores[1] + ". Constitution " + created_ability_scores[2] + ". Intelligence " + created_ability_scores[3] + ". Wisdom " + created_ability_scores[4] + ". Charisma " + created_ability_scores[5] + ". Weapon: " + created_weapon + "." + feat_summary + spell_summary + phase1_summary + " Press enter to confirm, or Escape or Backspace to go back.", true);
    while (true) {
        wait(10);
        network_loop();
        if (key_pressed(KEY_RETURN)) return true;
        if (key_pressed(KEY_ESCAPE) or key_pressed(KEY_BACK)) {
            creation_back_requested = true;
            speak("Going back to setting affiliations.", true);
            return false;
        }
    }
    return false;
}

bool choose_name_step() {
    bool canceled = false;
    string default_name = created_char_name != "" ? created_char_name : username;
    string name_input = input_box_form("Character Name", "Enter a name for your character:", default_name, canceled);
    show_window("Dungeon Legends");
    wait(50);
    if (canceled) return false;
    string trimmed = name_input.trim_whitespace();
    if (trimmed.empty()) trimmed = username;
    if (int(trimmed.length()) > 30) trimmed = trimmed.substr(0, 30);
    created_char_name = trimmed;
    speak("Your character will be named " + created_char_name + ".", false);
    return true;
}

bool choose_gender_step() {
    menu@ gender_menu = setup_sub_menu("Choose your character's gender.");
    gender_menu.add_item("Male.");
    gender_menu.add_item("Female.");
    int pick = creation_menu_run(gender_menu);
    if (pick < 0) return false;
    created_char_gender = pick == 0 ? "Male" : "Female";
    speak("Gender set to " + created_char_gender + ".", false);
    return true;
}

// Phase 1 affiliations step — optional setting-specific ties chosen at creation.
// Allows the player to pick a Theros Piety god, Tasha's Group Patron, Ravnica
// Guild, Grim Hollow Transformation, Ebon Tides Fey Court, and Wildemount
// Heroic Chronicle homeland. Each sub-menu offers "None (skip)" so players
// running vanilla PHB campaigns can bypass the entire block. Returns false
// if the player presses Escape/Backspace at the gateway menu (back-nav).
bool choose_phase1_affiliations_step() {
    clear_creation_back_request();
    menu@ gateway = setup_sub_menu("Setting affiliations. Would you like to pick a Theros god, Tasha's Group Patron, Ravnica Guild, Grim Hollow Transformation, Ebon Tides Fey Court, or Wildemount homeland? These are all optional.");
    gateway.add_item("Yes, configure setting affiliations. 1 of 2");
    gateway.add_item("No, skip. My character has no setting ties. 2 of 2");
    int gateway_pick = creation_menu_run(gateway);
    if (gateway_pick < 0) return false; // Escape -> back nav
    if (gateway_pick == 1) {
        // Skip all Phase 1 affiliations
        created_piety_god = "";
        created_group_patron = "";
        created_ravnica_guild = "";
        created_transformation = "";
        created_transformation_stage = 0;
        created_fey_court = "";
        created_heroic_homeland = "";
        speak("Setting affiliations skipped. You can still configure them later via the Shift P menu in combat.", false);
        return true;
    }

    // 1. Theros Piety — 15 gods
    menu@ piety_menu = setup_sub_menu("Theros Piety. Choose a god to worship, or skip. Devotees (Piety 3+) gain a free spell cast per long rest.");
    piety_menu.add_item("None. No god. 1 of 16");
    string[] theros_gods = {"Athreos", "Ephara", "Erebos", "Heliod", "Iroas", "Karametra", "Keranos", "Klothys", "Kruphix", "Mogis", "Nylea", "Pharika", "Phenax", "Purphoros", "Thassa"};
    string[] theros_titles = {"God of Passage", "Goddess of the Polis", "God of the Dead", "God of the Sun", "God of Victory", "Goddess of Harvests", "God of Storms and Wisdom", "Goddess of Destiny", "God of Horizons", "God of Slaughter", "Goddess of the Hunt", "Goddess of Affliction", "God of Deception", "God of the Forge", "Goddess of the Sea"};
    for (uint i = 0; i < theros_gods.length(); i++) {
        piety_menu.add_item(theros_gods[i] + ", " + theros_titles[i] + ". " + (i + 2) + " of 16");
    }
    int piety_pick = creation_menu_run(piety_menu);
    if (piety_pick < 0) return false;
    if (piety_pick == 0) {
        created_piety_god = "";
        speak("No Theros god.", false);
    } else {
        created_piety_god = theros_gods[piety_pick - 1];
        speak("You worship " + created_piety_god + ", " + theros_titles[piety_pick - 1] + ".", false);
    }

    // 2. Tasha's Group Patron — 8 archetypes
    menu@ patron_menu = setup_sub_menu("Group Patron. Choose a Tasha's group patron archetype that ties your party together, or skip. Grants Group Assistance 1d4 per long rest.");
    patron_menu.add_item("None. No group patron. 1 of 9");
    string[] patrons = {"Academy", "Ancient Being", "Aristocrat", "Criminal Syndicate", "Guild", "Military Force", "Religious Order", "Sovereign"};
    string[] patron_blurbs = {"scholars of arcane secrets", "elder dragon, lich, or celestial", "wealthy noble patron", "thieves guild or smuggler ring", "merchant or mage guild", "royal guard or mercenary company", "church, cult, or druid circle", "king, queen, or direct royal agent"};
    for (uint i = 0; i < patrons.length(); i++) {
        patron_menu.add_item(patrons[i] + ", " + patron_blurbs[i] + ". " + (i + 2) + " of 9");
    }
    int patron_pick = creation_menu_run(patron_menu);
    if (patron_pick < 0) return false;
    if (patron_pick == 0) {
        created_group_patron = "";
        speak("No group patron.", false);
    } else {
        created_group_patron = patrons[patron_pick - 1];
        speak("Your group serves " + created_group_patron + ".", false);
    }

    // 3. Ravnica Guild — 10 guilds
    menu@ guild_menu = setup_sub_menu("Ravnica Guild. Choose a guild to join, or skip. Grants contact perks and three free guild spells.");
    guild_menu.add_item("None. No Ravnica guild. 1 of 11");
    string[] guilds = {"Azorius Senate", "Boros Legion", "House Dimir", "Golgari Swarm", "Gruul Clans", "Izzet League", "Orzhov Syndicate", "Cult of Rakdos", "Selesnya Conclave", "Simic Combine"};
    string[] guild_colors = {"White Blue, law and order", "White Red, martial justice", "Blue Black, secret espionage", "Black Green, decay and renewal", "Red Green, savage wilderness", "Blue Red, mad arcane science", "White Black, debt and obligation", "Black Red, chaotic performance", "Green White, communal nature", "Green Blue, biological evolution"};
    for (uint i = 0; i < guilds.length(); i++) {
        guild_menu.add_item(guilds[i] + ", " + guild_colors[i] + ". " + (i + 2) + " of 11");
    }
    int guild_pick = creation_menu_run(guild_menu);
    if (guild_pick < 0) return false;
    if (guild_pick == 0) {
        created_ravnica_guild = "";
        speak("No Ravnica guild.", false);
    } else {
        created_ravnica_guild = guilds[guild_pick - 1];
        speak("You are a member of " + created_ravnica_guild + ".", false);
    }

    // 4. Grim Hollow Transformation — 6 paths
    menu@ trans_menu = setup_sub_menu("Grim Hollow Transformation. Are you undergoing a dark or blessed transformation? Most start at stage one, infected. You can advance the stage later.");
    trans_menu.add_item("None. No transformation. 1 of 7");
    string[] transforms = {"Vampirism", "Lycanthropy", "Lichdom", "Aberrant Horror", "Demonic Pact", "Seraphic Ascension"};
    string[] trans_blurbs = {"undead of the Crimson Court", "were-beast cursed by the moon", "undying wizard bound to a phylactery", "Far Realm mutated horror", "fiendish bargainer burning with fire", "blessed champion of the Arch Seraphs"};
    for (uint i = 0; i < transforms.length(); i++) {
        trans_menu.add_item(transforms[i] + ", " + trans_blurbs[i] + ". " + (i + 2) + " of 7");
    }
    int trans_pick = creation_menu_run(trans_menu);
    if (trans_pick < 0) return false;
    if (trans_pick == 0) {
        created_transformation = "";
        created_transformation_stage = 0;
        speak("No transformation.", false);
    } else {
        created_transformation = transforms[trans_pick - 1];
        created_transformation_stage = 1; // Always start at Infected — higher stages are DM unlocks
        speak("You are " + created_transformation + " at stage one, Infected. The full transformation will progress in-game.", false);
    }

    // 5. Ebon Tides Fey Court — 14 courts, truncated to major ones for the menu
    menu@ court_menu = setup_sub_menu("Ebon Tides Fey Court. Affiliate with a fey court of the Shadow Realm, or skip.");
    court_menu.add_item("None. No fey court. 1 of 15");
    string[] courts = {"Court of Golden Oaks", "Court of Mice and Ravens", "Court of Midnight Teeth", "Court of Night and Magic", "Court of One Million Stars", "Court of Pale Roses", "Court of Sparrows", "Court of the Moonlit King", "Court of Winter's Love", "Dalliance", "Langmire's Court", "Nightbrook", "Tower of Horn and Gold", "Witch Queen's Court"};
    for (uint i = 0; i < courts.length(); i++) {
        court_menu.add_item(courts[i] + ". " + (i + 2) + " of 15");
    }
    int court_pick = creation_menu_run(court_menu);
    if (court_pick < 0) return false;
    if (court_pick == 0) {
        created_fey_court = "";
        speak("No fey court.", false);
    } else {
        created_fey_court = courts[court_pick - 1];
        speak("You belong to the " + created_fey_court + ".", false);
    }

    // 6. Wildemount Heroic Chronicle homeland — 5 homelands
    menu@ homeland_menu = setup_sub_menu("Wildemount Heroic Chronicle. Choose your homeland on the continent of Wildemount, or skip.");
    homeland_menu.add_item("None. No Wildemount homeland. 1 of 6");
    string[] homelands = {"Menagerie Coast", "Marrow Valley", "Zemni Fields", "Greying Wildlands", "Xhorhas"};
    string[] homeland_blurbs = {"coastal trading cities of the Clovis Concord", "central heartland including Alfield and Berleben", "northern fields of the Dwendalian Empire", "untamed wilderness north of the empire", "dark eastern frontier of the Kryn Dynasty"};
    for (uint i = 0; i < homelands.length(); i++) {
        homeland_menu.add_item(homelands[i] + ", " + homeland_blurbs[i] + ". " + (i + 2) + " of 6");
    }
    int homeland_pick = creation_menu_run(homeland_menu);
    if (homeland_pick < 0) return false;
    if (homeland_pick == 0) {
        created_heroic_homeland = "";
        speak("No Wildemount homeland.", false);
    } else {
        created_heroic_homeland = homelands[homeland_pick - 1];
        speak("Your homeland is " + created_heroic_homeland + ".", false);
    }

    return true;
}

void character_creation_menu(string profile = "adventure", int forced_level = -1) {
    // Save current active profile so we can restore it if creation is cancelled
    string saved_profile = active_character_profile;
    init_feat_data();
    clear_character_buffer();
    clear_creation_back_request();
    speak("Character creation. Let's build your champion.", true);

    int step = 1;
    while (step <= 13) {
        clear_creation_back_request();
        if (step == 1) {
            if (choose_name_step()) step = 2;
            else {
                speak("Character creation cancelled.", true);
                // Restore previous character state
                if (saved_profile != "" and profile_has_character(saved_profile)) set_active_character_profile(saved_profile);
                return;
            }
        } else if (step == 2) {
            if (choose_gender_step()) step = 3;
            else step = 1;
        } else if (step == 3) {
            if (choose_race_step()) step = 4;
            else step = 2;
        } else if (step == 4) {
            if (choose_class_step()) step = 5;
            else step = 3;
        } else if (step == 5) {
            if (profile == "adventure") {
                created_char_level = forced_level > 0 ? forced_level : 1;
                speak("Adventure characters use your current Adventure level of " + created_char_level + ".", true);
                step = 6;
            } else {
                if (choose_level_step(profile, forced_level)) step = 6;
                else step = 4;
            }
        } else if (step == 6) {
            if (created_char_level < 3) {
                created_char_subclass = "";
                speak("Subclass selection unlocks at level 3.", false);
                step = 7;
            } else {
                created_char_subclass = "";
                choose_subclass_step();
                if (creation_should_go_back()) {
                    step = (profile == "adventure") ? 4 : 5;
                } else step = 7;
            }
        } else if (step == 7) {
            choose_background_step();
            if (creation_should_go_back()) {
                if (created_char_level < 3) {
                    step = (profile == "adventure") ? 4 : 5;
                } else step = 6;
            } else step = 8;
        } else if (step == 8) {
            if (assign_ability_scores_step()) step = 9;
            else step = 7;
        } else if (step == 9) {
            if (choose_weapon_step()) step = 10;
            else step = 8;
        } else if (step == 10) {
            if (apply_progression_choices_step()) step = 11;
            else step = 9;
        } else if (step == 11) {
            if (choose_spell_selection_step()) step = 12;
            else step = 10;
        } else if (step == 12) {
            if (choose_phase1_affiliations_step()) step = 13;
            else step = 11;
        } else if (step == 13) {
            if (confirm_character_summary_step()) break;
            step = 12;
        }
    }

    string cantrip_str = "";
    for (uint ci = 0; ci < created_cantrips.length(); ci++) {
        if (ci > 0) cantrip_str += ",";
        cantrip_str += created_cantrips[ci];
    }
    string spell_str = "";
    for (uint ci = 0; ci < created_spells.length(); ci++) {
        if (ci > 0) spell_str += ",";
        spell_str += created_spells[ci];
    }

    send({
        {"type", message_types::character_create},
        {"profile", profile},
        {"name", created_char_name},
        {"gender", created_char_gender},
        {"race", created_char_race},
        {"class", created_char_class},
        {"subclass", created_char_subclass},
        {"background", created_char_background},
        {"level", created_char_level},
        {"str", created_ability_scores[0]},
        {"dex", created_ability_scores[1]},
        {"con", created_ability_scores[2]},
        {"int", created_ability_scores[3]},
        {"wis", created_ability_scores[4]},
        {"cha", created_ability_scores[5]},
        {"base_str", created_pre_progression_ability_scores[0]},
        {"base_dex", created_pre_progression_ability_scores[1]},
        {"base_con", created_pre_progression_ability_scores[2]},
        {"base_int", created_pre_progression_ability_scores[3]},
        {"base_wis", created_pre_progression_ability_scores[4]},
        {"base_cha", created_pre_progression_ability_scores[5]},
        {"weapon", created_weapon},
        {"feats", join_csv_list(created_char_feats)},
        {"skills", join_csv_list(created_char_skill_proficiencies)},
        {"tools", join_csv_list(created_char_tool_proficiencies)},
        {"spell_ability_overrides", join_spell_override_specs()},
        {"free_cast_spells", join_csv_list(created_free_cast_spells)},
        {"cantrips", cantrip_str},
        {"spells", spell_str},
        // Phase 1 affiliations chosen via choose_phase1_affiliations_step
        {"piety_god", created_piety_god},
        {"group_patron", created_group_patron},
        {"ravnica_guild", created_ravnica_guild},
        {"transformation", created_transformation},
        {"transformation_stage", created_transformation_stage},
        {"fey_court", created_fey_court},
        {"heroic_homeland", created_heroic_homeland}
    });
    store_buffer_to_profile_cache(profile);
    set_active_character_profile(profile);
    string created_summary = created_char_name + ", " + created_char_race + " " + created_char_class;
    if (created_char_subclass != "") created_summary += " " + created_char_subclass;
    if (created_char_background != "") {
        background_choice_def@ bg = get_background_choice(created_char_background);
        if (@bg != null) created_summary += ", " + bg.name + " background";
    }
    created_summary += ", level " + created_char_level + ".";
    speak(character_profile_display_name(profile) + " character created! " + created_summary, true);
}
