    for (uint i = 0; i < races.length(); i++) race_menu.add_item(race_desc[i] + " " + (i + 1) + " of " + races.length());
    int race_pick = creation_menu_run(race_menu);
    if (race_pick < 0 or race_pick >= int(races.length())) return false;
    created_char_race = races[race_pick];
