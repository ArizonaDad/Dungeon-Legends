void choose_subclass_step() {
    created_char_subclass = "";
    if (created_char_level < 3) {
        speak("Subclass selection unlocks at level 3.", false);
        return;
    }

    string[] subclass_names;
    string[] subclass_descriptions;
    get_subclass_options(created_char_class, subclass_names, subclass_descriptions);
    if (subclass_names.length() == 0) return;

    menu@ subclass_menu = setup_sub_menu("Choose your subclass.");
    for (uint i = 0; i < subclass_descriptions.length(); i++) subclass_menu.add_item(subclass_descriptions[i] + " " + (i + 1) + " of " + subclass_descriptions.length());
    int pick = creation_menu_run(subclass_menu);
    if (pick < 0 or pick >= int(subclass_names.length())) return;
    created_char_subclass = subclass_names[pick];
    speak("You chose " + created_char_subclass + ".", true);

    if (created_char_subclass == "Eldritch Knight") {
        speak("Eldritch Knight uses the Wizard spell list and gains limited spellcasting.", false);
    } else if (created_char_subclass == "Arcane Trickster") {
        speak("Arcane Trickster uses the Wizard spell list, gains Mage Hand automatically, and focuses on enchantment and illusion spells.", false);
    }
}

int choose_subclass_step_profile() {
    created_char_subclass = "";
    if (created_char_level < 3) {
        speak("Subclass selection unlocks at level 3.", false);
        return 0;
    }

    string[] subclass_names;
    string[] subclass_descriptions;
    get_subclass_options(created_char_class, subclass_names, subclass_descriptions);
    if (subclass_names.length() == 0) return 0;

    menu@ subclass_menu = setup_sub_menu("Choose your subclass.");
    for (uint i = 0; i < subclass_descriptions.length(); i++) subclass_menu.add_item(subclass_descriptions[i] + " " + (i + 1) + " of " + subclass_descriptions.length());
    int pick = subclass_menu.run();
    if (pick < 0 or pick >= int(subclass_names.length())) return -1;
    created_char_subclass = subclass_names[pick];
    speak("You chose " + created_char_subclass + ".", true);

    if (created_char_subclass == "Eldritch Knight") {
        speak("Eldritch Knight uses the Wizard spell list and gains limited spellcasting.", false);
    } else if (created_char_subclass == "Arcane Trickster") {
        speak("Arcane Trickster uses the Wizard spell list, gains Mage Hand automatically, and focuses on enchantment and illusion spells.", false);
    }
    return 0;
}

const int STEP_NAME = 0;
const int STEP_SPECIES = 1;
const int STEP_CLASS = 2;
const int STEP_LEVEL = 3;
const int STEP_SUBCLASS = 4;
const int STEP_ABILITIES = 5;
const int STEP_WEAPON = 6;
const int STEP_SPELLS = 7;
const int STEP_SUMMARY = 8;

int run_weapon_step() {
    menu@ weapon_cat_menu = setup_sub_menu("Choose a weapon category.");
    weapon_cat_menu.add_item("Simple Melee Weapons. 1 of 4");
    weapon_cat_menu.add_item("Simple Ranged Weapons. 2 of 4");
    weapon_cat_menu.add_item("Martial Melee Weapons. 3 of 4");
    weapon_cat_menu.add_item("Martial Ranged Weapons. 4 of 4");
    int cat_pick = weapon_cat_menu.run();
    if (cat_pick < 0) return -1;

    menu@ weapon_menu;
    string[] weapon_names;

    if (cat_pick == 0) {
        @weapon_menu = setup_sub_menu("Choose a simple melee weapon.");
        weapon_names = {"Club", "Dagger", "Greatclub", "Handaxe", "Javelin", "Light Hammer", "Mace", "Quarterstaff", "Sickle", "Spear"};
        weapon_menu.add_item("Club. 1 d 4 bludgeoning. Light. Slow mastery. 1 of 10");
        weapon_menu.add_item("Dagger. 1 d 4 piercing. Finesse. Light. Thrown 20 / 60. Nick mastery. 2 of 10");
        weapon_menu.add_item("Greatclub. 1 d 8 bludgeoning. Two-handed. Push mastery. 3 of 10");
        weapon_menu.add_item("Handaxe. 1 d 6 slashing. Light. Thrown 20 / 60. Vex mastery. 4 of 10");
        weapon_menu.add_item("Javelin. 1 d 6 piercing. Thrown 30 / 120. Slow mastery. 5 of 10");
        weapon_menu.add_item("Light Hammer. 1 d 4 bludgeoning. Light. Thrown 20 / 60. Nick mastery. 6 of 10");
        weapon_menu.add_item("Mace. 1 d 6 bludgeoning. Sap mastery. 7 of 10");
        weapon_menu.add_item("Quarterstaff. 1 d 6 bludgeoning. Versatile 1 d 8. Topple mastery. 8 of 10");
        weapon_menu.add_item("Sickle. 1 d 4 slashing. Light. Nick mastery. 9 of 10");
        weapon_menu.add_item("Spear. 1 d 6 piercing. Versatile 1 d 8. Thrown 20 / 60. Sap mastery. 10 of 10");
    } else if (cat_pick == 1) {
        @weapon_menu = setup_sub_menu("Choose a simple ranged weapon.");
        weapon_names = {"Dart", "Light Crossbow", "Shortbow", "Sling"};
        weapon_menu.add_item("Dart. 1 d 4 piercing. Finesse. Thrown 20 / 60. Vex mastery. 1 of 4");
        weapon_menu.add_item("Light Crossbow. 1 d 8 piercing. Range 80 / 320. Loading. Two-handed. Slow mastery. 2 of 4");
        weapon_menu.add_item("Shortbow. 1 d 6 piercing. Range 80 / 320. Two-handed. Vex mastery. 3 of 4");
        weapon_menu.add_item("Sling. 1 d 4 bludgeoning. Range 30 / 120. Slow mastery. 4 of 4");
    } else if (cat_pick == 2) {
        @weapon_menu = setup_sub_menu("Choose a martial melee weapon.");
        weapon_names = {"Battleaxe", "Flail", "Glaive", "Greataxe", "Greatsword", "Halberd", "Lance", "Longsword", "Maul", "Morningstar", "Pike", "Rapier", "Scimitar", "Shortsword", "Trident", "War Pick", "Warhammer", "Whip"};
        weapon_menu.add_item("Battleaxe. 1 d 8 slashing. Versatile 1 d 10. Topple mastery. 1 of 18");
        weapon_menu.add_item("Flail. 1 d 8 bludgeoning. Sap mastery. 2 of 18");
        weapon_menu.add_item("Glaive. 1 d 10 slashing. Heavy. Reach. Two-handed. Graze mastery. 3 of 18");
        weapon_menu.add_item("Greataxe. 1 d 12 slashing. Heavy. Two-handed. Cleave mastery. 4 of 18");
        weapon_menu.add_item("Greatsword. 2 d 6 slashing. Heavy. Two-handed. Graze mastery. 5 of 18");
        weapon_menu.add_item("Halberd. 1 d 10 slashing. Heavy. Reach. Two-handed. Cleave mastery. 6 of 18");
        weapon_menu.add_item("Lance. 1 d 10 piercing. Reach. Topple mastery. 7 of 18");
        weapon_menu.add_item("Longsword. 1 d 8 slashing. Versatile 1 d 10. Sap mastery. 8 of 18");
        weapon_menu.add_item("Maul. 2 d 6 bludgeoning. Heavy. Two-handed. Topple mastery. 9 of 18");
        weapon_menu.add_item("Morningstar. 1 d 8 piercing. Sap mastery. 10 of 18");
        weapon_menu.add_item("Pike. 1 d 10 piercing. Heavy. Reach. Two-handed. Push mastery. 11 of 18");
        weapon_menu.add_item("Rapier. 1 d 8 piercing. Finesse. Vex mastery. 12 of 18");
        weapon_menu.add_item("Scimitar. 1 d 6 slashing. Finesse. Light. Nick mastery. 13 of 18");
        weapon_menu.add_item("Shortsword. 1 d 6 piercing. Finesse. Light. Vex mastery. 14 of 18");
        weapon_menu.add_item("Trident. 1 d 8 piercing. Versatile 1 d 10. Thrown 20 / 60. Topple mastery. 15 of 18");
        weapon_menu.add_item("War Pick. 1 d 8 piercing. Versatile 1 d 10. Sap mastery. 16 of 18");
        weapon_menu.add_item("Warhammer. 1 d 8 bludgeoning. Versatile 1 d 10. Push mastery. 17 of 18");
        weapon_menu.add_item("Whip. 1 d 4 slashing. Finesse. Reach. Slow mastery. 18 of 18");
    } else {
        @weapon_menu = setup_sub_menu("Choose a martial ranged weapon.");
        weapon_names = {"Blowgun", "Hand Crossbow", "Heavy Crossbow", "Longbow", "Musket", "Pistol"};
        weapon_menu.add_item("Blowgun. 1 piercing. Range 25 / 100. Loading. Vex mastery. 1 of 6");
        weapon_menu.add_item("Hand Crossbow. 1 d 6 piercing. Range 30 / 120. Light. Loading. Vex mastery. 2 of 6");
        weapon_menu.add_item("Heavy Crossbow. 1 d 10 piercing. Range 100 / 400. Heavy. Loading. Two-handed. Push mastery. 3 of 6");
        weapon_menu.add_item("Longbow. 1 d 8 piercing. Range 150 / 600. Heavy. Two-handed. Slow mastery. 4 of 6");
        weapon_menu.add_item("Musket. 1 d 12 piercing. Range 40 / 120. Loading. Two-handed. Slow mastery. 5 of 6");
        weapon_menu.add_item("Pistol. 1 d 10 piercing. Range 30 / 90. Loading. Vex mastery. 6 of 6");
    }

    int weapon_pick = weapon_menu.run();
    if (weapon_pick < 0 or weapon_pick >= int(weapon_names.length())) return -1;
    created_weapon = weapon_names[weapon_pick];
    speak("You chose " + created_weapon + ".", true);
    return 0;
}

