bool choose_class_step() {
    menu@ class_menu = setup_sub_menu("Choose your class. Your class determines your combat role, abilities, and how you fight.");
    string[] classes = {"Barbarian","Bard","Cleric","Druid","Fighter","Monk","Paladin","Ranger","Rogue","Sorcerer","Warlock","Wizard","Artificer","Gunslinger"};
    string[] class_desc = {
        "Barbarian. D 12 hit die. Rages in battle for extra damage and resistance.",
        "Bard. D 8 hit die. Charisma caster. Inspires allies with magic and music.",
        "Cleric. D 8 hit die. Wisdom caster. Divine magic, healing, and armor.",
        "Druid. D 8 hit die. Wisdom caster. Nature magic and wild shape.",
        "Fighter. D 10 hit die. Master of weapons. Action Surge and Extra Attacks.",
        "Monk. D 8 hit die. Martial artist with Focus Points for special techniques.",
        "Paladin. D 10 hit die. Holy warrior. Charisma caster with divine smite.",
        "Ranger. D 10 hit die. Wilderness warrior. Wisdom caster with favored enemies.",
        "Rogue. D 8 hit die. Stealthy striker. Sneak Attack for massive single-target damage.",
        "Sorcerer. D 6 hit die. Charisma caster. Innate magic with metamagic.",
        "Warlock. D 8 hit die. Pact magic with eldritch invocations.",
        "Wizard. D 6 hit die. Intelligence caster. Largest spell list. Arcane mastery.",
        "Artificer. D 8 hit die. Intelligence caster. Magical inventor with infusions.",
        "Gunslinger. D 8 hit die. Dexterity and Charisma. Firearms specialist with Risk Dice and Critical Shots. (Valda's)"
    };
    for (uint i = 0; i < classes.length(); i++) class_menu.add_item(class_desc[i] + " " + (i + 1) + " of " + classes.length());
    int class_pick = creation_menu_run(class_menu);
    if (class_pick < 0 or class_pick >= int(classes.length())) return false;
    created_char_class = classes[class_pick];
    speak("You chose " + created_char_class + ".", true);
    return true;
}

bool choose_level_step(string profile = "sandbox", int forced_level = -1) {
    if (profile == "adventure") {
        created_char_level = forced_level > 0 ? forced_level : 1;
        speak("Adventure characters use your current Adventure level of " + created_char_level + ".", true);
        return true;
    }
    menu@ level_menu = setup_sub_menu("Choose your level. 1 through 20.");
    for (int lv = 1; lv <= 20; lv++) level_menu.add_item("Level " + lv + ". " + lv + " of 20");
    int level_pick = creation_menu_run(level_menu);
    if (level_pick < 0 or level_pick >= 20) return false;
    created_char_level = level_pick + 1;
    speak("Level " + created_char_level + ".", true);
    return true;
}

bool assign_ability_scores_step() {
    int[] previous_scores = created_ability_scores;
    int[] standard = {15, 14, 13, 12, 10, 8};
    bool[] used = {false, false, false, false, false, false};
    int[] used_indices = {-1, -1, -1, -1, -1, -1};
    speak("Assign ability scores using the standard array: 15, 14, 13, 12, 10, 8.", true);

    string lc = created_char_class.lower();
    if (lc == "fighter" or lc == "barbarian" or lc == "paladin") {
        speak("Tip: Strength and Constitution are most important for your class.", false);
    } else if (lc == "rogue" or lc == "ranger" or lc == "monk") {
        speak("Tip: Dexterity is most important for your class.", false);
    } else if (lc == "wizard" or lc == "artificer") {
        speak("Tip: Intelligence is most important for your class.", false);
    } else if (lc == "cleric" or lc == "druid") {
        speak("Tip: Wisdom is most important for your class.", false);
    } else if (lc == "sorcerer" or lc == "warlock" or lc == "bard") {
        speak("Tip: Charisma is most important for your class.", false);
    }

    int a = 0;
    while (a < 6) {
        string ability_name = ABILITY_NAMES[a];
        string progress = "";
        for (int p = 0; p < a; p++) {
            if (progress != "") progress += ", ";
            progress += ABILITY_NAMES[p] + " " + created_ability_scores[p];
        }
        string available = "";
        menu@ score_menu = setup_sub_menu("Assign a score to " + ability_name + ".");
        int[] remaining_scores;
        int[] remaining_indices;
        // Count remaining scores first for numbering
        uint total_remaining = 0;
        for (uint sc = 0; sc < 6; sc++) { if (!used[sc]) total_remaining++; }
        for (uint s = 0; s < 6; s++) {
            if (used[s]) continue;
            if (available != "") available += ", ";
            available += standard[s];
            score_menu.add_item("" + standard[s] + ". " + (remaining_scores.length() + 1) + " of " + total_remaining);
            remaining_scores.insert_last(standard[s]);
            remaining_indices.insert_last(s);
        }
        string prompt_text = "Assign a score to " + ability_name + ".";
        if (progress != "") prompt_text += " So far: " + progress + ".";
        prompt_text += " Available: " + available + ".";
        if (a > 0) prompt_text += " Press backspace to redo the previous score.";
        score_menu.intro_text = prompt_text;
        int back_item = score_menu.add_item("Go back.");
        int pick = score_menu.run();
        if (pick < 0 or pick == back_item) {
            if (a > 0) {
                a--;
                int prev_index = used_indices[a];
                if (prev_index >= 0 and prev_index < 6) used[prev_index] = false;
                used_indices[a] = -1;
                created_ability_scores[a] = 10;
                speak("Going back to " + ABILITY_NAMES[a] + ".", false);
                continue;
            }
            created_ability_scores = previous_scores;
            return false;
        }
        if (pick >= int(remaining_scores.length())) {
            created_ability_scores = previous_scores;
            return false;
        }
        created_ability_scores[a] = remaining_scores[pick];
        used[remaining_indices[pick]] = true;
        used_indices[a] = remaining_indices[pick];
        speak(ability_name + " set to " + created_ability_scores[a] + ".", false);
        a++;
    }
    created_pre_progression_ability_scores = created_ability_scores;
    return true;
}

bool choose_weapon_step() {
    while (true) {
    menu@ weapon_cat_menu = setup_sub_menu("Choose your weapon. This is what you'll use to attack in combat.");
    weapon_cat_menu.add_item("Simple Melee Weapons. 1 of 4");
    weapon_cat_menu.add_item("Simple Ranged Weapons. 2 of 4");
    weapon_cat_menu.add_item("Martial Melee Weapons. 3 of 4");
    weapon_cat_menu.add_item("Martial Ranged Weapons. 4 of 4");
    int cat_pick = creation_menu_run(weapon_cat_menu);
    if (cat_pick < 0 or cat_pick > 3) return false;

    menu@ weapon_menu;
    string[] weapon_names;
    if (cat_pick == 0) {
        @weapon_menu = setup_sub_menu("Choose a simple melee weapon.");
        weapon_names = {"Unarmed", "Club", "Dagger", "Greatclub", "Handaxe", "Javelin", "Light Hammer", "Mace", "Quarterstaff", "Sickle", "Spear"};
