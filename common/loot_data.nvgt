	add_item("dmg_ring_animal_influence", "Ring of Animal Influence", SLOT_RING, RARITY_RARE, "This ring has 3 charges, and it regains 1d3 expended charges daily at dawn. While wearing the ring, you can expend 1 of its charges to cast Animal Friendship, Fear (on Beasts only), or Speak with Animals.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_ring_djinni_summoning", "Ring of Djinni Summoning", SLOT_RING, RARITY_LEGENDARY, "While wearing this ring, you can take a Magic action to summon a particular Djinni from the Elemental Plane of Air.", 1, 2, 10, 2, 0, 0, 1, 0);
