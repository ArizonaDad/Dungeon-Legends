	// DMG 2024 Bracers, Gauntlets, Eyes, Hats, Helms, Periapts, Robes (paras 7700-9750)
	add_item("dmg_bracers_archery", "Bracers of Archery", SLOT_ARMOR, RARITY_UNCOMMON, "While wearing these bracers, you have proficiency with the Longbow and Shortbow, and you gain a +2 bonus to damage rolls made with such weapons.", 0, 2, 0, 0, 1, 0, 0, 0);
