	add_item("dmg_dwarven_plate", "Dwarven Plate", SLOT_ARMOR, RARITY_EPIC, "While wearing this armor, you gain a +2 bonus to Armor Class. In addition, if an effect moves you against your will along the ground, you can take a Reaction to reduce the distance you are moved.", 3, 0, 10, 0, 0, 0, 0, 0);
	add_item("dmg_elven_chain", "Elven Chain", SLOT_ARMOR, RARITY_RARE, "You gain a +1 bonus to Armor Class while you wear this armor. You are considered trained with this armor even if you lack training with Medium or Heavy armor.", 1, 0, 0, 0, 1, 0, 0, 0);
	add_item("dmg_mithral_armor", "Mithral Armor", SLOT_ARMOR, RARITY_UNCOMMON, "Mithral is a light, flexible metal. Armor made of this substance can be worn under normal clothes. If the armor normally imposes Disadvantage on Dexterity (Stealth) checks or has a Strength requirement, the mithral version doesn't.", 0, 0, 0, 0, 1, 5, 0, 0);
	add_item("dmg_plate_etherealness", "Plate Armor of Etherealness", SLOT_ARMOR, RARITY_LEGENDARY, "While you're wearing this armor, you can take a Magic action and use a command word to gain the effect of the Etherealness spell.", 4, 0, 15, 0, 1, 0, 1, 0);

	// DMG 2024 Wands (paras 10414-10527)
	add_item("dmg_wand_binding", "Wand of Binding", SLOT_WEAPON, RARITY_RARE, "This wand has 7 charges. While holding it, you can use an action to expend 1 or more charges to cast Hold Monster or Hold Person from it.", 0, 1, 0, 1, 0, 0, 0, 0);
	add_item("dmg_wand_conducting", "Wand of Conducting", SLOT_WEAPON, RARITY_COMMON, "This wand has 3 charges. While holding it, you can take a Magic action to expend 1 charge and create orchestral music by waving it around.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_wand_enemy_detection", "Wand of Enemy Detection", SLOT_WEAPON, RARITY_RARE, "This wand has 3 charges. While holding it, you can take a Magic action to expend 1 charge and detect creatures within 60 feet that are hostile to you.", 0, 1, 0, 0, 1, 0, 0, 0);
	add_item("dmg_wand_fear", "Wand of Fear", SLOT_WEAPON, RARITY_RARE, "This wand has 7 charges. You can take a Magic action to expend 1 or more charges to force creatures to make a Wisdom save or be Frightened.", 0, 1, 0, 1, 0, 0, 0, 0);
	add_item("dmg_wand_fireballs", "Wand of Fireballs", SLOT_WEAPON, RARITY_RARE, "This wand has 7 charges. You can take a Magic action to expend 1 or more charges to cast Fireball from it. For 1 charge it casts the level 3 version; for each additional charge the slot level increases by 1, up to level 7.", 0, 2, 0, 2, 0, 0, 0, 0);
	add_item("dmg_wand_lightning_bolts", "Wand of Lightning Bolts", SLOT_WEAPON, RARITY_RARE, "This wand has 7 charges. You can take a Magic action to expend 1 or more charges to cast Lightning Bolt from it.", 0, 2, 0, 2, 0, 0, 0, 0);
	add_item("dmg_wand_magic_missiles", "Wand of Magic Missiles", SLOT_WEAPON, RARITY_UNCOMMON, "This wand has 7 charges. You can take a Magic action to expend 1 or more charges to cast Magic Missile from it.", 0, 1, 0, 1, 0, 0, 0, 0);
	add_item("dmg_wand_orcus", "Wand of Orcus", SLOT_WEAPON, RARITY_LEGENDARY, "This wand and its rod-like form possess immense necromantic power. Wielding it requires attunement to a creature of evil alignment, and the wielder gains command over Undead.", 0, 5, 10, 3, 0, 0, 1, 0);
	add_item("dmg_wand_paralysis", "Wand of Paralysis", SLOT_WEAPON, RARITY_RARE, "This wand has 7 charges. You can take a Magic action to expend 1 charge to cause a creature within 60 feet to make a Constitution save or be paralyzed for 1 minute.", 0, 2, 0, 2, 0, 0, 0, 0);
	add_item("dmg_wand_polymorph", "Wand of Polymorph", SLOT_WEAPON, RARITY_EPIC, "This wand has 7 charges. You can take a Magic action to expend 1 charge to cast Polymorph from it.", 0, 3, 0, 3, 0, 0, 0, 0);
	add_item("dmg_wand_war_mage_1", "Wand of the War Mage +1", SLOT_WEAPON, RARITY_UNCOMMON, "While holding this wand, you gain a +1 bonus to spell attack rolls. In addition, you ignore Half Cover when making a spell attack.", 0, 1, 0, 1, 0, 0, 0, 0);
	add_item("dmg_wand_war_mage_2", "Wand of the War Mage +2", SLOT_WEAPON, RARITY_RARE, "While holding this wand, you gain a +2 bonus to spell attack rolls. In addition, you ignore Half Cover when making a spell attack.", 0, 2, 0, 2, 0, 0, 0, 0);
	add_item("dmg_wand_war_mage_3", "Wand of the War Mage +3", SLOT_WEAPON, RARITY_EPIC, "While holding this wand, you gain a +3 bonus to spell attack rolls. In addition, you ignore Half Cover when making a spell attack.", 0, 3, 0, 3, 0, 0, 0, 0);
	add_item("dmg_wand_web", "Wand of Web", SLOT_WEAPON, RARITY_UNCOMMON, "This wand has 7 charges. You can take a Magic action to expend 1 charge to cast Web from it.", 0, 1, 0, 1, 0, 0, 0, 0);
	add_item("dmg_wand_wonder", "Wand of Wonder", SLOT_WEAPON, RARITY_RARE, "This wand has 7 charges. You can take a Magic action to expend 1 charge to cause one of many random magical effects.", 0, 2, 0, 2, 0, 0, 0, 0);

	// DMG 2024 Rods, Stones, Wondrous Items (paras 7484-10275)
	add_item("dmg_stone_good_luck", "Stone of Good Luck (Luckstone)", SLOT_AMULET, RARITY_UNCOMMON, "While this polished agate is on your person, you gain a +1 bonus to ability checks and saving throws.", 0, 0, 0, 0, 1, 0, 1, 0);
	add_item("dmg_rod_absorption", "Rod of Absorption", SLOT_WEAPON, RARITY_EPIC, "While holding this rod, you can use your reaction to absorb a spell that's targeting only you and not with an area of effect. The absorbed spell's effect is canceled, and the spell's energy is stored in the rod.", 0, 2, 0, 2, 0, 0, 1, 0);
	add_item("dmg_rod_lordly_might", "Rod of Lordly Might", SLOT_WEAPON, RARITY_LEGENDARY, "This rod has the properties of a +3 mace and a +3 melee weapon. You can use 6 different functions: Intimidate, Drain Life, Climb, Paralyze, Quarterstaff, and Battleaxe.", 0, 5, 0, 0, 0, 0, 1, 0);
	add_item("dmg_rod_resurrection", "Rod of Resurrection", SLOT_WEAPON, RARITY_LEGENDARY, "The rod has 5 charges. While you hold it, you can cast one of the following spells from it: Heal (expends 1 charge) or Resurrection (expends 5 charges).", 0, 2, 20, 2, 0, 0, 0, 0);
	add_item("dmg_bag_of_tricks", "Bag of Tricks", SLOT_AMULET, RARITY_UNCOMMON, "This bag made from gray, rust, or tan cloth appears empty. Reaching inside the bag reveals a small fuzzy object that becomes a creature when thrown up to 20 feet.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_decanter_endless_water", "Decanter of Endless Water", SLOT_AMULET, RARITY_UNCOMMON, "This stoppered flask sloshes when shaken, as if it contains water. The decanter weighs 2 pounds. You can take a Magic action to remove the stopper and speak one of three command words to cause water to pour out.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_bead_of_force", "Bead of Force", SLOT_AMULET, RARITY_RARE, "This black sphere has been infused with destructive force. As an action, you can throw the bead up to 60 feet, where it detonates in a 10-foot-radius sphere, dealing 5d4 force damage on a failed DEX save.", 0, 0, 0, 1, 0, 0, 0, 0);

	// Tasha's wondrous items already in DMG 2024
	add_item("dmg_immovable_rod", "Immovable Rod", SLOT_WEAPON, RARITY_UNCOMMON, "This flat iron rod has a button on one end. You can take a Magic action to press the button, which causes the rod to become magically fixed in place.", 0, 1, 0, 0, 0, 0, 0, 0);

	// Common consumable items mentioned by name in DMG 2024
	add_item("dmg_potion_healing_greater", "Potion of Healing (Greater)", SLOT_AMULET, RARITY_UNCOMMON, "You regain 4d4+4 hit points when you drink this potion.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_potion_climbing", "Potion of Climbing", SLOT_AMULET, RARITY_COMMON, "When you drink this potion, you gain a Climb Speed equal to your walking Speed for 1 hour.", 0, 0, 0, 0, 0, 0, 0, 0);

	// DMG 2024 Common Items (paras 7361-9300+) - source-quoted
	add_item("dmg_armor_of_gleaming", "Armor of Gleaming", SLOT_ARMOR, RARITY_COMMON, "This armor never gets dirty.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_bead_of_nourishment", "Bead of Nourishment", SLOT_AMULET, RARITY_COMMON, "This flavorless, gelatinous bead dissolves on your tongue and provides as much nourishment as 1 day of Rations.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_cast_off_armor", "Cast-Off Armor", SLOT_ARMOR, RARITY_COMMON, "You can doff this armor as a Magic action.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_clothes_of_mending", "Clothes of Mending", SLOT_ARMOR, RARITY_COMMON, "This elegant outfit magically mends itself to counteract daily wear and tear. Pieces of the outfit that are destroyed can't be repaired in this way.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_dread_helm", "Dread Helm", SLOT_ARMOR, RARITY_COMMON, "While you're wearing this fearsome steel helm, your eyes glow red and the rest of your face is hidden in shadow.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_enduring_spellbook", "Enduring Spellbook", SLOT_AMULET, RARITY_COMMON, "This spellbook, along with anything written on its pages, can't be damaged by fire or water. In addition, the spellbook doesn't deteriorate with age.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_ersatz_eye", "Ersatz Eye", SLOT_AMULET, RARITY_COMMON, "This magical eye replaces a real one that was lost or removed. You can see through the orb as if you had a normal eye, including blindness, magic, and similar effects that target organic eyes.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_hat_of_wizardry", "Hat of Wizardry", SLOT_ARMOR, RARITY_COMMON, "This cone-shaped hat is adorned with moons and stars. While you are wearing it, you can use the hat as a spellcasting focus and gain Mage Hand cantrip.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_horn_of_silent_alarm", "Horn of Silent Alarm", SLOT_AMULET, RARITY_COMMON, "This horn has 4 charges and regains 1d4 expended charges daily at dawn. As a Magic action, you can blow the horn while expending 1 charge. One creature of your choice within 600 feet hears a single loud horn note.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_lock_of_trickery", "Lock of Trickery", SLOT_AMULET, RARITY_COMMON, "This lock appears to be an ordinary Lock and comes with a single key. The tumblers in this lock magically adjust to thwart burglars. Dexterity checks made to pick the lock have Disadvantage.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_moon_touched_sword", "Moon-Touched Sword", SLOT_WEAPON, RARITY_COMMON, "In Darkness, the unsheathed blade of this weapon sheds moonlight, creating Bright Light in a 15-foot radius and Dim Light for an additional 15 feet.", 0, 1, 0, 0, 0, 0, 0, 0);
	add_item("dmg_orb_of_direction", "Orb of Direction", SLOT_AMULET, RARITY_COMMON, "This orb can be used as an Arcane Focus. While holding it, you can take a Magic action to determine which way is north.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_orb_of_time", "Orb of Time", SLOT_AMULET, RARITY_COMMON, "This orb can be used as an Arcane Focus. While holding it, you can take a Magic action to determine the time of day or the date.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_perfume_of_bewitching", "Perfume of Bewitching", SLOT_AMULET, RARITY_COMMON, "This tiny vial contains magic perfume, enough for one use. You can take a Magic action to apply the perfume to yourself, and its effect lasts 1 hour. For the duration, you have Advantage on Charisma checks directed at Humanoids of CR 1 or lower.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_charlatans_die", "Charlatan's Die (DMG)", SLOT_AMULET, RARITY_COMMON, "Whenever you roll this loaded d6, you can choose what number it lands on as long as no creature observes you using it.", 0, 0, 0, 0, 0, 0, 0, 0);

	// DMG 2024 Tomes/Manuals (paras 9700-10300+) - permanent stat-boost books
	add_item("dmg_pearl_of_power", "Pearl of Power", SLOT_AMULET, RARITY_UNCOMMON, "While this pearl is on your person, you can take a Magic action to regain one expended spell slot of level 3 or lower.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_quiver_ehlonna", "Quiver of Ehlonna", SLOT_AMULET, RARITY_UNCOMMON, "Each of the quiver's three compartments connects to an extradimensional space that allows the quiver to hold numerous items while never weighing more than 2 pounds.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_mantle_spell_resist", "Mantle of Spell Resistance", SLOT_ARMOR, RARITY_RARE, "You have Advantage on saving throws against spells while you wear this cloak.", 1, 0, 0, 0, 0, 0, 2, 0);
	add_item("dmg_tome_understanding", "Tome of Understanding", SLOT_AMULET, RARITY_EPIC, "After spending 48 hours studying this tome, your Wisdom score increases by 2, as does your maximum for that score. The book then loses its magic.", 0, 0, 5, 1, 0, 0, 1, 0);
	add_item("dmg_tome_clear_thought", "Tome of Clear Thought", SLOT_AMULET, RARITY_EPIC, "After spending 48 hours studying this tome, your Intelligence score increases by 2, as does your maximum for that score.", 0, 0, 5, 1, 0, 0, 1, 0);
	add_item("dmg_tome_leadership", "Tome of Leadership and Influence", SLOT_AMULET, RARITY_EPIC, "After spending 48 hours studying this tome, your Charisma score increases by 2, as does your maximum for that score.", 0, 0, 5, 1, 0, 0, 1, 0);
	add_item("dmg_manual_bodily_health", "Manual of Bodily Health", SLOT_AMULET, RARITY_EPIC, "After spending 48 hours studying this tome, your Constitution score increases by 2.", 0, 0, 15, 0, 0, 0, 1, 0);
	add_item("dmg_manual_gainful_exercise", "Manual of Gainful Exercise", SLOT_AMULET, RARITY_EPIC, "After spending 48 hours studying this tome, your Strength score increases by 2.", 0, 3, 5, 0, 0, 0, 0, 0);
	add_item("dmg_manual_quickness", "Manual of Quickness of Action", SLOT_AMULET, RARITY_EPIC, "After spending 48 hours studying this tome, your Dexterity score increases by 2.", 0, 0, 5, 0, 2, 5, 0, 0);

	// DMG 2024 Necklaces, Brooches, Crystal Balls, Gloves, Dust, Headbands (paras 7700-9180)
	add_item("dmg_brooch_shielding", "Brooch of Shielding", SLOT_AMULET, RARITY_UNCOMMON, "While wearing this brooch, you have Resistance to Force damage and Immunity to damage from the Magic Missile spell.", 0, 0, 5, 0, 0, 0, 1, 0);
	add_item("dmg_carpet_flying", "Carpet of Flying", SLOT_AMULET, RARITY_EPIC, "You can take a Magic action to make this carpet hover and fly. It moves at a Fly Speed of 60 feet, can carry a stated weight, and can be commanded by anyone riding it.", 0, 0, 0, 0, 1, 0, 0, 0);
	add_item("dmg_crystal_ball", "Crystal Ball", SLOT_AMULET, RARITY_EPIC, "The typical Crystal Ball is about 6 inches in diameter. While touching it, you can take a Magic action to cast Scrying from it.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_dust_disappearance", "Dust of Disappearance", SLOT_AMULET, RARITY_UNCOMMON, "Found in a small packet, this powder resembles very fine sand. There is enough of it for one use. When you use a Magic action to throw the dust into the air, you and each creature and object within 10 feet of you have the Invisible condition for 10 minutes.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_gem_brightness", "Gem of Brightness", SLOT_AMULET, RARITY_UNCOMMON, "This prism has 50 charges. While you hold it, you can take a Magic action to expend 1 charge and cause it to project Bright Light in a 30-foot cone.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_gloves_missile_snaring", "Gloves of Missile Snaring", SLOT_ARMOR, RARITY_UNCOMMON, "These gloves seem to almost meld into your hands when you don them. When a ranged weapon attack hits you, you can take a Reaction to reduce the damage by 1d10 + your Dexterity modifier and possibly catch the missile.", 0, 0, 0, 0, 1, 0, 0, 0);
	add_item("dmg_gloves_swim_climb", "Gloves of Swimming and Climbing", SLOT_ARMOR, RARITY_UNCOMMON, "While wearing these gloves, climbing and swimming don't cost you extra movement, and you gain a +5 bonus to Strength (Athletics) checks made to climb or swim.", 0, 0, 0, 0, 0, 5, 0, 0);
	add_item("dmg_gloves_thievery", "Gloves of Thievery", SLOT_ARMOR, RARITY_UNCOMMON, "These gloves are invisible while worn. While wearing them, you gain a +5 bonus to Dexterity (Sleight of Hand) checks and Dexterity checks made to pick locks.", 0, 0, 0, 0, 1, 0, 0, 0);
	add_item("dmg_headband_intellect", "Headband of Intellect", SLOT_ARMOR, RARITY_UNCOMMON, "Your Intelligence score is 19 while you wear this headband. It has no effect on you if your Intelligence is 19 or higher without it.", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("dmg_necklace_adaptation", "Necklace of Adaptation", SLOT_AMULET, RARITY_UNCOMMON, "While wearing this necklace, you can breathe normally in any environment, and you have Advantage on saving throws against harmful gases and vapors.", 0, 0, 5, 0, 0, 0, 1, 0);
	add_item("dmg_necklace_fireballs", "Necklace of Fireballs", SLOT_AMULET, RARITY_RARE, "This necklace has 1d6+3 beads hanging from it. You can take a Magic action to detach a bead and throw it up to 60 feet away. When it reaches the end of its trajectory, the bead detonates as a level 3 Fireball.", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("dmg_necklace_prayer_beads", "Necklace of Prayer Beads", SLOT_AMULET, RARITY_RARE, "This necklace has 1d4+2 magic beads. While wearing the necklace, you can use a Bonus Action to speak the prayer associated with one of the beads to cast its spell.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_ioun_stone_intellect", "Ioun Stone of Intellect", SLOT_AMULET, RARITY_RARE, "An Ioun Stone is a magical, dim-lit stone that orbits around your head when activated. While the stone orbits your head, your Intelligence score increases by 2, to a maximum of 20.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_ioun_stone_protection", "Ioun Stone of Protection", SLOT_AMULET, RARITY_RARE, "While the stone orbits your head, you gain a +1 bonus to AC.", 1, 0, 0, 0, 0, 0, 0, 0);

	// DMG 2024 More Rings (paras 9550-9700+)
	add_item("dmg_ring_free_action", "Ring of Free Action", SLOT_RING, RARITY_RARE, "While you wear this ring, Difficult Terrain doesn't cost you extra movement. In addition, magic can neither reduce any of your Speeds nor cause you to have the Paralyzed or Restrained condition.", 0, 0, 0, 0, 0, 5, 1, 0);
	add_item("dmg_ring_mind_shielding", "Ring of Mind Shielding", SLOT_RING, RARITY_UNCOMMON, "While wearing this ring, you are immune to magic that allows other creatures to read your thoughts, determine whether you are lying, know your alignment, or know your creature type.", 0, 0, 0, 0, 0, 0, 1, 0);
	add_item("dmg_ring_swimming", "Ring of Swimming", SLOT_RING, RARITY_UNCOMMON, "You have a Swim Speed of 40 feet while wearing this ring.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_ring_telekinesis", "Ring of Telekinesis", SLOT_RING, RARITY_EPIC, "While wearing this ring, you can cast Telekinesis from it.", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("dmg_ring_water_walking", "Ring of Water Walking", SLOT_RING, RARITY_UNCOMMON, "While wearing this ring, you cast Water Walk from it, targeting only yourself.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_ring_xray_vision", "Ring of X-ray Vision", SLOT_RING, RARITY_RARE, "While wearing this ring, you can take a Magic action to gain X-ray vision with a range of 30 feet for 1 minute.", 0, 0, 0, 0, 1, 0, 0, 0);
	add_item("dmg_ring_feather_falling", "Ring of Feather Falling", SLOT_RING, RARITY_RARE, "When you fall while wearing this ring, you descend 60 feet per round and take no damage from falling.", 0, 0, 5, 0, 0, 0, 0, 0);
	add_item("dmg_ring_jumping", "Ring of Jumping", SLOT_RING, RARITY_UNCOMMON, "While wearing this ring, you can cast Jump from it, but can target only yourself when you do so.", 0, 0, 0, 0, 0, 5, 0, 0);

	// DMG 2024 More Wondrous (paras 8287-10032)
	add_item("dmg_iron_bands_bilarro", "Iron Bands of Bilarro", SLOT_AMULET, RARITY_RARE, "This rusty iron sphere measures 3 inches in diameter. You can take a Magic action to throw the sphere at a Huge or smaller creature you can see within 60 feet, ensnaring them in iron bands.", 0, 1, 0, 0, 0, 0, 0, 0);
	add_item("dmg_sphere_annihilation", "Sphere of Annihilation", SLOT_AMULET, RARITY_LEGENDARY, "This 2-foot-diameter black sphere is a hole in the multiverse. It is unsupported and motionless unless you are within 60 feet of it. Anything that touches the sphere is destroyed.", 0, 5, 0, 3, 0, 0, 1, 0);
	add_item("dmg_goggles_of_night", "Goggles of Night", SLOT_ARMOR, RARITY_UNCOMMON, "While wearing these dark lenses, you have Darkvision out to 60 feet. If you already have Darkvision, wearing the goggles increases its range by 60 feet.", 0, 0, 0, 0, 1, 0, 0, 0);
	add_item("dmg_lantern_revealing", "Lantern of Revealing", SLOT_AMULET, RARITY_UNCOMMON, "While lit, this hooded lantern burns for 6 hours on 1 pint of oil, shedding Bright Light in a 30-foot radius. Invisible creatures and objects are visible as long as they are in the lantern's Bright Light.", 0, 0, 0, 0, 1, 0, 0, 0);
	add_item("dmg_driftglobe", "Driftglobe", SLOT_AMULET, RARITY_UNCOMMON, "This small sphere of thick glass weighs 1 pound. You can command it to emanate light equivalent to that of the Light or Daylight spell. The globe can also hover and follow you up to 60 feet away.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_folding_boat", "Folding Boat", SLOT_AMULET, RARITY_RARE, "This object appears as a wooden box that measures 12 inches long, 6 inches wide, and 6 inches deep. You can take a Bonus Action to speak one of three command words to cause it to unfold into a rowboat, sailing ship, or longship.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_handy_haversack", "Handy Haversack", SLOT_AMULET, RARITY_RARE, "This backpack has a central pouch and two side pouches, each of which is an extradimensional space.", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("dmg_apparatus_kwalish", "Apparatus of Kwalish", SLOT_ARMOR, RARITY_LEGENDARY, "A sealed iron barrel weighing 500 pounds that becomes a Large submersible vehicle when activated. AC 20, HP 200, Speed 30 ft (Swim 30 ft), Immunity to Poison and Psychic damage.", 6, 0, 50, 0, 0, 0, 2, 0);

	// Tasha's Cauldron of Everything magic items (verified against TASHA's source paras 6648-6862+)
	// Source quotes from TASHA'S CAULDRON OF EVERYTHING.docx
	add_item("tasha_absorbing_tattoo", "Absorbing Tattoo", SLOT_AMULET, RARITY_EPIC, "Produced by a special needle, this magic tattoo features designs that emphasize one color. While the tattoo is on your skin, you have resistance to a type of damage associated with that color. (Tasha's, Very Rare, Requires Attunement)", 0, 0, 5, 0, 0, 0, 1, 0);
	add_item("tasha_barrier_tattoo", "Barrier Tattoo", SLOT_ARMOR, RARITY_RARE, "Produced by a special needle, this magic tattoo depicts protective imagery and uses ink that resembles liquid metal. While you aren't wearing armor, the tattoo grants you an Armor Class depending on the tattoo's rarity. (Tasha's)", 3, 0, 0, 0, 0, 0, 0, 0);
	add_item("tasha_alchemical_compendium", "Alchemical Compendium", SLOT_AMULET, RARITY_RARE, "While you are holding the book, you can use it as a spellcasting focus for your wizard spells. The book has 3 charges, and it regains 1d3 expended charges daily at dawn. (Tasha's, Rare, Requires Attunement by a Wizard)", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("tasha_astral_shard", "Astral Shard", SLOT_AMULET, RARITY_RARE, "This crystal is a solidified shard of the Astral Plane, swirling with silver mist. When you use a Metamagic option on a spell while you are holding or wearing the shard, immediately after casting the spell you can teleport to an unoccupied space you can see within 30 feet of you. (Tasha's, Rare, Requires Attunement by a Sorcerer)", 0, 0, 0, 1, 1, 0, 0, 0);
	add_item("tasha_bloodwell_vial", "Bloodwell Vial", SLOT_AMULET, RARITY_RARE, "When you roll any Hit Dice to recover hit points while you are carrying the vial, you can regain 5 sorcery points. This property of the vial can't be used again until the next dawn. (Tasha's, Uncommon/Rare/Very Rare, Requires Attunement by a Sorcerer)", 0, 0, 5, 1, 0, 0, 0, 0);
	add_item("tasha_crystalline_chronicle", "Crystalline Chronicle", SLOT_AMULET, RARITY_EPIC, "An etched crystal sphere the size of a grapefruit hums faintly and pulses with irregular flares of inner light. While you are touching the crystal, you can retrieve and store information and spells within it. (Tasha's, Very Rare, Requires Attunement by a Wizard)", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("tasha_eldritch_claw_tattoo", "Eldritch Claw Tattoo", SLOT_AMULET, RARITY_UNCOMMON, "While the tattoo is on your skin, your unarmed strikes are considered magical for the purpose of overcoming immunity and resistance to nonmagical attacks, and you gain a +1 bonus to attack and damage rolls with unarmed strikes. (Tasha's, Uncommon, Requires Attunement)", 0, 1, 0, 0, 0, 0, 0, 0);

	// Tasha's additional items (2026-04-08 batch — verified against TASHA's source)
	add_item("tasha_all_purpose_tool", "All-Purpose Tool", SLOT_WEAPON, RARITY_RARE, "This simple screwdriver can transform into a variety of tools. While holding this tool, you gain a bonus to the spell attack rolls and the saving throw DCs of your artificer spells. (Tasha's para 6695, Uncommon/Rare/Very Rare, Requires Attunement by an Artificer)", 0, 1, 0, 2, 0, 0, 0, 0);
	add_item("tasha_amulet_of_the_devout", "Amulet of the Devout", SLOT_AMULET, RARITY_RARE, "This amulet bears the symbol of a deity inlaid with precious stones or metals. While you wear the holy symbol, you gain a bonus to spell attack rolls and the saving throw DCs of your spells. You can use your Channel Divinity feature without expending a use, once per dawn. (Tasha's para 6700, Uncommon/Rare/Very Rare, Requires Attunement by a Cleric or Paladin)", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("tasha_arcane_grimoire", "Arcane Grimoire", SLOT_AMULET, RARITY_RARE, "While you are holding this leather-bound book, you can use it as a spellcasting focus for your wizard spells, and you gain a bonus to spell attack rolls and to the saving throw DCs of your wizard spells. When you use Arcane Recovery, you can regain 1 additional spell slot level. (Tasha's para 6704, Uncommon/Rare/Very Rare, Requires Attunement by a Wizard)", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("tasha_atlas_endless_horizons", "Atlas of Endless Horizons", SLOT_AMULET, RARITY_RARE, "This thick book is bound in dark leather, crisscrossed with inlaid silver lines suggesting a map or chart. When found, the book contains the following spells, which are wizard spells for you while you read it. (Tasha's para 6719, Rare, Requires Attunement by a Wizard)", 0, 0, 0, 1, 0, 5, 0, 0);
	add_item("tasha_bell_branch", "Bell Branch", SLOT_AMULET, RARITY_RARE, "This silver implement is shaped like a tree branch and is strung with small golden bells. The branch is a spellcasting focus for your spells. The branch has 3 charges and detects aberrations, celestials, constructs, elementals, fey, fiends, or undead within 60 feet. (Tasha's para 6760, Rare, Requires Attunement by a Druid or Warlock)", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("tasha_blood_fury_tattoo", "Blood Fury Tattoo", SLOT_AMULET, RARITY_LEGENDARY, "Produced by a special needle, this magic tattoo evokes fury in its form and colors. While the tattoo is on your skin, you can deal extra damage with melee weapon attacks and use a reaction when damaged to make a melee attack. (Tasha's para 6766, Legendary, Requires Attunement)", 0, 3, 5, 0, 0, 0, 0, 0);
	add_item("tasha_coiling_grasp_tattoo", "Coiling Grasp Tattoo", SLOT_AMULET, RARITY_UNCOMMON, "Produced by a special needle, this magic tattoo has long intertwining designs. As a reaction when a creature you can see ends its turn within 30 feet of you, you can magically grasp it. (Tasha's para 6785, Uncommon, Requires Attunement)", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("tasha_feywild_shard", "Feywild Shard", SLOT_AMULET, RARITY_UNCOMMON, "This warm crystal glints with the sunset colors of the Feywild sky. When you use a Metamagic option on a spell while holding the shard, you can roll on the Wild Magic Surge table. (Tasha's para 6890, Uncommon, Requires Attunement by a Sorcerer)", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("tasha_guardian_emblem", "Guardian Emblem", SLOT_AMULET, RARITY_UNCOMMON, "This emblem is the symbol of a deity or a spiritual tradition. The emblem has 3 charges. When you or a creature within 30 feet suffers a critical hit while you're wearing the armor or shield bearing the emblem, you can use your reaction to expend 1 charge to turn it into a normal hit. (Tasha's para 6913, Uncommon, Requires Attunement by a Cleric or Paladin)", 0, 0, 0, 0, 0, 0, 1, 0);
	add_item("tasha_heart_weavers_primer", "Heart Weaver's Primer", SLOT_AMULET, RARITY_RARE, "This pristine book contains the following spells: antipathy/sympathy, charm person, dominate person, enthrall, hypnotic pattern. While holding it, you can use it as a spellcasting focus for your wizard spells. (Tasha's para 6918, Rare, Requires Attunement by a Wizard)", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("tasha_illuminators_tattoo", "Illuminator's Tattoo", SLOT_AMULET, RARITY_COMMON, "Produced by a special needle, this magic tattoo features beautiful calligraphy and images of writing implements. While the tattoo is on your skin, you can produce illumination from your fingertip. (Tasha's para 6925, Common, Requires Attunement)", 0, 0, 0, 0, 0, 0, 0, 0);
	add_item("tasha_lifewell_tattoo", "Lifewell Tattoo", SLOT_AMULET, RARITY_EPIC, "Produced by a special needle, this magic tattoo features symbols of life and rebirth. While the tattoo is on your skin, you have a number of charges based on rarity that allow you to gain temporary hit points when reduced to 0. (Tasha's para 6939, Very Rare, Requires Attunement)", 0, 0, 10, 0, 0, 0, 1, 0);
	add_item("tasha_lyre_of_building", "Lyre of Building", SLOT_AMULET, RARITY_RARE, "While holding this lyre, you can cast mending as an action. You can play the lyre as a reaction to prevent damage to objects/structures, and to cast fabricate, move earth, passwall, or summon construct. (Tasha's para 7018, Rare, Requires Attunement by a Bard)", 0, 0, 0, 1, 0, 0, 0, 0);
	add_item("tasha_moon_sickle", "Moon Sickle", SLOT_WEAPON, RARITY_RARE, "This silver-bladed sickle glimmers softly with moonlight. While holding this magic weapon, you gain a bonus to attack and damage rolls, and you gain a bonus to spell attack rolls and the saving throw DCs of your spells. When you cast a healing spell, you can roll a d4 and add the number to hit points restored. (Tasha's para 7084, Uncommon/Rare/Very Rare, Requires Attunement by a Druid or Ranger)", 0, 2, 0, 2, 0, 0, 0, 0);
	add_item("tasha_natures_mantle", "Nature's Mantle", SLOT_ARMOR, RARITY_UNCOMMON, "This cloak shifts color and texture to blend with the terrain surrounding you. While wearing the cloak, you can use it as a spellcasting focus for your druid and ranger spells. While in an area that is lightly obscured, you can Hide as a bonus action even if directly observed. (Tasha's para 7088, Uncommon, Requires Attunement by a Druid or Ranger)", 0, 0, 0, 1, 1, 0, 0, 0);
	add_item("tasha_revelers_concertina", "Reveler's Concertina", SLOT_AMULET, RARITY_RARE, "While holding this concertina, you gain a +2 bonus to the saving throw DC of your bard spells. As an action, you can use the concertina to cast Otto's irresistible dance from the item, once per dawn. (Tasha's para 7126, Rare, Requires Attunement by a Bard)", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("tasha_rhythm_makers_drum", "Rhythm-Maker's Drum", SLOT_AMULET, RARITY_RARE, "While holding this drum, you gain a bonus to spell attack rolls and to the saving throw DCs of your bard spells. As an action, you can play the drum to regain one use of your Bardic Inspiration feature, once per dawn. (Tasha's para 7130, Uncommon/Rare/Very Rare, Requires Attunement by a Bard)", 0, 0, 0, 2, 0, 0, 0, 0);

	// Fizban's Treasury of Dragons items (verified against FIZBAN'S source)
	add_item("fizban_amethyst_lodestone", "Amethyst Lodestone", SLOT_AMULET, RARITY_EPIC, "This fist-sized chunk of amethyst is infused with an amethyst dragon's ability to bend gravitational forces. While carrying the lodestone, you have advantage on Strength saving throws. The lodestone has 6 charges for various gravitational properties. (Fizban's para 802, Very Rare, Requires Attunement)", 0, 0, 0, 1, 0, 0, 1, 0);
	add_item("fizban_crystal_blade", "Crystal Blade", SLOT_WEAPON, RARITY_RARE, "This magic sword's blade is fashioned from a horn or spine from a crystal dragon. When you hit with an attack roll using this sword, the target takes an extra 1d8 radiant damage. The sword has 3 charges to regain hit points equal to damage dealt. (Fizban's para 809, Rare, Requires Attunement)", 0, 2, 0, 0, 0, 0, 0, 0);
	add_item("fizban_dragonhide_belt", "Dragonhide Belt", SLOT_AMULET, RARITY_RARE, "This finely detailed belt is made of dragonhide. While wearing it, you gain a bonus to the saving throw DCs of your ki features. (Fizban's para 814, Uncommon/Rare/Very Rare, Requires Attunement by a Monk)", 0, 0, 0, 2, 0, 0, 0, 0);
	add_item("fizban_dragonlance", "Dragonlance", SLOT_WEAPON, RARITY_LEGENDARY, "A dragonlance is a renowned weapon forged from rare metal with the aid of powerful artifacts associated with Bahamut. You gain a +3 bonus to attack and damage rolls made with this magic weapon. Against dragons, the lance deals an extra 2d6 damage. (Fizban's para 817, Legendary, Requires Attunement)", 0, 5, 0, 0, 0, 0, 1, 0);
	add_item("fizban_dragon_wing_bow", "Dragon Wing Bow", SLOT_WEAPON, RARITY_RARE, "The limb tips of this magic bow are shaped like a dragon's wings, and the weapon is infused with the essence of a dragon's breath. When you hit with an attack roll using this bow, the target takes an extra 1d6 damage of the type matching the dragon (acid, cold, fire, lightning, or poison). (Fizban's para 822, Rare, Requires Attunement)", 0, 2, 0, 0, 0, 0, 0, 0);
	add_item("fizban_dragons_wrath_weapon", "Dragon's Wrath Weapon", SLOT_WEAPON, RARITY_EPIC, "This weapon is decorated with dragon heads, claws, wings, scales, or Draconic letters. When it steeps in a dragon's hoard, it absorbs the energy of the dragon's breath weapon and deals damage of that type. (Fizban's para 929, Rarity Varies, Requires Attunement)", 0, 3, 0, 0, 0, 0, 0, 0);
	add_item("fizban_dragon_touched_focus", "Dragon-Touched Focus", SLOT_AMULET, RARITY_RARE, "This wondrous item can be a scepter, an orb, an amulet, a crystal, or another finely crafted object. It typically incorporates imagery of dragons' wings, claws, teeth, or scales. While holding the focus, it can function as a spellcasting focus for all your spells. (Fizban's para 941, Slumbering=Uncommon, Stirring=Rare, Wakened=Very Rare, Ascendant=Legendary, Requires Attunement by a Spellcaster)", 0, 0, 0, 1, 1, 0, 0, 0);
	add_item("fizban_dragon_vessel", "Dragon Vessel", SLOT_AMULET, RARITY_RARE, "This vessel can be a potion bottle, drinking horn, or other container meant to hold a liquid. Slumbering: refills with ale, oil, healing potion, or climbing potion. Higher rarities grant breath weapon resistance and reflection abilities. (Fizban's para 954, Rarity Varies, Requires Attunement)", 0, 0, 5, 0, 0, 0, 0, 0);
