	add_item("dmg_ring_protection", "Ring of Protection", SLOT_RING, RARITY_RARE, "You gain a +1 bonus to AC and saving throws while you wear this ring.", 1, 0, 0, 0, 0, 0, 1, 0);
	add_item("dmg_ring_regeneration", "Ring of Regeneration", SLOT_RING, RARITY_EPIC, "While wearing this ring, you regain 1d6 Hit Points every 10 minutes if you have at least 1 Hit Point.", 0, 0, 25, 0, 0, 0, 1, 0);
	add_item("dmg_ring_resistance", "Ring of Resistance", SLOT_RING, RARITY_RARE, "You have Resistance to one type of damage while wearing this ring.", 0, 0, 5, 0, 0, 0, 1, 0);
	add_item("dmg_ring_spell_storing", "Ring of Spell Storing", SLOT_RING, RARITY_RARE, "This ring stores spells cast into it, holding them until the attuned wearer uses them. The ring can store up to 5 levels worth of spells at a time.", 0, 0, 0, 2, 0, 0, 0, 0);
