// ---- LOOT GENERATION ----

int get_loot_tier(int monster_xp) {
	if (monster_xp <= 50) return 0;
	if (monster_xp <= 200) return 1;
	if (monster_xp <= 700) return 2;
	if (monster_xp <= 2900) return 3;
	return 4;
}

item_def@ generate_loot(int monster_xp, int player_level) {
	init_item_catalog();

	int tier = get_loot_tier(monster_xp);
	int roll = random(1, 100);

	// Base drop rates, shifted by tier
	int nothing_threshold = 40 - (tier * 5);
	int common_threshold = nothing_threshold + 30 - (tier * 3);
	int uncommon_threshold = common_threshold + 18 + (tier * 2);
	int rare_threshold = uncommon_threshold + 8 + (tier * 2);
	int epic_threshold = rare_threshold + 3 + tier;

	int target_rarity;
	if (roll <= nothing_threshold) return null;
	else if (roll <= common_threshold) target_rarity = RARITY_COMMON;
	else if (roll <= uncommon_threshold) target_rarity = RARITY_UNCOMMON;
	else if (roll <= rare_threshold) target_rarity = RARITY_RARE;
	else if (roll <= epic_threshold) target_rarity = RARITY_EPIC;
	else target_rarity = RARITY_LEGENDARY;

	// Collect items of the target rarity
	item_def@[] pool;
	for (uint i = 0; i < ITEM_CATALOG.length(); i++) {
		if (ITEM_CATALOG[i].rarity == target_rarity) pool.insert_last(ITEM_CATALOG[i]);
	}

	if (pool.length() == 0) return null;
	return pool[random(0, pool.length() - 1)];
}

item_def@ generate_boss_loot(int monster_xp, int player_level) {
	init_item_catalog();

	int roll = random(1, 100);
	int target_rarity;
	if (roll <= 30) target_rarity = RARITY_RARE;
	else if (roll <= 70) target_rarity = RARITY_EPIC;
	else target_rarity = RARITY_LEGENDARY;

	item_def@[] pool;
	for (uint i = 0; i < ITEM_CATALOG.length(); i++) {
		if (ITEM_CATALOG[i].rarity == target_rarity) pool.insert_last(ITEM_CATALOG[i]);
	}

	if (pool.length() == 0) return null;
	return pool[random(0, pool.length() - 1)];
}

// ---- INVENTORY HELPERS ----

bool inventory_has_item(json_array@ inventory, string item_id) {
	if (@inventory == null) return false;
	for (uint i = 0; i < inventory.length(); i++) {
		json_object@ entry = inventory[i];
		if (@entry != null and entry.exists("id") and string(entry["id"]) == item_id) return true;
	}
	return false;
}

bool inventory_add_item(json_array@ inventory, string item_id) {
	if (@inventory == null or int(inventory.length()) >= MAX_INVENTORY) return false;
	json_object entry;
	entry["id"] = item_id;
	inventory.add(entry);
	return true;
}

bool inventory_remove_item(json_array@ inventory, string item_id) {
	if (@inventory == null) return false;
	for (uint i = 0; i < inventory.length(); i++) {
		json_object@ entry = inventory[i];
		if (@entry != null and entry.exists("id") and string(entry["id"]) == item_id) {
			inventory.remove(i);
			return true;
		}
	}
	return false;
}

// ---- ITEM UPGRADING ----

int get_upgrade_glory_cost(int rarity) {
	if (rarity == RARITY_COMMON) return 10;
	if (rarity == RARITY_UNCOMMON) return 25;
	if (rarity == RARITY_RARE) return 50;
	if (rarity == RARITY_EPIC) return 100;
	return 0;
}

item_def@ generate_upgrade_result(int target_rarity) {
	init_item_catalog();
	item_def@[] pool;
	for (uint i = 0; i < ITEM_CATALOG.length(); i++) {
		if (ITEM_CATALOG[i].rarity == target_rarity) pool.insert_last(ITEM_CATALOG[i]);
	}
	if (pool.length() == 0) return null;
	return pool[random(0, pool.length() - 1)];
}
