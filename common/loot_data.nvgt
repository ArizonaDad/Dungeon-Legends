	add_item("dmg_amulet_of_proof", "Amulet of Proof against Detection and Location", SLOT_AMULET, RARITY_UNCOMMON, "While wearing this amulet, you can't be targeted by Divination spells or perceived through magical scrying sensors unless you allow it.", 0, 0, 0, 0, 0, 0, 1, 0);
	add_item("dmg_amulet_of_planes", "Amulet of the Planes", SLOT_AMULET, RARITY_RARE, "While wearing this amulet, you can take a Magic action to name a location that you are familiar with on another plane of existence.", 0, 0, 0, 1, 0, 0, 1, 0);

	// DMG 2024 Armor / Shields (paras 7311+)
	add_item("dmg_animated_shield", "Animated Shield", SLOT_ARMOR, RARITY_EPIC, "While holding this Shield, you can take a Bonus Action to cause it to animate. The Shield leaps into the air and hovers in your space to protect you as if you were wielding it, leaving your hands free. (Very Rare, Requires Attunement)", 2, 0, 0, 0, 0, 0, 0, 0);

	// DMG 2024 Bags / Wondrous (paras 7479+)
	add_item("dmg_bag_of_holding", "Bag of Holding", SLOT_AMULET, RARITY_UNCOMMON, "This bag has an interior space considerably larger than its outside dimensions, roughly 2 feet square by 4 feet deep, holding up to 500 pounds.", 0, 0, 0, 0, 0, 0, 0, 0);

	// DMG 2024 Belts (paras 7561+)
	add_item("dmg_belt_of_dwarvenkind", "Belt of Dwarvenkind", SLOT_AMULET, RARITY_RARE, "While wearing this belt, your Constitution score increases by 2 (max 20), you gain Advantage on saves against Poison, and you have Resistance to Poison damage.", 0, 0, 10, 0, 0, 0, 1, 0);
	add_item("dmg_belt_of_giant_str_hill", "Belt of Hill Giant Strength", SLOT_AMULET, RARITY_RARE, "Your Strength score is 21 while you wear this belt. It has no effect on you if your Strength is 21 or higher without it.", 0, 3, 0, 0, 0, 0, 0, 0);
	add_item("dmg_belt_of_giant_str_stone", "Belt of Stone/Frost Giant Strength", SLOT_AMULET, RARITY_EPIC, "Your Strength score is 23 while you wear this belt.", 0, 4, 0, 0, 0, 0, 0, 0);
