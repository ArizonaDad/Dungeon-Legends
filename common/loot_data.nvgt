	add_item("dmg_periapt_proof_poison", "Periapt of Proof against Poison", SLOT_AMULET, RARITY_RARE, "This delicate silver chain has a brilliant-cut black gem pendant. While you wear it, you have Immunity to the Poisoned condition and Poison damage.", 0, 0, 0, 0, 0, 0, 1, 0);
	add_item("dmg_periapt_wound_closure", "Periapt of Wound Closure", SLOT_AMULET, RARITY_UNCOMMON, "While wearing this pendant, you stabilize automatically when dying. In addition, when you roll a Hit Die to regain hit points, double the number of HP it restores.", 0, 0, 15, 0, 0, 0, 0, 0);
	add_item("dmg_robe_eyes", "Robe of Eyes", SLOT_ARMOR, RARITY_RARE, "This robe is adorned with eyelike patterns. While you wear the robe, you gain Advantage on Wisdom (Perception) checks, can see in all directions, and have Darkvision out to 120 feet.", 1, 0, 0, 0, 2, 0, 1, 0);
	add_item("dmg_robe_archmagi", "Robe of the Archmagi", SLOT_ARMOR, RARITY_LEGENDARY, "This elegant garment is made from exquisite cloth and adorned with runes. Your base AC becomes 15 + your Dexterity modifier (no shield), you gain Advantage on saves against spells, and your spell save DC and spell attack bonus increase by 2.", 4, 0, 15, 4, 0, 0, 2, 0);

	// DMG 2024 Magic Weapons (paras 7934-10406)
	add_item("dmg_dagger_venom", "Dagger of Venom", SLOT_WEAPON, RARITY_RARE, "You gain a +1 bonus to attack rolls and damage rolls made with this magic weapon. You can use a Bonus Action to coat the dagger in poison; the next creature hit takes 2d10 extra poison damage and must save vs poison.", 0, 3, 0, 0, 0, 0, 0, 0);
	add_item("dmg_flame_tongue", "Flame Tongue", SLOT_WEAPON, RARITY_RARE, "While holding this magic weapon, you can take a Bonus Action and use a command word to cause flames to engulf the damage-dealing part of the weapon. While engulfed, the weapon deals an extra 2d6 Fire damage.", 0, 4, 0, 0, 0, 0, 0, 0);
	add_item("dmg_frost_brand", "Frost Brand", SLOT_WEAPON, RARITY_EPIC, "When you hit with an attack roll using this magic weapon, the target takes an extra 1d6 Cold damage. In addition, while you hold the weapon, you have Resistance to Fire damage.", 0, 4, 5, 0, 0, 0, 1, 0);
	add_item("dmg_hammer_thunderbolts", "Hammer of Thunderbolts", SLOT_WEAPON, RARITY_LEGENDARY, "You gain a +1 bonus to attack rolls and damage rolls made with this magic weapon. When attuned and wearing a Belt of Giant Strength and Gauntlets of Ogre Power, your STR is increased to 25 and you can throw the hammer to make ranged thunder attacks.", 0, 5, 10, 0, 0, 0, 0, 0);
	add_item("dmg_holy_avenger", "Holy Avenger", SLOT_WEAPON, RARITY_LEGENDARY, "You gain a +3 bonus to attack rolls and damage rolls made with this magic weapon. When you hit a Fiend or an Undead with it, that creature takes an extra 2d10 Radiant damage. While holding it, you and friendly creatures within 10 feet have Advantage on saves against spells and other magical effects.", 0, 6, 0, 0, 0, 0, 2, 0);
	add_item("dmg_mace_of_disruption", "Mace of Disruption", SLOT_WEAPON, RARITY_RARE, "When you hit a Fiend or an Undead with this magic weapon, that creature takes an extra 2d6 Radiant damage. If the target has 25 Hit Points or fewer after taking this damage, it must succeed on a DC 15 Wisdom save or be destroyed.", 0, 4, 0, 0, 0, 0, 0, 0);
