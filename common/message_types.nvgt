namespace message_types
{
	const string login = "login";
	const string signup = "signup";
	const string error = "error";
	const string announce = "announce";
	const string pop_text = "pop_text";
	const string chat_message = "chat_message";
	const string tell = "tell";
	const string new_room = "new_room";
	const string list_rooms = "list_rooms";
	const string check_online = "check_online";
	const string join_room = "join_room";
	const string leave_room = "leave_room";
	const string leave_game = "leave_game";
	const string room_players = "room_players";       // Server sends list of players in the room.
	const string kick_player = "kick_player";         // Host kicks a player from the room.
	const string start_game = "start_game";
	const string close_list = "close_list";
	const string private_message = "private_message";
	const string report_player = "report_player";
	const string report_confirm = "report_confirm";
	const string friend_request = "friend_request";
	const string friend_request_received = "friend_request_received";
	const string friend_accept = "friend_accept";
	const string friend_decline = "friend_decline";
	const string friend_remove = "friend_remove";
	const string friend_list = "friend_list";
	const string friend_online = "friend_online";
	const string pending_requests = "pending_requests";
	const string password_required = "password_required";
	const string password_submit = "password_submit";
	const string room_closed = "room_closed";
	const string game_invite = "game_invite";                 // Client sends game invite to a friend.
	const string game_invite_received = "game_invite_received"; // Server notifies client of incoming invite.
	const string game_invite_response = "game_invite_response"; // Client accepts/declines an invite.

	// AI bot management.
	const string add_bot = "add_bot";                           // Host requests to add an AI player to the room.
	const string remove_bot = "remove_bot";                     // Host requests to remove an AI player.

	// === COMBAT SYSTEM ===
	// Game state
	const string game_state = "game_state";                   // Server sends full game state snapshot.
	const string game_start_battle = "game_start_battle";     // Server signals battle has begun.
	const string game_end_battle = "game_end_battle";         // Server signals battle is over.

	// Turn system
	const string turn_start = "turn_start";                   // Server tells a player their turn started.
	const string turn_end = "turn_end";                       // Client signals they end their turn.
	const string initiative_order = "initiative_order";       // Server sends initiative order to all.
	const string roll_request = "roll_request";               // Server asks client to press Roll.
	const string roll_result = "roll_result";                 // Client pressed Roll, server sends result.
	const string bardic_prompt = "bardic_prompt";             // Server offers Bardic Inspiration after a failed roll.
	const string bardic_response = "bardic_response";         // Client chooses whether to spend Bardic Inspiration.
	const string lucky_prompt = "lucky_prompt";               // Server offers Lucky reroll after a failed d20 roll.
	const string lucky_response = "lucky_response";           // Client chooses whether to spend a Luck Point.
	const string heroic_prompt = "heroic_prompt";             // Server offers Heroic Inspiration reroll after a failed d20 roll.
	const string heroic_response = "heroic_response";         // Client chooses whether to spend Heroic Inspiration.
	const string tactical_mind_prompt = "tactical_mind_prompt";   // Server offers Fighter L2 Tactical Mind: spend a Second Wind use to add 1d10 to a failed ability check.
	const string tactical_mind_response = "tactical_mind_response"; // Client chooses whether to spend a Second Wind use on Tactical Mind.

	// Actions
	const string action_move = "action_move";                 // Client moves their character.
	const string action_attack = "action_attack";             // Client attacks a target.
	const string action_cast = "action_cast";                 // Client casts a spell.
	const string action_dodge = "action_dodge";               // Client takes Dodge action.
	const string action_dash = "action_dash";                 // Client takes Dash action.
	const string action_disengage = "action_disengage";       // Client takes Disengage action.
	const string action_help = "action_help";                 // Client takes Help action.
	const string action_hide = "action_hide";                 // Client takes Hide action.
	const string action_ready = "action_ready";               // Client readies an action.
	const string action_use_item = "action_use_item";         // Client uses an item.
	const string action_shove = "action_shove";               // Client shoves a target.
	const string action_grapple = "action_grapple";           // Client grapples a target.
	const string action_grapple_escape = "action_grapple_escape"; // Client attempts to escape a grapple.
	const string action_stabilize = "action_stabilize";         // Client attempts to stabilize a dying ally.
	const string action_call_lightning = "action_call_lightning"; // Client uses action to call another lightning bolt.
	const string action_flame_blade = "action_flame_blade";     // Client uses action to attack with Flame Blade.
	const string action_investiture_ice = "action_investiture_ice";       // Client uses action for Investiture of Ice cone.
	const string action_investiture_stone = "action_investiture_stone";   // Client uses action for Investiture of Stone earthquake.
	const string action_investiture_wind = "action_investiture_wind";     // Client uses action for Investiture of Wind blast.
	const string bonus_action = "bonus_action";               // Client uses bonus action.
	const string reaction_opportunity = "reaction_opp";       // Server triggers opportunity attack.
	const string reaction_spell = "reaction_spell";           // Client uses a reaction spell.
	const string reaction_ready_trigger = "reaction_ready";   // Server triggers readied action.
	const string smite_prompt = "smite_prompt";               // Server asks Paladin if they want to Divine Smite after melee hit.
	const string smite_response = "smite_response";           // Client responds to Divine Smite prompt.
	const string reaction_prompt = "reaction_prompt";         // Server offers defender reaction options before attack resolves.
	const string reaction_response = "reaction_response";     // Client responds to reaction prompt.
	const string spell_choice_prompt = "spell_choice_prompt";   // Server asks caster to pick a mid-spell variant (e.g., Fire Shield warm/chill, Spirit Guardians radiant/necrotic, Adjust Density halve/double).
	const string spell_choice_response = "spell_choice_response"; // Client responds with their selected option key.

	// Combat feedback
	const string damage_dealt = "damage_dealt";               // Server announces damage to all.
	const string healing_done = "healing_done";               // Server announces healing.
	const string condition_applied = "condition_applied";     // Server announces condition change.
	const string condition_removed = "condition_removed";     // Server announces condition removed.
	const string death_save = "death_save";                   // Server/client death saving throw.
	const string creature_died = "creature_died";             // Server announces a creature died.
	const string creature_stabilized = "creature_stabilized"; // Server announces stabilization.
	const string spell_effect = "spell_effect";               // Server announces spell effect.
	const string concentration_check = "concentration_check"; // Server requests concentration save.

	// Scanning / targeting
	const string scan_direction = "scan_direction";           // Client scans IJKL direction.
	const string scan_result = "scan_result";                 // Server sends scan results.
	const string set_target = "set_target";                   // Client locks onto a target.
	const string target_info = "target_info";                 // Server sends target details.

	// Character data
	const string character_data = "character_data";           // Server sends active character sheet.
	const string character_create = "character_create";       // Client creates a new character (appended to list).
	const string character_list = "character_list";           // Server sends list of all characters for a profile.
	const string character_select = "character_select";       // Client sets active character slot.
	const string character_delete = "character_delete";       // Client deletes a character by slot.
	const string level_up = "level_up";                       // Client levels up.
	const string spell_list = "spell_list";                   // Server sends available spells.
	const string inventory_update = "inventory_update";       // Server sends inventory changes.
	const string progression_update = "progression_update";   // Server sends Adventure XP/progression updates.
	const string achievement_unlocked = "achievement_unlocked"; // Server announces a newly earned achievement.

	// Level-up / daily
	const string level_up_choices = "level_up_choices";       // Server sends level-up options after Adventure battle.
	const string level_up_response = "level_up_response";     // Client sends chosen spells/subclass.
	const string daily_bonus = "daily_bonus";                 // Server sends daily login bonus info.

	// Monster/wave system
	const string wave_start = "wave_start";                   // Server announces new wave.
	const string wave_complete = "wave_complete";             // Server announces wave cleared.
	const string monster_spawn = "monster_spawn";             // Server spawns monster.
	const string monster_action = "monster_action";           // Server announces monster action.
	const string monster_update = "monster_update";           // Server sends monster state update.

	// Loot & inventory system
	const string loot_drop = "loot_drop";                     // Server sends loot items after battle.
	const string inventory_list = "inventory_list";           // Server sends full inventory to client.
	const string equip_item = "equip_item";                   // Client equips an item.
	const string discard_item = "discard_item";               // Client discards an item.
	const string glory_update = "glory_update";               // Server sends updated Glory Points.

	// Prestige system
	const string prestige_action = "prestige_action";         // Client requests prestige reset.

	// Endless survival mode
	const string endless_wave_start = "endless_wave_start";   // Server announces next endless wave.

	// Item upgrading
	const string upgrade_item = "upgrade_item";               // Client requests to upgrade 3 items into 1.

	// Trading system
	const string trade_request = "trade_request";             // Client sends trade request to another player.
	const string trade_accept = "trade_accept";               // Target accepts a trade request.
	const string trade_offer = "trade_offer";                 // Client updates their offered items in a trade.
	const string trade_confirm = "trade_confirm";             // Client confirms the trade.
	const string trade_cancel = "trade_cancel";               // Client cancels the trade.
	const string trade_update = "trade_update";               // Server sends trade state update to both players.
	const string trade_complete = "trade_complete";           // Server announces trade completed successfully.

	// Weekly challenges
	const string weekly_challenges = "weekly_challenges";     // Client requests or server sends weekly challenge data.
	const string challenge_complete = "challenge_complete";   // Server announces a challenge was completed.

	// Glory shop
	const string glory_shop_list = "glory_shop_list";         // Client requests or server sends glory shop listings.
	const string glory_shop_buy = "glory_shop_buy";           // Client requests to buy a glory shop item.
	const string set_active_title = "set_active_title";       // Client requests to set their active title.

	// Daily dungeon
	const string daily_dungeon_info = "daily_dungeon_info";   // Server sends daily dungeon info to client.

	// Leaderboards
	const string leaderboard_request = "leaderboard_request"; // Client requests leaderboard data.
	const string leaderboard_data = "leaderboard_data";       // Server sends leaderboard data to client.

	// Consumable shop & modifiers
	const string shop_list = "shop_list";                     // Client requests or server sends shop item list.
	const string shop_buy = "shop_buy";                       // Client requests to buy a consumable.
	const string use_consumable = "use_consumable";           // Client uses a consumable in combat.
	const string modifier_info = "modifier_info";             // Server sends active dungeon modifier info.

	// Guild system
	const string create_guild = "create_guild";               // Client requests to create a new guild.
	const string join_guild = "join_guild";                    // Client requests to join an existing guild.
	const string leave_guild = "leave_guild";                  // Client requests to leave their guild.
	const string guild_chat = "guild_chat";                    // Client sends a message to guild members.
	const string guild_info = "guild_info";                    // Client requests or server sends guild info.
	const string guild_invite = "guild_invite";                // Client invites a friend to their guild.
	const string guild_invite_received = "guild_invite_received"; // Server notifies client of incoming guild invite.
	const string guild_invite_response = "guild_invite_response"; // Client accepts/declines a guild invite.

	// Player stats
	const string player_stats = "player_stats";               // Client requests or server sends full player stats.
	const string inspect_player = "inspect_player";           // Client requests to view another player's public stats.
	const string player_inspect_data = "player_inspect_data"; // Server sends inspected player's public stats.
}
