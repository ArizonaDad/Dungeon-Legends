feat_choice_def@ get_feat_choice(string id) {
	init_feat_data();
	for (uint i = 0; i < FEAT_CHOICES.length(); i++) {
		if (FEAT_CHOICES[i].id == id) return FEAT_CHOICES[i];
	}
	return null;
}

background_choice_def@ get_background_choice(string id) {
	init_feat_data();
	for (uint i = 0; i < BACKGROUND_CHOICES.length(); i++) {
		if (BACKGROUND_CHOICES[i].id == id) return BACKGROUND_CHOICES[i];
	}
	return null;
}

bool feat_is_repeatable(string id) {
	feat_choice_def@ feat = get_feat_choice(id);
	return @feat != null and feat.repeatable;
}

bool feat_is_origin(string id) {
	feat_choice_def@ feat = get_feat_choice(id);
	return @feat != null and feat.category == FEAT_CATEGORY_ORIGIN;
}

bool feat_is_fighting_style(string id) {
	feat_choice_def@ feat = get_feat_choice(id);
	return @feat != null and feat.category == FEAT_CATEGORY_FIGHTING_STYLE;
}

bool feat_is_epic_boon(string id) {
	feat_choice_def@ feat = get_feat_choice(id);
	return @feat != null and feat.category == FEAT_CATEGORY_EPIC;
}

bool feat_is_magic_initiate(string id) {
	return id == "magic_initiate_cleric" or id == "magic_initiate_druid" or id == "magic_initiate_wizard";
}

string feat_magic_initiate_list_class(string id) {
	if (id == "magic_initiate_cleric") return "cleric";
	if (id == "magic_initiate_druid") return "druid";
	if (id == "magic_initiate_wizard") return "wizard";
	return "";
}

int ability_id_from_key(string key) {
	key = key.lower();
	if (key == "str" or key == "strength") return ABILITY_STR;
	if (key == "dex" or key == "dexterity") return ABILITY_DEX;
	if (key == "con" or key == "constitution") return ABILITY_CON;
	if (key == "int" or key == "intelligence") return ABILITY_INT;
	if (key == "wis" or key == "wisdom") return ABILITY_WIS;
	if (key == "cha" or key == "charisma") return ABILITY_CHA;
	return -1;
}

string ability_key_from_id(int ability_id) {
	if (ability_id == ABILITY_STR) return "str";
	if (ability_id == ABILITY_DEX) return "dex";
	if (ability_id == ABILITY_CON) return "con";
	if (ability_id == ABILITY_INT) return "int";
	if (ability_id == ABILITY_WIS) return "wis";
	if (ability_id == ABILITY_CHA) return "cha";
	return "";
}
