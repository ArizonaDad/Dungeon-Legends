const string FEAT_CATEGORY_ORIGIN = "origin";
const string FEAT_CATEGORY_GENERAL = "general";
const string FEAT_CATEGORY_FIGHTING_STYLE = "fighting_style";
const string FEAT_CATEGORY_EPIC = "epic";

class feat_choice_def {
	string id;
	string name;
	string category;
	string description;
	bool repeatable = false;
	int min_level = 1;
	string prerequisite_class = "";
	bool requires_fighting_style_feature = false;
	bool requires_spellcasting = false;
	int prerequisite_ability = -1;
	int prerequisite_score = 0;
}

class background_choice_def {
	string id;
	string name;
	string description;
	string ability_csv;
	string feat_id;
	string[] skills;
	string tool_name;
}

class skill_choice_def {
	string name;
	string description;
}

feat_choice_def@[] FEAT_CHOICES;
background_choice_def@[] BACKGROUND_CHOICES;
skill_choice_def@[] SKILL_CHOICES;

void add_feat_choice(string id, string name, string category, string description, bool repeatable = false, int min_level = 1, string prerequisite_class = "", bool requires_fighting_style_feature = false, bool requires_spellcasting = false, int prerequisite_ability = -1, int prerequisite_score = 0) {
	feat_choice_def f;
	f.id = id;
	f.name = name;
	f.category = category;
	f.description = description;
	f.repeatable = repeatable;
	f.min_level = min_level;
	f.prerequisite_class = prerequisite_class;
	f.requires_fighting_style_feature = requires_fighting_style_feature;
	f.requires_spellcasting = requires_spellcasting;
	f.prerequisite_ability = prerequisite_ability;
	f.prerequisite_score = prerequisite_score;
	FEAT_CHOICES.insert_last(f);
}

void add_background_choice(string id, string name, string description, string ability_csv, string feat_id, string[]@ skills, string tool_name) {
	background_choice_def b;
	b.id = id;
	b.name = name;
	b.description = description;
	b.ability_csv = ability_csv;
	b.feat_id = feat_id;
	if (@skills != null) b.skills = skills;
	b.tool_name = tool_name;
	BACKGROUND_CHOICES.insert_last(b);
}

void add_skill_choice(string name, string description) {
	skill_choice_def s;
	s.name = name;
	s.description = description;
	SKILL_CHOICES.insert_last(s);
}

void init_feat_data() {
	if (FEAT_CHOICES.length() > 0) return;

	add_skill_choice("Acrobatics", "Balance, tumble, and wriggle free.");
	add_skill_choice("Animal Handling", "Calm, direct, and understand animals.");
	add_skill_choice("Arcana", "Recall magical lore and theory.");
	add_skill_choice("Athletics", "Climb, jump, wrestle, and overpower.");
	add_skill_choice("Deception", "Lie convincingly and maintain a disguise.");
	add_skill_choice("History", "Recall historical events and lore.");
	add_skill_choice("Insight", "Read motives and emotional tells.");
	add_skill_choice("Intimidation", "Coerce with menace or force of presence.");
	add_skill_choice("Investigation", "Search for clues and make deductions.");
	add_skill_choice("Medicine", "Stabilize and diagnose injuries or illness.");
	add_skill_choice("Nature", "Recall terrain, beasts, and natural lore.");
	add_skill_choice("Perception", "Notice ambushes, creatures, and details.");
	add_skill_choice("Performance", "Entertain with music, dance, or drama.");
	add_skill_choice("Persuasion", "Influence with tact and confidence.");
	add_skill_choice("Religion", "Recall divine lore and rites.");
	add_skill_choice("Sleight of Hand", "Pick pockets and manipulate objects subtly.");
	add_skill_choice("Stealth", "Move quietly and stay hidden.");
	add_skill_choice("Survival", "Track creatures and endure the wilds.");

	add_feat_choice("alert", "Alert", FEAT_CATEGORY_ORIGIN, "Add your Proficiency Bonus to initiative rolls.", false, 1);
	add_feat_choice("magic_initiate_cleric", "Magic Initiate (Cleric)", FEAT_CATEGORY_ORIGIN, "Learn two Cleric cantrips and one level 1 Cleric spell. You can cast the spell once for free each battle.", false, 1);
	add_feat_choice("magic_initiate_druid", "Magic Initiate (Druid)", FEAT_CATEGORY_ORIGIN, "Learn two Druid cantrips and one level 1 Druid spell. You can cast the spell once for free each battle.", false, 1);
	add_feat_choice("magic_initiate_wizard", "Magic Initiate (Wizard)", FEAT_CATEGORY_ORIGIN, "Learn two Wizard cantrips and one level 1 Wizard spell. You can cast the spell once for free each battle.", false, 1);
	add_feat_choice("savage_attacker", "Savage Attacker", FEAT_CATEGORY_ORIGIN, "Once on each of your turns, reroll your weapon damage dice and use either result.", false, 1);
	add_feat_choice("skilled", "Skilled", FEAT_CATEGORY_ORIGIN, "Gain proficiency in any combination of three skills or tools of your choice.", true, 1);
	add_feat_choice("tough", "Tough", FEAT_CATEGORY_ORIGIN, "Your Hit Point maximum increases by 2 per character level.", false, 1);
	add_feat_choice("tavern_brawler", "Tavern Brawler", FEAT_CATEGORY_ORIGIN, "Improve unarmed fighting and push foes when you land an unarmed strike.", false, 1);
	add_feat_choice("healer", "Healer", FEAT_CATEGORY_ORIGIN, "Your healing rolls reroll 1s.", false, 1);
	add_feat_choice("lucky", "Lucky", FEAT_CATEGORY_ORIGIN, "You gain Luck Points equal to your Proficiency Bonus. Spend one to reroll a failed d20 roll.", false, 1);
	add_feat_choice("crafter", "Crafter", FEAT_CATEGORY_ORIGIN, "You gain proficiency with three Artisan's Tools and can craft items at a discount.", false, 1);
	add_feat_choice("musician", "Musician", FEAT_CATEGORY_ORIGIN, "You can play a musical instrument to grant Bardic Inspiration to allies after a rest.", false, 1);

	add_feat_choice("ability_score_improvement", "Ability Score Improvement", FEAT_CATEGORY_GENERAL, "Increase one ability score by 2, or increase two ability scores by 1.", true, 4);
	add_feat_choice("grappler", "Grappler", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1 and gain advantage against creatures grappled by you.", false, 4, "", false, false, -1, 0);

	add_feat_choice("archery", "Archery", FEAT_CATEGORY_FIGHTING_STYLE, "You gain a +2 bonus to attack rolls you make with ranged weapons.", false, 1, "", true);
	add_feat_choice("defense", "Defense", FEAT_CATEGORY_FIGHTING_STYLE, "You gain a +1 bonus to Armor Class.", false, 1, "", true);
	add_feat_choice("great_weapon_fighting", "Great Weapon Fighting", FEAT_CATEGORY_FIGHTING_STYLE, "Treat weapon damage die rolls of 1 or 2 as 3 when wielding a suitable melee weapon.", false, 1, "", true);
	add_feat_choice("two_weapon_fighting", "Two-Weapon Fighting", FEAT_CATEGORY_FIGHTING_STYLE, "Add your ability modifier to the damage of your light-weapon extra attacks.", false, 1, "", true);

	add_feat_choice("boon_of_combat_prowess", "Boon of Combat Prowess", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. Once on each of your turns, a missed attack can hit instead.", false, 19);
	add_feat_choice("boon_of_irresistible_offense", "Boon of Irresistible Offense", FEAT_CATEGORY_EPIC, "Increase Strength or Dexterity by 1. Your natural 20 weapon hits deal extra damage.", false, 19);
	add_feat_choice("boon_of_spell_recall", "Boon of Spell Recall", FEAT_CATEGORY_EPIC, "Increase Intelligence, Wisdom, or Charisma by 1. Lower-level spell slots can sometimes be preserved.", false, 19, "", false, true);
	add_feat_choice("boon_of_truesight", "Boon of Truesight", FEAT_CATEGORY_EPIC, "Increase one ability score by 1 and gain truesight out to 60 feet.", false, 19);

	// === PHB 2024 General Feats (Level 4+) ===
	add_feat_choice("actor", "Actor", FEAT_CATEGORY_GENERAL, "Increase Charisma by 1. Advantage on Deception and Performance checks when impersonating someone. Mimic speech of creatures you have heard.", false, 4);
	add_feat_choice("athlete", "Athlete", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Standing from Prone uses only 5 feet. Climbing does not cost extra movement.", false, 4);
	add_feat_choice("charger", "Charger", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. When you Dash, you can make one melee attack or shove as a Bonus Action with +1d8 damage.", false, 4);
	add_feat_choice("chef", "Chef", FEAT_CATEGORY_GENERAL, "Increase Constitution or Wisdom by 1. You can cook special food during a Short Rest to heal extra 1d8 HP. Treats grant temp HP.", false, 4);
	add_feat_choice("crossbow_expert", "Crossbow Expert", FEAT_CATEGORY_GENERAL, "Increase Dexterity by 1. Ignore Loading property on crossbows. No disadvantage on ranged attacks within 5 feet.", false, 4);
	add_feat_choice("crusher", "Crusher", FEAT_CATEGORY_GENERAL, "Increase Strength or Constitution by 1. Once per turn when you deal Bludgeoning damage, push target 5 feet. On a critical hit, attacks against target have advantage until your next turn.", false, 4);
	add_feat_choice("defensive_duelist", "Defensive Duelist", FEAT_CATEGORY_GENERAL, "Increase Dexterity by 1. When wielding a Finesse weapon and hit by melee attack, use Reaction to add Proficiency Bonus to AC for that attack.", false, 4);
	add_feat_choice("dual_wielder", "Dual Wielder", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. When wielding a weapon in each hand, gain +1 AC. Draw or stow two weapons at once.", false, 4);
	add_feat_choice("durable", "Durable", FEAT_CATEGORY_GENERAL, "Increase Constitution by 1. When you roll Hit Dice to regain HP, the minimum roll equals twice your Constitution modifier.", false, 4);
	add_feat_choice("elemental_adept", "Elemental Adept", FEAT_CATEGORY_GENERAL, "Increase Intelligence, Wisdom, or Charisma by 1. Choose a damage type (Acid, Cold, Fire, Lightning, or Thunder). Spells of that type ignore resistance and treat 1s as 2s on damage dice.", false, 4);
	add_feat_choice("fey_touched", "Fey Touched", FEAT_CATEGORY_GENERAL, "Increase Intelligence, Wisdom, or Charisma by 1. Learn Misty Step and one 1st-level Divination or Enchantment spell. Cast each once for free per Long Rest.", false, 4);
	add_feat_choice("great_weapon_master", "Great Weapon Master", FEAT_CATEGORY_GENERAL, "Increase Strength by 1. When you score a critical hit or reduce a creature to 0 HP with a Heavy melee weapon, you can make one melee attack as a Bonus Action.", false, 4);
	add_feat_choice("heavily_armored", "Heavily Armored", FEAT_CATEGORY_GENERAL, "Increase Strength by 1. Gain proficiency with Heavy Armor.", false, 4);
	add_feat_choice("heavy_armor_master", "Heavy Armor Master", FEAT_CATEGORY_GENERAL, "Increase Strength by 1. When wearing Heavy Armor, reduce Bludgeoning, Piercing, and Slashing damage from nonmagical weapons by your Proficiency Bonus.", false, 4);
	add_feat_choice("inspiring_leader", "Inspiring Leader", FEAT_CATEGORY_GENERAL, "Increase Wisdom or Charisma by 1. After a Short or Long Rest, give a speech to grant up to 6 creatures temp HP equal to your level plus your Charisma modifier.", false, 4);
	add_feat_choice("keen_mind", "Keen Mind", FEAT_CATEGORY_GENERAL, "Increase Intelligence by 1. You can take the Study action as a Bonus Action. You always know the time and direction of north.", false, 4);
	add_feat_choice("lightly_armored", "Lightly Armored", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Gain proficiency with Light Armor and Shields.", false, 4);
	add_feat_choice("mage_slayer", "Mage Slayer", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. When a creature within 5 feet casts a spell, you can use your Reaction to make a melee attack against it. You have advantage on saves against spells cast within 5 feet.", false, 4);
	add_feat_choice("martial_weapon_training", "Martial Weapon Training", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Gain proficiency with Martial Weapons.", false, 4);
	add_feat_choice("medium_armor_master", "Medium Armor Master", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Medium Armor no longer imposes disadvantage on Stealth. You can add up to +3 DEX modifier in Medium Armor.", false, 4);
	add_feat_choice("moderately_armored", "Moderately Armored", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Gain proficiency with Medium Armor and Shields.", false, 4);
	add_feat_choice("mounted_combatant", "Mounted Combatant", FEAT_CATEGORY_GENERAL, "Increase Strength, Dexterity, or Wisdom by 1. Advantage on melee attacks against unmounted creatures smaller than your mount. Force attacks targeting mount to target you instead.", false, 4);
	add_feat_choice("observant", "Observant", FEAT_CATEGORY_GENERAL, "Increase Intelligence or Wisdom by 1. You can take the Search action as a Bonus Action. +5 to passive Perception and passive Investigation.", false, 4);
	add_feat_choice("piercer", "Piercer", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Once per turn, reroll one Piercing damage die. Critical hits with Piercing damage deal one extra damage die.", false, 4);
	add_feat_choice("poisoner", "Poisoner", FEAT_CATEGORY_GENERAL, "Increase Dexterity or Intelligence by 1. You can apply poison as a Bonus Action. Creatures have no advantage on saves against your poisons.", false, 4);
	add_feat_choice("polearm_master", "Polearm Master", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Bonus Action butt-end attack for 1d4 with polearms. Creatures provoke Opportunity Attacks when entering your reach.", false, 4);
	add_feat_choice("resilient", "Resilient", FEAT_CATEGORY_GENERAL, "Increase one ability score by 1 and gain proficiency in saving throws using that ability.", false, 4);
	add_feat_choice("ritual_caster", "Ritual Caster", FEAT_CATEGORY_GENERAL, "Increase Intelligence, Wisdom, or Charisma by 1. Learn two Ritual spells. Cast Ritual spells without spell slots.", false, 4);
	add_feat_choice("sentinel", "Sentinel", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Opportunity Attacks reduce target speed to 0. Creatures that attack allies within 5 feet provoke Opportunity Attacks.", false, 4);
	add_feat_choice("shadow_touched", "Shadow Touched", FEAT_CATEGORY_GENERAL, "Increase Intelligence, Wisdom, or Charisma by 1. Learn Invisibility and one 1st-level Illusion or Necromancy spell. Cast each once for free per Long Rest.", false, 4);
	add_feat_choice("sharpshooter", "Sharpshooter", FEAT_CATEGORY_GENERAL, "Increase Dexterity by 1. Ranged attacks ignore Half and Three-Quarters Cover. Attack at long range without disadvantage.", false, 4);
	add_feat_choice("shield_master", "Shield Master", FEAT_CATEGORY_GENERAL, "Increase Strength by 1. Bonus Action shove when taking Attack action. Add shield AC bonus to DEX saves.", false, 4);
	add_feat_choice("skill_expert", "Skill Expert", FEAT_CATEGORY_GENERAL, "Increase one ability score by 1. Gain proficiency in one skill. Choose one proficient skill for Expertise.", false, 4);
	add_feat_choice("skulker", "Skulker", FEAT_CATEGORY_GENERAL, "Increase Dexterity by 1. Hide when Lightly Obscured. Missing ranged attacks while hidden does not reveal you. Darkvision 60 feet.", false, 4);
	add_feat_choice("slasher", "Slasher", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Slashing damage reduces target speed by 10 feet. Critical Slashing hits cause disadvantage on attacks.", false, 4);
	add_feat_choice("speedy", "Speedy", FEAT_CATEGORY_GENERAL, "Increase Dexterity or Constitution by 1. Speed increases by 10 feet. Opportunity Attacks have disadvantage against you. Dash as Bonus Action.", false, 4);
	add_feat_choice("spell_sniper", "Spell Sniper", FEAT_CATEGORY_GENERAL, "Increase Intelligence, Wisdom, or Charisma by 1. Spell attacks ignore Half and Three-Quarters Cover. Learn one attack cantrip.", false, 4);
	add_feat_choice("telekinetic", "Telekinetic", FEAT_CATEGORY_GENERAL, "Increase Intelligence, Wisdom, or Charisma by 1. Learn invisible Mage Hand. Bonus Action shove creature 5 feet (STR save).", false, 4);
	add_feat_choice("telepathic", "Telepathic", FEAT_CATEGORY_GENERAL, "Increase Intelligence, Wisdom, or Charisma by 1. Telepathic speech within 60 feet. Cast Detect Thoughts once for free per Long Rest.", false, 4);
	add_feat_choice("war_caster", "War Caster", FEAT_CATEGORY_GENERAL, "Increase Intelligence, Wisdom, or Charisma by 1. Advantage on Concentration saves. Cantrip for Opportunity Attacks. Somatic components with full hands.", false, 4);
	add_feat_choice("weapon_master", "Weapon Master", FEAT_CATEGORY_GENERAL, "Increase Strength or Dexterity by 1. Gain a Weapon Mastery property of your choice to use with one weapon.", false, 4);

	// === PHB 2024 Fighting Style Feats ===
	add_feat_choice("blind_fighting", "Blind Fighting", FEAT_CATEGORY_FIGHTING_STYLE, "You have Blindsight 10 feet. You can see anything not behind Total Cover within that range, even if Blinded.", false, 1, "", true);
	add_feat_choice("dueling", "Dueling", FEAT_CATEGORY_FIGHTING_STYLE, "When wielding a melee weapon in one hand and no other weapons, +2 to damage rolls with that weapon.", false, 1, "", true);
	add_feat_choice("interception", "Interception", FEAT_CATEGORY_FIGHTING_STYLE, "When an ally within 5 feet is hit, use Reaction to reduce damage by 1d10 plus Proficiency Bonus.", false, 1, "", true);
	add_feat_choice("protection", "Protection", FEAT_CATEGORY_FIGHTING_STYLE, "When an ally within 5 feet is targeted, use Reaction to impose disadvantage on the attack roll. Requires Shield.", false, 1, "", true);
	add_feat_choice("thrown_weapon_fighting", "Thrown Weapon Fighting", FEAT_CATEGORY_FIGHTING_STYLE, "Draw Thrown weapons as part of the attack. +2 to damage with Thrown weapons.", false, 1, "", true);
	add_feat_choice("unarmed_fighting", "Unarmed Fighting", FEAT_CATEGORY_FIGHTING_STYLE, "Unarmed strikes deal 1d6 (or 1d8 with both hands free). Deal 1d4 to grappled creature at start of your turn.", false, 1, "", true);

	// === PHB 2024 Epic Boon Feats (Level 19+) ===
	add_feat_choice("boon_of_dimensional_travel", "Boon of Dimensional Travel", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. After using a spell slot, teleport up to 30 feet.", false, 19);
	add_feat_choice("boon_of_energy_resistance", "Boon of Energy Resistance", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. Use Reaction to gain Resistance to Acid, Cold, Fire, Lightning, or Thunder until next turn.", false, 19);
	add_feat_choice("boon_of_fate", "Boon of Fate", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. Change a D20 Test within 60 feet by 2d4. Uses equal to Proficiency Bonus.", false, 19);
	add_feat_choice("boon_of_fortitude", "Boon of Fortitude", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. Your Hit Point maximum increases by 40.", false, 19);
	add_feat_choice("boon_of_recovery", "Boon of Recovery", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. Bonus Action to regain half your Hit Point maximum. Once per Long Rest.", false, 19);
	add_feat_choice("boon_of_skill", "Boon of Skill", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. Proficiency in all skills. Expertise in two skills.", false, 19);
	add_feat_choice("boon_of_speed", "Boon of Speed", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. Your Speed increases by 30 feet.", false, 19);
	add_feat_choice("boon_of_the_night_spirit", "Boon of the Night Spirit", FEAT_CATEGORY_EPIC, "Increase one ability score by 1. Darkvision 300 feet. Become Invisible as Bonus Action in Dim Light or Darkness.", false, 19);

	string[] acolyte_skills = {"Insight", "Religion"};
