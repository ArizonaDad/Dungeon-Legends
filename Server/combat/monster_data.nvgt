monster_def@ get_monster_def(string id) {
    for (uint i = 0; i < MONSTER_DEFS.length(); i++) {
        if (MONSTER_DEFS[i].id == id) return MONSTER_DEFS[i];
    }
    return null;
}

// Factory: create a combatant from a monster definition placed at grid position (x, y)
combatant@ create_monster_combatant(monster_def@ def, int x, int y) {
    if (@def == null) return null;
    combatant c;
    c.name = def.name;
    c.is_player = false;
    c.player_username = "";
    c.x = x;
    c.y = y;
    c.size = def.size;
    c.max_hp = def.hp;
    c.current_hp = def.hp;
    c.armor_class = def.ac;
    c.speed = def.speed;
    c.initiative_bonus = ability_modifier(def.dex);

    // Ability scores: STR DEX CON INT WIS CHA
    c.ability_scores = {def.str, def.dex, def.con, def.intelligence, def.wis, def.cha};

    // Equip primary attack
    c.main_hand = def.attack_name;
    c.main_hand_damage_dice = def.damage_dice;
    c.main_hand_damage_count = def.damage_count;
    c.main_hand_damage_type = def.damage_type;
    c.main_hand_range = def.attack_range;
    c.main_hand_finesse = false;

    // Extra attacks from multiattack (subtract 1 for the base attack)
    if (def.has_multiattack and def.multiattack_count > 1) {
        c.extra_attacks = def.multiattack_count - 1;
    }

    return c;
}
