// D&D 5e Monster Data - SRD Stat Blocks
// Defines monster templates and a factory to create combatants from them.

#include "combat_engine.nvgt"

class monster_def {
    string id;
    string name;
    string type;
    int size = SIZE_MEDIUM;
    int ac;
    int hp;
    int speed = 30;
    int str = 10; int dex = 10; int con = 10;
    int intelligence = 10; int wis = 10; int cha = 10;
    string attack_name = "Attack";
    int attack_bonus = 0;
    int damage_dice = 4;
    int damage_count = 1;
    int damage_mod = 0;
    int damage_type = DMG_SLASHING;
    int attack_range = 5;
    string attack2_name = "";
    int attack2_bonus = 0;
    int attack2_dice = 0;
    int attack2_count = 0;
    int attack2_mod = 0;
    int attack2_type = 0;
    int attack2_range = 0;
    bool has_multiattack = false;
    int multiattack_count = 1;
    int xp = 50;
    string description = "";
}

monster_def@[] MONSTER_DEFS;

