    { spell_def s; s.id="death_ward"; s.name="Death Ward"; s.level=4; s.school="abjuration"; s.casting_time=0; s.range=5; s.concentration=false; s.duration_rounds=4800; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You touch a creature and grant it a measure of protection from death. The first time the target would drop to 0 Hit Points before the spell ends, the "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="dimension_door"; s.name="Dimension Door"; s.level=4; s.school="conjuration"; s.casting_time=0; s.range=500; s.concentration=false; s.duration_rounds=0; s.save_type=-1; s.damage_dice=6; s.damage_count=4; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You teleport to a location within range. You arrive at exactly the spot desired. It can be a place you can see, one you can visualize, or one you can "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
