    { spell_def s; s.id="giant_insect"; s.name="Giant Insect"; s.level=4; s.school="conjuration"; s.casting_time=0; s.range=60; s.concentration=true; s.duration_rounds=100; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You summon a giant centipede, spider, or wasp (chosen when you cast the spell). It manifests in an unoccupied space you can see within range and uses "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
