    { spell_def s; s.id="commune"; s.name="Commune"; s.level=5; s.school="divination"; s.casting_time=0; s.range=0; s.concentration=false; s.duration_rounds=10; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You contact a deity or a divine proxy and ask up to three questions that can be answered with yes or no. You must ask your questions before the spell "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="commune_with_nature"; s.name="Commune with Nature"; s.level=5; s.school="divination"; s.casting_time=0; s.range=0; s.concentration=false; s.duration_rounds=0; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You commune with nature spirits and gain knowledge of the surrounding area. In the outdoors, the spell gives you knowledge of the area within 3 miles "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="conjure_elemental"; s.name="Conjure Elemental"; s.level=5; s.school="conjuration"; s.casting_time=0; s.range=60; s.concentration=true; s.duration_rounds=100; s.save_type=ABILITY_DEX; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=2; s.scales_with_level=false; s.max_targets=1; s.description="You conjure a Large, intangible spirit from the Elemental Planes that appears in an unoccupied space within range. Choose the spirit’s element, which "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="contact_other_plane"; s.name="Contact Other Plane"; s.level=5; s.school="divination"; s.casting_time=0; s.range=0; s.concentration=false; s.duration_rounds=10; s.save_type=ABILITY_INT; s.damage_dice=6; s.damage_count=6; s.damage_type=DMG_PSYCHIC; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You mentally contact a demigod, the spirit of a long-dead sage, or some other knowledgeable entity from another plane. Contacting this otherworldly in"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="contagion"; s.name="Contagion"; s.level=5; s.school="necromancy"; s.casting_time=0; s.range=5; s.concentration=false; s.duration_rounds=0; s.save_type=ABILITY_CON; s.damage_dice=8; s.damage_count=11; s.damage_type=DMG_NECROTIC; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="Your touch inflicts a magical contagion. The target must succeed on a Constitution saving throw or take 11d8 Necrotic damage and have the Poisoned con"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="creation"; s.name="Creation"; s.level=5; s.school="illusion"; s.casting_time=0; s.range=30; s.concentration=false; s.duration_rounds=10; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.is_aoe=true; s.aoe_radius=5; s.description="You pull wisps of shadow material from the Shadowfell to create an object within range. It is either an object of vegetable matter (soft goods, rope, "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="dispel_evil_and_good"; s.name="Dispel Evil and Good"; s.level=5; s.school="abjuration"; s.casting_time=0; s.range=0; s.concentration=true; s.duration_rounds=10; s.save_type=ABILITY_CHA; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="For the duration, Celestials, Elementals, Fey, Fiends, and Undead have Disadvantage on attack rolls against you. You can end the spell early by using "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="dominate_person"; s.name="Dominate Person"; s.level=5; s.school="enchantment"; s.casting_time=0; s.range=60; s.concentration=true; s.duration_rounds=10; s.save_type=ABILITY_WIS; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="One Humanoid you can see within range must succeed on a Wisdom saving throw or have the Charmed condition for the duration. The target has Advantage o"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="dream"; s.name="Dream"; s.level=5; s.school="illusion"; s.casting_time=0; s.range=0; s.concentration=false; s.duration_rounds=10; s.save_type=ABILITY_WIS; s.damage_dice=6; s.damage_count=3; s.damage_type=DMG_PSYCHIC; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You target a creature you know on the same plane of existence. You or a willing creature you touch enters a trance state to act as a dream messenger. "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
