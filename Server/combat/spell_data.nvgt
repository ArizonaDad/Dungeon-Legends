    { spell_def s; s.id="daylight"; s.name="Daylight"; s.level=3; s.school="evocation"; s.casting_time=0; s.range=60; s.concentration=false; s.duration_rounds=600; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.is_aoe=true; s.aoe_radius=60; s.description="For the duration, sunlight spreads from a point within range and fills a 60-foot-radius Sphere. The sunlight’s area is Bright Light and sheds Dim Ligh"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="dispel_magic"; s.name="Dispel Magic"; s.level=3; s.school="abjuration"; s.casting_time=0; s.range=120; s.concentration=false; s.duration_rounds=0; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="Choose one creature, object, or magical effect within range. Any ongoing spell of level 3 or lower on the target ends. For each ongoing spell of level"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
