    { spell_def s; s.id="otilukes_resilient_sphere"; s.name="Otiluke’s Resilient Sphere"; s.level=4; s.school="abjuration"; s.casting_time=0; s.range=30; s.concentration=false; s.duration_rounds=10; s.save_type=ABILITY_DEX; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="A shimmering sphere encloses a Large or smaller creature or object within range. An unwilling creature must succeed on a Dexterity saving throw or be "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="phantasmal_killer"; s.name="Phantasmal Killer"; s.level=4; s.school="illusion"; s.casting_time=0; s.range=120; s.concentration=true; s.duration_rounds=10; s.save_type=ABILITY_WIS; s.damage_dice=10; s.damage_count=4; s.damage_type=DMG_PSYCHIC; s.is_healing=false; s.upcast_extra_dice=1; s.scales_with_level=false; s.max_targets=1; s.description="You tap into the nightmares of a creature you can see within range and create an illusion of its deepest fears, visible only to that creature. The tar"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="stone_shape"; s.name="Stone Shape"; s.level=4; s.school="transmutation"; s.casting_time=0; s.range=5; s.concentration=false; s.duration_rounds=0; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You touch a stone object of Medium size or smaller or a section of stone no more than 5 feet in any dimension and form it into any shape you like. For"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
