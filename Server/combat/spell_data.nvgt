    { spell_def s; s.id="animate_objects"; s.name="Animate Objects"; s.level=5; s.school="transmutation"; s.casting_time=0; s.range=120; s.concentration=true; s.duration_rounds=10; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=1; s.scales_with_level=false; s.max_targets=6; s.description="Objects animate at your command. Choose a number of nonmagical objects within range that aren’t being worn or carried, aren’t fixed to a surface, and "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="antilife_shell"; s.name="Antilife Shell"; s.level=5; s.school="abjuration"; s.casting_time=0; s.range=0; s.concentration=true; s.duration_rounds=600; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.is_aoe=true; s.aoe_radius=10; s.description="An aura extends from you in a 10-foot Emanation for the duration. The aura prevents creatures other than Constructs and Undead from passing or reachin"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="awaken"; s.name="Awaken"; s.level=5; s.school="transmutation"; s.casting_time=0; s.range=5; s.concentration=false; s.duration_rounds=0; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You spend the casting time tracing magical pathways within a precious gemstone, and then touch the target. The target must be either a Beast or Plant "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
