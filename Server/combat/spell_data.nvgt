#include "../../common/combat_constants.nvgt"
#include "combat_engine.nvgt"

class spell_def {
    string id;
    string name;
    int level;              // 0 = cantrip, 1-9 = spell level
    string school;          // evocation, necromancy, etc.
    int casting_time;       // 0=action, 1=bonus action, 2=reaction
    int range;              // in feet, 0=self, 5=touch
    bool concentration;
    int duration_rounds;    // 0=instant, -1=until dispelled
    int save_type;          // -1=none (attack roll), ABILITY_DEX, ABILITY_CON, etc.
    int save_dc_ability;    // which ability mod to use for DC calculation
    // Damage/healing
    int damage_dice;
    int damage_count;
    int damage_type;        // DMG_FIRE, DMG_RADIANT, etc.
    bool is_healing;
    int healing_dice;
    int healing_count;
    // Scaling
    int upcast_extra_dice;  // extra dice per spell level above base
    bool scales_with_level; // cantrips scale at 5/11/17
    // Targets
    int max_targets;        // 1=single, 0=self, 3=magic missile etc.
    bool is_aoe;
    int aoe_radius;         // in feet
    // Description for TTS
    string description;
    // Which classes can use this spell
    string class_list;      // comma separated: "wizard,sorcerer,cleric"
}

spell_def@[] SPELL_DEFS;

void init_spell_defs() {
    // CANTRIPS (level 0)
    { spell_def s; s.id="fire_bolt"; s.name="Fire Bolt"; s.level=0; s.school="evocation"; s.casting_time=0; s.range=120; s.concentration=false; s.duration_rounds=0; s.save_type=-1; s.damage_dice=10; s.damage_count=1; s.damage_type=DMG_FIRE; s.is_healing=false; s.scales_with_level=true; s.max_targets=1; s.description="Hurl a mote of fire. Ranged spell attack. 1d10 fire damage, scales at levels 5, 11, 17."; s.class_list="wizard,sorcerer,artificer"; SPELL_DEFS.insert_last(s); }

    { spell_def s; s.id="sacred_flame"; s.name="Sacred Flame"; s.level=0; s.school="evocation"; s.casting_time=0; s.range=60; s.concentration=false; s.duration_rounds=0; s.save_type=ABILITY_DEX; s.damage_dice=8; s.damage_count=1; s.damage_type=DMG_RADIANT; s.is_healing=false; s.scales_with_level=true; s.max_targets=1; s.description="Flame descends on a creature. DEX save or 1d8 radiant damage. No cover benefit."; s.class_list="cleric"; SPELL_DEFS.insert_last(s); }

