    { spell_def s; s.id="blight"; s.name="Blight"; s.level=4; s.school="necromancy"; s.casting_time=0; s.range=30; s.concentration=false; s.duration_rounds=0; s.save_type=ABILITY_CON; s.damage_dice=8; s.damage_count=8; s.damage_type=DMG_NECROTIC; s.is_healing=false; s.upcast_extra_dice=1; s.scales_with_level=false; s.max_targets=1; s.description="A creature that you can see within range makes a Constitution saving throw, taking 8d8 Necrotic damage on a failed save or half as much damage on a su"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
