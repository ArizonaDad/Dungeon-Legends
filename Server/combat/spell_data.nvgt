    { spell_def s; s.id="evards_black_tentacles"; s.name="Evard’s Black Tentacles"; s.level=4; s.school="conjuration"; s.casting_time=0; s.range=90; s.concentration=true; s.duration_rounds=0; s.save_type=ABILITY_STR; s.damage_dice=6; s.damage_count=3; s.damage_type=DMG_BLUDGEONING; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=6; s.description="Squirming, ebony tentacles fill a 20-foot square on ground that you can see within range. For the duration, these tentacles turn the ground in that ar"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="fabricate"; s.name="Fabricate"; s.level=4; s.school="transmutation"; s.casting_time=0; s.range=120; s.concentration=false; s.duration_rounds=0; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.is_aoe=true; s.aoe_radius=10; s.description="You convert raw materials into products of the same material. For example, you can fabricate a wooden bridge from a clump of trees, a rope from a patc"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="fire_shield"; s.name="Fire Shield"; s.level=4; s.school="evocation"; s.casting_time=0; s.range=0; s.concentration=false; s.duration_rounds=100; s.save_type=-1; s.damage_dice=8; s.damage_count=2; s.damage_type=DMG_FIRE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.is_aoe=true; s.aoe_radius=10; s.description="Wispy flames wreathe your body for the duration, shedding Bright Light in a 10-foot radius and Dim Light for an additional 10 feet."; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
