    { spell_def s; s.id="reverse_gravity"; s.name="Reverse Gravity"; s.level=7; s.school="transmutation"; s.casting_time=0; s.range=100; s.concentration=true; s.duration_rounds=10; s.save_type=ABILITY_DEX; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=6; s.is_aoe=true; s.aoe_radius=50; s.description="This spell reverses gravity in a 50-foot-radius, 100-foot high Cylinder centered on a point within range. All creatures and objects in that area that "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
