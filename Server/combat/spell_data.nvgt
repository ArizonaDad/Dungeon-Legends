    { spell_def s; s.id="guardian_of_faith"; s.name="Guardian of Faith"; s.level=4; s.school="conjuration"; s.casting_time=0; s.range=30; s.concentration=false; s.duration_rounds=4800; s.save_type=ABILITY_DEX; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="A Large spectral guardian appears and hovers for the duration in an unoccupied space that you can see within range. The guardian occupies that space a"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="hallucinatory_terrain"; s.name="Hallucinatory Terrain"; s.level=4; s.school="illusion"; s.casting_time=0; s.range=300; s.concentration=false; s.duration_rounds=100; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.is_aoe=true; s.aoe_radius=150; s.description="You make natural terrain in a 150-foot Cube in range look, sound, and smell like another sort of natural terrain. Thus, open fields or a road can be m"; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
    { spell_def s; s.id="leomunds_secret_chest"; s.name="Leomund’s Secret Chest"; s.level=4; s.school="conjuration"; s.casting_time=0; s.range=5; s.concentration=false; s.duration_rounds=0; s.save_type=-1; s.damage_dice=0; s.damage_count=0; s.damage_type=DMG_FORCE; s.is_healing=false; s.upcast_extra_dice=0; s.scales_with_level=false; s.max_targets=1; s.description="You hide a chest and all its contents on the Ethereal Plane. You must touch the chest and the miniature replica that serve as Material components for "; s.class_list="wizard"; SPELL_DEFS.insert_last(s); }
