// D&D 5e Combat Engine - Server Side
// Manages initiative, turns, actions, attacks, damage, conditions, death saves.

#include "../../common/combat_constants.nvgt"
#include "../../common/feat_data.nvgt"

// A single combatant in battle (player or monster)
class combatant {
	uint id;
	string name;
	bool is_player;          // true = player, false = monster/NPC
	string player_username;  // if is_player, the user's username

	// Position on grid
	int x;
	int y;
	int size = SIZE_MEDIUM;  // creature size

	// Core stats
	int max_hp;
	int current_hp;
	int temp_hp = 0;
	int armor_class;
	int speed;               // in feet
	int initiative_bonus;    // dex mod + any bonuses

	// Equipment bonuses (from loot items)
	int equip_ac_bonus = 0;
	int equip_damage_bonus = 0;
	int equip_hp_bonus = 0;
	int equip_spell_dc_bonus = 0;
	int equip_initiative_bonus = 0;
	int equip_speed_bonus = 0;
	int equip_save_bonus = 0;
	int equip_crit_reduction = 0;

	// Ability scores
	int[] ability_scores = {10, 10, 10, 10, 10, 10}; // STR DEX CON INT WIS CHA
	int[] save_proficiencies = {0, 0, 0, 0, 0, 0};   // 1 = proficient
	string class_name = "";
	string subclass = "";
	string background = "";
	int level = 1;
	int proficiency = 2;
	int spellcasting_ability = -1;

	// Turn state
	int initiative_roll = 0;
	bool has_action = true;
	bool has_bonus_action = true;
	bool has_reaction = true;
	int movement_remaining = 0;     // feet remaining this turn
	bool has_moved = false;
	bool used_action = false;
	bool used_bonus_action = false;
	bool cast_ba_spell_this_turn = false;    // PHB 2024 Bonus Action Spell rule tracking
	bool cast_leveled_spell_this_turn = false; // Blocks BA spells after a leveled action spell

	// Conditions (array of active condition IDs)
	int[] conditions;
	int exhaustion_level = 0;

	// Death saves
	int death_save_successes = 0;
	int death_save_failures = 0;
	bool is_dead = false;
	bool is_stable = false;

	// Combat tracking
	bool is_concentrating = false;
	string concentration_spell = "";
	bool is_dodging = false;
	bool is_hidden = false;
	bool took_disengage = false;
	int readied_action = -1;       // -1 = none
	string readied_trigger = "";
	uint readied_target_id = 0;
	bool shield_active = false;
	int shield_ac_bonus = 0;
	bool blessed = false;
	bool baned = false;                  // Bane spell: subtract 1d4 from attacks + saves until concentration ends
	int magic_weapon_bonus = 0;          // Magic Weapon spell: +1/+2/+3 to attack and damage rolls
	bool divine_favor_active = false;    // Divine Favor spell: +1d4 radiant damage on weapon hits
	int mirror_images = 0;               // Mirror Image spell: number of remaining illusory duplicates
	bool blink_active = false;           // Blink spell: 50% chance to phase to Ethereal Plane
	bool globe_of_invulnerability_active = false; // Globe of Invulnerability: blocks lower-level spells
	int globe_of_invulnerability_level = 5;  // Highest spell level the globe blocks
	bool holy_aura_active = false;       // Holy Aura: 30 ft aura, allies adv on saves, enemies disadv to attack
	bool stoneskin_active = false;       // Stoneskin spell: B/P/S resistance flag (cleared by Dispel Magic)
	bool fly_active = false;             // Fly spell: flag for Dispel Magic to clear flying_speed
	bool swift_quiver_active = false;    // Swift Quiver spell: BA for 2 ranged attacks (concentration)
	bool true_seeing_active = false;     // True Seeing spell: Truesight 120ft (not concentration per 2024)
	bool counterspell_pending = false;   // Counterspell readied as a reaction (intercept the next enemy spell)
	bool searing_smite_pending = false;  // Searing Smite rider on next weapon hit
	int searing_smite_dice = 0;          // Number of d6 to roll for Searing Smite damage
	bool investiture_flame_active = false; // Investiture of Flame: 1d10 fire to adjacent creatures
	uint bless_source_id = 0;
	bool guiding_bolt_advantage = false;
	uint guiding_bolt_source_id = 0;
	bool faerie_fire_outlined = false;   // Faerie Fire: persistent advantage on attacks (not consumed like Guiding Bolt)
	uint faerie_fire_source_id = 0;      // Faerie Fire: caster id for concentration cleanup
	int longstrider_bonus = 0;
	int pass_without_trace_bonus = 0;
	uint pass_without_trace_source_id = 0;
	int focus_points = 0;
	int sorcery_points = 0;     // Sorcerer Font of Magic resource (PHB Sorcerer L2)
	int sorcery_points_max = 0;
	// Theros Piety system (Mythic Odysseys of Theros pp. 1236-1252)
	string piety_god = "";      // Empty = no god worship; otherwise one of THEROS_GODS
	int piety_score = 0;        // 0 = no devotion; tier benefits at 3, 10, 25, 50
	int piety_devotee_uses = 0; // Per-rest uses of Piety 3+ trait spell
	int piety_devotee_uses_max = 0;
	// Tasha's Group Patrons system (Tasha's pp. 4892-5300+)
	string group_patron = "";   // Empty = no patron; one of: Academy, Ancient Being, Aristocrat, Criminal Syndicate, Guild, Military Force, Religious Order, Sovereign
	bool group_assistance_used_this_rest = false;  // Per-rest d4 inspiration die from patron
	// Ravnica Guild Membership
	string ravnica_guild = "";
	// Grim Hollow Transformations (Campaign Guide paras 2294-2306)
	string transformation = "";    // "" = untransformed; one of 6 paths
	int transformation_stage = 0;  // 0-20 progression
	// Wildemount Vestige in combat (for active vestige item)
	string active_vestige_id = "";
	int active_vestige_state = 0;  // 0=Dormant, 1=Awakened, 2=Exalted
	// Ebon Tides fey court affiliation
	string fey_court = "";
	int climb_speed = 0;        // PHB Athlete feat / climbing race trait
	int inspiring_leader_temp_hp_pool = 0; // Pool of temp HP grants from Inspiring Leader rest performance
	int blindsight_range = 0;   // PHB Blind Fighting feat (10 ft) and various species/subclass effects
	bool unarmed_fighting_active = false; // PHB Unarmed Fighting feat: 1d6+STR unarmed damage
	bool beacon_of_hope_active = false; // Beacon of Hope spell: max healing + adv on WIS/death saves
	bool death_ward_active = false; // Death Ward spell: first 0 HP becomes 1 HP and ends spell
	bool holy_weapon_active = false; // Xanathar's Holy Weapon: +2d8 radiant on weapon hits
	// Basic Rules 2024 Guidance (para 13659): "Once before the spell ends, the target
	// can add 1d4 to one ability check using the chosen ability. The spell then ends."
	// Simplified: single-use 1d4 on next ability check, cleared on use.
	bool guidance_active = false;
	// Basic Rules 2024 Resistance (para 14772): "Once before the spell ends, the target
	// can add 1d4 to one saving throw of the chosen type. The spell then ends."
	// Simplified: single-use 1d4 on next saving throw, cleared on use.
	bool resistance_active = false;
	// Basic Rules 2024 Protection from Energy (para 14707): "the willing creature you
	// touch has Resistance to one damage type: Acid, Cold, Fire, Lightning, or Thunder."
	// Concentration, halves matching damage type in apply_damage.
	bool protection_from_energy_active = false;
	int protection_from_energy_type = 0; // DMG_ACID/COLD/FIRE/LIGHTNING/THUNDER
	// Barbarian PHB 2024 base class features
	bool reckless_attack_active = false; // Set on the turn the barbarian declares Reckless Attack
	bool danger_sense_active = false;    // Always-on if Barbarian level 2+ (advantage on DEX saves)
	int relentless_rage_dc = 10;         // Resets to 10 on rest, +5 each successful use
	bool persistent_rage_active = false; // Barbarian L15: rage doesn't auto-end after 1 round
	// PHB 2024 Barbarian L9 Brutal Strike (para 2338-2341): forgo Reckless Attack advantage
	// on one STR-based attack; on hit, +1d10 damage (2d10 at L17) + chosen effect.
	bool brutal_strike_active = false;       // Toggled on, consumed after first qualifying attack
	string brutal_strike_effect = "";        // "forceful"/"hamstring" (L9), "staggering"/"sundering" (L13)
	string brutal_strike_effect2 = "";       // L17: second effect choice
	bool brutal_strike_used_this_turn = false; // One Brutal Strike per turn
	bool sundering_blow_target_active = false; // Sundering Blow: next other creature's attack gets +5
	uint sundering_blow_target_id = 0;         // Target marked by Sundering Blow
	bool staggering_blow_active = false;       // Staggering Blow: disadvantage on next save + no OAs
	// Fighter PHB 2024 base class features
	int indomitable_uses = 0;            // Fighter L9: 1 use/LR, 2 at L13, 3 at L17 (failed save reroll)
	bool studied_attacks_active = false; // Fighter L13: passive flag - advantage on next attack after a miss
	uint studied_attacks_target_id = 0;  // The creature you missed (gives advantage on next attack vs them)
	// Monk PHB 2024 base class features
	int focus_points_max = 0;              // L2+: cap on focus points (= Monk level)
	bool stunning_strike_available = true; // Once per turn if at L5+ with focus points (reset at turn start)
	uint stunning_strike_source_id = 0;    // L5: tracks which monk applied the strike (cleared at start of their next turn)
	bool stunning_strike_advantage_pending = false; // L5 success rider: next attack vs target has advantage
	int stunning_strike_speed_orig = 0;    // L5 success rider: orig speed to restore at start of monk's next turn
	bool uncanny_metabolism_available = false; // L2: 1/long rest, regain all FP + heal at initiative
	bool empowered_strikes_active = false; // L6+: unarmed strike can deal force damage instead
	bool empowered_strikes_force = true;  // L6+: toggle — true = Force damage, false = normal type
	bool evasion_active = false;           // L7+: succeed on DEX save = 0 damage, fail = half (uncapped)
	bool self_restoration_active = false;  // L10: end-of-turn remove Charmed/Frightened/Poisoned
	bool heightened_focus_active = false;  // L10: Flurry 3 strikes, Patient Defense temp HP, Step of Wind ally move
	bool disciplined_survivor_active = false; // L14: reroll failed save by spending 1 FP
	bool body_and_mind_applied = false;    // L20: tracks the one-time +4 DEX/WIS boost
	bool superior_defense_active = false;  // L18: damage resistance to all but Force for 1 minute
	int superior_defense_rounds_remaining = 0; // L18: ticks down at start of turn, ends at 0 or Incapacitated
	int deflect_attacks_reduction = 0;     // L3 Deflect Attacks: damage to subtract in apply_damage
	bool deflect_attacks_reduced_to_zero = false; // L3 Deflect Attacks: set true when reduction zeroed this attack (redirect gate)
	int deflect_attacks_orig_damage_type = 0; // L3 Deflect Attacks: damage type for redirect (matches incoming attack)
	// Rogue PHB 2024 base class features
	bool reliable_talent_active = false;   // L11: treat d20 <=9 as 10 on checks using proficient skills
	// Wizard PHB 2024 base class features
	int arcane_recovery_charges = 0;       // L1: recover slots on short rest
	// PHB 2024 Wizard L1 Ritual Adept (para 8616-8617): "You can cast any spell as a
	// Ritual if that spell has the Ritual tag and the spell is in your spellbook. You
	// needn't have the spell prepared, but you must read from the book to cast a spell
	// in this way." Combat sim flag — actual ritual casting handled in spell pipeline.
	bool ritual_adept_active = false;
	// PHB 2024 Wizard L18 Spell Mastery (paras 8629-8631): "Choose a level 1 and a level
	// 2 spell in your spellbook that have a casting time of an action. You always have
	// those spells prepared, and you can cast them at their lowest level without expending
	// a spell slot." Designations must come from the player; cast pipeline checks the
	// spell ID against these strings before bypassing the slot.
	bool spell_mastery_active = false;
	string spell_mastery_l1_spell_id = ""; // player-designated L1 spell
	string spell_mastery_l2_spell_id = ""; // player-designated L2 spell
	// PHB 2024 Wizard L20 Signature Spells (para 8634-8635): "Choose two level 3 spells
	// in your spellbook as your signature spells. You always have these spells prepared,
	// and you can cast each of them once at level 3 without expending a spell slot. When
	// you do so, you can't cast them in this way again until you finish a Short or Long
	// Rest." Two charges that refresh on short rest.
	int signature_spells_charges_remaining = 0;
	int signature_spells_charges_max = 0;
	string signature_spell_a_id = ""; // first player-designated L3 spell
	string signature_spell_b_id = ""; // second player-designated L3 spell
	bool signature_spell_a_used_this_rest = false;
	bool signature_spell_b_used_this_rest = false;
	// Druid PHB 2024 base class features
	bool wild_companion_active = false;    // L2: cast Find Familiar via Wild Shape
	bool elemental_fury_active = false;    // L7: damage type swap on Wild Shape attacks
	// Sorcerer PHB 2024 base class features
	// PHB 2024 Sorcerer L1 Innate Sorcery (para 6963-6967): "As a Bonus Action, you
	// can unleash that magic for 1 minute, during which you gain the following benefits:
	// • The spell save DC of your Sorcerer spells increases by 1.
	// • You have Advantage on the attack rolls of Sorcerer spells you cast.
	// You can use this feature twice, and you regain all expended uses of it when you
	// finish a Long Rest."
	int innate_sorcery_uses_remaining = 0;
	int innate_sorcery_uses_max = 0;
	bool innate_sorcery_active = false;
	int innate_sorcery_rounds_remaining = 0; // 1 minute = 10 rounds
	// PHB 2024 Sorcerer L5 Sorcerous Restoration (para 7002-7003): once per long rest,
	// regain SP up to half level on a short rest. We track availability so future short
	// rest plumbing can consume it.
	bool sorcerous_restoration_available = false;
	// PHB 2024 Sorcerer L7 Sorcery Incarnate (para 7004-7006): when out of Innate Sorcery
	// uses, can spend 2 SP to activate it; while active, can use up to 2 metamagic per spell.
	bool sorcery_incarnate_active = false;
	bool metamagic_quickened_active = false; // L2 Metamagic - Quickened Spell pending toggle
	bool metamagic_twinned_active = false;   // L2 Metamagic - Twinned Spell pending toggle
	bool metamagic_subtle_active = false;    // L2 Metamagic - Subtle Spell pending toggle
	// PHB 2024 Sorcerer L2 Metamagic options not yet wired (para 7011-7044):
	bool metamagic_careful_active = false;   // 1 SP - allies auto-succeed save (CHA mod creatures)
	bool metamagic_distant_active = false;   // 1 SP - double range / 30ft for Touch
	bool metamagic_empowered_active = false; // 1 SP - reroll up to CHA mod damage dice
	bool metamagic_extended_active = false;  // 1 SP - double duration up to 24h, advantage on conc saves
	bool metamagic_heightened_active = false; // 2 SP - one target has disadvantage on saves vs spell
	bool metamagic_seeking_active = false;   // 1 SP - reroll missed spell attack
	bool metamagic_transmuted_active = false; // 1 SP - swap damage type Acid/Cold/Fire/Lightning/Poison/Thunder
	int metamagic_transmuted_target_type = 0; // Damage type ID to convert to
	string[] metamagic_choices; // Sorcerer L2+ selected metamagic option IDs (for validation)
	// Warlock PHB 2024 base class features
	int eldritch_invocations_known = 0;    // L1+: scales by level
	bool pact_of_the_blade = false;        // Pact Boon variants
	bool pact_of_the_chain = false;
	bool pact_of_the_tome = false;
	bool pact_of_the_talisman = false;
	// PHB 2024 Warlock L2 Magical Cunning (para 7782-7783): "perform an esoteric rite for
	// 1 minute. At the end of it, you regain expended Pact Magic spell slots but no more
	// than a number equal to half your maximum (round up). Once you use this feature, you
	// can't do so again until you finish a Long Rest."
	bool magical_cunning_available = false;
	// PHB 2024 Warlock L9 Contact Patron (paras 7788-7790): always have Contact Other Plane
	// prepared, can cast it without expending a slot, auto-success on the spell save. 1/LR.
	bool contact_patron_available = false;
	// PHB 2024 Warlock L11/13/15/17 Mystic Arcanum (paras 7791-7795): chosen high-level
	// Warlock spell castable once without a slot, refreshes on Long Rest.
	bool mystic_arcanum_6_available = false; // L11
	bool mystic_arcanum_7_available = false; // L13
	bool mystic_arcanum_8_available = false; // L15
	bool mystic_arcanum_9_available = false; // L17
	// PHB 2024 Warlock L20 Eldritch Master (para 7798-7799): "When you use your Magical
	// Cunning feature, you regain all your expended Pact Magic spell slots." (Flag is
	// passive — Magical Cunning handler reads class+level instead of a separate field,
	// but tracking here keeps state symmetric for the broadcast.)
	bool eldritch_master_active = false;
	// Eldritch Invocations — individual combat-relevant invocations (PHB 2024 paras 7749-7837)
	// NOTE: Defaulted based on level+pact until an invocation selection prompt exists.
	bool agonizing_blast = false;          // L2+: +CHA mod to chosen cantrip damage (para 7749-7752)
	bool repelling_blast = false;          // L2+: push Large or smaller 10ft on cantrip hit (para 7831-7834)
	bool devils_sight = false;             // L2+: see in magical/nonmagical darkness 120ft (para 7758-7760)
	bool thirsting_blade = false;          // L5+, Pact of Blade: Extra Attack with pact weapon (para 7835-7837)
	bool eldritch_smite = false;           // L5+, Pact of Blade: expend slot for force dmg + prone (para 7766-7768)
	bool eldritch_smite_used_this_turn = false;
	bool lifedrinker = false;              // L9+, Pact of Blade: +1d6 necrotic on pact weapon hit (para 7801-7803)
	bool lifedrinker_used_this_turn = false;
	bool devouring_blade = false;          // L12+, Thirsting Blade: 3 attacks instead of 2 (para 7761-7763)
	bool armor_of_shadows = false;        // L1+: free Mage Armor on self (para 7808-7809)
	bool eldritch_mind = false;           // L1+: advantage on concentration saves (para 7823-7824)
	bool eldritch_spear = false;          // L2+: +30*level range on EB (para 7830-7832)
	bool fiendish_vigor = false;          // L2+: auto False Life max die 12 temp HP (para 7835-7837)
	bool gift_of_the_protectors = false;  // L9+, Pact of Tome: drop to 1 HP instead of 0 1/LR (para 7849-7852)
	bool gift_of_the_protectors_used = false;
	// PHB 2024 Fighter L9 Tactical Master (para 5125-5126): replace weapon mastery with Push/Sap/Slow
	bool tactical_master_active = false;
	int tactical_master_mastery = 0; // MASTERY_PUSH, MASTERY_SAP, or MASTERY_SLOW
	// --- Companion / Summon System (TODO §7C) ---
	// Companions are full combatants tracked in combat.combatants with their own initiative,
	// HP, AC, attacks, and conditions. They're owned by another combatant via owner_id and
	// scaled to the owner's level + proficiency bonus per source.
	bool is_companion = false;          // True for Beast Master pet, Battle Smith Steel Defender, Drakewarden Drake, etc.
	uint owner_id = 0;                  // The combatant this companion is bound to (death/exhaustion may dismiss)
	string companion_subclass = "";     // "beast_master", "battle_smith", "drakewarden", "wildfire", "echo_knight", etc.
	int companion_attack_bonus = 0;     // Cached attack roll modifier (owner_prof + relevant_ability_mod)
	int companion_attack_dice = 0;      // Damage dice count
	int companion_attack_die_sides = 0; // Damage die sides
	int companion_attack_dmg_mod = 0;   // Damage flat modifier
	int companion_attack_dmg_type = 0;  // Damage type ID
	int lay_on_hands_pool = 0;
	int aura_of_protection_bonus = 0; // PHB 2024 Paladin L6+: CHA mod (source value on the Paladin)
	int paladin_aura_received_bonus = 0; // Received bonus from best nearby Paladin aura (refreshed on move/turn)
	bool paladin_aura_courage_immune = false; // L10+ Paladin within aura range: immune to Frightened
	int bardic_inspiration_uses = 0;
	int bardic_inspiration_grant_die = 0;
	int bardic_inspiration_die = 0;
	uint bardic_inspiration_source_id = 0;
	// PHB 2024 Bard L5 Font of Inspiration (para 2753-2755): regain BI on Short/Long Rest;
	// also expend a spell slot (no action) to regain 1 BI use.
	bool font_of_inspiration_active = false;
	// PHB 2024 Bard L7 Countercharm (para 2756-2757): Reaction to reroll a save with
	// advantage when an ally within 30 ft fails a save vs Charmed/Frightened.
	bool countercharm_active = false;
	// PHB 2024 Bard L10 Magical Secrets (para 2758-2759): can prepare spells from
	// Bard/Cleric/Druid/Wizard lists. Flag for future spell-prep prompt.
	bool magical_secrets_active = false;
	// PHB 2024 Bard L18 Superior Inspiration (para 2760-2761): on initiative roll,
	// regain expended BI uses until you have 2 if you have fewer.
	bool superior_inspiration_active = false;
	// PHB 2024 Bard L20 Words of Creation (para 2764-2765): always prepared Power Word
	// Heal/Kill; can target a second creature within 10 ft of the first.
	bool words_of_creation_active = false;
	int rage_uses_remaining = 0;
	int rage_damage_bonus = 0;
	bool raging = false;
	// Species/feat resistances and immunities
	bool fire_resistance = false;
	bool cold_resistance = false;
	bool necrotic_resistance = false;
	bool psychic_resistance = false;
	bool acid_resistance = false;
	bool lightning_resistance = false;
	bool piercing_resistance = false;
	bool bludgeoning_resistance = false;
	bool slashing_resistance = false;
	bool thunder_resistance = false;
	bool poison_resistance = false;
	bool radiant_resistance = false; // Xanathar's Celestial Warlock L6 Radiant Soul
	bool lightning_immunity = false; // Xanathar's Storm Sorcery L18 Wind Soul
	bool thunder_immunity = false;   // Xanathar's Storm Sorcery L18 Wind Soul
	bool poison_immunity = false;
	bool magic_resistance = false;
	// PHB 2024 Elemental Adept (para 7610): chosen damage type(s) for Energy Mastery
	bool elemental_adept_acid = false;
	bool elemental_adept_cold = false;
	bool elemental_adept_fire = false;
	bool elemental_adept_lightning = false;
	bool elemental_adept_thunder = false;
	// Armor (used for Heavy Armor Master check)
	string armor_type = "none";
	bool has_shield = false;
	// Species traits
	bool darkvision = false;
	int darkvision_range = 0;
	int flying_speed = 0;
	int swim_speed = 0;
	// Feat once-per-turn flags
	bool crusher_used_this_turn = false;
	bool crusher_crit_advantage = false; // PHB 2024 Crusher: advantage on attacks vs this target
	uint crusher_crit_source_id = 0; // Who applied the crusher crit (clears at their turn start)
	bool slasher_used_this_turn = false;
	bool slasher_crit_disadvantage = false; // PHB 2024 Slasher: disadvantage on target's attacks
	uint slasher_crit_source_id = 0; // Who applied the slasher crit (clears at their turn start)
	bool slasher_hamstring_active = false; // PHB 2024 Slasher: -10ft speed until attacker's next turn
	uint slasher_hamstring_source_id = 0; // Who applied the hamstring
	bool piercer_reroll_used_this_turn = false;
	int temp_ac_bonus_this_attack = 0; // Defensive Duelist reaction
	// Subclass feature tracking (Xanathar's/Tasha's)
	bool planar_warrior_active = false; // Horizon Walker Ranger
	uint path_to_grave_target = 0; // Grave Domain Cleric (caster tracking)
	bool path_to_grave_vulnerable = false; // Grave Domain: on TARGET, doubles next hit
	// Xanathar's Grave Domain (paras 756-803)
	bool circle_of_mortality_active = false; // L1: max healing dice at 0 HP
	int sentinel_at_death_uses = 0; // L6: reaction negate crit, WIS mod uses/LR
	bool keeper_of_souls_active = false; // L17: heal on enemy death within 60ft
	bool keeper_of_souls_used_this_turn = false; // L17: once per turn
	uint hexblade_curse_target = 0; // Hexblade Warlock
	bool hexblade_curse_used = false; // Xanathar's Hexblade L1 (para 2779-2784): 1/SR
	bool armor_of_hexes_active = false; // Xanathar's Hexblade L10 (para 2792-2793)
	bool master_of_hexes_active = false; // Xanathar's Hexblade L14 (para 2794-2795)
	bool fighting_spirit_active = false; // Samurai Fighter
	int fighting_spirit_uses = 0; // Samurai
	// Cavalier Fighter (Xanathar's paras 1669-1682)
	uint marked_by_cavalier_id = 0; // ON ANY COMBATANT: ID of Cavalier who marked this creature
	bool cavalier_mark_turn_flag = false; // expiry: true = marks placed this turn, false = clear next turn start
	bool cavalier_retaliation_available = false; // BA retaliation available (marked creature damaged someone else)
	uint cavalier_retaliation_target = 0; // target for BA retaliation attack
	int unwavering_mark_ba_uses = 0; // STR mod uses per LR for retaliation BA
	int unwavering_mark_ba_uses_max = 0;
	int warding_maneuver_uses = 0; // L7: CON mod uses per LR (para 1674-1676)
	int warding_maneuver_uses_max = 0;
	bool warding_maneuver_resistance = false; // consumed in apply_damage to halve damage
	bool hold_the_line_active = false; // L10: deferred (needs OA trigger on 5ft move)
	bool ferocious_charger_active = false; // L15: deferred (needs movement path tracking)
	bool ferocious_charger_used_this_turn = false;
	bool vigilant_defender_active = false; // L18: deferred (needs multi-reaction system)
	// Oath of Conquest Paladin (Xanathar's paras 1992-2003)
	bool scornful_rebuke_active = false; // L15: attacker takes CHA mod psychic on hit
