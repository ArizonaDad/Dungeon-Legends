	// in this way, you can't use this benefit again until you finish a Long Rest."
	bool boon_of_spell_recall_used = false;
	// PHB 2024 Fey Touched / Shadow Touched free casts (paras 1793-1800, 3563-3570)
	bool fey_touched_free_cast_used = false;
	bool shadow_touched_free_cast_used = false;

	// Subclass tracking
	bool has_frenzy = false;
	string wild_heart_choice = "";
	int zealot_fury_used = 0;
	bool fanatical_focus_used_this_rage = false; // Xanathar's Zealot L6 (para 443-444)
	bool zealous_presence_available = false; // Xanathar's Zealot L10 (para 445-447)
	bool zealous_presence_buff_active = false; // Buff from Zealous Presence (advantage attacks+saves)
	uint zealous_presence_source_id = 0; // Who granted the buff
	bool rage_beyond_death_active = false; // Xanathar's Zealot L14 (para 448-450)
	int psionic_strike_uses = 0; // Tasha's Psi Warrior (para 6-13): Psionic Energy dice pool (2×prof)
	int psionic_die_size = 6;   // Tasha's Psi Warrior: d6(L3), d8(L5), d10(L11), d12(L17)
	int superiority_dice = 0;
	int superiority_dice_max = 0;
	bool trip_attack_pending = false;
	bool precision_attack_pending = false;
	bool riposte_ready = false;
	bool assassinate_available = false;
	bool war_magic_used = false;
	int warding_flare_uses = 0;
	int war_priest_uses = 0;
	bool sacred_weapon_active = false;
	uint vow_of_enmity_target = 0;
	bool invoke_duplicity_active = false;
	int portent_roll_1 = 0;
	int portent_roll_2 = 0;
	bool portent_1_used = false;
	bool portent_2_used = false;
	int arcane_ward_hp = 0;
	int arcane_ward_max = 0;
	bool cutting_words_available = true;
	int healing_light_dice = 0;
	bool radiant_soul_used_this_turn = false; // Xanathar's Celestial Warlock L6 (para 2742)
	bool entropic_ward_active = false;
	bool dread_ambusher_used = false;
	bool dread_ambusher_extra_attack_used = false; // Xanathar's Gloom Stalker L3 (para 2154)
	uint ambush_master_marked_by = 0; // Xanathar's Scout L13 (para 2399): all attacks have advantage vs this target
	int elemental_attunement_points = 0;
	bool restore_balance_available = true;
	int dark_luck_used = 0;
	bool fey_presence_used = false;
	bool is_first_hit_this_turn = true;
	int channel_divinity_uses = 0;
	int preserve_life_pool = 0;
	// PHB 2024 Cleric L1 Divine Order (para 3600-3603) — "" / "protector" / "thaumaturge"
	string divine_order = "";
	// PHB 2024 Cleric L7 Blessed Strikes (para 3617-3620) — "" / "divine_strike" / "potent_spellcasting"
	string blessed_strikes_choice = "";
	// Divine Strike damage type sub-choice (when blessed_strikes_choice == "divine_strike")
	string divine_strike_damage_type = "";
	// Tracks "Once on each of your turns" rule for Divine Strike (para 3619)
	bool divine_strike_used_this_turn = false;
	// PHB 2024 Cleric L10 Divine Intervention (para 3621-3622): "you can call on
	// your deity or pantheon to intervene on your behalf. As a Magic action, choose
	// any Cleric spell of level 5 or lower... You can't use this feature again until
	// you finish a Long Rest." Implemented as a flag set by the action; the next
	// cast of a level <=5 cleric spell consumes the flag instead of a spell slot.
	bool divine_intervention_ready = false;
	bool divine_intervention_used_this_rest = false;

	// PHB 2024 Druid L1 Primal Order (para 4387-4390) — "" / "magician" / "warden"
	string primal_order = "";
	// PHB 2024 Druid L7 Elemental Fury (para 4430-4433) — "" / "potent_spellcasting" / "primal_strike"
	string elemental_fury_choice = "";
	// Primal Strike damage type sub-choice — "cold" / "fire" / "lightning" / "thunder"
	string primal_strike_damage_type = "";
	// "Once on each of your turns" tracking for Primal Strike (para 4433)
	bool primal_strike_used_this_turn = false;
	// PHB 2024 Druid L5 Wild Resurgence (para 4427-4429): one direction is "no action" once-per-turn
	// (slot → wild shape use) and the other is "no action" 1/long rest (wild shape → L1 slot).
	bool wild_resurgence_slot_to_use_used_this_turn = false;
	bool wild_resurgence_use_to_slot_used_this_rest = false;
	// PHB 2024 Druid L20 Archdruid Nature Magician (para 4445): convert WS uses to one slot, 1/LR
	bool nature_magician_used_this_rest = false;

	// Potion buff tracking
	int potion_damage_bonus = 0;
	int potion_ac_bonus = 0;
	int potion_speed_bonus = 0;
	int potion_spell_dc_bonus = 0;
	int potion_damage_rounds = 0;
	int potion_ac_rounds = 0;
	int potion_speed_rounds = 0;
	int potion_spell_dc_rounds = 0;

	// Boss phase tracking
	int boss_phase = 0;
	bool phase_2_triggered = false;
	bool phase_3_triggered = false;
	bool is_boss = false;

	// Summoned creature tracking
	uint summoner_id = 0;

	// Polymorph tracking
	int polymorph_original_hp = 0;
	int polymorph_original_ac = 0;
	uint polymorph_caster_id = 0;

	// Lucky feat
	int luck_points = 0;
	int luck_points_max = 0;
	bool has_lucky_feat = false;

	// Heroic Inspiration
	bool has_heroic_inspiration = false;

	// Helpers
	int get_ability_mod(int ability_id) {
		return ability_modifier(ability_scores[ability_id]);
	}

	int get_save_bonus(int ability_id) {
		// PHB 2024 Stunned (para 16247) / Paralyzed (para 16231): "The creature
		// automatically fails Strength and Dexterity saving throws."
		if ((has_condition(COND_STUNNED) or has_condition(COND_PARALYZED)) and (ability_id == ABILITY_STR or ability_id == ABILITY_DEX)) {
			return -100; // Guarantee auto-failure at all 120+ save sites
		}
		int mod = get_ability_mod(ability_id);
		if (save_proficiencies[ability_id] == 1) mod += proficiency;
		// 2024 exhaustion: subtract 2 * level from d20 rolls
		mod -= exhaustion_level * 2;
		// Basic Rules 2024 Bane (para 12032): "the target must roll a d4 and subtract
		// the number rolled from the attack roll or saving throw."
		if (baned) mod -= random(1, 4);
		// Barbarian Danger Sense (PHB 2024 para 2783, L2): "You have Advantage on Dexterity
		// saving throws unless you have the Incapacitated condition." Approximated as +5
		// to the save bonus since the existing save flow doesn't currently roll twice.
		if (danger_sense_active and ability_id == ABILITY_DEX and !has_condition(COND_INCAPACITATED)) {
			mod += 5;
		}
		// PHB 2024 Restrained (para 16240): "The creature has Disadvantage on
		// Dexterity saving throws." Approximated as -5 (matching Danger Sense +5
		// pattern) so all 120+ save sites are covered uniformly.
		if (has_condition(COND_RESTRAINED) and ability_id == ABILITY_DEX) {
			mod -= 5;
		}
		// PHB 2024 Dodge action (para 4584): "Until the start of your next turn,
		// ... you have Advantage on Dexterity saving throws." Approximated as +5
		// (matching Danger Sense pattern) so all 120+ save sites are covered.
		if (is_dodging and ability_id == ABILITY_DEX and !has_condition(COND_INCAPACITATED)) {
			mod += 5;
		}
		// PHB 2024 Paladin L6 Aura of Protection (para 5665-5669): "You and your allies
		// have a bonus to saving throws equal to your Charisma modifier (min +1) while
		// within 10 ft (30 ft at L18)." Received bonus refreshed by battle_manager on
		// turn start and movement — covers both the Paladin and nearby allies.
		if (paladin_aura_received_bonus > 0) {
			mod += paladin_aura_received_bonus;
		}
		// Xanathar's War Magic L10 Durable Magic (para 2941-2942): "While you maintain
		// concentration on a spell, you have a +2 bonus to... all saving throws."
		if (durable_magic_active and is_concentrating) mod += 2;
		// Tasha's Rune Knight L3 Giant's Might (para 3125-3130): "You have Advantage
		// on Strength checks and Strength saving throws." while active.
		if (giants_might_active and ability_id == ABILITY_STR) mod += 5;
		// Basic Rules 2024 Enlarge/Reduce (para 12795-12800): Enlarge grants Advantage
		// on STR saves; Reduce grants Disadvantage on STR saves. Approximated as +/-5.
		if (enlarge_active and ability_id == ABILITY_STR) mod += 5;
		if (reduce_active and ability_id == ABILITY_STR) mod -= 5;
		// PHB 2024 Shield Master (para 7796): "You add your Shield's AC Bonus to
		// any Dexterity saving throw you make against a spell or other harmful
		// effect that targets only you." Shield grants +2 AC.
		if (has_feat("shield_master") and has_shield and ability_id == ABILITY_DEX) mod += 2;
		// Basic Rules 2024 Resistance (para 14772): "Once before the spell ends,
		// the target can add 1d4 to one saving throw of the chosen type."
		// Simplified: adds 1d4 to any single saving throw and then expires.
		if (resistance_active) {
			int resistance_bonus = random(1, 4);
			mod += resistance_bonus;
			resistance_active = false;
		}
		// Heroes' Feast (Basic Rules 2024 para 13760): "advantage on Wisdom
		// saving throws" for 24 hours. Approximated as +5 (matching Danger Sense).
		if (heroes_feast_active and ability_id == ABILITY_WIS) mod += 5;
		return mod;
	}

	bool has_condition(int cond_id) {
		for (uint i = 0; i < conditions.length(); i++) {
			if (conditions[i] == cond_id) return true;
		}
		return false;
	}

	void add_condition(int cond_id) {
		// PHB 2024 Paladin L10 Aura of Courage (para 5682-5683): "You and your allies
		// have Immunity to the Frightened condition while in your Aura of Protection."
		// paladin_aura_courage_immune is refreshed by battle_manager.refresh_paladin_auras()
		// to cover both self and allies within the aura range.
		if (cond_id == COND_FRIGHTENED and paladin_aura_courage_immune) return;
		// PHB 2024 Petrified (para 16234): "The creature is immune to the Poisoned
		// condition." Also immune to disease but no disease system exists yet.
		if (cond_id == COND_POISONED and has_condition(COND_PETRIFIED)) return;
		// PHB 2024 Freedom of Movement (Level 4): "spells and other magical effects
		// can neither reduce the target's Speed nor cause the target to have the
		// Paralyzed or Restrained condition."
		if (freedom_of_movement_active and (cond_id == COND_PARALYZED or cond_id == COND_RESTRAINED)) return;
		// Heroes' Feast (Basic Rules 2024 para 13760): "Immunity to the Frightened
		// and Poisoned conditions" for 24 hours.
		if (heroes_feast_active and (cond_id == COND_FRIGHTENED or cond_id == COND_POISONED)) return;
		// Monster condition immunities (SRD stat block immunities)
		if (immune_poisoned and cond_id == COND_POISONED) return;
		if (immune_frightened and cond_id == COND_FRIGHTENED) return;
		if (immune_charmed and cond_id == COND_CHARMED) return;
		if (immune_paralyzed and cond_id == COND_PARALYZED) return;
		if (!has_condition(cond_id)) conditions.insert_last(cond_id);
	}

	void remove_condition(int cond_id) {
		for (int i = int(conditions.length()) - 1; i >= 0; i--) {
			if (conditions[i] == cond_id) { conditions.remove_at(i); break; }
		}
		if (cond_id == COND_FRIGHTENED) frightened_source_id = 0;
		if (cond_id == COND_GRAPPLED) grapple_source_id = 0;
	}

	bool is_alive() {
		return current_hp > 0 and !is_dead;
	}

	bool knows_spell(string spell_id) {
		for (uint i = 0; i < known_cantrips.length(); i++) {
			if (known_cantrips[i] == spell_id) return true;
		}
		for (uint i = 0; i < prepared_spells.length(); i++) {
			if (prepared_spells[i] == spell_id) return true;
		}
		return false;
	}

	bool has_feat(string feat_id) {
		for (uint i = 0; i < feats.length(); i++) {
			if (feats[i] == feat_id) return true;
		}
		return false;
	}

	bool has_skill_proficiency(string skill_name) {
		for (uint i = 0; i < skill_proficiencies.length(); i++) {
			if (skill_proficiencies[i] == skill_name) return true;
		}
		return false;
	}

	bool has_skill_expertise(string skill_name) {
		for (uint i = 0; i < skill_expertise.length(); i++) {
			if (skill_expertise[i] == skill_name) return true;
		}
		return false;
	}

	bool has_skill_check_advantage(string skill_name) {
		for (uint i = 0; i < skill_check_advantage.length(); i++) {
			if (skill_check_advantage[i] == skill_name) return true;
		}
		return false;
	}

	bool has_skill_check_disadvantage(string skill_name) {
		for (uint i = 0; i < skill_check_disadvantage.length(); i++) {
			if (skill_check_disadvantage[i] == skill_name) return true;
		}
		return false;
	}

	// PHB 2024 Barbarian L18 Indomitable Might (para 2354-2355): "If your total for a
	// Strength check or Strength saving throw is less than your Strength score, you can
	// use that score in place of the total." Returns the maximum of the supplied total
	// and the Strength score when the combatant qualifies; otherwise returns total.
	int apply_indomitable_might(int total, int ability_id) {
		if (class_name == "Barbarian" and level >= 18 and ability_id == ABILITY_STR) {
			int str_score = ability_scores[ABILITY_STR];
			if (total < str_score) return str_score;
		}
		return total;
	}

	// PHB 2024 Cleric L7 Blessed Strikes — Potent Spellcasting (para 3620): "Add your
	// Wisdom modifier to the damage you deal with any Cleric cantrip." Returns the WIS
	// modifier when the cleric has explicitly chosen Potent Spellcasting; 0 otherwise.
	int potent_spellcasting_bonus() {
		if (class_name != "Cleric") return 0;
		if (level < 7) return 0;
		if (blessed_strikes_choice != "potent_spellcasting") return 0;
		int wm = get_ability_mod(ABILITY_WIS);
		if (wm < 0) return 0;
		return wm;
	}

	// PHB 2024 Cleric L14 Improved Blessed Strikes — Potent Spellcasting (para 3626):
	// "When you cast a Cleric cantrip and deal damage to a creature with it, you can
	// give vitality to yourself or another creature within 60 feet of yourself, granting
	// a number of Temporary Hit Points equal to twice your Wisdom modifier." Auto-applies
	// to self (the always-available default). The "or another creature" choice is
	// deferred until a target-prompt system exists. Returns granted temp HP.
	int apply_improved_potent_temp_hp() {
		if (class_name != "Cleric") return 0;
		if (level < 14) return 0;
		if (blessed_strikes_choice != "potent_spellcasting") return 0;
		int wm = get_ability_mod(ABILITY_WIS);
		if (wm < 1) return 0;
		int grant = wm * 2;
		if (grant > temp_hp) temp_hp = grant; // Temp HP doesn't stack — replace if higher
		return grant;
	}

	// PHB 2024 Cleric L7 Blessed Strikes — Divine Strike (para 3619): "Once on each of
	// your turns when you hit a creature with an attack roll using a weapon, you can
	// cause the target to take an extra 1d8 Necrotic or Radiant damage (your choice)."
	// L14 Improved Blessed Strikes (para 3625): "The extra damage of your Divine Strike
	// increases to 2d8." Returns the rolled extra damage (1d8 or 2d8) and the chosen
	// damage type via out parameters; returns 0 if not eligible. Marks once-per-turn flag.
	int roll_divine_strike(int&out out_damage_type) {
		out_damage_type = -1;
		if (class_name != "Cleric") return 0;
		if (level < 7) return 0;
		if (blessed_strikes_choice != "divine_strike") return 0;
		if (divine_strike_used_this_turn) return 0;
		if (divine_strike_damage_type == "") return 0; // Player must pick damage type first
		int dice = (level >= 14) ? 2 : 1;
		int total = 0;
		for (int i = 0; i < dice; i++) total += random(1, 8);
		divine_strike_used_this_turn = true;
		out_damage_type = (divine_strike_damage_type == "necrotic") ? DMG_NECROTIC : DMG_RADIANT;
		return total;
	}

	// PHB 2024 Druid L7 Elemental Fury — Potent Spellcasting (para 4432): "Add your
	// Wisdom modifier to the damage you deal with any Druid cantrip." Returns WIS mod
	// when the druid has explicitly chosen this option; 0 otherwise.
	int druid_potent_spellcasting_bonus() {
		if (class_name != "Druid") return 0;
		if (level < 7) return 0;
		if (elemental_fury_choice != "potent_spellcasting") return 0;
		int wm = get_ability_mod(ABILITY_WIS);
		if (wm < 0) return 0;
		return wm;
	}

	// PHB 2024 Druid L7 Elemental Fury — Primal Strike (para 4433): "Once on each of
	// your turns when you hit a creature with an attack roll using a weapon or a Beast
	// form's attack in Wild Shape, you can cause the target to take an extra 1d8 Cold,
	// Fire, Lightning, or Thunder damage (choose when you hit)."
	// L15 Improved Elemental Fury (para 4437): "The extra damage of your Primal Strike
	// increases to 2d8." Returns rolled damage and chosen damage type via out param.
	int roll_primal_strike(int&out out_damage_type) {
		out_damage_type = -1;
		if (class_name != "Druid") return 0;
		if (level < 7) return 0;
		if (elemental_fury_choice != "primal_strike") return 0;
		if (primal_strike_used_this_turn) return 0;
		if (primal_strike_damage_type == "") return 0; // Player must pick damage type first
		int dice = (level >= 15) ? 2 : 1;
		int total = 0;
		for (int i = 0; i < dice; i++) total += random(1, 8);
		primal_strike_used_this_turn = true;
		if (primal_strike_damage_type == "cold") out_damage_type = DMG_COLD;
		else if (primal_strike_damage_type == "fire") out_damage_type = DMG_FIRE;
		else if (primal_strike_damage_type == "lightning") out_damage_type = DMG_LIGHTNING;
		else if (primal_strike_damage_type == "thunder") out_damage_type = DMG_THUNDER;
		return total;
	}

	int get_skill_bonus(string skill_name, int ability_id) {
		// PHB 2024: ability mod + proficiency bonus (if proficient) + 2x prof if expertise +
		// half prof if Jack of All Trades and not otherwise proficient.
		int bonus = get_ability_mod(ability_id);
		bool proficient = has_skill_proficiency(skill_name);
		if (has_skill_expertise(skill_name)) {
			// Expertise: doubled proficiency. Source: Bard L3 / Rogue L1 PHB.
			bonus += proficiency * 2;
		} else if (proficient) {
			bonus += proficiency;
		} else if (jack_of_all_trades) {
			// Jack of All Trades (Bard L2): "you can add half your Proficiency Bonus, rounded
			// down, to any ability check you make that doesn't already include your Proficiency
			// Bonus." PHB Bard class feature.
			bonus += proficiency / 2;
		}
		bonus -= exhaustion_level * 2;
		// Xanathar's Samurai L7 Elegant Courtier (para 1705-1707): "+WIS mod to
		// Persuasion checks" (also applies to all CHA checks per some readings,
		// but strict RAW is Persuasion only)
		if (skill_name == "Persuasion" and class_name == "Fighter" and subclass == "Samurai" and level >= 7) {
			int wis_mod = get_ability_mod(ABILITY_WIS);
			if (wis_mod > 0) bonus += wis_mod;
		}
		return bonus;
	}

	int get_spellcasting_override_ability(string spell_id) {
		for (uint i = 0; i < spellcasting_override_spells.length() and i < spellcasting_override_abilities.length(); i++) {
			if (spellcasting_override_spells[i] == spell_id) return spellcasting_override_abilities[i];
		}
		return -1;
	}

	int get_free_cast_uses_remaining(string spell_id) {
		for (uint i = 0; i < free_cast_spells.length() and i < free_cast_uses_remaining.length(); i++) {
			if (free_cast_spells[i] == spell_id) return free_cast_uses_remaining[i];
		}
		return 0;
	}

	void grant_free_cast(string spell_id, int uses) {
		for (uint i = 0; i < free_cast_spells.length() and i < free_cast_uses_remaining.length(); i++) {
			if (free_cast_spells[i] == spell_id) {
				if (uses > free_cast_uses_remaining[i]) free_cast_uses_remaining[i] = uses;
				return;
			}
		}
		free_cast_spells.insert_last(spell_id);
		free_cast_uses_remaining.insert_last(uses);
	}

	bool use_free_cast(string spell_id) {
		for (uint i = 0; i < free_cast_spells.length() and i < free_cast_uses_remaining.length(); i++) {
			if (free_cast_spells[i] == spell_id and free_cast_uses_remaining[i] > 0) {
				free_cast_uses_remaining[i]--;
				return true;
			}
		}
		return false;
	}

	bool is_conscious() {
		return is_alive() and !has_condition(COND_UNCONSCIOUS);
	}

	bool is_incapacitated_check() {
		return has_condition(COND_INCAPACITATED) or has_condition(COND_PARALYZED) or has_condition(COND_PETRIFIED) or has_condition(COND_STUNNED) or has_condition(COND_UNCONSCIOUS);
	}
}

// The battle instance managing one combat encounter
class battle {
	uint id;
	combatant@[] combatants;
	int[] initiative_order;        // indices into combatants, sorted by initiative
	int current_turn_index = -1;   // index into initiative_order
	int round_number = 0;
	bool battle_active = false;
	string mode = "pvp";           // "pvp", "wave", "boss"
	int wave_number = 0;

	// Pending roll state
	bool waiting_for_roll = false;
	uint roll_target_id = 0;       // who we're waiting for
	int roll_type = -1;
	int roll_dice_type = 20;       // d20 by default
	int roll_modifier = 0;
	string roll_reason = "";

	// Map
	int map_width = DEFAULT_MAP_WIDTH;
	int map_height = DEFAULT_MAP_HEIGHT;

	// Get combatant by ID
	combatant@ get_combatant(uint cid) {
		for (uint i = 0; i < combatants.length(); i++) {
			if (combatants[i].id == cid) return combatants[i];
		}
		return null;
	}

	// Get current turn combatant
	combatant@ current_combatant() {
		if (current_turn_index < 0 or current_turn_index >= int(initiative_order.length())) return null;
		int idx = initiative_order[current_turn_index];
		if (idx < 0 or idx >= int(combatants.length())) return null;
		return combatants[idx];
	}

	// Add a combatant to the battle (IDs start at 1, 0 = unset/invalid)
	uint add_combatant(combatant@ c) {
		c.id = combatants.length() + 1;
		combatants.insert_last(c);
		return c.id;
	}

	// Roll a d20 (server-side, but result sent after player presses Roll)
	int roll_d20() {
		return random(1, 20);
	}

	// Roll any dice: count d sides
	int roll_dice_pool(int count, int sides) {
		int total = 0;
		for (int i = 0; i < count; i++) {
			total += random(1, sides);
		}
		return total;
	}

	// Start initiative phase - reset state for new initiative rolling.
	// Does NOT auto-roll; battle_manager.request_next_initiative() handles rolling.
	void start_initiative() {
		battle_active = true;
		round_number = 0;
		current_turn_index = 0;
		initiative_order.resize(0);
		// Reset initiative rolls to 0 so they can be set by battle_manager
		for (uint i = 0; i < combatants.length(); i++) {
			combatants[i].initiative_roll = 0;
		}
	}

	// Build and sort initiative order from stored rolls (called after all rolls are collected).
	void build_initiative_order() {
		initiative_order.resize(0);
		// Collect alive combatant indices
		for (uint i = 0; i < combatants.length(); i++) {
			if (!combatants[i].is_alive()) continue;
			initiative_order.insert_last(int(i));
		}
		// Bubble sort by initiative roll descending
		for (uint i = 0; i < initiative_order.length(); i++) {
			for (uint j = i + 1; j < initiative_order.length(); j++) {
				if (combatants[initiative_order[j]].initiative_roll > combatants[initiative_order[i]].initiative_roll) {
					int temp = initiative_order[i];
					initiative_order[i] = initiative_order[j];
					initiative_order[j] = temp;
				}
			}
		}
	}

	// Start the next turn
	void advance_turn() {
		current_turn_index++;
		if (current_turn_index >= int(initiative_order.length())) {
			current_turn_index = 0;
			round_number++;
		}
		// Skip dead combatants (unconscious ones still need death saves)
		combatant@ c = current_combatant();
		if (@c == null) return;

		// Reset turn resources
		c.has_action = true;
		c.has_bonus_action = true;
		c.movement_remaining = c.speed;
		c.has_moved = false;
		c.used_action = false;
		c.used_bonus_action = false;
		c.is_dodging = false;
		c.took_disengage = false;
		c.attacks_remaining_this_turn = 0;
		c.divine_smite_pending = false;
		c.divine_smite_slot_level = 0;
		c.savage_attacker_used = false;
		c.combat_prowess_used = false;
		c.tavern_brawler_push_used = false;
		c.hunter_colossus_used = false;
		c.is_first_hit_this_turn = true;
		c.dread_ambusher_used = false;
		c.dread_ambusher_extra_attack_used = false;
		c.radiant_soul_used_this_turn = false;
		c.crusher_used_this_turn = false;
		c.slasher_used_this_turn = false;
		c.piercer_reroll_used_this_turn = false;
		c.fighting_spirit_active = false;
		c.ferocious_charger_used_this_turn = false;
		c.ancestral_protector_hit_this_turn = false;
		c.planar_warrior_active = false;
		c.swashbuckler_attacked_this_turn = false;
		c.trip_attack_pending = false;
		c.precision_attack_pending = false;
		c.stalkers_flurry_used_this_turn = false;
		if (c.agile_parry_bonus) {
			c.armor_class -= 2;
		}
		c.agile_parry_bonus = false;
		c.blade_flourish_speed_applied = false;
		c.kenseis_shot_active = false;
		c.deft_strike_used_this_turn = false;
		c.unerring_accuracy_used_this_turn = false;
		c.slayer_prey_used_this_turn = false;
		c.storm_aura_used_this_turn = false;
		c.twf_attack_used_this_turn = false;
		if (c.arcane_deflection_no_spell_turns > 0) c.arcane_deflection_no_spell_turns--;

		// Reaction resets at start of YOUR turn
		c.has_reaction = true;

		// Slow spell enforcement (PHB 2024 para 15047-15049):
		// "it can't take Reactions" + "it can take EITHER an Action or a Bonus Action, not both"
		if (c.slow_spell_caster_id != 0) {
			c.has_reaction = false;
			c.has_bonus_action = false; // Keep action, remove bonus action (more useful default)
		}

		// 2024 Exhaustion: reduce speed by 5 per level
		c.movement_remaining -= c.exhaustion_level * 5;
		if (c.movement_remaining < 0) c.movement_remaining = 0;

		// If at 0 HP and not dead/stable, death save is needed
		// (handled externally via roll_request)
	}

	// Apply damage to a combatant
	void restore_wild_shape(combatant@ target, int overflow = 0) {
		if (@target == null or !target.wild_shape_active) return;

		target.name = target.wild_shape_saved_name;
		target.size = target.wild_shape_saved_size;
		target.max_hp = target.wild_shape_saved_max_hp;
		target.current_hp = target.wild_shape_saved_current_hp - overflow;
		target.temp_hp = target.wild_shape_saved_temp_hp;
		target.armor_class = target.wild_shape_saved_armor_class;
		target.speed = target.wild_shape_saved_speed;
		target.ability_scores[ABILITY_STR] = target.wild_shape_saved_strength;
		target.ability_scores[ABILITY_DEX] = target.wild_shape_saved_dexterity;
		target.ability_scores[ABILITY_CON] = target.wild_shape_saved_constitution;
		target.ability_scores[ABILITY_INT] = target.wild_shape_saved_intelligence;
		target.ability_scores[ABILITY_WIS] = target.wild_shape_saved_wisdom;
		target.ability_scores[ABILITY_CHA] = target.wild_shape_saved_charisma;
		target.main_hand = target.wild_shape_saved_main_hand;
		target.main_hand_damage_dice = target.wild_shape_saved_main_hand_damage_dice;
		target.main_hand_damage_count = target.wild_shape_saved_main_hand_damage_count;
		target.main_hand_damage_type = target.wild_shape_saved_main_hand_damage_type;
		target.main_hand_range = target.wild_shape_saved_main_hand_range;
		target.main_hand_finesse = target.wild_shape_saved_main_hand_finesse;
		target.main_hand_is_ranged = target.wild_shape_saved_main_hand_is_ranged;
		target.monster_attack_bonus = target.wild_shape_saved_monster_attack_bonus;
		target.monster_attack_damage_mod = target.wild_shape_saved_monster_attack_damage_mod;
		target.monster_attack2_name = target.wild_shape_saved_monster_attack2_name;
		target.monster_attack2_bonus = target.wild_shape_saved_monster_attack2_bonus;
		target.monster_attack2_dice = target.wild_shape_saved_monster_attack2_dice;
		target.monster_attack2_count = target.wild_shape_saved_monster_attack2_count;
		target.monster_attack2_mod = target.wild_shape_saved_monster_attack2_mod;
		target.monster_attack2_type = target.wild_shape_saved_monster_attack2_type;
		target.monster_attack2_range = target.wild_shape_saved_monster_attack2_range;
		target.extra_attacks = target.wild_shape_saved_extra_attacks;
		target.wild_shape_active = false;
		target.wild_shape_form_id = "";
		target.wild_shape_just_ended = true;
		if (target.current_hp > target.max_hp) target.current_hp = target.max_hp;
	}

	void apply_damage(combatant@ target, int amount, int damage_type, combatant@ source = null, bool was_crit = false) {
		if (@target == null or target.is_dead) return;
		if (amount <= 0) return;

		// Resilient Sphere: target enclosed in sphere is immune to all damage
		// from outside. Source inside the sphere (self-damage) is also blocked
		// since "nothing can pass through the barrier."
		if (target.resilient_sphere_trapped) return;

		// SRD Regeneration blocking: fire or acid damage prevents regen next turn
		if (target.regen_amount > 0) {
			if ((damage_type == DMG_FIRE and target.regen_needs_no_fire) or
				(damage_type == DMG_ACID and target.regen_needs_no_acid)) {
				target.regen_blocked_this_round = true;
			}
		}

		if (target.raging and (damage_type == DMG_BLUDGEONING or damage_type == DMG_PIERCING or damage_type == DMG_SLASHING)) {
			amount = (amount + 1) / 2;
		}

		// PHB 2024 Blade Ward (cantrip): "Until the start of your next turn, you have
		// Resistance to Bludgeoning, Piercing, and Slashing damage."
		if (target.blade_ward_active and (damage_type == DMG_BLUDGEONING or damage_type == DMG_PIERCING or damage_type == DMG_SLASHING)) {
			amount = (amount + 1) / 2;
		}

		// Ancestral Guardian Barbarian: Spirit Shield damage reduction (used reaction)
		if (target.spirit_shield_reduction > 0) {
			amount -= target.spirit_shield_reduction;
			if (amount < 0) amount = 0;
			target.spirit_shield_reduction = 0;
		}

		// PHB 2024 Monk L3 Deflect Attacks (para 5337-5339): reaction reduces attack's
		// total damage by 1d10 + DEX mod + Monk level. If reduced to 0, caller can spend
		// 1 Focus Point to redirect the force. The reduction value is set when the
		// Monk chose to use the reaction in handle_reaction_response.
		if (target.deflect_attacks_reduction > 0) {
			amount -= target.deflect_attacks_reduction;
			if (amount <= 0) {
				amount = 0;
				target.deflect_attacks_reduced_to_zero = true;
			}
			target.deflect_attacks_reduction = 0;
		}

		// PHB 2024 Rogue L5 Uncanny Dodge (para 6561-6562): "halve the attack's damage
		// against you (round down)." Set in handle_reaction_response when defender chose
		// the reaction; consumed here once per triggering attack.
		if (target.uncanny_dodge_pending) {
			amount = amount / 2;
			target.uncanny_dodge_pending = false;
		}

		// Xanathar's Cavalier L7 Warding Maneuver (para 1674-1676): "If the attack
		// still hits, the target has resistance against the attack's damage."
		if (target.warding_maneuver_resistance) {
			amount = amount / 2;
			target.warding_maneuver_resistance = false;
		}

		// Heavy Armor Master: reduce B/P/S damage by Proficiency Bonus when wearing heavy armor
		if (target.has_feat("heavy_armor_master") and (damage_type == DMG_BLUDGEONING or damage_type == DMG_PIERCING or damage_type == DMG_SLASHING)) {
			if (target.armor_type == "chain_mail" or target.armor_type == "splint" or target.armor_type == "plate" or target.armor_type == "ring_mail") {
				amount -= target.proficiency;
				if (amount < 1) amount = 1;
			}
		}

		// Tasha's Clockwork Soul L6 Bastion of Law (para 3997-4000): ward dice absorb damage
		if (target.bastion_of_law_dice > 0) {
			int ward_absorbed = 0;
			// Spend dice one at a time until damage is absorbed or dice run out
			while (target.bastion_of_law_dice > 0 and amount > 0) {
				int roll = random(1, 8);
				ward_absorbed += roll;
				target.bastion_of_law_dice--;
				amount -= roll;
			}
			if (amount < 0) amount = 0;
		}

		// Xanathar's Shadow Magic L18 Umbral Form (para 2605-2607): resistance to all
		// damage except force and radiant while in shadowy form.
		if (target.shadow_umbral_active and damage_type != DMG_FORCE and damage_type != DMG_RADIANT) {
			amount = (amount + 1) / 2;
		}

		// Xanathar's Oath of Conquest L20 Invincible Conqueror (para 1999):
		// "you gain resistance to all damage"
		if (target.invincible_conqueror_active) {
			amount = (amount + 1) / 2;
		}

		// Xanathar's Oath of Redemption L20 Emissary of Redemption (para 2052-2056):
		// "you have resistance to all damage dealt by other creatures (their attacks,
		// spells, and other effects). Also, whenever a creature damages you, it takes
		// radiant damage equal to half the amount it dealt to you."
		// Note: source excludes creatures you've attacked — deferred (needs per-creature tracking)
		if (target.emissary_of_redemption_active and @source != null and source.id != target.id) {
			amount = (amount + 1) / 2;
		}

		// PHB 2024 Elemental Adept (para 7610): "Spells you cast ignore Resistance
		// to damage of the chosen type." Bypass resistance for the 5 eligible types.
		bool ea_bypass = false;
		if (@source != null) {
			if ((damage_type == DMG_ACID and source.elemental_adept_acid) or
				(damage_type == DMG_COLD and source.elemental_adept_cold) or
				(damage_type == DMG_FIRE and source.elemental_adept_fire) or
				(damage_type == DMG_LIGHTNING and source.elemental_adept_lightning) or
				(damage_type == DMG_THUNDER and source.elemental_adept_thunder)) {
				ea_bypass = true;
			}
		}
		// Species/feat resistances and immunities
		if (damage_type == DMG_COLD and target.cold_resistance and !ea_bypass) amount = (amount + 1) / 2;
		if (damage_type == DMG_NECROTIC and target.necrotic_resistance) amount = (amount + 1) / 2;
		if (damage_type == DMG_PSYCHIC and target.psychic_resistance) amount = (amount + 1) / 2;
		// Tasha's Aberrant Mind L6 Psychic Defenses (para 3939-3941): psychic resistance
		// is now granted via psychic_resistance flag on init, not double-halving here.
		if (damage_type == DMG_ACID and target.acid_resistance and !ea_bypass) amount = (amount + 1) / 2;
		if (damage_type == DMG_LIGHTNING and target.lightning_immunity) amount = 0;
		if (damage_type == DMG_THUNDER and target.thunder_immunity) amount = 0;
		if (damage_type == DMG_LIGHTNING and target.lightning_resistance and !target.lightning_immunity and !ea_bypass) amount = (amount + 1) / 2;
		if (damage_type == DMG_THUNDER and target.thunder_resistance and !target.thunder_immunity and !ea_bypass) amount = (amount + 1) / 2;
		if (damage_type == DMG_PIERCING and target.piercing_resistance) amount = (amount + 1) / 2;
		if (damage_type == DMG_BLUDGEONING and target.bludgeoning_resistance) amount = (amount + 1) / 2;
		if (damage_type == DMG_SLASHING and target.slashing_resistance) amount = (amount + 1) / 2;
		// SRD: B/P/S resistance from nonmagical attacks (Lich, Pit Fiend, Wraith, Wight).
		// Approximation: player weapon attacks are treated as nonmagical unless they have
		// a magic weapon flag; spell-sourced B/P/S bypasses this resistance.
		if (target.resist_bps_nonmagical and !target.piercing_resistance and !target.bludgeoning_resistance and !target.slashing_resistance) {
			if (damage_type == DMG_BLUDGEONING or damage_type == DMG_PIERCING or damage_type == DMG_SLASHING) {
				// If source has Magic Weapon spell (+1/+2/+3), bypass this resistance
				bool magic_weapon = false;
				if (@source != null and source.magic_weapon_bonus > 0) magic_weapon = true;
				if (!magic_weapon) amount = (amount + 1) / 2;
			}
		}
		if (damage_type == DMG_FIRE and target.fire_resistance and !ea_bypass) amount = (amount + 1) / 2;
		// PHB 2024 Sorcerer Draconic Sorcery L6 Elemental Affinity (para 7559-7560):
		// "You have Resistance to that damage type" (the type chosen for Elemental
		// Affinity). Resistance halves damage of the chosen type.
		if (target.class_name == "Sorcerer" and target.subclass == "Draconic Sorcery" and target.level >= 6 and target.elemental_affinity_type != "") {
			int ea_dmg_int = -1;
			if (target.elemental_affinity_type == "acid") ea_dmg_int = DMG_ACID;
			else if (target.elemental_affinity_type == "cold") ea_dmg_int = DMG_COLD;
			else if (target.elemental_affinity_type == "fire") ea_dmg_int = DMG_FIRE;
			else if (target.elemental_affinity_type == "lightning") ea_dmg_int = DMG_LIGHTNING;
			else if (target.elemental_affinity_type == "poison") ea_dmg_int = DMG_POISON;
			if (ea_dmg_int >= 0 and damage_type == ea_dmg_int) {
				amount = (amount + 1) / 2;
			}
		}
		// Mother of Sorrows Poison Soul (Book of Ebon Tides para 1135):
		// "Any poison damage you deal ignores any resistance or immunity."
		// Poisoner feat (PHB para 7715): "When you make a damage roll that deals Poison
		// damage, it ignores Resistance to Poison damage."
		// Note: Poisoner only bypasses RESISTANCE, not immunity. Mother of Sorrows bypasses both.
		bool source_poison_soul = (@source != null and source.poison_soul_active);
		bool source_poisoner = (@source != null and source.has_feat("poisoner"));
		bool skip_poison_resistance = source_poison_soul or source_poisoner;
		bool skip_poison_immunity = source_poison_soul; // Poisoner does NOT bypass immunity
		if (damage_type == DMG_POISON and target.poison_resistance and !target.poison_immunity and !skip_poison_resistance) amount = (amount + 1) / 2;
		if (damage_type == DMG_POISON and target.poison_immunity and !skip_poison_immunity) amount = 0;
		if (damage_type == DMG_RADIANT and target.radiant_resistance) amount = (amount + 1) / 2;

		// PHB 2024 Petrified (para 16234-16236): "The creature has Resistance to all
		// damage" and "The creature is immune to the Poisoned condition." Poison
		// immunity is handled by zeroing poison damage here; condition immunity is
		// enforced in add_condition.
		if (target.has_condition(COND_PETRIFIED)) {
			if (damage_type == DMG_POISON) amount = 0;
			else amount = (amount + 1) / 2;
		}

		// Basic Rules 2024 Protection from Energy (para 14707): "the willing creature
		// you touch has Resistance to one damage type: Acid, Cold, Fire, Lightning, or
		// Thunder." Concentration spell, halves matching damage type.
		if (target.protection_from_energy_active and damage_type == target.protection_from_energy_type and !ea_bypass) {
			amount = (amount + 1) / 2;
		}

		// Heroes' Feast (Basic Rules 2024 para 13760): "Resistance to Poison damage"
		if (target.heroes_feast_active and damage_type == DMG_POISON and !ea_bypass) {
			amount = (amount + 1) / 2;
		}

		// Tasha's Circle of Stars L14 Full of Stars (para 2179-2181): "While in your
		// Starry Form, you become partially incorporeal, giving you resistance to
		// bludgeoning, piercing, and slashing damage."
		if (target.starry_form_active and target.level >= 14 and (damage_type == DMG_BLUDGEONING or damage_type == DMG_PIERCING or damage_type == DMG_SLASHING)) {
			amount = (amount + 1) / 2;
		}
		// PHB 2024 Monk L18 Superior Defense (para 5372-5373): "you have Resistance
		// to all damage except Force damage." Halve damage of any non-Force type.
		if (target.superior_defense_active and damage_type != DMG_FORCE) {
			amount = (amount + 1) / 2;
		}

		// Death Ward (Basic Rules para 12784): "The first time the target would drop to
		// 0 Hit Points before the spell ends, the target instead drops to 1 Hit Point,
		// and the spell ends."
		if (target.death_ward_active and amount >= target.current_hp + target.temp_hp) {
			target.current_hp = 1;
			target.temp_hp = 0;
			target.death_ward_active = false;
			return;
		}

		// Arcane Ward absorbs damage for Abjurer Wizards
		if (target.arcane_ward_hp > 0 and target.class_name == "Wizard" and target.subclass == "Abjurer") {
			if (amount <= target.arcane_ward_hp) {
				target.arcane_ward_hp -= amount;
				return;
			}
			amount -= target.arcane_ward_hp;
			target.arcane_ward_hp = 0;
		}

		// Temp HP absorbs first
		if (target.temp_hp > 0) {
			if (amount <= target.temp_hp) {
				target.temp_hp -= amount;
				return;
			}
			amount -= target.temp_hp;
			target.temp_hp = 0;
		}

		target.current_hp -= amount;

		// Tasha's Order Domain Order's Demand: charm ends when charmed creature takes damage.
		if (amount > 0 and target.orders_demand_charmed_by != 0 and target.has_condition(COND_CHARMED)) {
			target.remove_condition(COND_CHARMED);
			target.orders_demand_charmed_by = 0;
			target.orders_demand_turns_left = 0;
		}

		// Basic Rules 2024 Dominate Person (para 12981) / Dominate Monster (para 12967) /
		// Dominate Beast (para 12958): "Each time the target takes damage, it makes a new
		// Wisdom saving throw against the spell. If the saving throw succeeds, the spell ends."
		if (amount > 0 and target.charm_spell_caster_id != 0 and target.has_condition(COND_CHARMED)) {
			combatant@ dom_caster = get_combatant(target.charm_spell_caster_id);
			if (@dom_caster != null and dom_caster.is_concentrating
				and (dom_caster.concentration_spell == "Dominate Person"
					or dom_caster.concentration_spell == "Dominate Monster"
					or dom_caster.concentration_spell == "Dominate Beast")) {
				int dom_dc = spell_save_dc(dom_caster);
				int dom_save = random(1, 20) + target.get_save_bonus(ABILITY_WIS);
				if (dom_save >= dom_dc) {
					target.remove_condition(COND_CHARMED);
					target.charm_spell_caster_id = 0;
					dom_caster.is_concentrating = false;
					dom_caster.concentration_spell = "";
					dom_caster.remove_condition(COND_CONCENTRATING);
				}
			}
		}

		// Basic Rules 2024 Charm Person (para 12306): "The spell ends on a target if you
		// or your allies deal damage to it or force it to make a saving throw."
		// Approximation: if the charmed target takes ANY damage, end the charm.
		if (amount > 0 and target.charm_spell_caster_id != 0 and target.has_condition(COND_CHARMED)) {
			combatant@ chm_caster = get_combatant(target.charm_spell_caster_id);
			if (@chm_caster != null and chm_caster.is_concentrating
				and (chm_caster.concentration_spell == "Charm Person"
					or chm_caster.concentration_spell == "Charm Monster")) {
				target.remove_condition(COND_CHARMED);
				target.charm_spell_caster_id = 0;
				chm_caster.is_concentrating = false;
				chm_caster.concentration_spell = "";
				chm_caster.remove_condition(COND_CONCENTRATING);
			}
			// Basic Rules 2024 Hypnotic Pattern (para 13821): "The spell ends for an
			// affected creature if it takes any damage." Per-target end, not full spell.
			else if (@chm_caster != null and chm_caster.is_concentrating
				and chm_caster.concentration_spell == "Hypnotic Pattern") {
				target.remove_condition(COND_CHARMED);
				if (target.has_condition(COND_INCAPACITATED)) target.remove_condition(COND_INCAPACITATED);
				target.charm_spell_caster_id = 0;
			}
		}

		// Xanathar's Oath of Redemption L20 Emissary of Redemption retaliation (para 2054):
		// "whenever a creature damages you, it takes radiant damage equal to half the
		// amount it dealt to you." Guard against recursion via emissary check on source.
		if (target.emissary_of_redemption_active and @source != null and source.id != target.id and amount > 0 and !source.emissary_of_redemption_active) {
			int retribution = (amount + 1) / 2;
			if (retribution > 0) {
				source.current_hp -= retribution;
			}
		}

		if (target.wild_shape_active and target.current_hp <= 0) {
			int overflow = -target.current_hp;
			restore_wild_shape(target, overflow);
		}

		// Basic Rules 2024 Polymorph (para 14624-14626): "The creature reverts to
		// its normal form when it drops to 0 Hit Points." Excess damage carries over.
		if (target.polymorph_original_hp > 0 and target.current_hp <= 0) {
			int overflow = -target.current_hp;
			target.armor_class = target.polymorph_original_ac;
			target.current_hp = target.polymorph_original_hp - overflow;
			if (target.current_hp > target.max_hp) target.current_hp = target.max_hp;
			if (target.current_hp < 0) target.current_hp = 0;
			target.remove_condition(COND_CHARMED);
			target.polymorph_original_hp = 0;
			target.polymorph_original_ac = 0;
			target.polymorph_caster_id = 0;
		}

		// Note: concentration saves are handled by battle_manager.check_concentration()
		// which is called by each damage source site individually (spell handlers, OA, etc.)

		// Check for dropping to 0
		if (target.current_hp <= 0) {
			// Barbarian Relentless Rage (PHB 2024 paras 2806-2807, L11): "If you drop to
			// 0 Hit Points while your Rage is active and don't die outright, you can make
			// a DC 10 Constitution saving throw. If you succeed, your Hit Points instead
			// change to a number equal to twice your Barbarian level. Each time you use
			// this feature after the first, the DC increases by 5."
			if (target.class_name == "Barbarian" and target.level >= 11 and target.raging and !target.is_dead) {
				int rr_overflow = -target.current_hp;
				if (rr_overflow < target.max_hp) { // Not instant death
					int rr_save = random(1, 20) + target.get_save_bonus(ABILITY_CON);
					if (rr_save >= target.relentless_rage_dc) {
						target.current_hp = 2 * target.level;
						target.relentless_rage_dc += 5;
						return;
					}
				}
			}
			// Xanathar's Shadow Magic L1 Strength of the Grave (para 2593-2595):
			// "When damage reduces you to 0 HP, you can make a CHA save (DC 5 + damage).
			// On success, drop to 1 HP instead. Can't use if reduced by radiant damage
			// or by a critical hit. After success, can't use again until LR."
			// Xanathar's source also excludes critical hits per para 2594
			if (target.class_name == "Sorcerer" and target.subclass == "Shadow Magic" and !target.strength_of_the_grave_used and damage_type != DMG_RADIANT and !was_crit and !target.is_dead) {
				int overflow_check = -target.current_hp;
				if (overflow_check < target.max_hp) { // Not instant death (killed outright)
					int save_roll = random(1, 20);
					int save_bonus = target.get_ability_mod(ABILITY_CHA);
					int save_dc = 5 + amount;
					int save_total = save_roll + save_bonus;
					if (save_total >= save_dc) {
						target.current_hp = 1;
						target.strength_of_the_grave_used = true;
						// Announcement handled by battle_manager after apply_damage returns
						return;
					}
				}
			}
			// Valda's Spire Gunslinger L13 Cheat Death (paras 193-194): "When you are
			// reduced to 0 Hit Points and not killed outright, you can drop to 1 Hit
			// Point instead, and you regain a number of Hit Points equal to your
			// Gunslinger level. Once you use this feature, you can't use it again until
			// you finish a Short or Long Rest."
			if (target.class_name == "Gunslinger" and target.level >= 13 and !target.cheat_death_used and !target.is_dead) {
				int cd_overflow = -target.current_hp;
				if (cd_overflow < target.max_hp) { // Not killed outright
					target.cheat_death_used = true;
					target.current_hp = 1 + target.level;
					if (target.current_hp > target.max_hp) target.current_hp = target.max_hp;
					return;
				}
			}
			// Basic Rules 2024 Gift of the Protectors (para 7849-7852): "When any creature
			// whose name is on the page is reduced to 0 Hit Points but not killed outright,
			// the creature magically drops to 1 Hit Point instead."
			if (target.gift_of_the_protectors and !target.gift_of_the_protectors_used and !target.is_dead) {
				int gp_overflow = -target.current_hp;
				if (gp_overflow < target.max_hp) {
					target.gift_of_the_protectors_used = true;
					target.current_hp = 1;
					return;
				}
			}
			// Instant death check: remaining damage >= max HP
			int overflow = -target.current_hp;
			if (overflow >= target.max_hp) {
				target.is_dead = true;
				target.current_hp = 0;
				target.add_condition(COND_UNCONSCIOUS);
				return;
			}
			target.current_hp = 0;
			if (target.is_player) {
				// Xanathar's Zealot L14 Rage Beyond Death (para 448-450): "While you're
				// raging, having 0 hit points doesn't knock you unconscious. You still must
				// make death saving throws. However, if you would die due to failing death
				// saving throws, you don't die until your rage ends."
				if (target.rage_beyond_death_active and target.raging) {
					// Stay conscious at 0 HP while raging — death saves still accumulate
					// but death is deferred until rage ends
					target.death_save_successes = 0;
					target.death_save_failures = 0;
				} else {
					// Player falls unconscious, start death saves
					target.add_condition(COND_UNCONSCIOUS);
					target.death_save_successes = 0;
					target.death_save_failures = 0;
				}
			} else {
				// SRD Troll Regeneration: Troll doesn't die at 0 HP unless fire/acid
				// was the killing blow (regen_blocked_this_round). It stays at 0 HP
				// and regeneration at turn start will revive it.
				if (target.regen_amount > 0 and !target.regen_blocked_this_round) {
					// Troll is "down" but not dead — regeneration will bring it back
					target.add_condition(COND_UNCONSCIOUS);
				} else {
					// Monster dies instantly (standard D&D rule)
					target.is_dead = true;
				}
			}
			return;
		}

		// PHB 2024 (para 16157): "If you have 0 Hit Points and take damage, you
		// suffer a death saving throw failure. If the damage is from a Critical Hit,
		// you suffer two failures instead."
		if (target.current_hp == 0 and !target.is_dead and target.has_condition(COND_UNCONSCIOUS)) {
			if (was_crit) target.death_save_failures += 2;
			else target.death_save_failures++;
			if (target.death_save_failures >= DEATH_SAVE_FAILURES_NEEDED) {
				target.is_dead = true;
			}
		}
	}

	// Apply healing
	int apply_healing(combatant@ target, int amount) {
		if (@target == null or target.is_dead) return 0;
		if (amount <= 0) return 0;

		bool was_unconscious = target.current_hp == 0;
		int before = target.current_hp;
		target.current_hp += amount;
		if (target.current_hp > target.max_hp) target.current_hp = target.max_hp;
		int effective = target.current_hp - before;

		// Regaining HP from 0 removes unconscious
		if (was_unconscious and target.current_hp > 0) {
			target.remove_condition(COND_UNCONSCIOUS);
			target.death_save_successes = 0;
			target.death_save_failures = 0;
			target.is_stable = false;
		}
		return effective;
	}

	// Process a death saving throw result
	void process_death_save(combatant@ c, int roll, int total = -1) {
		if (@c == null or c.is_dead or c.current_hp > 0) return;
		if (total < 0) total = roll;

		if (roll == 1) {
			// Natural 1 = 2 failures
			c.death_save_failures += 2;
		} else if (roll == 20) {
			// Natural 20 = regain 1 HP
			c.current_hp = 1;
			c.remove_condition(COND_UNCONSCIOUS);
			c.death_save_successes = 0;
			c.death_save_failures = 0;
		} else if (total >= DEATH_SAVE_DC) {
			c.death_save_successes++;
		} else {
			c.death_save_failures++;
		}

		if (c.death_save_failures >= DEATH_SAVE_FAILURES_NEEDED) {
			// Xanathar's Zealot L14 Rage Beyond Death (para 448-450): "if you would die
			// due to failing death saving throws, you don't die until your rage ends"
			if (c.rage_beyond_death_active and c.raging) {
				// Death deferred — rage keeps you fighting at 0 HP
			} else {
				c.is_dead = true;
			}
		}
		if (c.death_save_successes >= DEATH_SAVE_SUCCESSES_NEEDED) {
			c.is_stable = true;
		}
	}

	// Resolve an attack roll
	// Returns: {hit (0/1), natural_roll, total, is_crit (0/1)}
	int[] resolve_attack(combatant@ attacker, combatant@ target, int attack_bonus, bool has_advantage, bool has_disadvantage) {
		int[] result = {0, 0, 0, 0};
		if (@attacker == null or @target == null) return result;

		int roll1 = roll_d20();
		int roll2 = roll_d20();
		int natural_roll = roll1;

		if (has_advantage and !has_disadvantage) {
			natural_roll = roll1 > roll2 ? roll1 : roll2;
		} else if (has_disadvantage and !has_advantage) {
			natural_roll = roll1 < roll2 ? roll1 : roll2;
		}

		// 2024 Exhaustion penalty
		int exhaustion_penalty = attacker.exhaustion_level * 2;

		int total = natural_roll + attack_bonus - exhaustion_penalty;
		bool is_crit = natural_roll == 20;
		bool is_miss = natural_roll == 1;

		bool hit = false;
		if (is_crit) hit = true;
		else if (is_miss) hit = false;
		else hit = total >= target.armor_class;

		result[0] = hit ? 1 : 0;
		result[1] = natural_roll;
		result[2] = total;
		result[3] = is_crit ? 1 : 0;
		return result;
	}

	// Roll damage
	int resolve_damage(int dice_count, int dice_sides, int modifier, bool is_crit) {
		int total = 0;
		int rolls = is_crit ? dice_count * 2 : dice_count;
		for (int i = 0; i < rolls; i++) {
			total += random(1, dice_sides);
		}
		total += modifier;
		if (total < 1) total = 1;
		return total;
	}

	// Check if a combatant can see another (basic - not hidden, not invisible)
	bool can_see(combatant@ viewer, combatant@ target) {
		if (@viewer == null or @target == null) return false;
		if (viewer.has_condition(COND_BLINDED)) return false;
		bool has_truesight = viewer.has_feat("boon_of_truesight") and feet_distance(viewer.x, viewer.y, target.x, target.y) <= 60;
		// True Seeing spell grants Truesight 120ft
		if (!has_truesight and viewer.true_seeing_active and feet_distance(viewer.x, viewer.y, target.x, target.y) <= 120) has_truesight = true;
		// See Invisibility (Basic Rules 2024 para 14864): see Invisible creatures
		// and objects as if visible. No range limit.
		if (!has_truesight and viewer.see_invisibility_active) has_truesight = true;
		if (has_truesight) return true;
		if (target.has_condition(COND_INVISIBLE)) return false;
		if (target.is_hidden and are_hostile(viewer, target)) return false;
		return true;
	}

	bool are_hostile(combatant@ viewer, combatant@ target) {
		if (@viewer == null or @target == null or viewer.id == target.id) return false;
		if (mode == "pvp") return true;
		return viewer.is_player != target.is_player;
	}

	// Check if battle is over (all of one side dead)
	bool check_battle_over() {
		bool any_player_alive = false;
		bool any_monster_alive = false;
		for (uint i = 0; i < combatants.length(); i++) {
			if (combatants[i].is_alive()) {
				if (combatants[i].is_player) any_player_alive = true;
				else any_monster_alive = true;
			}
		}
		if (mode == "pvp") {
			// PvP: check if only 1 player alive
			int alive_count = 0;
			for (uint i = 0; i < combatants.length(); i++) {
				if (combatants[i].is_alive() and combatants[i].is_player) alive_count++;
			}
			return alive_count <= 1;
		}
		// PvE: all players dead or all monsters dead
		return !any_player_alive or !any_monster_alive;
	}

	// Get battle state as JSON for sending to clients
	json_object@ build_state_json(string viewer_username = "") {
		json_object@ state = json_object();
		state["type"] = message_types::game_state;
		state["round"] = round_number;
		state["turn_index"] = current_turn_index;
		state["battle_active"] = battle_active;
		state["mode"] = mode;
		state["wave"] = wave_number;

		json_array combatant_arr;
		for (uint i = 0; i < combatants.length(); i++) {
			combatant@ c = combatants[i];
			json_object cobj;
			cobj["id"] = c.id;
			cobj["name"] = c.name;
			cobj["is_player"] = c.is_player;
			cobj["x"] = c.x;
			cobj["y"] = c.y;
			cobj["hp"] = c.current_hp;
			cobj["max_hp"] = c.max_hp;
			cobj["ac"] = c.armor_class;
			cobj["level"] = c.level;
			cobj["class_name"] = c.class_name;
			cobj["subclass"] = c.subclass;
			cobj["is_dead"] = c.is_dead;
			cobj["is_stable"] = c.is_stable;
			cobj["initiative"] = c.initiative_roll;
			cobj["wild_shape_form"] = c.wild_shape_form_id;
			// Conditions
			json_array cond_arr;
			for (uint j = 0; j < c.conditions.length(); j++) {
				cond_arr.add(c.conditions[j]);
			}
			cobj["conditions"] = cond_arr;
			// Phase 1 sub-system fields for UI display and bonus action gating
			cobj["piety_god"] = c.piety_god;
			cobj["piety_score"] = c.piety_score;
			cobj["piety_devotee_uses"] = c.piety_devotee_uses;
			cobj["group_patron"] = c.group_patron;
			cobj["group_assistance_used_this_rest"] = c.group_assistance_used_this_rest;
			cobj["ravnica_guild"] = c.ravnica_guild;
			cobj["transformation"] = c.transformation;
			cobj["transformation_stage"] = c.transformation_stage;
			cobj["fey_court"] = c.fey_court;
			combatant_arr.add(cobj);
		}
		state["combatants"] = combatant_arr;

		// Initiative order
		json_array init_arr;
		for (uint i = 0; i < initiative_order.length(); i++) {
			init_arr.add(initiative_order[i]);
		}
		state["initiative_order"] = init_arr;

		if (viewer_username != "") {
			for (uint i = 0; i < combatants.length(); i++) {
				combatant@ c = combatants[i];
				if (!c.is_player or c.player_username != viewer_username) continue;
				state["my_focus_points"] = c.focus_points;
				state["my_focus_points_max"] = c.focus_points_max;
				state["my_uncanny_metabolism_available"] = c.uncanny_metabolism_available;
				state["my_superior_defense_active"] = c.superior_defense_active;
				state["my_superior_defense_rounds_remaining"] = c.superior_defense_rounds_remaining;
				state["my_empowered_strikes_active"] = c.empowered_strikes_active;
				state["my_empowered_strikes_force"] = c.empowered_strikes_force;
				state["my_lay_on_hands_pool"] = c.lay_on_hands_pool;
				state["my_bardic_inspiration_uses"] = c.bardic_inspiration_uses;
				state["my_bardic_inspiration_grant_die"] = c.bardic_inspiration_grant_die;
				state["my_bardic_inspiration_die"] = c.bardic_inspiration_die;
				state["my_font_of_inspiration_active"] = c.font_of_inspiration_active;
				state["my_countercharm_active"] = c.countercharm_active;
				state["my_magical_secrets_active"] = c.magical_secrets_active;
				state["my_superior_inspiration_active"] = c.superior_inspiration_active;
				state["my_words_of_creation_active"] = c.words_of_creation_active;
				state["my_rage_uses_remaining"] = c.rage_uses_remaining;
				state["my_rage_damage_bonus"] = c.rage_damage_bonus;
				state["my_is_raging"] = c.raging;
				state["my_action_surge_uses_remaining"] = c.action_surge_uses_remaining;
				state["my_second_wind_available"] = c.second_wind_available;
				state["my_second_wind_uses_remaining"] = c.second_wind_uses_remaining;
				state["my_second_wind_uses_max"] = c.second_wind_uses_max;
				state["my_is_hidden"] = c.is_hidden;
				state["my_weapon_range"] = c.main_hand_range;
				state["my_main_hand_mastery"] = c.main_hand_mastery;
				state["my_main_hand_is_light"] = c.main_hand_is_light;
				state["my_off_hand"] = c.off_hand;
				state["my_off_hand_is_light"] = c.off_hand_is_light;
				state["my_movement_remaining"] = c.movement_remaining;
				state["my_speed"] = c.speed;
				state["my_has_action"] = c.has_action;
				state["my_has_bonus_action"] = c.has_bonus_action;
				state["my_has_reaction"] = c.has_reaction;
				state["my_attacks_remaining"] = c.attacks_remaining_this_turn;
				state["my_spiritual_weapon_active"] = c.spiritual_weapon_active;
				state["my_heat_metal_active"] = c.heat_metal_active;
				state["my_call_lightning_active"] = c.call_lightning_active;
				state["my_swift_quiver_active"] = c.swift_quiver_active;
				state["my_flaming_sphere_active"] = c.flaming_sphere_active;
				state["my_conjure_woodland_disengage"] = c.conjure_woodland_disengage;
				state["my_expeditious_retreat_active"] = c.expeditious_retreat_active;
				state["my_luck_points"] = c.luck_points;
				state["my_luck_points_max"] = c.luck_points_max;
				state["my_has_heroic_inspiration"] = c.has_heroic_inspiration;
				// Subclass state
				state["my_superiority_dice"] = c.superiority_dice;
				state["my_superiority_dice_max"] = c.superiority_dice_max;
				state["my_psionic_strike_uses"] = c.psionic_strike_uses;
				state["my_assassinate_available"] = c.assassinate_available;
				state["my_warding_flare_uses"] = c.warding_flare_uses;
				state["my_war_priest_uses"] = c.war_priest_uses;
				state["my_sacred_weapon_active"] = c.sacred_weapon_active;
				state["my_vow_of_enmity_target"] = c.vow_of_enmity_target;
				state["my_healing_light_dice"] = c.healing_light_dice;
				state["my_channel_divinity_uses"] = c.channel_divinity_uses;
				state["my_arcane_ward_hp"] = c.arcane_ward_hp;
				state["my_arcane_ward_max"] = c.arcane_ward_max;
				state["my_portent_roll_1"] = c.portent_roll_1;
				state["my_portent_roll_2"] = c.portent_roll_2;
				state["my_portent_1_used"] = c.portent_1_used;
				state["my_portent_2_used"] = c.portent_2_used;
				state["my_fey_presence_used"] = c.fey_presence_used;
				state["my_dread_ambusher_used"] = c.dread_ambusher_used;
				// PHB 2024 Ranger L10 Tireless / L14 Nature's Veil — broadcast use counts
				state["my_natures_veil_uses_remaining"] = c.natures_veil_uses_remaining;
				state["my_tireless_temp_hp_uses_remaining"] = c.tireless_temp_hp_uses_remaining;
				// PHB 2024 Sorcerer L1 Innate Sorcery / L2 Font of Magic
				state["my_innate_sorcery_uses_remaining"] = c.innate_sorcery_uses_remaining;
				state["my_innate_sorcery_active"] = c.innate_sorcery_active;
				state["my_sorcery_points"] = c.sorcery_points;
				state["my_sorcery_points_max"] = c.sorcery_points_max;
				// PHB 2024 Sorcerer L2 Metamagic: send known options for client menu filtering
				if (c.metamagic_choices.length() > 0) {
					json_array mc_arr;
					for (uint mci = 0; mci < c.metamagic_choices.length(); mci++) mc_arr.add(c.metamagic_choices[mci]);
					state["my_metamagic_choices"] = mc_arr;
				}
				// PHB 2024 Warlock L2 Magical Cunning / L9 Contact Patron / L11+ Mystic Arcanum
				state["my_magical_cunning_available"] = c.magical_cunning_available;
				state["my_contact_patron_available"] = c.contact_patron_available;
				state["my_mystic_arcanum_6_available"] = c.mystic_arcanum_6_available;
				state["my_mystic_arcanum_7_available"] = c.mystic_arcanum_7_available;
				state["my_mystic_arcanum_8_available"] = c.mystic_arcanum_8_available;
				state["my_mystic_arcanum_9_available"] = c.mystic_arcanum_9_available;
				// PHB 2024 Wizard L18 Spell Mastery / L20 Signature Spells
				state["my_spell_mastery_active"] = c.spell_mastery_active;
				state["my_spell_mastery_l1_spell_id"] = c.spell_mastery_l1_spell_id;
				state["my_spell_mastery_l2_spell_id"] = c.spell_mastery_l2_spell_id;
				state["my_signature_spells_charges_remaining"] = c.signature_spells_charges_remaining;
				state["my_signature_spells_charges_max"] = c.signature_spells_charges_max;
				state["my_signature_spell_a_id"] = c.signature_spell_a_id;
				state["my_signature_spell_b_id"] = c.signature_spell_b_id;
				// PHB 2024 Forge Artificer L1 Tinker's Magic / L7 Flash of Genius / L10/14/18 attunement / L20 Magical Guidance
				state["my_tinkers_magic_uses_current"] = c.tinkers_magic_uses_current;
				state["my_tinkers_magic_uses_max"] = c.tinkers_magic_uses_max;
				state["my_flash_of_genius_uses_current"] = c.flash_of_genius_uses_current;
				state["my_flash_of_genius_uses_max"] = c.flash_of_genius_uses_max;
				state["my_magic_item_attunement_max"] = c.magic_item_attunement_max;
				state["my_magical_guidance_active"] = c.magical_guidance_active;
				// Valda's Spire of Secrets Gunslinger (paras 159-203)
				state["my_risk_dice_current"] = c.risk_dice_current;
				state["my_risk_dice_max"] = c.risk_dice_max;
				state["my_risk_die_size"] = c.risk_die_size;
				state["my_gunslinger_crit_threshold"] = c.gunslinger_crit_threshold;
				state["my_overkill_active"] = c.overkill_active;
				state["my_dire_gambit_active"] = c.dire_gambit_active;
				state["my_deft_maneuver_active"] = c.deft_maneuver_active;
				state["my_headshot_active"] = c.headshot_active;
				state["my_headshot_used"] = c.headshot_used;
				state["my_cheat_death_used"] = c.cheat_death_used;
				// PHB 2024 Sorcerer Draconic Sorcery L6/L14/L18 + Wizard Evoker L3/L10/L14
				state["my_elemental_affinity_type"] = c.elemental_affinity_type;
				state["my_dragon_wings_active"] = c.dragon_wings_active;
				state["my_dragon_wings_used_this_rest"] = c.dragon_wings_used_this_rest;
				state["my_dragon_companion_used_this_rest"] = c.dragon_companion_used_this_rest;
				state["my_potent_cantrip_active"] = c.potent_cantrip_active;
				state["my_empowered_evocation_active"] = c.empowered_evocation_active;
				state["my_overchannel_pending"] = c.overchannel_pending;
				state["my_overchannel_uses_this_rest"] = c.overchannel_uses_this_rest;
				// Xanathar's Storm Sorcery + Divine Soul
				state["my_heart_of_the_storm_active"] = c.heart_of_the_storm_active;
				state["my_storms_fury_active"] = c.storms_fury_active;
				state["my_wind_soul_active"] = c.wind_soul_active;
				state["my_favored_by_gods_available"] = c.favored_by_gods_available;
				state["my_divine_soul_affinity"] = c.divine_soul_affinity;
				state["my_otherworldly_wings_active"] = c.otherworldly_wings_active;
				state["my_unearthly_recovery_available"] = c.unearthly_recovery_available;
				// PHB 2024 Boon of Dimensional Travel (para 7876)
				state["my_blink_steps_available"] = c.blink_steps_available;
				// PHB 2024 Elemental Adept type (para 7610)
				string ea_str = "";
				if (c.elemental_adept_acid) ea_str = "acid";
				else if (c.elemental_adept_cold) ea_str = "cold";
				else if (c.elemental_adept_fire) ea_str = "fire";
				else if (c.elemental_adept_lightning) ea_str = "lightning";
				else if (c.elemental_adept_thunder) ea_str = "thunder";
				state["my_elemental_adept_type"] = ea_str;
				// PHB 2024 Epic Boon state
				state["my_boon_of_recovery_used"] = c.boon_of_recovery_used;
				state["my_boon_of_fate_used"] = c.boon_of_fate_used;
				state["my_boon_of_spell_recall_used"] = c.boon_of_spell_recall_used;
				// Xanathar's Shadow Magic (paras 2557-2607)
				state["my_shadow_walk_available"] = c.shadow_walk_available;
				state["my_shadow_umbral_active"] = c.shadow_umbral_active;
				state["my_shadow_umbral_rounds"] = c.shadow_umbral_rounds;
				state["my_strength_of_the_grave_used"] = c.strength_of_the_grave_used;
				// Tasha's Aberrant Mind (paras 3894-3952)
				state["my_psionic_defenses_active"] = c.psionic_defenses_active;
				state["my_revelation_in_flesh_active"] = c.revelation_in_flesh_active;
				state["my_revelation_in_flesh_rounds"] = c.revelation_in_flesh_rounds;
				state["my_warping_implosion_available"] = c.warping_implosion_available;
				// Tasha's Clockwork Soul (paras 3953-4011)
				state["my_bastion_of_law_dice"] = c.bastion_of_law_dice;
				state["my_trance_of_order_active"] = c.trance_of_order_active;
				state["my_trance_of_order_rounds"] = c.trance_of_order_rounds;
				state["my_trance_of_order_used"] = c.trance_of_order_used;
				state["my_clockwork_cavalcade_available"] = c.clockwork_cavalcade_available;
				// Xanathar's War Magic (paras 2915-2944)
				state["my_tactical_wit_active"] = c.tactical_wit_active;
				state["my_power_surge_charges"] = c.power_surge_charges;
				state["my_power_surge_max"] = c.power_surge_max;
				state["my_durable_magic_active"] = c.durable_magic_active;
				state["my_deflecting_shroud_active"] = c.deflecting_shroud_active;
				// Xanathar's Grave Domain (paras 756-803)
				state["my_sentinel_at_death_uses"] = c.sentinel_at_death_uses;
				state["my_keeper_of_souls_active"] = c.keeper_of_souls_active;
				// Xanathar's Hexblade (paras 2748-2795)
				state["my_hexblade_curse_used"] = c.hexblade_curse_used;
				state["my_armor_of_hexes_active"] = c.armor_of_hexes_active;
				state["my_master_of_hexes_active"] = c.master_of_hexes_active;
				// Xanathar's Cavalier Fighter (paras 1669-1682)
				state["my_cavalier_retaliation_available"] = c.cavalier_retaliation_available;
				state["my_unwavering_mark_ba_uses"] = c.unwavering_mark_ba_uses;
				state["my_unwavering_mark_ba_uses_max"] = c.unwavering_mark_ba_uses_max;
				state["my_warding_maneuver_uses"] = c.warding_maneuver_uses;
				state["my_warding_maneuver_uses_max"] = c.warding_maneuver_uses_max;
				state["my_hold_the_line_active"] = c.hold_the_line_active;
				state["my_vigilant_defender_active"] = c.vigilant_defender_active;
				// Xanathar's Oath of Conquest Paladin (paras 1992-2003)
				state["my_scornful_rebuke_active"] = c.scornful_rebuke_active;
				state["my_aura_of_conquest_active"] = c.aura_of_conquest_active;
				state["my_invincible_conqueror_active"] = c.invincible_conqueror_active;
				// Xanathar's Gloom Stalker Ranger (paras 2130-2163)
				state["my_stalkers_flurry_active"] = c.stalkers_flurry_active;
				state["my_shadowy_dodge_active"] = c.shadowy_dodge_active;
				// Xanathar's Monk Subclasses (paras 1780-1865)
				state["my_drunken_technique_active"] = c.drunken_technique_active;
				state["my_kenseis_shot_active"] = c.kenseis_shot_active;
				state["my_deft_strike_active"] = c.deft_strike_active;
				state["my_sharpen_the_blade_bonus"] = c.sharpen_the_blade_bonus;
				state["my_unerring_accuracy_active"] = c.unerring_accuracy_active;
				state["my_sun_shield_active"] = c.sun_shield_active;
				// Horizon Walker / Monster Slayer / Oath of Redemption (Xanathar's)
				state["my_spectral_defense_active"] = c.spectral_defense_active;
				state["my_supernatural_defense_active"] = c.supernatural_defense_active;
				state["my_slayers_counter_active"] = c.slayers_counter_active;
				state["my_aura_of_guardian_active"] = c.aura_of_guardian_active;
				state["my_protective_spirit_active"] = c.protective_spirit_active;
				state["my_emissary_of_redemption_active"] = c.emissary_of_redemption_active;
				// Potion buff rounds remaining
				state["my_potion_damage_rounds"] = c.potion_damage_rounds;
				state["my_potion_ac_rounds"] = c.potion_ac_rounds;
				state["my_potion_speed_rounds"] = c.potion_speed_rounds;
				state["my_potion_spell_dc_rounds"] = c.potion_spell_dc_rounds;
				break;
			}
		}

		return state;
	}
}
