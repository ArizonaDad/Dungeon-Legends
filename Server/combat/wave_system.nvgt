#include "combat_engine.nvgt"
#include "monster_data.nvgt"

class wave_encounter {
    int wave_number;
    string[] monster_ids;
    int[] monster_counts;
}

class wave_scenario {
    string id;
    string name;
    string description;
    int recommended_level;
    int recommended_players;
    wave_encounter@[] waves;
}

wave_scenario@[] WAVE_SCENARIOS;

