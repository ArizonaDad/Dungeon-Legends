wave_scenario@ get_scenario(string id) {
    for (uint i = 0; i < WAVE_SCENARIOS.length(); i++) {
        if (WAVE_SCENARIOS[i].id == id) return WAVE_SCENARIOS[i];
    }
    return null;
}

// Spawn all monsters for a specific wave into a battle.
// hp_multiplier and damage_multiplier scale monster stats for difficulty modes.
void spawn_wave(battle@ b, wave_encounter@ wave, int map_width, float hp_multiplier = 1.0, float damage_multiplier = 1.0) {
    if (@b == null or @wave == null) return;
    int spawn_y = map_width - 2; // Spawn near top of map
    int spawn_x = 2;
    for (uint i = 0; i < wave.monster_ids.length(); i++) {
        monster_def@ def = get_monster_def(wave.monster_ids[i]);
        if (@def == null) continue;
        combatant@ c = create_monster_combatant(def, spawn_x, spawn_y);
        if (@c != null) {
            // Apply difficulty multipliers
            if (hp_multiplier != 1.0) {
                c.max_hp = int(float(c.max_hp) * hp_multiplier);
                c.current_hp = c.max_hp;
            }
            if (damage_multiplier != 1.0) {
                c.monster_attack_damage_mod = int(float(c.monster_attack_damage_mod) * damage_multiplier);
                if (c.monster_attack2_mod > 0) {
                    c.monster_attack2_mod = int(float(c.monster_attack2_mod) * damage_multiplier);
                }
            }
            b.add_combatant(c);
        }
        spawn_x += 3; // Space them out
        if (spawn_x >= map_width - 2) {
            spawn_x = 2;
            spawn_y -= 2;
        }
    }
}
