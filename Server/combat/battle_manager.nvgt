					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Fire Storm", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_FIRE, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "prismatic_spray") {
				// Basic Rules: DEX save, 10d6 damage of random type per target in 60 ft cone.
				broadcast_announce(c.name + " unleashes a Prismatic Spray of eight colors!", true);
				int[] prism_types = { DMG_FIRE, DMG_ACID, DMG_LIGHTNING, DMG_POISON, DMG_COLD, DMG_FORCE, DMG_RADIANT, DMG_NECROTIC };
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 60) continue;
					int ray_dmg = 0;
					for (int d = 0; d < 10; d++) ray_dmg += random(1, 6);
					int dtype = prism_types[random(0, 7)];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? ray_dmg / 2 : ray_dmg;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Prismatic Spray", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, dtype, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "conjure_celestial") {
				// Basic Rules: summon a celestial companion.
				int cel_hp = 40 + (5 * c.level);
				int cha_mod = c.get_ability_mod(ABILITY_CHA);
				int cel_attack = c.proficiency + get_spellcasting_ability_mod(c);
				combatant@ cel = spawn_companion(c, "conjure_celestial", c.name + "'s Celestial", cel_hp, 15 + c.proficiency, 40, cel_attack, 2, 10, cha_mod, DMG_RADIANT, 0);
				if (@cel != null) {
					broadcast_announce(c.name + " summons a radiant Celestial! HP " + cel_hp + ", AC " + (15 + c.proficiency) + ", 2d10+CHA radiant.", true);
				}
			}
			else if (spell.id == "regenerate" and @target != null) {
				// Basic Rules: heal 4d8 + 15, then 1 HP/round for 1 hour. Simplified: instant 4d8 + 15.
				int heal = 15;
				// Basic Rules 2024 Beacon of Hope (para 12201): max healing
				if (target.beacon_of_hope_active) {
					heal += 4 * 8; // 4d8 maximized = 32
				} else {
					for (int d = 0; d < 4; d++) heal += random(1, 8);
				}
				heal += get_life_domain_healing_bonus(c, spell, cast_slot_level);
				int effective = combat.apply_healing(target, heal);
				record_effective_healing(c.player_username, effective);
				broadcast_announce(c.name + " casts Regenerate on " + target.name + ", restoring " + heal + " HP.", true);
			}
			else if (spell.id == "symbol") {
				// Basic Rules: triggered glyph, simplified as 10d10 necrotic in 60 ft sphere AoE.
				int dice_count = 10;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
