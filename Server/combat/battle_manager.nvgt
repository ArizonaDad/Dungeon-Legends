				// Save failure chain
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "CON save vs Harm"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "CON save vs Harm"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				broadcast_roll(target.name, "CON save vs Harm", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
				combat.apply_damage(target, dmg, DMG_NECROTIC, c);
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "blade_barrier") {
				// Basic Rules: DEX save, 6d10 slashing in wall area. Simplified as AoE around target.
				int dice_count = 6;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				broadcast_announce(c.name + " conjures a Blade Barrier of whirling blades!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 10) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Blade Barrier"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Blade Barrier"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Blade Barrier", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_SLASHING, c);
				}
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "otilukes_freezing_sphere") {
				// Basic Rules: CON save, 10d6 cold in 60 ft radius. Upcast +3d6 per level.
				int dice_count = 10 + (upcast_levels * 3);
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " hurls Otiluke's Freezing Sphere!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 60) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Freezing Sphere", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_COLD, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "fire_storm") {
				// Basic Rules: DEX save, 7d10 fire in ten 10 ft cubes. Simplified: 20 ft radius AoE.
				int dice_count = 7;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				broadcast_announce(c.name + " unleashes a Fire Storm!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
