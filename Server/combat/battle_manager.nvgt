					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Symbol", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_NECROTIC, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "incendiary_cloud") {
				// Basic Rules: DEX save, 10d8 fire in 20 ft radius cloud.
				int dice_count = 10;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				broadcast_announce(c.name + " conjures an Incendiary Cloud!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Incendiary Cloud", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_FIRE, c);
				}
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "storm_of_vengeance") {
				// Basic Rules: DEX save, 2d6 thunder + lightning in 360 ft radius AoE.
				int thunder_dice = 2;
				int lightning_dice = 4;
				int thunder_total = 0;
				int lightning_total = 0;
				for (int d = 0; d < thunder_dice; d++) thunder_total += random(1, 6);
				for (int d = 0; d < lightning_dice; d++) lightning_total += random(1, 10);
				broadcast_announce(c.name + " summons a Storm of Vengeance! The sky erupts with thunder and lightning!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 360) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int td = saved ? thunder_total / 2 : thunder_total;
					int ld = saved ? lightning_total / 2 : lightning_total;
					if (td < 1) td = 1;
					if (ld < 1) ld = 1;
					broadcast_roll(t.name, "DEX save vs Storm of Vengeance", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, td, DMG_THUNDER, c);
					combat.apply_damage(t, ld, DMG_LIGHTNING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "weird") {
				// Basic Rules: WIS save, 4d10 psychic on each target in 30 ft radius + frightened.
				int dice_count = 4;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				broadcast_announce(c.name + " conjures phantasmal horrors with Weird!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 30) continue;
					int dmg = 0;
					for (int d = 0; d < dice_count; d++) dmg += random(1, 10);
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					if (t.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					broadcast_roll(t.name, "WIS save vs Weird", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Terrified!");
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved and try_countercharm_reroll(t, save_dc, save_bonus + bless_bonus, "WIS save vs Weird")) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Weird"); if (ds >= save_dc) saved = true; }
					if (!saved) { int new_total = try_flash_of_genius(t, save_dc, save_total, "WIS save vs Weird"); if (new_total >= save_dc) saved = true; }
				if (!saved) { int ms_total = try_maverick_spirit(t, save_dc, save_total, "WIS save vs Weird"); if (ms_total >= save_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf > 0) saved = true; }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					if (!saved) {
						combat.apply_damage(t, dmg, DMG_PSYCHIC, c);
						t.add_condition(COND_FRIGHTENED);
						t.frightened_source_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Frightened"}});
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "prismatic_wall") {
				// Basic Rules: DEX save, creatures nearby take multi-type damage from the wall.
				broadcast_announce(c.name + " conjures a shimmering Prismatic Wall!", true);
				int[] pw_types = { DMG_FIRE, DMG_COLD, DMG_LIGHTNING, DMG_POISON, DMG_ACID };
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 10) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (DEX — multi-type damage)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Prismatic Wall"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Prismatic Wall"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "DEX save vs Prismatic Wall", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					for (uint pi = 0; pi < pw_types.length(); pi++) {
						int layer_dmg = 0;
						for (int d = 0; d < 2; d++) layer_dmg += random(1, 10);
						int dmg = saved ? layer_dmg / 2 : layer_dmg;
						if (dmg < 1) dmg = 1;
						combat.apply_damage(t, dmg, pw_types[pi], c);
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else {
				broadcast_announce(c.name + " casts " + spell.name + ".", false);
			}
		}

		broadcast_state();
		check_battle_end();
	}

	// ---- Scanning and Targeting ----

	void handle_scan(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = null;
		// Find this player's combatant.
		for (uint i = 0; i < combat.combatants.length(); i++) {
			if (combat.combatants[i].is_player and combat.combatants[i].player_username == u.username) {
				@c = combat.combatants[i];
				break;
			}
		}
		if (@c == null) return;

		string direction = "north";
		if (msg.exists("direction")) direction = string(msg["direction"]);
		else if (msg.exists("dir")) direction = string(msg["dir"]);

		// Find creatures in the specified direction.
		json_array results;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ other = combat.combatants[i];
			if (@other == @c or other.is_dead) continue;

			bool matches = false;
			if (direction == "north" and other.y > c.y) matches = true;
			else if (direction == "south" and other.y < c.y) matches = true;
			else if (direction == "east" and other.x > c.x) matches = true;
			else if (direction == "west" and other.x < c.x) matches = true;

			if (matches) {
				if (!combat.can_see(c, other)) continue;
				int dist = feet_distance(c.x, c.y, other.x, other.y);
				json_object entry;
				entry["id"] = other.id;
				entry["name"] = other.name;
				entry["distance"] = dist;
				entry["is_player"] = other.is_player;
				entry["hp"] = other.current_hp;
				entry["max_hp"] = other.max_hp;
				results.add(entry);
			}
		}

		u.send({{"type", message_types::scan_result}, {"direction", direction}, {"results", results}});
	}

	void handle_set_target(user@ u, json_object@ msg) {
		if (@combat == null or @u == null or !msg.exists("target_id")) return;
		uint target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null) { u.send({{"type", message_types::error}, {"text", "Invalid target."}}); return; }

		combatant@ viewer = null;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			if (combat.combatants[i].is_player and combat.combatants[i].player_username == u.username) {
				@viewer = combat.combatants[i];
				break;
			}
		}
		if (@viewer == null) return;
		if (!combat.can_see(viewer, target)) {
			u.send({{"type", message_types::error}, {"text", "You cannot currently see that target."}});
			return;
		}

		// Send target info back to the player.
		json_object info;
		info["type"] = message_types::target_info;
		info["id"] = target.id;
		info["name"] = target.name;
		info["hp"] = target.current_hp;
		info["max_hp"] = target.max_hp;
		info["ac"] = target.armor_class;
		info["is_player"] = target.is_player;

		// Find player's combatant for distance calculation.
		info["distance"] = feet_distance(viewer.x, viewer.y, target.x, target.y);
		info["direction"] = relative_direction_text(viewer.x, viewer.y, target.x, target.y);

		json_array cond_arr;
		for (uint i = 0; i < target.conditions.length(); i++) {
			if (target.conditions[i] >= 0 and target.conditions[i] < int(CONDITION_NAMES.length()))
				cond_arr.add(CONDITION_NAMES[target.conditions[i]]);
		}
		info["conditions"] = cond_arr;
		u.send(info);
	}

	// ---- Monster AI Tick (fallback safety net) ----

	void tick() {
		if (@combat == null or !combat.battle_active) return;
		if (players.length() == 0) return; // No players left, don't tick

		// Delayed initiative start - gives clients time to enter combat loop
		if (initiative_delay_until > 0) {
			if (ticks() >= initiative_delay_until) {
				initiative_delay_until = 0;
				request_next_initiative();
			}
			return;
		}

		// Don't advance turns while initiative rolls are in progress
		if (initiative_phase) return;

		if (@current_roll != null) return;

		combatant@ c = combat.current_combatant();
		if (@c == null or c.is_dead) {
			monster_turn_start_time = 0;
			advance_turn();
			return;
		}
		if (c.is_player) {
			if (combatant_is_controlled_by_bot(c)) execute_player_bot_turn(c);
			return;
		}

		if (monster_turn_start_time > 0 and ticks() - monster_turn_start_time > 10000) {
			broadcast_announce(c.name + " ends its turn.");
			monster_turn_start_time = 0;
			advance_turn();
			return;
		}

		if (!c.has_action and c.movement_remaining < FEET_PER_TILE) {
			broadcast_announce(c.name + " ends its turn.");
			monster_turn_start_time = 0;
			advance_turn();
			return;
		}

		execute_monster_turn(c);
	}

	// ---- Battle End (legacy wrapper) ----

	void end_battle() {
		check_battle_end();
	}

	// ---- Post-Battle Cleanup ----

	void cleanup_after_battle() {
		// Find the room that owns this battle and reset it.
		for (uint pi = 0; pi < players.length(); pi++) {
			if (@players[pi] != null and @players[pi].room != null) {
				players[pi].room.started = false;
				break;
			}
		}
		reset_progression_tracking();
	}
}
