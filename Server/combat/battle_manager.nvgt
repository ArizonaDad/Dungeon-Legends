			else if (spell.id == "prismatic_wall") {
				// Basic Rules: DEX save, creatures nearby take multi-type damage from the wall.
				broadcast_announce(c.name + " conjures a shimmering Prismatic Wall!", true);
				int[] pw_types = { DMG_FIRE, DMG_COLD, DMG_LIGHTNING, DMG_POISON, DMG_ACID };
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 10) continue;
					int save_roll = random(1, 20);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					broadcast_roll(t.name, "DEX save vs Prismatic Wall", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					for (uint pi = 0; pi < pw_types.length(); pi++) {
						int layer_dmg = 0;
						for (int d = 0; d < 2; d++) layer_dmg += random(1, 10);
						int dmg = saved ? layer_dmg / 2 : layer_dmg;
						if (dmg < 1) dmg = 1;
						combat.apply_damage(t, dmg, pw_types[pi], c);
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else {
				broadcast_announce(c.name + " casts " + spell.name + ".", false);
			}
		}

		broadcast_state();
		check_battle_end();
	}

	// ---- Scanning and Targeting ----

	void handle_scan(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = null;
		// Find this player's combatant.
		for (uint i = 0; i < combat.combatants.length(); i++) {
			if (combat.combatants[i].is_player and combat.combatants[i].player_username == u.username) {
				@c = combat.combatants[i];
				break;
			}
		}
		if (@c == null) return;

		string direction = "north";
		if (msg.exists("direction")) direction = string(msg["direction"]);
		else if (msg.exists("dir")) direction = string(msg["dir"]);

		// Find creatures in the specified direction.
		json_array results;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ other = combat.combatants[i];
			if (@other == @c or other.is_dead) continue;

			bool matches = false;
			if (direction == "north" and other.y > c.y) matches = true;
			else if (direction == "south" and other.y < c.y) matches = true;
			else if (direction == "east" and other.x > c.x) matches = true;
			else if (direction == "west" and other.x < c.x) matches = true;

			if (matches) {
				if (!combat.can_see(c, other)) continue;
				int dist = feet_distance(c.x, c.y, other.x, other.y);
				json_object entry;
				entry["id"] = other.id;
				entry["name"] = other.name;
				entry["distance"] = dist;
				entry["is_player"] = other.is_player;
				entry["hp"] = other.current_hp;
				entry["max_hp"] = other.max_hp;
				results.add(entry);
			}
		}

		u.send({{"type", message_types::scan_result}, {"direction", direction}, {"results", results}});
	}

	void handle_set_target(user@ u, json_object@ msg) {
		if (@combat == null or @u == null or !msg.exists("target_id")) return;
		uint target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null) { u.send({{"type", message_types::error}, {"text", "Invalid target."}}); return; }

		combatant@ viewer = null;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			if (combat.combatants[i].is_player and combat.combatants[i].player_username == u.username) {
				@viewer = combat.combatants[i];
				break;
			}
		}
		if (@viewer == null) return;
		if (!combat.can_see(viewer, target)) {
			u.send({{"type", message_types::error}, {"text", "You cannot currently see that target."}});
			return;
		}

		// Send target info back to the player.
		json_object info;
		info["type"] = message_types::target_info;
		info["id"] = target.id;
		info["name"] = target.name;
		info["hp"] = target.current_hp;
		info["max_hp"] = target.max_hp;
		info["ac"] = target.armor_class;
		info["is_player"] = target.is_player;

		// Find player's combatant for distance calculation.
		info["distance"] = feet_distance(viewer.x, viewer.y, target.x, target.y);
		info["direction"] = relative_direction_text(viewer.x, viewer.y, target.x, target.y);

		json_array cond_arr;
		for (uint i = 0; i < target.conditions.length(); i++) {
			if (target.conditions[i] >= 0 and target.conditions[i] < int(CONDITION_NAMES.length()))
				cond_arr.add(CONDITION_NAMES[target.conditions[i]]);
		}
		info["conditions"] = cond_arr;
		u.send(info);
	}

	// ---- Monster AI Tick (fallback safety net) ----

	void tick() {
		if (@combat == null or !combat.battle_active) return;
		if (players.length() == 0) return; // No players left, don't tick

		// Delayed initiative start - gives clients time to enter combat loop
		if (initiative_delay_until > 0) {
			if (ticks() >= initiative_delay_until) {
				initiative_delay_until = 0;
				request_next_initiative();
			}
			return;
		}

		// Don't advance turns while initiative rolls are in progress
		if (initiative_phase) return;

		if (@current_roll != null) return;

		combatant@ c = combat.current_combatant();
		if (@c == null or c.is_dead) {
			monster_turn_start_time = 0;
			advance_turn();
			return;
		}
		if (c.is_player) {
			if (combatant_is_controlled_by_bot(c)) execute_player_bot_turn(c);
			return;
		}

		if (monster_turn_start_time > 0 and ticks() - monster_turn_start_time > 10000) {
			broadcast_announce(c.name + " ends its turn.");
			monster_turn_start_time = 0;
			advance_turn();
			return;
		}

		if (!c.has_action and c.movement_remaining < FEET_PER_TILE) {
			broadcast_announce(c.name + " ends its turn.");
			monster_turn_start_time = 0;
			advance_turn();
			return;
		}

		execute_monster_turn(c);
	}

	// ---- Battle End (legacy wrapper) ----

	void end_battle() {
		check_battle_end();
	}

	// ---- Post-Battle Cleanup ----

	void cleanup_after_battle() {
		// Find the room that owns this battle and reset it.
		for (uint pi = 0; pi < players.length(); pi++) {
			if (@players[pi] != null and @players[pi].room != null) {
				players[pi].room.started = false;
				break;
			}
		}
		reset_progression_tracking();
	}
}
