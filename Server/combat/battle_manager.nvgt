			else if (spell.id == "prismatic_spray") {
				// Basic Rules: DEX save, 10d6 damage of random type per target in 60 ft cone.
				broadcast_announce(c.name + " unleashes a Prismatic Spray of eight colors!", true);
				int[] prism_types = { DMG_FIRE, DMG_ACID, DMG_LIGHTNING, DMG_POISON, DMG_COLD, DMG_FORCE, DMG_RADIANT, DMG_NECROTIC };
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 60) continue;
					int ray_dmg = 0;
