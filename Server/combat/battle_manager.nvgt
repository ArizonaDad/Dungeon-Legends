				broadcast_announce(c.name + " casts Contingency, storing a spell for later automatic activation.", true);
			}
			else if (spell.id == "create_undead") {
				int undead_hp = 30 + (3 * c.level);
				int spell_mod_local = get_spellcasting_ability_mod(c);
				int undead_attack = c.proficiency + spell_mod_local;
				combatant@ undead = spawn_companion(c, "create_undead", c.name + "'s Ghoul", undead_hp, 12 + c.proficiency, 30, undead_attack, 2, 6, spell_mod_local, DMG_PIERCING, 1);
				if (@undead != null) {
