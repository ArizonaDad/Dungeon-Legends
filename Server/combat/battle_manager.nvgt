			else if (spell.id == "conjure_celestial") {
				// Basic Rules: summon a celestial companion.
				int cel_hp = 40 + (5 * c.level);
				int cha_mod = c.get_ability_mod(ABILITY_CHA);
				int cel_attack = c.proficiency + get_spellcasting_ability_mod(c);
				combatant@ cel = spawn_companion(c, "conjure_celestial", c.name + "'s Celestial", cel_hp, 15 + c.proficiency, 40, cel_attack, 2, 10, cha_mod, DMG_RADIANT, 0);
				if (@cel != null) {
					broadcast_announce(c.name + " summons a radiant Celestial! HP " + cel_hp + ", AC " + (15 + c.proficiency) + ", 2d10+CHA radiant.", true);
				}
			}
			else if (spell.id == "regenerate" and @target != null) {
				// Basic Rules: heal 4d8 + 15, then 1 HP/round for 1 hour. Simplified: instant 4d8 + 15.
				int heal = 15;
				for (int d = 0; d < 4; d++) heal += random(1, 8);
				heal += get_life_domain_healing_bonus(c, spell, cast_slot_level);
				int effective = combat.apply_healing(target, heal);
				record_effective_healing(c.player_username, effective);
				broadcast_announce(c.name + " casts Regenerate on " + target.name + ", restoring " + heal + " HP.", true);
			}
