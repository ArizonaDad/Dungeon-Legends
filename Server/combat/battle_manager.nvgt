// D&D 5e Battle Manager - Server Side
// Wires the combat engine into the server framework.
// Handles all combat message routing, roll requests, broadcasting, and monster AI.

#include "combat_engine.nvgt"
#include "character_data.nvgt"
#include "monster_data.nvgt"
#include "wave_system.nvgt"
#include "../../common/consumable_data.nvgt"

// Pending roll context stored between request and result.
class pending_roll {
	uint combatant_id;
	string player_username;
	int roll_type;           // ROLL_INITIATIVE, ROLL_ATTACK, etc.
	int dice_sides = 20;
	int modifier = 0;
	string reason = "";
	int dc = 0;
	string resolution_tag = "";
	int ability_id = -1;     // Ability used by this check (for Indomitable Might, Primal Knowledge, etc.)
	// Attack context (used when roll_type == ROLL_ATTACK or ROLL_DAMAGE)
	uint target_id = 0;
	int attack_bonus = 0;
	bool has_advantage = false;
	bool has_disadvantage = false;
	string attack_name = "";
	int attack_index = 0;
	// Damage context (used when chaining attack -> damage)
	int damage_dice_count = 0;
	int damage_dice_sides = 0;
	int damage_modifier = 0;
	int damage_type = DMG_SLASHING;
	int extra_damage_dice_count = 0;
	int extra_damage_dice_sides = 0;
	int extra_damage_modifier = 0;
	int extra_damage_type = -1;
	bool is_weapon_attack = false;
	bool is_crit = false;
	bool is_spell_effect = false;
	bool spell_uses_attack_roll = false;
	bool spell_requires_save = false;
	string spell_id = "";
	string spell_name = "";
	int spell_save_type = -1;
	int spell_save_dc = 0;
	bool spell_is_aoe = false;
	int spell_aoe_radius = 0;
	// Extra Attack tracking
	int attacks_remaining = 0;
	bool resume_turn_start = false;
	int rolls_completed = 0;
	int accumulated_natural = 0;
	int first_natural = 0;
	int savage_attacker_first_total = 0;
	bool savage_attacker_reroll = false;
	// Tasha's College of Eloquence Unfailing/Infectious Inspiration tracking
	uint bardic_source_id = 0; // Who gave the Bardic Inspiration die
	int bardic_die_used = 0;   // Die size consumed (0 = none)
	// Distribution chain: comma-separated list of remaining target IDs for spells like
	// Scorching Ray and Eldritch Blast where each ray/beam may target a different creature.
	// Consumed front-to-back by start_followup_spell_attack.
	string next_target_ids_csv = "";
	// Metamagic flags (snapshot at cast time so they persist through the roll pipeline)
	bool metamagic_careful = false;   // Allies auto-succeed saves
	bool metamagic_heightened = false; // Target has disadvantage on saves
	bool metamagic_empowered = false;  // Reroll CHA mod damage dice
	bool metamagic_seeking = false;    // Reroll missed spell attack
	bool metamagic_extended = false;   // Double duration, adv on concentration saves
	bool metamagic_transmuted = false; // Swap damage type
	int metamagic_transmuted_type = 0; // Target damage type
	// Twinned Spell: ID of the second target for save-based damage spells
	uint twinned_target_id = 0;
}

class pending_bardic_prompt {
	string player_username;
	pending_roll@ roll;
	int natural_roll = 0;
	int bless_bonus = 0;
	int failure_margin = 0;
	int die_size = 0;
}

class pending_lucky_prompt {
	string player_username;
	pending_roll@ roll;
	int natural_roll = 0;
	int bless_bonus = 0;
	int bardic_bonus = 0;
}

class pending_heroic_prompt {
	string player_username;
	pending_roll@ roll;
	int natural_roll = 0;
	int bless_bonus = 0;
	int bardic_bonus = 0;
}

// PHB 2024 Fighter L2 Tactical Mind (para 5113-5114): "When you fail an ability
// check, you can expend a use of your Second Wind to push yourself toward
// success. Rather than regaining Hit Points, you roll 1d10 and add the number
// rolled to the ability check, potentially turning it into a success. If the
// check still fails, this use of Second Wind isn't expended."
class pending_tactical_mind_prompt {
	string player_username;
	pending_roll@ roll;
	int natural_roll = 0;
	int bless_bonus = 0;
	int bardic_bonus = 0;
}

class pending_smite_prompt {
	string player_username;
	pending_roll@ damage_roll;       // The damage roll to resume after smite choice
	bool is_crit = false;
	int highest_slot = 0;            // Highest available slot for smite
	string smite_type = "divine";    // "divine" or "eldritch"
}

class pending_reaction_prompt {
	string defender_username;
	uint attacker_id;
	uint defender_id;
	int attack_total;                // The attack roll total
	int natural_roll;                // Natural d20 result
	bool is_crit;
	string[] options;                // Available reactions: "shield", "cutting_words", etc.
	pending_roll@ attack_roll;       // The original attack roll to resume
	int reported_modifier;
}

// Generic mid-spell player choice (Fire Shield warm/chill, Spirit Guardians radiant/necrotic,
// Adjust Density halve/double, Magic Missile/Scorching Ray/Eldritch Blast target distribution,
// future spell variants). Pauses spell finalisation, prompts the caster, and resumes via
// handle_spell_choice_response -> apply_spell_choice dispatch.
class pending_spell_choice {
	string player_username;
	uint caster_id;
	string spell_id;                 // e.g., "fire_shield", "magic_missile", "scorching_ray"
	int cast_slot_level;             // Slot level the spell was cast at (for upcast scaling)
	uint primary_target_id;          // For target-affecting binary spells (e.g., Adjust Density)
	string[] option_keys;            // Binary: choice keys ["warm","chill"]; Distribution: candidate combatant IDs as strings
	string[] option_labels;          // Display labels (binary: variant names; distribution: enemy names + distance)
	string prompt_text;              // Human-readable prompt for TTS
	string choice_kind = "binary";   // "binary" or "distribution"
	int distribution_count = 0;      // Number of picks needed for distribution (e.g., 3 for Scorching Ray L2)
	int dist_attack_bonus = 0;       // Spell attack bonus for distribution (Scorching Ray, Eldritch Blast)
	int dist_damage_count = 0;       // Damage dice count per projectile
	int dist_damage_sides = 0;       // Damage die sides per projectile
	int dist_damage_modifier = 0;    // Flat damage modifier per projectile (e.g., +1 for Magic Missile)
	int dist_damage_type = 0;        // Damage type ID (DMG_FORCE, DMG_FIRE, etc.)
	bool dist_uses_attack_roll = false; // false for Magic Missile (auto-hit)
}

class achievement_notice {
	string id;
	string name;
	string description;
	int xp_reward = 0;
}

const int READIED_ACTION_ATTACK = 0;

class battle_manager {
	battle@ combat;
	user@[] players;          // All players in this battle (mirrors room.players at start)
	pending_roll@ current_roll;
	pending_bardic_prompt@ current_bardic_prompt;
	pending_lucky_prompt@ current_lucky_prompt;
	pending_heroic_prompt@ current_heroic_prompt;
	pending_tactical_mind_prompt@ current_tactical_mind_prompt;
	pending_smite_prompt@ current_smite_prompt;
	pending_reaction_prompt@ current_reaction_prompt;
	pending_spell_choice@ current_spell_choice;
	bool initiative_phase = false;
	uint initiative_index = 0;
	uint64 initiative_delay_until = 0;
	string scenario_id = "";
	string active_modifier = "none";
	bool pending_turn_start_after_interrupt = false;
	string lobby_game_type = GAME_TYPE_SANDBOX;
	bool progression_enabled = false;
	string difficulty = "normal";
	float difficulty_hp_mult = 1.0;
	float difficulty_dmg_mult = 1.0;
	int party_monster_xp = 0;
	int waves_cleared_this_run = 0;
	dictionary run_kills;
	dictionary run_healing;
	dictionary run_crits;
	dictionary run_max_damage;
	dictionary run_damage;
	dictionary defeated_monsters;

	uint64 monster_turn_start_time = 0;

	battle_manager() {
		@combat = null;
		@current_roll = null;
		@current_bardic_prompt = null;
		@current_lucky_prompt = null;
		@current_heroic_prompt = null;
		@current_smite_prompt = null;
		@current_reaction_prompt = null;
		@current_spell_choice = null;
		reset_progression_tracking();
	}

	// ---- Broadcasting ----

	void broadcast_to_battle(json_object@ msg) {
		if (@msg == null) return;
		for (uint i = 0; i < players.length(); i++) {
			if (@players[i] != null and !players[i].disconnected and players[i].peer_id != 0) {
				try { players[i].send(msg); } catch {}
			}
		}
	}

	// Remove a player from the battle cleanly. Handles turn advancement if needed.
	void remove_player_from_battle(user@ u) {
		if (@u == null) return;
		int idx = players.find_by_ref(u);
		if (idx < 0) return;
		println("[BATTLE] Removing player " + u.username + " from battle (index " + idx + ")");
		broadcast_announce(u.username + " has left the battle.", false);
		players.remove_at(idx);
	}

	void broadcast_announce(string text, bool interrupt = false) {
		broadcast_to_battle({{"type", message_types::announce}, {"text", text}, {"interrupt", interrupt}});
	}

	void broadcast_roll(string roller_name, string reason, int natural_roll, int modifier, int total, string outcome) {
		string mod_text = "";
		if (modifier > 0) mod_text = " plus " + modifier;
		else if (modifier < 0) mod_text = " minus " + (-modifier);
		string text = roller_name + " rolls " + reason + ". Natural " + natural_roll + mod_text + ", total " + total + ". " + outcome;
		if (natural_roll == 20) text = roller_name + " rolls " + reason + ". Natural 20!" + mod_text + ", total " + total + ". " + outcome;
		else if (natural_roll == 1) text = roller_name + " rolls " + reason + ". Natural 1!" + mod_text + ", total " + total + ". " + outcome;
		broadcast_to_battle({{"type", message_types::announce}, {"text", text}, {"interrupt", false}});
		broadcast_to_battle({{"type", message_types::roll_result}, {"natural", natural_roll}, {"total", total}, {"outcome", outcome}});
	}

	// PHB 2024 Paladin L6 Aura of Protection (para 5665-5669) + L10 Aura of Courage
	// (para 5675-5679): refresh received bonuses for ALL combatants based on proximity
	// to friendly Paladins. Called at turn start and after movement/push.
	void refresh_paladin_auras() {
		if (@combat == null) return;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ c = combat.combatants[i];
			if (@c == null or c.is_dead) {
				c.paladin_aura_received_bonus = 0;
				c.paladin_aura_courage_immune = false;
				continue;
			}
			int best_bonus = 0;
			bool courage = false;
			for (uint j = 0; j < combat.combatants.length(); j++) {
				combatant@ p = combat.combatants[j];
				if (@p == null or p.is_dead or p.class_name != "Paladin") continue;
				if (p.has_condition(COND_INCAPACITATED)) continue;
				// Must be on the same team
				if (p.is_player != c.is_player and combat.mode != "pvp") continue;
				int aura_range = p.level >= 18 ? 30 : 10;
				if (feet_distance(c.x, c.y, p.x, p.y) <= aura_range) {
					// Aura of Protection (L6+)
					if (p.aura_of_protection_bonus > best_bonus) best_bonus = p.aura_of_protection_bonus;
					// Aura of Courage (L10+)
					if (p.level >= 10) courage = true;
				}
			}
			c.paladin_aura_received_bonus = best_bonus;
			c.paladin_aura_courage_immune = courage;
		}
	}

	void broadcast_state() {
		if (@combat == null) return;
		for (uint i = 0; i < players.length(); i++) {
			if (@players[i] == null) continue;
			json_object@ state = combat.build_state_json(players[i].username);
			players[i].send(state);
		}
	}

	void send_private_announce(user@ u, string text, bool interrupt = false) {
		if (@u == null or text == "") return;
		u.send({{"type", message_types::announce}, {"text", text}, {"interrupt", interrupt}});
	}

	combatant@ find_player_combatant(string username) {
		if (@combat == null or username == "") return null;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ c = combat.combatants[i];
			if (@c != null and c.is_player and c.player_username == username) return c;
		}
		return null;
	}

	bool combatant_is_controlled_by_bot(combatant@ c) {
		user@ u = find_user_for_combatant(c);
		return @u != null and u.is_bot;
	}

	// Spawn a companion combatant bound to the owner. Used by Beast Master Primal Companion,
	// Battle Smith Steel Defender, Drakewarden Drake Companion, Wildfire Spirit, Echo Knight
	// Manifest Echo, Artillerist Eldritch Cannon, etc. The companion is added to combat.combatants
	// in the slot immediately after the owner so it acts on the same initiative count.
	// Per TODO §7C this is the minimum viable companion implementation: full HP/AC/attack
	// scaling per source, owner_id back-reference, no death saves on the companion (HP 0 = removed).
	combatant@ spawn_companion(combatant@ owner, string subclass_id, string display_name, int hp, int ac, int speed, int attack_bonus, int dmg_count, int dmg_die, int dmg_mod, int dmg_type, int extra_attacks = 0) {
		if (@owner == null or @combat == null) return null;
		combatant c;
		c.name = display_name;
		c.is_player = owner.is_player; // Companion is on the owner's team
		c.player_username = "";
		c.x = owner.x + 1;
		c.y = owner.y;
		if (c.x >= combat.map_width) c.x = owner.x - 1;
		c.size = SIZE_MEDIUM;
		c.max_hp = hp;
		c.current_hp = hp;
		c.armor_class = ac;
		c.speed = speed;
		c.initiative_bonus = owner.initiative_bonus;
		c.ability_scores = owner.ability_scores;
		c.is_companion = true;
		c.owner_id = owner.id;
		c.companion_subclass = subclass_id;
		c.companion_attack_bonus = attack_bonus;
		c.companion_attack_dice = dmg_count;
		c.companion_attack_die_sides = dmg_die;
		c.companion_attack_dmg_mod = dmg_mod;
		c.companion_attack_dmg_type = dmg_type;
		// Wire up the regular weapon-attack fields so the existing combat code paths work
		// (find_nearest_target_for_monster, monster turn execution, etc.).
		c.main_hand = display_name + " strike";
		c.main_hand_damage_dice = dmg_die;
		c.main_hand_damage_count = dmg_count;
		c.main_hand_damage_type = dmg_type;
		c.main_hand_range = 5;
		c.main_hand_finesse = false;
		c.main_hand_is_ranged = false;
		c.monster_attack_bonus = attack_bonus;
		c.monster_attack_damage_mod = dmg_mod;
		c.extra_attacks = extra_attacks;
		c.summoner_id = owner.id;
		// Insert into combatants AFTER the owner so it acts on the same initiative tick
		// when initiative is rolled (or right after if mid-round).
		combat.combatants.insert_last(c);
		return @combat.combatants[combat.combatants.length() - 1];
	}

	// Cleans up a companion when the owner dies, leaves combat, or dismisses it.
	void dismiss_companion(combatant@ companion, bool announce = true) {
		if (@companion == null or !companion.is_companion) return;
		// Xanathar's Shadow Magic Hound of Ill Omen: clear hound_caster_id on target
		if (companion.companion_subclass == "hound_of_ill_omen" and @combat != null) {
			for (uint hci = 0; hci < combat.combatants.length(); hci++) {
				combatant@ ht = combat.combatants[hci];
				if (@ht != null and ht.hound_caster_id == companion.owner_id) {
					ht.hound_caster_id = 0;
				}
			}
		}
		companion.is_dead = true;
		companion.current_hp = 0;
		if (announce) broadcast_announce(companion.name + " fades away.", false);
	}

	combatant@ find_nearest_hostile_target(combatant@ actor) {
		if (@actor == null or @combat == null) return null;
		combatant@ nearest = null;
		int nearest_dist = 9999;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ other = combat.combatants[i];
			if (@other == null or other.id == actor.id or other.is_dead) continue;
			if (!other.is_alive() or other.current_hp == 0) continue;
			if (!combat.are_hostile(actor, other)) continue;
			int dist = feet_distance(actor.x, actor.y, other.x, other.y);
			if (dist < nearest_dist) {
				nearest_dist = dist;
				@nearest = other;
			}
		}
		return nearest;
	}

	string movement_direction_text(int dx, int dy) {
		if (dx > 0) return "east";
		if (dx < 0) return "west";
		if (dy > 0) return "north";
		if (dy < 0) return "south";
		return "nowhere";
	}

	void announce_movement_to_visible_players(combatant@ mover, int dx, int dy, int move_cost) {
		if (@mover == null or @combat == null) return;
		string direction = movement_direction_text(dx, dy);
		int used = move_cost;
		int remaining = mover.movement_remaining;
		string self_text = "You move " + direction + ", using " + used + " feet of movement. You have " + remaining + " feet remaining.";
		string other_text = mover.name + " moves " + direction + ", using " + used + " feet of movement. " + mover.name + " has " + remaining + " feet remaining.";
		for (uint i = 0; i < players.length(); i++) {
			user@ u = players[i];
			if (@u == null) continue;
			combatant@ viewer = find_player_combatant(u.username);
			if (@viewer == null) continue;
			if (viewer.id == mover.id) {
				send_private_announce(u, self_text, false);
				continue;
			}
			if (combat.can_see(viewer, mover)) send_private_announce(u, other_text, false);
		}
	}

	void resume_current_turn_after_interrupt() {
		if (@combat == null or !combat.battle_active or @current_roll != null) return;
		combatant@ active = combat.current_combatant();
		if (@active == null or active.is_dead) {
			advance_turn();
			return;
		}
		if (!active.is_player) {
			execute_monster_turn(active);
			return;
		}
		if (combatant_is_controlled_by_bot(active)) {
			execute_player_bot_turn(active);
			return;
		}
		broadcast_state();
	}

	void reset_progression_tracking() {
		lobby_game_type = GAME_TYPE_SANDBOX;
		progression_enabled = false;
		party_monster_xp = 0;
		waves_cleared_this_run = 0;
		active_modifier = "none";
		run_kills.delete_all();
		run_healing.delete_all();
		run_crits.delete_all();
		run_max_damage.delete_all();
		run_damage.delete_all();
		defeated_monsters.delete_all();
	}

	int get_run_kill_count(string username) {
		int value = 0;
		if (run_kills.exists(username)) run_kills.get(username, value);
		return value;
	}

	int get_run_healing_total(string username) {
		int value = 0;
		if (run_healing.exists(username)) run_healing.get(username, value);
		return value;
	}

	void add_run_kills(string username, int amount) {
		if (username == "" or amount <= 0) return;
		run_kills.set(username, get_run_kill_count(username) + amount);
	}

	void add_run_healing(string username, int amount) {
		if (username == "" or amount <= 0) return;
		run_healing.set(username, get_run_healing_total(username) + amount);
	}

	int get_run_crit_count(string username) {
		int value = 0;
		if (run_crits.exists(username)) run_crits.get(username, value);
		return value;
	}

	void add_run_crits(string username, int amount) {
		if (username == "" or amount <= 0) return;
		run_crits.set(username, get_run_crit_count(username) + amount);
	}

	int get_run_max_damage(string username) {
		int value = 0;
		if (run_max_damage.exists(username)) run_max_damage.get(username, value);
		return value;
	}

	void set_run_max_damage(string username, int amount) {
		if (username == "") return;
		run_max_damage.set(username, amount);
	}

	int get_run_damage_total(string username) {
		int value = 0;
		if (run_damage.exists(username)) run_damage.get(username, value);
		return value;
	}

	void add_run_damage(string username, int amount) {
		if (username == "" or amount <= 0) return;
		run_damage.set(username, get_run_damage_total(username) + amount);
	}

	int get_monster_progression_xp(combatant@ target) {
		if (@target == null) return 0;
		int monster_xp = target.monster_xp_value;
		if (monster_xp <= 25) return 30;
		if (monster_xp <= 50) return 40;
		if (monster_xp <= 100) return 55;
		if (monster_xp <= 200) return 75;
		if (monster_xp <= 450) return 105;
		if (monster_xp <= 700) return 135;
		if (monster_xp <= 1800) return 190;
		if (monster_xp <= 2900) return 240;
		if (monster_xp <= 5900) return 320;
		if (monster_xp <= 11500) return 420;
		if (monster_xp <= 18000) return 520;
		if (monster_xp <= 25000) return 620;
		return 750;
	}

	// ---- Multi-Phase Boss Fights ----

	void check_boss_phase(combatant@ boss) {
		if (@boss == null or !boss.is_boss or boss.is_dead or @combat == null) return;
		float hp_pct = float(boss.current_hp) / float(boss.max_hp);

		if (hp_pct <= 0.5 and !boss.phase_2_triggered) {
			boss.phase_2_triggered = true;
			boss.boss_phase = 2;
			boss.armor_class += 3;
			boss.monster_attack_damage_mod += 2;
			boss.speed += 10;
			broadcast_announce(boss.name + " enters Phase 2! It grows stronger!", true);
			// Spawn 2 minions based on boss tier
			string minion_id = "skeleton";
			if (boss.monster_xp_value >= 10000) minion_id = "shadow_demon";
			else if (boss.monster_xp_value >= 5000) minion_id = "ghoul";
			for (int m = 0; m < 2; m++) {
				monster_def@ md = get_monster_def(minion_id);
				if (@md != null) {
					combatant@ minion = create_monster_combatant(md, boss.x + (m == 0 ? -2 : 2), boss.y);
					if (@minion != null) {
						combat.add_combatant(minion);
						// Add minion to initiative order so it gets turns
						int minion_idx = int(combat.combatants.length()) - 1;
						minion.initiative_roll = boss.initiative_roll - 1;
						combat.initiative_order.insert_last(minion_idx);
						broadcast_announce(minion.name + " appears to aid " + boss.name + "!", false);
					}
				}
			}
			broadcast_state();
		}

		if (hp_pct <= 0.25 and !boss.phase_3_triggered) {
			boss.phase_3_triggered = true;
			boss.boss_phase = 3;
			boss.monster_attack_damage_mod += 2;
			int heal = boss.max_hp / 10;
			boss.current_hp += heal;
			if (boss.current_hp > boss.max_hp) boss.current_hp = boss.max_hp;
			broadcast_announce(boss.name + " enters Phase 3! Enraged! It heals " + heal + " HP!", true);
			broadcast_state();
		}
	}

	void record_effective_healing(string username, int amount) {
		if (!progression_enabled or amount <= 0) return;
		add_run_healing(username, amount);
	}

	void record_monster_defeat(combatant@ attacker, combatant@ target) {
		if (!progression_enabled or @target == null or target.is_player) return;
		string monster_key = "" + target.id;
		if (defeated_monsters.exists(monster_key)) return;
		defeated_monsters.set(monster_key, true);
		party_monster_xp += get_monster_progression_xp(target);
		if (@attacker != null and attacker.is_player and attacker.player_username != "") {
			add_run_kills(attacker.player_username, 1);
		}
	}

	bool queue_achievement_unlock(json_object@ progress, string id, string name, string description, int reward_xp, int&inout achievement_xp, achievement_notice@[]@ notices) {
		if (@progress == null or !unlock_progress_achievement(progress, id)) return false;
		achievement_xp += reward_xp;
		achievement_notice notice;
		notice.id = id;
		notice.name = name;
		notice.description = description;
		notice.xp_reward = reward_xp;
		notices.insert_last(notice);
		return true;
	}

	void finalize_adventure_progress(string result) {
		if (!progression_enabled) return;
		bool victory = result == "victory";
		for (uint i = 0; i < players.length(); i++) {
			user@ player = players[i];
			if (@player == null or player.is_bot or @player.account == null) continue;
			ensure_account_progression(player.account);
			if (!account_has_character_profile(player.account, GAME_TYPE_ADVENTURE)) continue;

			json_object@ progress = get_adventure_progress(player.account);
			if (@progress == null) continue;

			int kill_count = get_run_kill_count(player.username);
			int healing_total = get_run_healing_total(player.username);
			add_json_int(progress, "matches_completed", 1);
			add_json_int(progress, "monster_kills", kill_count);
			add_json_int(progress, "healing_done", healing_total);
			add_json_int(progress, "waves_cleared", waves_cleared_this_run);
			if (victory) add_json_int(progress, "victories", 1);
			if (victory and combat.mode == "boss") add_json_int(progress, "boss_kills", 1);

			// Track total damage dealt from this run
			add_json_int(progress, "total_damage_dealt", get_run_damage_total(player.username));

			// Track crit count and max single damage from this run
			int crit_count = get_run_crit_count(player.username);
			add_json_int(progress, "crit_count", crit_count);
			int this_run_max = get_run_max_damage(player.username);
			int current_max = get_json_int(progress, "max_single_damage");
			if (this_run_max > current_max) progress["max_single_damage"] = this_run_max;

			// Track deaths: check if this player's combatant is dead at battle end
			for (uint ci = 0; ci < combat.combatants.length(); ci++) {
				if (combat.combatants[ci].is_player and combat.combatants[ci].player_username == player.username) {
					if (combat.combatants[ci].is_dead) {
						add_json_int(progress, "total_deaths", 1);
					}
					break;
				}
			}

			// Track PvP wins and losses
			if (combat.mode == "pvp") {
				bool is_winner = false;
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					if (combat.combatants[ci].is_player and combat.combatants[ci].player_username == player.username and combat.combatants[ci].is_alive()) {
						is_winner = true;
						break;
					}
				}
				if (is_winner) {
					add_json_int(progress, "pvp_wins", 1);
				} else {
					add_json_int(progress, "pvp_losses", 1);
				}
			}

			// Track longest kill streak
			if (kill_count > get_json_int(progress, "longest_kill_streak")) {
				progress["longest_kill_streak"] = kill_count;
			}

			// Track class wins
			if (victory) {
				json_object@ class_wins = ensure_json_object_field(progress, "class_wins");
				string player_class = "";
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					if (combat.combatants[ci].is_player and combat.combatants[ci].player_username == player.username) {
						player_class = combat.combatants[ci].class_name;
						break;
					}
				}
				if (player_class != "") add_json_int(class_wins, player_class.lower(), 1);
			}

			// Track dungeon completions count
			if (victory and (combat.mode == "wave" or combat.mode == "boss")) {
				add_json_int(progress, "total_dungeons_cleared", 1);
			}

			int kill_xp = party_monster_xp;
			int healing_xp = healing_total / 4;
			if (healing_xp > 250) healing_xp = 250;
			int match_xp = 60;
			if (victory) match_xp += 60;
			if (combat.mode == "wave") {
				match_xp += waves_cleared_this_run * 20;
			} else if (combat.mode == "boss") {
				match_xp += victory ? 120 : 30;
			} else if (combat.mode == "endless") {
				match_xp += waves_cleared_this_run * 15;
			}

			int base_xp = kill_xp + healing_xp + match_xp;
			int total_awarded = 0;
			int levels_gained = 0;
			if (base_xp > 0) {
				int gained_levels = 0;
				apply_adventure_xp(player.account, base_xp, gained_levels);
				total_awarded += base_xp;
				levels_gained += gained_levels;
			}

			achievement_notice@[] notices;
			int achievement_xp = 0;
			if (get_json_int(progress, "matches_completed") >= 1) {
				queue_achievement_unlock(progress, "first_steps", "First Steps", "Complete your first Adventure run.", 75, achievement_xp, notices);
			}
			if (get_json_int(progress, "victories") >= 1) {
				queue_achievement_unlock(progress, "first_victory", "First Victory", "Win your first Adventure run.", 100, achievement_xp, notices);
			}
			if (get_json_int(progress, "monster_kills") >= 10) {
				queue_achievement_unlock(progress, "monster_hunter", "Monster Hunter", "Defeat 10 monsters in Adventure.", 125, achievement_xp, notices);
			}
			if (get_json_int(progress, "monster_kills") >= 50) {
				queue_achievement_unlock(progress, "slayer_veteran", "Slayer Veteran", "Defeat 50 monsters in Adventure.", 300, achievement_xp, notices);
			}
			if (get_json_int(progress, "healing_done") >= 100) {
				queue_achievement_unlock(progress, "field_medic", "Field Medic", "Restore 100 effective hit points in Adventure.", 75, achievement_xp, notices);
			}
			if (get_json_int(progress, "healing_done") >= 500) {
				queue_achievement_unlock(progress, "battlefield_surgeon", "Battlefield Surgeon", "Restore 500 effective hit points in Adventure.", 175, achievement_xp, notices);
			}
			if (get_json_int(progress, "waves_cleared") >= 5) {
				queue_achievement_unlock(progress, "wavebreaker", "Wavebreaker", "Clear 5 Adventure waves.", 125, achievement_xp, notices);
			}
			if (get_json_int(progress, "boss_kills") >= 1) {
				queue_achievement_unlock(progress, "boss_slayer", "Boss Slayer", "Defeat your first Adventure boss.", 200, achievement_xp, notices);
			}
			if (get_json_int(progress, "level", 1) >= 5) {
				queue_achievement_unlock(progress, "rising_hero", "Rising Hero", "Reach Adventure level 5.", 150, achievement_xp, notices);
			}

			// ---- New Achievement Checks (40+) ----

			// Combat milestones
			if (get_json_int(progress, "monster_kills") >= 100)
				queue_achievement_unlock(progress, "monster_slayer_100", "Monster Slayer", "Defeat 100 monsters.", 200, achievement_xp, notices);
			if (get_json_int(progress, "monster_kills") >= 500)
				queue_achievement_unlock(progress, "monster_slayer_500", "Monster Slayer Elite", "Defeat 500 monsters.", 500, achievement_xp, notices);
			if (get_json_int(progress, "crit_count") >= 25)
				queue_achievement_unlock(progress, "critical_master", "Critical Master", "Land 25 critical hits.", 150, achievement_xp, notices);
			if (get_json_int(progress, "max_single_damage") >= 100)
				queue_achievement_unlock(progress, "overkill", "Overkill", "Deal 100 or more damage in a single hit.", 100, achievement_xp, notices);

			// Class mastery (13 classes)
			{
				json_object@ cw = ensure_json_object_field(progress, "class_wins");
				string[] all_classes = {"barbarian","bard","cleric","druid","fighter","monk","paladin","ranger","rogue","sorcerer","warlock","wizard","artificer"};
				string[] class_display = {"Barbarian","Bard","Cleric","Druid","Fighter","Monk","Paladin","Ranger","Rogue","Sorcerer","Warlock","Wizard","Artificer"};
				for (uint ci = 0; ci < all_classes.length(); ci++) {
					if (get_json_int(cw, all_classes[ci]) >= 10)
						queue_achievement_unlock(progress, "master_" + all_classes[ci], class_display[ci] + " Master", "Win 10 battles as " + class_display[ci] + ".", 200, achievement_xp, notices);
				}
			}

			// Dungeon achievements
			if (get_json_int(progress, "total_dungeons_cleared") >= 10)
				queue_achievement_unlock(progress, "dungeon_crawler", "Dungeon Crawler", "Clear 10 dungeons.", 150, achievement_xp, notices);

			// Endless achievements
			int endless_best = get_json_int(progress, "endless_best_wave");
			if (endless_best >= 5)
				queue_achievement_unlock(progress, "endless_5", "Endless Survivor", "Reach wave 5 in Endless.", 100, achievement_xp, notices);
			if (endless_best >= 10)
				queue_achievement_unlock(progress, "endless_10", "Endless Warrior", "Reach wave 10 in Endless.", 200, achievement_xp, notices);
			if (endless_best >= 20)
				queue_achievement_unlock(progress, "endless_20", "Endless Champion", "Reach wave 20 in Endless.", 500, achievement_xp, notices);
			if (endless_best >= 30)
				queue_achievement_unlock(progress, "endless_30", "Endless Legend", "Reach wave 30 in Endless.", 1000, achievement_xp, notices);

			// Loot achievements
			int items = get_json_int(progress, "items_found");
			if (items >= 1)
				queue_achievement_unlock(progress, "first_loot", "First Find", "Find your first item.", 50, achievement_xp, notices);
			if (items >= 10)
				queue_achievement_unlock(progress, "collector_10", "Collector", "Find 10 items.", 150, achievement_xp, notices);

			// Trade achievement
			if (get_json_int(progress, "trades_completed") >= 1)
				queue_achievement_unlock(progress, "trader", "Trader", "Complete a trade with another player.", 100, achievement_xp, notices);

			// Prestige achievements
			int prestige = get_json_int(progress, "prestige_rank");
			if (prestige >= 1)
				queue_achievement_unlock(progress, "prestige_1", "Prestige Veteran", "Reach Prestige 1.", 300, achievement_xp, notices);
			if (prestige >= 3)
				queue_achievement_unlock(progress, "prestige_3", "Prestige Legend", "Reach Prestige 3.", 500, achievement_xp, notices);
			if (prestige >= 5)
				queue_achievement_unlock(progress, "prestige_5", "Prestige Ascendant", "Reach Prestige 5.", 1000, achievement_xp, notices);

			// Level milestones
			if (get_json_int(progress, "level", 1) >= 10)
				queue_achievement_unlock(progress, "level_10", "Seasoned Adventurer", "Reach Adventure level 10.", 250, achievement_xp, notices);
			if (get_json_int(progress, "level", 1) >= 15)
				queue_achievement_unlock(progress, "level_15", "Heroic Champion", "Reach Adventure level 15.", 400, achievement_xp, notices);
			if (get_json_int(progress, "level", 1) >= 20)
				queue_achievement_unlock(progress, "level_20", "Legend of the Realm", "Reach Adventure level 20.", 750, achievement_xp, notices);

			// Victory milestones
			if (get_json_int(progress, "victories") >= 10)
				queue_achievement_unlock(progress, "victor_10", "Proven Victor", "Win 10 Adventure battles.", 150, achievement_xp, notices);
			if (get_json_int(progress, "victories") >= 50)
				queue_achievement_unlock(progress, "victor_50", "Battle Hardened", "Win 50 Adventure battles.", 400, achievement_xp, notices);
			if (get_json_int(progress, "victories") >= 100)
				queue_achievement_unlock(progress, "victor_100", "Unstoppable", "Win 100 Adventure battles.", 750, achievement_xp, notices);

			// Match milestones
			if (get_json_int(progress, "matches_completed") >= 25)
				queue_achievement_unlock(progress, "matches_25", "Dedicated Fighter", "Complete 25 Adventure runs.", 150, achievement_xp, notices);
			if (get_json_int(progress, "matches_completed") >= 100)
				queue_achievement_unlock(progress, "matches_100", "Arena Regular", "Complete 100 Adventure runs.", 400, achievement_xp, notices);

			// Healing milestones
			if (get_json_int(progress, "healing_done") >= 1000)
				queue_achievement_unlock(progress, "healing_1000", "Divine Healer", "Restore 1000 effective hit points.", 300, achievement_xp, notices);

			// Wave milestones
			if (get_json_int(progress, "waves_cleared") >= 25)
				queue_achievement_unlock(progress, "wave_25", "Wave Master", "Clear 25 total waves.", 250, achievement_xp, notices);
			if (get_json_int(progress, "waves_cleared") >= 50)
				queue_achievement_unlock(progress, "wave_50", "Tide Turner", "Clear 50 total waves.", 400, achievement_xp, notices);

			// Boss milestones
			if (get_json_int(progress, "boss_kills") >= 5)
				queue_achievement_unlock(progress, "boss_5", "Boss Hunter", "Defeat 5 bosses.", 300, achievement_xp, notices);
			if (get_json_int(progress, "boss_kills") >= 10)
				queue_achievement_unlock(progress, "boss_10", "Boss Nemesis", "Defeat 10 bosses.", 500, achievement_xp, notices);

			// Crit milestones
			if (get_json_int(progress, "crit_count") >= 50)
				queue_achievement_unlock(progress, "crit_50", "Critical Fury", "Land 50 critical hits.", 300, achievement_xp, notices);
			if (get_json_int(progress, "crit_count") >= 100)
				queue_achievement_unlock(progress, "crit_100", "Critical Devastation", "Land 100 critical hits.", 500, achievement_xp, notices);

			// Damage milestones
			if (get_json_int(progress, "max_single_damage") >= 50)
				queue_achievement_unlock(progress, "big_hit_50", "Heavy Hitter", "Deal 50 or more damage in a single hit.", 75, achievement_xp, notices);
			if (get_json_int(progress, "max_single_damage") >= 200)
				queue_achievement_unlock(progress, "big_hit_200", "Devastating Blow", "Deal 200 or more damage in a single hit.", 300, achievement_xp, notices);

			// Glory milestones
			if (get_json_int(progress, "glory") >= 100)
				queue_achievement_unlock(progress, "glory_100", "Rising Fame", "Earn 100 Glory points.", 100, achievement_xp, notices);
			if (get_json_int(progress, "glory") >= 500)
				queue_achievement_unlock(progress, "glory_500", "Renowned Champion", "Earn 500 Glory points.", 300, achievement_xp, notices);

			// Items found milestones
			if (get_json_int(progress, "items_found") >= 25)
				queue_achievement_unlock(progress, "collector_25", "Treasure Hunter", "Find 25 items.", 250, achievement_xp, notices);
			if (get_json_int(progress, "items_found") >= 50)
				queue_achievement_unlock(progress, "collector_50", "Hoarder", "Find 50 items.", 400, achievement_xp, notices);

			// Dungeon milestones
			if (get_json_int(progress, "total_dungeons_cleared") >= 25)
				queue_achievement_unlock(progress, "dungeon_25", "Dungeon Delver", "Clear 25 dungeons.", 300, achievement_xp, notices);
			if (get_json_int(progress, "total_dungeons_cleared") >= 50)
				queue_achievement_unlock(progress, "dungeon_50", "Dungeon Conqueror", "Clear 50 dungeons.", 500, achievement_xp, notices);

			if (achievement_xp > 0) {
				int achievement_levels = 0;
				apply_adventure_xp(player.account, achievement_xp, achievement_levels);
				total_awarded += achievement_xp;
				levels_gained += achievement_levels;
			}

			// --- Glory Points ---
			int glory_earned = 10; // normal completion
			if (combat.mode == "boss") glory_earned = 25;
			else if (combat.mode == "endless") glory_earned = 5 + waves_cleared_this_run * 3;
			// Future: nightmare mode would grant 50
			if (victory or combat.mode == "endless") {
				add_glory(player.account, glory_earned);
			}

			// Track dungeon completions
			if (victory and scenario_id != "") {
				add_dungeon_completion(player.account, scenario_id);
			}

			// --- Loot Generation ---
			init_item_catalog();
			int player_level = get_json_int(progress, "level", 1);
			json_array@ inv = ensure_json_array_field(player.account.data, "adventure_inventory");
			json_array loot_items_arr;
			bool is_boss_mode = combat.mode == "boss";

			// Generate loot from each defeated monster
			for (uint mi = 0; mi < combat.combatants.length(); mi++) {
				combatant@ mon = combat.combatants[mi];
				if (@mon == null or mon.is_player or !mon.is_dead) continue;
				item_def@ dropped = null;
				if (is_boss_mode) {
					@dropped = generate_boss_loot(mon.monster_xp_value, player_level);
				} else {
					@dropped = generate_loot(mon.monster_xp_value, player_level);
				}
				if (@dropped != null and @inv != null and int(inv.length()) < MAX_INVENTORY) {
					inventory_add_item(inv, dropped.id);
					json_object loot_entry;
					loot_entry["id"] = dropped.id;
					loot_entry["name"] = dropped.name;
					loot_entry["rarity"] = dropped.rarity;
					loot_entry["slot"] = dropped.slot;
					loot_entry["description"] = dropped.description;
					loot_entry["stats"] = item_stat_summary(dropped);
					loot_items_arr.add(loot_entry);
				}
			}

			// Track items found for achievements
			if (int(loot_items_arr.length()) > 0) {
				add_json_int(progress, "items_found", int(loot_items_arr.length()));
			}

			player.account.commit();

			// Send loot drop message if any items were found
			if (loot_items_arr.length() > 0) {
				player.send({
					{"type", message_types::loot_drop},
					{"items", loot_items_arr}
				});
			}

			for (uint ai = 0; ai < notices.length(); ai++) {
				player.send({
					{"type", message_types::achievement_unlocked},
					{"id", notices[ai].id},
					{"name", notices[ai].name},
					{"description", notices[ai].description},
					{"xp_reward", notices[ai].xp_reward}
				});
			}

			// Send glory update
			if (victory and glory_earned > 0) {
				player.send({
					{"type", message_types::glory_update},
					{"glory", get_glory(player.account)},
					{"gained", glory_earned}
				});
			}

			// ---- Gold Awards ----
			init_consumable_catalog();
			int gold_earned = 0;
			for (uint gi = 0; gi < combat.combatants.length(); gi++) {
				combatant@ gmon = combat.combatants[gi];
				if (@gmon != null and !gmon.is_player and gmon.is_dead) {
					gold_earned += get_gold_for_monster(gmon.monster_xp_value);
				}
			}
			gold_earned += 10; // completion bonus
			if (active_modifier == "champions_trial") gold_earned = int(gold_earned * 1.5);
			if (gold_earned > 0) add_gold(player.account, gold_earned);

			// ---- Weekly Challenge Progress ----
			update_challenge_progress(player.account, "kills", kill_count);
			update_challenge_progress(player.account, "matches", 1);
			update_challenge_progress(player.account, "healing", healing_total);
			if (combat.mode == "wave") {
				update_challenge_progress(player.account, "endless", waves_cleared_this_run);
			}
			// Check and notify completed challenges
			string[] challenge_results = check_challenge_completion(player.account);
			for (uint ci = 0; ci < challenge_results.length(); ci++) {
				string[] parts = challenge_results[ci].split("|");
				if (parts.length() >= 2) {
					player.send({
						{"type", message_types::challenge_complete},
						{"description", parts[0]},
						{"glory", parse_int(parts[1])}
					});
				}
			}
			if (challenge_results.length() > 0) {
				player.send({
					{"type", message_types::glory_update},
					{"glory", get_glory(player.account)}
				});
			}

			json_object@ character_msg = build_character_data_message(player.account, GAME_TYPE_ADVENTURE);
			if (@character_msg != null) player.send(character_msg);

			json_object@ updated_progress = get_adventure_progress(player.account);
			string summary = "Adventure progress: +" + total_awarded + " XP.";
			summary += " Monsters +" + kill_xp + ", healing +" + healing_xp + ", completion +" + match_xp + ".";
			if (achievement_xp > 0) summary += " Achievements +" + achievement_xp + ".";
			if (victory and glory_earned > 0) summary += " Glory +" + glory_earned + ".";
			if (gold_earned > 0) summary += " Gold +" + gold_earned + ".";
			if (int(loot_items_arr.length()) > 0) summary += " Loot: " + int(loot_items_arr.length()) + " item(s) found!";
			if (levels_gained > 0 and @updated_progress != null) {
				int new_level = get_json_int(updated_progress, "level", 1);
				summary += " Level up! You are now level " + new_level + ".";
				send_level_up_choices(player, new_level, levels_gained);
			}
			player.send(build_progression_update_message(player.account, total_awarded, kill_xp, healing_xp, match_xp, achievement_xp, levels_gained, summary));
		}
	}

	// ---- Level-Up Choices ----

	void send_level_up_choices(user@ player, int new_level, int levels_gained) {
		if (@player == null or @player.account == null) return;
		json_object@ character = get_character_profile(player.account, GAME_TYPE_ADVENTURE);
		if (@character == null) return;

		string class_name = character.exists("class") ? string(character["class"]) : "";
		string subclass = character.exists("subclass") ? string(character["subclass"]) : "";
		int old_level = new_level - levels_gained;
		if (old_level < 1) old_level = 1;

		bool needs_subclass = (new_level >= 3 and subclass == "");

		json_object msg;
		msg["type"] = message_types::level_up_choices;
		msg["new_level"] = new_level;
		msg["old_level"] = old_level;
		msg["levels_gained"] = levels_gained;
		msg["class"] = class_name;
		msg["needs_subclass"] = needs_subclass;

		bool is_caster = false;
		string[] caster_classes = {"Bard", "Cleric", "Druid", "Sorcerer", "Warlock", "Wizard", "Paladin", "Ranger"};
		for (uint i = 0; i < caster_classes.length(); i++) {
			if (class_name == caster_classes[i]) { is_caster = true; break; }
		}
		if (subclass == "Eldritch Knight" or subclass == "Arcane Trickster") is_caster = true;

		int cantrip_slots_old = get_cantrip_count_for_class(class_name, subclass, old_level);
		int cantrip_slots_new = get_cantrip_count_for_class(class_name, subclass, new_level);
		int new_cantrips = cantrip_slots_new - cantrip_slots_old;
		if (new_cantrips < 0) new_cantrips = 0;

		int spells_old = get_known_spells_count_for_class(class_name, subclass, old_level);
		int spells_new = get_known_spells_count_for_class(class_name, subclass, new_level);
		int new_spells = spells_new - spells_old;
		if (new_spells < 0) new_spells = 0;

		msg["is_caster"] = is_caster;
		msg["new_cantrips"] = new_cantrips;
		msg["new_spells"] = new_spells;

		// Level-up selection prompts: Fighting Style, Pact Boon, Metamagic
		string existing_fs = character.exists("fighting_style") ? string(character["fighting_style"]) : "";
		bool fs_needed = false;
		if (existing_fs == "") {
			if (class_name == "Fighter" and new_level >= 1) fs_needed = true;
			if (class_name == "Paladin" and new_level >= 2) fs_needed = true;
			if (class_name == "Ranger" and new_level >= 2) fs_needed = true;
		}
		msg["fighting_style_needed"] = fs_needed;

		string existing_pb = character.exists("pact_boon") ? string(character["pact_boon"]) : "";
		bool pb_needed = (class_name == "Warlock" and new_level >= 3 and existing_pb == "");
		msg["pact_boon_needed"] = pb_needed;

		// Sorcerer Metamagic: 2 at L2, 4 at L10, 6 at L17
		int metamagic_total = 0;
		if (class_name == "Sorcerer") {
			if (new_level >= 17) metamagic_total = 6;
			else if (new_level >= 10) metamagic_total = 4;
			else if (new_level >= 2) metamagic_total = 2;
		}
		int metamagic_existing = 0;
		if (character.exists("metamagic_choices")) {
			json_array@ mc = character["metamagic_choices"];
			if (@mc != null) metamagic_existing = int(mc.length());
		}
		int metamagic_new = metamagic_total - metamagic_existing;
		if (metamagic_new < 0) metamagic_new = 0;
		msg["metamagic_count"] = metamagic_new;

		// Warlock Eldritch Invocations: known count by level (PHB 2024 paras 7607-7762)
		int inv_total = 0;
		if (class_name == "Warlock") {
			inv_total = 1;
			if (new_level >= 2) inv_total = 3;
			if (new_level >= 5) inv_total = 5;
			if (new_level >= 7) inv_total = 6;
			if (new_level >= 9) inv_total = 7;
			if (new_level >= 12) inv_total = 8;
			if (new_level >= 16) inv_total = 9;
			if (new_level >= 18) inv_total = 10;
		}
		int inv_existing = 0;
		json_array existing_inv_arr;
		if (character.exists("invocation_choices")) {
			json_array@ ic = character["invocation_choices"];
			if (@ic != null) { inv_existing = int(ic.length()); existing_inv_arr = ic; }
		}
		int inv_needed = inv_total - inv_existing;
		if (inv_needed < 0) inv_needed = 0;
		msg["invocations_needed"] = inv_needed;
		if (inv_needed > 0) {
			msg["existing_invocations"] = existing_inv_arr;
			string existing_pb = character.exists("pact_boon") ? string(character["pact_boon"]) : "";
			msg["existing_pact_boon"] = existing_pb;
		}

		// Wildemount Vestige of Divergence advancement announcement
		// (Wildemount para 9071): "A Vestige of Divergence typically remains
		// dormant until its wielder achieves 9th level. It becomes awakened
		// between levels 9 and 15, and achieves an exalted state between
		// levels 16 and 20." When the level-up crosses 9 or 16, scan equipped
		// items for any wildemount_<vestige_id> and announce its advancement.
		bool crossed_l9 = (old_level < 9 and new_level >= 9);
		bool crossed_l16 = (old_level < 16 and new_level >= 16);
		if ((crossed_l9 or crossed_l16) and character.exists("equipped")) {
			json_object@ equipped = character["equipped"];
			if (@equipped != null) {
				string[] eq_slots = {"weapon", "armor", "ring", "amulet"};
				string[] advanced_vestiges;
				for (uint si = 0; si < eq_slots.length(); si++) {
					if (!equipped.exists(eq_slots[si])) continue;
					string item_id = string(equipped[eq_slots[si]]);
					if (item_id == "" or item_id.find("wildemount_") != 0) continue;
					string vid = item_id.substr(11);
					vestige_def@ vd = get_vestige(vid);
					if (@vd != null) advanced_vestiges.insert_last(vd.name);
				}
				if (advanced_vestiges.length() > 0) {
					string state_name = crossed_l16 ? "Exalted" : "Awakened";
					string vlist = "";
					for (uint vi = 0; vi < advanced_vestiges.length(); vi++) {
						if (vi > 0) vlist += ", ";
						vlist += advanced_vestiges[vi];
					}
					msg["vestige_announcement"] = "Your Vestige of Divergence (" + vlist + ") has advanced to the " + state_name + " state! (Wildemount para 9071)";
				}
			}
		}

		player.send(msg);
	}

	int get_cantrip_count_for_class(string class_name, string subclass, int level) {
		if (class_name == "Bard" or class_name == "Druid" or class_name == "Warlock") {
			if (level >= 10) return 5;
			if (level >= 4) return 4;
			return level >= 1 ? 3 : 2;
		}
		if (class_name == "Cleric" or class_name == "Wizard") {
			if (level >= 10) return 6;
			if (level >= 4) return 5;
			return level >= 1 ? 4 : 3;
		}
		if (class_name == "Sorcerer") {
			if (level >= 10) return 7;
			if (level >= 4) return 6;
			return level >= 1 ? 5 : 4;
		}
		if (subclass == "Eldritch Knight" or subclass == "Arcane Trickster") {
			if (level >= 10) return 4;
			return level >= 3 ? 3 : 0;
		}
		return 0;
	}

	int get_known_spells_count_for_class(string class_name, string subclass, int level) {
		if (class_name == "Bard") return level >= 1 ? level + 3 : 0;
		if (class_name == "Sorcerer") return level >= 1 ? level + 1 : 0;
		if (class_name == "Warlock") return level >= 1 ? level + 1 : 0;
		if (class_name == "Ranger") return level >= 2 ? (level / 2) + 1 : 0;
		if (subclass == "Eldritch Knight") return level >= 3 ? (level <= 7 ? 3 : (level <= 10 ? 4 + (level - 8) : (level <= 13 ? 7 + (level - 11) : (level <= 19 ? 10 + (level - 14) : 13)))) : 0;
		if (subclass == "Arcane Trickster") return level >= 3 ? (level <= 7 ? 3 : (level <= 10 ? 4 + (level - 8) : (level <= 13 ? 7 + (level - 11) : (level <= 19 ? 10 + (level - 14) : 13)))) : 0;
		if (class_name == "Cleric" or class_name == "Druid" or class_name == "Wizard" or class_name == "Paladin") {
			return -1; // Prepared casters: they pick from full list, not "known"
		}
		return 0;
	}

	// Send a roll request to a specific player. Bots auto-resolve immediately.
	// Returns true if the roll was sent to a real player (awaiting response).
	// Returns false if it was auto-resolved (bot).
	bool request_roll(user@ u, combatant@ c, int roll_type, int dice_sides, int modifier, string reason, uint target_id = 0, int dc = 0, string resolution_tag = "") {
		if (@u == null or @c == null) return false;

		pending_roll pr;
		pr.combatant_id = c.id;
		pr.player_username = c.is_player ? c.player_username : c.name;
		pr.roll_type = roll_type;
		pr.dice_sides = dice_sides;
		pr.modifier = modifier;
		pr.reason = reason;
		pr.target_id = target_id;
		pr.dc = dc;
		pr.resolution_tag = resolution_tag;
		@current_roll = pr;

		// Bots and monsters auto-roll immediately.
		if (u.is_bot or !c.is_player) {
			int natural = random(1, dice_sides);
			process_roll_result(natural);
			return false;
		}

		// Send roll_request to the human player.
		send_roll_request(u, current_roll);
		return true;
	}

	// Find the user object for a given combatant.
	user@ find_user_for_combatant(combatant@ c) {
		if (@c == null) return null;
		if (!c.is_player) {
			// Monsters use the first connected player as proxy (auto-rolled anyway).
			for (uint i = 0; i < players.length(); i++) {
				if (@players[i] != null and !players[i].disconnected and players[i].peer_id != 0) return players[i];
			}
			return null;
		}
		for (uint i = 0; i < players.length(); i++) {
			if (@players[i] != null and !players[i].disconnected and players[i].username == c.player_username) return players[i];
		}
		return null;
	}

	// Canonical D&D 5e skill -> ability mapping (PHB Basic Rules para 303-360).
	// Returns -1 for unknown skill names so callers can fall back to a default.
	int skill_to_ability(string skill_name) {
		if (skill_name == "Athletics") return ABILITY_STR;
		if (skill_name == "Acrobatics") return ABILITY_DEX;
		if (skill_name == "Sleight of Hand") return ABILITY_DEX;
		if (skill_name == "Stealth") return ABILITY_DEX;
		if (skill_name == "Arcana") return ABILITY_INT;
		if (skill_name == "History") return ABILITY_INT;
		if (skill_name == "Investigation") return ABILITY_INT;
		if (skill_name == "Nature") return ABILITY_INT;
		if (skill_name == "Religion") return ABILITY_INT;
		if (skill_name == "Animal Handling") return ABILITY_WIS;
		if (skill_name == "Insight") return ABILITY_WIS;
		if (skill_name == "Medicine") return ABILITY_WIS;
		if (skill_name == "Perception") return ABILITY_WIS;
		if (skill_name == "Survival") return ABILITY_WIS;
		if (skill_name == "Deception") return ABILITY_CHA;
		if (skill_name == "Intimidation") return ABILITY_CHA;
		if (skill_name == "Performance") return ABILITY_CHA;
		if (skill_name == "Persuasion") return ABILITY_CHA;
		return -1;
	}

	// Build the resolution_tag string used by finalize_roll_result and the bardic prompt
	// to dispatch on a specific skill check. Format: "skill_<lowercased_skill_name>".
	// Spaces in skill names are converted to underscores.
	string skill_resolution_tag(string skill_name) {
		string tag = "skill_";
		for (uint i = 0; i < skill_name.length(); i++) {
			string ch = skill_name.substr(i, 1);
			if (ch == " ") tag += "_";
			else if (ch == "A") tag += "a";
			else if (ch == "B") tag += "b";
			else if (ch == "C") tag += "c";
			else if (ch == "D") tag += "d";
			else if (ch == "E") tag += "e";
			else if (ch == "F") tag += "f";
			else if (ch == "G") tag += "g";
			else if (ch == "H") tag += "h";
			else if (ch == "I") tag += "i";
			else if (ch == "J") tag += "j";
			else if (ch == "K") tag += "k";
			else if (ch == "L") tag += "l";
			else if (ch == "M") tag += "m";
			else if (ch == "N") tag += "n";
			else if (ch == "O") tag += "o";
			else if (ch == "P") tag += "p";
			else if (ch == "Q") tag += "q";
			else if (ch == "R") tag += "r";
			else if (ch == "S") tag += "s";
			else if (ch == "T") tag += "t";
			else if (ch == "U") tag += "u";
			else if (ch == "V") tag += "v";
			else if (ch == "W") tag += "w";
			else if (ch == "X") tag += "x";
			else if (ch == "Y") tag += "y";
			else if (ch == "Z") tag += "z";
			else tag += ch;
		}
		return tag;
	}

	// Request a generic skill check. Computes the modifier from get_skill_bonus, applies
	// advantage/disadvantage from feature flags, and routes through the standard
	// pending_roll pipeline so reroll prompts (Bardic, Lucky, Heroic) and Silver Tongue
	// clamping work automatically.
	bool request_skill_check(user@ u, combatant@ c, string skill_name, int dc, string custom_tag = "", bool extra_advantage = false, bool extra_disadvantage = false) {
		if (@combat == null or @c == null) return false;
		int ability_id = skill_to_ability(skill_name);
		if (ability_id < 0) return false;
		// PHB 2024 Barbarian L3 Primal Knowledge (para 2325-2327): "while your Rage is
		// active, you can channel primal power when you attempt certain tasks; whenever
		// you make an ability check using one of the following skills, you can make it
		// as a Strength check even if it normally uses a different ability: Acrobatics,
		// Intimidation, Perception, Stealth, or Survival."
		if (c.class_name == "Barbarian" and c.level >= 3 and c.raging) {
			if (skill_name == "Acrobatics" or skill_name == "Intimidation" or skill_name == "Perception" or skill_name == "Stealth" or skill_name == "Survival") {
				ability_id = ABILITY_STR;
			}
		}
		int mod = c.get_skill_bonus(skill_name, ability_id);
		bool adv = extra_advantage or c.has_skill_check_advantage(skill_name);
		bool disadv = extra_disadvantage or c.has_skill_check_disadvantage(skill_name);
		// Tasha's Rune Knight L3 Giant's Might: advantage on STR checks while active.
		if (c.giants_might_active and ability_id == ABILITY_STR) adv = true;
		// Tasha's Rune Knight Frost Rune invoke (para 3222-3224): "+2 bonus to all
		// ability checks and saving throws that use Strength or Constitution."
		if (c.frost_rune_active and (ability_id == ABILITY_STR or ability_id == ABILITY_CON)) mod += 2;
		// Basic Rules 2024 Enlarge/Reduce (para 12795-12800): Enlarge grants Advantage
		// on STR checks; Reduce grants Disadvantage on STR checks.
		if (c.enlarge_active and ability_id == ABILITY_STR) adv = true;
		if (c.reduce_active and ability_id == ABILITY_STR) disadv = true;
		// Basic Rules 2024 Enhance Ability (para 13068): advantage on all ability checks.
		if (c.enhance_ability_active) adv = true;
		// Basic Rules 2024 Foresight (para 13025-13031): "Advantage on D20 Tests"
		if (c.foresight_active) adv = true;
		// PHB 2024 Frightened (para 16222): "The creature has Disadvantage on ability
		// checks and attack rolls." PHB 2024 Poisoned (para 16237): same wording.
		if (c.has_condition(COND_FRIGHTENED) or c.has_condition(COND_POISONED)) disadv = true;
		// Basic Rules 2024 Hex (para 13730): "The target has Disadvantage on ability
		// checks made with the chosen ability." Scan for any caster with hex on this target.
		if (@combat != null) {
			for (uint hxi = 0; hxi < combat.combatants.length(); hxi++) {
				combatant@ hxc = combat.combatants[hxi];
				if (@hxc == null or hxc.is_dead) continue;
				if (hxc.hex_target_id == c.id and hxc.hex_cursed_ability == ability_id) {
					disadv = true;
					break;
				}
			}
		}
		// Basic Rules 2024 Bestow Curse (para 12219-12222): ability_X curse gives
		// "Disadvantage on ability checks and saving throws" for that ability.
		if (c.bestow_curse_source_id != 0) {
			int bc_cursed_ability = -1;
			if (c.bestow_curse_type == "ability_str") bc_cursed_ability = ABILITY_STR;
			else if (c.bestow_curse_type == "ability_dex") bc_cursed_ability = ABILITY_DEX;
			else if (c.bestow_curse_type == "ability_con") bc_cursed_ability = ABILITY_CON;
			else if (c.bestow_curse_type == "ability_int") bc_cursed_ability = ABILITY_INT;
			else if (c.bestow_curse_type == "ability_wis") bc_cursed_ability = ABILITY_WIS;
			else if (c.bestow_curse_type == "ability_cha") bc_cursed_ability = ABILITY_CHA;
			if (bc_cursed_ability == ability_id) disadv = true;
		}
		// Basic Rules 2024 Heat Metal (para 13734): "disadvantage on attack rolls
		// and ability checks until the start of your next turn."
		if (c.heat_metal_disadv) disadv = true;
		// PHB 2024 Swashbuckler L13 Elegant Maneuver (para 6599): "As a Bonus
		// Action, you can give yourself Advantage on the next Acrobatics or
		// Athletics check you make during the current turn."
		if (c.elegant_maneuver_active and (skill_name == "Acrobatics" or skill_name == "Athletics")) {
			adv = true;
			c.elegant_maneuver_active = false;
		}
		// Pass Without Trace stacks +10 onto Stealth checks (also Dexterity (Stealth)).
		if (skill_name == "Stealth") mod += c.pass_without_trace_bonus;
		// Xanathar's Drunken Master L11 Drunkard's Luck (para 1798-1800): "Whenever
		// you make an ability check, an attack roll, or a saving throw and have
		// disadvantage, you can spend 2 ki points to cancel the disadvantage."
		if (c.drunkards_luck_active and disadv and !adv and c.focus_points >= 2) {
			c.focus_points -= 2;
			disadv = false;
			broadcast_announce(c.name + " spends 2 Focus Points — Drunkard's Luck cancels the ability check disadvantage!", false);
		}
		string tag = custom_tag != "" ? custom_tag : skill_resolution_tag(skill_name);
		string reason = skill_name + " check";
		if (dc > 0) reason += " (DC " + dc + ")";
		// Build the pending_roll directly so we can set advantage/disadvantage on the roll.
		pending_roll pr;
		pr.combatant_id = c.id;
		pr.player_username = c.is_player ? c.player_username : c.name;
		pr.roll_type = ROLL_ABILITY_CHECK;
		pr.dice_sides = 20;
		pr.modifier = mod;
		pr.reason = reason;
		pr.dc = dc;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.resolution_tag = tag;
		pr.ability_id = ability_id;
		@current_roll = pr;
		if (@u != null and !u.is_bot and c.is_player) {
			send_roll_request(u, pr);
		} else {
			// Bot / NPC: roll immediately and process the result.
			int natural = random(1, 20);
			if (adv and !disadv) {
				int second = random(1, 20);
				if (second > natural) natural = second;
			} else if (disadv and !adv) {
				int second = random(1, 20);
				if (second < natural) natural = second;
			}
			process_roll_result(natural);
		}
		return true;
	}

	int parse_nonnegative_int(string text) {
		int value = 0;
		for (uint i = 0; i < text.length(); i++) {
			string ch = text.substr(i, 1);
			int digit = -1;
			if (ch == "0") digit = 0;
			else if (ch == "1") digit = 1;
			else if (ch == "2") digit = 2;
			else if (ch == "3") digit = 3;
			else if (ch == "4") digit = 4;
			else if (ch == "5") digit = 5;
			else if (ch == "6") digit = 6;
			else if (ch == "7") digit = 7;
			else if (ch == "8") digit = 8;
			else if (ch == "9") digit = 9;
			if (digit < 0) break;
			value = value * 10 + digit;
		}
		return value;
	}

	void parse_csv_list(string csv, string[]@ out_list) {
		out_list.resize(0);
		if (csv == "") return;
		string[]@ parts = csv.split(",");
		for (uint i = 0; i < parts.length(); i++) {
			if (parts[i] != "") out_list.insert_last(parts[i]);
		}
	}

	void parse_spell_override_specs(string csv, string[]@ spell_ids, int[]@ ability_ids) {
		spell_ids.resize(0);
		ability_ids.resize(0);
		if (csv == "") return;
		string[]@ parts = csv.split(",");
		for (uint i = 0; i < parts.length(); i++) {
			if (parts[i] == "") continue;
			int split_at = parts[i].find(":");
			if (split_at <= 0) continue;
			string spell_id = parts[i].substr(0, split_at);
			string ability_key = parts[i].substr(split_at + 1);
			int ability_id = ability_id_from_key(ability_key);
			if (spell_id == "" or ability_id < 0) continue;
			spell_ids.insert_last(spell_id);
			ability_ids.insert_last(ability_id);
		}
	}

	string die_label(int die_size) {
		if (die_size <= 0) return "d0";
		return "d" + die_size;
	}

	int get_passive_perception(combatant@ c) {
		if (@c == null) return 10;
		int passive = 10 + c.get_skill_bonus("Perception", ABILITY_WIS);
		// PHB 2024 Observant (para 7696): "+5 bonus to your Passive Perception
		// and Passive Investigation scores."
		if (c.has_feat("observant")) passive += 5;
		if (passive < 1) passive = 1;
		return passive;
	}

	int monk_martial_arts_die(combatant@ c) {
		if (@c == null) return 6;
		if (c.level >= 17) return 12;
		if (c.level >= 11) return 10;
		if (c.level >= 5) return 8;
		return 6;
	}

	// Xanathar's Storm Herald L3 Storm Aura (paras 416-422): Apply aura effect
	// based on environment choice. Called on rage entry + as BA each turn.
	// Xanathar's Storm Herald L10 Shielding Storm (para 428): "Each creature of your
	// choice has the damage resistance you gained from the Storm Soul feature while
	// the creature is in your Storm Aura." Called at turn start for refresh.
	void apply_shielding_storm(combatant@ c) {
		if (@c == null or @combat == null or !c.storm_aura_active or c.level < 10) return;
		for (uint si = 0; si < combat.combatants.length(); si++) {
			combatant@ ally = combat.combatants[si];
			if (@ally == null or ally.is_dead or ally.id == c.id) continue;
			if (ally.is_player != c.is_player) continue; // allies only
			if (feet_distance(c.x, c.y, ally.x, ally.y) > 10) continue;
			// Grant matching resistance
			if (c.storm_aura_damage_type == DMG_FIRE and !ally.shielding_storm_resistance) {
				ally.shielding_storm_resistance = true;
				ally.shielding_storm_type = DMG_FIRE;
				ally.fire_resistance = true;
			} else if (c.storm_aura_damage_type == DMG_LIGHTNING and !ally.shielding_storm_resistance) {
				ally.shielding_storm_resistance = true;
				ally.shielding_storm_type = DMG_LIGHTNING;
				ally.lightning_resistance = true;
			} else if (c.storm_aura_damage_type == DMG_COLD and !ally.shielding_storm_resistance) {
				ally.shielding_storm_resistance = true;
				ally.shielding_storm_type = DMG_COLD;
				ally.cold_resistance = true;
			}
		}
		// Remove resistance from allies who moved out of aura
		for (uint si = 0; si < combat.combatants.length(); si++) {
			combatant@ ally = combat.combatants[si];
			if (@ally == null or ally.id == c.id or !ally.shielding_storm_resistance) continue;
			if (ally.is_player != c.is_player or feet_distance(c.x, c.y, ally.x, ally.y) > 10 or ally.is_dead) {
				ally.shielding_storm_resistance = false;
				if (ally.shielding_storm_type == DMG_FIRE) ally.fire_resistance = false;
				else if (ally.shielding_storm_type == DMG_LIGHTNING) ally.lightning_resistance = false;
				else if (ally.shielding_storm_type == DMG_COLD) ally.cold_resistance = false;
				ally.shielding_storm_type = 0;
			}
		}
	}

	void apply_storm_aura_effect(combatant@ c) {
		if (@c == null or @combat == null or !c.storm_aura_active) return;
		int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_CON);
		// Damage/temp HP scaling: desert/tundra = flat 2/3/4/5/6 at L3/5/10/15/20
		// sea = 1d6/2d6/3d6/4d6 at L3/10/15/20
		if (c.storm_aura_damage_type == DMG_FIRE) {
			// Desert: all other creatures in 10ft take fire damage (no save)
			int flat_dmg = 2;
			if (c.level >= 20) flat_dmg = 6;
			else if (c.level >= 15) flat_dmg = 5;
			else if (c.level >= 10) flat_dmg = 4;
			else if (c.level >= 5) flat_dmg = 3;
			int hits = 0;
			for (uint si = 0; si < combat.combatants.length(); si++) {
				combatant@ t = combat.combatants[si];
				if (@t == null or t.is_dead or t.id == c.id) continue;
				if (feet_distance(c.x, c.y, t.x, t.y) > 10) continue;
				combat.apply_damage(t, flat_dmg, DMG_FIRE, c);
				hits++;
			}
			if (hits > 0) broadcast_announce(c.name + "'s Desert Storm Aura deals " + flat_dmg + " fire damage to " + hits + " creatures!", true);
		} else if (c.storm_aura_damage_type == DMG_LIGHTNING) {
			// Sea: one target in 10ft, DEX save, lightning damage
			int dice = 1;
			if (c.level >= 20) dice = 4;
			else if (c.level >= 15) dice = 3;
			else if (c.level >= 10) dice = 2;
			// Auto-pick nearest enemy
			combatant@ best = null;
			int best_dist = 999;
			for (uint si = 0; si < combat.combatants.length(); si++) {
				combatant@ t = combat.combatants[si];
				if (@t == null or t.is_dead or t.id == c.id) continue;
				if (t.is_player == c.is_player) continue; // skip allies
				int dist = feet_distance(c.x, c.y, t.x, t.y);
				if (dist <= 10 and dist < best_dist) { @best = t; best_dist = dist; }
			}
			if (@best != null) {
				int dmg = 0;
				for (int di = 0; di < dice; di++) dmg += random(1, 6);
				int dex_save = random(1, 20) + best.get_ability_mod(ABILITY_DEX);
				if (best.save_proficiencies[ABILITY_DEX] == 1) dex_save += best.proficiency;
				if (dex_save >= save_dc) dmg /= 2;
				if (dmg > 0) combat.apply_damage(best, dmg, DMG_LIGHTNING, c);
				string save_text = dex_save >= save_dc ? " (half, DEX save)" : "";
				broadcast_announce(c.name + "'s Sea Storm Aura strikes " + best.name + " for " + dmg + " lightning damage" + save_text + "!", true);
			}
		} else if (c.storm_aura_damage_type == DMG_COLD) {
			// Tundra: allies in 10ft gain temp HP
			int temp = 2;
			if (c.level >= 20) temp = 6;
			else if (c.level >= 15) temp = 5;
			else if (c.level >= 10) temp = 4;
			else if (c.level >= 5) temp = 3;
			int hits = 0;
			for (uint si = 0; si < combat.combatants.length(); si++) {
				combatant@ t = combat.combatants[si];
				if (@t == null or t.is_dead) continue;
				if (t.is_player != c.is_player) continue; // allies only
				if (feet_distance(c.x, c.y, t.x, t.y) > 10) continue;
				if (t.temp_hp < temp) { t.temp_hp = temp; hits++; }
			}
			if (hits > 0) broadcast_announce(c.name + "'s Tundra Storm Aura grants " + temp + " temp HP to " + hits + " allies!", true);
			// Xanathar's Storm Herald L14 Raging Storm Tundra (para 433-434): "you can
			// choose one creature you can see in the aura. That creature must succeed on
			// a Strength saving throw, or its speed is reduced to 0 until the start of
			// your next turn, as magical frost covers it."
			if (c.level >= 14) {
				combatant@ frost_target = null;
				int frost_best = 999;
				for (uint fi = 0; fi < combat.combatants.length(); fi++) {
					combatant@ ft = combat.combatants[fi];
					if (@ft == null or ft.is_dead or ft.id == c.id) continue;
					if (ft.is_player == c.is_player) continue; // enemies only
					int d = feet_distance(c.x, c.y, ft.x, ft.y);
					if (d <= 10 and d < frost_best) { frost_best = d; @frost_target = ft; }
				}
				if (@frost_target != null) {
					int frost_save = random(1, 20) + frost_target.get_save_bonus(ABILITY_STR);
					if (frost_save < save_dc) {
						frost_target.speed = 0;
						frost_target.movement_remaining = 0;
						broadcast_announce(c.name + "'s Raging Storm freezes " + frost_target.name + " in place! Speed reduced to 0.", false);
					} else {
						broadcast_announce(frost_target.name + " resists the Raging Storm's frost.", false);
					}
				}
			}
		}
	}

	int bardic_die_for_target(combatant@ c) {
		if (@c == null) return 0;
		return c.bardic_inspiration_die;
	}

	void clear_bardic_inspiration(combatant@ target, bool announce = false) {
		if (@target == null or target.bardic_inspiration_die <= 0) return;
		int old_die = target.bardic_inspiration_die;
		target.bardic_inspiration_die = 0;
		target.bardic_inspiration_source_id = 0;
		if (announce) {
			broadcast_announce("Bardic Inspiration fades from " + target.name + " (" + die_label(old_die) + ").", false);
		}
	}

	// Tasha's College of Eloquence L6 Unfailing Inspiration (para 1709-1711) and
	// L14 Infectious Inspiration (para 1716-1719). Called after a roll resolves
	// when Bardic Inspiration was consumed during that roll.
	void check_eloquence_inspiration(combatant@ c, pending_roll@ pr, bool roll_succeeded, int bardic_bonus) {
		if (@c == null or @pr == null or bardic_bonus <= 0) return;
		if (pr.bardic_die_used <= 0 or pr.bardic_source_id == 0) return;
		combatant@ source = combat.get_combatant(pr.bardic_source_id);
		if (@source == null or source.subclass != "College of Eloquence") return;

		// Unfailing Inspiration (L6): "When a creature adds one of your Bardic
		// Inspiration dice to its ability check, attack roll, or saving throw and
		// the roll fails, the creature can keep the Bardic Inspiration die."
		if (!roll_succeeded and source.level >= 6) {
			c.bardic_inspiration_die = pr.bardic_die_used;
			c.bardic_inspiration_source_id = pr.bardic_source_id;
			broadcast_announce(c.name + " keeps the Bardic Inspiration die — " + source.name + "'s Unfailing Inspiration!", false);
		}

		// Infectious Inspiration (L14): "When a creature within 60 feet of you adds
		// one of your Bardic Inspiration dice to its ability check, attack roll, or
		// saving throw and the roll succeeds, you can use your reaction to encourage
		// a different creature (other than yourself) within 60 feet..."
		if (roll_succeeded and source.level >= 14 and source.infectious_inspiration_uses > 0 and source.has_reaction) {
			combatant@ best = null;
			float best_d = 999;
			for (uint ii = 0; ii < combat.combatants.length(); ii++) {
				combatant@ ally = combat.combatants[ii];
				if (@ally == null or ally.is_dead or ally.id == source.id or ally.id == c.id) continue;
				if (ally.is_player != source.is_player) continue;
				if (ally.bardic_inspiration_die > 0) continue;
				float d = feet_distance(source.x, source.y, ally.x, ally.y);
				if (d <= 60 and d < best_d) { best_d = d; @best = ally; }
			}
			if (@best != null) {
				source.infectious_inspiration_uses--;
				source.has_reaction = false;
				best.bardic_inspiration_die = pr.bardic_die_used;
				best.bardic_inspiration_source_id = source.id;
				broadcast_announce(source.name + "'s Infectious Inspiration grants Bardic Inspiration to " + best.name + "! (" + source.infectious_inspiration_uses + " uses remain)", true);
			}
		}
	}

	void clear_help_effect(combatant@ helper, bool announce = false) {
		if (@helper == null or helper.help_target_id == 0) return;
		if (announce) broadcast_announce(helper.name + "'s Help effect expires.", false);
		helper.help_target_id = 0;
	}

	void clear_guiding_bolt_effect(combatant@ target, bool announce = false) {
		if (@target == null or !target.guiding_bolt_advantage) return;
		target.guiding_bolt_advantage = false;
		target.guiding_bolt_source_id = 0;
		if (announce) broadcast_announce("The guiding light around " + target.name + " fades.", false);
	}

	void clear_heroism_effect(combatant@ target, bool announce = false) {
		if (@target == null or target.heroism_source_id == 0) return;
		target.heroism_source_id = 0;
		target.heroism_temp_hp_amount = 0;
		target.remove_condition(COND_FRIGHTENED);
		if (announce) broadcast_announce("Heroism fades from " + target.name + ".", false);
	}

	void clear_pass_without_trace_effect(combatant@ target, bool announce = false) {
		if (@target == null or target.pass_without_trace_source_id == 0) return;
		target.pass_without_trace_bonus = 0;
		target.pass_without_trace_source_id = 0;
		if (announce) broadcast_announce("Pass without Trace fades from " + target.name + ".", false);
	}

	void reveal_hidden_combatant(combatant@ c, string reason = "") {
		if (@c == null or !c.is_hidden) return;
		c.is_hidden = false;
		c.hide_dc = 0;
		c.remove_condition(COND_HIDDEN);
		string text = c.name + " is no longer hidden";
		if (reason != "") text += " after " + reason;
		text += ".";
		broadcast_announce(text, false);
	}

	bool consume_help_advantage(combatant@ attacker, combatant@ target) {
		if (@attacker == null or @target == null or @combat == null) return false;
		if (combat.mode == "pvp") return false;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ helper = combat.combatants[i];
			if (@helper == null or helper.id == attacker.id or helper.is_dead) continue;
			if (!helper.is_conscious()) continue;
			if (helper.help_target_id != target.id) continue;
			if (combat.are_hostile(helper, attacker)) continue;
			clear_help_effect(helper, false);
			broadcast_announce(attacker.name + " gains advantage from " + helper.name + "'s Help against " + target.name + ".", false);
			return true;
		}
		return false;
	}

	bool has_pending_bardic_prompt() {
		return @current_bardic_prompt != null;
	}

	bool has_pending_lucky_prompt() {
		return @current_lucky_prompt != null;
	}

	bool has_pending_heroic_prompt() {
		return @current_heroic_prompt != null;
	}

	int get_weapon_attack_ability_mod(combatant@ c) {
		if (@c == null) return 0;
		if (attack_name_is_unarmed(c.main_hand) and c.class_name == "Monk") {
			return c.get_ability_mod(ABILITY_DEX);
		}
		if (c.main_hand_is_ranged) return c.get_ability_mod(ABILITY_DEX);
		int ability_mod = c.get_ability_mod(ABILITY_STR);
		if (c.main_hand_finesse) {
			int dex_mod = c.get_ability_mod(ABILITY_DEX);
			if (dex_mod > ability_mod) ability_mod = dex_mod;
		}
		// Xanathar's Hexblade L1 Hex Warrior (paras 2275-2277): CHA for melee
		// weapon attacks with non-two-handed weapons.
		if (c.class_name == "Warlock" and c.subclass == "Hexblade" and !c.main_hand_is_ranged and !weapon_qualifies_great_weapon_fighting(c.main_hand)) {
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			if (cha_mod > ability_mod) ability_mod = cha_mod;
		}
		// Basic Rules 2024 Shillelagh (para 14966-14974): "you can use your
		// spellcasting ability instead of Strength for the attack and damage rolls
		// of melee attacks using that weapon."
		if (c.shillelagh_active and !c.main_hand_is_ranged) {
			int spell_ability = c.spellcasting_ability;
			if (spell_ability < 0 or spell_ability > 5) spell_ability = ABILITY_WIS;
			int cast_mod = c.get_ability_mod(spell_ability);
			if (cast_mod > ability_mod) ability_mod = cast_mod;
		}
		return ability_mod;
	}

	int get_weapon_damage_ability_mod(combatant@ c) {
		return get_weapon_attack_ability_mod(c);
	}

	int get_spellcasting_ability_mod(combatant@ c) {
		if (@c == null) return 0;
		int spell_ability = c.spellcasting_ability;
		if (spell_ability < 0 or spell_ability > 5) spell_ability = ABILITY_INT;
		return c.get_ability_mod(spell_ability);
	}

	int get_critical_threshold(combatant@ attacker, pending_roll@ pr = null) {
		if (@attacker == null) return 20;
		bool weapon_attack = @pr == null ? false : pr.is_weapon_attack;
		if (attacker.class_name == "Fighter" and attacker.subclass == "Champion" and weapon_attack and attacker.level >= 3) {
			return 19;
		}
		// Hexblade Warlock: crit on 19-20 against cursed target
		if (attacker.class_name == "Warlock" and attacker.subclass == "The Hexblade" and @pr != null and attacker.hexblade_curse_target == pr.target_id) {
			return 19;
		}
		// Oath of Zeal (Grim Hollow) Mark of the Heretic: crit on 19+ vs marked target
		if (attacker.class_name == "Paladin" and attacker.subclass == "Oath of Zeal" and attacker.mark_of_heretic_active and @pr != null and attacker.mark_of_heretic_target == pr.target_id) {
			return 19;
		}
		// Valda's Spire Gunslinger L2 Critical Shot (paras 170-171): "Your attack rolls
		// with Ranged weapons can score a Critical Hit on a roll of 19 or 20 on the d20.
		// At Gunslinger level 9, your attack rolls with Ranged weapons score a Critical
		// Hit on a roll of 18-20. At Gunslinger level 17, they score a Critical Hit on
		// a roll of 17-20." Restricted to Ranged weapon attacks only.
		if (attacker.class_name == "Gunslinger" and weapon_attack and attacker.main_hand_is_ranged and attacker.gunslinger_crit_threshold < 20) {
			return attacker.gunslinger_crit_threshold;
		}
		// Xanathar's Oath of Conquest L20 Invincible Conqueror (para 2001):
		// "your melee weapon attacks score a critical hit on a roll of 19 or 20"
		if (attacker.invincible_conqueror_active and weapon_attack and !attacker.main_hand_is_ranged) {
			return 19;
		}
		return 20;
	}

	int get_life_domain_healing_bonus(combatant@ caster, spell_def@ spell, int cast_slot_level) {
		if (@caster == null or @spell == null) return 0;
		if (caster.class_name != "Cleric" or caster.subclass != "Life Domain") return 0;
		if (cast_slot_level <= 0 or spell.level <= 0) return 0;
		return 2 + cast_slot_level;
	}

	// Tasha's Circle of Stars L2 Starry Form — Chalice (para 2155-2159):
	// "Whenever you cast a spell using a spell slot that restores hit points to
	// a creature, you or another creature within 30 feet of you can regain hit
	// points equal to 1d8 plus your Wisdom modifier."
	// L10 Twinkling Constellations (para 2169-2173): scales to 2d8 + WIS.
	void try_chalice_healing(combatant@ caster) {
		if (@caster == null or @combat == null) return;
		if (!caster.starry_form_active or caster.starry_form_type != "Chalice") return;
		int wis_mod = caster.get_ability_mod(ABILITY_WIS);
		int dice_count = caster.level >= 10 ? 2 : 1;
		int heal = 0;
		for (int d = 0; d < dice_count; d++) heal += random(1, 8);
		heal += wis_mod;
		if (heal < 1) heal = 1;
		// Find the most-injured ally within 30ft (or self)
		combatant@ best_target = null;
		int worst_deficit = 0;
		for (uint chi = 0; chi < combat.combatants.length(); chi++) {
			combatant@ ally = combat.combatants[chi];
			if (@ally == null or ally.is_dead or ally.current_hp <= 0) continue;
			if (ally.is_player != caster.is_player and ally.id != caster.id) continue;
			if (feet_distance(caster.x, caster.y, ally.x, ally.y) > 30) continue;
			int deficit = ally.max_hp - ally.current_hp;
			if (deficit > worst_deficit) {
				worst_deficit = deficit;
				@best_target = ally;
			}
		}
		// If no injured ally, heal self (even if at full, apply_healing handles cap)
		if (@best_target == null) @best_target = caster;
		int eff = combat.apply_healing(best_target, heal);
		if (eff > 0) {
			record_effective_healing(caster.player_username, eff);
			broadcast_announce("Chalice form healing: " + best_target.name + " regains " + eff + " HP!", false);
		}
	}

	// Xanathar's Circle of the Shepherd L2 Unicorn Spirit Totem (para 923):
	// "if you cast a spell using a spell slot that restores hit points to any
	// creature inside or outside the aura, each creature of your choice in
	// the aura also regains hit points equal to your druid level."
	void try_unicorn_totem_heal(combatant@ caster) {
		if (@caster == null or @combat == null) return;
		if (caster.class_name != "Druid" or caster.subclass != "Circle of the Shepherd") return;
		if (!caster.shepherd_circle_active or caster.shepherd_totem_type != 2) return;
		int heal_amt = caster.level;
		if (heal_amt <= 0) return;
		for (uint ui = 0; ui < combat.combatants.length(); ui++) {
			combatant@ ally = combat.combatants[ui];
			if (@ally == null or ally.is_dead) continue;
			if (ally.is_player != caster.is_player) continue;
			if (feet_distance(caster.x, caster.y, ally.x, ally.y) > 30) continue;
			if (ally.current_hp >= ally.max_hp) continue;
			int eff = combat.apply_healing(ally, heal_amt);
			if (eff > 0) {
				record_effective_healing(caster.player_username, eff);
			}
		}
		broadcast_announce("The Unicorn Spirit heals allies in the aura for " + heal_amt + " HP!", false);
	}

	// Xanathar's Divine Soul Sorcerer L6 Empowered Healing (paras 2611-2620):
	// "whenever you or an ally within 5 feet of you rolls dice to determine the
	// number of hit points a spell restores, you can spend 1 sorcery point to
	// reroll any number of those dice once."
	// Helper: given a raw heal total from dice_count dice of die_size, simulate
	// rerolling dice that rolled below average, deduct 1 SP, and return the
	// potentially improved total.
	int apply_empowered_healing(combatant@ caster, int heal_amount, int dice_count, int die_size) {
		if (@caster == null) return heal_amount;
		if (!caster.empowered_healing_active) return heal_amount;
		if (caster.sorcery_points <= 0) return heal_amount;
		// Calculate average threshold (below which we reroll)
		int avg = (die_size + 1) / 2;  // e.g., d8 → 4, d4 → 2
		// Simulate: for each die, if it "would have" rolled below average, reroll.
		// Since we only have the total, we reconstruct approximate per-die values.
		// Deduct the old total and rebuild with rerolls for dice below average.
		int improved = 0;
		int rerolled_any = 0;
		for (int d = 0; d < dice_count; d++) {
			int roll = random(1, die_size);
			if (roll < avg) {
				int reroll = random(1, die_size);
				improved += reroll;
				rerolled_any++;
			} else {
				improved += roll;
			}
		}
		if (rerolled_any > 0) {
			caster.sorcery_points -= 1;
			broadcast_announce(caster.name + " uses Empowered Healing (1 SP) to reroll " + rerolled_any + " healing di" + (rerolled_any == 1 ? "e" : "ce") + "!", false);
			return improved;
		}
		return heal_amount;
	}

	int spiritual_weapon_damage_count_for_slot(int slot_level) {
		if (slot_level < 2) slot_level = 2;
		return 1 + ((slot_level - 2) / 2);
	}

	void clear_spiritual_weapon_effect(combatant@ caster, bool announce = false) {
		if (@caster == null or !caster.spiritual_weapon_active) return;
		caster.spiritual_weapon_active = false;
		caster.spiritual_weapon_slot_level = 0;
		if (announce) {
			broadcast_announce(caster.name + "'s Spiritual Weapon fades.", false);
		}
	}

	void maybe_apply_on_kill_features(combatant@ attacker, combatant@ target) {
		if (@attacker == null or @target == null or @combat == null) return;
		if (!combat.are_hostile(attacker, target)) return;
		if (target.current_hp > 0 and !target.is_dead) return;
		record_monster_defeat(attacker, target);

		if (attacker.class_name == "Warlock" and attacker.subclass == "Fiend Patron") {
			int temp_hp = attacker.level + attacker.get_ability_mod(ABILITY_CHA);
			if (temp_hp < 1) temp_hp = 1;
			if (temp_hp > attacker.temp_hp) {
				attacker.temp_hp = temp_hp;
				broadcast_announce(attacker.name + " gains " + temp_hp + " temporary hit points from Fiend Patron.", false);
			}
		}

		// Xanathar's Hexblade L1 Hexblade's Curse on-kill heal + L14 Master of Hexes transfer
		// (para 2779-2784): "you regain hit points equal to your warlock level + your Charisma
		// modifier" when the cursed target drops to 0 HP.
		if (target.is_dead) {
			for (uint hx = 0; hx < combat.combatants.length(); hx++) {
				combatant@ hxc = combat.combatants[hx];
				if (@hxc == null or hxc.is_dead) continue;
				if (hxc.class_name != "Warlock" or hxc.subclass != "The Hexblade") continue;
				if (hxc.hexblade_curse_target != target.id) continue;
				// Heal on cursed target death
				int hx_heal = hxc.level + hxc.get_ability_mod(ABILITY_CHA);
				if (hx_heal < 1) hx_heal = 1;
				int healed = combat.apply_healing(hxc, hx_heal);
				if (healed > 0) broadcast_announce(hxc.name + "'s Hexblade's Curse restores " + healed + " HP from the kill!", false);
				// L14 Master of Hexes (para 2794-2795): "you can move the curse to a different
				// creature you can see within 30 feet. You don't regain HP from the previous
				// target." Auto-transfer to nearest living enemy within 30ft.
				if (hxc.master_of_hexes_active) {
					combatant@ new_target = null;
					float best_dist = 999;
					for (uint nt = 0; nt < combat.combatants.length(); nt++) {
						combatant@ nt_c = combat.combatants[nt];
						if (@nt_c == null or nt_c.is_dead or nt_c.id == target.id) continue;
						if (nt_c.is_player == hxc.is_player) continue; // Only enemies
						float nx = float(nt_c.x - hxc.x);
						float ny = float(nt_c.y - hxc.y);
						float nd = sqrt(nx * nx + ny * ny) * 5.0f;
						if (nd <= 30 and nd < best_dist) { best_dist = nd; @new_target = nt_c; }
					}
					if (@new_target != null) {
						hxc.hexblade_curse_target = new_target.id;
						broadcast_announce(hxc.name + "'s Master of Hexes transfers the curse to " + new_target.name + "!", true);
					} else {
						hxc.hexblade_curse_target = 0;
					}
				} else {
					hxc.hexblade_curse_target = 0;
				}
			}
		}

		// Sword Coast: Way of the Long Death L3 Touch of Death — temp HP = WIS mod + monk level when reducing creature to 0 HP within 5ft
		if (attacker.class_name == "Monk" and attacker.subclass == "Way of the Long Death" and attacker.level >= 3) {
			if (feet_distance(attacker.x, attacker.y, target.x, target.y) <= 5) {
				int td_temp = attacker.get_ability_mod(ABILITY_WIS) + attacker.level;
				if (td_temp < 1) td_temp = 1;
				if (td_temp > attacker.temp_hp) {
					attacker.temp_hp = td_temp;
					broadcast_announce(attacker.name + "'s Touch of Death grants " + td_temp + " temp HP!", false);
				}
			}
		}

		// Tasha's Phantom Rogue L9 Tokens of the Departed (para 3454-3460): "as a
		// reaction when a creature you can see dies within 30 feet of you, you can
		// open your free hand and cause a Tiny trinket to appear." Max = proficiency.
		// Also scan ALL Phantom Rogues, not just the attacker.
		if (target.is_dead) {
			for (uint st = 0; st < combat.combatants.length(); st++) {
				combatant@ phantom = combat.combatants[st];
				if (@phantom == null or phantom.is_dead) continue;
				if (phantom.class_name != "Rogue" or phantom.subclass != "Phantom") continue;
				if (phantom.level < 9) continue;
				if (phantom.soul_trinkets >= phantom.soul_trinkets_max) continue;
				if (!phantom.has_reaction) continue;
				int pd = feet_distance(phantom.x, phantom.y, target.x, target.y);
				if (pd > 30) continue;
				phantom.soul_trinkets++;
				phantom.has_reaction = false;
				broadcast_announce(phantom.name + " claims a soul trinket from " + target.name + "'s departing soul! (" + phantom.soul_trinkets + "/" + phantom.soul_trinkets_max + " trinkets)", false);
			}
		}

		// PHB 2024 Hunter's Mark (para 13825-13826): "If the target drops to 0 Hit
		// Points before this spell ends, you can use a Bonus Action on a later turn
		// to mark a new creature." Auto-transfer to nearest hostile within 90ft
		// (following Hexblade's Curse pattern for bot/NPC compatibility).
		if (target.is_dead) {
			for (uint hm = 0; hm < combat.combatants.length(); hm++) {
				combatant@ hmc = combat.combatants[hm];
				if (@hmc == null or hmc.is_dead) continue;
				if (hmc.hunters_mark_target_id != target.id) continue;
				// Find nearest hostile within 90ft
				combatant@ hm_new = null;
				float hm_best = 999;
				for (uint hmt = 0; hmt < combat.combatants.length(); hmt++) {
					combatant@ hmt_c = combat.combatants[hmt];
					if (@hmt_c == null or hmt_c.is_dead or hmt_c.id == target.id) continue;
					if (!combat.are_hostile(hmc, hmt_c)) continue;
					int hm_dist = feet_distance(hmc.x, hmc.y, hmt_c.x, hmt_c.y);
					if (hm_dist <= 90 and float(hm_dist) < hm_best) {
						hm_best = float(hm_dist);
						@hm_new = hmt_c;
					}
				}
				if (@hm_new != null) {
					hmc.hunters_mark_target_id = hm_new.id;
					broadcast_announce(hmc.name + "'s Hunter's Mark transfers to " + hm_new.name + "!", false);
				} else {
					hmc.hunters_mark_target_id = 0;
				}
			}
		}

		// Basic Rules 2024 Hex (para 13730): "If the target drops to 0 Hit Points
		// before this spell ends, you can use a Bonus Action on a later turn to
		// curse a new creature." Auto-transfer to nearest hostile within 90ft.
		if (target.is_dead) {
			for (uint hx2 = 0; hx2 < combat.combatants.length(); hx2++) {
				combatant@ hxc2 = combat.combatants[hx2];
				if (@hxc2 == null or hxc2.is_dead) continue;
				if (hxc2.hex_target_id != target.id) continue;
				combatant@ hex_new = null;
				float hex_best = 999;
				for (uint hxt = 0; hxt < combat.combatants.length(); hxt++) {
					combatant@ hxt_c = combat.combatants[hxt];
					if (@hxt_c == null or hxt_c.is_dead or hxt_c.id == target.id) continue;
					if (!combat.are_hostile(hxc2, hxt_c)) continue;
					int hx_dist = feet_distance(hxc2.x, hxc2.y, hxt_c.x, hxt_c.y);
					if (hx_dist <= 90 and float(hx_dist) < hex_best) {
						hex_best = float(hx_dist);
						@hex_new = hxt_c;
					}
				}
				if (@hex_new != null) {
					hxc2.hex_target_id = hex_new.id;
					broadcast_announce(hxc2.name + "'s Hex transfers to " + hex_new.name + "!", false);
				} else {
					hxc2.hex_target_id = 0;
				}
			}
		}

		// Xanathar's Grave Domain L17 Keeper of Souls (para 802-803): "At the start
		// of your turn, if there is a creature that has died since the start of your
		// last turn within 60 feet... you or one creature within 60 feet regains HP
		// equal to the number of Hit Dice the creature had." Approximated: triggers
		// immediately on enemy death, once per round, heal = target level/CR Hit Dice.
		if (target.is_dead and @combat != null) {
			for (uint kos = 0; kos < combat.combatants.length(); kos++) {
				combatant@ kc = combat.combatants[kos];
				if (@kc == null or kc.is_dead) continue;
				if (kc.class_name != "Cleric" or kc.subclass != "Grave Domain") continue;
				if (!kc.keeper_of_souls_active or kc.keeper_of_souls_used_this_turn) continue;
				float kd_x = float(kc.x - target.x);
				float kd_y = float(kc.y - target.y);
				float kd_dist = sqrt(kd_x * kd_x + kd_y * kd_y) * 5.0f;
				if (kd_dist <= 60) {
					// Heal the most injured ally within 60ft (or self)
					int heal_amount = target.level > 0 ? target.level : 1;
					combatant@ heal_target = null;
					int worst_deficit = 0;
					for (uint ht = 0; ht < combat.combatants.length(); ht++) {
						combatant@ ally = combat.combatants[ht];
						if (@ally == null or ally.is_dead or ally.current_hp >= ally.max_hp) continue;
						if (ally.is_player != kc.is_player) continue; // Only allies
						float hd_x = float(kc.x - ally.x);
						float hd_y = float(kc.y - ally.y);
						float hd_dist = sqrt(hd_x * hd_x + hd_y * hd_y) * 5.0f;
						if (hd_dist > 60) continue;
						int deficit = ally.max_hp - ally.current_hp;
						if (deficit > worst_deficit) { worst_deficit = deficit; @heal_target = ally; }
					}
					if (@heal_target != null) {
						int healed = combat.apply_healing(heal_target, heal_amount);
						kc.keeper_of_souls_used_this_turn = true;
						broadcast_announce(kc.name + "'s Keeper of Souls restores " + healed + " HP to " + heal_target.name + "!", false);
					}
					break; // Only one Keeper of Souls triggers
				}
			}
		}
	}

	void clear_readied_action(combatant@ c) {
		if (@c == null) return;
		c.readied_action = -1;
		c.readied_trigger = "";
		c.readied_target_id = 0;
	}

	bool attack_name_is_unarmed(string attack_name) {
		string lc = attack_name.lower();
		return lc == "unarmed" or lc.find("unarmed") >= 0 or lc.find("flurry") >= 0 or lc.find("fist") >= 0;
	}

	bool attack_name_is_ranged(string attack_name) {
		string lc = attack_name.lower();
		return lc.find("bow") >= 0 or lc.find("crossbow") >= 0 or lc.find("ray") >= 0 or lc.find("rock") >= 0 or lc.find("bolt") >= 0 or lc.find("arrow") >= 0 or lc.find("sling") >= 0 or lc.find("javelin") >= 0 or lc.find("dart") >= 0 or lc.find("spit") >= 0;
	}

	bool weapon_qualifies_great_weapon_fighting(string attack_name) {
		string lc = attack_name.lower();
		return lc == "glaive" or lc == "greataxe" or lc == "greatsword" or lc == "halberd" or lc == "maul" or lc == "pike";
	}

	int roll_single_attack_damage_die(combatant@ attacker, pending_roll@ pr) {
		if (@pr == null) return 0;
		int roll = random(1, pr.damage_dice_sides);
		if (@attacker != null and attacker.has_feat("great_weapon_fighting") and weapon_qualifies_great_weapon_fighting(pr.attack_name) and roll < 3) {
			roll = 3;
		}
		// PHB 2024 Elemental Adept (para 7610): "when you roll damage for a spell
		// you cast that deals damage of that type, you can treat any 1 on a damage
		// die as a 2."
		if (pr.is_spell_effect and roll == 1) {
			combatant@ caster = @attacker != null ? attacker : combat.get_combatant(pr.combatant_id);
			if (@caster != null) {
				int dt = pr.metamagic_transmuted ? pr.metamagic_transmuted_type : pr.damage_type;
				if ((dt == DMG_ACID and caster.elemental_adept_acid) or
					(dt == DMG_COLD and caster.elemental_adept_cold) or
					(dt == DMG_FIRE and caster.elemental_adept_fire) or
					(dt == DMG_LIGHTNING and caster.elemental_adept_lightning) or
					(dt == DMG_THUNDER and caster.elemental_adept_thunder)) {
					roll = 2;
				}
			}
		}
		return roll;
	}

	int roll_attack_damage_natural(combatant@ attacker, pending_roll@ pr) {
		if (@pr == null) return 0;
		int total = 0;
		int min_die = pr.damage_dice_sides + 1; // track lowest die for Piercer
		for (int di = 0; di < pr.damage_dice_count; di++) {
			int r = roll_single_attack_damage_die(attacker, pr);
			total += r;
			if (r < min_die) min_die = r;
		}
		// PHB 2024 Piercer (para 7707): "Once per turn when you hit a creature with
		// an attack that deals Piercing damage, you can reroll one of the attack's
		// damage dice, and you must use the new roll."
		if (@attacker != null and attacker.has_feat("piercer") and pr.damage_type == DMG_PIERCING and !attacker.piercer_reroll_used_this_turn and pr.damage_dice_count > 0) {
			attacker.piercer_reroll_used_this_turn = true;
			int new_roll = roll_single_attack_damage_die(attacker, pr);
			int old_min = min_die;
			total = total - old_min + new_roll;
			broadcast_announce(attacker.name + "'s Piercer rerolls lowest damage die (" + old_min + " -> " + new_roll + ").", false);
		}
		if (@attacker != null and attacker.has_feat("savage_attacker") and !attacker.savage_attacker_used and pr.damage_dice_count > 0) {
			int reroll_total = 0;
			for (int di = 0; di < pr.damage_dice_count; di++) {
				reroll_total += roll_single_attack_damage_die(attacker, pr);
			}
			attacker.savage_attacker_used = true;
			int chosen_total = reroll_total > total ? reroll_total : total;
			broadcast_announce(attacker.name + " uses Savage Attacker and keeps " + chosen_total + " weapon damage instead of " + (reroll_total > total ? total : reroll_total) + ".", false);
			total = chosen_total;
		}
		return total;
	}

	bool has_effective_advantage(pending_roll@ pr) {
		return @pr != null and pr.has_advantage and !pr.has_disadvantage;
	}

	bool has_effective_disadvantage(pending_roll@ pr) {
		return @pr != null and pr.has_disadvantage and !pr.has_advantage;
	}

	bool can_use_savage_attacker(combatant@ attacker, pending_roll@ pr) {
		return @attacker != null and @pr != null and !pr.is_spell_effect and pr.damage_dice_count > 0 and attacker.has_feat("savage_attacker") and !attacker.savage_attacker_used;
	}

	string build_roll_request_reason(pending_roll@ pr) {
		if (@pr == null) return "Roll";
		string reason = pr.reason;
		if (pr.roll_type == ROLL_ATTACK and (has_effective_advantage(pr) or has_effective_disadvantage(pr))) {
			string mode = has_effective_advantage(pr) ? "advantage" : "disadvantage";
			reason += ". Roll " + (pr.rolls_completed + 1) + " of 2 for " + mode;
		}
		else if (pr.roll_type == ROLL_DAMAGE) {
			if (pr.damage_dice_count > 1) reason += ". Damage die " + (pr.rolls_completed + 1) + " of " + pr.damage_dice_count;
			if (pr.savage_attacker_reroll) reason += ". Savage Attacker reroll";
		}
		return reason;
	}

	int build_roll_request_modifier(pending_roll@ pr) {
		if (@pr == null) return 0;
		if (pr.roll_type == ROLL_DAMAGE) return 0;
		return pr.modifier;
	}

	void send_roll_request(user@ u, pending_roll@ pr) {
		if (@u == null or @pr == null) return;
		u.send({
			{"type", message_types::roll_request},
			{"roll_type", pr.roll_type},
			{"dice", pr.dice_sides},
			{"count", 1},
			{"modifier", build_roll_request_modifier(pr)},
			{"reason", build_roll_request_reason(pr)},
			{"player", pr.player_username}
		});
	}

	bool spell_uses_attack_roll(spell_def@ spell) {
		return @spell != null and spell.damage_count > 0 and spell.save_type < 0 and spell.id != "magic_missile";
	}

	int spell_effective_range(combatant@ caster, spell_def@ spell) {
		if (@spell == null) return 0;
		if (spell.id == "true_strike" and @caster != null and caster.main_hand_range > 0) return caster.main_hand_range;
		return spell.range;
	}

	bool spell_attack_is_ranged(combatant@ caster, spell_def@ spell, int effective_range) {
		if (@spell == null) return effective_range > 5;
		if (spell.id == "thorn_whip" or spell.id == "shocking_grasp" or spell.id == "true_strike") return false;
		if (spell.id == "starry_wisp" or spell.id == "guiding_bolt" or spell.id == "fire_bolt" or spell.id == "ray_of_frost" or spell.id == "chill_touch" or spell.id == "eldritch_blast" or spell.id == "scorching_ray" or spell.id == "sorcerous_burst") return true;
		return effective_range > 5;
	}

	int get_spell_attack_instance_count(spell_def@ spell, combatant@ caster, int cast_slot_level) {
		if (@spell == null or @caster == null) return 1;
		if (spell.id == "eldritch_blast") {
			if (caster.level >= 17) return 4;
			if (caster.level >= 11) return 3;
			if (caster.level >= 5) return 2;
			return 1;
		}
		if (spell.id == "scorching_ray") {
			int extra_rays = cast_slot_level - spell.level;
			if (extra_rays < 0) extra_rays = 0;
			return 3 + extra_rays;
		}
		return 1;
	}

	int get_spell_damage_dice_count_for_cast(spell_def@ spell, combatant@ caster, int cast_slot_level) {
		if (@spell == null or @caster == null) return 0;
		if (spell.id == "eldritch_blast") return spell.damage_count;
		int upcast_levels = cast_slot_level - spell.level;
		if (upcast_levels < 0) upcast_levels = 0;
		if (spell.level == 0 and spell.scales_with_level) {
			return cantrip_dice_count(spell.damage_count, caster.level);
		}
		int dice_count = spell.damage_count;
		if (spell.upcast_extra_dice > 0 and upcast_levels > 0) dice_count += upcast_levels * spell.upcast_extra_dice;
		return dice_count;
	}

	int get_spell_damage_die_sides_for_cast(spell_def@ spell, combatant@ primary_target) {
		if (@spell == null) return 0;
		if (spell.id == "toll_the_dead" and @primary_target != null and primary_target.current_hp < primary_target.max_hp) return 12;
		return spell.damage_dice;
	}

	void queue_spell_attack_roll(user@ u, combatant@ caster, combatant@ target, spell_def@ spell, int attack_bonus, int damage_count, int damage_sides, int damage_modifier, int remaining_attacks, bool adv = false, bool disadv = false, string next_target_ids_csv = "") {
		if (@u == null or @caster == null or @target == null or @spell == null) return;
		pending_roll pr;
		pr.combatant_id = caster.id;
		pr.player_username = caster.player_username;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = attack_bonus;
		pr.reason = spell.name + " attack against " + target.name;
		pr.target_id = target.id;
		pr.attack_name = spell.name;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.damage_dice_count = damage_count;
		pr.damage_dice_sides = damage_sides;
		pr.damage_modifier = damage_modifier;
		pr.damage_type = spell.damage_type;
		pr.attacks_remaining = remaining_attacks;
		pr.is_spell_effect = true;
		pr.spell_uses_attack_roll = true;
		pr.spell_id = spell.id;
		pr.spell_name = spell.name;
		pr.next_target_ids_csv = next_target_ids_csv;
		// Snapshot metamagic flags for spell attack rolls
		pr.metamagic_empowered = caster.metamagic_empowered_active;
		pr.metamagic_seeking = caster.metamagic_seeking_active;
		pr.metamagic_transmuted = caster.metamagic_transmuted_active;
		pr.metamagic_transmuted_type = caster.metamagic_transmuted_target_type;
		@current_roll = pr;
		send_roll_request(u, pr);
	}

	void queue_spell_damage_roll(user@ u, combatant@ caster, combatant@ center_target, spell_def@ spell, int damage_count, int damage_sides, int damage_modifier, bool requires_save = false, int save_type = -1, int save_dc = 0) {
		if (@u == null or @caster == null or @spell == null) return;
		pending_roll pr;
		pr.combatant_id = caster.id;
		pr.player_username = caster.player_username;
		pr.roll_type = ROLL_DAMAGE;
		pr.dice_sides = damage_sides;
		pr.modifier = damage_modifier;
		pr.reason = spell.name + " damage";
		pr.target_id = @center_target != null ? center_target.id : 0;
		pr.attack_name = spell.name;
		pr.damage_dice_count = damage_count;
		pr.damage_dice_sides = damage_sides;
		pr.damage_modifier = damage_modifier;
		pr.damage_type = spell.damage_type;
		pr.is_spell_effect = true;
		pr.spell_uses_attack_roll = false;
		pr.spell_requires_save = requires_save;
		pr.spell_id = spell.id;
		pr.spell_name = spell.name;
		pr.spell_save_type = save_type;
		pr.spell_save_dc = save_dc;
		pr.spell_is_aoe = spell.is_aoe;
		pr.spell_aoe_radius = spell.aoe_radius;
		// Snapshot metamagic flags onto the pending_roll
		pr.metamagic_careful = caster.metamagic_careful_active;
		pr.metamagic_heightened = caster.metamagic_heightened_active;
		pr.metamagic_empowered = caster.metamagic_empowered_active;
		pr.metamagic_seeking = caster.metamagic_seeking_active;
		pr.metamagic_extended = caster.metamagic_extended_active;
		pr.metamagic_transmuted = caster.metamagic_transmuted_active;
		pr.metamagic_transmuted_type = caster.metamagic_transmuted_target_type;
		@current_roll = pr;
		send_roll_request(u, pr);
	}

	bool start_followup_spell_attack(combatant@ caster, pending_roll@ pr, combatant@ preferred_target) {
		if (@caster == null or @pr == null or !pr.is_spell_effect or pr.attacks_remaining <= 0) return false;
		user@ caster_user = find_user_for_combatant(caster);
		if (@caster_user == null or caster_user.is_bot) return false;
		spell_def@ spell = get_spell(pr.spell_id);
		if (@spell == null) return false;
		// Distribution chain: if next_target_ids_csv is non-empty, pop the next id from
		// the front of the queue and target that creature instead of the preferred_target.
		// This is how Magic Missile / Scorching Ray / Eldritch Blast send rays at different
		// creatures across the multi-attack chain.
		string remaining_csv = pr.next_target_ids_csv;
		combatant@ target = preferred_target;
		while (remaining_csv != "") {
			int comma = remaining_csv.find(",");
			string first_id_str;
			if (comma < 0) { first_id_str = remaining_csv; remaining_csv = ""; }
			else { first_id_str = remaining_csv.substr(0, comma); remaining_csv = remaining_csv.substr(comma + 1); }
			uint next_id = uint(parse_nonnegative_int(first_id_str));
			combatant@ candidate = combat.get_combatant(next_id);
			if (@candidate != null and !candidate.is_dead and combat.are_hostile(caster, candidate) and combat.can_see(caster, candidate)) {
				@target = candidate;
				break;
			}
			// Skip dead/invisible targets — keep popping
		}
		if (@target == null or target.is_dead or !combat.are_hostile(caster, target)) @target = find_nearest_hostile_target(caster);
		if (@target == null or target.is_dead) return false;
		int effective_range = spell_effective_range(caster, spell);
		int dist = feet_distance(caster.x, caster.y, target.x, target.y);
		if (effective_range > 0 and dist > effective_range) return false;
		if (!combat.can_see(caster, target)) return false;
		bool adv = false;
		bool disadv = false;
		apply_attack_advantage_state(caster, target, dist, spell_attack_is_ranged(caster, spell, effective_range), adv, disadv, true);
		queue_spell_attack_roll(caster_user, caster, target, spell, pr.modifier, pr.damage_dice_count, pr.damage_dice_sides, pr.damage_modifier, pr.attacks_remaining - 1, adv, disadv, remaining_csv);
		return true;
	}

	void apply_spell_hit_effects(combatant@ caster, combatant@ target, pending_roll@ pr) {
		if (@caster == null or @target == null or @pr == null or !pr.is_spell_effect) return;
		if (pr.spell_id == "guiding_bolt") {
			target.guiding_bolt_advantage = true;
			target.guiding_bolt_source_id = caster.id;
			broadcast_announce(target.name + " glows with guiding light. The next attack against them has advantage.", false);
		}
		else if (pr.spell_id == "ray_of_frost") {
			target.movement_remaining -= 10;
			if (target.movement_remaining < 0) target.movement_remaining = 0;
			broadcast_announce(target.name + " is slowed by Ray of Frost.", false);
		}
		else if (pr.spell_id == "shocking_grasp") {
			target.has_reaction = false;
			broadcast_announce(target.name + " loses its reaction from Shocking Grasp.", false);
		}
		else if (pr.spell_id == "thorn_whip") {
			int pull_dx = 0;
			int pull_dy = 0;
			if (target.x > caster.x) pull_dx = -1;
			else if (target.x < caster.x) pull_dx = 1;
			if (target.y > caster.y) pull_dy = -1;
			else if (target.y < caster.y) pull_dy = 1;
			target.x += pull_dx * 2;
			target.y += pull_dy * 2;
			if (target.x < 0) target.x = 0;
			if (target.y < 0) target.y = 0;
			if (target.x >= combat.map_width) target.x = combat.map_width - 1;
			if (target.y >= combat.map_height) target.y = combat.map_height - 1;
			broadcast_announce(caster.name + " pulls " + target.name + " 10 feet closer with Thorn Whip.", false);
		}
		else if (pr.spell_id == "chill_touch") {
			// Basic Rules 2024 Chill Touch (para 12055-12062): "it can't regain
			// Hit Points until the end of your next turn."
			target.chill_touch_source_id = caster.id;
			target.chill_touch_caster_turns = 2;
			broadcast_announce(target.name + " is chilled by necrotic energy — can't regain Hit Points until end of " + caster.name + "'s next turn.", false);
		}
		else if (pr.spell_id == "starry_wisp") {
			// Basic Rules 2024 Starry Wisp (para 14595-14602): "until the end of
			// your next turn, it emits Dim Light in a 10-foot radius and can't
			// benefit from the Invisible condition."
			if (target.has_condition(COND_INVISIBLE)) {
				target.remove_condition(COND_INVISIBLE);
				target.is_hidden = false;
				target.greater_invisibility_active = false;
				broadcast_announce(target.name + "'s invisibility is stripped by Starry Wisp!", false);
			}
			target.starry_wisp_no_invis = true;
			target.starry_wisp_source_id = caster.id;
			target.starry_wisp_caster_turns = 2;
			broadcast_announce(target.name + " is illuminated by Starry Wisp — can't benefit from the Invisible condition.", false);
		}
	}

	void resolve_spell_save_damage_roll(combatant@ caster, pending_roll@ pr, int natural_roll) {
		if (@caster == null or @pr == null or !pr.is_spell_effect or !pr.spell_requires_save or @combat == null) return;
		// PHB 2024 Wizard Evoker L14 Overchannel (para 9265-9268): "When you cast a
		// Wizard spell with a spell slot of levels 1-5 that deals damage, you can deal
		// maximum damage with that spell on the turn you cast it. The first time you
		// do so, you suffer no adverse effect. If you use this feature again before you
		// finish a Long Rest, you take 2d12 Necrotic damage for each level of the spell
		// slot immediately after you cast it. This damage ignores Resistance and
		// Immunity. Each time you use this feature again before finishing a Long Rest,
		// the Necrotic damage per spell level increases by 1d12."
		spell_def@ oc_spell = get_spell(pr.spell_id);
		bool overchannel_used_now = false;
		int overchannel_spell_level_used = 0;
		if (caster.overchannel_pending and @oc_spell != null and oc_spell.level >= 1 and oc_spell.level <= 5 and caster.class_name == "Wizard" and caster.subclass == "Evoker" and caster.level >= 14) {
			int max_dice = pr.damage_dice_count * pr.damage_dice_sides;
			if (max_dice > natural_roll) natural_roll = max_dice;
			caster.overchannel_pending = false;
			overchannel_used_now = true;
			overchannel_spell_level_used = oc_spell.level;
			broadcast_announce(caster.name + " unleashes Overchannel — maximum damage!", true);
		}
		// Metamagic: Empowered Spell — reroll CHA mod damage dice (para 6985-6986)
		if (pr.metamagic_empowered and caster.class_name == "Sorcerer") {
			int cha_mod_empower = caster.get_ability_mod(ABILITY_CHA);
			if (cha_mod_empower < 1) cha_mod_empower = 1;
			// Reroll cha_mod_empower of the damage dice (take new results unconditionally per source)
			int rerolled = 0;
			for (int eri = 0; eri < cha_mod_empower and eri < pr.damage_dice_count; eri++) {
				natural_roll += random(1, pr.damage_dice_sides); // Add a new roll
				rerolled++;
			}
			// Subtract the worst dice from the original roll (approximation: add extra then keep best)
			// Simpler: just add cha_mod bonus dice and average out — source says reroll, we approximate
			// by rolling extra dice and keeping the count. Net effect: add ~CHA_mod * avg_die/2 damage.
			// For true accuracy, track individual dice (complex). Acceptable approximation for now.
			caster.metamagic_empowered_active = false;
			broadcast_announce(caster.name + "'s Empowered Spell rerolls " + rerolled + " damage " + (rerolled == 1 ? "die" : "dice") + "!", false);
		}
		int base_damage = natural_roll + pr.damage_modifier;
		if (base_damage < 1) base_damage = 1;
		// PHB 2024 Cleric L7 Blessed Strikes — Potent Spellcasting (para 3620):
		// "Add your Wisdom modifier to the damage you deal with any Cleric cantrip."
		// Check the spell is a Cleric-list cantrip (level 0 with cleric in class_list).
		spell_def@ pcs_spell = get_spell(pr.spell_id);
		if (@pcs_spell != null and pcs_spell.level == 0 and pcs_spell.class_list.find("cleric") >= 0) {
			int pcs_bonus = caster.potent_spellcasting_bonus();
			if (pcs_bonus > 0) base_damage += pcs_bonus;
		}
		// PHB 2024 Druid L7 Elemental Fury — Potent Spellcasting (para 4432): "Add your
		// Wisdom modifier to the damage you deal with any Druid cantrip." Same gating
		// as Cleric — only when the chosen Elemental Fury option is potent_spellcasting.
		if (@pcs_spell != null and pcs_spell.level == 0 and pcs_spell.class_list.find("druid") >= 0) {
			int dpc_bonus = caster.druid_potent_spellcasting_bonus();
			if (dpc_bonus > 0) base_damage += dpc_bonus;
		}
		// PHB 2024 Wizard Evoker L10 Empowered Evocation (para 9263-9264): "Whenever
		// you cast a Wizard spell from the Evocation school, you can add your
		// Intelligence modifier to one damage roll of that spell."
		if (@pcs_spell != null and pcs_spell.school == "evocation" and caster.empowered_evocation_active and caster.class_name == "Wizard") {
			int int_mod_ee = caster.get_ability_mod(ABILITY_INT);
			if (int_mod_ee > 0) {
				base_damage += int_mod_ee;
				broadcast_announce(caster.name + "'s Empowered Evocation adds +" + int_mod_ee + " to the damage.", false);
			}
		}
		// PHB 2024 Sorcerer Draconic Sorcery L6 Elemental Affinity (para 7559-7560):
		// "When you cast a spell that deals damage of the type associated with your
		// Draconic Ancestry, you can add your Charisma modifier to one damage roll of
		// that spell." Damage type is set via Shift+P set_elemental_affinity choice.
		if (caster.class_name == "Sorcerer" and caster.subclass == "Draconic Sorcery" and caster.level >= 6 and caster.elemental_affinity_type != "") {
			int affinity_dmg_int = -1;
			if (caster.elemental_affinity_type == "acid") affinity_dmg_int = DMG_ACID;
			else if (caster.elemental_affinity_type == "cold") affinity_dmg_int = DMG_COLD;
			else if (caster.elemental_affinity_type == "fire") affinity_dmg_int = DMG_FIRE;
			else if (caster.elemental_affinity_type == "lightning") affinity_dmg_int = DMG_LIGHTNING;
			else if (caster.elemental_affinity_type == "poison") affinity_dmg_int = DMG_POISON;
			if (affinity_dmg_int >= 0 and pr.damage_type == affinity_dmg_int) {
				int cha_mod_ea = caster.get_ability_mod(ABILITY_CHA);
				if (cha_mod_ea > 0) {
					base_damage += cha_mod_ea;
					broadcast_announce(caster.name + "'s Elemental Affinity adds +" + cha_mod_ea + " " + caster.elemental_affinity_type + " damage.", false);
				}
			}
		}
		// Xanathar's Celestial Warlock L6 Radiant Soul (para 2742): "when you cast a
		// spell that deals radiant or fire damage, you can add your Charisma modifier
		// to one radiant or fire damage roll of that spell against one of its targets."
		if (caster.subclass == "Celestial Patron" and caster.level >= 6 and !caster.radiant_soul_used_this_turn) {
			if (pr.damage_type == DMG_FIRE or pr.damage_type == DMG_RADIANT) {
				int rs_cha = caster.get_ability_mod(ABILITY_CHA);
				if (rs_cha > 0) {
					base_damage += rs_cha;
					caster.radiant_soul_used_this_turn = true;
					broadcast_announce(caster.name + "'s Radiant Soul adds +" + rs_cha + " to the spell damage.", false);
				}
			}
		}
		// Metamagic: Transmuted Spell — swap damage type (para 7005-7008)
		if (pr.metamagic_transmuted and caster.class_name == "Sorcerer" and pr.metamagic_transmuted_type > 0) {
			string old_type = pr.damage_type >= 0 and pr.damage_type < int(DAMAGE_TYPE_NAMES.length()) ? DAMAGE_TYPE_NAMES[pr.damage_type] : "unknown";
			pr.damage_type = pr.metamagic_transmuted_type;
			string new_type = pr.damage_type >= 0 and pr.damage_type < int(DAMAGE_TYPE_NAMES.length()) ? DAMAGE_TYPE_NAMES[pr.damage_type] : "unknown";
			broadcast_announce(caster.name + "'s Transmuted Spell changes " + old_type + " to " + new_type + "!", false);
		}
		string dmg_type_name = "damage";
		if (pr.damage_type >= 0 and pr.damage_type < int(DAMAGE_TYPE_NAMES.length())) {
			dmg_type_name = DAMAGE_TYPE_NAMES[pr.damage_type] + " damage";
		}
		broadcast_roll(caster.name, pr.spell_name + " damage", natural_roll, pr.damage_modifier, base_damage, base_damage + " " + dmg_type_name + " before saves.");

		int center_x = caster.x;
		int center_y = caster.y;
		combatant@ center_target = combat.get_combatant(pr.target_id);
		if (@center_target != null) {
			center_x = center_target.x;
			center_y = center_target.y;
		}

		combatant@[] targets;
		if (pr.spell_is_aoe) {
			for (uint ti = 0; ti < combat.combatants.length(); ti++) {
				combatant@ t = combat.combatants[ti];
				if (@t == null or t.is_dead or t.id == caster.id) continue;
				if (combat.mode != "pvp" and t.is_player == caster.is_player) continue;
				int dist = feet_distance(center_x, center_y, t.x, t.y);
				if (dist <= pr.spell_aoe_radius) targets.insert_last(t);
			}
		}
		else if (@center_target != null and !center_target.is_dead) {
			targets.insert_last(center_target);
		}
		// Twinned Spell: add the second target to the save-based damage targets
		if (pr.twinned_target_id > 0) {
			combatant@ twin = combat.get_combatant(pr.twinned_target_id);
			if (@twin != null and !twin.is_dead) {
				// Avoid duplicating if already in targets
				bool already = false;
				for (uint chk = 0; chk < targets.length(); chk++) { if (targets[chk].id == twin.id) { already = true; break; } }
				if (!already) targets.insert_last(twin);
			}
		}

		// PHB 2024 Wizard Evoker L6 Sculpt Spells (para 9261-9262): "When you cast an
		// Evocation spell that affects other creatures that you can see, you can choose
		// a number of them equal to 1 plus the spell's level. The chosen creatures
		// automatically succeed on their saving throws against the spell, and they
		// take no damage if they would normally take half damage on a successful save."
		// Auto-pick allies (matching is_player) up to the limit and skip them entirely.
		// TODO: full player choice prompt for selecting any creatures (deferred — current
		// auto-pick implements the only sensible use case: protecting allies in PvE).
		bool sculpt_active = (caster.sculpt_spells_active and @oc_spell != null and oc_spell.school == "evocation" and caster.class_name == "Wizard");
		uint sculpt_skipped_ids_count = 0;
		uint[] sculpt_skipped_ids;
		if (sculpt_active and pr.spell_is_aoe and @oc_spell != null) {
			int sculpt_max = 1 + oc_spell.level;
			int sculpt_used = 0;
			for (uint si = 0; si < targets.length() and sculpt_used < sculpt_max; si++) {
				combatant@ st = targets[si];
				if (@st == null) continue;
				if (st.is_player == caster.is_player and combat.mode != "pvp") {
					sculpt_skipped_ids.insert_last(st.id);
					sculpt_used++;
				}
			}
			sculpt_skipped_ids_count = sculpt_skipped_ids.length();
			if (sculpt_skipped_ids_count > 0) {
				broadcast_announce(caster.name + "'s Sculpt Spells protects " + sculpt_skipped_ids_count + " " + (sculpt_skipped_ids_count == 1 ? "ally" : "allies") + " from " + pr.spell_name + ".", false);
			}
		}

		for (uint ti = 0; ti < targets.length(); ti++) {
			combatant@ t = targets[ti];
			// Sculpt Spells: skip protected allies entirely (auto-success, no damage).
			bool sculpt_protected = false;
			for (uint sk = 0; sk < sculpt_skipped_ids_count; sk++) {
				if (sculpt_skipped_ids[sk] == t.id) { sculpt_protected = true; break; }
			}
			if (sculpt_protected) continue;
			// Metamagic: Careful Spell — allies auto-succeed (para 6981-6982)
			if (caster.class_name == "Sorcerer" and pr.metamagic_careful) {
				if (t.is_player == caster.is_player and t.id != caster.id and combat.mode != "pvp") {
					broadcast_announce(t.name + " auto-succeeds on the save — " + caster.name + "'s Careful Spell!", false);
					continue; // Skip damage entirely (per source: "takes no damage")
				}
			}
			int save_roll = random(1, 20);
			// Metamagic: Heightened Spell — disadvantage on save (para 6989-6990)
			if (caster.class_name == "Sorcerer" and pr.metamagic_heightened and t.is_player != caster.is_player) {
				int save_roll2 = random(1, 20);
				if (save_roll2 < save_roll) save_roll = save_roll2;
				broadcast_announce(t.name + " has disadvantage on the save — " + caster.name + "'s Heightened Spell!", false);
			}
			// PHB 2024 Barbarian L13 Staggering Blow (para 2346): "The target has
			// Disadvantage on the next saving throw it makes." Consumed on use.
			if (t.staggering_blow_active) {
				int stag_roll2 = random(1, 20);
				if (stag_roll2 < save_roll) save_roll = stag_roll2;
				t.staggering_blow_active = false;
				broadcast_announce(t.name + " has disadvantage on the save from Staggering Blow!", false);
			}
			// Xanathar's Shadow Magic L6 Hound of Ill Omen (para 2596-2602)
			apply_hound_save_disadvantage(t, caster.id, save_roll);
			int save_bonus = t.get_save_bonus(pr.spell_save_type);
			int bless_bonus = roll_bless_bonus(t);
			int unsettling_penalty = 0;
			// College of Eloquence - Unsettling Words: subtract Bardic Inspiration die from save
			for (uint ub = 0; ub < combat.combatants.length(); ub++) {
				combatant@ ub_c = combat.combatants[ub];
				if (@ub_c == null or ub_c.is_dead) continue;
				if (ub_c.unsettling_words_pending and ub_c.unsettling_words_target == t.id) {
					int bardic_die = ub_c.bardic_inspiration_die > 0 ? ub_c.bardic_inspiration_die : 6;
					unsettling_penalty = random(1, bardic_die);
					ub_c.unsettling_words_pending = false;
					ub_c.unsettling_words_target = 0;
					broadcast_announce(t.name + "'s save reduced by " + unsettling_penalty + " from " + ub_c.name + "'s Unsettling Words!", true);
					break;
				}
			}
			// (2024 Mage Slayer does not grant advantage on saves; removed wrong 2014 effect)
			// Mind Domain Gestalt Anchor: +2 to INT/WIS/CHA saves if a Mind Domain cleric is within 10ft
			// Paladin Aura of Protection (PHB 2024 Paladin L7): "You and creatures of
			// your choice within 10 feet of you have a bonus to saving throws equal to
			// your Charisma modifier (with a minimum bonus of +1)." At L18 the range
			// becomes 30 feet.
			// Scan for ANY paladin with aura_of_protection_bonus within 10 ft (or 30 ft
			// at L18+) and apply the best bonus found.
			int best_aura_bonus = 0;
			for (uint gi = 0; gi < combat.combatants.length(); gi++) {
				combatant@ pal = combat.combatants[gi];
				if (@pal == null or pal.is_dead) continue;
				if (pal.aura_of_protection_bonus <= 0) continue;
				if (pal.is_player != t.is_player) continue; // allies only
				int aura_range = pal.level >= 18 ? 30 : 10;
				if (feet_distance(pal.x, pal.y, t.x, t.y) > aura_range) continue;
				if (pal.aura_of_protection_bonus > best_aura_bonus) best_aura_bonus = pal.aura_of_protection_bonus;
			}
			if (best_aura_bonus > 0 and t.aura_of_protection_bonus == 0) {
				// Apply only if the target isn't the paladin themselves (who already
				// has the bonus baked into get_save_bonus). save_bonus is added to
				// save_total later in this block.
				save_bonus += best_aura_bonus;
				broadcast_announce(t.name + " gains +" + best_aura_bonus + " to the save from a nearby paladin's Aura of Protection.", false);
			}
			// Holy Aura (Basic Rules para 13799): "creatures of your choice have Advantage
			// on all saving throws" while in the 30-foot Emanation. Approximated as +5 to
			// the save bonus when any ally caster within 30 ft has holy_aura_active.
			for (uint hai = 0; hai < combat.combatants.length(); hai++) {
				combatant@ ha_caster = combat.combatants[hai];
				if (@ha_caster == null or ha_caster.is_dead) continue;
				if (!ha_caster.holy_aura_active) continue;
				if (ha_caster.is_player != t.is_player) continue;
				if (feet_distance(ha_caster.x, ha_caster.y, t.x, t.y) > 30) continue;
				save_bonus += 5;
				broadcast_announce(t.name + " gains advantage on the save from " + ha_caster.name + "'s Holy Aura!", false);
				break;
			}
			if (pr.spell_save_type == ABILITY_INT or pr.spell_save_type == ABILITY_WIS or pr.spell_save_type == ABILITY_CHA) {
				for (uint gi = 0; gi < combat.combatants.length(); gi++) {
					combatant@ ga_cleric = combat.combatants[gi];
					if (@ga_cleric == null or ga_cleric.is_dead) continue;
					if (!ga_cleric.gestalt_anchor_active) continue;
					if (ga_cleric.is_player != t.is_player) continue; // allies only
					if (feet_distance(ga_cleric.x, ga_cleric.y, t.x, t.y) <= 10) {
						save_bonus += 2;
						broadcast_announce(t.name + " gains +2 from " + ga_cleric.name + "'s Gestalt Anchor!", false);
						break;
					}
				}
			}
			int save_total = save_roll + save_bonus + bless_bonus - unsettling_penalty;
			// PHB 2024 Indomitable Might (para 2351): floor STR saves at STR score
			if (pr.spell_save_type == ABILITY_STR) save_total = t.apply_indomitable_might(save_total, ABILITY_STR);
			bool saved = save_total >= pr.spell_save_dc;
			string save_name = pr.spell_save_type >= 0 and pr.spell_save_type < int(ABILITY_SHORT.length()) ? ABILITY_SHORT[pr.spell_save_type] : "save";
			if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
			// Save failure reaction chain for damage saves (mirrors condition save chain)
			if (!saved and try_arcane_deflection_save(t, pr.spell_save_dc, save_total)) saved = true;
			if (!saved) { int fg = try_flash_of_genius(t, pr.spell_save_dc, save_total, save_name + " save vs " + pr.spell_name); if (fg >= pr.spell_save_dc) { saved = true; save_total = fg; } }
			if (!saved) { int mv = try_maverick_spirit(t, pr.spell_save_dc, save_total, save_name + " save vs " + pr.spell_name); if (mv >= pr.spell_save_dc) { saved = true; save_total = mv; } }
			if (!saved and (pr.spell_save_type == ABILITY_INT or pr.spell_save_type == ABILITY_WIS or pr.spell_save_type == ABILITY_CHA) and try_mage_slayer_guarded_mind(t, pr.spell_save_type)) saved = true;
			if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, pr.spell_save_dc); if (bf >= pr.spell_save_dc) { saved = true; save_total = bf; } }
			if (!saved and try_stroke_of_luck_save(t, pr.spell_save_dc, save_bonus + bless_bonus)) saved = true;
			broadcast_roll(t.name, save_name + " save vs " + pr.spell_name, save_roll, save_bonus + bless_bonus, save_total, saved ? "Save! Half damage." : "Failed!");

			int damage = base_damage;
			if (saved) damage = damage / 2;
			if (damage < 1) damage = 1;
			// Evasion (PHB 2024 Monk L7 / Rogue L7): "When you're subjected to an effect
			// that allows you to make a Dexterity saving throw to take only half damage,
			// you instead take no damage if you succeed on the saving throw and only half
			// damage if you fail."
			// Overwrites the computed damage: success = 0, failure = half (not full).
			if (t.evasion_active and pr.spell_save_type == ABILITY_DEX and !t.has_condition(COND_INCAPACITATED)) {
				if (saved) {
					damage = 0;
					broadcast_announce(t.name + "'s Evasion turns the save into no damage!", false);
				} else {
					damage = base_damage / 2;
					if (damage < 1) damage = 1;
					broadcast_announce(t.name + "'s Evasion reduces the failed save to half damage.", false);
				}
			}
			// PHB 2024 Shield Master Interpose (para 7797): "If you're subjected to
			// an effect that allows you to make a DEX save to take only half damage,
			// you can use your Reaction to take no damage if you succeed, interposing
			// your shield." Functions like Evasion but consumes reaction.
			else if (saved and t.has_feat("shield_master") and t.has_shield and pr.spell_save_type == ABILITY_DEX and !t.has_condition(COND_INCAPACITATED) and t.has_reaction) {
				damage = 0;
				t.has_reaction = false;
				broadcast_announce(t.name + "'s Shield Master interposes their shield — no damage!", false);
			}

			// Xanathar's War Magic L6 Power Surge (para 2937-2940): "Once per turn when
			// you deal damage to a creature with a spell, you can spend one Power Surge
			// to deal extra Force damage equal to half your Wizard level."
			if (damage > 0 and caster.class_name == "Wizard" and caster.subclass == "War Magic" and caster.level >= 6 and caster.power_surge_charges > 0 and !caster.power_surge_used_this_turn) {
				int surge_dmg = caster.level / 2;
				if (surge_dmg < 1) surge_dmg = 1;
				damage += surge_dmg;
				caster.power_surge_charges--;
				caster.power_surge_used_this_turn = true;
				broadcast_announce(caster.name + "'s Power Surge deals " + surge_dmg + " extra force damage! (" + caster.power_surge_charges + "/" + caster.power_surge_max + " surges remaining)", false);
			}
			bool aoe_target_was_full = (t.current_hp == t.max_hp);
			bool aoe_caster_was_hidden = caster.is_hidden;
			if (caster.is_player and caster.player_username != "" and progression_enabled) {
				add_run_damage(caster.player_username, damage);
			}
			combat.apply_damage(t, damage, pr.damage_type, caster);
			// PHB 2024 Cleric L14 Improved Blessed Strikes (para 3626): cantrip damage
			// grants 2x WIS mod temp HP to self.
			if (damage > 0 and @pcs_spell != null and pcs_spell.level == 0 and pcs_spell.class_list.find("cleric") >= 0) {
				int ipt2 = caster.apply_improved_potent_temp_hp();
				if (ipt2 > 0) broadcast_announce(caster.name + "'s Improved Blessed Strikes grants " + ipt2 + " temp HP.", false);
			}
			// Graviturgy Gravity Well: L6 — when a spell hits a creature and deals damage, move them 5ft
			if (caster.class_name == "Wizard" and caster.subclass == "Graviturgy Magic" and caster.level >= 6 and !saved and damage > 0) {
				// Move 5ft toward caster (simple pull)
				if (t.x < caster.x) t.x += 5;
				else if (t.x > caster.x) t.x -= 5;
				else if (t.y < caster.y) t.y += 5;
				else if (t.y > caster.y) t.y -= 5;
				broadcast_announce(caster.name + "'s Gravity Well pulls " + t.name + " 5ft!", false);
			}
			broadcast_to_battle({{"type", message_types::damage_dealt}, {"attacker", caster.name}, {"target", t.name}, {"amount", damage}, {"damage_type", DAMAGE_TYPE_NAMES[pr.damage_type]}, {"is_crit", false}, {"is_spell", true}});
			if (t.is_dead) {
				broadcast_to_battle({{"type", message_types::creature_died}, {"name", t.name}, {"is_player", t.is_player}, {"killed_by", caster.name}, {"was_full_hp", aoe_target_was_full}, {"was_overkill", damage >= t.max_hp * 2}, {"was_stealth", aoe_caster_was_hidden}});
			}
			check_concentration(t, damage, caster);
		}

		// PHB 2024 Wizard Evoker L14 Overchannel self-damage (para 9265-9268): only
		// after the second+ use of the feature this rest. First use is free.
		if (overchannel_used_now) {
			if (caster.overchannel_uses_this_rest >= 1) {
				int extra_dice_per_level = 2 + (caster.overchannel_uses_this_rest - 1); // 2d12 second use, 3d12 third, etc.
				int total_dice = extra_dice_per_level * overchannel_spell_level_used;
				int self_damage = 0;
				for (int sd = 0; sd < total_dice; sd++) self_damage += random(1, 12);
				broadcast_announce(caster.name + " suffers " + self_damage + " necrotic damage from Overchannel backlash!", true);
				// Direct HP subtraction — bypasses resistance/immunity per source.
				caster.current_hp -= self_damage;
				if (caster.current_hp < 0) caster.current_hp = 0;
				if (caster.current_hp == 0) {
					caster.is_dead = true;
					broadcast_to_battle({{"type", message_types::creature_died}, {"name", caster.name}, {"is_player", caster.is_player}, {"killed_by", "Overchannel backlash"}, {"was_full_hp", false}, {"was_overkill", false}, {"was_stealth", false}});
				}
			}
			caster.overchannel_uses_this_rest++;
		}

		broadcast_state();
		check_battle_end();
	}

	void apply_attack_advantage_state(combatant@ attacker, combatant@ target, int dist, bool attack_is_ranged, bool&out adv, bool&out disadv, bool is_spell_attack = false) {
		adv = false;
		disadv = false;
		if (@attacker == null or @target == null) return;
		// PHB 2024 Sorcerer L1 Innate Sorcery (para 6963-6967): "You have Advantage
		// on the attack rolls of Sorcerer spells you cast." Only applied when the
		// attack is a Sorcerer spell attack and the active Sorcerer has the buff up.
		if (is_spell_attack and attacker.class_name == "Sorcerer" and attacker.innate_sorcery_active) adv = true;
		bool can_ignore_invisible = (attacker.has_feat("boon_of_truesight") and dist <= 60)
			or (attacker.true_seeing_active and dist <= 120)
			or attacker.see_invisibility_active;
		// Barbarian Reckless Attack (PHB 2024 para 2785): "When you make your first attack
		// roll on your turn, you can decide to attack recklessly. Doing so gives you Advantage
		// on attack rolls using Strength until the start of your next turn, and attack rolls
		// against you have Advantage during that time."
		if (attacker.reckless_attack_active and !attack_is_ranged) {
			// PHB 2024 Barbarian L9 Brutal Strike (para 2338-2341): forgo Reckless advantage
			// on one STR-based attack to gain +1d10 damage and a rider effect on hit.
			if (attacker.brutal_strike_active and !attacker.brutal_strike_used_this_turn
				and !attack_is_ranged) {
				// Forgo the advantage — do NOT set adv = true for this attack
				// (brutal_strike hit bonus + effects applied in finalize_roll_result)
			} else {
				adv = true;
			}
		}
		if (target.reckless_attack_active) adv = true; // Target attacked self recklessly: incoming gets advantage
		// Fighter L13 Studied Attacks (PHB 2024 para 5983): "If you make an attack roll
		// against a creature and miss, you have Advantage on your next attack roll against
		// that creature before the end of your next turn."
		if (attacker.studied_attacks_active and attacker.studied_attacks_target_id == target.id) {
			adv = true;
			attacker.studied_attacks_target_id = 0; // Consume the bonus
		}
		// PHB 2024 Monk L5 Stunning Strike success rider (para 5349): "the next attack
		// roll made against the target before then has Advantage." Consumed on first
		// attack against the target after the rider was tagged.
		if (target.stunning_strike_advantage_pending) {
			adv = true;
			target.stunning_strike_advantage_pending = false;
		}
		// PHB 2024 Crusher (para 7579): crit advantage on attacks against target
		if (target.crusher_crit_advantage) adv = true;
		// Basic Rules 2024 Shining Smite (para 14976-14983): "attack rolls against
		// it have Advantage" while the smite aura persists on the target.
		if (target.shining_smite_debuff) adv = true;
		// PHB 2024 Slasher (para 7597): crit disadvantage on target's attacks
		if (attacker.slasher_crit_disadvantage) disadv = true;
		if (target.has_condition(COND_PRONE) and !attack_is_ranged and dist <= 5) adv = true;
		if (target.has_condition(COND_PRONE) and (attack_is_ranged or dist > 5)) disadv = true;
		// Xanathar's Investiture of Wind: "Ranged weapon attacks made against you have
		// disadvantage on the attack roll."
		if (target.investiture_wind_active and attack_is_ranged) disadv = true;
		if (target.has_condition(COND_PARALYZED) or target.has_condition(COND_STUNNED) or target.has_condition(COND_UNCONSCIOUS)) adv = true;
		// PHB 2024 Blinded condition (para 16208): "Attack rolls against the creature
		// have Advantage." Mirrors Invisible mechanic but for defender side.
		if (target.has_condition(COND_BLINDED)) adv = true;
		if (attacker.has_condition(COND_BLINDED) or attacker.has_condition(COND_POISONED) or attacker.has_condition(COND_FRIGHTENED) or attacker.has_condition(COND_RESTRAINED)) disadv = true;
		// Valda's Spire Gunslinger L5 Gut Shot (paras 184-185): the gut-shot creature
		// "has Disadvantage on attack rolls" until it dislodges or 1 minute passes.
		if (attacker.gut_shot_rounds_remaining > 0) disadv = true;
		if (target.is_dodging and !attacker.has_condition(COND_BLINDED)) disadv = true;
		// PHB 2024 Blur (Level 2, Concentration): "any creature that can see you has
		// Disadvantage on attack rolls against you." Blinded attackers can't see the
		// target, so Blur has no effect on them.
		if (target.blur_active and !attacker.has_condition(COND_BLINDED)) disadv = true;
		if (target.has_condition(COND_INVISIBLE) and !can_ignore_invisible) disadv = true;
		// Basic Rules 2024 Protection from Evil and Good (para 14688-14691):
		// "Creatures of those types have Disadvantage on attack rolls against the target."
		if (target.protection_from_evil_and_good_active and is_pfeg_creature_type(attacker.creature_type)) disadv = true;
		// Basic Rules 2024 Holy Aura (para 13799): "other creatures have Disadvantage on
		// attack rolls against them" while in the 30-foot Emanation of the Holy Aura caster.
		if (@combat != null) {
			for (uint hai2 = 0; hai2 < combat.combatants.length(); hai2++) {
				combatant@ ha_src = combat.combatants[hai2];
				if (@ha_src == null or ha_src.is_dead or !ha_src.holy_aura_active) continue;
				if (ha_src.is_player != target.is_player and combat.mode != "pvp") continue; // Aura protects allies
				if (ha_src.is_player == target.is_player or !combat.are_hostile(ha_src, target)) {
					if (feet_distance(ha_src.x, ha_src.y, target.x, target.y) <= 30) {
						disadv = true;
						break;
					}
				}
			}
		}
		// Basic Rules 2024 Bestow Curse (para 12219-12222): attack_disadv curse gives
		// the target "Disadvantage on attack rolls against" the curse source.
		if (attacker.bestow_curse_type == "attack_disadv" and attacker.bestow_curse_source_id == target.id) {
			disadv = true;
		}
		// Basic Rules 2024 Vicious Mockery (para 15527): "Disadvantage on the next
		// attack roll it makes before the end of its next turn." Consumed on first attack.
		if (attacker.vicious_mockery_disadv) {
			disadv = true;
			attacker.vicious_mockery_disadv = false;
		}
		// Basic Rules 2024 Heat Metal (para 13734): "the creature has disadvantage on
		// attack rolls and ability checks until the start of your next turn."
		if (attacker.heat_metal_disadv) {
			disadv = true;
		}
		// PHB 2024 Invisible condition (para 16219): "Attack rolls against the creature
		// have Disadvantage, and the creature's attack rolls have Advantage." The defender
		// Disadvantage is above; the attacker Advantage is here.
		if (attacker.has_condition(COND_INVISIBLE)) adv = true;
		if (target.has_condition(COND_RESTRAINED)) adv = true;
		if (attacker.is_hidden and combat.are_hostile(attacker, target)) adv = true;
		// Crossbow Expert: no disadvantage on ranged attacks within 5ft
		// Sharpshooter (PHB para 7760): "Being within 5 feet of an enemy doesn't impose
		// Disadvantage on your attack rolls with Ranged weapons."
		// Spell Sniper (PHB para 7805): same effect for spell attacks.
		if (attack_is_ranged and has_hostile_within_5_feet(attacker) and !attacker.has_feat("crossbow_expert") and !attacker.has_feat("sharpshooter") and !attacker.has_feat("spell_sniper")) disadv = true;
		if (attacker.has_feat("grappler") and target.grapple_source_id == attacker.id and target.has_condition(COND_GRAPPLED)) adv = true;
		if (target.guiding_bolt_advantage) {
			adv = true;
			clear_guiding_bolt_effect(target, false);
			broadcast_announce("Guiding light grants advantage against " + target.name + ".", false);
		}
		// Faerie Fire: persistent advantage on ALL attacks against outlined targets (not consumed)
		// Basic Rules para 13167: "Attack rolls against an affected creature have Advantage"
		if (target.faerie_fire_outlined) {
			adv = true;
		}
		if (consume_help_advantage(attacker, target)) adv = true;
		// Assassin: advantage on first round (Assassinate feature)
		if (attacker.subclass == "Assassin" and attacker.assassinate_available and @combat != null and combat.round_number <= 1) {
			adv = true;
		}
		// Paladin Vow of Enmity: advantage vs sworn target
		if (attacker.vow_of_enmity_target != 0 and attacker.vow_of_enmity_target == target.id) {
			adv = true;
		}
		// SRD Pack Tactics (Wolves, Kobolds, etc.): advantage on attack when an ally
		// is within 5 feet of the target and the ally isn't incapacitated.
		if (attacker.pack_tactics and @combat != null) {
			for (uint pti = 0; pti < combat.combatants.length(); pti++) {
				combatant@ ally = combat.combatants[pti];
				if (@ally == null or ally.is_dead or ally.id == attacker.id) continue;
				if (ally.is_player != attacker.is_player) continue; // Must be same side
				if (ally.has_condition(COND_INCAPACITATED) or !ally.is_alive()) continue;
				if (feet_distance(ally.x, ally.y, target.x, target.y) <= 5) {
					adv = true;
					break;
				}
			}
		}
		// PHB 2024 Ranger L17 Precise Hunter (para 6187-6188): "You have Advantage
		// on attack rolls against the creature currently marked by your Hunter's
		// Mark."
		if (attacker.class_name == "Ranger" and attacker.level >= 17 and attacker.hunters_mark_target_id != 0 and attacker.hunters_mark_target_id == target.id) {
			adv = true;
		}
		// Valda's Spire Gunslinger Deadeye L14 Focused Shot (paras 252-253): "You have
		// Advantage on this attack roll" — flag set by the bonus action handler that
		// commits the player to a single ranged attack.
		if (attacker.focused_shot_pending and attack_is_ranged) {
			adv = true;
		}
		// PHB 2024 Rogue L3 Steady Aim (para 6550-6551): "you give yourself Advantage
		// on your next attack roll on the current turn." Consumed inline by the next
		// attack. The flag is set by the bonus action handler and reset at start of
		// each turn (advance_turn) so it cannot leak across turns.
		if (attacker.class_name == "Rogue" and attacker.steady_aim_pending) {
			adv = true;
			attacker.steady_aim_pending = false;
		}
		// Samurai Fighter: Fighting Spirit — advantage on attacks when active
		if (attacker.class_name == "Fighter" and attacker.subclass == "Samurai" and attacker.fighting_spirit_active) {
			adv = true;
		}
		// Hexblade Warlock: Hexblade's Curse — crit on 19-20 vs cursed target (handled in crit threshold)
		// Xanathar's Cavalier L3 Unwavering Mark (para 1670): "While it is within 5 feet
		// of you, a creature marked by you has disadvantage on any attack roll that doesn't
		// target you."
		if (attacker.marked_by_cavalier_id != 0 and @target != null and @combat != null) {
			for (uint cav = 0; cav < combat.combatants.length(); cav++) {
				combatant@ cav_c = combat.combatants[cav];
				if (@cav_c == null or cav_c.is_dead or cav_c.id != attacker.marked_by_cavalier_id) continue;
				if (target.id != cav_c.id) { // attacking someone other than the Cavalier
					float cdx = float(attacker.x - cav_c.x);
					float cdy = float(attacker.y - cav_c.y);
					float cav_dist = sqrt(cdx * cdx + cdy * cdy) * 5.0f;
					if (cav_dist <= 5) disadv = true;
				}
				break;
			}
		}
		// Xanathar's Ancestral Guardian L3 Ancestral Protectors (para 389-390):
		// "that target has disadvantage on any attack roll that isn't against you"
		if (attacker.ancestral_protector_marked_by != 0 and @target != null and @combat != null) {
			for (uint ag = 0; ag < combat.combatants.length(); ag++) {
				combatant@ ag_c = combat.combatants[ag];
				if (@ag_c == null or ag_c.is_dead or ag_c.id != attacker.ancestral_protector_marked_by) continue;
				if (target.id != ag_c.id) disadv = true; // attacking someone other than the barbarian
				break;
			}
		}
		// Sacred Weapon: add CHA mod to attack rolls (handled via attack bonus modification)

		// Xanathar's Scout L13 Ambush Master (para 2399): "attack rolls against that
		// target have advantage until the start of your next turn."
		if (target.ambush_master_marked_by != 0) adv = true;
		// PHB 2024 Battle Master Goading Attack (para 6036-6037): goaded target has
		// disadvantage on attacks against anyone other than the goader.
		if (attacker.goading_attack_source_id != 0 and attacker.goading_attack_turns > 0 and @target != null and target.id != attacker.goading_attack_source_id) disadv = true;
		// PHB 2024 Battle Master Distracting Strike (para 6030-6031): next attack by
		// another creature against the target has advantage. Consumed on use.
		if (target.distracting_strike_marked and attacker.id != target.distracting_strike_source_id) {
			adv = true;
			target.distracting_strike_marked = false;
			target.distracting_strike_source_id = 0;
		}
		// Xanathar's Swashbuckler L9 Panache (para 2423-2426): hostile panached target
		// has disadvantage on attacks against anyone other than the Swashbuckler.
		if (attacker.panache_source_id != 0 and attacker.panache_rounds > 0 and @target != null and target.id != attacker.panache_source_id) disadv = true;
		// Tasha's Phantom Rogue L13 Ghost Walk (para 3470): "attack rolls have
		// disadvantage against you" while in spectral form.
		if (target.ghost_walk_active) disadv = true;

		// Xanathar's Zealot L10 Zealous Presence (para 445-447): "Up to ten other
		// creatures of your choice within 60 feet of you that can hear you gain advantage
		// on attack rolls and saving throws until the start of your next turn."
		if (attacker.zealous_presence_buff_active) adv = true;

		// PHB 2024 Weapon Mastery — Vex (para 10351): "you have Advantage on your
		// next attack roll against that creature before the end of your next turn."
		if (attacker.mastery_vex_active and attacker.mastery_vex_target_id == target.id) {
			adv = true;
			attacker.mastery_vex_active = false;
			attacker.mastery_vex_target_id = 0;
		}
		// PHB 2024 Weapon Mastery — Sap (para 10345): "that creature has Disadvantage
		// on its next attack roll before the start of your next turn."
		if (attacker.mastery_sap_active) {
			disadv = true;
			attacker.mastery_sap_active = false;
		}

		// PHB 2024 Fighting Style: Protection (para 7868): "When a creature you can
		// see attacks a target other than you that is within 5 feet of you, you can
		// use your Reaction to impose Disadvantage on the attack roll. Requires Shield."
		if (@combat != null) {
			for (uint pi = 0; pi < combat.combatants.length(); pi++) {
				combatant@ protector = combat.combatants[pi];
				if (@protector == null or protector.is_dead or !protector.is_alive()) continue;
				if (!protector.is_conscious() or protector.is_incapacitated_check()) continue;
				if (protector.id == attacker.id or protector.id == target.id) continue;
				if (!protector.has_feat("protection")) continue;
				if (!protector.has_shield) continue;
				if (!protector.has_reaction) continue;
				if (combat.are_hostile(protector, target)) continue;
				if (feet_distance(protector.x, protector.y, target.x, target.y) > 5) continue;
				if (!combat.can_see(protector, attacker)) continue;
				protector.has_reaction = false;
				disadv = true;
				broadcast_announce(protector.name + "'s Protection imposes Disadvantage on " + attacker.name + "'s attack against " + target.name + "!", true);
				break;
			}
		}
		// Basic Rules 2024 Foresight (para 13025-13031): "the target has Advantage
		// on D20 Tests, and other creatures have Disadvantage on attack rolls against it."
		if (attacker.foresight_active) adv = true;
		if (target.foresight_active) disadv = true;

		// Xanathar's Drunken Master L11 Drunkard's Luck (para 1798-1800): "Whenever
		// you make an ability check, an attack roll, or a saving throw and have
		// disadvantage, you can spend 2 ki points to cancel the disadvantage."
		if (attacker.drunkards_luck_active and disadv and !adv and attacker.focus_points >= 2) {
			attacker.focus_points -= 2;
			disadv = false;
			broadcast_announce(attacker.name + " spends 2 Focus Points — Drunkard's Luck cancels the attack disadvantage!", false);
		}

		// PHB 2024 Rogue L18 Elusive (para 6576-6577): "No attack roll can have
		// Advantage against you unless you have the Incapacitated condition." Strip
		// any advantage that would have been granted to the attacker against this
		// target — applied last so it overrides every prior source of advantage.
		if (target.elusive_active and !target.has_condition(COND_INCAPACITATED)) {
			adv = false;
		}
		// Tasha's Clockwork Soul L14 Trance of Order (para 4001-4003): "attack rolls
		// against you can't benefit from advantage."
		if (target.trance_of_order_active) {
			adv = false;
		}
		// Valda's Spire Gunslinger High Roller L6 Risky Business (paras 265-266):
		// "Once per turn when you make an attack roll against an enemy and the roll
		// doesn't have Disadvantage, you can choose to make the roll with Disadvantage.
		// When you do, you regain one expended Risk Die." Pending flag set by the
		// player via bonus action menu before attacking. Per-turn limit enforced via
		// risky_business_used_this_turn (cleared in advance_turn). Only fires when
		// the roll would not already have Disadvantage and Risk Dice can be refunded.
		if (attacker.risky_business_pending and !disadv and !attacker.risky_business_used_this_turn and attacker.risk_dice_current < attacker.risk_dice_max) {
			attacker.risky_business_pending = false;
			attacker.risky_business_used_this_turn = true;
			adv = false;
			disadv = true;
			attacker.risk_dice_current++;
			broadcast_announce(attacker.name + "'s Risky Business: takes Disadvantage on the attack and regains a Risk Die! (" + attacker.risk_dice_current + "/" + attacker.risk_dice_max + ")", false);
		} else if (attacker.risky_business_pending) {
			// Conditions not met (already disadv, already used this turn, or Risk Dice full) — clear the pending flag silently
			attacker.risky_business_pending = false;
		}
	}

	bool has_hostile_within_5_feet(combatant@ attacker) {
		if (@attacker == null or @combat == null) return false;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ other = combat.combatants[i];
			if (@other == null or other.id == attacker.id or other.is_dead) continue;
			if (!combat.are_hostile(attacker, other)) continue;
			if (feet_distance(attacker.x, attacker.y, other.x, other.y) <= 5) return true;
		}
		return false;
	}

	// Protection from Evil and Good: check if a creature type is one of the six
	// types affected by the spell (Aberration, Celestial, Elemental, Fey, Fiend, Undead).
	bool is_pfeg_creature_type(string creature_type) {
		return creature_type == "aberration" or creature_type == "celestial"
			or creature_type == "elemental" or creature_type == "fey"
			or creature_type == "fiend" or creature_type == "undead";
	}

	bool monster_has_secondary_attack(combatant@ monster) {
		if (@monster == null) return false;
		return monster.monster_attack2_name != "" and monster.monster_attack2_count > 0 and monster.monster_attack2_dice > 0;
	}

	bool monster_secondary_is_ranged(combatant@ monster) {
		if (!monster_has_secondary_attack(monster)) return false;
		return monster.monster_attack2_range > 5 and attack_name_is_ranged(monster.monster_attack2_name);
	}

	// Basic Rules 2024 Bane (para 12032): "Whenever a target makes an attack roll
	// or a saving throw before the spell ends, the target must roll a d4 and subtract
	// the number rolled from the attack roll or saving throw."
	int roll_bane_penalty(combatant@ c) {
		if (@c == null or !c.baned) return 0;
		return random(1, 4);
	}

	int get_attack_bonus_for_roll(combatant@ attacker, bool use_secondary = false) {
		if (@attacker == null) return 0;
		int atk_bonus = 0;
		if (!attacker.is_player or attacker.wild_shape_active) atk_bonus = use_secondary ? attacker.monster_attack2_bonus : attacker.monster_attack_bonus;
		else {
			atk_bonus = get_weapon_attack_ability_mod(attacker) + attacker.proficiency;
			// Basic Rules 2024 Alter Self Natural Weapons (para 12010-12012):
			// "you can use your spellcasting ability for the attack and damage rolls"
			if (attacker.alter_self_natural_weapons and !attacker.main_hand_is_ranged) {
				int spell_atk = get_spellcasting_ability_mod(attacker) + attacker.proficiency;
				if (spell_atk > atk_bonus) atk_bonus = spell_atk;
			}
			if (attacker.has_feat("archery") and attacker.main_hand_is_ranged) atk_bonus += 2;
		}
		atk_bonus -= attacker.exhaustion_level * 2;
		atk_bonus -= roll_bane_penalty(attacker);
		// Magic Weapon spell (Basic Rules para 14108): +1/+2/+3 to attack rolls
		if (attacker.magic_weapon_bonus > 0) atk_bonus += attacker.magic_weapon_bonus;
		// Xanathar's Kensei L11 Sharpen the Blade (para 1832-1835): +1/+2/+3 to attack rolls.
		// "This feature has no effect on a magic weapon that already has a bonus."
		if (attacker.sharpen_the_blade_bonus > 0 and attacker.magic_weapon_bonus == 0) atk_bonus += attacker.sharpen_the_blade_bonus;
		return atk_bonus;
	}

	int get_damage_modifier_for_attack(combatant@ attacker, bool use_secondary = false) {
		if (@attacker == null) return 0;
		if (!attacker.is_player or attacker.wild_shape_active) return use_secondary ? attacker.monster_attack2_mod : attacker.monster_attack_damage_mod;
		int mod = get_weapon_damage_ability_mod(attacker);
		// Basic Rules 2024 Alter Self Natural Weapons (para 12010-12012):
		// "you can use your spellcasting ability for the attack and damage rolls"
		if (attacker.alter_self_natural_weapons and !attacker.main_hand_is_ranged) {
			int spell_mod = get_spellcasting_ability_mod(attacker);
			if (spell_mod > mod) mod = spell_mod;
		}
		if (attacker.raging and !attacker.main_hand_is_ranged) mod += attacker.rage_damage_bonus;
		// Fighting Style: Dueling (+2 damage with one-handed melee, no second weapon)
		if (attacker.has_feat("dueling") and !attacker.main_hand_is_ranged and attacker.main_hand_range <= 5) mod += 2;
		// Fighting Style: Thrown Weapon Fighting (+2 damage with thrown weapons)
		if (attacker.has_feat("thrown_weapon_fighting") and attacker.main_hand_is_ranged and attacker.main_hand_range <= 60) mod += 2;
		// Magic Weapon spell (Basic Rules para 14108): +1/+2/+3 to damage rolls
		if (attacker.magic_weapon_bonus > 0) mod += attacker.magic_weapon_bonus;
		// Xanathar's Kensei L11 Sharpen the Blade (para 1832-1835): +1/+2/+3 to damage rolls.
		if (attacker.sharpen_the_blade_bonus > 0 and attacker.magic_weapon_bonus == 0) mod += attacker.sharpen_the_blade_bonus;
		return mod;
	}

	int get_attack_damage_count(combatant@ attacker, bool use_secondary = false) {
		if (@attacker == null) return 0;
		if (!attacker.is_player and use_secondary) return attacker.monster_attack2_count;
		// Basic Rules 2024 Shillelagh (para 14966-14974): 2d6 at level 17+
		if (attacker.shillelagh_active and !attacker.main_hand_is_ranged and attacker.level >= 17) return 2;
		return attacker.main_hand_damage_count;
	}

	int get_attack_damage_dice(combatant@ attacker, bool use_secondary = false) {
		if (@attacker == null) return 0;
		if (!attacker.is_player and use_secondary) return attacker.monster_attack2_dice;
		// Basic Rules 2024 Shillelagh (para 14966-14974): "the weapon's damage die
		// becomes a d8. Cantrip Upgrade: d10 at L5, d12 at L11, 2d6 at L17."
		if (attacker.shillelagh_active and !attacker.main_hand_is_ranged) return attacker.shillelagh_damage_die;
		if (attack_name_is_unarmed(attacker.main_hand)) {
			if (attacker.class_name == "Monk") {
				int martial_die = monk_martial_arts_die(attacker);
				if (martial_die > attacker.main_hand_damage_dice) return martial_die;
			}
			if (attacker.has_feat("tavern_brawler") and attacker.main_hand_damage_dice < 4) return 4;
			// Unarmed Fighting feat (PHB para 7880): "you can deal Bludgeoning damage equal
			// to 1d6 plus your Strength modifier instead of the normal damage of an Unarmed
			// Strike. If you aren't holding any weapons or a Shield when you make the
			// attack, the d6 becomes a d8."
			if (attacker.unarmed_fighting_active) {
				int uf_die = (attacker.has_shield) ? 6 : 8;
				if (uf_die > attacker.main_hand_damage_dice) return uf_die;
			}
		}
		// Basic Rules 2024 Alter Self Natural Weapons (para 12010-12012):
		// "the Unarmed Strike deals 1d6 damage" — floor at d6 for any melee attack
		if (attacker.alter_self_natural_weapons and !attacker.main_hand_is_ranged and attacker.main_hand_damage_dice < 6) return 6;
		return attacker.main_hand_damage_dice;
	}

	int get_attack_damage_type(combatant@ attacker, bool use_secondary = false) {
		if (@attacker == null) return DMG_SLASHING;
		if (!attacker.is_player and use_secondary) return attacker.monster_attack2_type;
		// PHB 2024 Monk L6 Empowered Strikes (para 5350-5351): "Whenever you deal damage
		// with your Unarmed Strike, it can deal your choice of Force damage or its normal
		// damage type." Toggle via empowered_strikes_force (bonus action menu).
		if (attacker.empowered_strikes_active and attacker.empowered_strikes_force and attack_name_is_unarmed(attacker.main_hand)) {
			return DMG_FORCE;
		}
		// Basic Rules 2024 Shillelagh (para 14966-14974): "If the attack deals damage,
		// it can be Force damage or the weapon's normal damage type (your choice)."
		// Default to Force (strictly better — few creatures resist it). Player
		// damage-type prompt deferred; logged in TODO_SOURCE_ACCURACY.md.
		if (attacker.shillelagh_active and !attacker.main_hand_is_ranged) return DMG_FORCE;
		return attacker.main_hand_damage_type;
	}

	int get_attack_range(combatant@ attacker, bool use_secondary = false) {
		if (@attacker == null) return 5;
		if (!attacker.is_player and use_secondary) return attacker.monster_attack2_range;
		return attacker.main_hand_range;
	}

	string get_attack_name(combatant@ attacker, bool use_secondary = false) {
		if (@attacker == null) return "Attack";
		if (!attacker.is_player and use_secondary and monster_has_secondary_attack(attacker)) return attacker.monster_attack2_name;
		if (attacker.main_hand != "") return attacker.main_hand;
		return "Attack";
	}

	int get_monster_desired_attack_range(combatant@ monster, int target_distance) {
		if (@monster == null) return 5;
		int desired_range = monster.main_hand_range;
		if (!monster_has_secondary_attack(monster)) return desired_range;
		if (monster_secondary_is_ranged(monster)) {
			if (target_distance <= monster.main_hand_range) return monster.main_hand_range;
			return monster.monster_attack2_range;
		}
		if (monster.extra_attacks > 0 and monster.monster_attack2_range > 0 and monster.monster_attack2_range < desired_range) {
			desired_range = monster.monster_attack2_range;
		}
		return desired_range;
	}

	bool should_use_monster_secondary_attack(combatant@ monster, combatant@ target, int attack_index) {
		if (@monster == null or @target == null or !monster_has_secondary_attack(monster)) return false;

		int dist = feet_distance(monster.x, monster.y, target.x, target.y);
		bool primary_in_range = dist <= monster.main_hand_range;
		bool secondary_in_range = dist <= monster.monster_attack2_range;
		if (!secondary_in_range) return false;
		if (!primary_in_range) return true;
		if (monster_secondary_is_ranged(monster)) return false;

		int total_attacks = monster.extra_attacks + 1;
		if (total_attacks <= 1) return false;

		string primary_name = monster.main_hand.lower();
		string secondary_name = monster.monster_attack2_name.lower();
		if (secondary_name.find("bite") >= 0 and primary_name.find("claw") >= 0) {
			return attack_index == total_attacks - 1;
		}
		if (primary_name.find("bite") >= 0 or primary_name.find("beak") >= 0 or primary_name.find("snake") >= 0 or primary_name.find("mace") >= 0 or primary_name.find("touch") >= 0) {
			return attack_index > 0;
		}
		return attack_index > 0;
	}

	// Smart monster targeting: score-based system instead of pure nearest.
	// Priority: low HP targets > concentrating casters > healers > nearest.
	// Never attack downed (0 HP) players if others are still conscious.
	combatant@ find_nearest_target_for_monster(combatant@ monster) {
		if (@monster == null or @combat == null) return null;

		combatant@ best_target = null;
		int best_score = -9999;

		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ other = combat.combatants[i];
			if (@other == null or !other.is_player or other.is_dead) continue;
			if (other.current_hp <= 0) continue; // Skip downed players

			int dist = feet_distance(monster.x, monster.y, other.x, other.y);
			int score = 0;

			// Base: prefer closer targets (distance penalty)
			score -= dist;

			// Heavily prioritize targets already in melee range
			if (dist <= monster.main_hand_range) score += 50;

			// Focus fire: prefer wounded targets (the lower HP %, the higher priority)
			if (other.max_hp > 0) {
				int hp_pct = (other.current_hp * 100) / other.max_hp;
				if (hp_pct <= 25) score += 80;       // Nearly dead — finish them
				else if (hp_pct <= 50) score += 40;  // Wounded
				else if (hp_pct <= 75) score += 15;  // Somewhat hurt
			}

			// Target concentrating casters (break their spell)
			if (other.is_concentrating) score += 35;

			// Target healers (Cleric, Druid, Paladin, Bard — they sustain the party)
			if (other.class_name == "Cleric" or other.class_name == "Druid") score += 25;
			else if (other.class_name == "Paladin" or other.class_name == "Bard") score += 15;

			// Slightly avoid targets in Resilient Sphere (can't damage them)
			if (other.resilient_sphere_trapped) score -= 200;

			// Slightly prefer targets not currently dodging
			if (other.is_dodging) score -= 20;

			if (score > best_score) {
				best_score = score;
				@best_target = other;
			}
		}

		if (@best_target != null) return best_target;

		// Fallback: find ANY living player (including 0 HP) for death save attacks
		combatant@ fallback = null;
		int fallback_dist = 9999;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ other = combat.combatants[i];
			if (@other == null or !other.is_player or other.is_dead) continue;
			int dist = feet_distance(monster.x, monster.y, other.x, other.y);
			if (dist < fallback_dist) {
				fallback_dist = dist;
				@fallback = other;
			}
		}
		return fallback;
	}

	bool start_monster_attack_sequence(combatant@ monster, combatant@ target, int attack_index, int attacks_remaining) {
		if (@monster == null or @target == null or @combat == null or monster.is_dead or target.is_dead) return false;

		bool use_secondary = should_use_monster_secondary_attack(monster, target, attack_index);
		int dist = feet_distance(monster.x, monster.y, target.x, target.y);
		int attack_range = get_attack_range(monster, use_secondary);
		if (dist > attack_range) return false;
		if (!combat.can_see(monster, target)) return false;

		// Basic Rules 2024 Sanctuary (para 14826): WIS save before targeting
		if (target.sanctuary_active and target.sanctuary_dc > 0) {
			int sanc_roll = random(1, 20) + monster.get_save_bonus(ABILITY_WIS);
			if (sanc_roll < target.sanctuary_dc) {
				broadcast_announce(monster.name + " is deterred by " + target.name + "'s Sanctuary!", false);
				return false;
			}
			broadcast_announce(monster.name + " resists " + target.name + "'s Sanctuary.", false);
		}

		// Xanathar's College of Glamour Bard L14 Unbreakable Majesty (para 562-565):
		// CHA save or can't attack this target this turn.
		if (target.unbreakable_majesty_active) {
			int um_dc = spell_save_dc(target);
			int um_roll = random(1, 20);
			int um_bonus = monster.get_save_bonus(ABILITY_CHA);
			int um_total = um_roll + um_bonus;
			if (um_total < um_dc) {
				broadcast_announce(monster.name + " is awed by " + target.name + "'s Unbreakable Majesty and cannot attack! (CHA " + um_total + " vs DC " + um_dc + ")", true);
				return false;
			}
			broadcast_announce(monster.name + " resists " + target.name + "'s Unbreakable Majesty (CHA " + um_total + " vs DC " + um_dc + ").", false);
		}

		bool attack_is_ranged = use_secondary ? monster_secondary_is_ranged(monster) : (monster.main_hand_range > 5 and attack_name_is_ranged(monster.main_hand));
		bool adv = false;
		bool disadv = false;
		apply_attack_advantage_state(monster, target, dist, attack_is_ranged, adv, disadv);

		string attack_name = get_attack_name(monster, use_secondary);
		// PHB 2024 Sentinel Guardian — fire on first attack of the sequence
		if (attack_index == 0) {
			check_sentinel_guardian(monster, target);
			if (monster.is_dead or @combat == null or !combat.battle_active) return false;
		}
		broadcast_announce(monster.name + " attacks " + target.name + " with " + attack_name + "!");

		pending_roll pr;
		pr.combatant_id = monster.id;
		pr.player_username = monster.name;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = get_attack_bonus_for_roll(monster, use_secondary);
		pr.reason = attack_name + " attack against " + target.name;
		pr.target_id = target.id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.attack_name = attack_name;
		pr.attack_index = attack_index;
		pr.damage_dice_count = get_attack_damage_count(monster, use_secondary);
		pr.damage_dice_sides = get_attack_damage_dice(monster, use_secondary);
		pr.damage_modifier = get_damage_modifier_for_attack(monster, use_secondary);
		pr.damage_type = get_attack_damage_type(monster, use_secondary);
		pr.is_weapon_attack = true;
		pr.attacks_remaining = attacks_remaining;
		@current_roll = pr;

		int roll1 = random(1, 20);
		int roll2 = random(1, 20);
		int natural = roll1;
		if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
		else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;

		process_roll_result(natural);
		return true;
	}

	bool start_player_bot_attack_sequence(combatant@ bot, combatant@ target) {
		if (@bot == null or @target == null or @combat == null or !bot.is_player or bot.is_dead or target.is_dead) return false;
		if (!combatant_is_controlled_by_bot(bot)) return false;

		int dist = feet_distance(bot.x, bot.y, target.x, target.y);
		if (dist > bot.main_hand_range) return false;
		if (!combat.can_see(bot, target)) return false;

		// Basic Rules 2024 Sanctuary (para 14826): WIS save before targeting
		if (target.sanctuary_active and target.sanctuary_dc > 0) {
			int sanc_roll = random(1, 20) + bot.get_save_bonus(ABILITY_WIS);
			if (sanc_roll < target.sanctuary_dc) {
				broadcast_announce(bot.name + " is deterred by " + target.name + "'s Sanctuary!", false);
				return false;
			}
			broadcast_announce(bot.name + " resists " + target.name + "'s Sanctuary.", false);
		}

		// Xanathar's College of Glamour Bard L14 Unbreakable Majesty (para 562-565):
		// CHA save or can't attack this target this turn.
		if (target.unbreakable_majesty_active) {
			int um_dc = spell_save_dc(target);
			int um_roll = random(1, 20);
			int um_bonus = bot.get_save_bonus(ABILITY_CHA);
			int um_total = um_roll + um_bonus;
			if (um_total < um_dc) {
				broadcast_announce(bot.name + " is awed by " + target.name + "'s Unbreakable Majesty and cannot attack! (CHA " + um_total + " vs DC " + um_dc + ")", true);
				return false;
			}
			broadcast_announce(bot.name + " resists " + target.name + "'s Unbreakable Majesty (CHA " + um_total + " vs DC " + um_dc + ").", false);
		}

		if (bot.attacks_remaining_this_turn > 0) {
			bot.attacks_remaining_this_turn--;
		} else {
			if (!bot.has_action) return false;
			bot.has_action = false;
			bot.used_action = true;
			bot.attacks_remaining_this_turn = bot.extra_attacks;
			// Basic Rules 2024 Haste (para 13688): +1 weapon attack (extra action approx)
			if (bot.hasted) bot.attacks_remaining_this_turn += 1;
			// PHB 2024 Sentinel Guardian — fire on first attack of the bot's Attack action
			check_sentinel_guardian(bot, target);
			if (bot.is_dead or @combat == null or !combat.battle_active) return false;
		}

		bool adv = false;
		bool disadv = false;
		apply_attack_advantage_state(bot, target, dist, bot.main_hand_is_ranged, adv, disadv);
		// PHB 2024 Skulker (para 7783): defer reveal for ranged Skulker attacks
		// Basic Rules 2024 Greater Invisibility (para 13658): does NOT break on attack.
		if (!bot.greater_invisibility_active and !(bot.is_hidden and bot.has_feat("skulker") and bot.main_hand_is_ranged)) {
			reveal_hidden_combatant(bot, "making an attack");
		}
		broadcast_announce(bot.name + " attacks " + target.name + " with " + bot.main_hand + ".", false);

		pending_roll pr;
		pr.combatant_id = bot.id;
		pr.player_username = bot.player_username;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = get_attack_bonus_for_roll(bot, false);
		pr.reason = bot.main_hand + " attack against " + target.name;
		pr.target_id = target.id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.attack_name = bot.main_hand;
		pr.damage_dice_count = get_attack_damage_count(bot, false);
		pr.damage_dice_sides = get_attack_damage_dice(bot, false);
		pr.damage_modifier = get_damage_modifier_for_attack(bot, false);
		pr.damage_type = bot.main_hand_damage_type;
		@current_roll = pr;

		int roll1 = random(1, 20);
		int roll2 = random(1, 20);
		int natural = roll1;
		if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
		else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
		process_roll_result(natural);
		return true;
	}

	void execute_player_bot_turn(combatant@ bot) {
		if (@bot == null or @combat == null or bot.is_dead or !bot.is_player) return;
		if (!combatant_is_controlled_by_bot(bot)) return;

		combatant@ nearest = find_nearest_hostile_target(bot);
		int nearest_dist = @nearest != null ? feet_distance(bot.x, bot.y, nearest.x, nearest.y) : 9999;
		if (@nearest == null) {
			broadcast_announce(bot.name + " has no targets and ends their turn.", false);
			advance_turn();
			return;
		}

		// PHB 2024 Prone: bot must spend half speed to stand before moving
		if (bot.has_condition(COND_PRONE)) {
			int stand_cost = bot.speed / 2;
			if (bot.movement_remaining >= stand_cost) {
				bot.movement_remaining -= stand_cost;
				bot.remove_condition(COND_PRONE);
				broadcast_announce(bot.name + " stands up (" + stand_cost + " ft used).", false);
			}
		}

		while (bot.movement_remaining >= FEET_PER_TILE and nearest_dist > bot.main_hand_range) {
			int old_x = bot.x;
			int old_y = bot.y;
			int dx = 0;
			int dy = 0;
			if (nearest.x > bot.x) dx = 1;
			else if (nearest.x < bot.x) dx = -1;
			if (nearest.y > bot.y) dy = 1;
			else if (nearest.y < bot.y) dy = -1;
			if (dx != 0) bot.x += dx;
			else if (dy != 0) bot.y += dy;
			else break;

			bot.movement_remaining -= FEET_PER_TILE;
			announce_movement_to_visible_players(bot, bot.x - old_x, bot.y - old_y, FEET_PER_TILE);
			check_opportunity_attacks(bot, old_x, old_y, bot.x, bot.y);
			if (@current_roll != null or bot.is_dead or bot.current_hp == 0) {
				broadcast_state();
				return;
			}
			nearest_dist = feet_distance(bot.x, bot.y, nearest.x, nearest.y);
		}

		broadcast_state();
		if (bot.has_action and nearest_dist <= bot.main_hand_range) {
			if (start_player_bot_attack_sequence(bot, nearest)) return;
		}

		broadcast_announce(bot.name + " ends their turn.", false);
		advance_turn();
	}

	void continue_player_bot_turn_after_attack(combatant@ bot, combatant@ preferred_target) {
		if (@bot == null or @combat == null or !bot.is_player) return;
		if (!combatant_is_controlled_by_bot(bot)) return;
		combatant@ active = combat.current_combatant();
		if (@active == null or active.id != bot.id) return;

		combatant@ next_target = preferred_target;
		if (@next_target == null or next_target.is_dead or !combat.are_hostile(bot, next_target) or feet_distance(bot.x, bot.y, next_target.x, next_target.y) > bot.main_hand_range) {
			@next_target = find_nearest_hostile_target(bot);
		}

		if (bot.attacks_remaining_this_turn > 0 and @next_target != null and next_target.is_alive()) {
			if (start_player_bot_attack_sequence(bot, next_target)) return;
		}

		broadcast_announce(bot.name + " ends their turn.", false);
		advance_turn();
	}

	monster_def@ choose_boss_monster() {
		int level_total = 0;
		int player_count = 0;
		if (@combat != null) {
			for (uint i = 0; i < combat.combatants.length(); i++) {
				if (!combat.combatants[i].is_player) continue;
				level_total += combat.combatants[i].level;
				player_count++;
			}
		}

		int effective_level = player_count > 0 ? level_total / player_count : 1;
		if (player_count >= 4) effective_level += 1;
		else if (player_count <= 1 and effective_level > 1) effective_level -= 1;

		if (effective_level <= 2) return get_monster_def("ogre");
		if (effective_level <= 4) return get_monster_def("owlbear");
		if (effective_level <= 6) return get_monster_def("troll");
		if (effective_level <= 8) return get_monster_def("young_white_dragon");
		if (effective_level <= 10) return get_monster_def("young_red_dragon");
		if (effective_level <= 13) return get_monster_def("beholder");
		if (effective_level <= 16) return get_monster_def("adult_black_dragon");
		if (effective_level <= 18) return get_monster_def("adult_red_dragon");
		if (effective_level <= 20) return get_monster_def("pit_fiend");
		monster_def@ boss = get_monster_def("lich");
		if (@boss == null) @boss = get_monster_def("pit_fiend");
		return boss;
	}

	void announce_turn_start(combatant@ c) {
		if (@c == null) return;

		// Tick down 1-minute concentration / curse counters at the start of the caster's turn.
		// Dancing Shadows (College of Shadow): 10-round sphere
		if (c.dancing_shadows_active) {
			c.dancing_shadows_rounds--;
			if (c.dancing_shadows_rounds <= 0) {
				c.dancing_shadows_active = false;
				broadcast_announce(c.name + "'s Dancing Shadows fade.", false);
			}
		}
		// Shadow Gnawer Consume Darkness L10: 1 HP regen at the start of each turn while
		// raging, after the initial bonus action heal. Source para 1202.
		if (c.consume_darkness_per_turn_heal > 0 and c.raging) {
			c.current_hp += 1;
			if (c.current_hp > c.max_hp) c.current_hp = c.max_hp;
		} else if (c.consume_darkness_per_turn_heal > 0 and !c.raging) {
			c.consume_darkness_per_turn_heal = 0;
		}
		// Venomous Mark (Mother of Sorrows): 10-round curse
		if (c.venomous_mark_target_id != 0 and c.venomous_mark_rounds > 0) {
			c.venomous_mark_rounds--;
			if (c.venomous_mark_rounds <= 0) {
				combatant@ vm_tgt = combat.get_combatant(c.venomous_mark_target_id);
				if (@vm_tgt != null) broadcast_announce(c.name + "'s Venomous Mark on " + vm_tgt.name + " fades.", false);
				c.venomous_mark_target_id = 0;
			}
		}

		// Refresh position-dependent aura bonuses at turn start
		refresh_paladin_auras();

		string round_text = "";
		if (combat.current_turn_index == 0) {
			round_text = "Round " + combat.round_number + "! ";
		}
		broadcast_announce(round_text + c.name + "'s turn.", true);

		broadcast_to_battle({
			{"type", message_types::turn_start},
			{"combatant_id", c.id},
			{"name", c.name},
			{"hp", c.current_hp},
			{"max_hp", c.max_hp},
			{"movement", c.movement_remaining},
			{"has_action", c.has_action},
			{"has_bonus_action", c.has_bonus_action},
			{"round", combat.round_number},
			{"turn_index", combat.current_turn_index}
		});

		broadcast_state();

		if (c.current_hp == 0 and c.has_condition(COND_UNCONSCIOUS) and !c.is_dead and !c.is_stable) {
			// Xanathar's Celestial Warlock L14 Searing Vengeance (paras 2745-2747):
			// "When you have to make a death saving throw at the start of your turn,
			// you can instead spring back to your feet with a burst of radiant energy.
			// You regain hit points equal to half your hit point maximum, and then you
			// stand up if you so choose. Each creature of your choice that is within
			// 30 feet of you takes radiant damage equal to 2d8 + your Charisma modifier,
			// and it is blinded until the end of the current turn."
			if (c.searing_vengeance_available and !c.searing_vengeance_used) {
				c.searing_vengeance_used = true;
				int heal_amt = c.max_hp / 2;
				c.current_hp = heal_amt;
				c.remove_condition(COND_UNCONSCIOUS);
				c.death_save_successes = 0;
				c.death_save_failures = 0;
				int cha_mod = c.get_ability_mod(ABILITY_CHA);
				int sv_dmg = random(1, 8) + random(1, 8) + cha_mod;
				if (sv_dmg < 1) sv_dmg = 1;
				broadcast_announce(c.name + " erupts with Searing Vengeance! Regains " + heal_amt + " HP!", true);
				for (uint svi = 0; svi < combat.combatants.length(); svi++) {
					combatant@ sv_t = combat.combatants[svi];
					if (@sv_t == null or sv_t.is_dead or sv_t.id == c.id) continue;
					if (sv_t.is_player == c.is_player) continue; // skip allies
					if (feet_distance(c.x, c.y, sv_t.x, sv_t.y) > 30) continue;
					combat.apply_damage(sv_t, sv_dmg, DMG_RADIANT, c);
					sv_t.add_condition(COND_BLINDED);
					broadcast_announce(sv_t.name + " takes " + sv_dmg + " radiant damage and is blinded!", false);
				}
				broadcast_state();
				// Continue turn normally — don't return, fall through to combat actions.
			} else {
				user@ u = find_user_for_combatant(c);
				if (c.is_player) {
					request_roll(u, c, ROLL_DEATH_SAVE, 20, 0, "death saving throw");
				} else {
					c.is_dead = true;
					advance_turn();
				}
				return;
			}
		}

		if (!c.is_player) {
			execute_monster_turn(c);
			return;
		}
		if (combatant_is_controlled_by_bot(c)) {
			execute_player_bot_turn(c);
			return;
		}
	}

	bool trigger_readied_actions(combatant@ turn_target) {
		if (@turn_target == null or @combat == null or turn_target.is_dead) return false;

		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ reactor = combat.combatants[i];
			if (@reactor == null or reactor.id == turn_target.id) continue;
			if (reactor.readied_action != READIED_ACTION_ATTACK) continue;
			if (reactor.readied_target_id != turn_target.id) continue;
			if (!reactor.is_alive() or !reactor.is_conscious()) continue;
			if (!reactor.has_reaction) continue;
			if (!combat.are_hostile(reactor, turn_target)) continue;

			int dist = feet_distance(reactor.x, reactor.y, turn_target.x, turn_target.y);
			if (dist > reactor.main_hand_range) continue;
			if (!combat.can_see(reactor, turn_target)) continue;

			bool adv = false;
			bool disadv = false;
			apply_attack_advantage_state(reactor, turn_target, dist, reactor.main_hand_is_ranged, adv, disadv);
			reveal_hidden_combatant(reactor, "making a readied attack");

			reactor.has_reaction = false;
			clear_readied_action(reactor);
			pending_turn_start_after_interrupt = true;

			broadcast_to_battle({{"type", message_types::reaction_ready_trigger}, {"attacker_id", reactor.id}, {"target_id", turn_target.id}});
			broadcast_announce(reactor.name + "'s readied attack triggers against " + turn_target.name + "!", true);

			pending_roll pr;
			pr.combatant_id = reactor.id;
			pr.player_username = reactor.is_player ? reactor.player_username : reactor.name;
			pr.roll_type = ROLL_ATTACK;
			pr.dice_sides = 20;
			pr.modifier = get_attack_bonus_for_roll(reactor, false);
			pr.reason = reactor.main_hand + " readied attack against " + turn_target.name;
			pr.target_id = turn_target.id;
			pr.has_advantage = adv;
			pr.has_disadvantage = disadv;
			pr.attack_name = reactor.main_hand;
			pr.damage_dice_count = get_attack_damage_count(reactor, false);
			pr.damage_dice_sides = get_attack_damage_dice(reactor, false);
			pr.damage_modifier = get_damage_modifier_for_attack(reactor, false);
			pr.damage_type = reactor.main_hand_damage_type;
			pr.is_weapon_attack = true;
			pr.resume_turn_start = true;
			@current_roll = pr;

			user@ reactor_user = find_user_for_combatant(reactor);
			if (@reactor_user != null and !reactor_user.is_bot and reactor.is_player) {
				send_roll_request(reactor_user, pr);
			} else {
				int roll1 = random(1, 20);
				int roll2 = random(1, 20);
				int natural = roll1;
				if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
				else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
				process_roll_result(natural);
			}
			return true;
		}

		return false;
	}

	void continue_pending_turn_start() {
		if (!pending_turn_start_after_interrupt or @combat == null or !combat.battle_active) return;
		pending_turn_start_after_interrupt = false;

		combatant@ c = combat.current_combatant();
		if (@c == null) return;
		if (c.is_dead) {
			advance_turn();
			return;
		}
		if (c.is_stable and c.current_hp == 0) {
			advance_turn();
			return;
		}
		if (trigger_readied_actions(c)) return;
		announce_turn_start(c);
	}

	void clear_shield_effect(combatant@ target, bool announce = false) {
		if (@target == null or !target.shield_active) return;
		target.armor_class -= target.shield_ac_bonus;
		if (target.armor_class < 0) target.armor_class = 0;
		target.shield_active = false;
		target.shield_ac_bonus = 0;
		if (announce) {
			broadcast_announce("Shield fades from " + target.name + ".", false);
		}
	}

	void clear_bless_effect(combatant@ target, bool announce = false) {
		if (@target == null or !target.blessed) return;
		target.blessed = false;
		target.bless_source_id = 0;
		if (announce) {
			broadcast_announce("Bless fades from " + target.name + ".", false);
		}
	}

	int roll_bless_bonus(combatant@ target) {
		if (@target == null or !target.blessed or target.is_dead) return 0;
		return random(1, 4);
	}

	// Xanathar's War Magic L2 Arcane Deflection save variant (para 2932-2934): "When
	// you fail a saving throw, you can use your reaction to gain a +4 bonus to that
	// saving throw." Restriction: can't cast non-cantrip spells until end of next turn.
	// Auto-fires for the target themselves if they are a War Magic Wizard with reaction.
	// Returns true if the +4 turned the failure into a success.
	bool try_arcane_deflection_save(combatant@ target, int save_dc, int save_total) {
		if (@target == null) return false;
		if (target.class_name != "Wizard" or target.subclass != "War Magic") return false;
		if (!target.arcane_deflection_available or !target.has_reaction) return false;
		int new_total = save_total + 4;
		if (new_total < save_dc) return false; // Smart-spend: only use if it actually helps
		target.has_reaction = false;
		target.arcane_deflection_no_spell_turns = 2; // Blocks non-cantrip until end of next turn
		broadcast_announce(target.name + " uses Arcane Deflection! +4 to saving throw (total " + new_total + " vs DC " + save_dc + ") — saved!", true);
		// L14 Deflecting Shroud: deal damage to up to 3 enemies within 60 ft
		if (target.deflecting_shroud_active and target.level >= 14) {
			int shroud_dmg = target.level / 2;
			if (shroud_dmg < 1) shroud_dmg = 1;
			int hits = 0;
			for (uint dsi = 0; dsi < combat.combatants.length(); dsi++) {
				if (hits >= 3) break;
				combatant@ ds = combat.combatants[dsi];
				if (@ds == null or ds.is_dead or ds.id == target.id) continue;
				if (ds.is_player == target.is_player) continue;
				if (feet_distance(target.x, target.y, ds.x, ds.y) > 60) continue;
				combat.apply_damage(ds, shroud_dmg, DMG_FORCE, target);
				broadcast_announce(target.name + "'s Deflecting Shroud deals " + shroud_dmg + " force damage to " + ds.name + "!", false);
				hits++;
			}
		}
		return true;
	}

	// PHB 2024 Bard L7 Countercharm (paras 2756-2757): "If you or a creature within
	// 30 feet of you fails a saving throw against an effect that applies the Charmed
	// or Frightened condition, you can take a Reaction to cause the save to be
	// rerolled, and the new roll has Advantage."
	// Auto-fires for any L7+ Bard ally within 30 ft of the failing target who still
	// has their reaction. Returns true if the reroll turned the failed save into a
	// success (caller should treat the save as passed and skip applying the condition).
	bool try_countercharm_reroll(combatant@ target, int save_dc, int save_bonus, string save_label) {
		if (@target == null or @combat == null) return false;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ bard = combat.combatants[i];
			if (@bard == null or bard.is_dead) continue;
			if (bard.class_name != "Bard" or bard.level < 7) continue;
			if (!bard.countercharm_active) continue;
			if (!bard.has_reaction) continue;
			// Source allows self ("you or a creature within 30 feet of you").
			// Allies only (not enemies) unless this is PvP.
			if (bard.is_player != target.is_player and combat.mode != "pvp") continue;
			if (feet_distance(bard.x, bard.y, target.x, target.y) > 30) continue;
			int r1 = random(1, 20);
			int r2 = random(1, 20);
			int new_roll = r1 > r2 ? r1 : r2;
			int new_total = new_roll + save_bonus;
			bard.has_reaction = false;
			bool new_saved = new_total >= save_dc;
			broadcast_announce(bard.name + " uses Countercharm! " + target.name + " rerolls the " + save_label + " with advantage (" + r1 + "/" + r2 + ", total " + new_total + ") — " + (new_saved ? "saved!" : "still failed."), true);
			return new_saved;
		}
		return false;
	}

	// Xanathar's Zealot L6 Fanatical Focus (para 443-444): "If you fail a saving throw
	// while you're raging, you can reroll it, and you must use the new roll. You can use
	// this ability only once per rage."
	// Returns the new total if the reroll succeeded, or the original total if not used.
	int try_fanatical_focus(combatant@ target, int save_dc, int save_total, int save_bonus, string save_label) {
		if (@target == null) return save_total;
		if (target.class_name != "Barbarian" or target.subclass != "Zealot" or target.level < 6) return save_total;
		if (!target.raging or target.fanatical_focus_used_this_rage) return save_total;
		target.fanatical_focus_used_this_rage = true;
		int reroll = random(1, 20);
		int new_total = reroll + save_bonus;
		bool new_saved = new_total >= save_dc;
		broadcast_announce(target.name + "'s Fanatical Focus rerolls the " + save_label + ": " + new_total + (new_saved ? " — saved!" : " — still failed."), true);
		return new_total;
	}

	// Xanathar's Shadow Magic L6 Hound of Ill Omen (para 2596-2602): "If the hound
	// is within 5 feet of the target at the start of the target's turn, the target
	// has disadvantage on saving throws against any spell you cast."
	// Checks: target has hound_caster_id matching the spell caster, and the hound
	// companion is alive and within 5ft. Modifies save_roll in place (takes lower).
	bool apply_hound_save_disadvantage(combatant@ target, uint caster_id, int &inout save_roll) {
		if (@target == null or target.hound_caster_id == 0 or target.hound_caster_id != caster_id) return false;
		if (@combat == null) return false;
		for (uint hi = 0; hi < combat.combatants.length(); hi++) {
			combatant@ h = combat.combatants[hi];
			if (@h == null or h.is_dead or !h.is_alive()) continue;
			if (!h.is_companion or h.owner_id != caster_id) continue;
			if (h.companion_subclass != "hound_of_ill_omen") continue;
			if (feet_distance(h.x, h.y, target.x, target.y) <= 5) {
				// Xanathar's Drunken Master L11 Drunkard's Luck (para 1798-1800): "Whenever
				// you make an ability check, an attack roll, or a saving throw and have
				// disadvantage, you can spend 2 ki points to cancel the disadvantage."
				if (target.drunkards_luck_active and target.focus_points >= 2) {
					target.focus_points -= 2;
					broadcast_announce(target.name + " spends 2 Focus Points — Drunkard's Luck cancels the disadvantage!", false);
					return false;
				}
				int hound_roll = random(1, 20);
				if (hound_roll < save_roll) save_roll = hound_roll;
				broadcast_announce(target.name + " has disadvantage — Hound of Ill Omen!", false);
				return true;
			}
		}
		return false;
	}

	// PHB 2024 Forge Artificer L7 Flash of Genius (paras 655-657): "When you or a
	// creature you can see within 30 feet of you fails an ability check or a saving
	// throw, you can take a Reaction to add a bonus to the roll, potentially causing
	// it to succeed. The bonus equals your Intelligence modifier (minimum of +1)."
	// Smart-spend: only auto-fires for an L7+ Artificer ally with reaction available
	// AND only if the bonus would actually turn the failure into a success. Returns
	// the new total (unchanged if no Flash of Genius applied). For checks vs DC use
	// this on the rolled total before comparing to dc; for saves use it on save_total.
	int try_flash_of_genius(combatant@ target, int dc, int current_total, string label) {
		if (@target == null or @combat == null) return current_total;
		if (current_total >= dc) return current_total; // not failing
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ art = combat.combatants[i];
			if (@art == null or art.is_dead) continue;
			if (art.class_name != "Artificer" or art.level < 7) continue;
			if (art.flash_of_genius_uses_current <= 0) continue;
			if (!art.has_reaction) continue;
			// Source allows self ("you or a creature you can see within 30 feet of you").
			// Allies only (not enemies) unless this is PvP.
			if (art.is_player != target.is_player and combat.mode != "pvp") continue;
			if (feet_distance(art.x, art.y, target.x, target.y) > 30) continue;
			int int_mod = art.get_ability_mod(ABILITY_INT);
			if (int_mod < 1) int_mod = 1;
			int new_total = current_total + int_mod;
			if (new_total < dc) continue; // smart-spend: don't waste the use if it can't succeed
			art.flash_of_genius_uses_current--;
			art.has_reaction = false;
			broadcast_announce(art.name + " uses Flash of Genius! " + target.name + " adds +" + int_mod + " to the " + label + " (new total " + new_total + ") — succeeded!", true);
			return new_total;
		}
		return current_total;
	}

	// PHB 2024 Mage Slayer feat Guarded Mind (para 7693): "If you fail an Intelligence,
	// Wisdom, or Charisma saving throw, you can cause yourself to succeed instead.
	// Once you use this benefit, you can't use it again until you finish a Short or
	// Long Rest." Returns true if the save was auto-succeeded.
	bool try_mage_slayer_guarded_mind(combatant@ target, int ability_id) {
		if (@target == null) return false;
		if (!target.has_feat("mage_slayer")) return false;
		if (target.mage_slayer_guarded_mind_used) return false;
		if (ability_id != ABILITY_INT and ability_id != ABILITY_WIS and ability_id != ABILITY_CHA) return false;
		target.mage_slayer_guarded_mind_used = true;
		string ability_name = "WIS";
		if (ability_id == ABILITY_INT) ability_name = "INT";
		else if (ability_id == ABILITY_CHA) ability_name = "CHA";
		broadcast_announce(target.name + "'s Mage Slayer (Guarded Mind) auto-succeeds the " + ability_name + " saving throw!", true);
		return true;
	}

	// PHB 2024 Boon of Fate (para 7877): "When you or another creature within 60 feet
	// of you succeeds on or fails a D20 Test, you can roll 2d4 and apply the total
	// rolled as a bonus or penalty to the d20 roll." 1/SR or Initiative.
	// For ally saves: applies as bonus (turns failure into success).
	// Returns the 2d4 bonus if used (0 if not used or wouldn't help).
	int try_boon_of_fate_bonus(combatant@ target, int current_total, int dc) {
		if (@target == null or @combat == null) return 0;
		// Scan for any ally with Boon of Fate within 60 ft (including self)
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ helper = combat.combatants[i];
			if (@helper == null or helper.is_dead) continue;
			if (!helper.has_feat("boon_of_fate")) continue;
			if (helper.boon_of_fate_used) continue;
			if (!helper.is_player) continue;
			// Must be on the same side as the target
			if (combat.are_hostile(helper, target)) continue;
			int dist = feet_distance(helper.x, helper.y, target.x, target.y);
			if (dist > 60) continue;
			// Smart-spend: only commit if the 2d4 (2-8) could turn the failure into success
			int max_bonus = 8;
			if (current_total + max_bonus < dc) continue; // Even max can't help
			int bonus = random(1, 4) + random(1, 4);
			if (current_total + bonus >= dc) {
				helper.boon_of_fate_used = true;
				broadcast_announce(helper.name + "'s Boon of Fate adds +" + bonus + " to " + target.name + "'s saving throw! New total: " + (current_total + bonus) + " vs DC " + dc + ".", true);
				return bonus;
			}
			// Rolled but wasn't enough — don't consume (try next ally if any)
		}
		return 0;
	}

	// PHB 2024 Monk L14 Disciplined Survivor (paras 5367-5369): "Whenever you make a
	// saving throw and fail, you can expend 1 Focus Point to reroll it, and you must
	// use the new roll."
	// Smart-spend: only fires if reroll could feasibly pass (nat 20 + bonus >= dc).
	// Returns new total if used, original total if not.
	int try_disciplined_survivor_reroll(combatant@ target, int save_dc, int save_total, int save_bonus, string save_label) {
		if (@target == null) return save_total;
		if (!target.disciplined_survivor_active) return save_total;
		if (target.focus_points <= 0) return save_total;
		// Smart-spend: only if a natural 20 + bonus could pass
		if (20 + save_bonus < save_dc) return save_total;
		target.focus_points--;
		int reroll = random(1, 20);
		int new_total = reroll + save_bonus;
		bool new_saved = new_total >= save_dc;
		broadcast_announce(target.name + " spends 1 Focus Point for Disciplined Survivor reroll on " + save_label + ": " + new_total + (new_saved ? " — saved!" : " — still failed.") + " (" + target.focus_points + " FP remaining)", true);
		return new_total;
	}

	// PHB 2024 Rogue L20 Stroke of Luck (paras 6579-6581): "If you fail a D20 Test,
	// you can turn the roll into a 20." Once per Short or Long Rest.
	// Auto-fires as absolute last resort on save failures. Returns true if saved.
	bool try_stroke_of_luck_save(combatant@ target, int save_dc, int save_bonus) {
		if (@target == null) return false;
		if (target.class_name != "Rogue" or !target.stroke_of_luck_available) return false;
		int new_total = 20 + save_bonus;
		if (new_total < save_dc) return false; // Even a 20 won't pass
		target.stroke_of_luck_available = false;
		broadcast_announce(target.name + "'s Stroke of Luck turns the saving throw into a 20! New total: " + new_total + " — saved!", true);
		return true;
	}

	// Valda's Spire Gunslinger maneuver Grazing Shot (paras 213-214): "When you miss with
	// a ranged attack roll using a weapon, you can expend one Risk Die (no action required)
	// to deal damage to that creature equal to a roll of the die plus your Dexterity
	// modifier (minimum of 1). This damage is the same type dealt by the weapon, and the
	// damage can be increased only by increasing the ability modifier. You can only use
	// this maneuver once per turn."
	// Returns true if Grazing Shot was used (and applied damage server-side).
	bool try_grazing_shot(combatant@ attacker, combatant@ target, int weapon_dmg_type) {
		if (@attacker == null or @target == null) return false;
		if (attacker.class_name != "Gunslinger") return false;
		if (attacker.risk_dice_current <= 0) return false;
		if (attacker.grazing_shot_used_this_turn) return false;
		if (!attacker.main_hand_is_ranged) return false;
		if (target.is_dead) return false;
		attacker.grazing_shot_used_this_turn = true;
		attacker.risk_dice_current--;
		int gs_roll = random(1, attacker.risk_die_size);
		int dex_mod = attacker.get_ability_mod(ABILITY_DEX);
		if (dex_mod < 1) dex_mod = 1;
		int gs_damage = gs_roll + dex_mod;
		string dmg_name = (weapon_dmg_type >= 0 and weapon_dmg_type < int(DAMAGE_TYPE_NAMES.length())) ? DAMAGE_TYPE_NAMES[weapon_dmg_type] : "weapon";
		broadcast_announce(attacker.name + " uses Grazing Shot! Risk Die 1d" + attacker.risk_die_size + " (" + gs_roll + ") + DEX mod " + dex_mod + " = " + gs_damage + " " + dmg_name + " damage to " + target.name + ". (" + attacker.risk_dice_current + "/" + attacker.risk_dice_max + " Risk Dice)", true);
		combat.apply_damage(target, gs_damage, weapon_dmg_type, attacker);
		return true;
	}

	// Valda's Spire Gunslinger maneuver Maverick Spirit (paras 215-216): "When you fail
	// an Intelligence, Wisdom, or Charisma ability check or saving throw, you can expend
	// one Risk Die to add it to the roll, potentially turning it into a success. You can
	// only use this maneuver once per turn." Smart-spend: only auto-fires if the rolled
	// Risk Die would actually turn the failure into a success.
	// High Roller L10 Risk Taker (paras 267-268): the Gunslinger may use Maverick Spirit
	// without expending a Risk Die — instead rolls a d6.
	int try_maverick_spirit(combatant@ target, int dc, int current_total, string label) {
		if (@target == null) return current_total;
		if (target.class_name != "Gunslinger") return current_total;
		if (current_total >= dc) return current_total; // not failing
		if (target.maverick_spirit_used_this_turn) return current_total;
		bool risk_taker = (target.subclass == "High Roller" and target.risk_taker_active);
		if (!risk_taker and target.risk_dice_current <= 0) return current_total;
		// Smart-spend: roll the die and only commit if it turns the failure into a success.
		int die_size = risk_taker ? 6 : target.risk_die_size;
		int ms_roll = random(1, die_size);
		int new_total = current_total + ms_roll;
		if (new_total < dc) return current_total; // would still fail — don't burn the use
		target.maverick_spirit_used_this_turn = true;
		string die_label = "1d" + die_size;
		string source_label;
		if (risk_taker) {
			source_label = " (Risk Taker free use)";
		} else {
			target.risk_dice_current--;
			source_label = " (" + target.risk_dice_current + "/" + target.risk_dice_max + " Risk Dice)";
		}
		broadcast_announce(target.name + " uses Maverick Spirit! Adds " + die_label + " (" + ms_roll + ") to the " + label + " (new total " + new_total + ") — succeeded!" + source_label, true);
		return new_total;
	}

	// Valda's Spire Gunslinger Deadeye L3 Eagle Eye [Maneuver] (paras 240-241): "Once per
	// turn when you miss with a ranged attack roll, you can expend one Risk Die and add
	// it to the attack roll, potentially causing the attack to hit." Smart-spend: only
	// commits if the rolled Risk Die would actually turn the miss into a hit.
	// Returns the new attack total (may equal current_total if no use).
	int try_eagle_eye(combatant@ attacker, combatant@ target, int current_total) {
		if (@attacker == null or @target == null) return current_total;
		if (attacker.class_name != "Gunslinger" or attacker.subclass != "Deadeye") return current_total;
		if (current_total >= target.armor_class) return current_total; // already hits
		if (attacker.risk_dice_current <= 0) return current_total;
		if (attacker.eagle_eye_used_this_turn) return current_total;
		if (!attacker.main_hand_is_ranged) return current_total;
		// Smart-spend: roll the die first; only commit if it turns the miss into a hit.
		int ee_roll = random(1, attacker.risk_die_size);
		int new_total = current_total + ee_roll;
		if (new_total < target.armor_class) return current_total;
		attacker.eagle_eye_used_this_turn = true;
		attacker.risk_dice_current--;
		broadcast_announce(attacker.name + " uses Eagle Eye! Adds 1d" + attacker.risk_die_size + " (" + ee_roll + ") to the missed attack roll (new total " + new_total + " vs AC " + target.armor_class + ") — hit! (" + attacker.risk_dice_current + "/" + attacker.risk_dice_max + " Risk Dice)", true);
		return new_total;
	}

	// Valda's Spire Gunslinger Trick Shot L3 Ricochet [Maneuver] (paras 442-443): "When
	// you miss with a ranged attack using a weapon, you can take a Bonus Action and
	// expend one Risk Die to reroll the attack and add the Risk Die to the roll. You
	// must use the new roll." Smart-spend: only commits if Bonus Action available AND
	// the rerolled total would hit. Returns the new attack total.
	int try_ricochet(combatant@ attacker, combatant@ target, int current_total, int attack_modifier) {
		if (@attacker == null or @target == null) return current_total;
		if (attacker.class_name != "Gunslinger" or attacker.subclass != "Trick Shot") return current_total;
		if (current_total >= target.armor_class) return current_total; // already hits
		if (attacker.risk_dice_current <= 0) return current_total;
		if (!attacker.has_bonus_action) return current_total;
		if (attacker.ricochet_used_this_turn) return current_total;
		if (!attacker.main_hand_is_ranged) return current_total;
		// Smart-spend: roll the new d20 + risk die first, only commit if it hits.
		int new_natural = random(1, 20);
		int rc_roll = random(1, attacker.risk_die_size);
		int new_total = new_natural + attack_modifier + rc_roll;
		if (new_total < target.armor_class) return current_total;
		attacker.ricochet_used_this_turn = true;
		attacker.risk_dice_current--;
		attacker.has_bonus_action = false;
		attacker.used_bonus_action = true;
		broadcast_announce(attacker.name + " uses Ricochet (Bonus Action)! Rerolled attack: " + new_natural + " + " + attack_modifier + " + 1d" + attacker.risk_die_size + " (" + rc_roll + ") = " + new_total + " vs AC " + target.armor_class + " — hit! (" + attacker.risk_dice_current + "/" + attacker.risk_dice_max + " Risk Dice)", true);
		return new_total;
	}

	void clear_haste_effect(combatant@ target, bool apply_lethargy = true, bool announce = true) {
		if (@target == null or !target.hasted) return;
		target.speed = target.speed / 2;
		target.armor_class -= 2;
		if (target.armor_class < 0) target.armor_class = 0;
		target.hasted = false;
		target.haste_source_id = 0;
		if (apply_lethargy and target.is_alive()) target.haste_loses_next_turn = true;
		if (announce) {
			string text = "Haste ends on " + target.name + ".";
			if (apply_lethargy and target.is_alive()) text += " " + target.name + " becomes lethargic.";
			broadcast_announce(text, true);
		}
	}

	// Xanathar's Arcane Archer Piercing Arrow (Transmutation, para 1636-1638):
	// "the arrow shoots forward in a line, which is 1 foot wide and 30 feet long...
	// Each creature in that line must make a Dexterity saving throw. On a failed
	// save, a creature takes damage as if it were hit by the arrow, plus an extra
	// 1d6 piercing damage. On a successful save, a target takes half as much damage."
	void resolve_piercing_arrow(combatant@ c) {
		if (@combat == null or @c == null) return;
		int as_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
		int shot_dice = c.level >= 18 ? 2 : 1;
		// Calculate base weapon damage (longbow/shortbow assumed ranged + DEX)
		int weapon_dmg = 0;
		for (int wd = 0; wd < c.main_hand_damage_count; wd++) weapon_dmg += random(1, c.main_hand_damage_dice);
		weapon_dmg += c.get_ability_mod(ABILITY_DEX);
		// Extra piercing dice from the shot
		for (int ed = 0; ed < shot_dice; ed++) weapon_dmg += random(1, 6);
		if (weapon_dmg < 1) weapon_dmg = 1;
		// Determine line direction toward nearest hostile
		combatant@ line_target = null;
		int best_d = 999;
		for (uint lt = 0; lt < combat.combatants.length(); lt++) {
			combatant@ ct = combat.combatants[lt];
			if (@ct == null or ct.is_dead or ct.id == c.id or !combat.are_hostile(c, ct)) continue;
			int d = feet_distance(c.x, c.y, ct.x, ct.y);
			if (d < best_d) { best_d = d; @line_target = ct; }
		}
		if (@line_target == null) {
			broadcast_announce(c.name + "'s Piercing Arrow finds no targets in range!", false);
			return;
		}
		float dx = float(line_target.x - c.x);
		float dy = float(line_target.y - c.y);
		float len = sqrt(dx * dx + dy * dy);
		if (len < 0.001f) { dx = 1.0f; dy = 0.0f; len = 1.0f; }
		float ndx = dx / len;
		float ndy = dy / len;
		broadcast_announce(c.name + "'s Piercing Arrow fires in a 30ft line! (DEX save DC " + as_dc + ")", true);
		int targets_hit = 0;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ ct = combat.combatants[i];
			if (@ct == null or ct.is_dead or ct.id == c.id) continue;
			if (!combat.are_hostile(c, ct)) continue;
			int dist = feet_distance(c.x, c.y, ct.x, ct.y);
			if (dist > 30 or dist == 0) continue;
			// Check if creature is roughly on the line (within 1 tile / 5ft perp distance)
			float tx = float(ct.x - c.x);
			float ty = float(ct.y - c.y);
			float proj = tx * ndx + ty * ndy;
			if (proj <= 0) continue; // Behind the archer
			float perp = abs(tx * ndy - ty * ndx) * 5.0f;
			if (perp > 5.0f) continue; // Too far from the line
			// DEX save with full save failure chain
			int sn = random(1, 20);
			apply_hound_save_disadvantage(ct, c.id, sn);
			int sb = ct.get_save_bonus(ABILITY_DEX);
			int bl = roll_bless_bonus(ct);
			int st = sn + sb + bl;
			bool saved = st >= as_dc;
			if (!saved and try_arcane_deflection_save(ct, as_dc, st)) saved = true;
			if (!saved) { int fg = try_flash_of_genius(ct, as_dc, st, "DEX save vs Piercing Arrow"); if (fg >= as_dc) saved = true; }
			if (!saved) { int mv = try_maverick_spirit(ct, as_dc, st, "DEX save vs Piercing Arrow"); if (mv >= as_dc) saved = true; }
			if (!saved) { int bf = try_boon_of_fate_bonus(ct, st, as_dc); if (bf >= as_dc) saved = true; }
			if (!saved and try_stroke_of_luck_save(ct, as_dc, sb + bl)) saved = true;
			int dmg = saved ? weapon_dmg / 2 : weapon_dmg;
			broadcast_roll(ct.name, "DEX save vs Piercing Arrow", sn, sb + bl, st, saved ? "Saved! (" + dmg + " dmg)" : "Failed! (" + dmg + " dmg)");
			combat.apply_damage(ct, dmg, DMG_PIERCING, c);
			targets_hit++;
		}
		if (targets_hit == 0) broadcast_announce("The Piercing Arrow finds no creatures in its path.", false);
		broadcast_state();
		check_battle_end();
	}

	// Xanathar's Arcane Archer Seeking Arrow (Divination, para 1640-1643):
	// "choose one creature you have seen in the past minute. The arrow flies toward
	// that creature, moving around corners... the target must make a Dexterity saving
	// throw. On a failed save, the target takes damage as if it were hit by the arrow,
	// plus an extra 1d6 force damage... On a successful save, half damage."
	void resolve_seeking_arrow(combatant@ c) {
		if (@combat == null or @c == null) return;
		int as_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
		int shot_dice = c.level >= 18 ? 2 : 1;
		// Find nearest hostile target (seeking ignores cover/LoS)
		combatant@ target = null;
		int best_d = 999;
		for (uint st = 0; st < combat.combatants.length(); st++) {
			combatant@ ct = combat.combatants[st];
			if (@ct == null or ct.is_dead or ct.id == c.id or !combat.are_hostile(c, ct)) continue;
			int d = feet_distance(c.x, c.y, ct.x, ct.y);
			if (d < best_d) { best_d = d; @target = ct; }
		}
		if (@target == null) {
			broadcast_announce(c.name + "'s Seeking Arrow finds no targets!", false);
			return;
		}
		// Calculate weapon damage + extra force dice
		int weapon_dmg = 0;
		for (int wd = 0; wd < c.main_hand_damage_count; wd++) weapon_dmg += random(1, c.main_hand_damage_dice);
		weapon_dmg += c.get_ability_mod(ABILITY_DEX);
		for (int ed = 0; ed < shot_dice; ed++) weapon_dmg += random(1, 6);
		if (weapon_dmg < 1) weapon_dmg = 1;
		broadcast_announce(c.name + "'s Seeking Arrow hones in on " + target.name + "! (DEX save DC " + as_dc + ")", true);
		// DEX save with full save failure chain
		int sn = random(1, 20);
		apply_hound_save_disadvantage(target, c.id, sn);
		int sb = target.get_save_bonus(ABILITY_DEX);
		int bl = roll_bless_bonus(target);
		int st = sn + sb + bl;
		bool saved = st >= as_dc;
		if (!saved and try_arcane_deflection_save(target, as_dc, st)) saved = true;
		if (!saved) { int fg = try_flash_of_genius(target, as_dc, st, "DEX save vs Seeking Arrow"); if (fg >= as_dc) saved = true; }
		if (!saved) { int mv = try_maverick_spirit(target, as_dc, st, "DEX save vs Seeking Arrow"); if (mv >= as_dc) saved = true; }
		if (!saved) { int bf = try_boon_of_fate_bonus(target, st, as_dc); if (bf >= as_dc) saved = true; }
		if (!saved and try_stroke_of_luck_save(target, as_dc, sb + bl)) saved = true;
		int dmg = saved ? weapon_dmg / 2 : weapon_dmg;
		broadcast_roll(target.name, "DEX save vs Seeking Arrow", sn, sb + bl, st, saved ? "Saved! (" + dmg + " dmg)" : "Failed! (" + dmg + " dmg)");
		combat.apply_damage(target, dmg, DMG_FORCE, c);
		broadcast_state();
		check_battle_end();
	}

	void clear_concentration_effects(combatant@ caster) {
		if (@caster == null or @combat == null) return;
		// Xanathar's War Magic L10 Durable Magic (para 2941-2942): remove +2 AC
		// granted while concentrating.
		if (caster.durable_magic_active and caster.is_concentrating) {
			caster.armor_class -= 2;
		}
		// Bane: per-caster cleanup — only clear baned flag on targets cursed by THIS caster.
		if (caster.concentration_spell == "Bane" or caster.concentration_spell == "bane") {
			for (uint bi = 0; bi < combat.combatants.length(); bi++) {
				combatant@ b_t = combat.combatants[bi];
				if (@b_t != null and b_t.baned and b_t.bane_source_id == caster.id) {
					b_t.baned = false;
					b_t.bane_source_id = 0;
				}
			}
		}
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ target = combat.combatants[i];
			if (@target == null) continue;
			if (target.bless_source_id == caster.id) {
				clear_bless_effect(target, true);
			}
			if (target.haste_source_id == caster.id) {
				clear_haste_effect(target, true, true);
			}
			if (target.heroism_source_id == caster.id) {
				clear_heroism_effect(target, true);
			}
			if (target.pass_without_trace_source_id == caster.id) {
				clear_pass_without_trace_effect(target, true);
			}
			if (target.adjust_density_active and target.adjust_density_caster_id == caster.id) {
				clear_adjust_density(target, true);
			}
		}
		caster.hunters_mark_target_id = 0;
		caster.hex_target_id = 0;
		caster.hex_cursed_ability = -1;
		// Spirit Guardians: 15ft aura concentration spell — must stop dealing damage
		caster.spirit_guardians_active = false;
		caster.spirit_guardians_slot_level = 0;
		caster.spirit_guardians_necrotic = false;
		// Divine Favor: +1d4 radiant on weapon hits (concentration)
		caster.divine_favor_active = false;
		// Holy Weapon: +2d8 radiant on weapon hits (concentration)
		caster.holy_weapon_active = false;
		// Fire Shield: warm/chill shield (concentration)
		// Basic Rules 2024 Fire Shield (para 13322): clears resistance on break.
		// Warm shield grants cold resistance; chill shield grants fire resistance.
		if (caster.fire_shield_active) {
			if (caster.fire_shield_warm) caster.cold_resistance = false;
			else caster.fire_resistance = false;
		}
		caster.fire_shield_active = false;
		// Stoneskin: B/P/S resistance (concentration)
		// Basic Rules 2024 Stoneskin (para 15008): clears B/P/S resistance on break.
		// Edge case: if creature had natural B/P/S resistance, it's lost until re-init.
		if (caster.stoneskin_active) {
			caster.piercing_resistance = false;
			caster.bludgeoning_resistance = false;
			caster.slashing_resistance = false;
		}
		caster.stoneskin_active = false;
		// Fly: grant flying speed (concentration)
		if (caster.fly_active) {
			caster.fly_active = false;
			caster.flying_speed = 0;
		}
		// Ensnaring Strike: pending weapon hit rider (concentration)
		caster.ensnaring_strike_pending = false;
		// Basic Rules 2024 Searing Smite (para 14881): clear repeating DOT on targets
		caster.searing_smite_pending = false;
		caster.searing_smite_dice = 0;
		for (uint ssi = 0; ssi < combat.combatants.length(); ssi++) {
			combatant@ ss_t = combat.combatants[ssi];
			if (@ss_t != null and ss_t.searing_smite_caster_id == caster.id) {
				ss_t.searing_smite_caster_id = 0;
				ss_t.searing_smite_dot_dice = 0;
			}
		}
		// Basic Rules 2024 Shining Smite (para 14976): clear debuff on targets
		caster.shining_smite_pending = false;
		caster.shining_smite_dice = 0;
		for (uint shi = 0; shi < combat.combatants.length(); shi++) {
			combatant@ sh_t = combat.combatants[shi];
			if (@sh_t != null and sh_t.shining_smite_debuff_source_id == caster.id) {
				sh_t.shining_smite_debuff = false;
				sh_t.shining_smite_debuff_source_id = 0;
				sh_t.shining_smite_debuff_rounds = 0;
				sh_t.starry_wisp_no_invis = false; // Clear shared invisibility block
			}
		}
		// Sanctuary: protection aura on target (concentration)
		// Clear any sanctuary sourced by this caster on all combatants
		for (uint sci = 0; sci < combat.combatants.length(); sci++) {
			combatant@ sc = combat.combatants[sci];
			if (@sc == null) continue;
			if (sc.sanctuary_active and sc.sanctuary_source_id == caster.id) {
				sc.sanctuary_active = false;
				sc.sanctuary_dc = 0;
				sc.sanctuary_source_id = 0;
			}
		}
		// Venomous Mark: curse damage on target (concentration)
		caster.venomous_mark_target_id = 0;
		caster.venomous_mark_rounds = 0;
		// Concentration AoE per-turn tracking (Cloudkill, Stinking Cloud,
		// Spike Growth, Insect Plague, Evard's Black Tentacles)
		caster.conc_aoe_x = 0;
		caster.conc_aoe_y = 0;
		caster.conc_aoe_slot_level = 0;
		// Moonbeam per-turn tracking
		caster.moonbeam_active = false;
		caster.moonbeam_x = 0;
		caster.moonbeam_y = 0;
		caster.moonbeam_slot_level = 0;
		// Area effects — fog_cloud/darkness are positional not per-caster,
		// so we clear the caster's flag (damage/visibility effects will
		// be handled separately if positional tracking is added later).
		caster.fog_cloud_active = false;
		caster.darkness_active = false;
		// Silence cleanup
		if (caster.silence_active) {
			caster.silence_active = false;
			// Remove Deafened from creatures that were inside the silence zone
			for (uint si = 0; si < combat.combatants.length(); si++) {
				combatant@ st = combat.combatants[si];
				if (@st == null or st.is_dead) continue;
				if (feet_distance(caster.silence_x, caster.silence_y, st.x, st.y) <= 20) {
					if (st.has_condition(COND_DEAFENED)) {
						st.remove_condition(COND_DEAFENED);
					}
				}
			}
			caster.silence_x = 0;
			caster.silence_y = 0;
		}
		// Blur: disadvantage on attacks against caster (concentration)
		caster.blur_active = false;
		// Conjure Minor Elementals cleanup
		caster.conjure_minor_elementals_active = false;
		caster.conjure_minor_elementals_slot_level = 0;
		// Conjure Woodland Beings cleanup
		caster.conjure_woodland_active = false;
		caster.conjure_woodland_slot_level = 0;
		caster.conjure_woodland_disengage = false;
		// Polymorph: restore original HP/AC when concentration breaks.
		// Basic Rules 2024 Polymorph (para 14624-14626): "The creature reverts to
		// its normal form when it drops to 0 Hit Points or the spell ends."
		if (caster.concentration_spell == "polymorph") {
			for (uint pi = 0; pi < combat.combatants.length(); pi++) {
				combatant@ pt = combat.combatants[pi];
				if (@pt == null or pt.is_dead) continue;
				if (pt.polymorph_caster_id == caster.id and pt.polymorph_original_hp > 0) {
					pt.armor_class = pt.polymorph_original_ac;
					pt.current_hp = pt.polymorph_original_hp;
					if (pt.current_hp > pt.max_hp) pt.current_hp = pt.max_hp;
					pt.remove_condition(COND_CHARMED);
					pt.polymorph_original_hp = 0;
					pt.polymorph_original_ac = 0;
					pt.polymorph_caster_id = 0;
					broadcast_announce(pt.name + " reverts from Polymorph!", true);
				}
			}
		}
		// Heat Metal: BA re-damage ends with concentration. Also clear disadvantage
		// on the target since the spell is no longer active.
		if (caster.heat_metal_active and caster.heat_metal_target_id != 0) {
			combatant@ hm_t = combat.get_combatant(caster.heat_metal_target_id);
			if (@hm_t != null) hm_t.heat_metal_disadv = false;
		}
		caster.heat_metal_active = false;
		caster.heat_metal_target_id = 0;
		caster.heat_metal_dice_count = 0;
		// Call Lightning: per-turn bolt action ends with concentration
		caster.call_lightning_active = false;
		caster.call_lightning_dice_count = 0;
		// Flame Blade: persistent weapon ends with concentration
		caster.flame_blade_active = false;
		caster.flame_blade_dice = 0;
		// Flaming Sphere: BA re-damage ends with concentration
		caster.flaming_sphere_active = false;
		caster.flaming_sphere_dice_count = 0;
		// Swift Quiver: bonus action ranged attacks end with concentration
		caster.swift_quiver_active = false;
		// Extended Spell: advantage on concentration saves ends with concentration
		caster.extended_spell_concentration = false;
		// Xanathar's Glamour Bard L6 Mantle of Majesty (para 558-561): ends on
		// concentration break. Clears the active flag and remaining rounds.
		if (caster.mantle_of_majesty_active) {
			caster.mantle_of_majesty_active = false;
			caster.mantle_of_majesty_rounds = 0;
			broadcast_announce(caster.name + "'s Mantle of Majesty fades as concentration breaks.", false);
		}
		// Enhance Ability: clear on all combatants where this caster was the source
		for (uint eai = 0; eai < combat.combatants.length(); eai++) {
			combatant@ ea_target = combat.combatants[eai];
			if (@ea_target != null and ea_target.enhance_ability_active and ea_target.enhance_ability_caster_id == caster.id) {
				ea_target.enhance_ability_active = false;
				ea_target.enhance_ability_caster_id = 0;
			}
		}
		// Basic Rules 2024 Guidance (para 13659): concentration cantrip — clear on
		// the caster's concentration breaking. Since we don't track source on the
		// target, blanket-clear all guidance flags when the caster had guidance as
		// their concentration spell.
		if (caster.concentration_spell == "Guidance") {
			for (uint gi = 0; gi < combat.combatants.length(); gi++) {
				if (@combat.combatants[gi] != null) combat.combatants[gi].guidance_active = false;
			}
		}
		// Basic Rules 2024 Resistance (para 14772): concentration cantrip — same
		// blanket-clear pattern as Guidance.
		if (caster.concentration_spell == "Resistance") {
			for (uint ri = 0; ri < combat.combatants.length(); ri++) {
				if (@combat.combatants[ri] != null) combat.combatants[ri].resistance_active = false;
			}
		}
		// Basic Rules 2024 Protection from Energy (para 14707): concentration
		// spell — clear protection on the target when caster's concentration breaks.
		// No source tracking, so blanket-clear when caster had this spell.
		if (caster.concentration_spell == "Protection from Energy") {
			for (uint pei = 0; pei < combat.combatants.length(); pei++) {
				if (@combat.combatants[pei] != null and combat.combatants[pei].protection_from_energy_active) {
					combat.combatants[pei].protection_from_energy_active = false;
					combat.combatants[pei].protection_from_energy_type = 0;
				}
			}
		}
		// Protection from Evil and Good: clear flag on all targets sourced by this caster
		for (uint pfi = 0; pfi < combat.combatants.length(); pfi++) {
			combatant@ pf_t = combat.combatants[pfi];
			if (@pf_t != null and pf_t.protection_from_evil_and_good_active and pf_t.pfeg_source_id == caster.id) {
				pf_t.protection_from_evil_and_good_active = false;
				pf_t.pfeg_source_id = 0;
			}
		}
		// Expeditious Retreat: clear flag when concentration breaks
		caster.expeditious_retreat_active = false;
		// Levitate: clear flag on all targets sourced by this caster
		for (uint li = 0; li < combat.combatants.length(); li++) {
			combatant@ lev_t = combat.combatants[li];
			if (@lev_t != null and lev_t.levitate_active and lev_t.levitate_source_id == caster.id) {
				lev_t.levitate_active = false;
				lev_t.levitate_source_id = 0;
			}
		}
		// Charm/Dominate/Hypnotic Pattern/Enthrall/Compulsion: remove COND_CHARMED
		// (and COND_INCAPACITATED for Hypnotic Pattern) from targets when the
		// caster's concentration breaks. Uses charm_spell_caster_id for precise
		// per-caster tracking; Compulsion blanket-clears as a fallback since it
		// hits multiple targets and doesn't set the tracking field.
		string conc = caster.concentration_spell;
		bool is_charm_conc = (conc == "Charm Person" or conc == "Charm Monster"
			or conc == "Dominate Person" or conc == "Dominate Monster"
			or conc == "Dominate Beast" or conc == "Hypnotic Pattern"
			or conc == "Enthrall" or conc == "Compulsion");
		if (is_charm_conc) {
			for (uint cpi = 0; cpi < combat.combatants.length(); cpi++) {
				combatant@ cp_t = combat.combatants[cpi];
				if (@cp_t == null or cp_t.is_dead) continue;
				// Source-tracked targets: only clear charm from this caster's victims
				if (cp_t.charm_spell_caster_id == caster.id and cp_t.has_condition(COND_CHARMED)) {
					cp_t.remove_condition(COND_CHARMED);
					cp_t.charm_spell_caster_id = 0;
					// Hypnotic Pattern also applies Incapacitated alongside Charmed
					if (conc == "Hypnotic Pattern" and cp_t.has_condition(COND_INCAPACITATED)) {
						cp_t.remove_condition(COND_INCAPACITATED);
					}
					broadcast_announce(cp_t.name + " is freed from " + conc + "!", true);
				}
				// Compulsion fallback: blanket-clear (no per-target tracking)
				if (conc == "Compulsion" and cp_t.has_condition(COND_CHARMED)) {
					cp_t.remove_condition(COND_CHARMED);
				}
			}
		}
		// Hold Person / Hold Monster: remove COND_PARALYZED from held targets
		if (conc == "Hold Person" or conc == "Hold Monster") {
			for (uint hpi = 0; hpi < combat.combatants.length(); hpi++) {
				combatant@ hp_t = combat.combatants[hpi];
				if (@hp_t == null or hp_t.is_dead) continue;
				if (hp_t.hold_spell_caster_id == caster.id and hp_t.has_condition(COND_PARALYZED)) {
					hp_t.remove_condition(COND_PARALYZED);
					hp_t.hold_spell_caster_id = 0;
					broadcast_announce(hp_t.name + " is freed from " + conc + "!", true);
				}
			}
		}
		// Tasha's Hideous Laughter: remove COND_INCAPACITATED + COND_PRONE
		if (conc == "Tasha's Hideous Laughter") {
			for (uint thi = 0; thi < combat.combatants.length(); thi++) {
				combatant@ th_t = combat.combatants[thi];
				if (@th_t == null or th_t.is_dead) continue;
				if (th_t.laughter_spell_caster_id == caster.id) {
					if (th_t.has_condition(COND_INCAPACITATED)) th_t.remove_condition(COND_INCAPACITATED);
					if (th_t.has_condition(COND_PRONE)) th_t.remove_condition(COND_PRONE);
					th_t.laughter_spell_caster_id = 0;
					broadcast_announce(th_t.name + " stops laughing as the spell fades!", true);
				}
			}
		}
		// Fear / Phantasmal Killer / Eyebite: remove COND_FRIGHTENED from targets
		// where this caster is the frightened_source_id. All three spells already
		// set frightened_source_id = c.id in their handlers.
		if (conc == "Fear" or conc == "Phantasmal Killer" or conc == "Eyebite") {
			for (uint fri = 0; fri < combat.combatants.length(); fri++) {
				combatant@ fr_t = combat.combatants[fri];
				if (@fr_t == null or fr_t.is_dead) continue;
				if (fr_t.frightened_source_id == caster.id and fr_t.has_condition(COND_FRIGHTENED)) {
					fr_t.remove_condition(COND_FRIGHTENED);
					broadcast_announce(fr_t.name + " is freed from " + conc + "!", true);
				}
			}
		}
		// Eyebite additional cleanup: Asleep (Unconscious) and Sickened (Poisoned) effects
		if (conc == "Eyebite") {
			for (uint ebi = 0; ebi < combat.combatants.length(); ebi++) {
				combatant@ eb_t = combat.combatants[ebi];
				if (@eb_t == null or eb_t.is_dead) continue;
				if (eb_t.eyebite_asleep_source_id == caster.id) {
					if (eb_t.has_condition(COND_UNCONSCIOUS)) eb_t.remove_condition(COND_UNCONSCIOUS);
					if (eb_t.has_condition(COND_INCAPACITATED)) eb_t.remove_condition(COND_INCAPACITATED);
					eb_t.eyebite_asleep_source_id = 0;
					broadcast_announce(eb_t.name + " wakes as Eyebite fades!", true);
				}
				if (eb_t.eyebite_sickened_source_id == caster.id) {
					if (eb_t.has_condition(COND_POISONED)) eb_t.remove_condition(COND_POISONED);
					eb_t.eyebite_sickened_source_id = 0;
					broadcast_announce(eb_t.name + " is no longer Sickened as Eyebite fades!", true);
				}
			}
		}
		// Web / Entangle / Flesh to Stone: remove COND_RESTRAINED from targets
		if (conc == "Web" or conc == "Entangle" or conc == "Flesh to Stone") {
			for (uint ri = 0; ri < combat.combatants.length(); ri++) {
				combatant@ r_t = combat.combatants[ri];
				if (@r_t == null or r_t.is_dead) continue;
				if (r_t.restrained_spell_caster_id == caster.id and r_t.has_condition(COND_RESTRAINED)) {
					r_t.remove_condition(COND_RESTRAINED);
					r_t.restrained_spell_caster_id = 0;
					broadcast_announce(r_t.name + " is freed from " + conc + "!", true);
				}
			}
		}
		// Sleep / Confusion / Otto's Irresistible Dance: remove COND_INCAPACITATED
		if (conc == "Sleep" or conc == "Confusion" or conc == "Otto's Irresistible Dance") {
			for (uint ici = 0; ici < combat.combatants.length(); ici++) {
				combatant@ ic_t = combat.combatants[ici];
				if (@ic_t == null or ic_t.is_dead) continue;
				if (ic_t.incap_spell_caster_id == caster.id) {
					if (ic_t.has_condition(COND_INCAPACITATED)) ic_t.remove_condition(COND_INCAPACITATED);
					if (ic_t.has_condition(COND_UNCONSCIOUS)) ic_t.remove_condition(COND_UNCONSCIOUS);
					ic_t.incap_spell_caster_id = 0;
					broadcast_announce(ic_t.name + " is freed from " + conc + "!", true);
				}
			}
		}
		// Sunbeam: remove COND_BLINDED from targets
		if (conc == "Sunbeam") {
			for (uint sbi = 0; sbi < combat.combatants.length(); sbi++) {
				combatant@ sb_t = combat.combatants[sbi];
				if (@sb_t == null or sb_t.is_dead) continue;
				if (sb_t.blinded_spell_caster_id == caster.id and sb_t.has_condition(COND_BLINDED)) {
					sb_t.remove_condition(COND_BLINDED);
					sb_t.blinded_spell_caster_id = 0;
					broadcast_announce(sb_t.name + "'s blindness fades as Sunbeam ends!", true);
				}
			}
		}
		// Faerie Fire: remove outlined effect from all targets when concentration breaks
		if (conc == "Faerie Fire") {
			for (uint ffi = 0; ffi < combat.combatants.length(); ffi++) {
				combatant@ ff_t = combat.combatants[ffi];
				if (@ff_t == null or ff_t.is_dead) continue;
				if (ff_t.faerie_fire_outlined and ff_t.faerie_fire_source_id == caster.id) {
					ff_t.faerie_fire_outlined = false;
					ff_t.faerie_fire_source_id = 0;
					broadcast_announce(ff_t.name + " is no longer outlined as Faerie Fire fades!", true);
				}
			}
		}
		// Investiture spells: clear all flags when concentration breaks
		caster.investiture_flame_active = false;
		caster.investiture_ice_active = false;
		if (caster.investiture_stone_active) {
			// Only clear B/P/S nonmagical resistance if no other source provides it
			// (monsters might have it innately). Conservative: always clear for players.
			if (caster.is_player) caster.resist_bps_nonmagical = false;
		}
		caster.investiture_stone_active = false;
		if (caster.investiture_wind_active) {
			caster.speed -= 30; // Remove fly speed boost
			if (caster.speed < 0) caster.speed = 0;
		}
		caster.investiture_wind_active = false;
		// Dismiss companions spawned by concentration spells when concentration breaks.
		// Permanent companions (beast_master, steel_defender, drake_companion, etc.) are excluded.
		for (uint dci = 0; dci < combat.combatants.length(); dci++) {
			combatant@ comp = combat.combatants[dci];
			if (@comp == null or comp.is_dead or !comp.is_companion) continue;
			if (comp.owner_id != caster.id) continue;
			string cs = comp.companion_subclass;
			if (cs == "animate_objects" or cs == "giant_insect" or cs == "bigbys_hand"
				or cs == "conjure_animals_pack" or cs == "conjure_elemental"
				or cs == "summon_dragon" or cs == "conjure_fey" or cs == "conjure_celestial") {
				dismiss_companion(comp, true);
			}
		}
		// Slow: restore speed and AC for all affected targets when concentration breaks
		if (conc == "Slow") {
			for (uint sli = 0; sli < combat.combatants.length(); sli++) {
				combatant@ sl_t = combat.combatants[sli];
				if (@sl_t == null or sl_t.is_dead) continue;
				if (sl_t.slow_spell_caster_id == caster.id) {
					sl_t.speed = sl_t.slow_original_speed;
					sl_t.armor_class += 2;
					sl_t.slow_spell_caster_id = 0;
					sl_t.slow_original_speed = 0;
					broadcast_announce(sl_t.name + " is freed from the Slow effect!", true);
				}
			}
		}
		// Enlarge/Reduce: restore original size and clear buffs/debuffs when concentration breaks
		if (conc == "Enlarge/Reduce") {
			for (uint eri = 0; eri < combat.combatants.length(); eri++) {
				combatant@ er_t = combat.combatants[eri];
				if (@er_t == null or er_t.is_dead) continue;
				if (er_t.enlarge_reduce_caster_id == caster.id) {
					er_t.size = er_t.enlarge_original_size;
					er_t.enlarge_active = false;
					er_t.reduce_active = false;
					er_t.enlarge_reduce_caster_id = 0;
					er_t.enlarge_original_size = SIZE_MEDIUM;
					broadcast_announce(er_t.name + " returns to normal size as Enlarge/Reduce ends!", true);
				}
			}
		}
		// Antimagic Field: clear flag when concentration breaks
		caster.antimagic_field_active = false;
		// Basic Rules 2024 Antilife Shell: clear barrier when concentration breaks
		caster.antilife_shell_active = false;
		// Globe of Invulnerability: clear spell-blocking shield when concentration breaks
		caster.globe_of_invulnerability_active = false;
		caster.globe_of_invulnerability_level = 5;
		// Holy Aura: clear aura when concentration breaks
		caster.holy_aura_active = false;
		// Basic Rules 2024 Alter Self: clear Natural Weapons when concentration breaks
		caster.alter_self_natural_weapons = false;
		// Basic Rules 2024 Telekinesis: release restrained targets when concentration breaks
		for (uint tki = 0; tki < combat.combatants.length(); tki++) {
			combatant@ tk_t = combat.combatants[tki];
			if (@tk_t != null and tk_t.telekinesis_source_id == caster.id) {
				tk_t.remove_condition(COND_RESTRAINED);
				tk_t.telekinesis_source_id = 0;
				tk_t.restrained_spell_caster_id = 0;
			}
		}
		// Basic Rules 2024 Aura of Life (para 12166-12168): clear aura when concentration breaks.
		// Remove aura-granted necrotic resistance from all allies who got it from this caster.
		if (caster.aura_of_life_active) {
			for (uint aoli = 0; aoli < combat.combatants.length(); aoli++) {
				combatant@ aol_t = combat.combatants[aoli];
				if (@aol_t == null) continue;
				if (aol_t.aura_of_life_necrotic_from == caster.id) {
					aol_t.necrotic_resistance = false;
					aol_t.aura_of_life_necrotic_from = 0;
				}
			}
		}
		caster.aura_of_life_active = false;
		// Bestow Curse: clear curse effects on all combatants cursed by this caster
		for (uint bci = 0; bci < combat.combatants.length(); bci++) {
			combatant@ bct = combat.combatants[bci];
			if (@bct == null) continue;
			if (bct.bestow_curse_source_id == caster.id) {
				bct.bestow_curse_type = "";
				bct.bestow_curse_source_id = 0;
				broadcast_announce(bct.name + "'s curse from Bestow Curse fades!", true);
			}
		}
		// Shield of Faith: remove +2 AC from target when concentration breaks
		// Basic Rules 2024 Shield of Faith (para 15004): concentration, 10 min.
		if (caster.concentration_spell == "Shield of Faith") {
			for (uint sfi = 0; sfi < combat.combatants.length(); sfi++) {
				combatant@ sft = combat.combatants[sfi];
				if (@sft == null) continue;
				if (sft.shield_of_faith_active and sft.shield_of_faith_caster_id == caster.id) {
					sft.armor_class -= 2;
					if (sft.armor_class < 0) sft.armor_class = 0;
					sft.shield_of_faith_active = false;
					sft.shield_of_faith_caster_id = 0;
					broadcast_announce("Shield of Faith fades from " + sft.name + ".", true);
				}
			}
		}
		// Beacon of Hope: clear max-healing flag from all affected allies
		// Basic Rules 2024 Beacon of Hope (para 12201): concentration, 1 min.
		if (caster.concentration_spell == "Beacon of Hope") {
			for (uint bhi = 0; bhi < combat.combatants.length(); bhi++) {
				combatant@ bht = combat.combatants[bhi];
				if (@bht == null) continue;
				if (bht.beacon_of_hope_active and bht.beacon_of_hope_caster_id == caster.id) {
					bht.beacon_of_hope_active = false;
					bht.beacon_of_hope_caster_id = 0;
				}
			}
		}
		// Greater Invisibility: remove Invisible condition and hidden state
		// Basic Rules 2024 Greater Invisibility (para 13658): concentration, 1 min.
		if (caster.concentration_spell == "Greater Invisibility") {
			for (uint gi = 0; gi < combat.combatants.length(); gi++) {
				combatant@ git = combat.combatants[gi];
				if (@git == null) continue;
				if (git.greater_invisibility_active and git.greater_invisibility_caster_id == caster.id) {
					git.greater_invisibility_active = false;
					git.greater_invisibility_caster_id = 0;
					git.remove_condition(COND_INVISIBLE);
					git.is_hidden = false;
					broadcast_to_battle({{"type", message_types::condition_removed}, {"target", git.name}, {"condition", "Invisible"}});
					broadcast_announce(git.name + "'s Greater Invisibility fades.", true);
				}
			}
		}
	}

	// ---- Swarming Modifier Helper ----

	void spawn_swarming_extra(wave_encounter@ wave, float hp_multiplier = 1.0) {
		if (@wave == null or @combat == null or active_modifier != "swarming") return;
		if (wave.monster_ids.length() == 0) return;
		string extra_id = wave.monster_ids[random(0, wave.monster_ids.length() - 1)];
		monster_def@ def = get_monster_def(extra_id);
		if (@def == null) return;
		combatant@ extra = create_monster_combatant(def, combat.map_width - 3, combat.map_height - 3);
		if (@extra != null) {
			if (hp_multiplier != 1.0) { extra.max_hp = int(float(extra.max_hp) * hp_multiplier); extra.current_hp = extra.max_hp; }
			combat.add_combatant(extra);
		}
	}

	// ---- Game Start ----

	void start_game(user@ host, string mode = "pvp", string scenario = "", string diff = "normal") {
		if (@host == null or @host.room == null) {
			if (@host != null) host.send({{"type", message_types::error}, {"text", "Failed to start game: invalid room."}});
			return;
		}
		reset_progression_tracking();
		lobby_game_type = normalize_game_type(host.room.game_type);
		progression_enabled = is_adventure_game_type(lobby_game_type);
		difficulty = diff;
		if (difficulty == "hard") { difficulty_hp_mult = 1.5; difficulty_dmg_mult = 1.25; }
		else if (difficulty == "nightmare") { difficulty_hp_mult = 2.0; difficulty_dmg_mult = 1.5; }
		else { difficulty_hp_mult = 1.0; difficulty_dmg_mult = 1.0; }

		// Copy room players into battle manager.
		players.resize(0);
		for (uint i = 0; i < host.room.players.length(); i++) {
			players.insert_last(host.room.players[i]);
		}

		// Create battle instance.
		@combat = battle();
		combat.battle_active = true;

		combat.mode = mode;
		scenario_id = scenario;

		// Add each player/bot as a combatant from their character sheet.
		for (uint i = 0; i < players.length(); i++) {
			// Load character from account data
			character_sheet cs;
			bool has_char = false;
			if (@players[i].account != null) {
				json_object@ data = players[i].account.data;
				string character_key = get_character_storage_key(lobby_game_type);
				if (data.exists(character_key)) {
					json_object@ ch = data[character_key];
					cs.name = ch.exists("name") ? string(ch["name"]) : players[i].username;
					cs.race = ch.exists("race") ? string(ch["race"]) : "Human";
					cs.class_name = ch.exists("class") ? string(ch["class"]) : "Fighter";
					cs.subclass = ch.exists("subclass") ? string(ch["subclass"]) : "";
					cs.background = ch.exists("background") ? string(ch["background"]) : "";
					cs.level = ch.exists("level") ? int(ch["level"]) : 1;
					cs.strength = ch.exists("str") ? int(ch["str"]) : 10;
					cs.dexterity = ch.exists("dex") ? int(ch["dex"]) : 10;
					cs.constitution = ch.exists("con") ? int(ch["con"]) : 10;
					cs.intelligence = ch.exists("int") ? int(ch["int"]) : 10;
					cs.wisdom = ch.exists("wis") ? int(ch["wis"]) : 10;
					cs.charisma = ch.exists("cha") ? int(ch["cha"]) : 10;
					cs.weapon_name = ch.exists("weapon") ? string(ch["weapon"]) : "Longsword";
					if (ch.exists("feats")) parse_csv_list(string(ch["feats"]), cs.feats);
					if (ch.exists("skills")) parse_csv_list(string(ch["skills"]), cs.skill_proficiencies);
					if (ch.exists("tools")) parse_csv_list(string(ch["tools"]), cs.tool_proficiencies);
					if (ch.exists("spell_ability_overrides")) parse_spell_override_specs(string(ch["spell_ability_overrides"]), cs.spellcasting_override_spells, cs.spellcasting_override_abilities);
					if (ch.exists("free_cast_spells")) parse_csv_list(string(ch["free_cast_spells"]), cs.free_cast_spells);
					if (ch.exists("cantrips")) parse_csv_list(string(ch["cantrips"]), cs.cantrips);
					if (ch.exists("spells")) parse_csv_list(string(ch["spells"]), cs.spells);
					// Phase 1 sub-system fields (Piety, Group Patron, Guild, Vestiges,
					// Bastion, Transformation, Heroic Chronicle, Fey Court)
					if (ch.exists("piety_god")) cs.piety_god = string(ch["piety_god"]);
					if (ch.exists("piety_score")) cs.piety_score = int(ch["piety_score"]);
					if (ch.exists("group_patron")) cs.group_patron = string(ch["group_patron"]);
					if (ch.exists("ravnica_guild")) cs.ravnica_guild = string(ch["ravnica_guild"]);
					if (ch.exists("transformation")) cs.transformation = string(ch["transformation"]);
					if (ch.exists("transformation_stage")) cs.transformation_stage = int(ch["transformation_stage"]);
					if (ch.exists("heroic_homeland")) cs.heroic_homeland = string(ch["heroic_homeland"]);
					if (ch.exists("heroic_background_egw")) cs.heroic_background_egw = string(ch["heroic_background_egw"]);
					if (ch.exists("fey_court")) cs.fey_court = string(ch["fey_court"]);
					if (ch.exists("bastion_name")) cs.bastion_name = string(ch["bastion_name"]);
					if (ch.exists("vestige_ids")) parse_csv_list(string(ch["vestige_ids"]), cs.vestige_ids);
					// PHB 2024 Cleric L1 Divine Order, L7 Blessed Strikes choices
					if (ch.exists("divine_order")) cs.divine_order = string(ch["divine_order"]);
					if (ch.exists("blessed_strikes_choice")) cs.blessed_strikes_choice = string(ch["blessed_strikes_choice"]);
					if (ch.exists("divine_strike_damage_type")) cs.divine_strike_damage_type = string(ch["divine_strike_damage_type"]);
					// PHB 2024 Druid L1 Primal Order, L7 Elemental Fury choices
					if (ch.exists("primal_order")) cs.primal_order = string(ch["primal_order"]);
					if (ch.exists("elemental_fury_choice")) cs.elemental_fury_choice = string(ch["elemental_fury_choice"]);
					if (ch.exists("primal_strike_damage_type")) cs.primal_strike_damage_type = string(ch["primal_strike_damage_type"]);
					// PHB 2024 Sorcerer Draconic Sorcery L6 Elemental Affinity choice (para 7559-7560)
					if (ch.exists("elemental_affinity_type")) cs.elemental_affinity_type = string(ch["elemental_affinity_type"]);
					// PHB 2024 Elemental Adept (para 7610): persisted damage type choice
					if (ch.exists("elemental_adept_type")) cs.elemental_adept_type = string(ch["elemental_adept_type"]);
					// Xanathar's Divine Soul L1 Divine Magic affinity (para 2532-2546)
					if (ch.exists("divine_soul_affinity")) cs.divine_soul_affinity = string(ch["divine_soul_affinity"]);
					// PHB 2024 Wizard L18 Spell Mastery + L20 Signature Spells designation
					if (ch.exists("spell_mastery_l1_spell_id")) cs.spell_mastery_l1_spell_id = string(ch["spell_mastery_l1_spell_id"]);
					if (ch.exists("spell_mastery_l2_spell_id")) cs.spell_mastery_l2_spell_id = string(ch["spell_mastery_l2_spell_id"]);
					if (ch.exists("signature_spell_a_id")) cs.signature_spell_a_id = string(ch["signature_spell_a_id"]);
					if (ch.exists("signature_spell_b_id")) cs.signature_spell_b_id = string(ch["signature_spell_b_id"]);
					// Level-up selection choices
					if (ch.exists("fighting_style")) cs.fighting_style = string(ch["fighting_style"]);
					if (ch.exists("pact_boon")) cs.pact_boon = string(ch["pact_boon"]);
					if (ch.exists("metamagic_choices")) {
						json_array@ mc = ch["metamagic_choices"];
						if (@mc != null) { for (uint mci = 0; mci < mc.length(); mci++) cs.metamagic_choices.insert_last(string(mc[mci])); }
					}
					if (ch.exists("invocation_choices")) {
						json_array@ ic = ch["invocation_choices"];
						if (@ic != null) { for (uint ici = 0; ici < ic.length(); ici++) cs.invocation_choices.insert_last(string(ic[ici])); }
					}
					has_char = true;
				} else if (lobby_game_type == GAME_TYPE_SANDBOX and data.exists(ACCOUNT_KEY_LEGACY_CHARACTER)) {
					json_object@ ch = data[ACCOUNT_KEY_LEGACY_CHARACTER];
					cs.name = ch.exists("name") ? string(ch["name"]) : players[i].username;
					cs.race = ch.exists("race") ? string(ch["race"]) : "Human";
					cs.class_name = ch.exists("class") ? string(ch["class"]) : "Fighter";
					cs.subclass = ch.exists("subclass") ? string(ch["subclass"]) : "";
					cs.level = ch.exists("level") ? int(ch["level"]) : 1;
					cs.strength = ch.exists("str") ? int(ch["str"]) : 10;
					cs.dexterity = ch.exists("dex") ? int(ch["dex"]) : 10;
					cs.constitution = ch.exists("con") ? int(ch["con"]) : 10;
					cs.intelligence = ch.exists("int") ? int(ch["int"]) : 10;
					cs.wisdom = ch.exists("wis") ? int(ch["wis"]) : 10;
					cs.charisma = ch.exists("cha") ? int(ch["cha"]) : 10;
					cs.weapon_name = ch.exists("weapon") ? string(ch["weapon"]) : "Longsword";
					if (ch.exists("cantrips")) parse_csv_list(string(ch["cantrips"]), cs.cantrips);
					if (ch.exists("spells")) parse_csv_list(string(ch["spells"]), cs.spells);
					has_char = true;
				}
			}
			if (!has_char) {
				// Default character for players without one
				cs.name = players[i].username;
				cs.race = "Human";
				cs.class_name = "Fighter";
				cs.subclass = "";
				cs.background = "";
				cs.level = 1;
				cs.strength = 15; cs.dexterity = 14; cs.constitution = 13;
				cs.intelligence = 10; cs.wisdom = 12; cs.charisma = 8;
				cs.weapon_name = "Longsword";
			}
			// Apply all class/race/weapon defaults and calculate HP/AC
			finalize_character(cs);
			// Create combatant from character sheet
			combatant@ c = create_player_combatant(cs, players[i].username, 1, int(i) + 1);

			// Apply equipment bonuses from equipped items (Adventure mode)
			if (@players[i].account != null) {
				json_object@ acct_data = players[i].account.data;
				string char_key = get_character_storage_key(lobby_game_type);
				if (acct_data.exists(char_key)) {
					json_object@ char_obj = acct_data[char_key];
					if (char_obj.exists("equipped")) {
						json_object@ equipped = char_obj["equipped"];
						apply_equipment_bonuses(c, equipped);
					}
				}

				// Apply prestige bonuses (Adventure mode)
				if (progression_enabled) {
					int prestige_rank = get_prestige_rank(players[i].account);
					if (prestige_rank > 0) {
						apply_prestige_bonuses(c, prestige_rank);
						string title = get_prestige_title(prestige_rank);
						if (title != "") c.name = title + " " + c.name;
					}
				}
			}

			combat.add_combatant(c);
		}

		// If wave mode, spawn first wave of monsters
		if (mode == "wave" and scenario != "") {
			wave_scenario@ ws = get_scenario(scenario);
			if (@ws != null and ws.waves.length() > 0) {
				combat.mode = "wave";
				combat.wave_number = 1;
				spawn_wave(combat, ws.waves[0], combat.map_width, difficulty_hp_mult, difficulty_dmg_mult);
				spawn_swarming_extra(ws.waves[0]);
				string diff_label = difficulty == "hard" ? " Hard difficulty." : (difficulty == "nightmare" ? " Nightmare difficulty!" : "");
				broadcast_announce("Wave 1! " + ws.name + "." + diff_label, false);
			} else {
				broadcast_announce("Unknown scenario. Defaulting to PvP arena.", false);
				combat.mode = "pvp";
			}
		} else if (mode == "endless") {
			// Endless Survival mode - start at wave 1
			combat.mode = "endless";
			combat.wave_number = 1;
			wave_encounter@ first_wave = generate_endless_wave(1);
			spawn_wave(combat, first_wave, combat.map_width, difficulty_hp_mult, difficulty_dmg_mult);
			spawn_swarming_extra(first_wave);
			broadcast_announce("Endless Survival! Wave 1!", false);
		} else if (mode == "boss") {
			monster_def@ boss_def = choose_boss_monster();
			if (@boss_def != null) {
				combat.mode = "boss";
				combat.wave_number = 1;
				scenario_id = boss_def.id;
				combatant@ boss = create_monster_combatant(boss_def, combat.map_width / 2, combat.map_height - 2);
				if (@boss != null) {
					boss.is_boss = true;
					if (difficulty_hp_mult != 1.0) { boss.max_hp = int(float(boss.max_hp) * difficulty_hp_mult); boss.current_hp = boss.max_hp; }
					if (difficulty_dmg_mult != 1.0) { boss.monster_attack_damage_mod = int(float(boss.monster_attack_damage_mod) * difficulty_dmg_mult); }
					combat.add_combatant(boss);
					broadcast_announce("Boss Rush! " + boss_def.name + " enters the battlefield.", false);
				}
			}
		}
		// ---- Dungeon Modifier System ----
		init_modifiers();
		active_modifier = pick_random_modifier();
		modifier_def@ active_mod = find_modifier(active_modifier);
		if (@active_mod != null and active_mod.id != "none") {
			broadcast_announce("Dungeon Modifier: " + active_mod.name + "! " + active_mod.description, true);
		}

		// Apply modifier effects to combatants
		for (uint mi = 0; mi < combat.combatants.length(); mi++) {
			combatant@ mc = combat.combatants[mi];
			if (@mc == null) continue;
			if (mc.is_player) {
				if (active_modifier == "empowered") mc.equip_damage_bonus += 3;
				if (active_modifier == "fortified") { mc.armor_class += 2; mc.equip_ac_bonus += 2; }
				if (active_modifier == "swift") { mc.speed += 10; mc.equip_speed_bonus += 10; }
				if (active_modifier == "last_stand") {
					mc.current_hp = mc.max_hp / 2;
					mc.equip_damage_bonus += 4;
				}
			} else {
				if (active_modifier == "armored_foes") mc.armor_class += 3;
				if (active_modifier == "champions_trial") {
					mc.max_hp = int(float(mc.max_hp) * 1.25);
					mc.current_hp = mc.max_hp;
				}
			}
		}

		broadcast_announce("Battle begins! Rolling initiative.", true);
		broadcast_state();

		// Send game_start_battle to each player individually with their combatant_id.
		for (uint pi = 0; pi < players.length(); pi++) {
			// Find this player's combatant.
			uint cid = 0;
			for (uint ci = 0; ci < combat.combatants.length(); ci++) {
				if (combat.combatants[ci].is_player and combat.combatants[ci].player_username == players[pi].username) {
					cid = combat.combatants[ci].id;
					break;
				}
			}
			players[pi].send({
				{"type", message_types::game_start_battle},
				{"combatant_id", cid},
				{"mode", combat.mode},
				{"scenario", scenario_id}
			});
		}

		// Inspiring Leader feat (PHB para 7649): "After Bolstering Performance, choose
		// up to six allies (which can include yourself) within 30 feet... Each of those
		// allies gains Temporary Hit Points equal to your character level + your Charisma
		// modifier." Battle start is treated as the post-rest performance moment since
		// combat doesn't currently track rest cycles.
		for (uint il = 0; il < combat.combatants.length(); il++) {
			combatant@ leader = combat.combatants[il];
			if (@leader == null or leader.is_dead) continue;
			if (!leader.is_player) continue;
			if (leader.inspiring_leader_temp_hp_pool <= 0) continue;
			int granted = 0;
			for (uint tg = 0; tg < combat.combatants.length() and granted < 6; tg++) {
				combatant@ ally = combat.combatants[tg];
				if (@ally == null or ally.is_dead) continue;
				if (ally.is_player != leader.is_player) continue;
				if (feet_distance(leader.x, leader.y, ally.x, ally.y) > 30) continue;
				if (ally.temp_hp < leader.inspiring_leader_temp_hp_pool) ally.temp_hp = leader.inspiring_leader_temp_hp_pool;
				granted++;
			}
			if (granted > 0) {
				broadcast_announce(leader.name + "'s Inspiring Leader grants " + leader.inspiring_leader_temp_hp_pool + " temporary hit points to " + granted + " ally" + (granted == 1 ? "" : "ies") + ".", false);
			}
		}
		// PHB 2024 Musician Origin feat: grant Heroic Inspiration at battle start
		for (uint mu = 0; mu < combat.combatants.length(); mu++) {
			combatant@ musician = combat.combatants[mu];
			if (@musician == null or musician.is_dead or !musician.is_player) continue;
			if (!musician.has_feat("musician")) continue;
			int cha_mod = musician.get_ability_mod(ABILITY_CHA);
			int max_targets = musician.proficiency + cha_mod;
			if (max_targets < 1) max_targets = 1;
			int granted_hi = 0;
			for (uint mg = 0; mg < combat.combatants.length() and granted_hi < max_targets; mg++) {
				combatant@ ally = combat.combatants[mg];
				if (@ally == null or ally.is_dead) continue;
				if (ally.is_player != musician.is_player) continue;
				if (feet_distance(musician.x, musician.y, ally.x, ally.y) > 30) continue;
				if (!ally.has_heroic_inspiration) {
					ally.has_heroic_inspiration = true;
					granted_hi++;
				}
			}
			if (granted_hi > 0) {
				broadcast_announce(musician.name + "'s Musician performance grants Heroic Inspiration to " + granted_hi + " allies!", false);
			}
		}

		// Xanathar's Celestial Warlock L10 Celestial Resilience (paras 2740-2743):
		// "Additionally, choose up to five creatures you can see at the end of the rest.
		// Those creatures each gain temporary hit points equal to half your warlock level
		// + your Charisma modifier." Applied at battle start (post-rest assumption).
		for (uint cr = 0; cr < combat.combatants.length(); cr++) {
			combatant@ warlock = combat.combatants[cr];
			if (@warlock == null or warlock.is_dead or !warlock.is_player) continue;
			if (warlock.subclass != "Celestial" or warlock.level < 10) continue;
			int ally_temp_hp = warlock.level / 2 + warlock.get_ability_mod(ABILITY_CHA);
			if (ally_temp_hp <= 0) continue;
			int cr_count = 0;
			for (uint cra = 0; cra < combat.combatants.length(); cra++) {
				if (cr_count >= 5) break;
				combatant@ ally = combat.combatants[cra];
				if (@ally == null or ally.is_dead or !ally.is_player or ally.id == warlock.id) continue;
				if (ally.temp_hp < ally_temp_hp) {
					ally.temp_hp = ally_temp_hp;
					cr_count++;
				}
			}
			if (cr_count > 0) {
				broadcast_announce(warlock.name + "'s Celestial Resilience grants " + ally_temp_hp + " temporary hit points to " + cr_count + " all" + (cr_count == 1 ? "y" : "ies") + ".", false);
			}
		}

		// Delay initiative to let clients enter combat loop.
		initiative_phase = true;
		initiative_index = 0;
		initiative_delay_until = ticks() + 2000;
	}

	// ---- Initiative Phase ----

	void request_next_initiative() {
		if (@combat == null or !initiative_phase) return;

		// Skip dead combatants.
		while (initiative_index < combat.combatants.length() and !combat.combatants[initiative_index].is_alive()) {
			initiative_index++;
		}

		if (initiative_index >= combat.combatants.length()) {
			// All initiative rolls collected. Sort and start combat.
			finish_initiative();
			return;
		}

		combatant@ c = combat.combatants[initiative_index];
		int mod = c.initiative_bonus;
		// Xanathar's War Magic L2 Tactical Wit (para 2935-2936): "You gain a bonus to
		// your initiative rolls equal to your Intelligence modifier."
		if (c.tactical_wit_active) mod += c.get_ability_mod(ABILITY_INT);
		// Xanathar's Gloom Stalker L3 Dread Ambusher (para 2153): "You can give
		// yourself a bonus to your initiative rolls equal to your Wisdom modifier."
		if (c.class_name == "Ranger" and c.subclass == "Gloom Stalker" and c.level >= 3) {
			mod += c.get_ability_mod(ABILITY_WIS);
		}
		// Xanathar's Swashbuckler L3 Rakish Audacity (para 2421-2423):
		// "you add your Charisma modifier to your initiative rolls"
		if (c.class_name == "Rogue" and c.subclass == "Swashbuckler" and c.level >= 3) {
			mod += c.get_ability_mod(ABILITY_CHA);
		}
		user@ u = find_user_for_combatant(c);

		pending_roll pr;
		pr.combatant_id = c.id;
		pr.player_username = c.is_player ? c.player_username : c.name;
		pr.roll_type = ROLL_INITIATIVE;
		pr.dice_sides = 20;
		// PHB 2024 Exhaustion (para 16255): d20 Tests reduced by 2 * exhaustion level
		mod -= c.exhaustion_level * 2;
		pr.modifier = mod;
		pr.reason = "initiative";
		// PHB 2024 Barbarian Level 7: Feral Instinct (para 2334-2335):
		// "Your instincts are so honed that you have Advantage on Initiative rolls."
		if (c.class_name == "Barbarian" and c.level >= 7) pr.has_advantage = true;
		// Valda's Spire Gunslinger L1 Quick Draw (paras 162-164): "You have Advantage
		// on Initiative rolls."
		if (c.class_name == "Gunslinger" and c.quick_draw_active) pr.has_advantage = true;
		// Xanathar's Scout L13 Ambush Master (para 2398-2399):
		// "you have advantage on initiative rolls"
		if (c.class_name == "Rogue" and c.subclass == "Scout" and c.level >= 13) pr.has_advantage = true;
		// PHB 2024 Bard Level 18: Superior Inspiration (para 2760-2761):
		// "When you roll Initiative, you regain expended uses of Bardic Inspiration
		// until you have two if you have fewer than that."
		if (c.class_name == "Bard" and c.superior_inspiration_active and c.bardic_inspiration_uses < 2) {
			int restored = 2 - c.bardic_inspiration_uses;
			c.bardic_inspiration_uses = 2;
			broadcast_announce(c.name + "'s Superior Inspiration restores " + restored + " Bardic Inspiration use" + (restored == 1 ? "" : "s") + ".", false);
		}
		// Xanathar's Samurai L10 Tireless Spirit (para 1708-1709): "when you roll
		// initiative and have no uses of Fighting Spirit remaining, you regain one use."
		if (c.class_name == "Fighter" and c.subclass == "Samurai" and c.level >= 10 and c.fighting_spirit_uses <= 0) {
			c.fighting_spirit_uses = 1;
			broadcast_announce(c.name + "'s Tireless Spirit restores 1 Fighting Spirit use!", false);
		}
		// Xanathar's Arcane Archer L15 Ever-Ready Shot (para 1626-1627): "If you roll
		// initiative and have no uses of Arcane Shot remaining, you regain one use of it."
		if (c.class_name == "Fighter" and c.subclass == "Arcane Archer" and c.level >= 15 and c.arcane_shot_uses <= 0) {
			c.arcane_shot_uses = 1;
			broadcast_announce(c.name + "'s Ever-Ready Shot restores 1 Arcane Shot use!", false);
		}
		// Valda's Spire Gunslinger L15 Dire Gambit (para 196): "Whenever you roll
		// Initiative or score a Critical Hit, you regain one expended Risk Die."
		if (c.class_name == "Gunslinger" and c.dire_gambit_active and c.risk_dice_current < c.risk_dice_max) {
			c.risk_dice_current++;
			broadcast_announce(c.name + "'s Dire Gambit regains a Risk Die from rolling Initiative! (" + c.risk_dice_current + "/" + c.risk_dice_max + ")", false);
		}
		// PHB 2024 Druid L20 Archdruid: "If you have no uses of Wild Shape left,
		// you regain one expended use of it."
		if (c.class_name == "Druid" and c.level >= 20 and c.wild_shape_uses <= 0) {
			c.wild_shape_uses = 1;
			broadcast_announce(c.name + "'s Archdruid restores 1 Wild Shape use!", false);
		}
		// PHB 2024 Monk L2 Uncanny Metabolism (para 5334-5336): "When you roll
		// Initiative and have no Focus Points remaining, you can regain all expended
		// Focus Points. When you do so, roll your Martial Arts die, and you regain a
		// number of Hit Points equal to your Monk level plus the number rolled."
		if (c.class_name == "Monk" and c.level >= 2 and c.uncanny_metabolism_available and c.focus_points <= 0) {
			c.focus_points = c.focus_points_max;
			int ma_die = monk_martial_arts_die(c);
			int heal_roll = random(1, ma_die);
			int heal_amount = c.level + heal_roll;
			c.current_hp += heal_amount;
			if (c.current_hp > c.max_hp) c.current_hp = c.max_hp;
			c.uncanny_metabolism_available = false;
			broadcast_announce(c.name + "'s Uncanny Metabolism restores all Focus Points (" + c.focus_points_max + ") and heals " + heal_amount + " HP!", false);
		}
		@current_roll = pr;

		if (@u != null and !u.is_bot and c.is_player) {
			// Human player: send roll request.
			send_roll_request(u, pr);
		} else {
			// Bot/monster: auto-roll. Apply advantage (e.g. Feral Instinct) by rolling twice.
			int natural = random(1, 20);
			if (pr.has_advantage and !pr.has_disadvantage) {
				int second = random(1, 20);
				if (second > natural) natural = second;
			} else if (pr.has_disadvantage and !pr.has_advantage) {
				int second = random(1, 20);
				if (second < natural) natural = second;
			}
			process_roll_result(natural);
		}
	}

	void finish_initiative() {
		if (@combat == null) return;
		initiative_phase = false;

		// PHB 2024 Monk L15 Perfect Focus (para 5370-5371): "When you roll Initiative
		// and don't use Uncanny Metabolism, you regain expended Focus Points until you
		// have 4 if you have 3 or fewer." Applied immediately after initiative is
		// rolled. Uncanny Metabolism is a separate bonus action that fully refills,
		// so this top-up is a no-op for monks who later use UM.
		for (uint pfi = 0; pfi < combat.combatants.length(); pfi++) {
			combatant@ pfm = combat.combatants[pfi];
			if (@pfm == null) continue;
			if (pfm.class_name == "Monk" and pfm.level >= 15 and pfm.focus_points <= 3) {
				int pf_top = 4 - pfm.focus_points;
				pfm.focus_points = 4;
				broadcast_announce(pfm.name + "'s Perfect Focus restores " + pf_top + " Focus Points (now at 4).", false);
			}
		}

		// Build and sort initiative order from stored rolls.
		combat.build_initiative_order();

		// Announce all initiative rolls to all players in one message,
		// then the turn order. Individual broadcast_roll calls during
		// initiative chain too fast for TTS to speak.
		string rolls_text = "Initiative rolls: ";
		for (uint i = 0; i < combat.combatants.length(); i++) {
			if (!combat.combatants[i].is_alive()) continue;
			if (i > 0) rolls_text += ". ";
			rolls_text += combat.combatants[i].name + " rolled " + combat.combatants[i].initiative_roll;
		}
		rolls_text += ".";
		broadcast_announce(rolls_text, true);

		// Announce turn order (highest to lowest).
		string order_text = "Turn order: ";
		for (uint i = 0; i < combat.initiative_order.length(); i++) {
			combatant@ c = combat.combatants[combat.initiative_order[i]];
			if (i > 0) order_text += ", ";
			order_text += (i + 1) + " " + c.name;
		}
		order_text += ".";
		broadcast_announce(order_text, false);

		// Send initiative_order message.
		json_array init_arr;
		for (uint i = 0; i < combat.initiative_order.length(); i++) {
			init_arr.add(combat.initiative_order[i]);
		}
		broadcast_to_battle({
			{"type", message_types::initiative_order},
			{"order", init_arr},
			{"initiative_order", init_arr},
			{"round", combat.round_number},
			{"turn_index", combat.current_turn_index}
		});

		// Start first turn (round 1).
		combat.current_turn_index = -1;
		combat.round_number = 1;
		advance_turn();
	}

	// ---- Turn Management ----

	void advance_turn() {
		if (@combat == null or !combat.battle_active) return;

		// Remove Dodging condition from the combatant whose turn just ended.
		combatant@ prev = combat.current_combatant();
		if (@prev != null) {
			prev.is_dodging = false;
			prev.remove_condition(COND_DODGING);
			// PHB 2024 Ranger L14 Nature's Veil (para 6184-6186): Invisible "until the
			// end of your next turn." Cast sets rounds_remaining = 2; tick down on each
			// of the Ranger's turn-ends. When it hits 0, remove the Invisible condition.
			if (prev.natures_veil_rounds_remaining > 0) {
				prev.natures_veil_rounds_remaining--;
				if (prev.natures_veil_rounds_remaining <= 0) {
					prev.remove_condition(COND_INVISIBLE);
					broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Invisible"}});
					broadcast_announce(prev.name + "'s Nature's Veil fades.", false);
				}
			}
			// Basic Rules 2024 Chill Touch (para 12055-12062) + Starry Wisp (para
			// 14595-14602): "until the end of your next turn" — tick down on each
			// of the caster's turn-ends across all affected targets.
			for (uint cti = 0; cti < combat.combatants.length(); cti++) {
				combatant@ ct = combat.combatants[cti];
				if (ct.chill_touch_source_id == prev.id and ct.chill_touch_caster_turns > 0) {
					ct.chill_touch_caster_turns--;
					if (ct.chill_touch_caster_turns <= 0) {
						ct.chill_touch_source_id = 0;
					}
				}
				if (ct.starry_wisp_source_id == prev.id and ct.starry_wisp_caster_turns > 0) {
					ct.starry_wisp_caster_turns--;
					if (ct.starry_wisp_caster_turns <= 0) {
						ct.starry_wisp_no_invis = false;
						ct.starry_wisp_source_id = 0;
					}
				}
			}
			// PHB 2024 Sorcerer L1 Innate Sorcery (para 6963-6967): "for 1 minute" — 10
			// rounds. Tick down on each of the Sorcerer's turn-ends; expire at 0.
			if (prev.innate_sorcery_active and prev.innate_sorcery_rounds_remaining > 0) {
				prev.innate_sorcery_rounds_remaining--;
				if (prev.innate_sorcery_rounds_remaining <= 0) {
					prev.innate_sorcery_active = false;
					prev.sorcery_incarnate_active = false;
					broadcast_announce(prev.name + "'s Innate Sorcery fades.", false);
				}
			}
			// Xanathar's Kensei L11 Sharpen the Blade (para 1832-1833): "lasts 1 minute"
			if (prev.sharpen_the_blade_rounds > 0) {
				prev.sharpen_the_blade_rounds--;
				if (prev.sharpen_the_blade_rounds <= 0) {
					prev.sharpen_the_blade_bonus = 0;
					broadcast_announce(prev.name + "'s Sharpen the Blade fades.", false);
				}
			}
			// Xanathar's Oath of Conquest L20 Invincible Conqueror (para 1998-2003):
			// "for 1 minute" — tick down 10-round duration
			if (prev.invincible_conqueror_active and prev.invincible_conqueror_rounds > 0) {
				prev.invincible_conqueror_rounds--;
				if (prev.invincible_conqueror_rounds <= 0) {
					prev.invincible_conqueror_active = false;
					prev.extra_attacks--;
					broadcast_announce(prev.name + "'s Invincible Conqueror fades.", false);
				}
			}
			// Xanathar's Oath of Redemption L15 Protective Spirit (para 2050-2051):
			// "You regain hit points equal to 1d6 + half your paladin level if you end
			// your turn in combat with fewer than half of your hit points remaining."
			if (prev.protective_spirit_active and !prev.is_dead and !prev.has_condition(COND_INCAPACITATED) and prev.current_hp < prev.max_hp / 2) {
				int ps_heal = random(1, 6) + prev.level / 2;
				int old_hp = prev.current_hp;
				prev.current_hp += ps_heal;
				if (prev.current_hp > prev.max_hp) prev.current_hp = prev.max_hp;
				int actual_heal = prev.current_hp - old_hp;
				if (actual_heal > 0) broadcast_announce(prev.name + "'s Protective Spirit heals " + actual_heal + " HP!", false);
			}

			// Xanathar's Glamour Bard L6 Mantle of Majesty (para 558-561): "for 1 minute
			// or until your concentration ends." Tick down on caster's turn-end.
			if (prev.mantle_of_majesty_active and prev.mantle_of_majesty_rounds > 0) {
				prev.mantle_of_majesty_rounds--;
				if (prev.mantle_of_majesty_rounds <= 0) {
					prev.mantle_of_majesty_active = false;
					if (prev.is_concentrating and prev.concentration_spell == "Mantle of Majesty") {
						prev.is_concentrating = false;
						prev.remove_condition(COND_CONCENTRATING);
						prev.concentration_spell = "";
					}
					broadcast_announce(prev.name + "'s Mantle of Majesty fades.", false);
				}
			}

			// Xanathar's Glamour Bard L14 Unbreakable Majesty (para 562-565): "for 1
			// minute or until you are incapacitated." Tick down on caster's turn-end.
			if (prev.unbreakable_majesty_active and prev.unbreakable_majesty_rounds > 0) {
				prev.unbreakable_majesty_rounds--;
				if (prev.unbreakable_majesty_rounds <= 0) {
					prev.unbreakable_majesty_active = false;
					broadcast_announce(prev.name + "'s Unbreakable Majesty fades.", false);
				}
			}

			// PHB 2024 Sorcerer Draconic Sorcery L14 Dragon Wings (para 7561-7563):
			// "The wings last for 1 hour or until you dismiss them." 1 hour ≈ 600
			// rounds. Tick down on each of the Sorcerer's turn-ends; clear flying
			// speed and the active flag at 0.
			if (prev.dragon_wings_active and prev.dragon_wings_rounds_remaining > 0) {
				prev.dragon_wings_rounds_remaining--;
				if (prev.dragon_wings_rounds_remaining <= 0) {
					prev.dragon_wings_active = false;
					if (prev.flying_speed == 60) prev.flying_speed = 0;
					broadcast_announce(prev.name + "'s Dragon Wings fade.", false);
				}
			}
			// Xanathar's Shadow Magic L18 Umbral Form (para 2605-2607): "1 minute"
			// = 10 rounds. Resistance to all except force/radiant.
			if (prev.shadow_umbral_active and prev.shadow_umbral_rounds > 0) {
				prev.shadow_umbral_rounds--;
				if (prev.shadow_umbral_rounds <= 0) {
					prev.shadow_umbral_active = false;
					broadcast_announce(prev.name + "'s Umbral Form fades.", false);
				}
			}
			// Tasha's Aberrant Mind L14 Revelation in Flesh (para 3942-3948): "10 minutes"
			// = 100 rounds. On expiry, clear chosen options.
			if (prev.revelation_in_flesh_active and prev.revelation_in_flesh_rounds > 0) {
				prev.revelation_in_flesh_rounds--;
				if (prev.revelation_in_flesh_rounds <= 0) {
					prev.revelation_in_flesh_active = false;
					if (prev.revelation_fly) {
						prev.flying_speed = 0;
						prev.revelation_fly = false;
					}
					prev.revelation_see_invisible = false;
					broadcast_announce(prev.name + "'s Revelation in Flesh ends.", false);
				}
			}
			// Tasha's Clockwork Soul L14 Trance of Order (para 4001-4004): "1 minute"
			// = 10 rounds. Advantage cancellation + d20 clamping expire.
			if (prev.trance_of_order_active and prev.trance_of_order_rounds > 0) {
				prev.trance_of_order_rounds--;
				if (prev.trance_of_order_rounds <= 0) {
					prev.trance_of_order_active = false;
					broadcast_announce(prev.name + "'s Trance of Order ends.", false);
				}
			}
			// Tasha's Rune Knight Frost Rune invoke (para 3222-3224): "10 minutes"
			// = 100 rounds. +2 to STR/CON checks and saves.
			if (prev.frost_rune_active and prev.frost_rune_rounds > 0) {
				prev.frost_rune_rounds--;
				if (prev.frost_rune_rounds <= 0) {
					prev.frost_rune_active = false;
					broadcast_announce(prev.name + "'s Frost Rune invocation fades.", false);
				}
			}
			// Tasha's Rune Knight Hill Rune invoke (para 3231-3232): "1 minute"
			// = 10 rounds. B/P/S resistance.
			if (prev.hill_rune_active and prev.hill_rune_rounds > 0) {
				prev.hill_rune_rounds--;
				if (prev.hill_rune_rounds <= 0) {
					prev.hill_rune_active = false;
					broadcast_announce(prev.name + "'s Hill Rune invocation fades. B/P/S resistance ends.", false);
				}
			}
			// Valda's Spire Gunslinger L5 Gut Shot debuff tickdown (paras 184-185):
			// "For 1 minute or until the target replaces one of its attacks with
			// dislodging the projectile, its Speed is halved..." 1 minute = 10 rounds.
			// On expiry, restore the original speed (doubled because we halved it on apply).
			if (prev.gut_shot_rounds_remaining > 0) {
				prev.gut_shot_rounds_remaining--;
				if (prev.gut_shot_rounds_remaining <= 0) {
					prev.speed = prev.speed * 2;
					broadcast_announce(prev.name + " dislodges the Gut Shot projectile. Speed restored.", false);
				}
			}
			// Xanathar's Arcane Archer Grasping Arrow (paras 1618-1646): "The effect
			// lasts for 1 minute." Tick down rounds; clear on expiry, restore speed.
			if (prev.arcane_grasping_active and prev.arcane_grasping_rounds > 0) {
				prev.arcane_grasping_rounds--;
				if (prev.arcane_grasping_rounds <= 0) {
					prev.arcane_grasping_active = false;
					prev.arcane_grasping_source = 0;
					prev.speed += 10;
					broadcast_announce(prev.name + "'s Grasping Arrow thorns wither away. Speed restored.", false);
				}
			}
			// Valda's Spire Gunslinger White Hat L10 Long Arm of the Law (paras 462-463):
			// The hobble lasts only one turn — clear the lockout flag at end of the
			// affected combatant's turn so it doesn't persist into future rounds.
			if (prev.cant_move_until_disengage) {
				prev.cant_move_until_disengage = false;
			}
			if (prev.raging) {
				if (prev.is_dead) {
					prev.raging = false;
					prev.rage_turns_remaining = 0;
				}
				// Xanathar's Zealot L14 Rage Beyond Death (para 448-450): don't end rage
				// early due to 0 HP — let the timer run, then check for death on expiry
				else if (prev.current_hp <= 0 and !prev.rage_beyond_death_active) {
					prev.raging = false;
					prev.rage_turns_remaining = 0;
				}
				else {
					prev.rage_turns_remaining--;
					if (prev.rage_turns_remaining <= 0) {
						prev.raging = false;
						prev.rage_turns_remaining = 0;
						broadcast_announce(prev.name + "'s Rage ends.", false);
						// Zealot Rage Beyond Death: die if still at 0 HP when rage ends
						if (prev.rage_beyond_death_active and prev.current_hp <= 0 and !prev.is_dead) {
							prev.is_dead = true;
							prev.add_condition(COND_UNCONSCIOUS);
							broadcast_announce(prev.name + "'s rage fades and death claims them.", true);
						}
					}
				}
			}
		}

		// End-of-turn saves for the combatant whose turn just ended
		if (@prev != null and prev.is_alive()) {
			// Hold Person / Hold Monster: WIS save to end Paralyzed
			if (prev.has_condition(COND_PARALYZED) and prev.hold_spell_caster_id != 0) {
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ caster = combat.combatants[ci];
					if (@caster == null or caster.is_dead) continue;
					if (caster.id == prev.hold_spell_caster_id and caster.is_concentrating
						and (caster.concentration_spell == "Hold Person" or caster.concentration_spell == "Hold Monster")) {
						int save_roll = random(1, 20);
						if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; broadcast_announce(prev.name + " has disadvantage from Staggering Blow!", false); }
						apply_hound_save_disadvantage(prev, caster.id, save_roll);
						int save_bonus = prev.get_save_bonus(ABILITY_WIS);
						int save_dc_val = spell_save_dc(caster);
						int save_total = save_roll + save_bonus;
						bool saved = save_total >= save_dc_val;
						string hold_name = caster.concentration_spell;
						broadcast_roll(prev.name, "WIS save vs " + hold_name + " (end of turn)", save_roll, save_bonus, save_total, saved ? "Freed!" : "Still paralyzed!");
						if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
						if (!saved) { int ff_total = try_fanatical_focus(prev, save_dc_val, save_total, save_bonus, "WIS save vs " + hold_name); if (ff_total >= save_dc_val) saved = true; }
						if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus, "WIS save vs " + hold_name); if (ds >= save_dc_val) saved = true; }
						if (!saved) { int new_total = try_flash_of_genius(prev, save_dc_val, save_total, "WIS save vs " + hold_name); if (new_total >= save_dc_val) saved = true; }
						if (!saved) { int ms_total = try_maverick_spirit(prev, save_dc_val, save_total, "WIS save vs " + hold_name); if (ms_total >= save_dc_val) saved = true; }
						if (!saved and try_mage_slayer_guarded_mind(prev, ABILITY_WIS)) saved = true;
						if (!saved) { int bf = try_boon_of_fate_bonus(prev, save_total, save_dc_val); if (bf > 0) saved = true; }
						if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus)) saved = true;
						if (saved) {
							prev.remove_condition(COND_PARALYZED);
							prev.hold_spell_caster_id = 0;
							broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Paralyzed"}});
						}
						break;
					}
				}
			}
			// Web: STR save or Athletics check to end Restrained
			if (prev.has_condition(COND_RESTRAINED)) {
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ caster = combat.combatants[ci];
					if (@caster == null or caster.is_dead) continue;
					if (caster.concentration_spell == "Web" and caster.is_concentrating) {
						int save_roll = random(1, 20);
						if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; broadcast_announce(prev.name + " has disadvantage from Staggering Blow!", false); }
						apply_hound_save_disadvantage(prev, caster.id, save_roll);
						int save_bonus = prev.get_save_bonus(ABILITY_DEX);
						int save_dc_val = spell_save_dc(caster);
						int save_total = save_roll + save_bonus;
						bool saved = save_total >= save_dc_val;
						broadcast_roll(prev.name, "DEX save vs Web (end of turn)", save_roll, save_bonus, save_total, saved ? "Freed!" : "Still restrained!");
						if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
						if (!saved) { int ff_total = try_fanatical_focus(prev, save_dc_val, save_total, save_bonus, "DEX save vs Web"); if (ff_total >= save_dc_val) saved = true; }
						if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus, "DEX save vs Web"); if (ds >= save_dc_val) saved = true; }
						if (!saved) { int new_total = try_flash_of_genius(prev, save_dc_val, save_total, "DEX save vs Web"); if (new_total >= save_dc_val) saved = true; }
						if (!saved) { int bf = try_boon_of_fate_bonus(prev, save_total, save_dc_val); if (bf >= save_dc_val) saved = true; }
						if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus)) saved = true;
						if (saved) {
							prev.remove_condition(COND_RESTRAINED);
							prev.restrained_spell_caster_id = 0;
							broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Restrained"}});
						}
						break;
					}
				}
			}
			// Tasha's Rune Knight Fire Rune (para 3218-3221): "At the end of each of the
			// target's turns, the target can make a Constitution saving throw, ending
			// the effect on a success." CON save vs rune DC to break free of Restrained.
			if (prev.has_condition(COND_RESTRAINED) and prev.fire_rune_restrained_source != 0) {
				int fr_save_roll = random(1, 20);
				int fr_save_bonus = prev.get_save_bonus(ABILITY_CON);
				int fr_save_dc = prev.fire_rune_restrained_dc;
				int fr_save_total = fr_save_roll + fr_save_bonus;
				bool fr_saved = fr_save_total >= fr_save_dc;
				broadcast_roll(prev.name, "CON save vs Fire Rune (end of turn)", fr_save_roll, fr_save_bonus, fr_save_total, fr_saved ? "Freed from fiery shackles!" : "Still restrained!");
				if (!fr_saved and try_arcane_deflection_save(prev, fr_save_dc, fr_save_total)) fr_saved = true;
				if (!fr_saved) { int ds = try_disciplined_survivor_reroll(prev, fr_save_dc, fr_save_total, fr_save_bonus, "CON save vs Fire Rune"); if (ds >= fr_save_dc) fr_saved = true; }
				if (!fr_saved) { int fg = try_flash_of_genius(prev, fr_save_dc, fr_save_total, "CON save vs Fire Rune"); if (fg >= fr_save_dc) fr_saved = true; }
				if (!fr_saved) { int bf = try_boon_of_fate_bonus(prev, fr_save_total, fr_save_dc); if (bf >= fr_save_dc) fr_saved = true; }
				if (!fr_saved and try_stroke_of_luck_save(prev, fr_save_dc, fr_save_bonus)) fr_saved = true;
				if (fr_saved) {
					prev.remove_condition(COND_RESTRAINED);
					prev.fire_rune_restrained_source = 0;
					prev.fire_rune_restrained_dc = 0;
					broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Restrained"}});
					broadcast_announce(prev.name + " breaks free from the Fire Rune's fiery shackles!", false);
				}
			}
			// Blindness/Deafness: CON save each turn
			if (prev.has_condition(COND_BLINDED)) {
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ caster = combat.combatants[ci];
					if (@caster == null or caster.is_dead) continue;
					if (caster.concentration_spell == "Blindness/Deafness" and caster.is_concentrating) {
						int save_roll = random(1, 20);
						if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; broadcast_announce(prev.name + " has disadvantage from Staggering Blow!", false); }
						apply_hound_save_disadvantage(prev, caster.id, save_roll);
						int save_bonus = prev.get_save_bonus(ABILITY_CON);
						int save_dc_val = spell_save_dc(caster);
						int save_total = save_roll + save_bonus;
						bool saved = save_total >= save_dc_val;
						broadcast_roll(prev.name, "CON save vs Blindness/Deafness (end of turn)", save_roll, save_bonus, save_total, saved ? "Recovered!" : "Still blinded!");
						if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
						if (!saved) { int ff_total = try_fanatical_focus(prev, save_dc_val, save_total, save_bonus, "CON save vs Blindness/Deafness"); if (ff_total >= save_dc_val) saved = true; }
						if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus, "CON save vs Blindness/Deafness"); if (ds >= save_dc_val) saved = true; }
						if (!saved) { int new_total = try_flash_of_genius(prev, save_dc_val, save_total, "CON save vs Blindness/Deafness"); if (new_total >= save_dc_val) saved = true; }
						if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus)) saved = true;
						if (saved) {
							prev.remove_condition(COND_BLINDED);
							broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Blinded"}});
						}
						break;
					}
				}
			}
			// Fear: WIS save each turn
			if (prev.has_condition(COND_FRIGHTENED)) {
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ caster = combat.combatants[ci];
					if (@caster == null or caster.is_dead) continue;
					if (caster.concentration_spell == "Fear" and caster.is_concentrating) {
						int save_roll = random(1, 20);
						if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; broadcast_announce(prev.name + " has disadvantage from Staggering Blow!", false); }
						apply_hound_save_disadvantage(prev, caster.id, save_roll);
						// Aberrant Mind L6 Psychic Defenses / Fey Ancestry: advantage on charm/frighten saves
						if (prev.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
						int save_bonus = prev.get_save_bonus(ABILITY_WIS);
						int save_dc_val = spell_save_dc(caster);
						int save_total = save_roll + save_bonus;
						bool saved = save_total >= save_dc_val;
						broadcast_roll(prev.name, "WIS save vs Fear (end of turn)", save_roll, save_bonus, save_total, saved ? "Courage returns!" : "Still frightened!");
						if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
						if (!saved) { int ff_total = try_fanatical_focus(prev, save_dc_val, save_total, save_bonus, "WIS save vs Fear"); if (ff_total >= save_dc_val) saved = true; }
						if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus, "WIS save vs Fear"); if (ds >= save_dc_val) saved = true; }
						if (!saved) { int new_total = try_flash_of_genius(prev, save_dc_val, save_total, "WIS save vs Fear"); if (new_total >= save_dc_val) saved = true; }
						if (!saved) { int ms_total = try_maverick_spirit(prev, save_dc_val, save_total, "WIS save vs Fear"); if (ms_total >= save_dc_val) saved = true; }
						if (!saved and try_mage_slayer_guarded_mind(prev, ABILITY_WIS)) saved = true;
						if (!saved) { int bf = try_boon_of_fate_bonus(prev, save_total, save_dc_val); if (bf > 0) saved = true; }
						if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus)) saved = true;
						if (saved) {
							prev.remove_condition(COND_FRIGHTENED);
							broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Frightened"}});
						}
						break;
					}
				}
			}
			// Tasha's Hideous Laughter: WIS save each turn
			if (prev.has_condition(COND_INCAPACITATED) and prev.laughter_spell_caster_id != 0) {
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ caster = combat.combatants[ci];
					if (@caster == null or caster.is_dead) continue;
					if (caster.id == prev.laughter_spell_caster_id and caster.is_concentrating
						and caster.concentration_spell == "Tasha's Hideous Laughter") {
						int save_roll = random(1, 20);
						if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; broadcast_announce(prev.name + " has disadvantage from Staggering Blow!", false); }
						apply_hound_save_disadvantage(prev, caster.id, save_roll);
						int save_bonus = prev.get_save_bonus(ABILITY_WIS);
						int save_dc_val = spell_save_dc(caster);
						int save_total = save_roll + save_bonus;
						bool saved = save_total >= save_dc_val;
						broadcast_roll(prev.name, "WIS save vs Tasha's Hideous Laughter (end of turn)", save_roll, save_bonus, save_total, saved ? "Laughter fades!" : "Still laughing!");
						if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
						if (!saved) { int ff_total = try_fanatical_focus(prev, save_dc_val, save_total, save_bonus, "WIS save vs Tasha's Hideous Laughter"); if (ff_total >= save_dc_val) saved = true; }
						if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus, "WIS save vs Tasha's Hideous Laughter"); if (ds >= save_dc_val) saved = true; }
						if (!saved) { int new_total = try_flash_of_genius(prev, save_dc_val, save_total, "WIS save vs Tasha's Hideous Laughter"); if (new_total >= save_dc_val) saved = true; }
						if (!saved) { int ms_total = try_maverick_spirit(prev, save_dc_val, save_total, "WIS save vs Tasha's Hideous Laughter"); if (ms_total >= save_dc_val) saved = true; }
						if (!saved and try_mage_slayer_guarded_mind(prev, ABILITY_WIS)) saved = true;
						if (!saved) { int bf = try_boon_of_fate_bonus(prev, save_total, save_dc_val); if (bf > 0) saved = true; }
						if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus)) saved = true;
						if (saved) {
							prev.remove_condition(COND_INCAPACITATED);
							prev.remove_condition(COND_PRONE);
							prev.laughter_spell_caster_id = 0;
							broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Incapacitated"}});
						}
						break;
					}
				}
			}
			// PHB 2024 Monk L10 Self-Restoration (para 5362-5364): "Through sheer
			// force of will, you can remove one of the following conditions from
			// yourself at the end of each of your turns: Charmed, Frightened, or
			// Poisoned." Auto-fires on the highest-priority condition the monk has.
			if (prev.self_restoration_active and prev.is_alive()) {
				if (prev.has_condition(COND_FRIGHTENED)) {
					prev.remove_condition(COND_FRIGHTENED);
					broadcast_announce(prev.name + " uses Self-Restoration to shake off the Frightened condition.", false);
				} else if (prev.has_condition(COND_CHARMED)) {
					prev.remove_condition(COND_CHARMED);
					broadcast_announce(prev.name + " uses Self-Restoration to shake off the Charmed condition.", false);
				} else if (prev.has_condition(COND_POISONED)) {
					prev.remove_condition(COND_POISONED);
					broadcast_announce(prev.name + " uses Self-Restoration to shake off the Poisoned condition.", false);
				}
			}

			// Compulsion (Basic Rules 2024 para 12594-12597): "After moving in this
			// way, a target repeats the save, ending the spell on itself on a success."
			// End-of-turn WIS save to break free from Charmed (Compulsion only).
			if (prev.has_condition(COND_CHARMED)) {
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ caster = combat.combatants[ci];
					if (@caster == null or caster.is_dead) continue;
					if (caster.concentration_spell == "Compulsion" and caster.is_concentrating) {
						int save_roll = random(1, 20);
						if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; }
						apply_hound_save_disadvantage(prev, caster.id, save_roll);
						int save_bonus = prev.get_save_bonus(ABILITY_WIS);
						int save_dc_val = spell_save_dc(caster);
						int save_total = save_roll + save_bonus;
						bool saved = save_total >= save_dc_val;
						broadcast_roll(prev.name, "WIS save vs Compulsion (end of turn)", save_roll, save_bonus, save_total, saved ? "Freed!" : "Still compelled!");
						if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
						if (!saved) { if (try_countercharm_reroll(prev, save_dc_val, save_bonus, "WIS save vs Compulsion")) saved = true; }
						if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus, "WIS save vs Compulsion"); if (ds >= save_dc_val) saved = true; }
						if (!saved) { int fg = try_flash_of_genius(prev, save_dc_val, save_total, "WIS save vs Compulsion"); if (fg >= save_dc_val) saved = true; }
						if (!saved) { int mv = try_maverick_spirit(prev, save_dc_val, save_total, "WIS save vs Compulsion"); if (mv >= save_dc_val) saved = true; }
						if (!saved and try_mage_slayer_guarded_mind(prev, ABILITY_WIS)) saved = true;
						if (!saved) { int bf = try_boon_of_fate_bonus(prev, save_total, save_dc_val); if (bf > 0) saved = true; }
						if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus)) saved = true;
						if (saved) {
							prev.remove_condition(COND_CHARMED);
							broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Charmed"}});
						}
						break;
					}
				}
			}
			// Slow: WIS save at end of turn to end the effect on this target
			// Basic Rules para 15047-15049: "An affected target can make a Wisdom saving
			// throw at the end of each of its turns, ending the spell on itself on a success."
			if (prev.slow_spell_caster_id != 0) {
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ caster = combat.combatants[ci];
					if (@caster == null or caster.is_dead) continue;
					if (caster.concentration_spell == "Slow" and caster.is_concentrating and prev.slow_spell_caster_id == caster.id) {
						int save_roll = random(1, 20);
						if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; broadcast_announce(prev.name + " has disadvantage from Staggering Blow!", false); }
						apply_hound_save_disadvantage(prev, caster.id, save_roll);
						int save_bonus = prev.get_save_bonus(ABILITY_WIS);
						int bless_bonus = roll_bless_bonus(prev);
						int save_dc_val = spell_save_dc(caster);
						int save_total = save_roll + save_bonus + bless_bonus;
						bool saved = save_total >= save_dc_val;
						broadcast_roll(prev.name, "WIS save vs Slow (end of turn)", save_roll, save_bonus + bless_bonus, save_total, saved ? "Freed!" : "Still slowed!");
						if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
						if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus + bless_bonus, "WIS save vs Slow"); if (ds >= save_dc_val) saved = true; }
						if (!saved) { int fg = try_flash_of_genius(prev, save_dc_val, save_total, "WIS save vs Slow"); if (fg >= save_dc_val) saved = true; }
						if (!saved) { int mv = try_maverick_spirit(prev, save_dc_val, save_total, "WIS save vs Slow"); if (mv >= save_dc_val) saved = true; }
						if (!saved and try_mage_slayer_guarded_mind(prev, ABILITY_WIS)) saved = true;
						if (!saved) { int bf = try_boon_of_fate_bonus(prev, save_total, save_dc_val); if (bf >= save_dc_val) saved = true; }
						if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus + bless_bonus)) saved = true;
						if (saved) {
							prev.speed = prev.slow_original_speed;
							prev.armor_class += 2;
							prev.slow_spell_caster_id = 0;
							prev.slow_original_speed = 0;
							broadcast_announce(prev.name + " breaks free from the Slow spell!", true);
						}
						break;
					}
				}
			}
			// Confusion: WIS save at end of turn to end the effect on this target
			// Basic Rules para 12510: "An affected target can make a Wisdom saving throw
			// at the end of each of its turns. On a successful save, this effect ends for that target."
			if (prev.has_condition(COND_INCAPACITATED) and prev.incap_spell_caster_id != 0) {
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ caster = combat.combatants[ci];
					if (@caster == null or caster.is_dead) continue;
					if (caster.concentration_spell == "Confusion" and caster.is_concentrating and prev.incap_spell_caster_id == caster.id) {
						int save_roll = random(1, 20);
						if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; broadcast_announce(prev.name + " has disadvantage from Staggering Blow!", false); }
						apply_hound_save_disadvantage(prev, caster.id, save_roll);
						int save_bonus = prev.get_save_bonus(ABILITY_WIS);
						int bless_bonus = roll_bless_bonus(prev);
						int save_dc_val = spell_save_dc(caster);
						int save_total = save_roll + save_bonus + bless_bonus;
						bool saved = save_total >= save_dc_val;
						broadcast_roll(prev.name, "WIS save vs Confusion (end of turn)", save_roll, save_bonus + bless_bonus, save_total, saved ? "Freed!" : "Still confused!");
						if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
						if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus + bless_bonus, "WIS save vs Confusion"); if (ds >= save_dc_val) saved = true; }
						if (!saved) { int fg = try_flash_of_genius(prev, save_dc_val, save_total, "WIS save vs Confusion"); if (fg >= save_dc_val) saved = true; }
						if (!saved) { int mv = try_maverick_spirit(prev, save_dc_val, save_total, "WIS save vs Confusion"); if (mv >= save_dc_val) saved = true; }
						if (!saved and try_mage_slayer_guarded_mind(prev, ABILITY_WIS)) saved = true;
						if (!saved) { int bf = try_boon_of_fate_bonus(prev, save_total, save_dc_val); if (bf >= save_dc_val) saved = true; }
						if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus + bless_bonus)) saved = true;
						if (saved) {
							prev.remove_condition(COND_INCAPACITATED);
							prev.incap_spell_caster_id = 0;
							broadcast_announce(prev.name + " shakes off the Confusion!", true);
							broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Confused"}});
						}
						break;
					}
				}
			}
		}

		// Basic Rules 2024 Power Word Stun (para 14671-14673): "The Stunned target makes
		// a Constitution saving throw at the end of each of its turns, ending the condition
		// on itself on a success." No concentration — the stun lasts until they save.
		if (@prev != null and prev.is_alive() and prev.power_word_stun_caster_id != 0
			and prev.has_condition(COND_STUNNED)) {
			combatant@ pws_caster = combat.get_combatant(prev.power_word_stun_caster_id);
			if (@pws_caster != null) {
				int save_dc_val = spell_save_dc(pws_caster);
				int save_roll = random(1, 20);
				if (prev.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; prev.staggering_blow_active = false; broadcast_announce(prev.name + " has disadvantage from Staggering Blow!", false); }
				int save_bonus = prev.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(prev);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc_val;
				broadcast_roll(prev.name, "CON save vs Power Word Stun (end of turn)", save_roll, save_bonus + bless_bonus, save_total, saved ? "Freed!" : "Still stunned!");
				if (!saved and try_arcane_deflection_save(prev, save_dc_val, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(prev, save_dc_val, save_total, save_bonus + bless_bonus, "CON save vs Power Word Stun"); if (ds >= save_dc_val) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(prev, save_dc_val, save_total, "CON save vs Power Word Stun"); if (fg >= save_dc_val) saved = true; }
				if (!saved) { int bf = try_boon_of_fate_bonus(prev, save_total, save_dc_val); if (bf >= save_dc_val) saved = true; }
				if (!saved and try_stroke_of_luck_save(prev, save_dc_val, save_bonus + bless_bonus)) saved = true;
				if (saved) {
					prev.remove_condition(COND_STUNNED);
					prev.power_word_stun_caster_id = 0;
					broadcast_to_battle({{"type", message_types::condition_removed}, {"target", prev.name}, {"condition", "Stunned"}});
					broadcast_announce(prev.name + " breaks free from Power Word Stun!", true);
				}
			} else {
				// Caster is dead/gone — free the stunned target
				prev.remove_condition(COND_STUNNED);
				prev.power_word_stun_caster_id = 0;
				broadcast_announce(prev.name + " breaks free from Power Word Stun as the caster is gone!", true);
			}
		}

		// Time Stop: if the combatant whose turn just ended has time_stop_turns_remaining,
		// DON'T advance initiative — instead restart their turn immediately.
		if (@prev != null and prev.time_stop_turns_remaining > 0 and prev.is_alive()) {
			prev.time_stop_turns_remaining--;
			prev.has_action = true;
			prev.has_bonus_action = true;
			prev.has_reaction = true;
			prev.movement_remaining = prev.speed;
			prev.has_moved = false;
			prev.used_action = false;
			prev.used_bonus_action = false;
			prev.cast_ba_spell_this_turn = false;
			prev.cast_leveled_spell_this_turn = false;
			int ts_remaining = prev.time_stop_turns_remaining;
			broadcast_announce("Time is frozen! " + prev.name + " takes another turn. (" + (ts_remaining + 1) + " turn" + (ts_remaining > 0 ? "s" : "") + " remaining)", true);
			broadcast_to_battle({
				{"type", message_types::turn_start},
				{"combatant_id", prev.id},
				{"name", prev.name},
				{"hp", prev.current_hp},
				{"max_hp", prev.max_hp},
				{"has_action", prev.has_action},
				{"has_bonus_action", prev.has_bonus_action},
				{"round", combat.round_number},
				{"turn_index", combat.current_turn_index}
			});
			broadcast_state();
			// Start monster AI if it's a monster's time-stopped turn
			if (!prev.is_player) execute_monster_turn(prev);
			else if (combatant_is_controlled_by_bot(prev)) execute_player_bot_turn(prev);
			return;
		}

		// Xanathar's Scout Rogue L3 Skirmisher (paras 2391-2393): "If an enemy ends
		// its turn within 5 feet of you, you can use your reaction to move up to half
		// your speed. This movement doesn't provoke opportunity attacks."
		if (@prev != null and prev.is_alive()) {
			for (uint ski = 0; ski < combat.combatants.length(); ski++) {
				combatant@ sk = combat.combatants[ski];
				if (@sk == null or sk.is_dead or sk.id == prev.id) continue;
				if (!sk.skirmisher_active or !sk.has_reaction) continue;
				// Must be an enemy of the combatant whose turn just ended
				if (sk.is_player == prev.is_player) continue;
				// Must be within 5ft (1 tile) of the prev combatant
				if (feet_distance(sk.x, sk.y, prev.x, prev.y) > 5) continue;
				// Move up to half speed away from the enemy
				int tiles_to_move = sk.speed / 2 / FEET_PER_TILE;
				if (tiles_to_move < 1) tiles_to_move = 1;
				// Calculate direction away from enemy
				int dx = sk.x - prev.x;
				int dy = sk.y - prev.y;
				// Normalise to -1/0/+1 for tile-by-tile movement
				if (dx > 0) dx = 1; else if (dx < 0) dx = -1;
				if (dy > 0) dy = 1; else if (dy < 0) dy = -1;
				// If on the same tile, pick a default direction (away = +x)
				if (dx == 0 and dy == 0) dx = 1;
				for (int step = 0; step < tiles_to_move; step++) {
					sk.x += dx;
					sk.y += dy;
				}
				sk.has_reaction = false;
				broadcast_announce(sk.name + " uses Skirmisher to dart away (" + (tiles_to_move * FEET_PER_TILE) + " ft)!", false);
			}
		}

		combat.advance_turn();
		combatant@ c = combat.current_combatant();
		if (@c == null) return;
		clear_shield_effect(c, false);
		clear_help_effect(c, false);
		// Basic Rules 2024 Power Word Stun (para 14671-14673): >150 HP path —
		// "Speed is 0 until the start of your next turn." Clear at caster's turn start.
		for (uint pwsi = 0; pwsi < combat.combatants.length(); pwsi++) {
			combatant@ pws_t = combat.combatants[pwsi];
			if (@pws_t != null and pws_t.power_word_stun_speed_zero and pws_t.power_word_stun_speed_source == c.id) {
				pws_t.power_word_stun_speed_zero = false;
				pws_t.power_word_stun_speed_source = 0;
				broadcast_announce(pws_t.name + "'s speed is restored as the Power Word effect fades.", false);
			}
		}
		// Basic Rules 2024 Heat Metal (para 13734): disadvantage lasts "until the
		// start of your next turn" — clear on the CASTER's turn start.
		if (c.heat_metal_active and c.heat_metal_target_id != 0) {
			combatant@ hm_target = combat.get_combatant(c.heat_metal_target_id);
			if (@hm_target != null) hm_target.heat_metal_disadv = false;
		}
		if (c.readied_action >= 0) {
			broadcast_announce(c.name + "'s readied action expires.", false);
			clear_readied_action(c);
		}

		// Skip dead combatants.
		if (c.is_dead) {
			check_battle_end();
			if (!combat.battle_active) return;
			advance_turn();
			return;
		}

		// Skip stable unconscious combatants (they do nothing on their turn).
		if (c.is_stable and c.current_hp == 0) {
			check_battle_end();
			if (!combat.battle_active) return;
			advance_turn();
			return;
		}

		// PHB 2024: Stunned (para 16246), Paralyzed (para 16230), Unconscious
		// (para 16250) — creature can't take actions, bonus actions, or reactions
		// and can't move. Auto-skip turn (end-of-turn saves still fire in
		// advance_turn's condition save block above).
		if (c.has_condition(COND_STUNNED) or c.has_condition(COND_PARALYZED) or c.has_condition(COND_UNCONSCIOUS)) {
			string reason = "Stunned";
			if (c.has_condition(COND_PARALYZED)) reason = "Paralyzed";
			if (c.has_condition(COND_UNCONSCIOUS)) reason = "Unconscious";
			// Basic Rules 2024 Command (para 12421): commanded effect wasted — creature can't act.
			if (c.command_effect != "") { c.command_effect = ""; c.command_source_id = 0; }
			broadcast_announce(c.name + " is " + reason + " and loses their turn.", true);
			broadcast_state();
			advance_turn();
			return;
		}

		if (c.haste_loses_next_turn) {
			c.has_action = false;
			c.has_bonus_action = false;
			c.movement_remaining = 0;
			c.haste_loses_next_turn = false;
			broadcast_announce(c.name + " is lethargic as Haste ends and cannot move or act this turn.", true);
		}
		// PHB 2024 Rogue L14 Cunning Strike — Daze (para 6564): "on its next turn,
		// it can do only one of the following: move or take an action or a Bonus Action."
		// AI picks action (most impactful); players lose movement + bonus action.
		if (c.cunning_strike_dazed) {
			c.cunning_strike_dazed = false;
			c.cunning_strike_dazed_rounds = 0;
			if (c.is_player) {
				// Player: keep action, lose movement + bonus action
				c.has_bonus_action = false;
				c.movement_remaining = 0;
				broadcast_announce(c.name + " is dazed! Can only take an action this turn (no movement or bonus action).", true);
			} else {
				// Monster AI: keep action, lose movement + bonus action
				c.has_bonus_action = false;
				c.movement_remaining = 0;
				broadcast_announce(c.name + " is dazed! Can only take an action this turn.", true);
			}
		}
		// Basic Rules 2024 Command (para 12421-12433): execute the commanded effect
		// at the start of the commanded creature's next turn, then clear it.
		if (c.command_effect != "") {
			if (c.command_effect == "grovel") {
				// "The target has the Prone condition and then ends its turn."
				c.add_condition(COND_PRONE);
				c.has_action = false;
				c.has_bonus_action = false;
				c.movement_remaining = 0;
				broadcast_announce(c.name + " grovels on the ground, falling Prone!", true);
			}
			else if (c.command_effect == "halt") {
				// "On its turn, the target doesn't move and takes no action or Bonus Action."
				c.has_action = false;
				c.has_bonus_action = false;
				c.movement_remaining = 0;
				broadcast_announce(c.name + " is halted and cannot move or act this turn!", true);
			}
			else if (c.command_effect == "flee") {
				// "The target spends its turn moving away from you by the fastest
				// available means." Fastest means = Dash (double movement).
				combatant@ cmd_src = combat.get_combatant(c.command_source_id);
				if (@cmd_src != null and !cmd_src.is_dead) {
					c.movement_remaining = c.speed * 2; // Dash for fastest means
					while (c.movement_remaining >= FEET_PER_TILE and c.is_alive()) {
						int old_x = c.x;
						int old_y = c.y;
						int dx = 0, dy = 0;
						// Move AWAY from the caster
						if (cmd_src.x > c.x) dx = -1;
						else if (cmd_src.x < c.x) dx = 1;
						if (cmd_src.y > c.y) dy = -1;
						else if (cmd_src.y < c.y) dy = 1;
						if (dx != 0) { c.x += dx; c.movement_remaining -= FEET_PER_TILE; }
						else if (dy != 0) { c.y += dy; c.movement_remaining -= FEET_PER_TILE; }
						else break;
						check_opportunity_attacks(c, old_x, old_y, c.x, c.y);
						if (@current_roll != null or c.is_dead or c.current_hp == 0) break;
					}
				}
				c.has_action = false;
				c.has_bonus_action = false;
				c.movement_remaining = 0;
				if (c.is_alive()) broadcast_announce(c.name + " flees under the Command spell!", true);
			}
			else if (c.command_effect == "approach") {
				// "The target moves toward you by the shortest and most direct route,
				// ending its turn if it moves within 5 feet of you."
				combatant@ cmd_src = combat.get_combatant(c.command_source_id);
				if (@cmd_src != null and !cmd_src.is_dead) {
					while (c.movement_remaining >= FEET_PER_TILE and feet_distance(c.x, c.y, cmd_src.x, cmd_src.y) > FEET_PER_TILE and c.is_alive()) {
						int old_x = c.x;
						int old_y = c.y;
						int dx = 0, dy = 0;
						if (cmd_src.x > c.x) dx = 1;
						else if (cmd_src.x < c.x) dx = -1;
						if (cmd_src.y > c.y) dy = 1;
						else if (cmd_src.y < c.y) dy = -1;
						if (dx != 0) { c.x += dx; c.movement_remaining -= FEET_PER_TILE; }
						else if (dy != 0) { c.y += dy; c.movement_remaining -= FEET_PER_TILE; }
						else break;
						check_opportunity_attacks(c, old_x, old_y, c.x, c.y);
						if (@current_roll != null or c.is_dead or c.current_hp == 0) break;
					}
				}
				c.has_action = false;
				c.has_bonus_action = false;
				c.movement_remaining = 0;
				if (c.is_alive()) broadcast_announce(c.name + " approaches the caster under the Command spell!", true);
			}
			else if (c.command_effect == "drop") {
				// "The target drops whatever it is holding and then ends its turn."
				// No item-drop system — announce and waste their turn.
				c.has_action = false;
				c.has_bonus_action = false;
				c.movement_remaining = 0;
				broadcast_announce(c.name + " drops what they're holding under the Command spell!", true);
			}
			c.command_effect = "";
			c.command_source_id = 0;
			broadcast_state();
		}
		// Basic Rules 2024 Bestow Curse (para 12219-12222): forced_dodge curse —
		// "target must make a WIS save at the start of each of its turns. On a
		// failed save, it wastes its Action that turn doing nothing."
		if (c.bestow_curse_type == "forced_dodge" and c.bestow_curse_source_id != 0) {
			combatant@ curse_src = combat.get_combatant(c.bestow_curse_source_id);
			if (@curse_src != null and !curse_src.is_dead) {
				int bc_dc = spell_save_dc(curse_src);
				int bc_roll = random(1, 20);
				if (c.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < bc_roll) bc_roll = sb2; c.staggering_blow_active = false; }
				apply_hound_save_disadvantage(c, curse_src.id, bc_roll);
				int bc_bonus = c.get_save_bonus(ABILITY_WIS);
				int bc_bless = roll_bless_bonus(c);
				int bc_total = bc_roll + bc_bonus + bc_bless;
				bool bc_saved = bc_total >= bc_dc;
				if (!bc_saved and try_arcane_deflection_save(c, bc_dc, bc_total)) bc_saved = true;
				if (!bc_saved) { int ds = try_disciplined_survivor_reroll(c, bc_dc, bc_total, bc_bonus + bc_bless, "WIS save vs Bestow Curse"); if (ds >= bc_dc) bc_saved = true; }
				if (!bc_saved) { int fg = try_flash_of_genius(c, bc_dc, bc_total, "WIS save vs Bestow Curse"); if (fg >= bc_dc) { bc_saved = true; bc_total = fg; } }
				if (!bc_saved) { int mv = try_maverick_spirit(c, bc_dc, bc_total, "WIS save vs Bestow Curse"); if (mv >= bc_dc) { bc_saved = true; bc_total = mv; } }
				if (!bc_saved and try_mage_slayer_guarded_mind(c, ABILITY_WIS)) bc_saved = true;
				if (!bc_saved) { int bf = try_boon_of_fate_bonus(c, bc_total, bc_dc); if (bf > 0) bc_saved = true; }
				if (!bc_saved and try_stroke_of_luck_save(c, bc_dc, bc_bonus + bc_bless)) bc_saved = true;
				broadcast_roll(c.name, "WIS save vs Bestow Curse (turn start)", bc_roll, bc_bonus + bc_bless, bc_total, bc_saved ? "Resists!" : "Forced to Dodge!");
				if (!bc_saved) {
					c.has_action = false;
					c.is_dodging = true;
					broadcast_announce(c.name + " is forced to Dodge by the curse!", true);
				}
			}
		}
		if (c.heroism_source_id != 0 and c.is_alive() and c.heroism_temp_hp_amount > 0) {
			if (c.temp_hp < c.heroism_temp_hp_amount) c.temp_hp = c.heroism_temp_hp_amount;
			c.remove_condition(COND_FRIGHTENED);
			broadcast_announce(c.name + " gains " + c.heroism_temp_hp_amount + " temporary hit points from Heroism.", false);
		}

		// Tick potion buff durations
		if (c.potion_damage_rounds > 0) {
			c.potion_damage_rounds--;
			if (c.potion_damage_rounds <= 0) { c.potion_damage_bonus = 0; broadcast_announce(c.name + "'s Strength potion wears off."); }
		}
		if (c.potion_ac_rounds > 0) {
			c.potion_ac_rounds--;
			if (c.potion_ac_rounds <= 0) { c.armor_class -= c.potion_ac_bonus; c.potion_ac_bonus = 0; broadcast_announce(c.name + "'s Iron Skin potion wears off."); }
		}
		if (c.potion_speed_rounds > 0) {
			c.potion_speed_rounds--;
			if (c.potion_speed_rounds <= 0) { c.speed -= c.potion_speed_bonus; c.potion_speed_bonus = 0; broadcast_announce(c.name + "'s Speed potion wears off."); }
		}
		if (c.potion_spell_dc_rounds > 0) {
			c.potion_spell_dc_rounds--;
			if (c.potion_spell_dc_rounds <= 0) { c.potion_spell_dc_bonus = 0; broadcast_announce(c.name + "'s Focus potion wears off."); }
		}

		// Blessed Grounds modifier: heal 5 HP at turn start
		if (active_modifier == "blessed_grounds" and c.is_player and c.is_alive() and c.current_hp > 0) {
			int healed = combat.apply_healing(c, 5);
			if (healed > 0) broadcast_announce(c.name + " heals " + healed + " HP from Blessed Grounds.", false);
		}

		// Basic Rules 2024 Aura of Life (para 12166-12168): "While in the aura, you and
		// your allies have Resistance to Necrotic damage, and your Hit Point maximums can't
		// be reduced. If an ally with 0 Hit Points starts its turn in the aura, that ally
		// regains 1 Hit Point."
		// Check all living casters with aura_of_life_active. If this combatant is an ally
		// within 30ft: grant necrotic resistance for the turn, and heal 1 HP if at 0.
		{
			bool in_any_aol = false;
			for (uint aoli = 0; aoli < combat.combatants.length(); aoli++) {
				combatant@ aol_caster = combat.combatants[aoli];
				if (@aol_caster == null or aol_caster.is_dead or !aol_caster.aura_of_life_active) continue;
				// Must be on the same side (allies), or the caster themselves
				if (aol_caster.is_player != c.is_player and aol_caster.id != c.id) continue;
				int aol_dist = feet_distance(aol_caster.x, aol_caster.y, c.x, c.y);
				if (aol_dist <= 30) {
					in_any_aol = true;
					// Grant necrotic resistance while in aura (track source for cleanup)
					if (!c.necrotic_resistance) {
						c.necrotic_resistance = true;
						c.aura_of_life_necrotic_from = aol_caster.id;
					}
					// Ally at 0 HP regains 1 HP (not the caster — source says "an ally")
					if (c.id != aol_caster.id and c.current_hp == 0 and c.is_alive()) {
						int aol_healed = combat.apply_healing(c, 1);
						if (aol_healed > 0) {
							broadcast_announce(c.name + " regains 1 HP from " + aol_caster.name + "'s Aura of Life!", true);
						}
					}
					break; // Only need one aura source to apply
				}
			}
			// If NOT in any Aura of Life but resistance was granted by one, remove it
			if (!in_any_aol and c.aura_of_life_necrotic_from != 0) {
				c.necrotic_resistance = false;
				c.aura_of_life_necrotic_from = 0;
			}
		}

		// Spirit Guardians: WIS save; enemies who start their turn inside the 15ft aura take damage.
		// Basic Rules 2024 Spirit Guardians (para 15123-15126): "the first time on a turn
		// [the creature] enters the Emanation or starts its turn in it." Movement entry
		// is handled in handle_move. Halved speed while inside the aura.
		for (uint sgi = 0; sgi < combat.combatants.length(); sgi++) {
			combatant@ sg_caster = combat.combatants[sgi];
			if (@sg_caster == null or sg_caster.is_dead or !sg_caster.spirit_guardians_active) continue;
			if (sg_caster.id == c.id) continue;
			if (sg_caster.is_player == c.is_player) continue;
			int sg_dist = feet_distance(sg_caster.x, sg_caster.y, c.x, c.y);
			if (sg_dist <= 15 and !c.spirit_guardians_damaged_this_turn) {
				int sg_dice = 3 + (sg_caster.spirit_guardians_slot_level - 3);
				if (sg_dice < 3) sg_dice = 3;
				int sg_save_roll = random(1, 20);
				int sg_save_bonus = c.get_save_bonus(ABILITY_WIS);
				int sg_dc = spell_save_dc(sg_caster, "spirit_guardians");
				bool sg_saved = (sg_save_roll + sg_save_bonus) >= sg_dc;
				broadcast_roll(c.name, "WIS save vs Spirit Guardians", sg_save_roll, sg_save_bonus, sg_save_roll + sg_save_bonus, sg_saved ? "Saved! Half damage." : "Failed!");
				int sg_dmg = 0;
				for (int sd = 0; sd < sg_dice; sd++) sg_dmg += random(1, 8);
				if (sg_saved) sg_dmg /= 2;
				if (sg_dmg < 1) sg_dmg = 1;
				// Damage type: radiant (good/neutral) or necrotic (evil) - default radiant
				int sg_damage_type = sg_caster.spirit_guardians_necrotic ? DMG_NECROTIC : DMG_RADIANT;
				string sg_type_name = sg_caster.spirit_guardians_necrotic ? "necrotic" : "radiant";
				combat.apply_damage(c, sg_dmg, sg_damage_type, sg_caster);
				broadcast_announce(c.name + " takes " + sg_dmg + " " + sg_type_name + " damage from " + sg_caster.name + "'s Spirit Guardians!", true);
				c.spirit_guardians_damaged_this_turn = true;
				// Half movement speed within aura
				c.speed = c.speed / 2 > 5 ? c.speed / 2 : 5;
				break;
			}
		}

		// Basic Rules 2024 Searing Smite (para 14881-14888): "At the start of each
		// of its turns until the spell ends, the target takes 1d6 Fire damage and
		// then makes a Constitution saving throw. On a failed save, the spell
		// continues. On a successful save, the spell ends."
		if (c.searing_smite_caster_id != 0 and c.searing_smite_dot_dice > 0) {
			combatant@ ss_caster = combat.get_combatant(c.searing_smite_caster_id);
			if (@ss_caster != null and !ss_caster.is_dead and ss_caster.is_concentrating and ss_caster.concentration_spell == "Searing Smite") {
				int ss_dot_dmg = 0;
				for (int sd = 0; sd < c.searing_smite_dot_dice; sd++) ss_dot_dmg += random(1, 6);
				combat.apply_damage(c, ss_dot_dmg, DMG_FIRE, ss_caster);
				broadcast_announce(c.name + " takes " + ss_dot_dmg + " fire damage from Searing Smite!", true);
				// CON save to end the effect
				int ss_save_roll = random(1, 20);
				int ss_save_bonus = c.get_save_bonus(ABILITY_CON);
				int ss_dc = spell_save_dc(ss_caster, "searing_smite");
				bool ss_saved = (ss_save_roll + ss_save_bonus) >= ss_dc;
				broadcast_roll(c.name, "CON save vs Searing Smite", ss_save_roll, ss_save_bonus, ss_save_roll + ss_save_bonus, ss_saved ? "Saved! Fire extinguished." : "Failed! Fire continues.");
				if (ss_saved) {
					c.searing_smite_caster_id = 0;
					c.searing_smite_dot_dice = 0;
					ss_caster.is_concentrating = false;
					ss_caster.concentration_spell = "";
				}
			} else {
				// Caster dead or lost concentration — clear DOT
				c.searing_smite_caster_id = 0;
				c.searing_smite_dot_dice = 0;
			}
		}

		// Basic Rules 2024 Shining Smite (para 14976-14983): "Until the spell ends,
		// the target sheds Bright Light in a 5-foot radius, attack rolls against it
		// have Advantage, and it can't benefit from the Invisible condition."
		// Tick down duration on the debuffed target's turn start.
		if (c.shining_smite_debuff and c.shining_smite_debuff_rounds > 0) {
			c.shining_smite_debuff_rounds--;
			if (c.shining_smite_debuff_rounds <= 0) {
				c.shining_smite_debuff = false;
				c.shining_smite_debuff_source_id = 0;
				c.starry_wisp_no_invis = false; // Clear the shared invisibility block
				broadcast_announce(c.name + "'s Shining Smite aura fades.", false);
			}
		}

		// Concentration AoE per-turn effects: creatures starting their turn in
		// the caster's ongoing concentration area take the per-round effect.
		// Cloudkill, Insect Plague, Stinking Cloud, Spike Growth, Black Tentacles, Moonbeam.
		for (uint cai = 0; cai < combat.combatants.length(); cai++) {
			combatant@ ca_caster = combat.combatants[cai];
			if (@ca_caster == null or ca_caster.is_dead or !ca_caster.is_concentrating) continue;
			if (ca_caster.id == c.id) continue; // casters not affected by own AoE

			// Cloudkill (Basic Rules para 12408): CON save, 5d8+upcast poison, half on save
			if (ca_caster.concentration_spell == "Cloudkill" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 20) {
					int ck_dice = 5 + (ca_caster.conc_aoe_slot_level - 5);
					if (ck_dice < 5) ck_dice = 5;
					int ck_dc = spell_save_dc(ca_caster, "cloudkill");
					int ck_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, ck_roll);
					int ck_bonus = c.get_save_bonus(ABILITY_CON);
					int ck_bless = roll_bless_bonus(c);
					int ck_total = ck_roll + ck_bonus + ck_bless;
					bool ck_saved = ck_total >= ck_dc;
					broadcast_roll(c.name, "CON save vs Cloudkill", ck_roll, ck_bonus + ck_bless, ck_total, ck_saved ? "Half damage!" : "Full damage!");
					if (!ck_saved and try_arcane_deflection_save(c, ck_dc, ck_total)) ck_saved = true;
					if (!ck_saved) { int fg = try_flash_of_genius(c, ck_dc, ck_total, "CON save vs Cloudkill"); if (fg >= ck_dc) ck_saved = true; }
					if (!ck_saved) { int bf = try_boon_of_fate_bonus(c, ck_total, ck_dc); if (bf >= ck_dc) ck_saved = true; }
					if (!ck_saved and try_stroke_of_luck_save(c, ck_dc, ck_bonus + ck_bless)) ck_saved = true;
					int ck_dmg = 0;
					for (int d = 0; d < ck_dice; d++) ck_dmg += random(1, 8);
					if (ck_saved) ck_dmg /= 2;
					if (ck_dmg < 1) ck_dmg = 1;
					combat.apply_damage(c, ck_dmg, DMG_POISON, ca_caster);
					broadcast_announce(c.name + " takes " + ck_dmg + " poison damage from " + ca_caster.name + "'s Cloudkill!", true);
					if (c.is_dead) break;
				}
			}

			// Insect Plague (Basic Rules para 13899): CON save, 4d10+upcast piercing, half on save
			else if (ca_caster.concentration_spell == "Insect Plague" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 20) {
					int ip_dice = 4 + (ca_caster.conc_aoe_slot_level - 5);
					if (ip_dice < 4) ip_dice = 4;
					int ip_dc = spell_save_dc(ca_caster, "insect_plague");
					int ip_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, ip_roll);
					int ip_bonus = c.get_save_bonus(ABILITY_CON);
					int ip_bless = roll_bless_bonus(c);
					int ip_total = ip_roll + ip_bonus + ip_bless;
					bool ip_saved = ip_total >= ip_dc;
					broadcast_roll(c.name, "CON save vs Insect Plague", ip_roll, ip_bonus + ip_bless, ip_total, ip_saved ? "Half damage!" : "Full damage!");
					if (!ip_saved and try_arcane_deflection_save(c, ip_dc, ip_total)) ip_saved = true;
					if (!ip_saved) { int fg = try_flash_of_genius(c, ip_dc, ip_total, "CON save vs Insect Plague"); if (fg >= ip_dc) ip_saved = true; }
					if (!ip_saved) { int bf = try_boon_of_fate_bonus(c, ip_total, ip_dc); if (bf >= ip_dc) ip_saved = true; }
					if (!ip_saved and try_stroke_of_luck_save(c, ip_dc, ip_bonus + ip_bless)) ip_saved = true;
					int ip_dmg = 0;
					for (int d = 0; d < ip_dice; d++) ip_dmg += random(1, 10);
					if (ip_saved) ip_dmg /= 2;
					if (ip_dmg < 1) ip_dmg = 1;
					combat.apply_damage(c, ip_dmg, DMG_PIERCING, ca_caster);
					broadcast_announce(c.name + " takes " + ip_dmg + " piercing damage from " + ca_caster.name + "'s Insect Plague!", true);
					if (c.is_dead) break;
				}
			}

			// Stinking Cloud (Basic Rules para 15152): CON save or Poisoned until end of turn
			else if (ca_caster.concentration_spell == "Stinking Cloud" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 20) {
					int sc_dc = spell_save_dc(ca_caster, "stinking_cloud");
					int sc_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, sc_roll);
					int sc_bonus = c.get_save_bonus(ABILITY_CON);
					int sc_bless = roll_bless_bonus(c);
					int sc_total = sc_roll + sc_bonus + sc_bless;
					bool sc_saved = sc_total >= sc_dc;
					broadcast_roll(c.name, "CON save vs Stinking Cloud", sc_roll, sc_bonus + sc_bless, sc_total, sc_saved ? "Saved!" : "Poisoned!");
					if (!sc_saved and try_arcane_deflection_save(c, sc_dc, sc_total)) sc_saved = true;
					if (!sc_saved) { int ds = try_disciplined_survivor_reroll(c, sc_dc, sc_total, sc_bonus + sc_bless, "CON save vs Stinking Cloud"); if (ds >= sc_dc) sc_saved = true; }
					if (!sc_saved) { int fg = try_flash_of_genius(c, sc_dc, sc_total, "CON save vs Stinking Cloud"); if (fg >= sc_dc) sc_saved = true; }
					if (!sc_saved) { int bf = try_boon_of_fate_bonus(c, sc_total, sc_dc); if (bf >= sc_dc) sc_saved = true; }
					if (!sc_saved and try_stroke_of_luck_save(c, sc_dc, sc_bonus + sc_bless)) sc_saved = true;
					if (!sc_saved) {
						c.add_condition(COND_POISONED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", c.name}, {"condition", "Poisoned"}});
						broadcast_announce(c.name + " is Poisoned by " + ca_caster.name + "'s Stinking Cloud!", true);
					}
				}
			}

			// Spike Growth (Basic Rules para 15114): 2d4 piercing, no save (movement approximation)
			else if (ca_caster.concentration_spell == "Spike Growth" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 20) {
					int spk_dmg = random(1, 4) + random(1, 4);
					combat.apply_damage(c, spk_dmg, DMG_PIERCING, ca_caster);
					broadcast_announce(c.name + " takes " + spk_dmg + " piercing damage from " + ca_caster.name + "'s Spike Growth!", true);
					if (c.is_dead) break;
				}
			}

			// Evard's Black Tentacles (Basic Rules): STR save, 3d6 bludgeoning + Restrained
			else if (ca_caster.concentration_spell == "Evard's Black Tentacles" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 20) {
					int bt_dc = spell_save_dc(ca_caster, "evards_black_tentacles");
					int bt_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, bt_roll);
					int bt_bonus = c.get_save_bonus(ABILITY_STR);
					int bt_bless = roll_bless_bonus(c);
					int bt_total = bt_roll + bt_bonus + bt_bless;
					bool bt_saved = bt_total >= bt_dc;
					broadcast_roll(c.name, "STR save vs Black Tentacles", bt_roll, bt_bonus + bt_bless, bt_total, bt_saved ? "Saved!" : "Grabbed!");
					if (!bt_saved and try_arcane_deflection_save(c, bt_dc, bt_total)) bt_saved = true;
					if (!bt_saved) { int ds = try_disciplined_survivor_reroll(c, bt_dc, bt_total, bt_bonus + bt_bless, "STR save vs Black Tentacles"); if (ds >= bt_dc) bt_saved = true; }
					if (!bt_saved) { int fg = try_flash_of_genius(c, bt_dc, bt_total, "STR save vs Black Tentacles"); if (fg >= bt_dc) bt_saved = true; }
					if (!bt_saved) { int bf = try_boon_of_fate_bonus(c, bt_total, bt_dc); if (bf >= bt_dc) bt_saved = true; }
					if (!bt_saved and try_stroke_of_luck_save(c, bt_dc, bt_bonus + bt_bless)) bt_saved = true;
					int bt_dmg = 0;
					for (int d = 0; d < 3; d++) bt_dmg += random(1, 6);
					combat.apply_damage(c, bt_dmg, DMG_BLUDGEONING, ca_caster);
					broadcast_announce(c.name + " takes " + bt_dmg + " bludgeoning damage from " + ca_caster.name + "'s Black Tentacles!", true);
					if (!bt_saved) {
						c.add_condition(COND_RESTRAINED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", c.name}, {"condition", "Restrained"}});
					}
					if (c.is_dead) break;
				}
			}

			// Wall of Fire (Basic Rules para 15545-15547): DEX save, 5d8+upcast fire, half on save.
			// "deals 5d8 Fire damage to each creature that ends its turn within 10 feet of that side"
			else if (ca_caster.concentration_spell == "Wall of Fire" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 10) {
					int wf_dice = 5 + (ca_caster.conc_aoe_slot_level - 4);
					if (wf_dice < 5) wf_dice = 5;
					int wf_dc = spell_save_dc(ca_caster, "wall_of_fire");
					int wf_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, wf_roll);
					int wf_bonus = c.get_save_bonus(ABILITY_DEX);
					int wf_bless = roll_bless_bonus(c);
					int wf_total = wf_roll + wf_bonus + wf_bless;
					bool wf_saved = wf_total >= wf_dc;
					broadcast_roll(c.name, "DEX save vs Wall of Fire", wf_roll, wf_bonus + wf_bless, wf_total, wf_saved ? "Half damage!" : "Full damage!");
					if (!wf_saved and try_arcane_deflection_save(c, wf_dc, wf_total)) wf_saved = true;
					if (!wf_saved) { int fg = try_flash_of_genius(c, wf_dc, wf_total, "DEX save vs Wall of Fire"); if (fg >= wf_dc) wf_saved = true; }
					if (!wf_saved) { int bf = try_boon_of_fate_bonus(c, wf_total, wf_dc); if (bf >= wf_dc) wf_saved = true; }
					if (!wf_saved and try_stroke_of_luck_save(c, wf_dc, wf_bonus + wf_bless)) wf_saved = true;
					int wf_dmg = 0;
					for (int d = 0; d < wf_dice; d++) wf_dmg += random(1, 8);
					if (wf_saved) wf_dmg /= 2;
					if (wf_dmg < 1) wf_dmg = 1;
					combat.apply_damage(c, wf_dmg, DMG_FIRE, ca_caster);
					broadcast_announce(c.name + " takes " + wf_dmg + " fire damage from " + ca_caster.name + "'s Wall of Fire!", true);
					if (c.is_dead) break;
				}
			}

			// Sleet Storm (Basic Rules para 15038-15039): DEX save or Prone + lose Concentration.
			// "starts its turn there, must succeed on a DEX saving throw or have the Prone condition"
			else if (ca_caster.concentration_spell == "Sleet Storm" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 20) {
					int ss_dc = spell_save_dc(ca_caster, "sleet_storm");
					int ss_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, ss_roll);
					int ss_bonus = c.get_save_bonus(ABILITY_DEX);
					int ss_bless = roll_bless_bonus(c);
					int ss_total = ss_roll + ss_bonus + ss_bless;
					bool ss_saved = ss_total >= ss_dc;
					broadcast_roll(c.name, "DEX save vs Sleet Storm", ss_roll, ss_bonus + ss_bless, ss_total, ss_saved ? "Saved!" : "Prone!");
					if (!ss_saved and try_arcane_deflection_save(c, ss_dc, ss_total)) ss_saved = true;
					if (!ss_saved) { int ds = try_disciplined_survivor_reroll(c, ss_dc, ss_total, ss_bonus + ss_bless, "DEX save vs Sleet Storm"); if (ds >= ss_dc) ss_saved = true; }
					if (!ss_saved) { int fg = try_flash_of_genius(c, ss_dc, ss_total, "DEX save vs Sleet Storm"); if (fg >= ss_dc) ss_saved = true; }
					if (!ss_saved) { int bf = try_boon_of_fate_bonus(c, ss_total, ss_dc); if (bf >= ss_dc) ss_saved = true; }
					if (!ss_saved and try_stroke_of_luck_save(c, ss_dc, ss_bonus + ss_bless)) ss_saved = true;
					if (!ss_saved) {
						c.add_condition(COND_PRONE);
						if (c.is_concentrating) {
							clear_concentration_effects(c);
							c.is_concentrating = false;
							c.remove_condition(COND_CONCENTRATING);
							broadcast_announce(c.name + "'s concentration is broken by " + ca_caster.name + "'s Sleet Storm!", true);
						} else {
							broadcast_announce(c.name + " is knocked Prone by " + ca_caster.name + "'s Sleet Storm!", true);
						}
					}
				}
			}

			// Flaming Sphere (Basic Rules para 13310-13312): DEX save, 2d6+upcast fire, half on save.
			// "Any creature that ends its turn within 5 feet of the sphere makes a DEX saving throw"
			else if (ca_caster.concentration_spell == "Flaming Sphere" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 5) {
					int fs_dice = 2 + (ca_caster.conc_aoe_slot_level - 2);
					if (fs_dice < 2) fs_dice = 2;
					int fs_dc = spell_save_dc(ca_caster, "flaming_sphere");
					int fs_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, fs_roll);
					int fs_bonus = c.get_save_bonus(ABILITY_DEX);
					int fs_bless = roll_bless_bonus(c);
					int fs_total = fs_roll + fs_bonus + fs_bless;
					bool fs_saved = fs_total >= fs_dc;
					broadcast_roll(c.name, "DEX save vs Flaming Sphere", fs_roll, fs_bonus + fs_bless, fs_total, fs_saved ? "Half damage!" : "Full damage!");
					if (!fs_saved and try_arcane_deflection_save(c, fs_dc, fs_total)) fs_saved = true;
					if (!fs_saved) { int fg = try_flash_of_genius(c, fs_dc, fs_total, "DEX save vs Flaming Sphere"); if (fg >= fs_dc) fs_saved = true; }
					if (!fs_saved) { int bf = try_boon_of_fate_bonus(c, fs_total, fs_dc); if (bf >= fs_dc) fs_saved = true; }
					if (!fs_saved and try_stroke_of_luck_save(c, fs_dc, fs_bonus + fs_bless)) fs_saved = true;
					int fs_dmg = 0;
					for (int d = 0; d < fs_dice; d++) fs_dmg += random(1, 6);
					if (fs_saved) fs_dmg /= 2;
					if (fs_dmg < 1) fs_dmg = 1;
					combat.apply_damage(c, fs_dmg, DMG_FIRE, ca_caster);
					broadcast_announce(c.name + " takes " + fs_dmg + " fire damage from " + ca_caster.name + "'s Flaming Sphere!", true);
					if (c.is_dead) break;
				}
			}

			// Blade Barrier (Basic Rules para 12214): DEX save, 6d10 slashing, half on save.
			// "A creature also makes that save if it ends its turn there."
			else if (ca_caster.concentration_spell == "Blade Barrier" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 10) {
					int bb_dc = spell_save_dc(ca_caster, "blade_barrier");
					int bb_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, bb_roll);
					int bb_bonus = c.get_save_bonus(ABILITY_DEX);
					int bb_bless = roll_bless_bonus(c);
					int bb_total = bb_roll + bb_bonus + bb_bless;
					bool bb_saved = bb_total >= bb_dc;
					broadcast_roll(c.name, "DEX save vs Blade Barrier", bb_roll, bb_bonus + bb_bless, bb_total, bb_saved ? "Half damage!" : "Full damage!");
					if (!bb_saved and try_arcane_deflection_save(c, bb_dc, bb_total)) bb_saved = true;
					if (!bb_saved) { int fg = try_flash_of_genius(c, bb_dc, bb_total, "DEX save vs Blade Barrier"); if (fg >= bb_dc) bb_saved = true; }
					if (!bb_saved) { int bf = try_boon_of_fate_bonus(c, bb_total, bb_dc); if (bf >= bb_dc) bb_saved = true; }
					if (!bb_saved and try_stroke_of_luck_save(c, bb_dc, bb_bonus + bb_bless)) bb_saved = true;
					int bb_dmg = 0;
					for (int d = 0; d < 6; d++) bb_dmg += random(1, 10);
					if (bb_saved) bb_dmg /= 2;
					if (bb_dmg < 1) bb_dmg = 1;
					combat.apply_damage(c, bb_dmg, DMG_SLASHING, ca_caster);
					broadcast_announce(c.name + " takes " + bb_dmg + " slashing damage from " + ca_caster.name + "'s Blade Barrier!", true);
					if (c.is_dead) break;
				}
			}

			// Incendiary Cloud (Basic Rules): DEX save, 10d8 fire, half on save.
			// "A creature must also make this save when it ends its turn there."
			else if (ca_caster.concentration_spell == "Incendiary Cloud" and ca_caster.conc_aoe_slot_level > 0) {
				if (feet_distance(ca_caster.conc_aoe_x, ca_caster.conc_aoe_y, c.x, c.y) <= 20) {
					int ic_dc = spell_save_dc(ca_caster, "incendiary_cloud");
					int ic_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, ic_roll);
					int ic_bonus = c.get_save_bonus(ABILITY_DEX);
					int ic_bless = roll_bless_bonus(c);
					int ic_total = ic_roll + ic_bonus + ic_bless;
					bool ic_saved = ic_total >= ic_dc;
					broadcast_roll(c.name, "DEX save vs Incendiary Cloud", ic_roll, ic_bonus + ic_bless, ic_total, ic_saved ? "Half damage!" : "Full damage!");
					if (!ic_saved and try_arcane_deflection_save(c, ic_dc, ic_total)) ic_saved = true;
					if (!ic_saved) { int fg = try_flash_of_genius(c, ic_dc, ic_total, "DEX save vs Incendiary Cloud"); if (fg >= ic_dc) ic_saved = true; }
					if (!ic_saved) { int bf = try_boon_of_fate_bonus(c, ic_total, ic_dc); if (bf >= ic_dc) ic_saved = true; }
					if (!ic_saved and try_stroke_of_luck_save(c, ic_dc, ic_bonus + ic_bless)) ic_saved = true;
					int ic_dmg = 0;
					for (int d = 0; d < 10; d++) ic_dmg += random(1, 8);
					if (ic_saved) ic_dmg /= 2;
					if (ic_dmg < 1) ic_dmg = 1;
					combat.apply_damage(c, ic_dmg, DMG_FIRE, ca_caster);
					broadcast_announce(c.name + " takes " + ic_dmg + " fire damage from " + ca_caster.name + "'s Incendiary Cloud!", true);
					if (c.is_dead) break;
				}
			}

			// Conjure Woodland Beings: caster-centered 10ft emanation, per-turn WIS save
			else if (ca_caster.concentration_spell == "Conjure Woodland Beings" and ca_caster.conjure_woodland_active) {
				if (ca_caster.id != c.id and combat.are_hostile(ca_caster, c) and feet_distance(ca_caster.x, ca_caster.y, c.x, c.y) <= 10) {
					int cwb_dc = spell_save_dc(ca_caster, "conjure_woodland_beings");
					int cwb_dice = 5 + (ca_caster.conjure_woodland_slot_level - 4);
					if (cwb_dice < 5) cwb_dice = 5;
					int cwb_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, cwb_roll);
					int cwb_bonus = c.get_save_bonus(ABILITY_WIS);
					int cwb_bless = roll_bless_bonus(c);
					int cwb_total = cwb_roll + cwb_bonus + cwb_bless;
					bool cwb_saved = cwb_total >= cwb_dc;
					broadcast_roll(c.name, "WIS save vs Conjure Woodland Beings", cwb_roll, cwb_bonus + cwb_bless, cwb_total, cwb_saved ? "Half damage!" : "Full damage!");
					if (!cwb_saved and try_arcane_deflection_save(c, cwb_dc, cwb_total)) cwb_saved = true;
					if (!cwb_saved) { int fg = try_flash_of_genius(c, cwb_dc, cwb_total, "WIS save vs CWB"); if (fg >= cwb_dc) cwb_saved = true; }
					if (!cwb_saved) { int ms = try_maverick_spirit(c, cwb_dc, cwb_total, "WIS save vs CWB"); if (ms >= cwb_dc) cwb_saved = true; }
					if (!cwb_saved and try_mage_slayer_guarded_mind(c, ABILITY_WIS)) cwb_saved = true;
					if (!cwb_saved) { int bf = try_boon_of_fate_bonus(c, cwb_total, cwb_dc); if (bf > 0) cwb_saved = true; }
					if (!cwb_saved and try_stroke_of_luck_save(c, cwb_dc, cwb_bonus + cwb_bless)) cwb_saved = true;
					int cwb_dmg = 0;
					for (int d = 0; d < cwb_dice; d++) cwb_dmg += random(1, 8);
					if (cwb_saved) cwb_dmg /= 2;
					if (cwb_dmg < 1) cwb_dmg = 1;
					combat.apply_damage(c, cwb_dmg, DMG_FORCE, ca_caster);
					broadcast_announce(c.name + " takes " + cwb_dmg + " force damage from " + ca_caster.name + "'s Conjure Woodland Beings!", true);
					if (c.is_dead) break;
				}
			}

			// Moonbeam (Basic Rules): 5ft cylinder, CON save, 2d10+upcast radiant, half on save
			if (ca_caster.moonbeam_active and ca_caster.moonbeam_slot_level > 0) {
				if (feet_distance(ca_caster.moonbeam_x, ca_caster.moonbeam_y, c.x, c.y) <= 5) {
					int mb_dice = 2 + (ca_caster.moonbeam_slot_level - 2);
					if (mb_dice < 2) mb_dice = 2;
					int mb_dc = spell_save_dc(ca_caster, "moonbeam");
					int mb_roll = random(1, 20);
					apply_hound_save_disadvantage(c, ca_caster.id, mb_roll);
					int mb_bonus = c.get_save_bonus(ABILITY_CON);
					int mb_bless = roll_bless_bonus(c);
					int mb_total = mb_roll + mb_bonus + mb_bless;
					bool mb_saved = mb_total >= mb_dc;
					broadcast_roll(c.name, "CON save vs Moonbeam", mb_roll, mb_bonus + mb_bless, mb_total, mb_saved ? "Half damage!" : "Full damage!");
					if (!mb_saved and try_arcane_deflection_save(c, mb_dc, mb_total)) mb_saved = true;
					if (!mb_saved) { int fg = try_flash_of_genius(c, mb_dc, mb_total, "CON save vs Moonbeam"); if (fg >= mb_dc) mb_saved = true; }
					if (!mb_saved) { int bf = try_boon_of_fate_bonus(c, mb_total, mb_dc); if (bf >= mb_dc) mb_saved = true; }
					if (!mb_saved and try_stroke_of_luck_save(c, mb_dc, mb_bonus + mb_bless)) mb_saved = true;
					int mb_dmg = 0;
					for (int d = 0; d < mb_dice; d++) mb_dmg += random(1, 10);
					if (mb_saved) mb_dmg /= 2;
					if (mb_dmg < 1) mb_dmg = 1;
					combat.apply_damage(c, mb_dmg, DMG_RADIANT, ca_caster);
					broadcast_announce(c.name + " takes " + mb_dmg + " radiant damage from " + ca_caster.name + "'s Moonbeam!", true);
					if (c.is_dead) break;
				}
			}

			// Investiture of Flame (Xanathar's para 4992-4993): 1d10 fire to adjacent creatures.
			// "Any creature that moves within 5 feet of you for the first time on a turn or
			// ends its turn there takes 1d10 fire damage." No save — automatic damage.
			if (ca_caster.investiture_flame_active) {
				if (feet_distance(ca_caster.x, ca_caster.y, c.x, c.y) <= 5) {
					int inv_dmg = random(1, 10);
					combat.apply_damage(c, inv_dmg, DMG_FIRE, ca_caster);
					broadcast_announce(c.name + " takes " + inv_dmg + " fire damage from " + ca_caster.name + "'s Investiture of Flame!", true);
					if (c.is_dead) break;
				}
			}
		}

		// Xanathar's Shadow Magic L6 Hound of Ill Omen (para 2596-2602): "At the start
		// of the target's turn, the hound deals psychic damage to that target equal to
		// half your sorcerer level (rounded down)."
		if (c.hound_caster_id > 0 and @combat != null) {
			for (uint hdi = 0; hdi < combat.combatants.length(); hdi++) {
				combatant@ hound = combat.combatants[hdi];
				if (@hound == null or hound.is_dead or !hound.is_alive()) continue;
				if (!hound.is_companion or hound.owner_id != c.hound_caster_id) continue;
				if (hound.companion_subclass != "hound_of_ill_omen") continue;
				// Find the sorcerer owner for level calculation
				combatant@ sorc = combat.get_combatant(hound.owner_id);
				if (@sorc == null or sorc.is_dead) break;
				int hound_psychic = sorc.level / 2;
				if (hound_psychic < 1) hound_psychic = 1;
				combat.apply_damage(c, hound_psychic, DMG_PSYCHIC, sorc);
				broadcast_announce(c.name + " takes " + hound_psychic + " psychic damage from the Hound of Ill Omen!", true);
				check_concentration(c, hound_psychic, sorc);
				if (c.is_dead) {
					broadcast_announce(c.name + " has been slain by the Hound of Ill Omen!", true);
				}
				broadcast_state();
				check_battle_end();
				break;
			}
		}

		// ---- Subclass turn-start effects ----

		// Berserker Frenzy: announce bonus action melee attack available while raging
		if (c.class_name == "Barbarian" and c.subclass == "Berserker" and c.raging and c.has_frenzy) {
			broadcast_announce(c.name + " is in a Frenzy! Bonus action melee attack available.", false);
		}

		// Assassinate: disable after first round
		if (c.subclass == "Assassin" and c.assassinate_available and combat.round_number > 1) {
			c.assassinate_available = false;
		}

		// Xanathar's Scout L13 Ambush Master (para 2399): advantage vs marked target
		// ends "at the start of your next turn" — clear marks set by this Scout.
		if (c.class_name == "Rogue" and c.subclass == "Scout" and c.level >= 13) {
			for (uint ami = 0; ami < combat.combatants.length(); ami++) {
				if (combat.combatants[ami].ambush_master_marked_by == c.id) combat.combatants[ami].ambush_master_marked_by = 0;
			}
		}
		// Xanathar's Zealot L10 Zealous Presence (para 445-447): buff "until the start
		// of your next turn" — clear buffs granted by this Zealot.
		if (c.class_name == "Barbarian" and c.subclass == "Zealot" and c.level >= 10) {
			for (uint zpi = 0; zpi < combat.combatants.length(); zpi++) {
				if (combat.combatants[zpi].zealous_presence_buff_active and combat.combatants[zpi].zealous_presence_source_id == c.id) {
					combat.combatants[zpi].zealous_presence_buff_active = false;
					combat.combatants[zpi].zealous_presence_source_id = 0;
				}
			}
		}
		// Reset first hit tracking for subclass on-hit effects
		c.is_first_hit_this_turn = true;
		// PHB 2024 Rogue L1 Sneak Attack (para 6537): "Once per turn" — reset.
		c.sneak_attack_used_this_turn = false;
		// PHB 2024 Bonus Action Spell rule (para 7986-7989): per-turn tracking.
		c.cast_ba_spell_this_turn = false;
		c.cast_leveled_spell_this_turn = false;
		// Spirit Guardians: once per turn damage tracking
		c.spirit_guardians_damaged_this_turn = false;
		// Arcane Archer Grasping Arrow: once per turn movement damage tracking
		c.arcane_grasping_damaged_this_turn = false;
		// Counterspell readied action expires at start of your next turn
		c.counterspell_pending = false;
		// PHB 2024 Boon of Dimensional Travel Blink Steps (para 7876)
		c.blink_steps_available = false;
		c.blink_steps_used_this_turn = false;
		// PHB 2024 Rogue L3 Steady Aim (para 6550-6551): pending advantage flag clears
		// each new turn — only valid for one attack on the turn it was activated.
		c.steady_aim_pending = false;
		// PHB 2024 Blade Ward (cantrip): resistance expires at the start of the caster's next turn.
		c.blade_ward_active = false;
		// Basic Rules 2024 Shillelagh (para 14966-14974): 1 minute duration countdown.
		if (c.shillelagh_active) {
			c.shillelagh_rounds--;
			if (c.shillelagh_rounds <= 0) {
				c.shillelagh_active = false;
				broadcast_announce(c.name + "'s Shillelagh effect fades.", false);
			}
		}
		// Levitate: levitated creatures cannot move horizontally. Zero out their movement.
		if (c.levitate_active) c.movement_remaining = 0;
		// Reset Shield Master once-per-turn shove
		c.shield_bash_used_this_turn = false;
		// PHB 2024 Weapon Mastery per-turn resets
		c.cleave_used_this_turn = false;
		// Slow mastery: restore speed on targets this combatant slowed
		if (@combat != null) {
			for (uint sl = 0; sl < combat.combatants.length(); sl++) {
				combatant@ sl_t = combat.combatants[sl];
				if (@sl_t != null and sl_t.mastery_slow_applied) {
					sl_t.speed += 10;
					sl_t.mastery_slow_applied = false;
				}
			}
		}
		// PHB 2024 Crusher crit / Slasher crit+hamstring: clear effects this combatant applied
		for (uint cr = 0; cr < combat.combatants.length(); cr++) {
			combatant@ cr_t = combat.combatants[cr];
			if (@cr_t != null and cr_t.crusher_crit_advantage and cr_t.crusher_crit_source_id == c.id) {
				cr_t.crusher_crit_advantage = false;
				cr_t.crusher_crit_source_id = 0;
			}
			// PHB 2024 Slasher crit: clear disadvantage on targets this combatant slashed
			if (@cr_t != null and cr_t.slasher_crit_disadvantage and cr_t.slasher_crit_source_id == c.id) {
				cr_t.slasher_crit_disadvantage = false;
				cr_t.slasher_crit_source_id = 0;
			}
			// PHB 2024 Slasher hamstring: restore speed on targets this combatant hamstrung
			if (@cr_t != null and cr_t.slasher_hamstring_active and cr_t.slasher_hamstring_source_id == c.id) {
				cr_t.speed += 10;
				cr_t.slasher_hamstring_active = false;
				cr_t.slasher_hamstring_source_id = 0;
			}
			// Basic Rules 2024 Telekinesis: restrained expires at start of caster's next turn
			if (@cr_t != null and cr_t.telekinesis_source_id == c.id) {
				cr_t.remove_condition(COND_RESTRAINED);
				cr_t.telekinesis_source_id = 0;
				cr_t.restrained_spell_caster_id = 0;
			}
			// Xanathar's Arcane Archer: clear shot debuffs that expire "at start of your next turn"
			if (@cr_t != null and cr_t.arcane_enfeeble_source == c.id) {
				cr_t.arcane_enfeeble_source = 0;
			}
			if (@cr_t != null and cr_t.arcane_banish_source == c.id) {
				cr_t.remove_condition(COND_INCAPACITATED);
				cr_t.arcane_banish_source = 0;
				broadcast_announce(cr_t.name + " returns from banishment!", false);
			}
		}
		c.mastery_sap_active = false;
		c.mastery_vex_active = false;
		c.mastery_vex_target_id = 0;
		// Eldritch Invocations per-turn resets
		c.eldritch_smite_used_this_turn = false;
		c.lifedrinker_used_this_turn = false;
		// PHB 2024 Cleric L7 Divine Strike (para 3619): "Once on each of your turns" — reset.
		c.divine_strike_used_this_turn = false;
		// PHB 2024 Druid L7 Primal Strike (para 4433): "Once on each of your turns" — reset.
		c.primal_strike_used_this_turn = false;
		// PHB 2024 Druid L5 Wild Resurgence (para 4428): "Once on each of your turns" — reset.
		c.wild_resurgence_slot_to_use_used_this_turn = false;
		// PHB 2024 Fighter L5 Tactical Shift (para 5121-5122): the OA-free movement
		// pool only persists for the turn it was activated. Clear at start of turn.
		c.tactical_shift_feet_remaining = 0;
		// Reset Way of the Prophet Righteous Strike (1/turn)
		c.righteous_strike_used_this_turn = false;
		// Reset Stunning Strike (PHB 2024 Monk L5: "Once per turn")
		c.stunning_strike_available = true;
		// PHB 2024 Monk L3 Deflect Attacks: clear the redirect-available flag (defensive
		// cleanup — gets set mid-attack when reduction zeros the incoming damage, should
		// never persist past the Monk's own turn).
		c.deflect_attacks_reduced_to_zero = false;
		// PHB 2024 Monk L5 Stunning Strike (para 5349): The Stunned condition (and
		// the success-rider speed-halving / advantage tag) lasts "until the start of
		// your next turn". When this monk's turn starts, scan all combatants and clear
		// any lingering Stunning Strike effects sourced from this monk.
		if (c.class_name == "Monk" and c.level >= 5) {
			for (uint ssi = 0; ssi < combat.combatants.length(); ssi++) {
				combatant@ ss_target = combat.combatants[ssi];
				if (@ss_target == null or ss_target.id == c.id) continue;
				if (ss_target.stunning_strike_source_id != c.id) continue;
				if (ss_target.has_condition(COND_STUNNED)) {
					ss_target.remove_condition(COND_STUNNED);
					broadcast_announce(ss_target.name + " is no longer stunned by " + c.name + "'s Stunning Strike.", false);
				}
				if (ss_target.stunning_strike_speed_orig > 0) {
					ss_target.speed = ss_target.stunning_strike_speed_orig;
					ss_target.stunning_strike_speed_orig = 0;
				}
				ss_target.stunning_strike_advantage_pending = false;
				ss_target.stunning_strike_source_id = 0;
			}
		}
		// Tasha's Order Domain Order's Demand: charm expires at end of caster's next turn.
		// Decrement counter for all targets charmed by this combatant; remove at 0.
		for (uint odi = 0; odi < combat.combatants.length(); odi++) {
			combatant@ od_target = combat.combatants[odi];
			if (@od_target == null or od_target.orders_demand_charmed_by != c.id) continue;
			if (od_target.orders_demand_turns_left > 0) od_target.orders_demand_turns_left--;
			if (od_target.orders_demand_turns_left <= 0) {
				od_target.orders_demand_charmed_by = 0;
				if (od_target.has_condition(COND_CHARMED)) {
					od_target.remove_condition(COND_CHARMED);
					broadcast_announce(od_target.name + "'s Order's Demand charm expires.", false);
				}
			}
		}
		// PHB 2024 Monk L18 Superior Defense (para 5372-5373): "At the start of your
		// turn, you can expend 3 Focus Points to bolster yourself against harm for 1
		// minute or until you have the Incapacitated condition. During that time, you
		// have Resistance to all damage except Force damage." Tick down the active
		// duration; ends if Incapacitated or 0 rounds remain.
		if (c.superior_defense_active) {
			if (c.has_condition(COND_INCAPACITATED) or c.is_dead) {
				c.superior_defense_active = false;
				c.superior_defense_rounds_remaining = 0;
				broadcast_announce(c.name + "'s Superior Defense ends.", false);
			} else if (c.superior_defense_rounds_remaining > 0) {
				c.superior_defense_rounds_remaining--;
				if (c.superior_defense_rounds_remaining <= 0) {
					c.superior_defense_active = false;
					broadcast_announce(c.name + "'s Superior Defense fades.", false);
				}
			}
		}
		// Reckless Attack ends at the start of the barbarian's next turn (PHB 2024 para 2785).
		c.reckless_attack_active = false;
		// PHB 2024 Barbarian Brutal Strike per-turn flags reset.
		c.brutal_strike_used_this_turn = false;
		c.brutal_strike_active = false;
		c.brutal_strike_effect = "";
		c.brutal_strike_effect2 = "";
		// Clear Staggering Blow and Hamstring effects that last "until start of your next turn"
		// These were applied TO the target by a Barbarian, so we need to clear them when
		// the Barbarian's turn starts. For simplicity, clear any staggering blow on the
		// target at the start of ANY new turn (conservative).
		c.staggering_blow_active = false;

		// Tasha's Eloquence Bard Unsettling Words: expires at start of Bard's next turn
		// if not consumed by a save (Tasha's para 1711-1714).
		if (c.unsettling_words_pending) {
			c.unsettling_words_pending = false;
			c.unsettling_words_target = 0;
		}
		// PHB 2024 Mobile feat (para 7635): clear per-creature attack tracking.
		c.mobile_attacked_ids.resize(0);
		// Valda's Spire Gunslinger maneuvers (paras 213-216): per-turn use flags reset.
		c.grazing_shot_used_this_turn = false;
		c.maverick_spirit_used_this_turn = false;
		c.rapid_strike_used_this_turn = false;
		// Valda's Spire Gunslinger Blindfire (paras 209-210): "until the end of the current
		// turn." Cleared at start of next turn so the buff doesn't bleed across rounds.
		c.blindfire_active = false;
		// Valda's Spire Gunslinger subclass per-turn use flags reset (paras 240, 265, 442, 446, 462):
		// Eagle Eye (Deadeye L3), Risky Business (High Roller L6), Ricochet (Trick Shot L3),
		// Gun Spinning (Trick Shot L6), Long Arm of the Law (White Hat L10).
		c.eagle_eye_used_this_turn = false;
		c.risky_business_used_this_turn = false;
		c.ricochet_used_this_turn = false;
		c.gun_spinning_used_this_turn = false;
		c.long_arm_used_this_turn = false;
		// Xanathar's War Magic L6 Power Surge (para 2940): once per turn reset.
		c.power_surge_used_this_turn = false;
		// Xanathar's Grave Domain L17 Keeper of Souls (para 802-803): once per round.
		c.keeper_of_souls_used_this_turn = false;
		// PHB 2024 Battle Master maneuver per-turn flags reset
		c.menacing_attack_pending = false;
		c.goading_attack_pending = false;
		c.pushing_attack_pending = false;
		c.disarming_attack_pending = false;
		c.distracting_strike_pending = false;
		c.sweeping_attack_pending = false;
		// Goading Attack expiry: 2-tick counter decremented on goader's turn start
		if (c.class_name == "Fighter" and c.subclass == "Battle Master") {
			for (uint gai = 0; gai < combat.combatants.length(); gai++) {
				combatant@ gt = combat.combatants[gai];
				if (@gt == null or gt.goading_attack_source_id != c.id) continue;
				gt.goading_attack_turns--;
				if (gt.goading_attack_turns <= 0) {
					gt.goading_attack_source_id = 0;
					gt.goading_attack_turns = 0;
				}
			}
		}
		// Xanathar's Scout L17 Sudden Strike per-turn flag reset
		c.sudden_strike_used_this_turn = false;
		// Xanathar's Storm Herald L14 Raging Storm per-turn flag reset
		c.raging_storm_used_this_turn = false;
		// Tasha's Circle of Stars Archer per-turn BA attack reset
		c.starry_form_archer_used_this_turn = false;
		// Xanathar's Storm Herald L10 Shielding Storm (para 428): refresh resistance on allies
		if (c.class_name == "Barbarian" and c.subclass == "Storm Herald" and c.storm_aura_active and c.level >= 10) {
			apply_shielding_storm(c);
		}
		// Xanathar's Swashbuckler L13 Elegant Maneuver per-turn flag reset
		c.elegant_maneuver_active = false;
		// Xanathar's Swashbuckler L9 Panache rounds tickdown on panache source's turn
		if (c.class_name == "Rogue" and c.subclass == "Swashbuckler") {
			for (uint pi = 0; pi < combat.combatants.length(); pi++) {
				combatant@ pt = combat.combatants[pi];
				if (@pt == null or pt.panache_source_id != c.id) continue;
				pt.panache_rounds--;
				if (pt.panache_rounds <= 0) {
					pt.panache_source_id = 0;
					pt.panache_rounds = 0;
				}
			}
		}
		// Xanathar's Ancestral Guardian L3 Ancestral Protectors expiry (para 389):
		// "Until the start of your next turn." Clear marks at start of barbarian's turn.
		if (c.class_name == "Barbarian" and c.subclass == "Ancestral Guardian") {
			for (uint ag = 0; ag < combat.combatants.length(); ag++) {
				if (combat.combatants[ag].ancestral_protector_marked_by == c.id) {
					combat.combatants[ag].ancestral_protector_marked_by = 0;
				}
			}
			c.ancestral_protector_target = 0;
		}
		// Xanathar's Cavalier L3 Unwavering Mark expiry (para 1669): "until the end of
		// your next turn." On the Cavalier's turn start: if flag is false, clear all marks
		// by this Cavalier; if true, set to false (marks persist through this turn).
		if (c.class_name == "Fighter" and c.subclass == "Cavalier") {
			if (!c.cavalier_mark_turn_flag) {
				for (uint um = 0; um < combat.combatants.length(); um++) {
					if (combat.combatants[um].marked_by_cavalier_id == c.id) {
						combat.combatants[um].marked_by_cavalier_id = 0;
					}
				}
			}
			c.cavalier_mark_turn_flag = false;
		}
		// Xanathar's Oath of Conquest L7 Aura of Conquest (para 1992-1995): "If a
		// creature is frightened of you, its speed is reduced to 0 while in the aura,
		// and that creature takes psychic damage equal to half your paladin level if
		// it starts its turn there."
		if (c.has_condition(COND_FRIGHTENED)) {
			for (uint aco = 0; aco < combat.combatants.length(); aco++) {
				combatant@ pal = combat.combatants[aco];
				if (@pal == null or pal.is_dead or !pal.aura_of_conquest_active) continue;
				if (pal.has_condition(COND_INCAPACITATED)) continue;
				if (pal.is_player == c.is_player) continue; // aura only affects enemies
				float adx = float(c.x - pal.x);
				float ady = float(c.y - pal.y);
				float aura_dist = sqrt(adx * adx + ady * ady) * 5.0f;
				if (aura_dist <= float(pal.aura_of_conquest_range)) {
					c.movement_remaining = 0;
					int aura_dmg = pal.level / 2;
					if (aura_dmg < 1) aura_dmg = 1;
					c.current_hp -= aura_dmg;
					broadcast_announce(c.name + " is frozen by " + pal.name + "'s Aura of Conquest — speed 0, " + aura_dmg + " psychic damage!", true);
					if (c.current_hp <= 0) {
						c.current_hp = 0;
						if (c.is_player) {
							c.add_condition(COND_UNCONSCIOUS);
							c.death_save_successes = 0;
							c.death_save_failures = 0;
						} else {
							c.is_dead = true;
						}
					}
					break; // only one aura applies
				}
			}
		}
		// Xanathar's Gloom Stalker L3 Dread Ambusher (para 2153-2154): "At the start
		// of your first turn of each combat, your walking speed increases by 10 feet,
		// which lasts until the end of that turn."
		if (combat.round_number == 1 and c.class_name == "Ranger" and c.subclass == "Gloom Stalker" and c.level >= 3) {
			c.movement_remaining += 10;
			broadcast_announce(c.name + "'s Dread Ambusher grants +10 ft speed this turn!", false);
		}
		// Valda's Spire Gunslinger White Hat L10 Long Arm of the Law (paras 462-463):
		// "The creature can't move on its next turn unless it first takes the Disengage
		// action." If this combatant was hobbled, zero out movement at turn start. The
		// flag is cleared at end of turn (whether they moved or not). Disengage clears
		// the flag earlier in the turn so they can resume moving (handled in the
		// Disengage action handler in users _dom.nvgt).
		if (c.cant_move_until_disengage) {
			c.movement_remaining = 0;
			broadcast_announce(c.name + " is hobbled by Long Arm of the Law and cannot move (must Disengage first).", false);
		}

		// Resilient Sphere duration countdown: at the start of the trapped
		// creature's turn, decrement rounds. When 0, the sphere expires.
		if (c.resilient_sphere_trapped) {
			c.resilient_sphere_rounds--;
			if (c.resilient_sphere_rounds <= 0) {
				c.resilient_sphere_trapped = false;
				c.resilient_sphere_source_id = 0;
				c.resilient_sphere_rounds = 0;
				c.remove_condition(COND_INCAPACITATED);
				broadcast_to_battle({{"type", message_types::condition_removed}, {"target", c.name}, {"condition", "Incapacitated"}});
				broadcast_announce(c.name + "'s Resilient Sphere fades away!", true);
			} else {
				broadcast_announce(c.name + " is still trapped in a Resilient Sphere. (" + c.resilient_sphere_rounds + " round" + (c.resilient_sphere_rounds != 1 ? "s" : "") + " remaining)", false);
			}
		}

		// SRD Monster Regeneration: heal at start of turn (Troll, etc.)
		// Blocked if fire or acid damage was taken since last turn.
		// Trolls at 0 HP who weren't killed by fire/acid also regenerate back.
		if (c.regen_amount > 0 and !c.is_dead) {
			if (c.regen_blocked_this_round) {
				// Regen blocked — if at 0 HP, NOW the troll actually dies
				if (c.current_hp <= 0) {
					c.is_dead = true;
					c.remove_condition(COND_UNCONSCIOUS);
					broadcast_announce(c.name + "'s regeneration was stopped by fire or acid — it dies!", true);
					check_battle_end();
					if (!combat.battle_active) return;
				} else {
					broadcast_announce(c.name + "'s regeneration is blocked this turn!", false);
				}
				c.regen_blocked_this_round = false;
			} else if (c.current_hp >= 0) {
				int heal = c.regen_amount;
				int old_hp = c.current_hp;
				c.current_hp += heal;
				if (c.current_hp > c.max_hp) c.current_hp = c.max_hp;
				int healed = c.current_hp - old_hp;
				if (healed > 0) {
					// If monster was at 0 HP and regenerated, wake it up
					if (old_hp == 0 and c.current_hp > 0) {
						c.remove_condition(COND_UNCONSCIOUS);
						broadcast_announce(c.name + " regenerates " + healed + " HP and gets back up! (" + c.current_hp + "/" + c.max_hp + ")", true);
					} else {
						broadcast_announce(c.name + " regenerates " + healed + " HP! (" + c.current_hp + "/" + c.max_hp + ")", false);
					}
				}
			}
		}

		// SRD Breath Weapon Recharge: roll d6 at start of turn. If >= recharge_min, recharged.
		if (!c.breath_available and c.breath_name != "") {
			int recharge_roll = random(1, 6);
			if (recharge_roll >= c.breath_recharge_min) {
				c.breath_available = true;
				broadcast_announce(c.name + "'s " + c.breath_name + " recharges!", true);
			}
		}

		// Sacred Weapon glow reminder
		if (c.sacred_weapon_active) {
			broadcast_announce(c.name + "'s weapon glows with sacred power. (+" + c.get_ability_mod(ABILITY_CHA) + " to attack rolls)", false);
		}

		// Arcane Ward status
		if (c.class_name == "Wizard" and c.subclass == "Abjurer" and c.arcane_ward_hp > 0) {
			broadcast_announce(c.name + "'s Arcane Ward has " + c.arcane_ward_hp + " of " + c.arcane_ward_max + " HP.", false);
		}

		if (trigger_readied_actions(c)) return;
		announce_turn_start(c);
	}

	// ---- Concentration Check ----

	void check_concentration(combatant@ target, int damage, combatant@ attacker = null) {
		if (@target == null or @combat == null) return;
		if (!target.is_concentrating) return;
		// PHB 2024 Ranger L13 Relentless Hunter (para 6182-6183): "Taking damage
		// can't break your Concentration on Hunter's Mark." Skip the save entirely
		// when the concentrated spell is Hunter's Mark and the caster is L13+ Ranger.
		if (target.class_name == "Ranger" and target.level >= 13 and target.concentration_spell == "Hunter's Mark") return;
		if (target.is_dead or target.current_hp <= 0) {
			// Concentration automatically broken at 0 HP.
			string ended_spell = target.concentration_spell;
			clear_concentration_effects(target);
			target.is_concentrating = false;
			target.remove_condition(COND_CONCENTRATING);
			broadcast_announce(target.name + "'s concentration on " + ended_spell + " is broken!");
			broadcast_to_battle({{"type", message_types::concentration_check}, {"name", target.name}, {"spell", ended_spell}, {"broken", true}});
			target.concentration_spell = "";
			broadcast_state();
			return;
		}

		// DC = max(10, damage / 2).
		int dc = damage / 2;
		if (dc < 10) dc = 10;
		int con_mod = target.get_save_bonus(ABILITY_CON);
		// 2024 Mage Slayer feat: damaging a concentrating creature gives it disadvantage on concentration save
		bool mage_slayer_disadv = (@attacker != null and attacker.has_feat("mage_slayer"));
		// PHB 2024 War Caster (para 7840): "You have Advantage on Constitution saving
		// throws that you make to maintain Concentration."
		bool war_caster_adv = target.has_feat("war_caster");
		// PHB 2024 Sorcerer Metamagic Extended Spell (para 7029): "you have Advantage
		// on any Constitution saving throw you make to maintain Concentration on it."
		// Basic Rules 2024 Eldritch Mind (para 7823-7824): "You have Advantage on
		// Constitution saving throws that you make to maintain Concentration."
		bool conc_adv = war_caster_adv or target.extended_spell_concentration or target.eldritch_mind;

		user@ u = find_user_for_combatant(target);
		if (target.is_player and @u != null and !u.is_bot) {
			// Request CON save from the player.
			pending_roll pr;
			pr.combatant_id = target.id;
			pr.player_username = target.player_username;
			pr.roll_type = ROLL_CONCENTRATION;
			pr.dice_sides = 20;
			pr.modifier = con_mod;
			pr.reason = "Constitution save to maintain concentration on " + target.concentration_spell + " (DC " + dc + ")";
			pr.dc = dc;
			pr.has_disadvantage = mage_slayer_disadv;
			if (conc_adv) pr.has_advantage = true;
			if (mage_slayer_disadv) broadcast_announce(attacker.name + "'s Mage Slayer imposes disadvantage on " + target.name + "'s concentration save!", false);
			if (war_caster_adv) broadcast_announce(target.name + " has advantage on the concentration save from War Caster!", false);
			else if (target.eldritch_mind) broadcast_announce(target.name + " has advantage on the concentration save from Eldritch Mind!", false);
			else if (conc_adv) broadcast_announce(target.name + " has advantage on the concentration save from Extended Spell!", false);
			@current_roll = pr;

			send_roll_request(u, pr);
		} else {
			// Auto-roll for monsters/bots.
			int natural = random(1, 20);
			if (conc_adv and !mage_slayer_disadv) {
				int r2 = random(1, 20);
				if (r2 > natural) natural = r2;
				if (war_caster_adv) broadcast_announce(target.name + " has advantage on the concentration save from War Caster!", false);
				else if (target.eldritch_mind) broadcast_announce(target.name + " has advantage on the concentration save from Eldritch Mind!", false);
				else broadcast_announce(target.name + " has advantage on the concentration save from Extended Spell!", false);
			}
			if (mage_slayer_disadv and !conc_adv) {
				int r2 = random(1, 20);
				if (r2 < natural) natural = r2;
				broadcast_announce(attacker.name + "'s Mage Slayer imposes disadvantage on " + target.name + "'s concentration save!", false);
			}
			int bless_bonus = roll_bless_bonus(target);
			int total = natural + con_mod + bless_bonus;
			bool success = total >= dc;
			string outcome = success ? "Maintains concentration!" : "Concentration broken!";
			if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the concentration save.", false);
			broadcast_roll(target.name, "Constitution save (DC " + dc + ")", natural, con_mod + bless_bonus, total, outcome);

			if (!success) {
				string ended_spell = target.concentration_spell;
				clear_concentration_effects(target);
				target.is_concentrating = false;
				target.remove_condition(COND_CONCENTRATING);
				broadcast_announce(target.name + "'s concentration on " + ended_spell + " is broken!");
				broadcast_to_battle({{"type", message_types::concentration_check}, {"name", target.name}, {"spell", ended_spell}, {"broken", true}});
				target.concentration_spell = "";
			} else {
				broadcast_to_battle({{"type", message_types::concentration_check}, {"name", target.name}, {"spell", target.concentration_spell}, {"broken", false}});
			}
			broadcast_state();
		}
	}

	// ---- Short Rest (between waves) ----

	void apply_short_rest(combatant@ c) {
		if (@c == null or c.is_dead) return;
		// Heal 25% max HP
		int heal_amount = c.max_hp / 4;
		if (heal_amount < 1) heal_amount = 1;
		int old_hp = c.current_hp;
		c.current_hp += heal_amount;
		if (c.current_hp > c.max_hp) c.current_hp = c.max_hp;
		int actual_heal = c.current_hp - old_hp;

		// PHB 2024 Fighter Second Wind: regain 1 use on SR (para 5105)
		if (c.class_name == "Fighter" and c.second_wind_uses_remaining < c.second_wind_uses_max) {
			c.second_wind_uses_remaining++;
			c.second_wind_available = c.second_wind_uses_remaining > 0;
		}
		// PHB 2024 Fighter Action Surge: regain all uses on SR
		if (c.class_name == "Fighter" and c.level >= 2) {
			int max_surge = c.level >= 17 ? 2 : 1;
			c.action_surge_uses_remaining = max_surge;
		}
		// PHB 2024 Warlock Pact Magic: regain all pact slots on SR
		if (c.class_name == "Warlock") {
			for (int si = 0; si < 10; si++) c.spell_slots_current[si] = c.spell_slots_max[si];
			c.magical_cunning_available = true;
		}
		// PHB 2024 Wizard L1 Arcane Recovery: regain 1 charge on SR
		if (c.class_name == "Wizard") {
			c.arcane_recovery_charges = 1;
			// L20 Signature Spells: regain charges + per-spell flags on SR
			if (c.signature_spells_charges_max > 0) {
				c.signature_spells_charges_remaining = c.signature_spells_charges_max;
				c.signature_spell_a_used_this_rest = false;
				c.signature_spell_b_used_this_rest = false;
			}
		}
		// PHB 2024 Druid Wild Shape: regain uses on SR (2 base)
		if (c.class_name == "Druid" and c.wild_shape_uses < 2) {
			c.wild_shape_uses = 2;
		}
		// Xanathar's Arcane Archer: regain all Arcane Shot uses on SR (para 1620)
		if (c.class_name == "Fighter" and c.subclass == "Arcane Archer") {
			c.arcane_shot_uses = 2;
		}
		// Tasha's Rune Knight: rune invocations reset on SR (para 3215)
		if (c.class_name == "Fighter" and c.subclass == "Rune Knight") {
			c.rune_invoke_uses = c.rune_invoke_uses_max;
			c.fire_rune_pending = false;
			c.frost_rune_active = false;
			c.frost_rune_rounds = 0;
			c.hill_rune_active = false;
			c.hill_rune_rounds = 0;
		}
		// War Magic L6 Power Surge: floor at 1 on SR
		if (c.class_name == "Wizard" and c.subclass == "War Magic" and c.power_surge_charges < 1) {
			c.power_surge_charges = 1;
		}
		// Xanathar's Samurai Fighting Spirit: 3 uses restored on SR
		if (c.class_name == "Fighter" and c.subclass == "Samurai") {
			c.fighting_spirit_uses = 3;
		}
		// Xanathar's Cavalier Warding Maneuver: CON mod uses restored on SR
		if (c.class_name == "Fighter" and c.subclass == "Cavalier") {
			int con_mod = c.get_ability_mod(ABILITY_CON);
			if (con_mod < 1) con_mod = 1;
			c.warding_maneuver_uses = con_mod;
			c.unwavering_mark_ba_uses = c.unwavering_mark_ba_uses_max;
		}
		// Battle Master superiority dice: regain all on SR
		if (c.class_name == "Fighter" and c.subclass == "Battle Master") {
			c.superiority_dice = c.superiority_dice_max;
		}
		// Gunslinger Risk Dice: regain all on SR
		if (c.class_name == "Gunslinger") {
			c.risk_dice_current = c.risk_dice_max;
		}
		// Bard Bardic Inspiration: regain uses on SR via Font of Inspiration (L5+)
		if (c.class_name == "Bard" and c.level >= 5) {
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			if (cha_mod < 1) cha_mod = 1;
			c.bardic_inspiration_uses = cha_mod;
		}
		// Monk Focus Points: regain all on SR (PHB 2024 para 5322)
		if (c.class_name == "Monk") {
			c.focus_points = c.focus_points_max;
		}
		// Cleric Channel Divinity: 1 use regained on SR (PHB 2024)
		if (c.class_name == "Cleric" or c.class_name == "Paladin") {
			int cd_max = 1;
			if (c.class_name == "Cleric" and c.level >= 6) cd_max = 2;
			if (c.class_name == "Cleric" and c.level >= 18) cd_max = 3;
			if (c.channel_divinity_uses < cd_max) c.channel_divinity_uses++;
		}
		// PHB 2024 Sorcerer L5 Sorcerous Restoration (para 7002-7003):
		// "You regain expended Sorcery Points whenever you finish a Short Rest.
		// The number of Sorcery Points you regain equals half your Sorcerer level (round down)."
		if (c.class_name == "Sorcerer" and c.level >= 5 and c.sorcerous_restoration_available) {
			int sp_regain = c.level / 2;
			c.sorcery_points += sp_regain;
			if (c.sorcery_points > c.sorcery_points_max) c.sorcery_points = c.sorcery_points_max;
			c.sorcerous_restoration_available = false;
			broadcast_announce(c.name + " regains " + sp_regain + " Sorcery Points via Sorcerous Restoration.", false);
		}
		// Artificer L20 Soul of Artifice — Magical Guidance: regain ALL Flash of Genius on SR
		if (c.class_name == "Artificer" and c.magical_guidance_active) {
			c.flash_of_genius_uses_current = c.flash_of_genius_uses_max;
		}
		// Artificer L14 Advanced Artifice: regain 1 Flash of Genius use on SR
		else if (c.class_name == "Artificer" and c.refreshed_genius_active and c.flash_of_genius_uses_current < c.flash_of_genius_uses_max) {
			c.flash_of_genius_uses_current++;
		}
		// PHB 2024 Ranger L10 Tireless (para 6178-6180): "Whenever you finish a
		// Short Rest, your Exhaustion level, if any, decreases by 1."
		if (c.class_name == "Ranger" and c.level >= 10 and c.exhaustion_level > 0) {
			c.exhaustion_level--;
			broadcast_announce(c.name + "'s Tireless reduces exhaustion to level " + c.exhaustion_level + ".", false);
		}
		// Rogue L20 Stroke of Luck: reset on SR
		c.stroke_of_luck_available = (c.class_name == "Rogue" and c.level >= 20);
		// Hexblade Curse: 1/SR (Xanathar's para 2779-2784)
		c.hexblade_curse_used = false;
		// Swashbuckler L17 Master Duelist: 1/SR reroll
		c.master_duelist_used = false;
		// Divine Soul L1 Favored by the Gods: 1/SR (Xanathar's para 2547-2548)
		c.favored_by_gods_available = (c.class_name == "Sorcerer" and c.subclass == "Divine Soul");
		// Gunslinger L13 Cheat Death: 1/SR
		c.cheat_death_used = false;
		// Gunslinger L20 Headshot: 1/SR
		c.headshot_used = false;
		// Monster Slayer L11 Magic User's Nemesis: 1/SR
		c.magic_users_nemesis_used = false;
		// Mage Slayer Guarded Mind: 1/SR (PHB 2024 para 7693)
		c.mage_slayer_guarded_mind_used = false;
		// Boon of Fate: 1/SR (PHB 2024 para 7877)
		c.boon_of_fate_used = false;
		// Ebon Tides / Grim Hollow subclass 1/SR features
		c.shadow_martyr_used = false;
		c.exit_strategy_used = false;
		c.pinball_shot_used = false;
		c.night_music_used = false;
		c.sickening_revenge_used = false;
		c.touch_of_sorrow_used = false;
		c.darkness_falls_used = false;
		c.duty_over_death_used = false;
		c.consume_darkness_used = false;
		c.umbral_shadow_grasp_used = false;
		c.bend_reality_used = false;

		// Clear conditions and concentration
		c.remove_condition(COND_FRIGHTENED);
		c.remove_condition(COND_CHARMED);
		c.remove_condition(COND_POISONED);
		// Call clear_concentration_effects BEFORE clearing state to properly
		// remove per-target spell flags (heat_metal_disadv, greater_invisibility,
		// bestow_curse, enlarge, shield_of_faith, beacon_of_hope, etc.)
		if (c.is_concentrating) {
			clear_concentration_effects(c);
			c.remove_condition(COND_CONCENTRATING);
		}
		c.is_concentrating = false;
		c.concentration_spell = "";

		if (actual_heal > 0) {
			broadcast_announce(c.name + " rests and recovers " + actual_heal + " HP. (" + c.current_hp + "/" + c.max_hp + ")", false);
		}
	}

	void apply_short_rest_all_players() {
		broadcast_announce("Short rest! Players recover resources between waves.", true);
		for (uint i = 0; i < combat.combatants.length(); i++) {
			if (combat.combatants[i].is_player) {
				apply_short_rest(combat.combatants[i]);
			}
		}
		// Inspiring Leader: re-grant temp HP after short rest (PHB para 7649)
		for (uint il = 0; il < combat.combatants.length(); il++) {
			combatant@ leader = combat.combatants[il];
			if (@leader == null or leader.is_dead or !leader.is_player) continue;
			if (leader.inspiring_leader_temp_hp_pool <= 0) continue;
			int granted = 0;
			for (uint tg = 0; tg < combat.combatants.length() and granted < 6; tg++) {
				combatant@ ally = combat.combatants[tg];
				if (@ally == null or ally.is_dead) continue;
				if (ally.is_player != leader.is_player) continue;
				if (feet_distance(leader.x, leader.y, ally.x, ally.y) > 30) continue;
				if (ally.temp_hp < leader.inspiring_leader_temp_hp_pool) ally.temp_hp = leader.inspiring_leader_temp_hp_pool;
				granted++;
			}
			if (granted > 0) {
				broadcast_announce(leader.name + "'s Inspiring Leader grants " + leader.inspiring_leader_temp_hp_pool + " temporary HP to " + granted + " allies after rest.", false);
			}
		}
		// PHB 2024 Musician Origin feat: "As you finish a Short or Long Rest, you
		// can play a song... Choose a number of creatures equal to your Proficiency
		// Bonus + your Charisma modifier (minimum of one creature). Those creatures
		// each gain Heroic Inspiration."
		for (uint mu = 0; mu < combat.combatants.length(); mu++) {
			combatant@ musician = combat.combatants[mu];
			if (@musician == null or musician.is_dead or !musician.is_player) continue;
			if (!musician.has_feat("musician")) continue;
			int cha_mod = musician.get_ability_mod(ABILITY_CHA);
			int max_targets = musician.proficiency + cha_mod;
			if (max_targets < 1) max_targets = 1;
			int granted_hi = 0;
			for (uint mg = 0; mg < combat.combatants.length() and granted_hi < max_targets; mg++) {
				combatant@ ally = combat.combatants[mg];
				if (@ally == null or ally.is_dead) continue;
				if (ally.is_player != musician.is_player) continue;
				if (feet_distance(musician.x, musician.y, ally.x, ally.y) > 30) continue;
				if (!ally.has_heroic_inspiration) {
					ally.has_heroic_inspiration = true;
					granted_hi++;
				}
			}
			if (granted_hi > 0) {
				broadcast_announce(musician.name + "'s Musician performance grants Heroic Inspiration to " + granted_hi + " allies!", false);
			}
		}
		// PHB 2024 Chef feat (para 7568): "As part of a Short Rest, you can cook
		// special food... any creature who eats the food regains an extra 1d8 HP."
		for (uint ch = 0; ch < combat.combatants.length(); ch++) {
			combatant@ chef = combat.combatants[ch];
			if (@chef == null or chef.is_dead or !chef.is_player) continue;
			if (!chef.has_feat("chef")) continue;
			int max_servings = 4 + chef.proficiency;
			int fed = 0;
			for (uint cg = 0; cg < combat.combatants.length() and fed < max_servings; cg++) {
				combatant@ ally = combat.combatants[cg];
				if (@ally == null or ally.is_dead) continue;
				if (ally.is_player != chef.is_player) continue;
				if (ally.current_hp < ally.max_hp) {
					int chef_heal = random(1, 8);
					ally.current_hp += chef_heal;
					if (ally.current_hp > ally.max_hp) ally.current_hp = ally.max_hp;
					fed++;
				}
			}
			if (fed > 0) {
				broadcast_announce(chef.name + "'s Chef cooking restores extra HP to " + fed + " allies!", false);
			}
		}
		broadcast_state();
	}

	// ---- Battle End Detection ----

	void check_battle_end() {
		if (@combat == null or !combat.battle_active) return;
		if (!combat.check_battle_over()) return;

		if (combat.mode == "pvp") {
			// PvP: find the last player standing.
			string winner = "Nobody";
			for (uint i = 0; i < combat.combatants.length(); i++) {
				if (combat.combatants[i].is_alive() and combat.combatants[i].is_player) {
					winner = combat.combatants[i].name;
					break;
				}
			}
			combat.battle_active = false;
			broadcast_announce("Battle is over! " + winner + " is victorious!", true);
			// Award PvP challenge progress to the winner
			if (winner != "Nobody") {
				for (uint pi = 0; pi < players.length(); pi++) {
					if (@players[pi] != null and !players[pi].is_bot and @players[pi].account != null and players[pi].username == winner) {
						update_challenge_progress(players[pi].account, "pvp", 1);
						string[] challenge_results = check_challenge_completion(players[pi].account);
						for (uint ci = 0; ci < challenge_results.length(); ci++) {
							string[] parts = challenge_results[ci].split("|");
							if (parts.length() >= 2) {
								players[pi].send({
									{"type", message_types::challenge_complete},
									{"description", parts[0]},
									{"glory", parse_int(parts[1])}
								});
							}
						}
						if (challenge_results.length() > 0) {
							players[pi].account.commit();
							players[pi].send({{"type", message_types::glory_update}, {"glory", get_glory(players[pi].account)}});
						}
						break;
					}
				}
			}
			broadcast_to_battle({{"type", message_types::game_end_battle}, {"winner", winner}, {"mode", "pvp"}});
			broadcast_state();
			cleanup_after_battle();
		} else if (combat.mode == "endless") {
			// Endless Survival mode
			bool any_player_alive = false;
			for (uint i = 0; i < combat.combatants.length(); i++) {
				if (combat.combatants[i].is_player and combat.combatants[i].is_alive()) {
					any_player_alive = true;
					break;
				}
			}
			if (!any_player_alive) {
				// Total party kill - end the endless run
				combat.battle_active = false;
				broadcast_announce("All players have fallen on wave " + combat.wave_number + "! Defeat!", true);
				finalize_adventure_progress("defeat");
				broadcast_to_battle({{"type", message_types::game_end_battle}, {"winner", "monsters"}, {"mode", "endless"}, {"result", "defeat"}, {"final_wave", combat.wave_number}});
				// Update best wave for each player
				for (uint pi = 0; pi < players.length(); pi++) {
					if (@players[pi] != null and !players[pi].is_bot and @players[pi].account != null) {
						update_endless_best_wave(players[pi].account, combat.wave_number);
					}
				}
				broadcast_state();
				cleanup_after_battle();
				return;
			}
			// Check if all monsters are dead
			bool any_monster_alive = false;
			for (uint i = 0; i < combat.combatants.length(); i++) {
				if (!combat.combatants[i].is_player and combat.combatants[i].is_alive()) {
					any_monster_alive = true;
					break;
				}
			}
			if (!any_monster_alive) {
				// Wave complete in endless mode - heal, increment, spawn next
				broadcast_announce("Endless wave " + combat.wave_number + " complete!", true);
				waves_cleared_this_run++;
				broadcast_to_battle({{"type", message_types::wave_complete}, {"wave", combat.wave_number}});

				// Heal all alive players 25% of max HP
				for (uint i = 0; i < combat.combatants.length(); i++) {
					combatant@ c = combat.combatants[i];
					if (@c != null and c.is_player and c.is_alive()) {
						int heal_amount = c.max_hp / 4;
						c.current_hp += heal_amount;
						if (c.current_hp > c.max_hp) c.current_hp = c.max_hp;
					}
				}

				// Award XP per player: wave_number * 15
				int wave_xp = combat.wave_number * 15;
				for (uint pi = 0; pi < players.length(); pi++) {
					if (@players[pi] != null and !players[pi].is_bot and @players[pi].account != null and progression_enabled) {
						int lvls = 0;
						apply_adventure_xp(players[pi].account, wave_xp, lvls);
						if (lvls > 0) {
							send_private_announce(players[pi], "You gained " + wave_xp + " XP and leveled up!", false);
						}
					}
				}

				// Short rest between endless waves — heal + restore SR resources
				apply_short_rest_all_players();

				// Increment wave
				combat.wave_number++;

				// Remove dead monsters from combatants
				for (int ri = int(combat.combatants.length()) - 1; ri >= 0; ri--) {
					if (!combat.combatants[ri].is_player) combat.combatants.remove_at(ri);
				}

				// Calculate HP multiplier for waves beyond 16
				float hp_mult = combat.wave_number > 16 ? 1.0 + (combat.wave_number - 16) * 0.1 : 1.0;

				// Generate and spawn next wave
				wave_encounter@ next = generate_endless_wave(combat.wave_number);
				float total_hp_mult = hp_mult * difficulty_hp_mult;
				spawn_wave(combat, next, combat.map_width, total_hp_mult, difficulty_dmg_mult);
				spawn_swarming_extra(next, total_hp_mult);

				// Apply armored_foes/champions_trial to newly spawned monsters
				if (active_modifier == "armored_foes" or active_modifier == "champions_trial") {
					for (uint nmi = 0; nmi < combat.combatants.length(); nmi++) {
						if (!combat.combatants[nmi].is_player and combat.combatants[nmi].is_alive()) {
							if (active_modifier == "armored_foes") combat.combatants[nmi].armor_class += 3;
							if (active_modifier == "champions_trial") {
								combat.combatants[nmi].max_hp = int(float(combat.combatants[nmi].max_hp) * 1.25);
								combat.combatants[nmi].current_hp = combat.combatants[nmi].max_hp;
							}
						}
					}
				}

				broadcast_to_battle({{"type", message_types::endless_wave_start}, {"wave", combat.wave_number}});
				broadcast_announce("Endless wave " + combat.wave_number + "!", true);

				// Re-roll initiative with new monsters
				combat.start_initiative();
				initiative_phase = true;
				initiative_index = 0;
				request_next_initiative();
				broadcast_state();
				return; // Don't end battle
			}
		} else if (combat.mode == "wave" or combat.mode == "boss") {
			// Check if all players are dead.
			bool any_player_alive = false;
			for (uint i = 0; i < combat.combatants.length(); i++) {
				if (combat.combatants[i].is_player and combat.combatants[i].is_alive()) {
					any_player_alive = true;
					break;
				}
			}
			if (!any_player_alive) {
				// Total party kill.
				combat.battle_active = false;
				broadcast_announce("All players have fallen! Defeat!", true);
				finalize_adventure_progress("defeat");
				broadcast_to_battle({{"type", message_types::game_end_battle}, {"winner", "monsters"}, {"mode", combat.mode}, {"result", "defeat"}});
				broadcast_state();
				cleanup_after_battle();
				return;
			}

			// All monsters dead = wave complete.
			bool any_monster_alive = false;
			for (uint i = 0; i < combat.combatants.length(); i++) {
				if (!combat.combatants[i].is_player and combat.combatants[i].is_alive()) {
					any_monster_alive = true;
					break;
				}
			}
			if (!any_monster_alive) {
				if (combat.mode == "boss") {
					string boss_name = "The boss";
					monster_def@ boss_def = get_monster_def(scenario_id);
					if (@boss_def != null) boss_name = boss_def.name;
					combat.battle_active = false;
					broadcast_announce(boss_name + " is defeated! Victory!", true);
					finalize_adventure_progress("victory");
					broadcast_to_battle({{"type", message_types::game_end_battle}, {"winner", "players"}, {"mode", combat.mode}, {"result", "victory"}});
					broadcast_state();
					cleanup_after_battle();
					return;
				}

				broadcast_announce("Wave " + combat.wave_number + " complete!", true);
				waves_cleared_this_run++;
				broadcast_to_battle({{"type", message_types::wave_complete}, {"wave", combat.wave_number}});
				broadcast_state();

				if (combat.mode == "wave") {
					wave_scenario@ ws = get_scenario(scenario_id);
					if (@ws != null and combat.wave_number < int(ws.waves.length())) {
						// Short rest between waves — heal + restore SR resources
						apply_short_rest_all_players();
						// Remove dead monsters from combatants
						for (int ri = int(combat.combatants.length()) - 1; ri >= 0; ri--) {
							if (!combat.combatants[ri].is_player) combat.combatants.remove_at(ri);
						}
						// Spawn next wave
						spawn_wave(combat, ws.waves[combat.wave_number], combat.map_width, difficulty_hp_mult, difficulty_dmg_mult);
						spawn_swarming_extra(ws.waves[combat.wave_number]);
						// Apply modifiers to newly spawned monsters
						if (active_modifier == "armored_foes" or active_modifier == "champions_trial") {
							for (uint nmi = 0; nmi < combat.combatants.length(); nmi++) {
								if (!combat.combatants[nmi].is_player and combat.combatants[nmi].is_alive()) {
									if (active_modifier == "armored_foes") combat.combatants[nmi].armor_class += 3;
									if (active_modifier == "champions_trial") {
										combat.combatants[nmi].max_hp = int(float(combat.combatants[nmi].max_hp) * 1.25);
										combat.combatants[nmi].current_hp = combat.combatants[nmi].max_hp;
									}
								}
							}
						}
						combat.wave_number++;
						broadcast_to_battle({{"type", message_types::wave_start}, {"wave", combat.wave_number}});
						broadcast_announce("Wave " + combat.wave_number + "!", true);
						// Re-roll initiative with new monsters
						combat.start_initiative();
						initiative_phase = true;
						initiative_index = 0;
						request_next_initiative();
						return; // Don't end battle
					}
				}

				// No more waves or not wave mode — victory
				broadcast_announce("Victory! All waves cleared!", true);
				combat.battle_active = false;
				finalize_adventure_progress("victory");
				broadcast_to_battle({{"type", message_types::game_end_battle}, {"winner", "players"}, {"mode", combat.mode}, {"result", "victory"}});
				broadcast_state();
				cleanup_after_battle();
			}
		}
	}

	// ---- Sentinel Guardian Reaction Attack ----

	// PHB 2024 Sentinel Guardian (para 7718-7720): "Immediately after a creature
	// within 5 feet of you takes the Attack action against a target other than you
	// (you don't need to see the attacker), you can make an Opportunity Attack
	// against the attacker."
	void check_sentinel_guardian(combatant@ attacker, combatant@ target) {
		if (@attacker == null or @target == null or @combat == null) return;
		if (attacker.is_dead) return;
		for (uint si = 0; si < combat.combatants.length(); si++) {
			combatant@ sentinel = combat.combatants[si];
			if (@sentinel == null or sentinel.is_dead or !sentinel.is_alive()) continue;
			if (!sentinel.is_conscious() or sentinel.is_incapacitated_check()) continue;
			if (sentinel.id == attacker.id) continue;
			if (sentinel.id == target.id) continue;
			if (!sentinel.has_feat("sentinel")) continue;
			if (!sentinel.has_reaction) continue;
			if (sentinel.main_hand_is_ranged) continue;
			if (!combat.are_hostile(sentinel, attacker)) continue;
			if (feet_distance(sentinel.x, sentinel.y, attacker.x, attacker.y) > 5) continue;
			// Source: "you don't need to see the attacker" — no LoS check.
			sentinel.has_reaction = false;
			int atk_bonus = get_attack_bonus_for_roll(sentinel, false);
			bool adv = false;
			bool disadv = false;
			apply_attack_advantage_state(sentinel, attacker, feet_distance(sentinel.x, sentinel.y, attacker.x, attacker.y), false, adv, disadv);
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int natural = roll1;
			if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
			else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
			bool is_crit = (natural == 20);
			bool is_fumble = (natural == 1);
			int total = natural + atk_bonus;
			bool hit = false;
			string outcome = "";
			if (is_crit) { hit = true; outcome = "Critical hit!"; }
			else if (is_fumble) { hit = false; outcome = "Miss!"; }
			else {
				hit = total >= attacker.armor_class;
				outcome = hit ? "Hit!" : "Miss!";
			}
			broadcast_announce(sentinel.name + "'s Sentinel — reaction attack against " + attacker.name + " for attacking " + target.name + "!", true);
			broadcast_roll(sentinel.name, "Sentinel attack", natural, atk_bonus, total, outcome);
			if (hit) {
				int dmg_mod = get_damage_modifier_for_attack(sentinel, false);
				pending_roll dmg_pr;
				dmg_pr.attack_name = sentinel.main_hand;
				int base_count = get_attack_damage_count(sentinel, false);
				dmg_pr.damage_dice_count = is_crit ? base_count * 2 : base_count;
				dmg_pr.damage_dice_sides = get_attack_damage_dice(sentinel, false);
				int dmg_natural = roll_attack_damage_natural(sentinel, dmg_pr);
				int total_damage = dmg_natural + dmg_mod;
				if (total_damage < 1) total_damage = 1;
				string dmg_type_name = "damage";
				if (sentinel.main_hand_damage_type >= 0 and sentinel.main_hand_damage_type < int(DAMAGE_TYPE_NAMES.length())) {
					dmg_type_name = DAMAGE_TYPE_NAMES[sentinel.main_hand_damage_type] + " damage";
				}
				broadcast_roll(sentinel.name, "Sentinel damage", dmg_natural, dmg_mod, total_damage, total_damage + " " + dmg_type_name + " to " + attacker.name + ".");
				combat.apply_damage(attacker, total_damage, sentinel.main_hand_damage_type, sentinel);
				// Sentinel Halt: OA hit sets speed to 0
				attacker.movement_remaining = 0;
				broadcast_announce(sentinel.name + "'s Sentinel stops " + attacker.name + " in their tracks!", false);
				maybe_apply_on_kill_features(sentinel, attacker);
				check_concentration(attacker, total_damage, sentinel);
				if (attacker.is_dead) {
					broadcast_announce(attacker.name + " has been slain by " + sentinel.name + "'s Sentinel!", true);
					broadcast_to_battle({{"type", message_types::creature_died}, {"name", attacker.name}, {"id", attacker.id}, {"killed_by", sentinel.name}, {"was_full_hp", false}, {"was_overkill", total_damage >= attacker.max_hp * 2}, {"was_stealth", false}});
				} else {
					broadcast_announce(attacker.name + " has " + attacker.current_hp + " of " + attacker.max_hp + " HP remaining.");
				}
				broadcast_state();
				check_battle_end();
			}
			break; // Only one Sentinel reaction per trigger
		}
	}

	// ---- Opportunity Attacks ----

	void check_opportunity_attacks(combatant@ mover, int old_x, int old_y, int new_x, int new_y) {
		if (@mover == null or @combat == null) return;
		// Disengage prevents opportunity attacks.
		if (mover.took_disengage) return;
		// PHB 2024 Fighter L5 Tactical Shift (para 5121-5122): "Whenever you
		// activate your Second Wind with a Bonus Action, you can move up to half
		// your Speed without provoking Opportunity Attacks." Greedy: consume the
		// shift pool first; once it's empty, normal OA rules apply again.
		if (mover.tactical_shift_feet_remaining > 0) {
			int step_feet = feet_distance(old_x, old_y, new_x, new_y);
			if (mover.tactical_shift_feet_remaining >= step_feet) {
				mover.tactical_shift_feet_remaining -= step_feet;
				return;
			}
		}

		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ enemy = combat.combatants[i];
			if (@enemy == null or enemy.is_dead or !enemy.is_alive()) continue;
			if (!enemy.is_conscious() or enemy.is_incapacitated_check()) continue;
			// Cannot make opportunity attack against yourself.
			if (enemy.id == mover.id) continue;
			// Must be on the opposite side (in PvP, all players are enemies to each other).
			if (!combat.are_hostile(enemy, mover)) continue;
			// Must have reaction available.
			if (!enemy.has_reaction) continue;
			// Must have been in melee range before the move (5ft = adjacent tile).
			int old_dist = feet_distance(old_x, old_y, enemy.x, enemy.y);
			int new_dist = feet_distance(new_x, new_y, enemy.x, enemy.y);
			int reach = enemy.main_hand_range;
			if (reach < 5) reach = 5;
			// Opportunity attack triggers when leaving reach OR entering reach (Polearm Master)
			// OR moving within reach (Cavalier Hold the Line).
			// PHB 2024 Polearm Master (para 7714): "Other creatures provoke Opportunity
			// Attacks from you when they enter your reach."
			// Xanathar's Cavalier L10 Hold the Line (para 1677-1678): "Creatures provoke
			// an opportunity attack from you when they move 5 feet or more while within
			// your reach." On hit: target's speed becomes 0 for the rest of the turn.
			bool leaving_reach = (old_dist <= reach and new_dist > reach);
			bool entering_reach = (old_dist > reach and new_dist <= reach and enemy.has_feat("polearm_master") and !enemy.main_hand_is_ranged);
			bool moving_in_reach = (old_dist <= reach and new_dist <= reach and enemy.hold_the_line_active);
			if (leaving_reach or entering_reach or moving_in_reach) {
				if (enemy.main_hand_is_ranged) continue;
				// Swashbuckler Rogue: Fancy Footwork — enemies attacked by Swashbuckler can't make OA
				if (mover.class_name == "Rogue" and mover.subclass == "Swashbuckler" and enemy.swashbuckler_attacked_this_turn) continue;
				// Xanathar's Swashbuckler L9 Panache (para 2423-2426): panached creature
				// "can't make opportunity attacks against targets other than you."
				if (enemy.panache_source_id != 0 and enemy.panache_rounds > 0 and mover.id != enemy.panache_source_id) continue;
				// PHB 2024 Mobile feat (para 7635): "When you make a melee attack against
				// a creature, you don't provoke Opportunity Attacks from that creature for
				// the rest of the turn, whether you hit or not."
				if (mover.has_feat("mobile")) {
					bool attacked_this_enemy = false;
					for (uint mi = 0; mi < mover.mobile_attacked_ids.length(); mi++) {
						if (mover.mobile_attacked_ids[mi] == enemy.id) { attacked_this_enemy = true; break; }
					}
					if (attacked_this_enemy) continue;
				}
				enemy.has_reaction = false;
				broadcast_announce(enemy.name + " makes an opportunity attack against " + mover.name + "!");
				// Calculate attack bonus.
			int atk_bonus = get_attack_bonus_for_roll(enemy, false);
			bool adv = false;
			bool disadv = false;
			apply_attack_advantage_state(enemy, mover, old_dist, false, adv, disadv);
			reveal_hidden_combatant(enemy, "making an opportunity attack");

				if (!enemy.is_player) {
					// Monster: auto-resolve the opportunity attack immediately.
					int roll1 = random(1, 20);
					int roll2 = random(1, 20);
					int natural = roll1;
					if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
					else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
					bool is_crit = (natural == 20);
					bool is_fumble = (natural == 1);
					int total = natural + atk_bonus;
					bool hit = false;
					string outcome = "";

					if (is_crit) { hit = true; outcome = "Critical hit!"; }
					else if (is_fumble) { hit = false; outcome = "Miss!"; }
					else {
						hit = total >= mover.armor_class;
						outcome = hit ? "Hit!" : "Miss! Needed " + mover.armor_class + ".";
					}

					broadcast_roll(enemy.name, "opportunity attack against " + mover.name, natural, atk_bonus, total, outcome);
					broadcast_to_battle({{"type", message_types::reaction_opportunity}, {"attacker_id", enemy.id}, {"target_id", mover.id}, {"hit", hit}});

					if (hit) {
						// Roll damage.
						int dmg_mod = get_damage_modifier_for_attack(enemy, false);
						pending_roll dmg_pr;
						dmg_pr.attack_name = enemy.main_hand;
						int base_damage_count = get_attack_damage_count(enemy, false);
						dmg_pr.damage_dice_count = is_crit ? base_damage_count * 2 : base_damage_count;
						dmg_pr.damage_dice_sides = get_attack_damage_dice(enemy, false);
						int dmg_natural = roll_attack_damage_natural(enemy, dmg_pr);
						int total_damage = dmg_natural + dmg_mod;
						if (total_damage < 1) total_damage = 1;

						string dmg_type_name = "damage";
						if (enemy.main_hand_damage_type >= 0 and enemy.main_hand_damage_type < int(DAMAGE_TYPE_NAMES.length())) {
							dmg_type_name = DAMAGE_TYPE_NAMES[enemy.main_hand_damage_type] + " damage";
						}

						broadcast_roll(enemy.name, "opportunity attack damage", dmg_natural, dmg_mod, total_damage, total_damage + " " + dmg_type_name + " to " + mover.name + ".");
						bool opp_target_was_full = (mover.current_hp == mover.max_hp);
						combat.apply_damage(mover, total_damage, enemy.main_hand_damage_type, enemy);
						// Feat: Sentinel — opportunity attacks reduce target speed to 0
						if (enemy.has_feat("sentinel")) {
							mover.movement_remaining = 0;
							broadcast_announce(enemy.name + "'s Sentinel stops " + mover.name + " in their tracks!", false);
						}
						// Xanathar's Cavalier L10 Hold the Line (para 1677-1678):
						// "the creature's speed becomes 0 until the end of the current turn."
						if (enemy.hold_the_line_active) {
							mover.movement_remaining = 0;
							if (!enemy.has_feat("sentinel")) // Avoid double announce
								broadcast_announce(enemy.name + " holds the line! " + mover.name + "'s speed drops to 0!", false);
						}
						maybe_apply_on_kill_features(enemy, mover);
						check_concentration(mover, total_damage, enemy);

						if (mover.is_dead) {
							broadcast_announce(mover.name + " has been slain!", true);
							broadcast_to_battle({{"type", message_types::creature_died}, {"name", mover.name}, {"id", mover.id}, {"killed_by", enemy.name}, {"was_full_hp", opp_target_was_full}, {"was_overkill", total_damage >= mover.max_hp * 2}, {"was_stealth", false}});
						} else if (mover.current_hp == 0 and mover.has_condition(COND_UNCONSCIOUS)) {
							broadcast_announce(mover.name + " falls unconscious!", true);
						} else {
							broadcast_announce(mover.name + " has " + mover.current_hp + " of " + mover.max_hp + " HP remaining.");
						}
						broadcast_state();
						check_battle_end();
					}
				} else {
					// Player: request the opportunity attack roll from the player.
					user@ opp_user = find_user_for_combatant(enemy);
					if (@opp_user != null) {
						pending_roll pr;
						pr.combatant_id = enemy.id;
						pr.player_username = enemy.player_username;
						pr.roll_type = ROLL_ATTACK;
						pr.dice_sides = 20;
						pr.modifier = atk_bonus;
						pr.reason = "opportunity attack against " + mover.name;
						pr.target_id = mover.id;
						pr.has_advantage = adv;
						pr.has_disadvantage = disadv;
						pr.attack_name = enemy.main_hand;
						pr.damage_dice_count = get_attack_damage_count(enemy, false);
						pr.damage_dice_sides = get_attack_damage_dice(enemy, false);
						pr.damage_modifier = get_damage_modifier_for_attack(enemy, false);
						pr.damage_type = enemy.main_hand_damage_type;
						pr.is_weapon_attack = true;
						pr.resolution_tag = "resume_current_turn";
						@current_roll = pr;
						if (opp_user.is_bot) {
							int roll1 = random(1, 20);
							int roll2 = random(1, 20);
							int natural = roll1;
							if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
							else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
							broadcast_to_battle({{"type", message_types::reaction_opportunity}, {"attacker_id", enemy.id}, {"target_id", mover.id}});
							process_roll_result(natural);
						} else {
							send_roll_request(opp_user, pr);
							broadcast_to_battle({{"type", message_types::reaction_opportunity}, {"attacker_id", enemy.id}, {"target_id", mover.id}});
							// Only one opportunity attack per move step; return to let roll resolve.
							return;
						}
					}
				}
			}
		}
	}

	// ---- Monster AI Turn ----

	void execute_monster_turn(combatant@ monster) {
		if (@monster == null or @combat == null or monster.is_dead) {
			if (@combat != null and combat.battle_active) advance_turn();
			return;
		}
		monster_turn_start_time = ticks();

		// SRD Frightful Presence (Adult Dragons): WIS save or Frightened for 1 minute.
		// Fires once per combat on the dragon's first turn.
		if (monster.frightful_presence_dc > 0 and !monster.frightful_presence_used) {
			monster.frightful_presence_used = true;
			broadcast_announce(monster.name + " unleashes a terrifying presence!", true);
			for (uint fpi = 0; fpi < combat.combatants.length(); fpi++) {
				combatant@ fp_target = combat.combatants[fpi];
				if (@fp_target == null or fp_target.is_dead or !fp_target.is_player or fp_target.current_hp <= 0) continue;
				if (feet_distance(monster.x, monster.y, fp_target.x, fp_target.y) > monster.frightful_presence_range) continue;
				if (fp_target.has_condition(COND_FRIGHTENED)) continue; // Already frightened
				int fp_roll = random(1, 20);
				int fp_bonus = fp_target.get_save_bonus(ABILITY_WIS);
				int fp_bless = roll_bless_bonus(fp_target);
				int fp_total = fp_roll + fp_bonus + fp_bless;
				bool fp_saved = fp_total >= monster.frightful_presence_dc;
				if (!fp_saved and try_arcane_deflection_save(fp_target, monster.frightful_presence_dc, fp_total)) fp_saved = true;
				if (!fp_saved) { if (try_countercharm_reroll(fp_target, monster.frightful_presence_dc, fp_bonus + fp_bless, "WIS save vs Frightful Presence")) fp_saved = true; }
				if (!fp_saved) { int fg = try_flash_of_genius(fp_target, monster.frightful_presence_dc, fp_total, "WIS save vs Frightful Presence"); if (fg >= monster.frightful_presence_dc) fp_saved = true; }
				broadcast_roll(fp_target.name, "WIS save vs Frightful Presence", fp_roll, fp_bonus + fp_bless, fp_total, fp_saved ? "Unafraid!" : "Frightened!");
				if (!fp_saved) {
					fp_target.add_condition(COND_FRIGHTENED);
					fp_target.frightened_source_id = monster.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", fp_target.name}, {"condition", "Frightened"}});
					broadcast_announce(fp_target.name + " is frightened by " + monster.name + "'s terrible presence!", true);
				}
			}
			broadcast_state();
		}

		combatant@ nearest = find_nearest_target_for_monster(monster);
		int nearest_dist = @nearest != null ? feet_distance(monster.x, monster.y, nearest.x, nearest.y) : 9999;

		if (@nearest == null) {
			// No targets: end turn.
			broadcast_announce(monster.name + " has no targets and ends its turn.");
			advance_turn();
			return;
		}

		// PHB 2024 Prone: monster must spend half speed to stand up before moving
		if (monster.has_condition(COND_PRONE)) {
			int stand_cost = monster.speed / 2;
			if (monster.movement_remaining >= stand_cost) {
				monster.movement_remaining -= stand_cost;
				monster.remove_condition(COND_PRONE);
				broadcast_announce(monster.name + " stands up (" + stand_cost + " ft used).", false);
			}
		}

		// Step 1: Move — toward target if out of range, AWAY if ranged-only and too close.
		// Ranged kiting: if monster has a ranged attack and target is within 5ft (melee zone),
		// the monster backs away to use its ranged attack without disadvantage.
		bool monster_frightened_blocked = false;
		if (monster.has_condition(COND_FRIGHTENED) and monster.frightened_source_id > 0) {
			combatant@ fear_src = combat.get_combatant(monster.frightened_source_id);
			if (@fear_src != null and !fear_src.is_dead and @nearest == fear_src) {
				monster_frightened_blocked = true;
			}
		}
		// Determine if this monster should kite (back away when target too close):
		// Kite if: has ranged attack, primary range > 5, and target is within melee (5ft)
		bool should_kite = false;
		int kite_range = 0;
		if (monster.main_hand_range > 5 and nearest_dist <= 5 and !monster_frightened_blocked) {
			should_kite = true;
			kite_range = monster.main_hand_range;
		} else if (monster_has_secondary_attack(monster) and monster_secondary_is_ranged(monster) and monster.main_hand_range <= 5 and nearest_dist <= 5 and !monster_frightened_blocked) {
			// Monster has melee primary + ranged secondary — don't kite, prefer melee
			should_kite = false;
		}
		// Execute kiting: move away from target
		if (should_kite) {
			while (monster.movement_remaining >= FEET_PER_TILE and nearest_dist < 15) {
				int old_x = monster.x;
				int old_y = monster.y;
				int dx = 0;
				int dy = 0;
				// Move AWAY from target
				if (nearest.x > monster.x) dx = -1;
				else if (nearest.x < monster.x) dx = 1;
				if (nearest.y > monster.y) dy = -1;
				else if (nearest.y < monster.y) dy = 1;
				if (dx != 0) { monster.x += dx; monster.movement_remaining -= FEET_PER_TILE; }
				else if (dy != 0) { monster.y += dy; monster.movement_remaining -= FEET_PER_TILE; }
				else break;
				check_opportunity_attacks(monster, old_x, old_y, monster.x, monster.y);
				if (@current_roll != null or monster.is_dead or monster.current_hp == 0) { broadcast_state(); return; }
				nearest_dist = feet_distance(monster.x, monster.y, nearest.x, nearest.y);
			}
			broadcast_state();
		}
		int desired_attack_range = get_monster_desired_attack_range(monster, nearest_dist);
		while (monster.movement_remaining >= FEET_PER_TILE and nearest_dist > desired_attack_range and !monster_frightened_blocked) {
			int old_x = monster.x;
			int old_y = monster.y;
			int dx = 0;
			int dy = 0;
			if (nearest.x > monster.x) dx = 1;
			else if (nearest.x < monster.x) dx = -1;
			if (nearest.y > monster.y) dy = 1;
			else if (nearest.y < monster.y) dy = -1;

			// PHB 2024 Frightened: block movement closer to fear source
			if (monster.has_condition(COND_FRIGHTENED) and monster.frightened_source_id > 0) {
				combatant@ mfs = combat.get_combatant(monster.frightened_source_id);
				if (@mfs != null and !mfs.is_dead) {
					int cur_fd = feet_distance(monster.x, monster.y, mfs.x, mfs.y);
					int new_fd = feet_distance(monster.x + (dx != 0 ? dx : 0), monster.y + (dx == 0 and dy != 0 ? dy : 0), mfs.x, mfs.y);
					if (new_fd < cur_fd) break;
				}
			}

			// Basic Rules 2024 Antilife Shell (para 11796-11803): block approach within 10ft
			// of a hostile Antilife Shell caster. Constructs/Undead are exempt.
			bool antilife_blocked = false;
			if (monster.creature_type != "construct" and monster.creature_type != "undead") {
				int try_x = monster.x + (dx != 0 ? dx : 0);
				int try_y = monster.y + (dx == 0 and dy != 0 ? dy : 0);
				for (uint asmi = 0; asmi < combat.combatants.length(); asmi++) {
					combatant@ as_m = combat.combatants[asmi];
					if (@as_m == null or as_m.is_dead or !as_m.antilife_shell_active) continue;
					if (!combat.are_hostile(monster, as_m)) continue;
					int new_as_dist = feet_distance(try_x, try_y, as_m.x, as_m.y);
					int old_as_dist = feet_distance(monster.x, monster.y, as_m.x, as_m.y);
					if (new_as_dist <= 10 and old_as_dist > 10) { antilife_blocked = true; break; }
				}
			}
			if (antilife_blocked) break;

			// Move one axis at a time (prefer x-axis, then y-axis).
			if (dx != 0) {
				monster.x += dx;
				monster.movement_remaining -= FEET_PER_TILE;
			} else if (dy != 0) {
				monster.y += dy;
				monster.movement_remaining -= FEET_PER_TILE;
			} else {
				break;
			}

			// Check opportunity attacks from moving.
			check_opportunity_attacks(monster, old_x, old_y, monster.x, monster.y);
			if (@current_roll != null or monster.is_dead or monster.current_hp == 0) {
				broadcast_state();
				return;
			}

			// Spirit Guardians entry damage on monster movement
			if (!monster.spirit_guardians_damaged_this_turn and !monster.is_dead) {
				for (uint sgi = 0; sgi < combat.combatants.length(); sgi++) {
					combatant@ sg_caster = combat.combatants[sgi];
					if (@sg_caster == null or sg_caster.is_dead or !sg_caster.spirit_guardians_active) continue;
					if (sg_caster.id == monster.id or sg_caster.is_player == monster.is_player) continue;
					int sg_old_dist = feet_distance(old_x, old_y, sg_caster.x, sg_caster.y);
					int sg_new_dist = feet_distance(monster.x, monster.y, sg_caster.x, sg_caster.y);
					if (sg_old_dist > 15 and sg_new_dist <= 15) {
						int sg_dice = 3 + (sg_caster.spirit_guardians_slot_level - 3);
						if (sg_dice < 3) sg_dice = 3;
						int sg_sr = random(1, 20);
						int sg_sb = monster.get_save_bonus(ABILITY_WIS);
						int sg_dc = spell_save_dc(sg_caster, "spirit_guardians");
						bool sg_ok = (sg_sr + sg_sb) >= sg_dc;
						broadcast_roll(monster.name, "WIS save vs Spirit Guardians", sg_sr, sg_sb, sg_sr + sg_sb, sg_ok ? "Saved!" : "Failed!");
						int sg_d = 0;
						for (int sd = 0; sd < sg_dice; sd++) sg_d += random(1, 8);
						if (sg_ok) sg_d /= 2;
						if (sg_d < 1) sg_d = 1;
						int sg_dt = sg_caster.spirit_guardians_necrotic ? DMG_NECROTIC : DMG_RADIANT;
						combat.apply_damage(monster, sg_d, sg_dt, sg_caster);
						broadcast_announce(monster.name + " enters Spirit Guardians and takes " + sg_d + " damage!", true);
						monster.spirit_guardians_damaged_this_turn = true;
						// Basic Rules 2024 Spirit Guardians (para 15126): "Speeds are halved in the Emanation."
						monster.movement_remaining = monster.movement_remaining / 2;
						if (monster.is_dead) { broadcast_state(); check_battle_end(); return; }
						break;
					}
				}
			}

			// Xanathar's Arcane Archer Grasping Arrow (paras 1618-1646): movement damage
			if (monster.arcane_grasping_active and !monster.arcane_grasping_damaged_this_turn and !monster.is_dead) {
				int grasp_dmg = random(1, 6) + random(1, 6);
				combatant@ grasp_src = combat.get_combatant(monster.arcane_grasping_source);
				combat.apply_damage(monster, grasp_dmg, DMG_SLASHING, @grasp_src != null ? grasp_src : monster);
				broadcast_announce(monster.name + " takes " + grasp_dmg + " slashing damage from Grasping Arrow thorns!", true);
				monster.arcane_grasping_damaged_this_turn = true;
				if (monster.is_dead) { broadcast_state(); check_battle_end(); return; }
			}

			nearest_dist = feet_distance(monster.x, monster.y, nearest.x, nearest.y);
			desired_attack_range = get_monster_desired_attack_range(monster, nearest_dist);
		}

		broadcast_state();

		// Step 1b: If still out of range and has action, Dash to double movement.
		if (monster.has_action and nearest_dist > desired_attack_range and !monster_frightened_blocked) {
			monster.has_action = false;
			monster.used_action = true;
			monster.movement_remaining += monster.speed;
			broadcast_announce(monster.name + " dashes!", false);
			// Continue moving with the extra movement
			while (monster.movement_remaining >= FEET_PER_TILE and nearest_dist > desired_attack_range) {
				int od_x = monster.x;
				int od_y = monster.y;
				int ddx = 0;
				int ddy = 0;
				if (nearest.x > monster.x) ddx = 1;
				else if (nearest.x < monster.x) ddx = -1;
				if (nearest.y > monster.y) ddy = 1;
				else if (nearest.y < monster.y) ddy = -1;
				// Frightened: can't move closer to fear source
				if (monster.has_condition(COND_FRIGHTENED) and monster.frightened_source_id > 0) {
					combatant@ dfs = combat.get_combatant(monster.frightened_source_id);
					if (@dfs != null and !dfs.is_dead) {
						int dfd = feet_distance(monster.x, monster.y, dfs.x, dfs.y);
						int nfd = feet_distance(monster.x + (ddx != 0 ? ddx : 0), monster.y + (ddx == 0 and ddy != 0 ? ddy : 0), dfs.x, dfs.y);
						if (nfd < dfd) break;
					}
				}
				if (ddx != 0) { monster.x += ddx; monster.movement_remaining -= FEET_PER_TILE; }
				else if (ddy != 0) { monster.y += ddy; monster.movement_remaining -= FEET_PER_TILE; }
				else break;
				check_opportunity_attacks(monster, od_x, od_y, monster.x, monster.y);
				if (@current_roll != null or monster.is_dead or monster.current_hp == 0) { broadcast_state(); return; }
				nearest_dist = feet_distance(monster.x, monster.y, nearest.x, nearest.y);
			}
			broadcast_state();
		}

		// Step 2: Use action — breath weapon or melee attack.
		// AI decision: prefer breath weapon when available and 2+ enemies in range.
		bool used_breath = false;
		if (monster.has_action and monster.breath_available and monster.breath_name != "") {
			// Count enemies within breath range
			int targets_in_breath_range = 0;
			for (uint bti = 0; bti < combat.combatants.length(); bti++) {
				combatant@ bt = combat.combatants[bti];
				if (@bt == null or bt.is_dead or !bt.is_player or bt.current_hp <= 0) continue;
				if (feet_distance(monster.x, monster.y, bt.x, bt.y) <= monster.breath_range) {
					targets_in_breath_range++;
				}
			}
			// Use breath if 2+ targets in range, or 1 target in range and not in melee
			if (targets_in_breath_range >= 2 or (targets_in_breath_range >= 1 and nearest_dist > 5)) {
				monster.has_action = false;
				monster.used_action = true;
				monster.breath_available = false;
				used_breath = true;
				// Roll breath weapon damage
				int breath_total = 0;
				for (int bd = 0; bd < monster.breath_count; bd++) breath_total += random(1, monster.breath_dice);
				broadcast_announce(monster.name + " uses " + monster.breath_name + "!", true);
				// Apply to all enemies in range
				for (uint bhi = 0; bhi < combat.combatants.length(); bhi++) {
					combatant@ bh = combat.combatants[bhi];
					if (@bh == null or bh.is_dead or !bh.is_player or bh.current_hp <= 0) continue;
					if (feet_distance(monster.x, monster.y, bh.x, bh.y) > monster.breath_range) continue;
					int save_roll = random(1, 20);
					int save_bonus = bh.get_save_bonus(monster.breath_save_type);
					int bless_bonus = roll_bless_bonus(bh);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= monster.breath_save_dc;
					// Full save failure chain
					if (!saved and try_arcane_deflection_save(bh, monster.breath_save_dc, save_total)) saved = true;
					if (!saved) { if (try_countercharm_reroll(bh, monster.breath_save_dc, save_bonus + bless_bonus, ABILITY_NAMES[monster.breath_save_type] + " save vs " + monster.breath_name)) saved = true; }
					if (!saved) { int ds = try_disciplined_survivor_reroll(bh, monster.breath_save_dc, save_total, save_bonus + bless_bonus, ABILITY_NAMES[monster.breath_save_type] + " save vs " + monster.breath_name); if (ds >= monster.breath_save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(bh, monster.breath_save_dc, save_total, ABILITY_NAMES[monster.breath_save_type] + " save vs " + monster.breath_name); if (fg >= monster.breath_save_dc) saved = true; }
					if (!saved) { int mv = try_maverick_spirit(bh, monster.breath_save_dc, save_total, ABILITY_NAMES[monster.breath_save_type] + " save vs " + monster.breath_name); if (mv >= monster.breath_save_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(bh, monster.breath_save_type)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(bh, save_total, monster.breath_save_dc); if (bf > 0) saved = true; }
					if (!saved and try_stroke_of_luck_save(bh, monster.breath_save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = breath_total;
					if (saved) dmg = dmg / 2;
					string save_name = "DEX";
					if (monster.breath_save_type == ABILITY_CON) save_name = "CON";
					else if (monster.breath_save_type == ABILITY_WIS) save_name = "WIS";
					broadcast_roll(bh.name, save_name + " save vs " + monster.breath_name, save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved! Half damage." : "Failed!");
					if (dmg > 0) {
						combat.apply_damage(bh, dmg, monster.breath_damage_type, monster);
						broadcast_announce(bh.name + " takes " + dmg + " damage from " + monster.breath_name + "!" + (saved ? " (half)" : ""), true);
						if (bh.is_dead or bh.current_hp <= 0) {
							check_battle_end();
							if (!combat.battle_active) return;
						}
					}
				}
				broadcast_state();
			}
		}

		// Gun Slinger Class Jam Weapon: monsters auto-unjam (spends their action)
		if (monster.weapon_jammed and monster.has_action) {
			monster.weapon_jammed = false;
			monster.has_action = false;
			monster.used_action = true;
			broadcast_announce(monster.name + " spends its action to unjam its weapon!", true);
		}

		// Step 2b: Melee/ranged attack if breath was not used
		if (!used_breath and monster.has_action and nearest_dist <= desired_attack_range) {
			monster.has_action = false;
			monster.used_action = true;
			int monster_attacks = monster.extra_attacks;
				// Basic Rules 2024 Haste (para 13688): +1 weapon attack (extra action approx)
				if (monster.hasted) monster_attacks += 1;
				if (start_monster_attack_sequence(monster, nearest, 0, monster_attacks)) return;
		}

		// Step 3: End monster turn.
		broadcast_announce(monster.name + " ends its turn.");
		advance_turn();
	}

	void handle_turn_end(user@ u) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null) return;
		// Only the active combatant's player can end the turn.
		if (c.is_player and c.player_username != u.username) return;

		broadcast_announce(c.name + " ends their turn.");
		broadcast_state();
		advance_turn();
	}

	bool start_flurry_strike(combatant@ attacker, combatant@ target, int remaining_after_current) {
		if (@combat == null or @attacker == null or @target == null) return false;
		if (target.is_dead or !target.is_alive()) return false;
		int dist = feet_distance(attacker.x, attacker.y, target.x, target.y);
		if (dist > 5) return false;
		if (!combat.can_see(attacker, target)) return false;

		bool adv = false;
		bool disadv = false;
		apply_attack_advantage_state(attacker, target, dist, false, adv, disadv);
		reveal_hidden_combatant(attacker, "making a Flurry of Blows attack");

		pending_roll pr;
		pr.combatant_id = attacker.id;
		pr.player_username = attacker.is_player ? attacker.player_username : attacker.name;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = attacker.get_ability_mod(ABILITY_DEX) + attacker.proficiency - attacker.exhaustion_level * 2;
		pr.reason = "Flurry of Blows against " + target.name;
		pr.target_id = target.id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.attack_name = "Flurry of Blows";
		pr.damage_dice_count = 1;
		pr.damage_dice_sides = monk_martial_arts_die(attacker);
		pr.damage_modifier = attacker.get_ability_mod(ABILITY_DEX);
		if (pr.damage_modifier < 0) pr.damage_modifier = 0;
		pr.damage_type = DMG_BLUDGEONING;
		pr.is_weapon_attack = true;
		pr.attacks_remaining = remaining_after_current;
		pr.resolution_tag = "flurry";
		@current_roll = pr;

		user@ u = find_user_for_combatant(attacker);
		if (@u != null and !u.is_bot and attacker.is_player) {
			send_roll_request(u, pr);
		} else {
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int natural = roll1;
			if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
			else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
			process_roll_result(natural);
		}
		return true;
	}

	// PHB 2024 Two-Weapon Fighting: off-hand attack with a Light melee weapon.
	// No ability mod to damage unless Two-Weapon Fighting style or negative mod.
	bool start_twf_offhand_strike(combatant@ attacker, combatant@ target) {
		if (@combat == null or @attacker == null or @target == null) return false;
		if (target.is_dead or !target.is_alive()) return false;
		if (attacker.off_hand == "" or attacker.off_hand_damage_count == 0) return false;
		int dist = feet_distance(attacker.x, attacker.y, target.x, target.y);
		if (dist > attacker.off_hand_range) return false;
		if (!combat.can_see(attacker, target)) return false;

		bool adv = false;
		bool disadv = false;
		apply_attack_advantage_state(attacker, target, dist, false, adv, disadv);
		reveal_hidden_combatant(attacker, "making an off-hand attack");

		// Determine ability modifier (finesse: higher of STR/DEX)
		int str_mod = attacker.get_ability_mod(ABILITY_STR);
		int dex_mod = attacker.get_ability_mod(ABILITY_DEX);
		int ability_mod = str_mod;
		if (attacker.off_hand_finesse and dex_mod > str_mod) ability_mod = dex_mod;

		pending_roll pr;
		pr.combatant_id = attacker.id;
		pr.player_username = attacker.is_player ? attacker.player_username : attacker.name;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = ability_mod + attacker.proficiency - attacker.exhaustion_level * 2;
		pr.reason = "Off-hand attack (" + attacker.off_hand + ") against " + target.name;
		pr.target_id = target.id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.attack_name = attacker.off_hand + " (off-hand)";
		pr.damage_dice_count = attacker.off_hand_damage_count;
		pr.damage_dice_sides = attacker.off_hand_damage_dice;
		// PHB 2024: "you don't add your Ability Modifier to the extra attack's damage
		// unless that modifier is negative." Two-Weapon Fighting style overrides this.
		bool has_twf_style = attacker.has_feat("two_weapon_fighting");
		if (has_twf_style) {
			pr.damage_modifier = ability_mod;
		} else if (ability_mod < 0) {
			pr.damage_modifier = ability_mod;
		} else {
			pr.damage_modifier = 0;
		}
		pr.damage_type = attacker.off_hand_damage_type;
		pr.is_weapon_attack = true;
		pr.resolution_tag = "twf_offhand";
		attacker.twf_attack_used_this_turn = true;
		@current_roll = pr;

		user@ u = find_user_for_combatant(attacker);
		if (@u != null and !u.is_bot and attacker.is_player) {
			send_roll_request(u, pr);
		} else {
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int natural = roll1;
			if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
			else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
			process_roll_result(natural);
		}
		return true;
	}

	// Basic Rules 2024 Swift Quiver (para 15218): bonus action for 2 ranged attacks
	// using the main weapon at full attack bonus. Uses flurry-style chaining.
	bool start_swift_quiver_strike(combatant@ attacker, combatant@ target, int remaining_after_current) {
		if (@combat == null or @attacker == null or @target == null) return false;
		if (target.is_dead or !target.is_alive()) return false;
		if (!attacker.main_hand_is_ranged) return false;
		int dist = feet_distance(attacker.x, attacker.y, target.x, target.y);
		if (dist > attacker.main_hand_range) return false;
		if (!combat.can_see(attacker, target)) return false;

		bool adv = false;
		bool disadv = false;
		apply_attack_advantage_state(attacker, target, dist, true, adv, disadv);
		reveal_hidden_combatant(attacker, "making a Swift Quiver attack");

		// Use main weapon stats at full attack bonus (includes Archery, Magic Weapon, etc.)
		int atk_bonus = get_attack_bonus_for_roll(attacker, false);
		int dmg_mod = get_damage_modifier_for_attack(attacker, false);

		pending_roll pr;
		pr.combatant_id = attacker.id;
		pr.player_username = attacker.is_player ? attacker.player_username : attacker.name;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = atk_bonus;
		pr.reason = "Swift Quiver attack (" + attacker.main_hand + ") against " + target.name;
		pr.target_id = target.id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.attack_name = attacker.main_hand + " (Swift Quiver)";
		pr.damage_dice_count = attacker.main_hand_damage_count;
		pr.damage_dice_sides = attacker.main_hand_damage_dice;
		pr.damage_modifier = dmg_mod;
		pr.damage_type = attacker.main_hand_damage_type;
		pr.is_weapon_attack = true;
		pr.attacks_remaining = remaining_after_current;
		pr.resolution_tag = "swift_quiver";
		@current_roll = pr;

		user@ u = find_user_for_combatant(attacker);
		if (@u != null and !u.is_bot and attacker.is_player) {
			send_roll_request(u, pr);
		} else {
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int natural = roll1;
			if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
			else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
			process_roll_result(natural);
		}
		return true;
	}

	bool start_true_strike_attack(combatant@ caster, combatant@ target) {
		if (@combat == null or @caster == null or @target == null) return false;
		if (target.is_dead or !target.is_alive()) return false;
		int dist = feet_distance(caster.x, caster.y, target.x, target.y);
		if (dist > caster.main_hand_range) return false;
		if (!combat.can_see(caster, target)) return false;

		bool attack_is_ranged = caster.main_hand_is_ranged;
		bool adv = false;
		bool disadv = false;
		apply_attack_advantage_state(caster, target, dist, attack_is_ranged, adv, disadv, true);
		reveal_hidden_combatant(caster, "making a True Strike attack");

		pending_roll pr;
		pr.combatant_id = caster.id;
		pr.player_username = caster.is_player ? caster.player_username : caster.name;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = spell_attack_bonus(caster) - caster.exhaustion_level * 2;
		pr.reason = "True Strike against " + target.name;
		pr.target_id = target.id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.attack_name = "True Strike";
		pr.damage_dice_count = caster.main_hand_damage_count;
		pr.damage_dice_sides = caster.main_hand_damage_dice;
		pr.damage_modifier = get_spellcasting_ability_mod(caster);
		pr.damage_type = caster.main_hand_damage_type;
		pr.extra_damage_dice_count = cantrip_dice_count(1, caster.level);
		pr.extra_damage_dice_sides = 6;
		pr.extra_damage_type = DMG_RADIANT;
		pr.is_weapon_attack = true;
		pr.resolution_tag = "true_strike";
		@current_roll = pr;

		user@ u = find_user_for_combatant(caster);
		if (@u != null and !u.is_bot and caster.is_player) {
			send_roll_request(u, pr);
		} else {
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int natural = roll1;
			if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
			else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
			process_roll_result(natural);
		}
		return true;
	}

	bool start_spiritual_weapon_attack(combatant@ caster, combatant@ target) {
		if (@combat == null or @caster == null or @target == null) return false;
		if (!caster.spiritual_weapon_active or caster.spiritual_weapon_slot_level < 2) return false;
		if (target.is_dead or !target.is_alive()) return false;
		int dist = feet_distance(caster.x, caster.y, target.x, target.y);
		if (dist > 60) return false;
		if (!combat.can_see(caster, target)) return false;

		bool adv = false;
		bool disadv = false;
		if (target.has_condition(COND_PARALYZED) or target.has_condition(COND_STUNNED) or target.has_condition(COND_UNCONSCIOUS)) adv = true;
		if (caster.has_condition(COND_BLINDED) or caster.has_condition(COND_POISONED)) disadv = true;
		if (target.is_dodging and !caster.has_condition(COND_BLINDED)) disadv = true;
		bool sw_can_ignore_invis = (caster.has_feat("boon_of_truesight") and dist <= 60)
			or (caster.true_seeing_active and dist <= 120);
		if (target.has_condition(COND_INVISIBLE) and !sw_can_ignore_invis) disadv = true;
		if (target.has_condition(COND_RESTRAINED)) adv = true;
		reveal_hidden_combatant(caster, "commanding Spiritual Weapon");

		pending_roll pr;
		pr.combatant_id = caster.id;
		pr.player_username = caster.is_player ? caster.player_username : caster.name;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = spell_attack_bonus(caster) - caster.exhaustion_level * 2;
		pr.reason = "Spiritual Weapon attack against " + target.name;
		pr.target_id = target.id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.attack_name = "Spiritual Weapon";
		pr.damage_dice_count = spiritual_weapon_damage_count_for_slot(caster.spiritual_weapon_slot_level);
		pr.damage_dice_sides = 8;
		pr.damage_modifier = get_spellcasting_ability_mod(caster);
		pr.damage_type = DMG_FORCE;
		pr.resolution_tag = "spiritual_weapon";
		@current_roll = pr;

		user@ u = find_user_for_combatant(caster);
		if (@u != null and !u.is_bot and caster.is_player) {
			send_roll_request(u, pr);
		} else {
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int natural = roll1;
			if (adv and !disadv) natural = roll1 > roll2 ? roll1 : roll2;
			else if (disadv and !adv) natural = roll1 < roll2 ? roll1 : roll2;
			process_roll_result(natural);
		}
		return true;
	}

	// ---- Roll Result Processing ----

	bool maybe_prompt_bardic_inspiration(pending_roll@ pr, combatant@ c, int natural_roll, int bless_bonus) {
		if (@pr == null or @c == null) return false;
		int die_size = bardic_die_for_target(c);
		if (die_size <= 0) return false;

		int total = natural_roll + pr.modifier + bless_bonus;
		int failure_margin = 0;
		string prompt_text = "";

		if (pr.roll_type == ROLL_ATTACK) {
			combatant@ target = combat.get_combatant(pr.target_id);
			if (@target == null or natural_roll == 1 or natural_roll == 20 or total >= target.armor_class) return false;
			failure_margin = target.armor_class - total;
			prompt_text = "You missed " + target.name + " by " + failure_margin + ".";
		}
		else if (pr.roll_type == ROLL_CONCENTRATION) {
			if (total >= pr.dc) return false;
			failure_margin = pr.dc - total;
			prompt_text = "You failed your concentration save by " + failure_margin + ".";
		}
		else if (pr.roll_type == ROLL_DEATH_SAVE) {
			if (natural_roll == 1 or natural_roll == 20 or total >= DEATH_SAVE_DC) return false;
			failure_margin = DEATH_SAVE_DC - total;
			prompt_text = "You failed your death save by " + failure_margin + ".";
		}
		else if (pr.roll_type == ROLL_ABILITY_CHECK and pr.resolution_tag == "hide") {
			if (total >= pr.dc) return false;
			failure_margin = pr.dc - total;
			prompt_text = "Your Hide check failed by " + failure_margin + ".";
		}
		else if (pr.roll_type == ROLL_ABILITY_CHECK and pr.dc > 0) {
			// Generic skill check with a target DC. Includes Persuasion, Deception, Athletics,
			// Investigation, etc. via the skill_<name> resolution tags. Bardic Inspiration
			// applies to ANY ability check the bard gives the die to (PHB Bard L1).
			if (total >= pr.dc) return false;
			failure_margin = pr.dc - total;
			prompt_text = "Your " + pr.reason + " failed by " + failure_margin + ".";
		}
		else {
			return false;
		}

		user@ roller_user = find_user_for_combatant(c);
		if (!c.is_player or @roller_user == null or roller_user.is_bot) {
			if (failure_margin > die_size) return false;
			int bardic_bonus = random(1, die_size);
			pr.bardic_source_id = c.bardic_inspiration_source_id; // Track for Eloquence features
			pr.bardic_die_used = die_size;
			clear_bardic_inspiration(c, false);
			broadcast_announce(c.name + " uses Bardic Inspiration (" + die_label(die_size) + ") and adds " + bardic_bonus + " to the roll.", false);
			finalize_roll_result(pr, natural_roll, bless_bonus, bardic_bonus);
			return true;
		}

		pending_bardic_prompt prompt;
		prompt.player_username = c.player_username;
		@prompt.roll = pr;
		prompt.natural_roll = natural_roll;
		prompt.bless_bonus = bless_bonus;
		prompt.failure_margin = failure_margin;
		prompt.die_size = die_size;
		@current_bardic_prompt = prompt;

		roller_user.send({
			{"type", message_types::bardic_prompt},
			{"text", prompt_text + " Press Enter to use Bardic Inspiration (" + die_label(die_size) + "), or Escape to save it."},
			{"die", die_size},
			{"margin", failure_margin}
		});
		return true;
	}

	// ---- Subclass On-Hit Damage ----
	// Called after a successful attack hit, returns bonus damage to add to total.
	int apply_subclass_on_hit_damage(combatant@ attacker, combatant@ target, bool is_weapon_attack, bool had_advantage = false, bool had_disadvantage = false) {
		int bonus = 0;
		if (@attacker == null or @target == null) return 0;

		// Xanathar's Zealot L3 Divine Fury (para 439-440): "While you're raging, the first
		// creature you hit on each of your turns with a weapon attack takes extra damage equal
		// to 1d6 + half your barbarian level. The extra damage is necrotic or radiant."
		if (attacker.class_name == "Barbarian" and attacker.subclass == "Zealot" and attacker.raging and attacker.is_first_hit_this_turn and is_weapon_attack) {
			int zealot_dmg = random(1, 6) + attacker.level / 2;
			bonus += zealot_dmg;
			broadcast_announce(attacker.name + "'s Divine Fury deals " + zealot_dmg + " extra radiant damage!", false);
		}

		// Tasha's Psi Warrior L3 Psionic Strike (para 16-18): "expend one Psionic
		// Energy die, rolling it and dealing force damage equal to the number rolled
		// plus your Intelligence modifier." Once per turn, on weapon hit.
		if (attacker.class_name == "Fighter" and attacker.subclass == "Psi Warrior" and attacker.psionic_strike_uses > 0 and is_weapon_attack) {
			int die = attacker.psionic_die_size > 0 ? attacker.psionic_die_size : 6;
			int psi_dmg = random(1, die) + attacker.get_ability_mod(ABILITY_INT);
			if (psi_dmg < 1) psi_dmg = 1;
			attacker.psionic_strike_uses--;
			bonus += psi_dmg;
			broadcast_announce(attacker.name + "'s Psionic Strike deals " + psi_dmg + " force damage! (" + attacker.psionic_strike_uses + " dice remain)", false);
			// Tasha's Psi Warrior L7 Telekinetic Thrust (para 26-29): "If the target is
			// Large or smaller, you can force the target to make a Strength saving throw.
			// Unless the save succeeds, you can push the target up to 10 feet and knock it Prone."
			if (attacker.level >= 7 and target.size <= SIZE_LARGE and !target.is_dead) {
				int thrust_dc = 8 + attacker.get_ability_mod(ABILITY_INT) + attacker.proficiency;
				int thrust_save = target.apply_indomitable_might(random(1, 20) + target.get_save_bonus(ABILITY_STR), ABILITY_STR);
				if (thrust_save < thrust_dc) {
					// Push 10 ft (2 tiles) directly away from attacker
					int push_dir_x = 0; int push_dir_y = 0;
					if (target.x > attacker.x) push_dir_x = 1;
					else if (target.x < attacker.x) push_dir_x = -1;
					if (target.y > attacker.y) push_dir_y = 1;
					else if (target.y < attacker.y) push_dir_y = -1;
					if (push_dir_x == 0 and push_dir_y == 0) push_dir_y = 1;
					target.x += push_dir_x * 2; target.y += push_dir_y * 2;
					target.add_condition(COND_PRONE);
					broadcast_announce(target.name + " is pushed 10 feet and knocked prone by Telekinetic Thrust!", false);
				} else {
					broadcast_announce(target.name + " resists the Telekinetic Thrust (STR save " + thrust_save + " vs DC " + thrust_dc + ").", false);
				}
			}
		}

		// Tasha's Rune Knight Fire Rune invoke (paras 3218-3221): "When you hit a creature
		// with an attack using a weapon, you can invoke the rune to summon fiery shackles:
		// the target takes an extra 2d6 fire damage, and it must make a Strength saving
		// throw. On a failed save, the target is restrained for 1 minute. At the end of
		// each of the target's turns, the target can make a Constitution saving throw,
		// ending the effect on a success."
		if (attacker.fire_rune_pending and is_weapon_attack and !target.is_dead) {
			attacker.fire_rune_pending = false;
			int fire_rune_dmg = random(1, 6) + random(1, 6);
			bonus += fire_rune_dmg;
			// Save DC = 8 + CON mod + proficiency (Rune Knight uses CON for rune DCs)
			int rune_dc = 8 + attacker.get_ability_mod(ABILITY_CON) + attacker.proficiency;
			int str_save = random(1, 20) + target.get_save_bonus(ABILITY_STR);
			str_save = target.apply_indomitable_might(str_save, ABILITY_STR);
			bool str_saved = str_save >= rune_dc;
			broadcast_announce(attacker.name + "'s Fire Rune deals " + fire_rune_dmg + " extra fire damage!", false);
			broadcast_roll(target.name, "STR save vs Fire Rune", str_save - target.get_save_bonus(ABILITY_STR), target.get_save_bonus(ABILITY_STR), str_save, str_saved ? "Saved!" : "Restrained!");
			if (!str_saved) {
				target.add_condition(COND_RESTRAINED);
				target.fire_rune_restrained_source = attacker.id;
				target.fire_rune_restrained_dc = rune_dc;
				broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Restrained"}});
				broadcast_announce(target.name + " is restrained by fiery shackles!", false);
			}
		}

		// Battle Master maneuver save DC: PHB 2024 para 6005 — "8 plus your Strength
		// or Dexterity modifier (your choice) and Proficiency Bonus"
		// We auto-pick the higher of STR/DEX for the player.
		// Trip Attack (para 6058-6059): +1d8, Large or smaller STR save or Prone
		if (attacker.class_name == "Fighter" and attacker.subclass == "Battle Master" and attacker.trip_attack_pending and is_weapon_attack) {
			int trip_dmg = random(1, 8);
			bonus += trip_dmg;
			attacker.trip_attack_pending = false;
			attacker.superiority_dice--;
			int bm_mod = attacker.get_ability_mod(ABILITY_STR) > attacker.get_ability_mod(ABILITY_DEX) ? attacker.get_ability_mod(ABILITY_STR) : attacker.get_ability_mod(ABILITY_DEX);
			int save_dc = 8 + attacker.proficiency + bm_mod;
			int save_roll = target.apply_indomitable_might(random(1, 20) + target.get_save_bonus(ABILITY_STR), ABILITY_STR);
			if (save_roll < save_dc and target.size <= SIZE_LARGE) {
				target.add_condition(COND_PRONE);
				broadcast_announce(attacker.name + "'s Trip Attack deals " + trip_dmg + " extra damage and knocks " + target.name + " prone! (" + attacker.superiority_dice + " dice remain)", false);
			} else {
				broadcast_announce(attacker.name + "'s Trip Attack deals " + trip_dmg + " extra damage, but " + target.name + " stays standing! (" + attacker.superiority_dice + " dice remain)", false);
			}
		}

		// PHB 2024 Battle Master: Menacing Attack (para 6042-6043)
		// +1d8 damage, WIS save or Frightened until end of attacker's next turn
		if (attacker.class_name == "Fighter" and attacker.subclass == "Battle Master" and attacker.menacing_attack_pending and is_weapon_attack) {
			int men_dmg = random(1, 8);
			bonus += men_dmg;
			attacker.menacing_attack_pending = false;
			attacker.superiority_dice--;
			int bm_mod = attacker.get_ability_mod(ABILITY_STR) > attacker.get_ability_mod(ABILITY_DEX) ? attacker.get_ability_mod(ABILITY_STR) : attacker.get_ability_mod(ABILITY_DEX);
			int save_dc = 8 + attacker.proficiency + bm_mod;
			int save_roll = random(1, 20) + target.get_save_bonus(ABILITY_WIS);
			if (save_roll < save_dc) {
				target.add_condition(COND_FRIGHTENED);
				target.frightened_source_id = attacker.id;
				broadcast_announce(attacker.name + "'s Menacing Attack deals " + men_dmg + " extra damage and Frightens " + target.name + "! (" + attacker.superiority_dice + " dice remain)", false);
			} else {
				broadcast_announce(attacker.name + "'s Menacing Attack deals " + men_dmg + " extra damage, but " + target.name + " resists the fear! (" + attacker.superiority_dice + " dice remain)", false);
			}
		}

		// PHB 2024 Battle Master: Goading Attack (para 6036-6037)
		// +1d8 damage, WIS save or disadvantage on attacks vs others until end of attacker's next turn
		if (attacker.class_name == "Fighter" and attacker.subclass == "Battle Master" and attacker.goading_attack_pending and is_weapon_attack) {
			int goad_dmg = random(1, 8);
			bonus += goad_dmg;
			attacker.goading_attack_pending = false;
			attacker.superiority_dice--;
			int bm_mod = attacker.get_ability_mod(ABILITY_STR) > attacker.get_ability_mod(ABILITY_DEX) ? attacker.get_ability_mod(ABILITY_STR) : attacker.get_ability_mod(ABILITY_DEX);
			int save_dc = 8 + attacker.proficiency + bm_mod;
			int save_roll = random(1, 20) + target.get_save_bonus(ABILITY_WIS);
			if (save_roll < save_dc) {
				target.goading_attack_source_id = attacker.id;
				target.goading_attack_turns = 2; // expires at end of attacker's next turn
				broadcast_announce(attacker.name + "'s Goading Attack deals " + goad_dmg + " extra damage! " + target.name + " has disadvantage on attacks against anyone except " + attacker.name + ". (" + attacker.superiority_dice + " dice remain)", false);
			} else {
				broadcast_announce(attacker.name + "'s Goading Attack deals " + goad_dmg + " extra damage, but " + target.name + " resists the goad! (" + attacker.superiority_dice + " dice remain)", false);
			}
		}

		// PHB 2024 Battle Master: Pushing Attack (para 6048-6049)
		// +1d8 damage, Large or smaller STR save or pushed 15ft away
		if (attacker.class_name == "Fighter" and attacker.subclass == "Battle Master" and attacker.pushing_attack_pending and is_weapon_attack) {
			int push_dmg = random(1, 8);
			bonus += push_dmg;
			attacker.pushing_attack_pending = false;
			attacker.superiority_dice--;
			int bm_mod = attacker.get_ability_mod(ABILITY_STR) > attacker.get_ability_mod(ABILITY_DEX) ? attacker.get_ability_mod(ABILITY_STR) : attacker.get_ability_mod(ABILITY_DEX);
			int save_dc = 8 + attacker.proficiency + bm_mod;
			int save_roll = target.apply_indomitable_might(random(1, 20) + target.get_save_bonus(ABILITY_STR), ABILITY_STR);
			if (save_roll < save_dc and target.size <= SIZE_LARGE) {
				// Push 15 ft (3 tiles) directly away from attacker
				int dx = target.x - attacker.x;
				int dy = target.y - attacker.y;
				if (dx == 0 and dy == 0) dy = 1;
				int push_tiles = 3; // 15ft / 5ft per tile
				if (dx != 0) target.x += (dx > 0 ? push_tiles : -push_tiles);
				if (dy != 0) target.y += (dy > 0 ? push_tiles : -push_tiles);
				broadcast_announce(attacker.name + "'s Pushing Attack deals " + push_dmg + " extra damage and shoves " + target.name + " 15 feet away! (" + attacker.superiority_dice + " dice remain)", false);
			} else {
				broadcast_announce(attacker.name + "'s Pushing Attack deals " + push_dmg + " extra damage, but " + target.name + " holds their ground! (" + attacker.superiority_dice + " dice remain)", false);
			}
		}

		// PHB 2024 Battle Master: Disarming Attack (para 6028-6029)
		// +1d8 damage, STR save or drop weapon (weapon_jammed as approximation)
		if (attacker.class_name == "Fighter" and attacker.subclass == "Battle Master" and attacker.disarming_attack_pending and is_weapon_attack) {
			int dis_dmg = random(1, 8);
			bonus += dis_dmg;
			attacker.disarming_attack_pending = false;
			attacker.superiority_dice--;
			int bm_mod = attacker.get_ability_mod(ABILITY_STR) > attacker.get_ability_mod(ABILITY_DEX) ? attacker.get_ability_mod(ABILITY_STR) : attacker.get_ability_mod(ABILITY_DEX);
			int save_dc = 8 + attacker.proficiency + bm_mod;
			int save_roll = target.apply_indomitable_might(random(1, 20) + target.get_save_bonus(ABILITY_STR), ABILITY_STR);
			if (save_roll < save_dc) {
				target.weapon_jammed = true; // Approximation: must use action to recover weapon
				broadcast_announce(attacker.name + "'s Disarming Attack deals " + dis_dmg + " extra damage and forces " + target.name + " to drop their weapon! (Use action to recover) (" + attacker.superiority_dice + " dice remain)", false);
			} else {
				broadcast_announce(attacker.name + "'s Disarming Attack deals " + dis_dmg + " extra damage, but " + target.name + " keeps hold of their weapon! (" + attacker.superiority_dice + " dice remain)", false);
			}
		}

		// PHB 2024 Battle Master: Distracting Strike (para 6030-6031)
		// +1d8 damage, next attack roll by another against target has Advantage
		if (attacker.class_name == "Fighter" and attacker.subclass == "Battle Master" and attacker.distracting_strike_pending and is_weapon_attack) {
			int dist_dmg = random(1, 8);
			bonus += dist_dmg;
			attacker.distracting_strike_pending = false;
			attacker.superiority_dice--;
			target.distracting_strike_marked = true;
			target.distracting_strike_source_id = attacker.id;
			broadcast_announce(attacker.name + "'s Distracting Strike deals " + dist_dmg + " extra damage! The next attack against " + target.name + " by another creature has advantage. (" + attacker.superiority_dice + " dice remain)", false);
		}

		// PHB 2024 Battle Master: Sweeping Attack (para 6054-6055)
		// On hit, choose another creature within 5ft of target and within reach.
		// If original attack roll would hit it, deal Superiority Die damage.
		if (attacker.class_name == "Fighter" and attacker.subclass == "Battle Master" and attacker.sweeping_attack_pending and is_weapon_attack and @combat != null) {
			attacker.sweeping_attack_pending = false;
			attacker.superiority_dice--;
			int sweep_dmg = random(1, 8);
			// Find nearest hostile within 5ft of target (and within attacker's reach)
			combatant@ sweep_target = null;
			int sweep_best = 999;
			for (uint si = 0; si < combat.combatants.length(); si++) {
				combatant@ st = combat.combatants[si];
				if (@st == null or st.is_dead or st.id == target.id or st.id == attacker.id) continue;
				if (st.is_player == attacker.is_player) continue; // skip allies
				int d_to_target = feet_distance(st.x, st.y, target.x, target.y);
				int d_to_attacker = feet_distance(st.x, st.y, attacker.x, attacker.y);
				int reach = attacker.main_hand_is_ranged ? 5 : (attacker.has_feat("polearm_master") ? 10 : 5);
				if (d_to_target <= 5 and d_to_attacker <= reach and d_to_target < sweep_best) {
					sweep_best = d_to_target;
					@sweep_target = st;
				}
			}
			if (@sweep_target != null) {
				combat.apply_damage(sweep_target, sweep_dmg, attacker.main_hand_damage_type, attacker);
				broadcast_announce(attacker.name + "'s Sweeping Attack cleaves into " + sweep_target.name + " for " + sweep_dmg + " damage! (" + attacker.superiority_dice + " dice remain)", false);
			} else {
				broadcast_announce(attacker.name + "'s Sweeping Attack finds no adjacent enemy to cleave. (" + attacker.superiority_dice + " dice remain)", false);
			}
		}

		// Gloom Stalker: +1d8 on first turn (Dread Ambusher)
		if (attacker.class_name == "Ranger" and attacker.subclass == "Gloom Stalker" and !attacker.dread_ambusher_used) {
			int ambush_dmg = random(1, 8);
			bonus += ambush_dmg;
			attacker.dread_ambusher_used = true;
			broadcast_announce(attacker.name + "'s Dread Ambusher deals " + ambush_dmg + " extra damage!", false);
		}

		// Fey Wanderer: +1d4 psychic on first hit per turn
		if (attacker.class_name == "Ranger" and attacker.subclass == "Fey Wanderer" and attacker.is_first_hit_this_turn and is_weapon_attack) {
			int fey_dmg = random(1, 4);
			bonus += fey_dmg;
			broadcast_announce(attacker.name + "'s Dreadful Strikes add " + fey_dmg + " psychic damage!", false);
		}

		// Xanathar's Horizon Walker L3 Planar Warrior (para 2199-2201): "The next
		// time you hit that creature on this turn with a weapon attack, all damage
		// becomes force, and the creature takes an extra 1d8 force. At 11th, 2d8."
		if (attacker.class_name == "Ranger" and attacker.subclass == "Horizon Walker" and is_weapon_attack and attacker.planar_warrior_active) {
			int planar_dmg = random(1, 8);
			if (attacker.level >= 11) planar_dmg += random(1, 8);
			bonus += planar_dmg;
			attacker.planar_warrior_active = false;
			broadcast_announce(attacker.name + "'s Planar Warrior deals " + planar_dmg + " force damage!", false);
		}

		// Xanathar's Monster Slayer L3 Slayer's Prey (para 2241-2243): "The first
		// time each turn that you hit that target with a weapon attack, it takes an
		// extra 1d6 damage from the weapon."
		if (attacker.class_name == "Ranger" and attacker.subclass == "Monster Slayer" and attacker.monster_slayer_prey and attacker.monster_slayer_target == target.id and is_weapon_attack and !attacker.slayer_prey_used_this_turn) {
			attacker.slayer_prey_used_this_turn = true;
			int prey_dmg = random(1, 6);
			bonus += prey_dmg;
			broadcast_announce(attacker.name + "'s Slayer's Prey deals " + prey_dmg + " extra damage!", false);
		}

		// Grave Domain Cleric: Path to the Grave vulnerability is now checked
		// in the main damage resolution path (doubles total_damage before apply_damage).
		// Old wrong +1d8 block removed — see para 794-796.

		// Hexblade: Hexblade's Curse — +Prof damage to cursed target
		if (attacker.class_name == "Warlock" and attacker.subclass == "The Hexblade" and attacker.hexblade_curse_target == target.id) {
			bonus += attacker.proficiency;
			broadcast_announce(attacker.name + "'s Hexblade's Curse adds " + attacker.proficiency + " damage!", false);
		}

		// Circle of Spores Druid: Symbiotic Entity — +1d6 necrotic on melee attacks
		if (attacker.class_name == "Druid" and attacker.subclass == "Circle of Spores" and attacker.symbiotic_entity_active and is_weapon_attack and !attacker.main_hand_is_ranged) {
			int spore_dmg = random(1, 6);
			bonus += spore_dmg;
			broadcast_announce(attacker.name + "'s Symbiotic Entity adds " + spore_dmg + " necrotic damage!", false);
		}

		// Xanathar's College of Swords L3 Blade Flourish (para 586-591) + L14 Master's
		// Flourish (para 594-595): "you can roll a d6 and use it instead of expending
		// a Bardic Inspiration die." 3 variants: Defensive, Slashing, Mobile.
		if (attacker.class_name == "Bard" and attacker.subclass == "College of Swords" and attacker.blade_flourish_active and is_weapon_attack) {
			int fl_die = attacker.masters_flourish_free ? 6 : attacker.bardic_inspiration_grant_die;
			int flourish_dmg = random(1, fl_die);
			bonus += flourish_dmg;
			attacker.blade_flourish_active = false;
			attacker.masters_flourish_free = false;
			string fl_label = fl_die == 6 ? "Master's Flourish" : "Blade Flourish";
			string fl_type = attacker.blade_flourish_type;
			if (fl_type == "defensive") {
				// Xanathar's Defensive Flourish (para 588): "You also add the number
				// rolled to your AC until the start of your next turn."
				attacker.armor_class += flourish_dmg;
				attacker.blade_flourish_ac_bonus = flourish_dmg;
				broadcast_announce(attacker.name + "'s Defensive " + fl_label + " adds " + flourish_dmg + " damage and +" + flourish_dmg + " AC!", false);
			} else if (fl_type == "slashing") {
				// Xanathar's Slashing Flourish (para 590): "damage to the target... and
				// to any other creature of your choice that you can see within 5 feet of you."
				if (@combat != null) {
					for (uint sfi = 0; sfi < combat.combatants.length(); sfi++) {
						combatant@ sf_ct = combat.combatants[sfi];
						if (@sf_ct == null or sf_ct.is_dead or sf_ct.id == attacker.id or sf_ct.id == target.id) continue;
						if (!combat.are_hostile(attacker, sf_ct)) continue;
						if (feet_distance(attacker.x, attacker.y, sf_ct.x, sf_ct.y) <= 5) {
							combat.apply_damage(sf_ct, flourish_dmg, attacker.main_hand_damage_type, attacker);
							broadcast_announce(sf_ct.name + " takes " + flourish_dmg + " slashing flourish damage!", false);
						}
					}
				}
				broadcast_announce(attacker.name + "'s Slashing " + fl_label + " adds " + flourish_dmg + " damage!", false);
			} else if (fl_type == "mobile") {
				// Xanathar's Mobile Flourish (para 592): "You can also push the target up
				// to 5 feet away from you, plus a number of feet equal to the number you
				// roll on that die."
				int push_dist = 5 + flourish_dmg;
				int push_tiles = push_dist / 5;
				if (push_tiles > 0 and @combat != null) {
					float pdx = float(target.x - attacker.x);
					float pdy = float(target.y - attacker.y);
					float plen = sqrt(pdx * pdx + pdy * pdy);
					if (plen > 0.001f) {
						pdx /= plen;
						pdy /= plen;
						int new_x = target.x + int(pdx * push_tiles);
						int new_y = target.y + int(pdy * push_tiles);
						if (new_x < 0) new_x = 0;
						if (new_y < 0) new_y = 0;
						if (new_x > 39) new_x = 39;
						if (new_y > 39) new_y = 39;
						target.x = new_x;
						target.y = new_y;
					}
				}
				broadcast_announce(attacker.name + "'s Mobile " + fl_label + " adds " + flourish_dmg + " damage and pushes " + target.name + " " + push_dist + " ft!", false);
			} else {
				// Default: just damage (backwards compat)
				broadcast_announce(attacker.name + "'s " + fl_label + " adds " + flourish_dmg + " damage!", false);
			}
		}

		// Xanathar's College of Whispers L3 Psychic Blades (para 610-613): "extra
		// 2d6 psychic damage... increasing to 3d6 at 5th level, 5d6 at 10th level,
		// and 8d6 at 15th level." Once per round on your turn.
		if (attacker.class_name == "Bard" and attacker.subclass == "College of Whispers" and attacker.psychic_blades_pending and is_weapon_attack) {
			int pb_dice = 2;
			if (attacker.level >= 15) pb_dice = 8;
			else if (attacker.level >= 10) pb_dice = 5;
			else if (attacker.level >= 5) pb_dice = 3;
			int psychic_dmg = 0;
			for (int pbi = 0; pbi < pb_dice; pbi++) psychic_dmg += random(1, 6);
			bonus += psychic_dmg;
			attacker.psychic_blades_pending = false;
			broadcast_announce(attacker.name + "'s Psychic Blades add " + psychic_dmg + " psychic damage! (" + pb_dice + "d6)", false);
		}

		// Cavalier Unwavering Mark: old +prof bonus removed — retaliation is now a BA attack per source (para 1671-1672)

		// Tasha's Rune Knight L3 Giant's Might (para varies): "one of your attacks
		// can deal an extra 1d6 damage" — scales to 1d8 at L10, 1d10 at L18
		if (attacker.class_name == "Fighter" and attacker.subclass == "Rune Knight" and attacker.giants_might_active and is_weapon_attack and attacker.is_first_hit_this_turn) {
			int gm_die = 6;
			if (attacker.level >= 18) gm_die = 10;
			else if (attacker.level >= 10) gm_die = 8;
			int giant_dmg = random(1, gm_die);
			bonus += giant_dmg;
			broadcast_announce(attacker.name + "'s Giant's Might adds " + giant_dmg + " damage!", false);
		}

		// Valda's Spire Gunslinger L11 Overkill (paras 189-191): "When you deal damage
		// with a Ranged weapon that doesn't add your ability modifier to the roll, you
		// add your ability modifier nonetheless. If you already add your modifier to the
		// damage roll, the target takes an extra 1d8 damage of the weapon's type."
		// Firearms have the Firearm property and don't add ability mod to damage rolls;
		// non-firearm ranged weapons do. We can't yet inspect the Firearm property
		// reliably across the weapon registry, so we apply the +1d8 branch as the safe
		// default for L11 Gunslingers using a ranged weapon (the modifier is already
		// applied to weapon damage in get_damage_modifier_for_attack).
		if (attacker.class_name == "Gunslinger" and attacker.overkill_active and is_weapon_attack and attacker.main_hand_is_ranged) {
			int over_dmg = random(1, 8);
			bonus += over_dmg;
			broadcast_announce(attacker.name + "'s Overkill adds " + over_dmg + " extra damage!", false);
		}

		// Deadeye Sharpshooter's Stance is a prone-benefit feature, not a damage bonus (removed).
		// Eagle Eye (reroll a miss using Risk Die) is handled via a different maneuver flow (TODO).

		// High Roller Liar's Dice is a hidden damage declaration bluff mechanic (not a flat damage bonus).
		// A full implementation would require a player-vs-GM bluff prompt. For now, the maneuver simulates
		// a coin-flip outcome handled in the bonus action handler.

		// Secret Agent License to Kill is LEVEL 14 (not 3) and adds exploding Risk Dice to damage on ranged hit.
		// Level 3 feature is Parting Shot (bonus action attack after Dash/Disengage/Dodge).

		// Trick Shot Ricochet rerolls a missed ranged attack using a Risk Die (handled in roll flow, not here).

		// === Setting subclass damage bonuses (Batch 17) ===

		// Frost Sorcerer: no flat weapon damage bonus in source; features are spell-based (Cryomancy)
		// Desert Soul: no flat weapon damage bonus in source; Sandstorm is a spell-cast rider
		// (removed incorrect flat bonuses)

		// Couatl Herald Fighter: Merciless Strike — once per turn, expend a Mercy Die for radiant damage.
		// L18 Heraldic Enforcer: once per turn without expending, AND can use again with expending.
		if (attacker.class_name == "Fighter" and attacker.subclass == "Couatl Herald" and attacker.is_first_hit_this_turn and is_weapon_attack) {
			bool free_use = attacker.level >= 18;
			bool has_dice = attacker.mercy_dice_current > 0;
			if (free_use or has_dice) {
				int mercy_dmg = random(1, attacker.mercy_die_size);
				bonus += mercy_dmg;
				if (!free_use) {
					attacker.mercy_dice_current--;
					broadcast_announce(attacker.name + "'s Merciless Strike adds " + mercy_dmg + " radiant damage! (Mercy Dice: " + attacker.mercy_dice_current + "/" + attacker.mercy_dice_max + ")", false);
				} else {
					broadcast_announce(attacker.name + "'s Heraldic Enforcer Merciless Strike adds " + mercy_dmg + " radiant damage!", false);
				}
			}
		}

		// Warrior of the Celestial Monk: Soul Strike (L17) adds flat 1d4 radiant; earlier levels use Celestial Emissary (L11+) with Martial Arts die
		if (attacker.class_name == "Monk" and attacker.subclass == "Warrior of the Celestial" and is_weapon_attack) {
			if (attacker.level >= 17) {
				int radiant_dmg = random(1, 4);
				bonus += radiant_dmg;
				broadcast_announce(attacker.name + "'s Soul Strike adds " + radiant_dmg + " radiant damage!", false);
			}
			// Celestial Emissary (L11+) requires advantage and is a limited resource — omitted for now
		}

		// Way of the Aether Monk: Spirit Strike adds force damage scaling with Martial Arts die
		if (attacker.class_name == "Monk" and attacker.subclass == "Way of the Aether" and is_weapon_attack) {
			int ma_die = 4;
			if (attacker.level >= 5) ma_die = 6;
			if (attacker.level >= 11) ma_die = 8;
			if (attacker.level >= 17) ma_die = 10;
			int aether_dmg = random(1, ma_die);
			bonus += aether_dmg;
			broadcast_announce(attacker.name + "'s Spirit Strike adds " + aether_dmg + " force damage!", false);
		}

		// Oath of the Hearth Paladin: Burning Weapon (Channel Divinity) adds +CHA fire damage on weapon attacks while active
		if (attacker.class_name == "Paladin" and attacker.subclass == "Oath of the Hearth" and attacker.oath_of_hearth_active and is_weapon_attack) {
			int cha_bonus = attacker.get_ability_mod(ABILITY_CHA);
			if (cha_bonus > 0) {
				bonus += cha_bonus;
				broadcast_announce(attacker.name + "'s Burning Weapon adds " + cha_bonus + " fire damage!", false);
			}
		}

		// Oath of Zeal Paladin (Grim Hollow): NO flat radiant rider.
		// Actual L3 is Mark of the Heretic Channel Divinity: crit 19+ vs marked target, reaction attack on marked turn start.
		// Flat rider removed. The crit expansion is handled in the attack roll code.

		// Path of the Carrion Raven (Grim Hollow): NO flat necrotic rider exists.
		// Baseline L3 is Feral Celerity (free attack on rage entry), maneuver pool, Carrion Feast optional.
		// Flat rider removed.

		// Misfortune Bringer Rogue (Grim Hollow): NO flat misfortune damage exists.
		// Actual L3 Evil Eye enables Sneak Attack without advantage; misfortune is a jinx point system.
		// Flat rider removed. Sneak Attack already handles its own bonus.

		// Runetagger Rogue: marked target takes bonus damage
		if (attacker.class_name == "Rogue" and attacker.subclass == "Runetagger" and attacker.runetagger_marked and attacker.runetagger_target == target.id and is_weapon_attack) {
			int rune_dmg = random(1, 6);
			bonus += rune_dmg;
			broadcast_announce(attacker.name + "'s Rune Tag adds " + rune_dmg + " force damage!", false);
		}

		// Xanathar's Storm Herald L14 Raging Storm Sea (para 431-432): "When you hit
		// a creature in your aura with an attack, you can use your reaction to force
		// that creature to make a Strength saving throw. On a failed save, the creature
		// is knocked prone, as if struck by a wave."
		if (attacker.class_name == "Barbarian" and attacker.subclass == "Storm Herald" and attacker.level >= 14
			and attacker.storm_aura_active and attacker.storm_aura_damage_type == DMG_LIGHTNING
			and attacker.has_reaction and !attacker.raging_storm_used_this_turn
			and is_weapon_attack and @target != null and !target.is_dead
			and feet_distance(attacker.x, attacker.y, target.x, target.y) <= 10) {
			attacker.has_reaction = false;
			attacker.raging_storm_used_this_turn = true;
			int storm_dc = 8 + attacker.proficiency + attacker.get_ability_mod(ABILITY_CON);
			int str_save = target.apply_indomitable_might(random(1, 20) + target.get_save_bonus(ABILITY_STR), ABILITY_STR);
			if (str_save < storm_dc) {
				target.add_condition(COND_PRONE);
				broadcast_announce(attacker.name + "'s Raging Storm wave knocks " + target.name + " prone!", false);
			} else {
				broadcast_announce(target.name + " withstands the Raging Storm wave.", false);
			}
		}

		// Grim Surgeon Rogue: precision strikes deal bonus damage
		if (attacker.class_name == "Rogue" and attacker.subclass == "Grim Surgeon" and attacker.is_first_hit_this_turn and is_weapon_attack) {
			int surgery_dmg = random(1, 4);
			bonus += surgery_dmg;
			broadcast_announce(attacker.name + "'s Surgical Strike adds " + surgery_dmg + " damage!", false);
		}

		// Inquisition Domain Cleric (Grim Hollow): Witch Hunter's Strike L1 — +1d8 force (+2d8 vs concentrating)
		// Limited to WIS-mod uses per long rest. At L14, doubles to 2d8/3d8.
		if (attacker.class_name == "Cleric" and attacker.subclass == "Inquisition Domain" and attacker.witch_hunter_strikes_remaining > 0 and is_weapon_attack) {
			int base_dice = attacker.level >= 14 ? 2 : 1;
			int concentrating_bonus_dice = attacker.level >= 14 ? 3 : 2;
			int inq_dice = target.is_concentrating ? concentrating_bonus_dice : base_dice;
			int inq_dmg = 0;
			for (int id2 = 0; id2 < inq_dice; id2++) inq_dmg += random(1, 8);
			bonus += inq_dmg;
			attacker.witch_hunter_strikes_remaining--;
			// On concentration break, grant temp HP equal to extra damage
			if (target.is_concentrating) {
				broadcast_announce(attacker.name + "'s Witch Hunter's Strike deals " + inq_dmg + " force damage vs concentration!", false);
				if (attacker.temp_hp < inq_dmg) attacker.temp_hp = inq_dmg;
			} else {
				broadcast_announce(attacker.name + "'s Witch Hunter's Strike deals " + inq_dmg + " force damage!", false);
			}
		}

		// Astral Domain Cleric: psychic damage on weapon strikes
		if (attacker.class_name == "Cleric" and attacker.subclass == "Astral Domain" and attacker.astral_domain_active and is_weapon_attack) {
			int astral_dmg = random(1, 4);
			bonus += astral_dmg;
			broadcast_announce(attacker.name + "'s Astral Power adds " + astral_dmg + " psychic damage!", false);
		}

		// Dirge Singer Bard L3: Broad Inspiration acts passively (see Bardic Inspiration grant path)
		// Dirge Singer L14: Battle Hymn grants +1d4 to allies in 30ft aura
		if (attacker.class_name == "Bard" and attacker.subclass == "College of the Dirge Singer" and attacker.level >= 14 and attacker.battle_hymn_active) {
			// Active passive aura effect applied elsewhere (save/check bonus)
		}

		// Circle of Sea Druid: Wave Strike — cold/lightning bonus on weapon strikes
		if (attacker.class_name == "Druid" and attacker.subclass == "Circle of the Sea" and attacker.sea_circle_active and is_weapon_attack) {
			int wave_dmg = 0;
			for (int wd = 0; wd < attacker.sea_wrath_dice; wd++) wave_dmg += random(1, 6);
			bonus += wave_dmg;
			broadcast_announce(attacker.name + "'s Wrath of the Sea adds " + wave_dmg + " cold damage!", false);
		}

		// Cartographer Artificer: Guided Precision L5 — +INT mod on weapon attacks vs Faerie Fire target OR on cantrip/spell
		// We approximate: +INT mod damage once per turn on any weapon hit
		if (attacker.class_name == "Artificer" and attacker.subclass == "Cartographer" and attacker.level >= 5 and attacker.is_first_hit_this_turn and is_weapon_attack) {
			int cart_dmg = attacker.get_ability_mod(ABILITY_INT);
			if (cart_dmg > 0) {
				bonus += cart_dmg;
				broadcast_announce(attacker.name + "'s Guided Precision adds " + cart_dmg + " damage!", false);
			}
		}

		// Sword Coast: Path of the Battlerager L3 — +3 piercing on successful grapple while raging in spiked armor
		// Approximated as +3 piercing on first hit per turn while raging (since grapple isn't tracked separately)
		if (attacker.class_name == "Barbarian" and attacker.subclass == "Path of the Battlerager" and attacker.raging and is_weapon_attack and !attacker.main_hand_is_ranged and attacker.is_first_hit_this_turn) {
			bonus += 3;
			broadcast_announce(attacker.name + "'s spiked armor adds 3 piercing damage!", false);
		}

		// Sword Coast: Way of the Long Death L3 Touch of Death — temp HP = WIS mod + monk level when reducing to 0 HP
		// (Handled separately when kill occurs; see below or maybe_apply_on_kill_features)

		// Graviturgy L10 Violent Attraction: any Graviturgy wizard within 60ft can add +1d10 weapon-type damage to a hit (reaction)
		// Auto-trigger for AI clarity if uses available
		for (uint vai = 0; vai < combat.combatants.length(); vai++) {
			combatant@ va_wizard = combat.combatants[vai];
			if (@va_wizard == null or va_wizard.is_dead) continue;
			if (va_wizard.class_name != "Wizard" or va_wizard.subclass != "Graviturgy Magic") continue;
			if (va_wizard.level < 10 or va_wizard.violent_attraction_uses <= 0) continue;
			if (va_wizard.is_player == attacker.is_player and va_wizard.id != attacker.id) {
				// Ally wizard within 60ft can boost this attacker's damage
				if (feet_distance(va_wizard.x, va_wizard.y, attacker.x, attacker.y) <= 60 and is_weapon_attack) {
					int va_dmg = random(1, 10);
					bonus += va_dmg;
					va_wizard.violent_attraction_uses--;
					broadcast_announce(va_wizard.name + "'s Violent Attraction adds " + va_dmg + " damage!", false);
					break;
				}
			}
		}

		// Path of the Glacier Barbarian L3 Frostbite: once per turn while raging, Strength-based attack
		// adds 1d6 cold (2d6 at L9, 3d6 at L16) and reduces target speed by 10ft until start of next turn.
		if (attacker.class_name == "Barbarian" and attacker.subclass == "Path of the Glacier" and attacker.raging and attacker.is_first_hit_this_turn and is_weapon_attack and !attacker.main_hand_is_ranged) {
			int glacier_dice = 1;
			if (attacker.level >= 9) glacier_dice = 2;
			if (attacker.level >= 16) glacier_dice = 3;
			int glacier_dmg = 0;
			for (int gd = 0; gd < glacier_dice; gd++) glacier_dmg += random(1, 6);
			bonus += glacier_dmg;
			target.speed = target.speed > 10 ? target.speed - 10 : 0;
			broadcast_announce(attacker.name + "'s Frostbite deals " + glacier_dmg + " cold and slows " + target.name + " by 10ft!", false);
		}

		// Path of the Infernal Barbarian: Hellfire Claw scaling 1d6/1d8/1d10/1d12 once per turn while raging
		if (attacker.class_name == "Barbarian" and attacker.subclass == "Path of the Infernal" and attacker.raging and attacker.is_first_hit_this_turn and is_weapon_attack) {
			int infernal_die = 6;
			if (attacker.level >= 6) infernal_die = 8;
			if (attacker.level >= 10) infernal_die = 10;
			if (attacker.level >= 14) infernal_die = 12;
			int infernal_dmg = random(1, infernal_die);
			bonus += infernal_dmg;
			broadcast_announce(attacker.name + "'s Hellfire Claw adds " + infernal_dmg + " fire damage!", false);
		}

		// College of Requiems Bard (Grim Hollow) Pluck the Heartstrings:
		// Auto-expend a Bardic Inspiration die on weapon hit for necrotic damage equal to die roll.
		if (attacker.class_name == "Bard" and attacker.subclass == "College of Requiems" and attacker.level >= 3 and attacker.bardic_inspiration_uses > 0 and is_weapon_attack) {
			int bi_die = attacker.bardic_inspiration_die > 0 ? attacker.bardic_inspiration_die : 6;
			int requiem_dmg = random(1, bi_die);
			bonus += requiem_dmg;
			attacker.bardic_inspiration_uses--;
			broadcast_announce(attacker.name + " plucks the heartstrings, adding " + requiem_dmg + " necrotic damage! (1 Bardic Inspiration spent)", false);
		}

		// Keeper Domain Cleric L8 - Hobbling Strike (Book of Ebon Tides para 1096):
		// "Once on each of your turns when you hit a creature with a weapon attack, the
		// target must make a Strength saving throw against your spell save DC or be
		// knocked prone. When you reach 14th level, the target's speed is also halved
		// until the start of your next turn." Auto-applies on the first weapon hit per turn.
		if (attacker.class_name == "Cleric" and attacker.subclass == "Keeper Domain" and attacker.level >= 8 and is_weapon_attack and attacker.is_first_hit_this_turn) {
			int hs_dc = 8 + attacker.proficiency + attacker.get_ability_mod(ABILITY_WIS);
			int hs_save = target.apply_indomitable_might(random(1, 20) + target.get_save_bonus(ABILITY_STR), ABILITY_STR);
			if (hs_save < hs_dc) {
				target.add_condition(COND_PRONE);
				if (attacker.level >= 14) {
					target.speed = target.speed / 2;
					broadcast_announce(attacker.name + "'s Hobbling Strike knocks " + target.name + " prone and halves their speed! (save " + hs_save + " vs DC " + hs_dc + ")", true);
				} else {
					broadcast_announce(attacker.name + "'s Hobbling Strike knocks " + target.name + " prone! (save " + hs_save + " vs DC " + hs_dc + ")", true);
				}
			}
		}

		// Umbral Binder Rogue L3 - Shadow Bind cold rider (option 2 of 3):
		// Source para 1215: "When you hit with a melee or ranged weapon attack, you can
		// cause the attack to deal additional cold damage equal to your proficiency bonus.
		// You can use this feature only once on each of your turns."
		if (attacker.class_name == "Rogue" and attacker.subclass == "Umbral Binder" and attacker.shadow_bind_choice == 2 and is_weapon_attack and attacker.is_first_hit_this_turn) {
			int sb_dmg = attacker.proficiency;
			bonus += sb_dmg;
			broadcast_announce(attacker.name + "'s Shadow Bind adds " + sb_dmg + " cold damage.", false);
		}

		// PHB 2024 Monk L5 Stunning Strike (para 5348-5349): "Once per turn when you
		// hit a creature with a Monk weapon or an Unarmed Strike, you can expend 1
		// Focus Point to attempt a stunning strike. The target must make a Constitution
		// saving throw. On a failed save, the target has the Stunned condition until
		// the start of your next turn. On a successful save, the target's Speed is
		// halved until the start of your next turn, and the next attack roll made
		// against the target before then has Advantage."
		// Auto-fires on the first weapon hit per turn for Monks L5+ if they have focus
		// points and haven't used Stunning Strike this turn. Defaults to ON since the
		// alternative would require a per-attack toggle prompt.
		if (attacker.class_name == "Monk" and attacker.level >= 5 and attacker.stunning_strike_available and attacker.focus_points > 0 and is_weapon_attack and (attack_name_is_unarmed(attacker.main_hand) or attacker.main_hand_damage_dice <= 6)) {
			attacker.stunning_strike_available = false;
			attacker.focus_points--;
			int ss_dc = 8 + attacker.proficiency + attacker.get_ability_mod(ABILITY_WIS);
			int ss_save = random(1, 20) + target.get_save_bonus(ABILITY_CON);
			target.stunning_strike_source_id = attacker.id;
			if (ss_save < ss_dc) {
				target.add_condition(COND_STUNNED);
				broadcast_announce(attacker.name + "'s Stunning Strike stuns " + target.name + " until the start of " + attacker.name + "'s next turn! (CON save " + ss_save + " vs DC " + ss_dc + ", 1 focus spent)", true);
			} else {
				// Success rider: speed halved + next attack vs target has Advantage.
				if (target.stunning_strike_speed_orig == 0) target.stunning_strike_speed_orig = target.speed;
				target.speed = target.speed / 2;
				target.stunning_strike_advantage_pending = true;
				broadcast_announce(target.name + " resists " + attacker.name + "'s Stunning Strike but their Speed is halved and the next attack against them has Advantage. (CON save " + ss_save + " vs DC " + ss_dc + ", 1 focus spent)", false);
			}
		}

		// Way of the Prophet Monk L6 - Righteous Strike (Book of Ebon Tides para 1231):
		// "When you hit a target with an unarmed strike, you can spend 1 ki point to cause
		// the attack to deal either radiant (if you are good-aligned or neutral-aligned)
		// or necrotic (if you are evil-aligned) damage equal to your proficiency bonus.
		// You can use this feature only once on each of your turns."
		// Auto-applies if the monk has at least 1 focus point and hasn't used it this turn,
		// since the source ties damage type to alignment which the game doesn't track —
		// defaults to radiant. (Players can disable by emptying their focus pool.)
		if (attacker.class_name == "Monk" and attacker.subclass == "Way of the Prophet" and attacker.level >= 6 and attacker.focus_points > 0 and !attacker.righteous_strike_used_this_turn and is_weapon_attack and attack_name_is_unarmed(attacker.main_hand)) {
			attacker.focus_points--;
			attacker.righteous_strike_used_this_turn = true;
			int prof_dmg = attacker.proficiency;
			bonus += prof_dmg;
			broadcast_announce(attacker.name + "'s Righteous Strike adds " + prof_dmg + " radiant damage! (1 focus spent)", false);
		}

		// Xanathar's Kensei L6 Deft Strike (para 1828-1831): "When you hit a target
		// with a kensei weapon, you can spend 1 ki point to cause the weapon to deal
		// extra damage to the target equal to your Martial Arts die."
		if (attacker.class_name == "Monk" and attacker.subclass == "Way of the Kensei" and attacker.deft_strike_active and !attacker.deft_strike_used_this_turn and attacker.focus_points > 0 and is_weapon_attack) {
			attacker.deft_strike_used_this_turn = true;
			attacker.focus_points--;
			int ma_die = monk_martial_arts_die(attacker);
			int deft_dmg = random(1, ma_die);
			bonus += deft_dmg;
			broadcast_announce(attacker.name + "'s Deft Strike deals " + deft_dmg + " extra damage! (1 Focus Point spent)", false);
		}

		// PHB 2024 Open Hand L17 Quivering Palm (para 5392-5400): "When you hit
		// a creature with an Unarmed Strike, you can spend 4 Focus Points to start
		// imperceptible vibrations in the creature's body." On hit with pending
		// toggle, auto-deduct FP and set vibrations. Only one creature at a time.
		if (attacker.quivering_palm_pending and attacker.focus_points >= 4
			and is_weapon_attack and attack_name_is_unarmed(attacker.main_hand)
			and @target != null and !target.is_dead) {
			attacker.quivering_palm_pending = false;
			attacker.focus_points -= 4;
			// Clear previous vibration target if any
			if (attacker.quivering_palm_target_id != 0) {
				combatant@ old_qp = combat.get_combatant(attacker.quivering_palm_target_id);
				if (@old_qp != null) broadcast_announce("The vibrations in " + old_qp.name + " fade.", false);
			}
			attacker.quivering_palm_target_id = target.id;
			broadcast_announce(attacker.name + " sets Quivering Palm vibrations in " + target.name + "! (4 Focus Points spent, " + attacker.focus_points + " remaining)", true);
		}

		// Xanathar's Kensei L3 Kensei's Shot (para 1814-1817): "You can use a bonus
		// action on your turn to make your ranged attacks with a kensei weapon more
		// deadly. Any target you hit with a ranged attack using a kensei weapon takes
		// an extra 1d4 damage of the weapon's damage type."
		if (attacker.class_name == "Monk" and attacker.subclass == "Way of the Kensei" and attacker.kenseis_shot_active and is_weapon_attack and attacker.main_hand_is_ranged) {
			int shot_dmg = random(1, 4);
			bonus += shot_dmg;
			broadcast_announce(attacker.name + "'s Kensei's Shot adds " + shot_dmg + " extra damage!", false);
		}

		// PHB 2024 Rogue L1 Sneak Attack (para 6537-6540): "Once per turn, you can deal
		// an extra 1d6 damage to one creature you hit with an attack roll if you have
		// Advantage on the roll and the attack uses a Finesse or a Ranged weapon. The
		// extra damage's type is the same as the weapon's type. You don't need Advantage
		// on the attack roll if at least one of your allies is within 5 feet of the
		// target, the ally doesn't have the Incapacitated condition, and you don't have
		// Disadvantage on the attack roll."
		// Damage scales 1d6 -> 10d6 per Rogue Features table (paras 6457-6533).
		if (attacker.class_name == "Rogue" and is_weapon_attack and !attacker.sneak_attack_used_this_turn
			and (attacker.main_hand_finesse or attacker.main_hand_is_ranged)) {
			bool sa_qualifies = false;
			if (had_advantage) {
				sa_qualifies = true;
			} else if (!had_disadvantage) {
				// Look for a non-incapacitated ally within 5 ft of the target.
				for (uint ai = 0; ai < combat.combatants.length(); ai++) {
					combatant@ ally = combat.combatants[ai];
					if (@ally == null or ally.id == attacker.id or ally.is_dead) continue;
					if (ally.is_player != attacker.is_player) continue;
					if (combat.mode == "pvp") continue; // PvP: no allies for SA condition
					if (ally.has_condition(COND_INCAPACITATED)) continue;
					if (feet_distance(ally.x, ally.y, target.x, target.y) <= 5) {
						sa_qualifies = true;
						break;
					}
				}
				// Xanathar's Swashbuckler L3 Rakish Audacity (para 2421-2423):
				// "you don't need advantage [...] if you are within 5 feet of it,
				// no other creature is within 5 feet of you, and you don't have
				// disadvantage on the attack roll."
				if (!sa_qualifies and attacker.subclass == "Swashbuckler" and attacker.level >= 3) {
					bool solo = true;
					for (uint si = 0; si < combat.combatants.length(); si++) {
						combatant@ nearby = combat.combatants[si];
						if (@nearby == null or nearby.id == attacker.id or nearby.id == target.id or nearby.is_dead) continue;
						if (feet_distance(nearby.x, nearby.y, attacker.x, attacker.y) <= 5) {
							solo = false;
							break;
						}
					}
					if (solo and feet_distance(attacker.x, attacker.y, target.x, target.y) <= 5) sa_qualifies = true;
				}
				// Xanathar's Inquisitive L3 Insightful Fighting (para 2336-2339):
				// SA without advantage vs studied target
				if (!sa_qualifies and attacker.subclass == "Inquisitive" and attacker.inquisitive_target == target.id) {
					sa_qualifies = true;
				}
			}
			if (sa_qualifies) {
				attacker.sneak_attack_used_this_turn = true;
				int sa_dice = (attacker.level + 1) / 2;
				// PHB 2024 Rogue L5 Cunning Strike (para 6553-6560): forgo SA dice for rider effects.
				// DC = 8 + DEX mod + Proficiency Bonus.
				int cs_dice_cost = 0;
				string cs_eff1 = attacker.cunning_strike_effect;
				string cs_eff2 = attacker.cunning_strike_effect2;
				if (attacker.level >= 5 and cs_eff1 != "") {
					// Calculate dice cost for chosen effects
					if (cs_eff1 == "poison" or cs_eff1 == "trip" or cs_eff1 == "withdraw") cs_dice_cost += 1;
					else if (cs_eff1 == "daze") cs_dice_cost += 2;
					else if (cs_eff1 == "obscure") cs_dice_cost += 3;
					else if (cs_eff1 == "knockout") cs_dice_cost += 6;
					// L11 Improved Cunning Strike: second effect
					if (attacker.level >= 11 and cs_eff2 != "") {
						if (cs_eff2 == "poison" or cs_eff2 == "trip" or cs_eff2 == "withdraw") cs_dice_cost += 1;
						else if (cs_eff2 == "daze") cs_dice_cost += 2;
						else if (cs_eff2 == "obscure") cs_dice_cost += 3;
						else if (cs_eff2 == "knockout") cs_dice_cost += 6;
					}
					// Must have enough dice remaining (at least 1 after cost)
					if (cs_dice_cost >= sa_dice) {
						broadcast_announce(attacker.name + " doesn't have enough Sneak Attack dice for Cunning Strike (" + cs_dice_cost + "d6 cost, only " + sa_dice + "d6 available).", false);
						cs_eff1 = ""; cs_eff2 = "";
						cs_dice_cost = 0;
					} else {
						sa_dice -= cs_dice_cost;
					}
				} else {
					cs_eff1 = ""; cs_eff2 = "";
				}
				// Clear toggle after use
				attacker.cunning_strike_effect = "";
				attacker.cunning_strike_effect2 = "";
				int sa_bonus = 0;
				for (int sd = 0; sd < sa_dice; sd++) sa_bonus += random(1, 6);
				bonus += sa_bonus;
				if (cs_dice_cost > 0) {
					broadcast_announce(attacker.name + "'s Sneak Attack deals " + sa_bonus + " extra damage! (" + sa_dice + "d6, " + cs_dice_cost + "d6 forfeited for Cunning Strike)", true);
				} else {
					broadcast_announce(attacker.name + "'s Sneak Attack deals " + sa_bonus + " extra damage! (" + sa_dice + "d6)", true);
				}
				// Apply Cunning Strike effects after damage (para 6553: "occurs immediately after the attack's damage is dealt")
				if (cs_eff1 != "" or cs_eff2 != "") {
					int cs_dc = 8 + attacker.get_ability_mod(ABILITY_DEX) + attacker.proficiency;
					// Apply each effect
					for (int csi = 0; csi < 2; csi++) {
						string eff = (csi == 0) ? cs_eff1 : cs_eff2;
						if (eff == "") continue;
						if (eff == "poison") {
							// Para 6555: CON save or Poisoned for 1 minute, repeating save at end of turn
							int save_roll = random(1, 20) + target.get_ability_mod(ABILITY_CON);
							if (save_roll < cs_dc) {
								target.add_condition(COND_POISONED);
								broadcast_announce(attacker.name + "'s Cunning Strike poisons " + target.name + "! (DC " + cs_dc + ", rolled " + save_roll + ")", true);
							} else {
								broadcast_announce(target.name + " resists the Cunning Strike poison! (DC " + cs_dc + ", rolled " + save_roll + ")", false);
							}
						} else if (eff == "trip") {
							// Para 6557: DEX save or Prone (Large or smaller)
							if (target.size <= SIZE_LARGE) {
								int save_roll = random(1, 20) + target.get_ability_mod(ABILITY_DEX);
								if (save_roll < cs_dc) {
									target.add_condition(COND_PRONE);
									broadcast_announce(attacker.name + "'s Cunning Strike trips " + target.name + "! (DC " + cs_dc + ", rolled " + save_roll + ")", true);
								} else {
									broadcast_announce(target.name + " resists the Cunning Strike trip! (DC " + cs_dc + ", rolled " + save_roll + ")", false);
								}
							} else {
								broadcast_announce(target.name + " is too large to trip!", false);
							}
						} else if (eff == "withdraw") {
							// Para 6558: move up to half speed without provoking OAs
							int half_speed = attacker.speed / 2;
							attacker.movement_remaining += half_speed;
							broadcast_announce(attacker.name + " withdraws " + half_speed + " ft after the strike!", false);
						} else if (eff == "daze") {
							// Para 6564 (L14 Devious Strikes): CON save or can only move/action/BA on next turn
							int save_roll = random(1, 20) + target.get_ability_mod(ABILITY_CON);
							if (save_roll < cs_dc) {
								target.cunning_strike_dazed = true;
								target.cunning_strike_dazed_rounds = 1;
								broadcast_announce(attacker.name + "'s Cunning Strike dazes " + target.name + "! (can only move OR act next turn, DC " + cs_dc + ", rolled " + save_roll + ")", true);
							} else {
								broadcast_announce(target.name + " resists the Cunning Strike daze! (DC " + cs_dc + ", rolled " + save_roll + ")", false);
							}
						} else if (eff == "knockout") {
							// Para 6566: CON save or Unconscious for 1 minute (repeating save at end of turn)
							int save_roll = random(1, 20) + target.get_ability_mod(ABILITY_CON);
							if (save_roll < cs_dc) {
								target.add_condition(COND_UNCONSCIOUS);
								broadcast_announce(attacker.name + "'s Cunning Strike knocks out " + target.name + "! (DC " + cs_dc + ", rolled " + save_roll + ")", true);
							} else {
								broadcast_announce(target.name + " resists the Cunning Strike knockout! (DC " + cs_dc + ", rolled " + save_roll + ")", false);
							}
						} else if (eff == "obscure") {
							// Para 6568: DEX save or Blinded until end of target's next turn
							int save_roll = random(1, 20) + target.get_ability_mod(ABILITY_DEX);
							if (save_roll < cs_dc) {
								target.add_condition(COND_BLINDED);
								broadcast_announce(attacker.name + "'s Cunning Strike blinds " + target.name + "! (DC " + cs_dc + ", rolled " + save_roll + ")", true);
							} else {
								broadcast_announce(target.name + " resists the Cunning Strike blinding! (DC " + cs_dc + ", rolled " + save_roll + ")", false);
							}
						}
					}
				}
				// Xanathar's Inquisitive L17 Eye for Weakness (para 2344-2345):
				// "your Sneak Attack damage against the creature is increased by 3d6"
				if (attacker.subclass == "Inquisitive" and attacker.level >= 17
					and attacker.inquisitive_target == target.id) {
					int efw_bonus = 0;
					for (int ef = 0; ef < 3; ef++) efw_bonus += random(1, 6);
					bonus += efw_bonus;
					broadcast_announce(attacker.name + "'s Eye for Weakness deals " + efw_bonus + " extra damage! (3d6)", false);
				}
				// Tasha's Phantom L3 Wails from the Grave (para 3454-3457): "Immediately
				// after you deal your Sneak Attack damage to a creature on your turn, you
				// can target a second creature within 30 feet of the first creature. Roll
				// half the number of Sneak Attack dice (round up)." Necrotic damage.
				if (attacker.subclass == "Phantom" and attacker.wails_from_grave_uses > 0) {
					int wail_dice = (sa_dice + 1) / 2;
					// Auto-select nearest enemy within 30ft of target
					combatant@ wail_target = null;
					float wail_best = 999;
					for (uint wi = 0; wi < combat.combatants.length(); wi++) {
						combatant@ wt = combat.combatants[wi];
						if (@wt == null or wt.is_dead or wt.id == target.id) continue;
						if (wt.is_player == attacker.is_player) continue; // Must be enemy
						float wd = feet_distance(target.x, target.y, wt.x, wt.y);
						if (wd <= 30 and wd < wail_best) { wail_best = wd; @wail_target = wt; }
					}
					if (@wail_target != null) {
						attacker.wails_from_grave_uses--;
						int wail_dmg = 0;
						for (int wd = 0; wd < wail_dice; wd++) wail_dmg += random(1, 6);
						// L17 Death's Friend (para 3470-3474): necrotic also hits first target
						if (attacker.level >= 17) {
							combat.apply_damage(target, wail_dmg, DMG_NECROTIC, attacker);
							broadcast_announce(attacker.name + "'s Wails from the Grave deal " + wail_dmg + " necrotic to " + target.name + " and " + wail_target.name + "! (" + attacker.wails_from_grave_uses + " uses remain)", true);
						} else {
							broadcast_announce(attacker.name + "'s Wails from the Grave deal " + wail_dmg + " necrotic to " + wail_target.name + "! (" + attacker.wails_from_grave_uses + " uses remain)", true);
						}
						combat.apply_damage(wail_target, wail_dmg, DMG_NECROTIC, attacker);
					}
				}
			}
		}

		// Scout Rogue: Skirmisher (handled via movement system, just notes)
		// Swashbuckler Rogue: Fancy Footwork — mark target as attacked (prevents OA)
		if (attacker.class_name == "Rogue" and attacker.subclass == "Swashbuckler") {
			target.swashbuckler_attacked_this_turn = true;
		}

		// Samurai: Fighting Spirit (advantage handled in advantage check; temp HP gained on activation)
		// Handled via bonus action

		// Xanathar's Scout L13 Ambush Master (para 2399): "the first creature you hit
		// during the first round of a combat becomes easier for you and others to strike;
		// attack rolls against that target have advantage until the start of your next turn."
		if (attacker.class_name == "Rogue" and attacker.subclass == "Scout" and attacker.level >= 13
			and combat.round_number == 1 and target.ambush_master_marked_by == 0) {
			target.ambush_master_marked_by = attacker.id;
			broadcast_announce(attacker.name + "'s Ambush Master marks " + target.name + "! All attacks have advantage against them.", false);
		}

		// PHB 2024 Eldritch Invocation: Lifedrinker (para 7801-7803): "Once per turn
		// when you hit a creature with your pact weapon, you can deal an extra 1d6
		// Necrotic damage to the creature, and you can expend one of your Hit Point
		// Dice to roll it and regain HP equal to roll + CON mod (min 1)."
		if (attacker.lifedrinker and attacker.pact_of_the_blade and is_weapon_attack
			and !attacker.lifedrinker_used_this_turn and !target.is_dead) {
			attacker.lifedrinker_used_this_turn = true;
			int ld_dmg = random(1, 6);
			bonus += ld_dmg;
			// HP recovery: expend a Hit Die (d8 for Warlock) + CON mod
			int con_mod = attacker.get_ability_mod(ABILITY_CON);
			int ld_heal = random(1, 8) + con_mod;
			if (ld_heal < 1) ld_heal = 1;
			attacker.current_hp += ld_heal;
			if (attacker.current_hp > attacker.max_hp) attacker.current_hp = attacker.max_hp;
			broadcast_announce(attacker.name + "'s Lifedrinker deals " + ld_dmg + " necrotic damage and heals " + ld_heal + " HP!", false);
		}

		// Basic Rules 2024 Conjure Minor Elementals: +2d8 elemental damage on attack hits
		// within 15ft caster-centered emanation. +2d8 per upcast level above 4.
		if (attacker.conjure_minor_elementals_active and attacker.conjure_minor_elementals_slot_level > 0) {
			int dist_to_target = feet_distance(attacker.x, attacker.y, target.x, target.y);
			if (dist_to_target <= 15) {
				int cme_dice = 2 + 2 * (attacker.conjure_minor_elementals_slot_level - 4);
				if (cme_dice < 2) cme_dice = 2;
				int cme_dmg = 0;
				for (int d = 0; d < cme_dice; d++) cme_dmg += random(1, 8);
				bonus += cme_dmg;
				broadcast_announce(attacker.name + "'s elemental spirits deal " + cme_dmg + " extra damage!", false);
			}
		}

		// PHB 2024 Eldritch Invocation: Eldritch Smite (para 7766-7768): "Once per turn
		// when you hit a creature with your pact weapon, you can expend a Pact Magic spell
		// slot to deal an extra 1d8 Force damage, plus 1d8 per level of the spell slot,
		// and give the target the Prone condition if Huge or smaller."
		// Auto-applied for bots/NPCs only. Real players get a smite prompt (like Divine Smite).
		if (attacker.eldritch_smite and attacker.pact_of_the_blade and is_weapon_attack
			and !attacker.eldritch_smite_used_this_turn and !target.is_dead
			and (!attacker.is_player or combatant_is_controlled_by_bot(attacker))) {
			// Find highest available spell slot (Pact Magic)
			int smite_slot = -1;
			for (int sl = 5; sl >= 1; sl--) {
				if (attacker.spell_slots_current[sl] > 0) { smite_slot = sl; break; }
			}
			// Bots/NPCs auto-smite with highest available slot
			if (smite_slot > 0) {
				attacker.eldritch_smite_used_this_turn = true;
				attacker.spell_slots_current[smite_slot]--;
				int smite_dice = 1 + smite_slot; // 1d8 base + 1d8 per slot level
				int smite_dmg = 0;
				for (int sd = 0; sd < smite_dice; sd++) smite_dmg += random(1, 8);
				bonus += smite_dmg;
				broadcast_announce(attacker.name + "'s Eldritch Smite deals " + smite_dmg + " force damage! (slot level " + smite_slot + ")", true);
				if (target.size <= SIZE_HUGE and !target.has_condition(COND_PRONE)) {
					target.add_condition(COND_PRONE);
					broadcast_announce(target.name + " is knocked prone by the Eldritch Smite!", true);
				}
			}
		}

		// Mark first hit used
		if (bonus > 0 or is_weapon_attack) {
			attacker.is_first_hit_this_turn = false;
		}

		return bonus;
	}

	void finalize_roll_result(pending_roll@ pr, int natural_roll, int bless_bonus = 0, int bardic_bonus = 0) {
		if (@pr == null or @combat == null) return;
		combatant@ c = combat.get_combatant(pr.combatant_id);
		if (@c == null) return;

		int total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
		int reported_modifier = pr.modifier + bless_bonus + bardic_bonus;

		// Heroic Inspiration: grant on natural 20 for any d20 roll (players only)
		if (natural_roll == 20 and c.is_player and !c.has_heroic_inspiration and pr.roll_type != ROLL_DAMAGE) {
			c.has_heroic_inspiration = true;
			broadcast_announce(c.name + " earns Heroic Inspiration!", false);
		}

		// Basic Rules 2024 Guidance (para 13659): "Once before the spell ends, the
		// target can add 1d4 to one ability check. The spell then ends."
		// Single-use: adds 1d4 and immediately clears the flag.
		if (c.guidance_active and pr.roll_type == ROLL_ABILITY_CHECK) {
			int guidance_bonus = random(1, 4);
			total += guidance_bonus;
			reported_modifier += guidance_bonus;
			c.guidance_active = false;
			broadcast_announce(c.name + "'s Guidance adds +" + guidance_bonus + " to the ability check.", false);
		}

		// Basic Rules 2024 Glibness (para 13139-13144): "when you make a Charisma
		// check, you can replace the number you roll with a 15." Applies to ALL CHA
		// checks, not just specific skills. Clamps BEFORE Silver Tongue.
		if (c.glibness_active and pr.roll_type == ROLL_ABILITY_CHECK and pr.ability_id == ABILITY_CHA and natural_roll < 15) {
			broadcast_announce(c.name + "'s Glibness replaces the " + natural_roll + " with a 15.", false);
			natural_roll = 15;
			total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
		}
		// Silver Tongue (College of Eloquence Bard L3, Tasha's para 1696):
		// "When you make a Charisma (Persuasion) or Charisma (Deception) check, you can
		// treat a d20 roll of 9 or lower as a 10."
		// Clamps the natural roll BEFORE total recalc so a sub-10 roll becomes 10.
		if (c.silver_tongue_active and pr.roll_type == ROLL_ABILITY_CHECK and natural_roll < 10) {
			if (pr.resolution_tag == "skill_persuasion" or pr.resolution_tag == "skill_deception") {
				broadcast_announce(c.name + "'s Silver Tongue treats the " + natural_roll + " as a 10.", false);
				natural_roll = 10;
				total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
			}
		}
		// Tasha's Circle of Stars L2 Starry Form — Dragon (para 2161-2168): "When you
		// make an Intelligence or a Wisdom check or a Constitution saving throw to
		// maintain concentration on a spell, you can treat a roll of 9 or lower as a 10."
		if (c.starry_form_active and c.starry_form_type == "Dragon" and natural_roll < 10) {
			bool dragon_applies = false;
			if (pr.roll_type == ROLL_ABILITY_CHECK and (pr.ability_id == ABILITY_INT or pr.ability_id == ABILITY_WIS)) dragon_applies = true;
			if (pr.roll_type == ROLL_CONCENTRATION) dragon_applies = true;
			if (dragon_applies) {
				broadcast_announce(c.name + "'s Dragon constellation treats the " + natural_roll + " as a 10.", false);
				natural_roll = 10;
				total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
			}
		}
		// Tasha's Clockwork Soul L14 Trance of Order (para 4001-4003): "whenever you
		// make an attack roll, an ability check, or a saving throw, you can treat a
		// roll of 9 or lower on the d20 as a 10."
		if (c.trance_of_order_active and natural_roll < 10) {
			broadcast_announce(c.name + "'s Trance of Order treats the " + natural_roll + " as a 10.", false);
			natural_roll = 10;
			total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
		}
		// PHB 2024 Barbarian L18 Indomitable Might (para 2354-2355): "If your total for
		// a Strength check or Strength saving throw is less than your Strength score,
		// you can use that score in place of the total." Applied to STR ability checks
		// here; STR saving throws are inline and clamp at their call sites.
		if (c.class_name == "Barbarian" and c.level >= 18 and pr.roll_type == ROLL_ABILITY_CHECK and pr.ability_id == ABILITY_STR) {
			int str_score = c.ability_scores[ABILITY_STR];
			if (total < str_score) {
				broadcast_announce(c.name + "'s Indomitable Might raises the total from " + total + " to " + str_score + ".", false);
				total = str_score;
			}
		}
		// PHB 2024 Rogue L7 Reliable Talent (para 6565-6566): "Whenever you make an
		// ability check that uses one of your skill or tool proficiencies, you can
		// treat a d20 roll of 9 or lower as a 10." Applies to ANY skill check where
		// the rogue is proficient, broader than Silver Tongue which only hits
		// Persuasion/Deception. (Source table line 6480 places this at L7 — was
		// gated to L11 in the legacy code carrying a 2014 mechanic.)
		if (c.reliable_talent_active and pr.roll_type == ROLL_ABILITY_CHECK and natural_roll < 10) {
			// Extract skill name from resolution_tag ("skill_stealth" -> "Stealth")
			if (pr.resolution_tag.find("skill_") == 0) {
				string skill_key = pr.resolution_tag.substr(6);
				// Check if the rogue has proficiency in any skill matching this tag
				bool has_prof = false;
				for (uint si = 0; si < c.skill_proficiencies.length(); si++) {
					string canonical_tag = skill_resolution_tag(c.skill_proficiencies[si]).substr(6);
					if (canonical_tag == skill_key) { has_prof = true; break; }
				}
				if (has_prof) {
					broadcast_announce(c.name + "'s Reliable Talent treats the " + natural_roll + " as a 10.", false);
					natural_roll = 10;
					total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
				}
			}
		}

		// PHB 2024 Forge Artificer L7 Flash of Genius (paras 655-657): for failed ability
		// checks routed through the pending_roll system (skill checks, hide, etc.) — try
		// to grant a +INT mod bonus from any nearby L7+ Artificer with the reaction and
		// uses available. Smart-spend: only fires if it would turn the failure into a success.
		if (pr.roll_type == ROLL_ABILITY_CHECK and pr.dc > 0 and total < pr.dc) {
			int new_total = try_flash_of_genius(c, pr.dc, total, pr.reason);
			if (new_total > total) {
				reported_modifier += (new_total - total);
				total = new_total;
			}
		}

		// Valda's Spire Gunslinger maneuver Maverick Spirit (paras 215-216): for failed
		// INT/WIS/CHA ability checks routed through the pending_roll system, the Gunslinger
		// can expend a Risk Die to add it to the roll. Smart-spend handled in helper.
		if (pr.roll_type == ROLL_ABILITY_CHECK and pr.dc > 0 and total < pr.dc and (pr.ability_id == ABILITY_INT or pr.ability_id == ABILITY_WIS or pr.ability_id == ABILITY_CHA)) {
			int ms_total = try_maverick_spirit(c, pr.dc, total, pr.reason);
			if (ms_total > total) {
				reported_modifier += (ms_total - total);
				total = ms_total;
			}
		}

		// PHB 2024 Cleric L1 Divine Order — Thaumaturge (para 3603): "your mystical
		// connection to the divine gives you a bonus to your Intelligence (Arcana or
		// Religion) checks. The bonus equals your Wisdom modifier (minimum of +1)."
		if (c.class_name == "Cleric" and c.divine_order == "thaumaturge" and pr.roll_type == ROLL_ABILITY_CHECK) {
			if (pr.resolution_tag == "skill_arcana" or pr.resolution_tag == "skill_religion") {
				int thaum_bonus = c.get_ability_mod(ABILITY_WIS);
				if (thaum_bonus < 1) thaum_bonus = 1;
				total += thaum_bonus;
				reported_modifier += thaum_bonus;
				broadcast_announce(c.name + "'s Thaumaturge Divine Order adds +" + thaum_bonus + " to the check.", false);
			}
		}

		// PHB 2024 Druid L1 Primal Order — Magician (para 4389): "your mystical connection
		// to nature gives you a bonus to your Intelligence (Arcana or Nature) checks. The
		// bonus equals your Wisdom modifier (minimum bonus of +1)."
		if (c.class_name == "Druid" and c.primal_order == "magician" and pr.roll_type == ROLL_ABILITY_CHECK) {
			if (pr.resolution_tag == "skill_arcana" or pr.resolution_tag == "skill_nature") {
				int mag_bonus = c.get_ability_mod(ABILITY_WIS);
				if (mag_bonus < 1) mag_bonus = 1;
				total += mag_bonus;
				reported_modifier += mag_bonus;
				broadcast_announce(c.name + "'s Magician Primal Order adds +" + mag_bonus + " to the check.", false);
			}
		}

		if (pr.roll_type == ROLL_INITIATIVE) {
			if (!initiative_phase) return; // Guard against stale/duplicate initiative rolls
			c.initiative_roll = total;
			// Don't broadcast individual rolls here - they chain too fast
			// for TTS when monsters auto-roll. finish_initiative() announces
			// all rolls and turn order in a single clear summary.
			broadcast_to_battle({{"type", message_types::roll_result}, {"natural", natural_roll}, {"total", total}, {"outcome", ""}});
			initiative_index++;
			request_next_initiative();
		}

		else if (pr.roll_type == ROLL_ATTACK) {
			combatant@ target = combat.get_combatant(pr.target_id);
			if (@target == null) return;

			// PHB 2024 Mobile feat (para 7635): track melee attack targets for per-creature OA immunity.
			if (pr.is_weapon_attack and !c.main_hand_is_ranged and c.has_feat("mobile")) {
				bool already_tracked = false;
				for (uint mi = 0; mi < c.mobile_attacked_ids.length(); mi++) {
					if (c.mobile_attacked_ids[mi] == target.id) { already_tracked = true; break; }
				}
				if (!already_tracked) c.mobile_attacked_ids.insert_last(target.id);
			}

			int crit_threshold = get_critical_threshold(c, pr);
			bool is_crit = (natural_roll >= crit_threshold);
			bool is_fumble = (natural_roll == 1);
			bool hit = false;
			string outcome = "";

			// Assassin: auto-crit on hit during first round
			if (!is_fumble and c.subclass == "Assassin" and c.assassinate_available and @combat != null and combat.round_number <= 1) {
				if (natural_roll >= crit_threshold or total >= target.armor_class) {
					is_crit = true;
					hit = true;
					outcome = "Critical hit! Assassinate!";
					broadcast_announce(c.name + "'s Assassinate turns the hit into a critical!", false);
				}
			}

			// PHB 2024 Paralyzed (para 16232) / Unconscious (para 16251): "Any attack
			// that hits the creature is a Critical Hit if the attacker is within 5 feet."
			if (!is_fumble and !is_crit and pr.is_weapon_attack) {
				int tgt_dist = feet_distance(c.x, c.y, target.x, target.y);
				if (tgt_dist <= 5 and (target.has_condition(COND_PARALYZED) or target.has_condition(COND_UNCONSCIOUS))) {
					is_crit = true;
				}
			}

			// Sacred Weapon: add CHA mod to attack roll for Devotion Paladin
			if (c.sacred_weapon_active and !is_fumble) {
				int cha_bonus = c.get_ability_mod(ABILITY_CHA);
				if (cha_bonus > 0) {
					total += cha_bonus;
					reported_modifier += cha_bonus;
				}
			}

			// Precision Attack: add superiority die to attack roll
			if (c.precision_attack_pending and c.superiority_dice > 0) {
				int precision_bonus = random(1, 8);
				total += precision_bonus;
				reported_modifier += precision_bonus;
				c.superiority_dice--;
				c.precision_attack_pending = false;
				broadcast_announce(c.name + "'s Precision Attack adds " + precision_bonus + " to the attack roll! (" + c.superiority_dice + " superiority dice remain)", false);
			}

			// Oath of Conquest Paladin: Guided Strike — +10 to attack roll
			if (c.guided_strike_pending) {
				total += 10;
				reported_modifier += 10;
				c.guided_strike_pending = false;
				broadcast_announce(c.name + "'s Guided Strike adds +10 to the attack roll!", false);
			}
			// PHB 2024 Barbarian L13 Sundering Blow (para 2347): next attack by ANOTHER creature
			// against the target gains +5. Consume on use.
			if (target.sundering_blow_target_active and target.sundering_blow_target_id != c.id) {
				total += 5;
				reported_modifier += 5;
				target.sundering_blow_target_active = false;
				target.sundering_blow_target_id = 0;
				broadcast_announce(c.name + " exploits the Sundering Blow for +5 to hit " + target.name + "!", false);
			}

			if (is_crit) {
				hit = true;
				if (outcome == "") outcome = "Critical hit!";
			} else if (is_fumble) {
				hit = false;
				outcome = "Miss!";
			} else {
				hit = total >= target.armor_class;
				outcome = hit ? "Hit!" : "Miss! Needed " + target.armor_class + ".";
			}
			if (!hit and !is_fumble and c.has_feat("boon_of_combat_prowess") and !c.combat_prowess_used) {
				hit = true;
				c.combat_prowess_used = true;
				outcome = "Hit! Boon of Combat Prowess turns the miss into a hit.";
			}
			// Valda's Spire Gunslinger Deadeye L3 Eagle Eye (paras 240-241): on miss with
			// a ranged weapon attack, smart-spend one Risk Die to add to the attack roll
			// and potentially turn it into a hit. Helper enforces per-turn flag, ranged
			// weapon, and smart-spend gating.
			if (!hit and !is_fumble and pr.is_weapon_attack and !pr.is_spell_effect) {
				int new_total = try_eagle_eye(c, target, total);
				if (new_total > total) {
					reported_modifier += (new_total - total);
					total = new_total;
					hit = true;
					outcome = "Hit! Eagle Eye turns the miss into a hit.";
				}
			}
			// Valda's Spire Gunslinger Trick Shot L3 Ricochet (paras 442-443): on miss with
			// a ranged weapon attack, smart-spend Bonus Action + Risk Die to reroll. Helper
			// enforces ranged weapon + bonus action availability + smart-spend.
			if (!hit and !is_fumble and pr.is_weapon_attack and !pr.is_spell_effect) {
				int rc_total = try_ricochet(c, target, total, reported_modifier);
				if (rc_total > total) {
					total = rc_total;
					hit = true;
					outcome = "Hit! Ricochet rerolls the miss into a hit.";
				}
			}
			// Valda's Spire Gunslinger Deadeye L14 Focused Shot (paras 252-253): "When you
			// take the Attack action, you can choose to make only one ranged attack roll
			// using a weapon to make a Focused Shot. You have Advantage on this attack roll
			// and, on a hit, score a Critical Hit." Advantage is granted via apply_attack_advantage_state
			// (see hook below). On hit, force critical and consume the flag.
			if (hit and c.focused_shot_pending and pr.is_weapon_attack and c.main_hand_is_ranged) {
				is_crit = true;
				c.focused_shot_pending = false;
				outcome = "Critical hit! Focused Shot.";
				broadcast_announce(c.name + "'s Focused Shot turns the hit into a Critical Hit!", true);
			}
			// Xanathar's Grave Domain L6 Sentinel at Death's Door (para 797-799): "When you
			// or a creature you can see within 30 feet suffers a critical hit, you can use
			// your reaction to turn that hit into a normal hit. Any effects triggered by a
			// critical hit are canceled." Uses = WIS mod per long rest.
			// Auto-resolved: scans for any Grave Cleric within 30 ft with reaction + uses.
			if (is_crit and @combat != null) {
				for (uint sdd = 0; sdd < combat.combatants.length(); sdd++) {
					combatant@ gc = combat.combatants[sdd];
					if (@gc == null or gc.is_dead or gc.id == c.id) continue;
					if (gc.class_name != "Cleric" or gc.subclass != "Grave Domain") continue;
					if (gc.level < 6 or gc.sentinel_at_death_uses <= 0 or !gc.has_reaction) continue;
					float sdx = float(gc.x - target.x);
					float sdy = float(gc.y - target.y);
					float sd_dist = sqrt(sdx * sdx + sdy * sdy) * 5.0f;
					if (sd_dist <= 30) {
						gc.sentinel_at_death_uses--;
						gc.has_reaction = false;
						is_crit = false;
						hit = true;
						outcome = "Hit! (crit negated)";
						broadcast_announce(gc.name + "'s Sentinel at Death's Door negates the critical hit! (" + gc.sentinel_at_death_uses + " uses remaining)", true);
						break;
					}
				}
			}
			// Fighter L13 Studied Attacks (PHB 2024 para 5983): on miss, mark the target
			// so the next attack roll against them gains advantage. The advantage flag is
			// consumed in apply_attack_advantage_state on the next attack.
			if (!hit and c.studied_attacks_active and pr.is_weapon_attack) {
				c.studied_attacks_target_id = target.id;
			}
			// Xanathar's Cavalier L3 Unwavering Mark (para 1669): "When you hit a
			// creature with a melee weapon attack, you can mark the creature until the
			// end of your next turn." Auto-applied on every melee weapon hit.
			if (hit and c.class_name == "Fighter" and c.subclass == "Cavalier" and c.level >= 3 and pr.is_weapon_attack and !c.main_hand_is_ranged and !pr.is_spell_effect) {
				target.marked_by_cavalier_id = c.id;
				c.cavalier_mark_turn_flag = true;
			}
			// Xanathar's Ancestral Guardian L3 Ancestral Protectors (para 389-390):
			// "the first creature you hit with an attack on your turn becomes the target
			// of the warriors." Mark only the FIRST creature hit per turn while raging.
			if (hit and c.class_name == "Barbarian" and c.subclass == "Ancestral Guardian" and c.raging and !c.ancestral_protector_hit_this_turn) {
				target.ancestral_protector_marked_by = c.id;
				c.ancestral_protector_target = int(target.id);
				c.ancestral_protector_hit_this_turn = true;
				broadcast_announce(c.name + "'s ancestral spirits focus on " + target.name + "!", false);
			}

			string attack_reason = pr.attack_name != "" ? pr.attack_name + " attack against " + target.name : "to attack " + target.name;
			broadcast_roll(c.name, attack_reason, natural_roll, reported_modifier, total, outcome);

			// Tasha's Eloquence Unfailing/Infectious Inspiration check
			check_eloquence_inspiration(c, pr, hit, bardic_bonus);

			// Xanathar's Kensei L3 Agile Parry (para 1825): "If you make an unarmed
			// strike as part of the Attack action on your turn and are holding a kensei
			// weapon, you can use it to defend yourself. You gain a +2 bonus to AC
			// until the start of your next turn."
			if (attack_name_is_unarmed(pr.attack_name) and c.class_name == "Monk" and c.subclass == "Kensei" and c.level >= 3 and c.kensei_weapon_active and !c.agile_parry_bonus) {
				c.agile_parry_bonus = true;
				c.armor_class += 2;
				broadcast_announce(c.name + "'s Agile Parry grants +2 AC until the start of their next turn.", false);
			}

			// Xanathar's Drunken Master L6 Redirect Attack (para 1798-1800): "When a
			// creature misses you with a melee attack roll, you can use your reaction
			// and spend 1 ki point to cause that attack to hit one creature of your
			// choice, other than the attacker, that you can see within 5 feet of you."
			// Ki + reaction already consumed in users_dom handler when flag was set.
			if (!hit and !is_fumble and pr.is_weapon_attack and !c.main_hand_is_ranged
				and target.drunken_master_opportunity and !target.is_dead and @combat != null) {
				combatant@ redirect_target = null;
				int best_rt_dist = 999;
				for (uint rti = 0; rti < combat.combatants.length(); rti++) {
					combatant@ rt = combat.combatants[rti];
					if (@rt == null or rt.is_dead or !rt.is_alive() or rt.id == c.id or rt.id == target.id) continue;
					if (!combat.are_hostile(target, rt)) continue;
					int rt_dist = feet_distance(target.x, target.y, rt.x, rt.y);
					if (rt_dist <= 5 and rt_dist < best_rt_dist) {
						best_rt_dist = rt_dist;
						@redirect_target = rt;
					}
				}
				if (@redirect_target != null) {
					target.drunken_master_opportunity = false;
					// Redirected attack auto-hits with the attacker's weapon damage
					int rd_dmg = 0;
					for (int rdi = 0; rdi < c.main_hand_damage_count; rdi++) rd_dmg += random(1, c.main_hand_damage_dice);
					rd_dmg += get_weapon_attack_ability_mod(c);
					if (rd_dmg < 1) rd_dmg = 1;
					combat.apply_damage(redirect_target, rd_dmg, c.main_hand_damage_type, c);
					broadcast_announce(target.name + " redirects the attack! " + c.name + "'s blow strikes " + redirect_target.name + " for " + rd_dmg + " damage! (Redirect Attack)", true);
				} else {
					// No valid target within 5ft to redirect to — flag wasted
					target.drunken_master_opportunity = false;
					broadcast_announce(target.name + " tries to Redirect Attack but no creature is within 5 feet!", false);
				}
			}

			// Valda's Spire Gunslinger maneuver Grazing Shot (paras 213-214): on miss with a
			// ranged weapon attack, expend one Risk Die for risk_die + DEX mod weapon-type damage.
			// "no action required" + "once per turn" — helper handles per-turn flag and Risk Die.
			if (!hit and !is_fumble and pr.is_weapon_attack and !pr.is_spell_effect) {
				int gs_dmg_type = pr.damage_dice_count > 0 ? pr.damage_type : get_attack_damage_type(c, false);
				try_grazing_shot(c, target, gs_dmg_type);
			}

			// PHB 2024 Wizard Evoker L3 Potent Cantrip (para 9259-9260): "When you cast
			// a cantrip at a creature and you miss with the attack roll or the target
			// succeeds on a saving throw against the cantrip, the target takes half the
			// cantrip's damage (if any) but suffers no additional effect from the
			// cantrip." Save-based cantrip path is already covered incidentally by the
			// unconditional half-on-save in resolve_spell_save_damage_roll (line 1872).
			if (!hit and pr.is_spell_effect and pr.spell_uses_attack_roll and c.potent_cantrip_active and c.class_name == "Wizard") {
				spell_def@ pc_spell = get_spell(pr.spell_id);
				if (@pc_spell != null and pc_spell.level == 0 and pr.damage_dice_count > 0 and pr.damage_dice_sides > 0) {
					int pc_total = 0;
					for (int pi = 0; pi < pr.damage_dice_count; pi++) pc_total += random(1, pr.damage_dice_sides);
					pc_total += pr.damage_modifier;
					int pc_half = pc_total / 2;
					if (pc_half < 1) pc_half = 1;
					broadcast_announce(c.name + "'s Potent Cantrip deals " + pc_half + " " + DAMAGE_TYPE_NAMES[pr.damage_type] + " damage to " + target.name + " on the miss.", false);
					combat.apply_damage(target, pc_half, pr.damage_type, c);
					broadcast_to_battle({{"type", message_types::damage_dealt}, {"attacker", c.name}, {"target", target.name}, {"amount", pc_half}, {"damage_type", DAMAGE_TYPE_NAMES[pr.damage_type]}, {"is_crit", false}, {"is_spell", true}});
					if (target.is_dead) {
						broadcast_to_battle({{"type", message_types::creature_died}, {"name", target.name}, {"is_player", target.is_player}, {"killed_by", c.name}, {"was_full_hp", false}, {"was_overkill", false}, {"was_stealth", false}});
					}
				}
			}

			// PHB 2024 Sorcerer L2 Metamagic — Seeking Spell (para 7040): "If you make
			// an attack roll for a spell and miss, you can spend 1 Sorcery Point to reroll
			// the d20, and you must use the new roll." Consumes the metamagic flag.
			if (!hit and !is_fumble and pr.is_spell_effect and pr.spell_uses_attack_roll
				and c.metamagic_seeking_active and !target.is_dead) {
				c.metamagic_seeking_active = false;
				int sk_roll = random(1, 20);
				int sk_total = sk_roll + pr.modifier;
				bool sk_hit = sk_total >= target.armor_class and sk_roll != 1;
				if (sk_roll >= get_critical_threshold(c, pr)) { sk_hit = true; }
				string sk_outcome = sk_hit ? "hits!" : "misses.";
				broadcast_roll(c.name, "Seeking Spell reroll", sk_roll, pr.modifier, sk_total, sk_outcome);
				if (sk_hit) {
					hit = true;
					natural_roll = sk_roll;
					total = sk_total;
					reported_modifier = pr.modifier;
					outcome = sk_outcome;
					is_fumble = false;
					pr.is_crit = (sk_roll >= get_critical_threshold(c, pr));
				}
			}
			// Xanathar's Gloom Stalker L11 Stalker's Flurry (para 2160-2161): "Once on
			// each of your turns when you miss with a weapon attack, you can make another
			// weapon attack as part of the same action."
			if (!hit and !is_fumble and pr.is_weapon_attack and !pr.is_spell_effect and c.stalkers_flurry_active and !c.stalkers_flurry_used_this_turn and !target.is_dead) {
				c.stalkers_flurry_used_this_turn = true;
				broadcast_announce(c.name + "'s Stalker's Flurry! Making another weapon attack.", false);
				int sf_roll = random(1, 20);
				int sf_mod = pr.modifier;
				bool sf_adv = false;
				bool sf_disadv = false;
				float sfdx = float(c.x - target.x);
				float sfdy = float(c.y - target.y);
				int sf_dist = int(sqrt(sfdx * sfdx + sfdy * sfdy) * 5.0f);
				apply_attack_advantage_state(c, target, sf_dist, c.main_hand_is_ranged, sf_adv, sf_disadv, false);
				if (sf_adv and !sf_disadv) { int sf_r2 = random(1, 20); if (sf_r2 > sf_roll) sf_roll = sf_r2; }
				if (sf_disadv and !sf_adv) { int sf_r2 = random(1, 20); if (sf_r2 < sf_roll) sf_roll = sf_r2; }
				int sf_total = sf_roll + sf_mod;
				bool sf_hit = sf_total >= target.armor_class and sf_roll != 1;
				if (sf_roll == 20) sf_hit = true;
				string sf_outcome = sf_hit ? "hits!" : "misses.";
				broadcast_roll(c.name, "Stalker's Flurry attack", sf_roll, sf_mod, sf_total, sf_outcome);
				if (sf_hit) {
					// Queue damage roll for the flurry attack
					pending_roll sf_pr;
					sf_pr.combatant_id = c.id;
					sf_pr.player_username = c.is_player ? c.player_username : c.name;
					sf_pr.roll_type = ROLL_DAMAGE;
					sf_pr.target_id = target.id;
					sf_pr.damage_dice_count = pr.damage_dice_count;
					sf_pr.damage_dice_sides = pr.damage_dice_sides;
					sf_pr.damage_modifier = pr.damage_modifier;
					sf_pr.damage_type = pr.damage_type;
					sf_pr.is_weapon_attack = true;
					sf_pr.is_crit = (sf_roll == 20);
					sf_pr.attack_name = "Stalker's Flurry";
					@current_roll = sf_pr;
					user@ sf_user = find_user_for_combatant(c);
					if (@sf_user == null or sf_user.is_bot or !c.is_player) {
						// Auto-roll for bots/NPCs
						int sf_natural = random(1, sf_pr.damage_dice_sides);
						process_roll_result(sf_natural);
					} else {
						send_roll_request(sf_user, sf_pr);
					}
					return;
				}
			}

			// Xanathar's Arcane Archer L7 Curving Shot (para 1624-1625): "When you
			// make an attack roll with a magic arrow and miss, you can use a bonus
			// action to reroll the attack roll against a different target within 60
			// feet of the original target."
			if (!hit and !is_fumble and pr.is_weapon_attack and c.curving_shot_active and c.has_bonus_action and c.main_hand_is_ranged and !target.is_dead) {
				// Find a different hostile target within 60ft of the original target
				combatant@ curve_target = null;
				int best_curve_dist = 999;
				for (uint csi = 0; csi < combat.combatants.length(); csi++) {
					combatant@ ct = combat.combatants[csi];
					if (@ct == null or ct.is_dead or !ct.is_alive() or ct.id == target.id or ct.id == c.id) continue;
					if (!combat.are_hostile(c, ct)) continue;
					int cdist = feet_distance(target.x, target.y, ct.x, ct.y);
					if (cdist <= 60 and cdist < best_curve_dist) {
						best_curve_dist = cdist;
						@curve_target = ct;
					}
				}
				if (@curve_target != null) {
					c.has_bonus_action = false; // Costs bonus action
					int cs_roll = random(1, 20);
					bool cs_adv = false;
					bool cs_disadv = false;
					int cs_dist = feet_distance(c.x, c.y, curve_target.x, curve_target.y);
					apply_attack_advantage_state(c, curve_target, cs_dist, true, cs_adv, cs_disadv, false);
					if (cs_adv and !cs_disadv) { int r2 = random(1, 20); if (r2 > cs_roll) cs_roll = r2; }
					if (cs_disadv and !cs_adv) { int r2 = random(1, 20); if (r2 < cs_roll) cs_roll = r2; }
					int cs_total = cs_roll + pr.modifier;
					bool cs_hit = cs_total >= curve_target.armor_class and cs_roll != 1;
					if (cs_roll == 20) cs_hit = true;
					string cs_outcome = cs_hit ? "hits!" : "misses.";
					broadcast_announce(c.name + "'s arrow curves toward " + curve_target.name + "!", false);
					broadcast_roll(c.name, "Curving Shot vs " + curve_target.name, cs_roll, pr.modifier, cs_total, cs_outcome);
					if (cs_hit) {
						pending_roll cs_pr;
						cs_pr.combatant_id = c.id;
						cs_pr.player_username = c.is_player ? c.player_username : c.name;
						cs_pr.roll_type = ROLL_DAMAGE;
						cs_pr.target_id = curve_target.id;
						cs_pr.damage_dice_count = pr.damage_dice_count;
						cs_pr.damage_dice_sides = pr.damage_dice_sides;
						cs_pr.damage_modifier = pr.damage_modifier;
						cs_pr.damage_type = pr.damage_type;
						cs_pr.is_weapon_attack = true;
						cs_pr.is_crit = (cs_roll == 20);
						cs_pr.attack_name = "Curving Shot";
						@current_roll = cs_pr;
						user@ cs_user = find_user_for_combatant(c);
						if (@cs_user == null or cs_user.is_bot or !c.is_player) {
							int cs_natural = random(1, cs_pr.damage_dice_sides);
							process_roll_result(cs_natural);
						} else {
							send_roll_request(cs_user, cs_pr);
						}
						return;
					}
				}
			}

			// Xanathar's Kensei L17 Unerring Accuracy (para 1836-1838): "If you miss
			// with an attack roll using a monk weapon on your turn, you can reroll it.
			// You can use this feature only once on each of your turns."
			if (!hit and !is_fumble and pr.is_weapon_attack and !pr.is_spell_effect and c.unerring_accuracy_active and !c.unerring_accuracy_used_this_turn and !target.is_dead) {
				c.unerring_accuracy_used_this_turn = true;
				int ua_roll = random(1, 20);
				int ua_total = ua_roll + pr.modifier;
				if (c.sharpen_the_blade_bonus > 0) ua_total += c.sharpen_the_blade_bonus;
				bool ua_hit = ua_total >= target.armor_class and ua_roll != 1;
				if (ua_roll == 20) ua_hit = true;
				string ua_outcome = ua_hit ? "hits!" : "misses.";
				broadcast_roll(c.name, "Unerring Accuracy reroll", ua_roll, pr.modifier, ua_total, ua_outcome);
				if (ua_hit) {
					hit = true;
					natural_roll = ua_roll;
					total = ua_total;
					reported_modifier = pr.modifier;
					outcome = ua_outcome;
					is_fumble = false;
					pr.is_crit = (ua_roll == 20);
				}
			}

			// Xanathar's Swashbuckler L17 Master Duelist (para 2429-2430): "If you miss
			// with an attack roll, you can roll it again with advantage. Once you do so,
			// you can't use this feature again until you finish a short or long rest."
			if (!hit and !is_fumble and pr.is_weapon_attack and c.master_duelist_active and !c.master_duelist_used and !target.is_dead) {
				c.master_duelist_used = true;
				int md_roll1 = random(1, 20);
				int md_roll2 = random(1, 20);
				int md_roll = md_roll1 > md_roll2 ? md_roll1 : md_roll2; // advantage
				int md_total = md_roll + pr.modifier;
				bool md_hit = md_total >= target.armor_class and md_roll != 1;
				if (md_roll == 20) md_hit = true;
				string md_outcome = md_hit ? "hits!" : "misses.";
				broadcast_roll(c.name, "Master Duelist reroll (advantage)", md_roll, pr.modifier, md_total, md_outcome);
				if (md_hit) {
					hit = true;
					natural_roll = md_roll;
					total = md_total;
					reported_modifier = pr.modifier;
					outcome = md_outcome;
					is_fumble = false;
					pr.is_crit = (md_roll == 20);
				}
			}

			// PHB 2024 Rogue L20 Stroke of Luck (para 6579-6581): "If you fail a
			// D20 Test, you can turn the roll into a 20." 1/SR. Auto-fires on attack
			// miss as a last resort after all other miss-recovery features.
			if (!hit and !is_fumble and c.class_name == "Rogue" and c.stroke_of_luck_available and !target.is_dead) {
				c.stroke_of_luck_available = false;
				natural_roll = 20;
				total = 20 + pr.modifier;
				hit = true;
				pr.is_crit = true;
				outcome = "Critical hit! (Stroke of Luck)";
				broadcast_roll(c.name, "Stroke of Luck turns the miss into a natural 20!", 20, pr.modifier, total, outcome);
			}

			// Xanathar's Cavalier L7 Warding Maneuver (para 1674-1676): "If you or a
			// creature you can see within 5 feet of you is hit by an attack, you can roll
			// 1d8 as a reaction [...] add the number rolled to the target's AC. If the
			// attack still hits, the target has resistance." Auto-resolved for allies.
			if (hit and !is_fumble and @combat != null) {
				for (uint wm = 0; wm < combat.combatants.length(); wm++) {
					combatant@ wmc = combat.combatants[wm];
					if (@wmc == null or wmc.is_dead or wmc.id == target.id) continue; // skip self (self handled in reaction prompt)
					if (wmc.class_name != "Fighter" or wmc.subclass != "Cavalier") continue;
					if (wmc.level < 7 or wmc.warding_maneuver_uses <= 0 or !wmc.has_reaction) continue;
					float wdx = float(wmc.x - target.x);
					float wdy = float(wmc.y - target.y);
					float wm_dist = sqrt(wdx * wdx + wdy * wdy) * 5.0f;
					if (wm_dist > 5) continue;
					int ward_roll = random(1, 8);
					wmc.warding_maneuver_uses--;
					wmc.has_reaction = false;
					if (total < target.armor_class + ward_roll) {
						hit = false;
						outcome = "Miss! (Warding Maneuver +" + ward_roll + " AC)";
						broadcast_announce(wmc.name + "'s Warding Maneuver (+"+ward_roll+" AC) turns the hit on " + target.name + " into a miss!", true);
					} else {
						target.warding_maneuver_resistance = true;
						broadcast_announce(wmc.name + "'s Warding Maneuver (+"+ward_roll+" AC) grants " + target.name + " resistance against the attack!", true);
					}
					break;
				}
			}

			// Reaction prompt: offer defender reactions BEFORE resolving hit
			// Only if: target is a player, has reaction, attack would hit, not a fumble
			if (!is_fumble and target.is_player and target.has_reaction and !target.is_incapacitated_check() and total >= target.armor_class) {
				string[] reaction_options;
				// Shield: caster with Shield in prepared_spells and a spell slot available
				bool has_shield_spell = false;
				for (uint si = 0; si < target.prepared_spells.length(); si++) {
					if (target.prepared_spells[si] == "shield") { has_shield_spell = true; break; }
				}
				if (has_shield_spell) {
					for (int sl = 1; sl <= 9; sl++) {
						if (target.spell_slots_current[sl] > 0) { reaction_options.insert_last("shield"); break; }
					}
				}
				// Cutting Words: Lore Bard with bardic inspiration uses
				if (target.subclass == "College of Lore" and target.bardic_inspiration_uses > 0) {
					reaction_options.insert_last("cutting_words");
				}
				// Warding Flare: Light Domain Cleric with uses remaining
				if (target.subclass == "Light Domain" and target.warding_flare_uses > 0) {
					reaction_options.insert_last("warding_flare");
				}
				// Feat: Defensive Duelist — when wielding a Finesse weapon, reaction gives +Prof to AC
				if (target.has_feat("defensive_duelist") and target.main_hand_finesse and !target.main_hand_is_ranged) {
					reaction_options.insert_last("defensive_duelist");
				}
				// Tasha's Clockwork Soul L1 Restore Balance (para 3993-3996): "When a creature
				// you can see within 60 feet of you is about to roll a d20 with advantage or
				// disadvantage, you can use your reaction to prevent the roll from being
				// affected by advantage and disadvantage." Only offered when attack has advantage.
				if (target.class_name == "Sorcerer" and target.subclass == "Clockwork Sorcery" and target.restore_balance_uses > 0 and has_effective_advantage(@current_roll)) {
					reaction_options.insert_last("restore_balance");
				}
				// Path of the Ancestral Guardian: Spirit Shield reaction — reduce damage
				if (target.class_name == "Barbarian" and target.subclass == "Ancestral Guardian" and target.raging and target.level >= 6) {
					reaction_options.insert_last("spirit_shield");
				}
				// Great Old One Warlock: Entropic Ward — impose disadvantage on attack
				if (target.class_name == "Warlock" and target.subclass == "Great Old One Patron" and target.entropic_ward_pending) {
					reaction_options.insert_last("entropic_ward");
				}
				// War Magic Wizard: Arcane Deflection — reduce damage or save by 4
				if (target.class_name == "Wizard" and target.subclass == "War Magic" and target.arcane_deflection_available) {
					reaction_options.insert_last("arcane_deflection");
				}
				// Xanathar's Cavalier L7 Warding Maneuver (para 1674-1676): self-defense
				if (target.class_name == "Fighter" and target.subclass == "Cavalier" and target.level >= 7 and target.warding_maneuver_uses > 0) {
					reaction_options.insert_last("warding_maneuver");
				}
				// Xanathar's Hexblade L10 Armor of Hexes (para 2792-2793): "If the target
				// cursed by your Hexblade's Curse hits you with an attack roll, you can use
				// your reaction to roll a d6. On a 4 or higher, the attack instead misses you."
				if (target.class_name == "Warlock" and target.subclass == "The Hexblade" and target.armor_of_hexes_active and target.hexblade_curse_target == c.id) {
					reaction_options.insert_last("armor_of_hexes");
				}
				// PHB 2024 Monk L3 Deflect Attacks (para 5337-5339): reduce an attack's
				// total damage by 1d10 + DEX mod + Monk level. Normally restricted to
				// Bludgeoning/Piercing/Slashing damage. L13 Deflect Energy (para 5366)
				// removes the damage-type restriction.
				if (target.class_name == "Monk" and target.level >= 3) {
					int incoming_dmg_type = pr.damage_dice_count > 0 ? pr.damage_type : get_attack_damage_type(c, false);
					bool is_bps = (incoming_dmg_type == DMG_BLUDGEONING or incoming_dmg_type == DMG_PIERCING or incoming_dmg_type == DMG_SLASHING);
					if (is_bps or target.level >= 13) {
						reaction_options.insert_last("deflect_attacks");
					}
				}
				// PHB 2024 Rogue L5 Uncanny Dodge (para 6561-6562): "When an attacker
				// that you can see hits you with an attack roll, you can take a Reaction
				// to halve the attack's damage against you (round down)."
				if (target.class_name == "Rogue" and target.level >= 5 and !target.has_condition(COND_INCAPACITATED)) {
					reaction_options.insert_last("uncanny_dodge");
				}
				// Xanathar's Storm Sorcery L14 Storm's Fury (para 2635-2636): "when you
				// are hit by a melee attack, you can use your reaction to deal lightning
				// damage to the attacker. The damage equals your sorcerer level."
				if (target.storms_fury_active and target.class_name == "Sorcerer" and target.level >= 14 and pr.is_weapon_attack and !c.main_hand_is_ranged) {
					reaction_options.insert_last("storms_fury");
				}
				// Xanathar's Gloom Stalker L15 Shadowy Dodge (para 2162-2163): "Whenever a
				// creature makes an attack roll against you and doesn't have advantage on the
				// roll, you can use your reaction to impose disadvantage on it."
				if (target.shadowy_dodge_active and !has_effective_advantage(@current_roll)) {
					reaction_options.insert_last("shadowy_dodge");
				}
				// Xanathar's Horizon Walker L15 Spectral Defense (para 2208-2209):
				// "When you take damage from an attack, you can use your reaction to
				// give yourself resistance to all of that attack's damage on this turn."
				if (target.spectral_defense_active) {
					reaction_options.insert_last("spectral_defense");
				}

				if (reaction_options.length() > 0) {
					user@ def_user = find_user_for_combatant(target);
					if (@def_user != null and !def_user.is_bot) {
						pending_reaction_prompt rp;
						rp.defender_username = target.player_username;
						rp.attacker_id = c.id;
						rp.defender_id = target.id;
						rp.attack_total = total;
						rp.natural_roll = natural_roll;
						rp.is_crit = is_crit;
						rp.options = reaction_options;
						@rp.attack_roll = pr;
						rp.reported_modifier = reported_modifier;
						@current_reaction_prompt = rp;
						// Build options text
						string opts = "";
						string opts_csv = "";
						for (uint oi = 0; oi < reaction_options.length(); oi++) {
							if (opts != "") opts += ", ";
							if (opts_csv != "") opts_csv += ",";
							opts_csv += reaction_options[oi];
							if (reaction_options[oi] == "shield") opts += "Shield (+5 AC)";
							else if (reaction_options[oi] == "cutting_words") opts += "Cutting Words (-1d" + target.bardic_inspiration_die + ")";
							else if (reaction_options[oi] == "warding_flare") opts += "Warding Flare (reroll attack)";
							else if (reaction_options[oi] == "defensive_duelist") opts += "Defensive Duelist (+" + target.proficiency + " AC)";
							else if (reaction_options[oi] == "restore_balance") opts += "Restore Balance (cancel advantage)";
							else if (reaction_options[oi] == "spirit_shield") opts += "Spirit Shield (reduce damage by 2d6+)";
							else if (reaction_options[oi] == "entropic_ward") opts += "Entropic Ward (force the hit to miss)";
							else if (reaction_options[oi] == "arcane_deflection") opts += "Arcane Deflection (+2 AC)";
							else if (reaction_options[oi] == "warding_maneuver") opts += "Warding Maneuver (+1d8 AC, resistance if still hit)";
						else if (reaction_options[oi] == "armor_of_hexes") opts += "Armor of Hexes (d6, 4+ = miss)";
							else if (reaction_options[oi] == "deflect_attacks") opts += "Deflect Attacks (reduce by 1d10+DEX+level)";
							else if (reaction_options[oi] == "uncanny_dodge") opts += "Uncanny Dodge (halve the damage)";
							else if (reaction_options[oi] == "storms_fury") opts += "Storm's Fury (" + target.level + " lightning damage to attacker + STR save or pushed 20 ft)";
						else if (reaction_options[oi] == "shadowy_dodge") opts += "Shadowy Dodge (impose disadvantage on the attack)";
							else if (reaction_options[oi] == "spectral_defense") opts += "Spectral Defense (resistance to all damage from this attack)";
						}
						def_user.send({{"type", message_types::reaction_prompt}, {"attacker", c.name}, {"options", opts}, {"options_csv", opts_csv}});
						return; // Pause — wait for reaction_response
					}
				}
			}

			if (hit) {
				int dmg_count = pr.damage_dice_count > 0 ? pr.damage_dice_count : get_attack_damage_count(c, false);
				int dmg_sides = pr.damage_dice_sides > 0 ? pr.damage_dice_sides : get_attack_damage_dice(c, false);
				int dmg_mod = pr.damage_dice_count > 0 ? pr.damage_modifier : get_damage_modifier_for_attack(c, false);
				int dmg_type = pr.damage_dice_count > 0 ? pr.damage_type : get_attack_damage_type(c, false);
				string dmg_attack_name = pr.attack_name != "" ? pr.attack_name : get_attack_name(c, false);

				pending_roll dmg_pr;
				dmg_pr.combatant_id = c.id;
				dmg_pr.player_username = c.is_player ? c.player_username : c.name;
				dmg_pr.roll_type = ROLL_DAMAGE;
				dmg_pr.dice_sides = dmg_sides;
				dmg_pr.modifier = dmg_mod;
				dmg_pr.reason = dmg_attack_name + " damage";
				dmg_pr.target_id = target.id;
				dmg_pr.attack_name = dmg_attack_name;
				dmg_pr.attack_index = pr.attack_index;
				dmg_pr.damage_dice_count = dmg_count;
				dmg_pr.damage_dice_sides = dmg_sides;
				dmg_pr.damage_modifier = dmg_mod;
				dmg_pr.damage_type = dmg_type;
				dmg_pr.extra_damage_dice_count = pr.extra_damage_dice_count;
				dmg_pr.extra_damage_dice_sides = pr.extra_damage_dice_sides;
				dmg_pr.extra_damage_modifier = pr.extra_damage_modifier;
				dmg_pr.extra_damage_type = pr.extra_damage_type;
				dmg_pr.is_weapon_attack = pr.is_weapon_attack;
				dmg_pr.is_crit = is_crit;
				dmg_pr.is_spell_effect = pr.is_spell_effect;
				dmg_pr.spell_uses_attack_roll = pr.spell_uses_attack_roll;
				dmg_pr.spell_requires_save = pr.spell_requires_save;
				dmg_pr.spell_id = pr.spell_id;
				dmg_pr.spell_name = pr.spell_name;
				dmg_pr.spell_save_type = pr.spell_save_type;
				dmg_pr.spell_save_dc = pr.spell_save_dc;
				dmg_pr.spell_is_aoe = pr.spell_is_aoe;
				dmg_pr.spell_aoe_radius = pr.spell_aoe_radius;
				dmg_pr.damage_dice_count = is_crit ? dmg_count * 2 : dmg_count;
				dmg_pr.attacks_remaining = pr.attacks_remaining;
				dmg_pr.resolution_tag = pr.resolution_tag;
				dmg_pr.resume_turn_start = pr.resume_turn_start;

				// Divine Smite on-hit prompt: only if Paladin didn't already pre-cast smite via bonus action
				if (c.class_name == "Paladin" and c.is_player and !c.divine_smite_pending and pr.is_weapon_attack and !pr.is_spell_effect and !c.main_hand_is_ranged and get_attack_range(c, false) <= 5) {
					int highest_slot = 0;
					for (int sl = 5; sl >= 1; sl--) {
						if (c.spell_slots_current[sl] > 0) { highest_slot = sl; break; }
					}
					if (highest_slot > 0) {
						user@ su = find_user_for_combatant(c);
						if (@su != null and !su.is_bot) {
							// Pause damage resolution, prompt for smite
							pending_smite_prompt sp;
							sp.player_username = c.player_username;
							@sp.damage_roll = dmg_pr;
							sp.is_crit = is_crit;
							sp.highest_slot = highest_slot;
							sp.smite_type = "divine";
							@current_smite_prompt = sp;
							// Build slot info for prompt
							string slots_info = "";
							for (int sl = 1; sl <= 5; sl++) {
								if (c.spell_slots_current[sl] > 0) {
									int smite_dice = sl + 1;
									if (is_crit) smite_dice *= 2;
									if (slots_info != "") slots_info += ", ";
									slots_info += "Level " + sl + " (" + smite_dice + "d8, " + c.spell_slots_current[sl] + " slots)";
								}
							}
							su.send({{"type", message_types::smite_prompt}, {"slots", slots_info}, {"is_crit", is_crit}, {"target", target.name}, {"smite_type", "divine"}});
							return; // Wait for smite_response before continuing
						}
					}
				}

				// Eldritch Smite on-hit prompt: Warlock with Pact of the Blade + Eldritch Smite invocation
				// Only fires for real players (bots auto-smite above). Skips if Paladin already got Divine Smite prompt.
				if (c.eldritch_smite and c.pact_of_the_blade and c.is_player and pr.is_weapon_attack
					and !pr.is_spell_effect and !c.eldritch_smite_used_this_turn and !target.is_dead) {
					// Check that this player is NOT a Paladin who would have gotten a Divine Smite prompt
					// (Paladin/Warlock multiclass gets Divine Smite first, then Eldritch Smite chains after)
					bool paladin_got_prompt = (c.class_name == "Paladin" and !c.divine_smite_pending
						and !c.main_hand_is_ranged and get_attack_range(c, false) <= 5);
					if (!paladin_got_prompt) {
						int es_highest_slot = 0;
						for (int sl = 5; sl >= 1; sl--) {
							if (c.spell_slots_current[sl] > 0) { es_highest_slot = sl; break; }
						}
						if (es_highest_slot > 0) {
							user@ esu = find_user_for_combatant(c);
							if (@esu != null and !esu.is_bot) {
								// Pause damage resolution, prompt for Eldritch Smite
								pending_smite_prompt esp;
								esp.player_username = c.player_username;
								@esp.damage_roll = dmg_pr;
								esp.is_crit = is_crit;
								esp.highest_slot = es_highest_slot;
								esp.smite_type = "eldritch";
								@current_smite_prompt = esp;
								// Build slot info for prompt
								string es_slots_info = "";
								for (int sl = 1; sl <= 5; sl++) {
									if (c.spell_slots_current[sl] > 0) {
										int es_dice = 1 + sl; // 1d8 base + 1d8 per slot level
										if (is_crit) es_dice *= 2;
										if (es_slots_info != "") es_slots_info += ", ";
										es_slots_info += "Level " + sl + " (" + es_dice + "d8 force + Prone, " + c.spell_slots_current[sl] + " slots)";
									}
								}
								esu.send({{"type", message_types::smite_prompt}, {"slots", es_slots_info}, {"is_crit", is_crit}, {"target", target.name}, {"smite_type", "eldritch"}});
								return; // Wait for smite_response before continuing
							}
						}
					}
				}

				@current_roll = dmg_pr;
				user@ u = find_user_for_combatant(c);
				if (@u != null and !u.is_bot and c.is_player) {
					send_roll_request(u, dmg_pr);
				} else {
					@current_roll = dmg_pr;
					process_roll_result(roll_attack_damage_natural(pr.is_spell_effect ? null : c, dmg_pr));
				}
			}
			else if (pr.is_spell_effect and pr.attacks_remaining > 0) {
				if (start_followup_spell_attack(c, pr, target)) return;
			}
			else if (pr.resolution_tag == "flurry") {
				if (pr.attacks_remaining > 0 and !target.is_dead) {
					start_flurry_strike(c, target, pr.attacks_remaining - 1);
				}
			}
			else if (pr.resolution_tag == "swift_quiver") {
				if (pr.attacks_remaining > 0 and !target.is_dead) {
					start_swift_quiver_strike(c, target, pr.attacks_remaining - 1);
				}
			}
			else if (c.is_player and combatant_is_controlled_by_bot(c)) {
				continue_player_bot_turn_after_attack(c, target);
				if (pr.resolution_tag == "resume_current_turn" and @combat != null and combat.battle_active) {
					resume_current_turn_after_interrupt();
				}
				return;
			}
			else if (!c.is_player) {
				combatant@ next_target = target;
				if ((@next_target == null or next_target.is_dead) and pr.attacks_remaining > 0) {
					@next_target = find_nearest_target_for_monster(c);
				}
				if (pr.attacks_remaining > 0 and @next_target != null and next_target.is_alive()) {
					if (!start_monster_attack_sequence(c, next_target, pr.attack_index + 1, pr.attacks_remaining - 1)) {
						broadcast_announce(c.name + " ends its turn.");
						advance_turn();
					}
				} else {
					broadcast_announce(c.name + " ends its turn.");
					advance_turn();
				}
			}
			// PHB 2024 Weapon Mastery — Graze (para 10339): "If your attack roll with
			// this weapon misses a creature, you can deal damage to that creature equal
			// to the ability modifier you used to make the attack roll."
			if (!hit and !is_fumble and pr.is_weapon_attack and !pr.is_spell_effect
				and c.main_hand_mastery == MASTERY_GRAZE and @target != null and !target.is_dead) {
				int graze_mod = get_weapon_attack_ability_mod(c);
				if (c.main_hand_is_ranged) graze_mod = c.get_ability_mod(ABILITY_DEX);
				if (graze_mod > 0) {
					combat.apply_damage(target, graze_mod, c.main_hand_damage_type, c);
					broadcast_announce(c.name + "'s Graze mastery deals " + graze_mod + " damage to " + target.name + " despite the miss!", false);
				}
			}
			if (!hit) broadcast_state();
			if (pr.resolution_tag == "resume_current_turn" and @combat != null and combat.battle_active) {
				resume_current_turn_after_interrupt();
				return;
			}
			if (pr.resume_turn_start and @combat != null and combat.battle_active) {
				continue_pending_turn_start();
			}
		}

		else if (pr.roll_type == ROLL_DAMAGE) {
			if (pr.is_spell_effect and pr.spell_requires_save) {
				resolve_spell_save_damage_roll(c, pr, natural_roll);
				return;
			}
			combatant@ target = combat.get_combatant(pr.target_id);
			if (@target == null) return;

			int total_damage = natural_roll + pr.damage_modifier;
			if (total_damage < 1) total_damage = 1;

			// Xanathar's Celestial Warlock L6 Radiant Soul (para 2742): +CHA to
			// one fire/radiant spell damage roll per turn.
			if (pr.is_spell_effect and c.subclass == "Celestial Patron" and c.level >= 6 and !c.radiant_soul_used_this_turn) {
				if (pr.damage_type == DMG_FIRE or pr.damage_type == DMG_RADIANT) {
					int rs_cha = c.get_ability_mod(ABILITY_CHA);
					if (rs_cha > 0) {
						total_damage += rs_cha;
						c.radiant_soul_used_this_turn = true;
						broadcast_announce(c.name + "'s Radiant Soul adds +" + rs_cha + " to the spell damage.", false);
					}
				}
			}

			// Valda's Spire Gunslinger High Roller L14 Double or Nothing (paras 269-270):
			// "When you score a Critical Hit using a Ranged weapon, you can gamble for a
			// higher result. Roll a d20. If the roll is a 10 or higher, roll all of the
			// attack's damage dice four times and add them together, instead of only two
			// times as normal for a Critical Hit. If you roll a 9 or lower on the d20,
			// the Critical Hit becomes a normal hit." Auto-fires when the toggle is on:
			// the gamble has positive expected value (avg ≥10 on a d20 = 55% chance) and
			// the upside (4x dice) outweighs the downside (1x dice instead of 2x).
			if (pr.is_crit and c.double_or_nothing_active and pr.is_weapon_attack and c.main_hand_is_ranged and !pr.is_spell_effect and pr.damage_dice_count > 0 and pr.damage_dice_sides > 0) {
				int dn_roll = random(1, 20);
				int base_count = pr.damage_dice_count / 2; // pr.damage_dice_count was doubled at attack-time for the crit
				if (base_count < 1) base_count = 1;
				if (dn_roll >= 10) {
					int extra_dn = 0;
					for (int dni = 0; dni < (2 * base_count); dni++) extra_dn += random(1, pr.damage_dice_sides);
					total_damage += extra_dn;
					broadcast_announce(c.name + "'s Double or Nothing rolls " + dn_roll + "! 4x damage dice — adds " + extra_dn + "!", true);
				} else {
					int new_natural = 0;
					for (int dni = 0; dni < base_count; dni++) new_natural += random(1, pr.damage_dice_sides);
					total_damage = total_damage - natural_roll + new_natural;
					if (total_damage < 1) total_damage = 1;
					pr.is_crit = false;
					broadcast_announce(c.name + "'s Double or Nothing rolls " + dn_roll + "! Critical Hit becomes a normal hit.", true);
				}
			}

			// Add potion damage bonus
			if (c.potion_damage_bonus > 0 and pr.is_weapon_attack) {
				total_damage += c.potion_damage_bonus;
			}
			// PHB 2024 Great Weapon Master (para 7624-7625): "When you hit with a weapon
			// attack using a Heavy weapon you are proficient with, you can deal extra
			// damage equal to your Proficiency Bonus."
			if (!pr.is_spell_effect and pr.is_weapon_attack and c.has_feat("great_weapon_master") and !c.main_hand_is_ranged and weapon_qualifies_great_weapon_fighting(c.main_hand)) {
				total_damage += c.proficiency;
				broadcast_announce(c.name + "'s Great Weapon Master adds +" + c.proficiency + " damage.", false);
			}

			int extra_damage = 0;
			if (pr.extra_damage_dice_count > 0 and pr.extra_damage_dice_sides > 0) {
				int extra_rolls = pr.is_crit ? pr.extra_damage_dice_count * 2 : pr.extra_damage_dice_count;
				for (int edi = 0; edi < extra_rolls; edi++) extra_damage += random(1, pr.extra_damage_dice_sides);
				extra_damage += pr.extra_damage_modifier;
				if (extra_damage < 0) extra_damage = 0;
				total_damage += extra_damage;
			}

			int smite_damage = 0;
			if (!pr.is_spell_effect and c.divine_smite_pending and pr.is_weapon_attack and !c.main_hand_is_ranged and get_attack_range(c, false) <= 5) {
				int smite_dice = c.divine_smite_slot_level + 1;
				for (int sd = 0; sd < smite_dice; sd++) smite_damage += random(1, 8);
				total_damage += smite_damage;
				c.divine_smite_pending = false;
				c.divine_smite_slot_level = 0;
				broadcast_announce(c.name + "'s Divine Smite deals " + smite_damage + " extra radiant damage!", true);
			}
			if (!pr.is_spell_effect and c.hunters_mark_target_id == target.id) {
				// PHB 2024 Ranger L20 Foe Slayer (para 6193-6194): "The damage die of
				// your Hunter's Mark is a d10 rather than a d6."
				int mark_die = (c.class_name == "Ranger" and c.level >= 20) ? 10 : 6;
				int mark_damage = random(1, mark_die);
				total_damage += mark_damage;
				broadcast_announce(c.name + "'s Hunter's Mark deals " + mark_damage + " extra damage to " + target.name + ".", false);
			}
			if ((!pr.is_spell_effect or pr.spell_uses_attack_roll) and c.hex_target_id == target.id) {
				int hex_damage = random(1, 6);
				total_damage += hex_damage;
				broadcast_announce(c.name + "'s Hex deals " + hex_damage + " extra necrotic damage to " + target.name + ".", false);
			}
			// Basic Rules 2024 Bestow Curse (para 12219-12222): extra_damage curse —
			// "whenever you deal damage to the Cursed target, it takes an extra 1d8 Necrotic."
			if (target.bestow_curse_type == "extra_damage" and target.bestow_curse_source_id == c.id) {
				int bc_dmg = random(1, 8);
				total_damage += bc_dmg;
				broadcast_announce(c.name + "'s Bestow Curse deals " + bc_dmg + " extra necrotic damage to " + target.name + ".", false);
			}
			// Basic Rules 2024 Enlarge/Reduce (para 12795-12800): Enlarged weapons deal
			// +1d4 extra damage; Reduced weapons deal -1d4 damage (min 1 total).
			if (c.enlarge_active and !pr.is_spell_effect and pr.is_weapon_attack) {
				int enlarge_dmg = random(1, 4);
				total_damage += enlarge_dmg;
				broadcast_announce(c.name + "'s enlarged weapons deal +" + enlarge_dmg + " extra damage.", false);
			}
			if (c.reduce_active and !pr.is_spell_effect and pr.is_weapon_attack) {
				int reduce_penalty = random(1, 4);
				total_damage -= reduce_penalty;
				if (total_damage < 1) total_damage = 1;
				broadcast_announce(c.name + "'s reduced weapons deal " + reduce_penalty + " less damage.", false);
			}
			// Xanathar's Holy Weapon (para 4936): "weapon attacks made with it deal an
			// extra 2d8 radiant damage on a hit." Triggers on weapon attacks only.
			if (c.holy_weapon_active and !pr.is_spell_effect and pr.is_weapon_attack) {
				int hw_dmg = random(1, 8) + random(1, 8);
				total_damage += hw_dmg;
				broadcast_announce(c.name + "'s Holy Weapon adds " + hw_dmg + " radiant damage.", false);
			}
			// Divine Favor (Basic Rules para 12922): "Until the spell ends, your attacks
			// with weapons deal an extra 1d4 Radiant damage on a hit."
			if (c.divine_favor_active and !pr.is_spell_effect and pr.is_weapon_attack) {
				int df_dmg = random(1, 4);
				total_damage += df_dmg;
				broadcast_announce(c.name + "'s Divine Favor adds " + df_dmg + " radiant damage.", false);
			}
			// Basic Rules 2024 Searing Smite (para 14881-14888): pending rider on next
			// melee hit. Extra fire damage + repeating DOT at target's turn start.
			if (c.searing_smite_pending and !pr.is_spell_effect and pr.is_weapon_attack and !c.main_hand_is_ranged) {
				int ss_dmg = 0;
				for (int d = 0; d < c.searing_smite_dice; d++) ss_dmg += random(1, 6);
				total_damage += ss_dmg;
				// Set up repeating fire DOT on the target
				target.searing_smite_caster_id = c.id;
				target.searing_smite_dot_dice = c.searing_smite_dice;
				c.searing_smite_pending = false;
				c.searing_smite_dice = 0;
				// Searing Smite is concentration — set on caster
				c.is_concentrating = true;
				c.concentration_spell = "Searing Smite";
				broadcast_announce(c.name + "'s Searing Smite ignites " + target.name + " for " + ss_dmg + " fire damage! Fire persists each turn.", true);
			}
			// Basic Rules 2024 Shining Smite (para 14976-14983): pending rider on next
			// weapon hit. 2d6+upcast radiant + advantage + invisibility block on target.
			if (c.shining_smite_pending and !pr.is_spell_effect and pr.is_weapon_attack) {
				int sh_dmg = 0;
				for (int d = 0; d < c.shining_smite_dice; d++) sh_dmg += random(1, 6);
				total_damage += sh_dmg;
				// Apply debuff on target
				target.shining_smite_debuff = true;
				target.shining_smite_debuff_source_id = c.id;
				target.shining_smite_debuff_rounds = 10; // 1 minute
				// Strip invisibility
				if (target.has_condition(COND_INVISIBLE)) {
					target.remove_condition(COND_INVISIBLE);
					target.is_hidden = false;
					target.greater_invisibility_active = false;
				}
				target.starry_wisp_no_invis = true; // Reuse the invisibility block
				c.shining_smite_pending = false;
				c.shining_smite_dice = 0;
				// Shining Smite is concentration
				c.is_concentrating = true;
				c.concentration_spell = "Shining Smite";
				broadcast_announce(c.name + "'s Shining Smite sears " + target.name + " for " + sh_dmg + " radiant damage! Target sheds bright light.", true);
			}
			// Gun Slinger Class Ballistic Smite: pending rider on next ranged hit.
			// 2d6+upcast force damage.
			if (c.ballistic_smite_pending and !pr.is_spell_effect and pr.is_weapon_attack and c.main_hand_is_ranged) {
				int bs_dmg = 0;
				for (int d = 0; d < c.ballistic_smite_dice; d++) bs_dmg += random(1, 6);
				total_damage += bs_dmg;
				c.ballistic_smite_pending = false;
				c.ballistic_smite_dice = 0;
				broadcast_announce(c.name + "'s Ballistic Smite blasts " + target.name + " for " + bs_dmg + " extra force damage!", true);
			}
			// Mother of Sorrows Venomous Mark (Book of Ebon Tides para 1137):
			// "Until the curse ends, you deal an extra 1d6 poison damage to the target
			// whenever you hit it with a spell attack."
			// Source clarifies: "You can only apply this damage once per spell even if
			// there are multiple spell attack instances, such as with eldritch blast."
			// We approximate "once per spell" by checking the first attack instance only
			// (rolls_completed == 0 on the chain).
			if (pr.is_spell_effect and pr.spell_uses_attack_roll and c.venomous_mark_target_id == target.id and c.venomous_mark_rounds > 0 and pr.rolls_completed == 0) {
				int vm_damage = random(1, 6);
				total_damage += vm_damage;
				broadcast_announce(c.name + "'s Venomous Mark adds " + vm_damage + " poison damage to " + target.name + ".", false);
			}
			// Ensnaring Strike: restrain target on weapon hit
			if (!pr.is_spell_effect and c.ensnaring_strike_pending and pr.is_weapon_attack) {
				c.ensnaring_strike_pending = false;
				int ens_save_roll = random(1, 20);
				int ens_save_bonus = target.get_save_bonus(ABILITY_STR);
				int ens_save_total = target.apply_indomitable_might(ens_save_roll + ens_save_bonus, ABILITY_STR);
				bool ens_saved = ens_save_total >= c.ensnaring_strike_dc;
				broadcast_roll(target.name, "STR save vs Ensnaring Strike", ens_save_roll, ens_save_bonus, ens_save_total, ens_saved ? "Saved!" : "Restrained!");
				if (!ens_saved) {
					target.add_condition(COND_RESTRAINED);
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Restrained"}});
					broadcast_announce(target.name + " is restrained by vines from Ensnaring Strike!", false);
				}
			}
			if (pr.is_crit and c.has_feat("boon_of_irresistible_offense")) {
				int boon_damage = random(1, 10) + random(1, 10);
				total_damage += boon_damage;
				broadcast_announce(c.name + "'s Boon of Irresistible Offense adds " + boon_damage + " extra damage!", false);
			}
			// Valda's Spire Gunslinger L5 Gut Shot (paras 184-185): "Whenever you score a
			// Critical Hit against a Large or smaller creature with a ranged attack using
			// a weapon, the projectile lodges itself in the target. For 1 minute or until
			// the target replaces one of its attacks with dislodging the projectile, its
			// Speed is halved and it has Disadvantage on attack rolls." 1 minute = 10 rounds.
			if (pr.is_crit and c.class_name == "Gunslinger" and c.gut_shot_active and pr.is_weapon_attack and c.main_hand_is_ranged and target.size <= SIZE_LARGE and !target.is_dead) {
				target.gut_shot_rounds_remaining = 10;
				target.speed = target.speed / 2;
				broadcast_announce(c.name + "'s Gut Shot lodges in " + target.name + "! Speed halved and Disadvantage on attacks for 1 minute.", true);
			}
			// Valda's Spire Gunslinger L20 Headshot (paras 201-203): "When you score a
			// Critical Hit against a creature using a Ranged weapon, you can choose for it
			// to be a Headshot. If the creature has less than 100 Hit Points, it dies.
			// Otherwise, it takes an extra 10d10 damage of the weapon's type." 1/SR or
			// expend 3 Risk Dice. Auto-fires when available — extra damage is always strict
			// upside, and the use can be refunded with 3 Risk Dice if the player has them.
			if (pr.is_crit and c.class_name == "Gunslinger" and c.headshot_active and !c.headshot_used and pr.is_weapon_attack and c.main_hand_is_ranged and !target.is_dead) {
				c.headshot_used = true;
				if (target.current_hp < 100) {
					total_damage += target.current_hp; // ensure kill — apply_damage handles overflow
					broadcast_announce(c.name + " lands a HEADSHOT on " + target.name + "! Killed instantly!", true);
				} else {
					int hs_dmg = 0;
					for (int hi = 0; hi < 10; hi++) hs_dmg += random(1, 10);
					total_damage += hs_dmg;
					broadcast_announce(c.name + "'s Headshot adds " + hs_dmg + " extra damage!", true);
				}
			}
			// Valda's Spire Gunslinger Secret Agent L14 License to Kill (paras 290-291):
			// "Whenever you deal damage with a Ranged weapon, you can expend either one
			// or two Risk Dice and add them to the damage roll. If you roll the highest
			// number on a Risk Die, you can roll the die again and add it to the damage
			// without expending it, rolling again if it is the highest number again, and
			// so on. The maximum number of Risk Dice you can add to the damage equals
			// your Proficiency Bonus." Triggered via opt-in pending flag set by bonus
			// action handler so the player chooses 1 or 2 dice and when to spend.
			if (c.license_to_kill_active and c.license_to_kill_pending and pr.is_weapon_attack and c.main_hand_is_ranged and !pr.is_spell_effect and c.risk_dice_current > 0) {
				c.license_to_kill_pending = false;
				int ltk_to_spend = c.license_to_kill_dice_to_spend;
				if (ltk_to_spend < 1) ltk_to_spend = 1;
				if (ltk_to_spend > 2) ltk_to_spend = 2;
				if (ltk_to_spend > c.risk_dice_current) ltk_to_spend = c.risk_dice_current;
				c.risk_dice_current -= ltk_to_spend;
				int ltk_total = 0;
				int ltk_dice_added = 0;
				int ltk_max_dice = c.proficiency;
				int ltk_die_sides = c.risk_die_size;
				for (int li = 0; li < ltk_to_spend; li++) {
					if (ltk_dice_added >= ltk_max_dice) break;
					int roll = random(1, ltk_die_sides);
					ltk_total += roll;
					ltk_dice_added++;
					// Exploding on max — keep rolling without expending
					while (roll == ltk_die_sides and ltk_dice_added < ltk_max_dice) {
						roll = random(1, ltk_die_sides);
						ltk_total += roll;
						ltk_dice_added++;
					}
				}
				total_damage += ltk_total;
				broadcast_announce(c.name + "'s License to Kill spends " + ltk_to_spend + " Risk Dice (" + ltk_dice_added + " total dice rolled with explosions) for +" + ltk_total + " damage! (" + c.risk_dice_current + "/" + c.risk_dice_max + " Risk Dice remaining)", true);
			}
			// Valda's Spire Gunslinger White Hat L6 Reach for the Skies (paras 460-461):
			// "When you score a Critical Hit against a creature, you call for the target
			// to surrender instead of lodging a projectile in it. The target must succeed
			// on a Wisdom saving throw against your Maneuver save DC or have the
			// Frightened and Incapacitated conditions for 1 minute. These conditions end
			// early if the creature takes any damage..." Note: since the source says the
			// conditions END if the creature takes damage, we apply the conditions but
			// they will be cleared by the very damage of this attack. The intent of the
			// feature is the surrender call before damage — implementation skips the
			// effect when total_damage > 0 and the source rule would auto-clear it. We
			// implement the spirit by giving the target the save first; if they fail and
			// total_damage == 0 (e.g., resisted to 0), the conditions stick. L14 Gold
			// Star Hero (para 466-468) upgrades Incapacitated → Stunned which would NOT
			// be cleared by the same damage rule (only Incapacitated/Frightened end on
			// damage per RAW; Stunned does not).
			if (pr.is_crit and c.reach_for_skies_active and pr.is_weapon_attack and c.main_hand_is_ranged and !pr.is_spell_effect and !target.is_dead) {
				int rfs_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_DEX);
				int rfs_save_roll = random(1, 20);
				int rfs_save_bonus = target.get_save_bonus(ABILITY_WIS);
				int rfs_save_total = rfs_save_roll + rfs_save_bonus;
				bool rfs_saved = rfs_save_total >= rfs_dc;
				broadcast_roll(target.name, "WIS save vs Reach for the Skies", rfs_save_roll, rfs_save_bonus, rfs_save_total, rfs_saved ? "Saved!" : "Failed!");
				if (!rfs_saved) {
					if (c.gold_star_hero_active) {
						target.add_condition(COND_STUNNED);
						broadcast_announce(c.name + "'s Reach for the Skies STUNS " + target.name + "! (Gold Star Hero)", true);
					} else {
						target.add_condition(COND_FRIGHTENED);
						target.frightened_source_id = c.id;
						target.add_condition(COND_INCAPACITATED);
						broadcast_announce(c.name + " calls for " + target.name + " to surrender — Frightened and Incapacitated!", true);
					}
				}
			}
			// Valda's Spire Gunslinger White Hat L10 Long Arm of the Law (paras 462-463):
			// "Once per turn when you hit a Large or smaller creature with a ranged
			// attack using a weapon, you can hobble the target. The creature can't move
			// on its next turn unless it first takes the Disengage action." Auto-fires
			// when available — strict upside, no resource cost.
			if (c.long_arm_used_this_turn == false and c.class_name == "Gunslinger" and c.subclass == "White Hat" and c.level >= 10 and pr.is_weapon_attack and c.main_hand_is_ranged and !pr.is_spell_effect and target.size <= SIZE_LARGE and !target.is_dead) {
				c.long_arm_used_this_turn = true;
				target.cant_move_until_disengage = true;
				broadcast_announce(c.name + "'s Long Arm of the Law hobbles " + target.name + "! Cannot move next turn unless they Disengage.", true);
			}
			// Valda's Spire Gunslinger L15 Dire Gambit (para 196): "Whenever you roll
			// Initiative or score a Critical Hit, you regain one expended Risk Die."
			if (pr.is_crit and c.class_name == "Gunslinger" and c.dire_gambit_active and c.risk_dice_current < c.risk_dice_max) {
				c.risk_dice_current++;
				broadcast_announce(c.name + "'s Dire Gambit regains a Risk Die from the critical hit! (" + c.risk_dice_current + "/" + c.risk_dice_max + ")", false);
			}
			// Feat: Great Weapon Master — bonus action attack on crit with Heavy melee weapon
			if (pr.is_crit and !pr.is_spell_effect and c.has_feat("great_weapon_master") and !c.main_hand_is_ranged and c.has_bonus_action and weapon_qualifies_great_weapon_fighting(c.main_hand)) {
				c.has_bonus_action = false;
				c.used_bonus_action = true;
				broadcast_announce(c.name + "'s Great Weapon Master grants a bonus attack on the crit!", true);
			}
			// Feat: Piercer — extra damage die on crits with piercing damage
			if (pr.is_crit and c.has_feat("piercer") and pr.damage_type == DMG_PIERCING) {
				int extra = random(1, pr.damage_dice_sides);
				total_damage += extra;
				broadcast_announce(c.name + "'s Piercer adds " + extra + " extra piercing damage on the crit!", false);
			}
			// Feat: Crusher — push target 5ft on bludgeoning damage (once per turn)
			// PHB 2024 para 7579: "no more than one size larger than you"
			if (c.has_feat("crusher") and pr.damage_type == DMG_BLUDGEONING and !c.crusher_used_this_turn and target.size <= c.size + 1) {
				c.crusher_used_this_turn = true;
				int push_dx = 0, push_dy = 0;
				if (target.x > c.x) push_dx = 1;
				else if (target.x < c.x) push_dx = -1;
				if (target.y > c.y) push_dy = 1;
				else if (target.y < c.y) push_dy = -1;
				target.x += push_dx;
				target.y += push_dy;
				broadcast_announce(c.name + "'s Crusher pushes " + target.name + " back 5 feet!", false);
			}
			// PHB 2024 Crusher (para 7579): "Once per turn, on crit with bludgeoning,
			// attack rolls against target have Advantage until start of your next turn."
			if (pr.is_crit and c.has_feat("crusher") and pr.damage_type == DMG_BLUDGEONING and !target.is_dead) {
				target.crusher_crit_advantage = true;
				target.crusher_crit_source_id = c.id;
				broadcast_announce(c.name + "'s Crusher critical — all attacks have Advantage against " + target.name + "!", true);
			}
			// Feat: Slasher — reduce target speed by 10 on slashing damage (once per turn)
			// PHB 2024 para 7597: "until the start of your next turn"
			if (c.has_feat("slasher") and pr.damage_type == DMG_SLASHING and !c.slasher_used_this_turn) {
				c.slasher_used_this_turn = true;
				target.speed -= 10;
				if (target.speed < 0) target.speed = 0;
				target.slasher_hamstring_active = true;
				target.slasher_hamstring_source_id = c.id;
				broadcast_announce(c.name + "'s Slasher reduces " + target.name + "'s speed by 10 feet!", false);
			}
			// PHB 2024 Slasher (para 7597): "Once per turn, on crit with slashing,
			// target has Disadvantage on attack rolls until start of your next turn."
			if (pr.is_crit and c.has_feat("slasher") and pr.damage_type == DMG_SLASHING and !target.is_dead) {
				target.slasher_crit_disadvantage = true;
				target.slasher_crit_source_id = c.id;
				broadcast_announce(c.name + "'s Slasher critical — " + target.name + " has Disadvantage on attacks!", true);
			}

			// PHB 2024 Charger feat (para 1394-1403): Charge Attack — after Dash + 10+ ft
			// move, next melee attack deals +1d8 damage. Approximated as +1d8 on next
			// melee hit after Dash (straight-line tracking deferred).
			if (c.charger_dash_active and pr.is_weapon_attack and !pr.is_spell_effect and !c.main_hand_is_ranged) {
				int charge_dmg = random(1, 8);
				total_damage += charge_dmg;
				c.charger_dash_active = false;
				broadcast_announce(c.name + "'s Charger feat deals " + charge_dmg + " extra damage on the charge!", false);
			}

			// PHB 2024 Barbarian L9 Brutal Strike (para 2338-2341): on hit after forgoing
			// Reckless Attack advantage, +1d10 damage (2d10 at L17) + chosen effect(s).
			if (c.brutal_strike_active and !c.brutal_strike_used_this_turn and pr.is_weapon_attack
				and !pr.is_spell_effect and c.reckless_attack_active and !c.main_hand_is_ranged) {
				c.brutal_strike_used_this_turn = true;
				c.brutal_strike_active = false;
				int bs_die_count = (c.level >= 17) ? 2 : 1;
				int bs_dmg = 0;
				for (int bsi = 0; bsi < bs_die_count; bsi++) bs_dmg += random(1, 10);
				total_damage += bs_dmg;
				broadcast_announce(c.name + "'s Brutal Strike deals " + bs_dmg + " extra damage! (" + bs_die_count + "d10)", true);
				// Apply effect(s). At L17 can use two different effects.
				int effects_to_apply = (c.level >= 17 and c.brutal_strike_effect2 != "") ? 2 : 1;
				for (int bse = 0; bse < effects_to_apply; bse++) {
					string bs_eff = (bse == 0) ? c.brutal_strike_effect : c.brutal_strike_effect2;
					if (bs_eff == "") continue;
					if (bs_eff == "forceful") {
						// Para 2339: push 15 ft straight away, then move half speed toward target
						int push_dx = 0, push_dy = 0;
						if (target.x > c.x) push_dx = 3; else if (target.x < c.x) push_dx = -3;
						if (target.y > c.y) push_dy = 3; else if (target.y < c.y) push_dy = -3;
						target.x += push_dx;
						target.y += push_dy;
						int half_speed = c.speed / 2;
						c.movement_remaining += half_speed;
						broadcast_announce(c.name + "'s Forceful Blow pushes " + target.name + " 15 ft away! " + c.name + " can move " + half_speed + " ft toward them.", true);
					} else if (bs_eff == "hamstring") {
						// Para 2340: reduce target speed by 15 until start of attacker's next turn
						target.speed -= 15;
						if (target.speed < 0) target.speed = 0;
						broadcast_announce(c.name + "'s Hamstring Blow reduces " + target.name + "'s speed by 15 ft!", true);
					} else if (bs_eff == "staggering") {
						// Para 2346: disadvantage on next save + no OA until start of attacker's next turn
						target.staggering_blow_active = true;
						broadcast_announce(c.name + "'s Staggering Blow gives " + target.name + " disadvantage on their next save and prevents Opportunity Attacks!", true);
					} else if (bs_eff == "sundering") {
						// Para 2347: next attack by another creature gains +5 to hit
						target.sundering_blow_target_active = true;
						target.sundering_blow_target_id = c.id;
						broadcast_announce(c.name + "'s Sundering Blow weakens " + target.name + "'s defenses! Next attack by an ally gains +5 to hit.", true);
					}
				}
				c.brutal_strike_effect = "";
				c.brutal_strike_effect2 = "";
			}
			int hunter_damage = 0;
			if (pr.is_weapon_attack and c.class_name == "Ranger" and c.subclass == "Hunter" and !c.hunter_colossus_used and target.current_hp < target.max_hp and target.current_hp > 0) {
				hunter_damage = random(1, 8);
				total_damage += hunter_damage;
				c.hunter_colossus_used = true;
				broadcast_announce(c.name + "'s Colossus Slayer deals " + hunter_damage + " extra damage!", false);
			}

			// Subclass on-hit bonus damage (passes advantage/disadvantage so Sneak Attack
			// can verify the source-required condition: Advantage on the roll OR ally
			// within 5 ft of target with no Disadvantage on the attack).
			int subclass_damage = apply_subclass_on_hit_damage(c, target, pr.is_weapon_attack, pr.has_advantage, pr.has_disadvantage);
			if (subclass_damage > 0) total_damage += subclass_damage;

			// PHB 2024 Eldritch Invocation: Agonizing Blast (para 7749-7752): "You can add
			// your Charisma modifier to that spell's damage rolls." Applied to each EB beam.
			if (c.agonizing_blast and pr.spell_id == "eldritch_blast") {
				int cha_mod = c.get_ability_mod(ABILITY_CHA);
				if (cha_mod > 0) {
					total_damage += cha_mod;
					broadcast_announce(c.name + "'s Agonizing Blast adds " + cha_mod + " damage!", false);
				}
			}

			// PHB 2024 Cleric L7 Blessed Strikes — Divine Strike (para 3619): "Once on
			// each of your turns when you hit a creature with an attack roll using a
			// weapon, you can cause the target to take an extra 1d8 Necrotic or Radiant
			// damage." L14 Improved Blessed Strikes (para 3625) increases to 2d8.
			// roll_divine_strike enforces "once per turn" and the player's choices.
			if (pr.is_weapon_attack and !pr.is_spell_effect) {
				int ds_type = -1;
				int ds_dmg = c.roll_divine_strike(ds_type);
				if (ds_dmg > 0 and ds_type >= 0) {
					string ds_name = (ds_type == DMG_NECROTIC) ? "necrotic" : "radiant";
					combat.apply_damage(target, ds_dmg, ds_type, c);
					broadcast_announce(c.name + "'s Divine Strike deals " + ds_dmg + " extra " + ds_name + " damage!", false);
				}
			}

			// PHB 2024 Druid L7 Elemental Fury — Primal Strike (para 4433): "Once on each
			// of your turns when you hit a creature with an attack roll using a weapon or
			// a Beast form's attack in Wild Shape, you can cause the target to take an
			// extra 1d8 Cold, Fire, Lightning, or Thunder damage (choose when you hit)."
			// L15 Improved Elemental Fury (para 4437) increases to 2d8.
			if (pr.is_weapon_attack and !pr.is_spell_effect) {
				int ps_type = -1;
				int ps_dmg = c.roll_primal_strike(ps_type);
				if (ps_dmg > 0 and ps_type >= 0) {
					string ps_name = "elemental";
					if (ps_type == DMG_COLD) ps_name = "cold";
					else if (ps_type == DMG_FIRE) ps_name = "fire";
					else if (ps_type == DMG_LIGHTNING) ps_name = "lightning";
					else if (ps_type == DMG_THUNDER) ps_name = "thunder";
					combat.apply_damage(target, ps_dmg, ps_type, c);
					broadcast_announce(c.name + "'s Primal Strike deals " + ps_dmg + " extra " + ps_name + " damage!", false);
				}
			}

			// PHB 2024 Paladin L11 Radiant Strikes (para 5684-5685): "Your strikes now
			// carry supernatural power. When you hit a target with an attack roll using
			// a Melee weapon or an Unarmed Strike, the target takes an extra 1d8 Radiant
			// damage." Applies on every qualifying hit (not once per turn). Excludes
			// ranged weapons (the source restricts to Melee weapons / Unarmed Strikes).
			if (c.class_name == "Paladin" and c.level >= 11 and pr.is_weapon_attack and !pr.is_spell_effect and !c.main_hand_is_ranged and get_attack_range(c, false) <= 5) {
				int rs_dmg = random(1, 8);
				combat.apply_damage(target, rs_dmg, DMG_RADIANT, c);
				broadcast_announce(c.name + "'s Radiant Strikes deal " + rs_dmg + " extra radiant damage!", false);
			}

			// Xanathar's War Magic L6 Power Surge (para 2937-2940): "Once per turn when you deal
			// damage to a creature with a wizard spell, you can spend one power surge to deal
			// extra force damage to that target. The extra damage equals half your wizard level."
			// Currently auto-fires on spell attack hits. Save-based spell damage has ~30 inline
			// sites — Power Surge for save-based damage deferred to a dedicated coverage batch.
			if (pr.is_spell_effect and c.class_name == "Wizard" and c.subclass == "War Magic" and c.level >= 6 and c.power_surge_charges > 0 and !c.power_surge_used_this_turn) {
				int surge_dmg = c.level / 2;
				if (surge_dmg < 1) surge_dmg = 1;
				c.power_surge_charges--;
				c.power_surge_used_this_turn = true;
				combat.apply_damage(target, surge_dmg, DMG_FORCE, c);
				broadcast_announce(c.name + "'s Power Surge deals " + surge_dmg + " extra force damage! (" + c.power_surge_charges + "/" + c.power_surge_max + " surges remaining)", false);
			}

			// Sacred Weapon: add CHA mod to attack (already applied via attack bonus), no damage bonus here
			// (Sacred Weapon affects attack rolls, handled in advantage section)

			// Arcane Ward: absorb damage for Abjurer Wizard (applied in apply_damage, but track here)

			string dmg_type_name = "damage";
			if (pr.damage_type >= 0 and pr.damage_type < int(DAMAGE_TYPE_NAMES.length())) {
				dmg_type_name = DAMAGE_TYPE_NAMES[pr.damage_type] + " damage";
			}

			// Apply modifier damage adjustments
			if (active_modifier == "glass_cannon") total_damage *= 2;
			if (active_modifier == "volatile" and pr.is_crit) total_damage = int(float(total_damage) * 1.5);

			// Track crit, max damage, and total damage stats
			if (c.is_player and c.player_username != "" and progression_enabled) {
				if (pr.is_crit) add_run_crits(c.player_username, 1);
				if (total_damage > get_run_max_damage(c.player_username)) set_run_max_damage(c.player_username, total_damage);
				add_run_damage(c.player_username, total_damage);
			}

			string damage_reason = pr.attack_name != "" ? pr.attack_name + " damage" : "damage";
			broadcast_roll(c.name, damage_reason, natural_roll, pr.damage_modifier, total_damage, total_damage + " " + dmg_type_name + " to " + target.name + ".");
			if (extra_damage > 0 and pr.extra_damage_type >= 0 and pr.extra_damage_type < int(DAMAGE_TYPE_NAMES.length())) {
				broadcast_announce(c.name + " adds " + extra_damage + " " + DAMAGE_TYPE_NAMES[pr.extra_damage_type] + " damage.", false);
			}
			string dmg_type_str = (pr.damage_type >= 0 and pr.damage_type < int(DAMAGE_TYPE_NAMES.length())) ? DAMAGE_TYPE_NAMES[pr.damage_type] : "physical";
			broadcast_to_battle({{"type", message_types::damage_dealt}, {"attacker", c.name}, {"target", target.name}, {"amount", total_damage}, {"damage_type", dmg_type_str}, {"is_crit", pr.is_crit}, {"weapon", pr.attack_name}, {"is_weapon_attack", pr.is_weapon_attack}});
			// Xanathar's Ancestral Guardian L3 Ancestral Protectors (para 389-390):
			// "when the target hits a creature other than you with an attack, that creature
			// has resistance to the damage dealt by the attack."
			if (c.ancestral_protector_marked_by != 0 and @combat != null) {
				for (uint agr = 0; agr < combat.combatants.length(); agr++) {
					combatant@ ag_c = combat.combatants[agr];
					if (@ag_c == null or ag_c.is_dead or ag_c.id != c.ancestral_protector_marked_by) continue;
					if (target.id != ag_c.id) {
						total_damage = total_damage / 2;
						broadcast_announce(target.name + " has resistance from Ancestral Protectors — damage halved to " + total_damage + "!", true);
					}
					break;
				}
			}
			// Xanathar's Grave Domain L2 Path to the Grave (para 794-796): "the next time
			// you or an ally hits the cursed creature with an attack, the creature has
			// vulnerability to all of that attack's damage, and then the curse ends."
			// Vulnerability = double damage. Applied to total_damage from ANY attacker.
			if (target.path_to_grave_vulnerable) {
				broadcast_announce("Path to the Grave! " + target.name + " is vulnerable — damage doubled from " + total_damage + " to " + (total_damage * 2) + "!", true);
				total_damage *= 2;
				target.path_to_grave_vulnerable = false;
				// Clear the caster's tracking too
				for (uint ptg = 0; ptg < combat.combatants.length(); ptg++) {
					combatant@ ptg_c = combat.combatants[ptg];
					if (@ptg_c != null and ptg_c.path_to_grave_target == target.id) ptg_c.path_to_grave_target = 0;
				}
			}
			// PHB 2024 Fighting Style: Interception (para 7864): "When a creature you
			// can see hits a target, other than you, within 5 feet of you with an attack,
			// you can use your Reaction to reduce the damage by 1d10 + Proficiency Bonus."
			if (!target.is_dead and @combat != null) {
				for (uint ic = 0; ic < combat.combatants.length(); ic++) {
					combatant@ protector = combat.combatants[ic];
					if (@protector == null or protector.is_dead or !protector.is_alive()) continue;
					if (!protector.is_conscious() or protector.is_incapacitated_check()) continue;
					if (protector.id == target.id or protector.id == c.id) continue;
					if (!protector.has_feat("interception")) continue;
					if (!protector.has_reaction) continue;
					if (!combat.are_hostile(protector, c)) continue;
					if (feet_distance(protector.x, protector.y, target.x, target.y) > 5) continue;
					if (!combat.can_see(protector, c)) continue;
					protector.has_reaction = false;
					int reduction = random(1, 10) + protector.proficiency;
					if (reduction > total_damage) reduction = total_damage;
					total_damage -= reduction;
					if (total_damage < 0) total_damage = 0;
					broadcast_announce(protector.name + "'s Interception reduces damage to " + target.name + " by " + reduction + "!", true);
					break;
				}
			}
			bool target_was_full_hp = (target.current_hp == target.max_hp);
			bool attacker_was_hidden = c.is_hidden;
			// PHB 2024 Skulker: reveal on hit (deferred from attack declaration)
			// Basic Rules 2024 Greater Invisibility: does NOT break on attack.
			if (c.is_hidden and !c.greater_invisibility_active) reveal_hidden_combatant(c, "hitting with an attack");
			// Xanathar's Arcane Archer Enfeebling Arrow (paras 1618-1646): "the damage
			// dealt by its weapon attacks is halved until the start of your next turn."
			if (c.arcane_enfeeble_source != 0 and pr.is_weapon_attack) {
				total_damage = (total_damage + 1) / 2;
				broadcast_announce(c.name + "'s weapon damage is halved by Enfeebling Arrow! (" + total_damage + " damage)", true);
			}
			combat.apply_damage(target, total_damage, pr.damage_type, c, pr.is_crit);

			// PHB 2024 Monk L3 Deflect Attacks — Redirect (para 5339): If damage was
			// reduced to 0 by Deflect Attacks, Monk can spend 1 Focus Point to redirect
			// force at the attacker. DEX save or 2d8 + DEX mod Force damage.
			if (target.deflect_attacks_reduced_to_zero and target.focus_points > 0 and !c.is_dead) {
				target.deflect_attacks_reduced_to_zero = false;
				target.focus_points--;
				int redirect_dmg = random(1, 8) + random(1, 8) + target.get_ability_mod(ABILITY_DEX);
				if (redirect_dmg < 1) redirect_dmg = 1;
				int redirect_dc = 8 + target.proficiency + target.get_ability_mod(ABILITY_DEX);
				int redirect_save = random(1, 20) + c.get_save_bonus(ABILITY_DEX);
				if (redirect_save >= redirect_dc) {
					broadcast_announce(target.name + " redirects the deflected force at " + c.name + ", but they dodge! (DEX save " + redirect_save + " vs DC " + redirect_dc + ")", false);
				} else {
					combat.apply_damage(c, redirect_dmg, DMG_FORCE, target);
					broadcast_announce(target.name + " deflects and redirects " + redirect_dmg + " force damage at " + c.name + "! (DEX save " + redirect_save + " vs DC " + redirect_dc + ")", true);
				}
			} else if (target.deflect_attacks_reduced_to_zero) {
				target.deflect_attacks_reduced_to_zero = false; // Clear flag if no FP to redirect
			}

			// Mirror Image (Basic Rules para 14260): "Each time a creature hits you with
			// an attack roll during the spell's duration, roll a d6 for each of your
			// remaining duplicates. If any of the d6s rolls a 3 or higher, one of the
			// duplicates is hit instead of you, and the duplicate is destroyed."
			if (target.mirror_images > 0 and !target.has_condition(COND_BLINDED)) {
				bool image_hit = false;
				for (int mi = 0; mi < target.mirror_images; mi++) {
					if (random(1, 6) >= 3) { image_hit = true; break; }
				}
				if (image_hit) {
					target.mirror_images--;
					broadcast_announce("One of " + target.name + "'s mirror images is destroyed instead! (" + target.mirror_images + " remaining)", false);
					broadcast_state();
					return; // Skip damage application
				}
			}
			// Blink spell (Basic Rules para 12284): caster has 50% chance to be on the
			// Ethereal Plane between turns; attacks targeting them auto-miss.
			if (target.blink_active and random(1, 6) >= 4) {
				broadcast_announce(target.name + " is on the Ethereal Plane from Blink — the attack passes through them!", true);
				broadcast_state();
				return;
			}
			// Fire Shield: melee attacker within 5ft takes 2d8 of opposing element
			if (target.fire_shield_active and !c.main_hand_is_ranged and !pr.is_spell_effect and feet_distance(c.x, c.y, target.x, target.y) <= 5) {
				int fs_dmg = random(1, 8) + random(1, 8);
				int fs_type = target.fire_shield_warm ? DMG_FIRE : DMG_COLD;
				string fs_name = target.fire_shield_warm ? "fire" : "cold";
				combat.apply_damage(c, fs_dmg, fs_type, target);
				broadcast_announce(target.name + "'s Fire Shield burns " + c.name + " for " + fs_dmg + " " + fs_name + " damage!", true);
			}

			// Refraction Shield (Light Weaver Sorcerer L6): melee attacker within 5 ft
			// takes 2d8 radiant (light-shifted) or 2d8 necrotic (dark-shifted) on hit.
			// Source para 1111: "the shield flashes with searing energy, and the attacker
			// takes 2d8 radiant damage if you are light-shifted or 2d8 necrotic damage if
			// you are dark-shifted."
			if (target.refraction_shield_active and !c.main_hand_is_ranged and !pr.is_spell_effect and feet_distance(c.x, c.y, target.x, target.y) <= 5) {
				int rs_dmg = random(1, 8) + random(1, 8);
				int rs_type = target.light_weaver_dark_shifted ? DMG_NECROTIC : DMG_RADIANT;
				string rs_name = target.light_weaver_dark_shifted ? "necrotic" : "radiant";
				combat.apply_damage(c, rs_dmg, rs_type, target);
				broadcast_announce(target.name + "'s Refraction Shield flashes, dealing " + rs_dmg + " " + rs_name + " damage to " + c.name + "!", true);
			}

			// Xanathar's Oath of Conquest L15 Scornful Rebuke (para 1996-1997):
			// "Whenever a creature hits you with an attack, that creature takes psychic
			// damage equal to your Charisma modifier (minimum of 1) if you're not
			// incapacitated."
			if (target.scornful_rebuke_active and !target.has_condition(COND_INCAPACITATED) and !target.is_dead) {
				int rebuke_dmg = target.get_ability_mod(ABILITY_CHA);
				if (rebuke_dmg < 1) rebuke_dmg = 1;
				combat.apply_damage(c, rebuke_dmg, DMG_PSYCHIC, target);
				broadcast_announce(target.name + "'s Scornful Rebuke deals " + rebuke_dmg + " psychic damage to " + c.name + "!", true);
			}

			// Xanathar's Sun Soul L17 Sun Shield (para 1863-1865): "If a creature hits
			// you with a melee attack while this light shines, you can use your reaction
			// to deal radiant damage to the creature. The radiant damage equals 5 + your
			// Wisdom modifier."
			if (target.sun_shield_active and target.has_reaction and !target.is_dead and !c.main_hand_is_ranged and !pr.is_spell_effect and feet_distance(c.x, c.y, target.x, target.y) <= 5) {
				target.has_reaction = false;
				int ss_dmg = 5 + target.get_ability_mod(ABILITY_WIS);
				if (ss_dmg < 1) ss_dmg = 1;
				combat.apply_damage(c, ss_dmg, DMG_RADIANT, target);
				broadcast_announce(target.name + "'s Sun Shield flares! " + ss_dmg + " radiant damage to " + c.name + "!", true);
			}

			// Xanathar's Oath of Redemption L3 Rebuke the Violent CD (para 2046):
			// "Immediately after an attacker within 30 feet of you deals damage with
			// an attack against a creature other than you, you can use your reaction
			// to force the attacker to make a Wisdom saving throw. On a failed save,
			// the attacker takes radiant damage equal to the damage it just dealt."
			if (@combat != null and c.id != target.id) {
				for (uint rv = 0; rv < combat.combatants.length(); rv++) {
					combatant@ pal = combat.combatants[rv];
					if (@pal == null or pal.is_dead or pal.id == c.id or pal.id == target.id) continue;
					if (pal.class_name != "Paladin" or pal.subclass != "Oath of Redemption") continue;
					if (!pal.rebuke_violent_ready or !pal.has_reaction) continue;
					if (feet_distance(pal.x, pal.y, c.x, c.y) > 30) continue;
					// Auto-resolve: attacker makes WIS save vs paladin's spell save DC
					int save_dc = 8 + pal.get_ability_mod(ABILITY_CHA) + pal.proficiency;
					int save_roll = random(1, 20) + c.get_ability_mod(ABILITY_WIS);
					if (c.save_proficiencies[ABILITY_WIS] == 1) save_roll += c.proficiency;
					pal.rebuke_violent_ready = false;
					pal.has_reaction = false;
					if (save_roll < save_dc) {
						combat.apply_damage(c, total_damage, DMG_RADIANT, pal);
						broadcast_announce(pal.name + "'s Rebuke the Violent! " + c.name + " takes " + total_damage + " radiant damage!", true);
					} else {
						int half_dmg = total_damage / 2;
						if (half_dmg > 0) combat.apply_damage(c, half_dmg, DMG_RADIANT, pal);
						broadcast_announce(pal.name + "'s Rebuke the Violent! " + c.name + " saves, takes " + half_dmg + " radiant damage.", true);
					}
					break; // Only one paladin can rebuke per attack
				}
			}

			// Xanathar's Cavalier L3 Unwavering Mark retaliation trigger (para 1671-1672):
			// "if a creature marked by you deals damage to anyone other than you, you can
			// make a special melee weapon attack against the marked creature as a bonus
			// action on your next turn."
			if (c.marked_by_cavalier_id != 0 and @combat != null) {
				for (uint umr = 0; umr < combat.combatants.length(); umr++) {
					combatant@ cav = combat.combatants[umr];
					if (@cav == null or cav.is_dead or cav.id != c.marked_by_cavalier_id) continue;
					if (target.id != cav.id and cav.unwavering_mark_ba_uses > 0 and !cav.cavalier_retaliation_available) {
						cav.cavalier_retaliation_available = true;
						cav.cavalier_retaliation_target = c.id;
						broadcast_announce(c.name + " damaged " + target.name + " while marked! " + cav.name + " can retaliate on their next turn.", false);
					}
					break;
				}
			}

			// PHB 2024 Shield Master (para 7797): after hitting with a melee weapon with a shield, shove
			// Attacker chooses Push 5ft OR Prone via shield_master_push_mode toggle
			if (c.has_feat("shield_master") and c.has_shield and !c.main_hand_is_ranged and !pr.is_spell_effect and !c.shield_bash_used_this_turn and !target.is_dead and feet_distance(c.x, c.y, target.x, target.y) <= 5) {
				c.shield_bash_used_this_turn = true;
				int sb_dc = 8 + c.get_ability_mod(ABILITY_STR) + c.proficiency;
				int sb_save = target.apply_indomitable_might(random(1, 20) + target.get_save_bonus(ABILITY_STR), ABILITY_STR);
				if (sb_save < sb_dc) {
					if (c.shield_master_push_mode) {
						// Push 5ft (1 tile) straight away from attacker
						int push_dir_x = 0; int push_dir_y = 0;
						if (target.x > c.x) push_dir_x = 1;
						else if (target.x < c.x) push_dir_x = -1;
						if (target.y > c.y) push_dir_y = 1;
						else if (target.y < c.y) push_dir_y = -1;
						if (push_dir_x != 0 or push_dir_y != 0) {
							target.x += push_dir_x; target.y += push_dir_y; // 5 ft = 1 tile
						}
						broadcast_announce(c.name + "'s Shield Master pushes " + target.name + " 5 feet away! (save " + sb_save + " vs DC " + sb_dc + ")", true);
					} else {
						target.add_condition(COND_PRONE);
						broadcast_announce(c.name + "'s Shield Master knocks " + target.name + " prone! (save " + sb_save + " vs DC " + sb_dc + ")", true);
					}
				} else {
					broadcast_announce(target.name + " resists " + c.name + "'s Shield Master shove (save " + sb_save + " vs DC " + sb_dc + ").", false);
				}
			}

			// SRD Monster On-Hit Riders: Knockdown (Wolf/Dire Wolf) and Paralyze (Ghoul).
			// These fire only on melee weapon hits from monsters with the trait.
			if (!c.is_player and pr.is_weapon_attack and !target.is_dead and target.is_alive()) {
				// SRD Wolf/Dire Wolf: Bite knocks target prone (STR save or Prone)
				if (c.knockdown_dc > 0 and !target.has_condition(COND_PRONE)) {
					int kd_roll = random(1, 20);
					int kd_bonus = target.get_save_bonus(ABILITY_STR);
					int kd_total = kd_roll + kd_bonus;
					bool kd_saved = kd_total >= c.knockdown_dc;
					broadcast_roll(target.name, "STR save vs knockdown", kd_roll, kd_bonus, kd_total, kd_saved ? "Stands firm!" : "Knocked prone!");
					if (!kd_saved) {
						target.add_condition(COND_PRONE);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Prone"}});
						broadcast_announce(c.name + " knocks " + target.name + " prone!", true);
					}
				}
				// SRD Basilisk/Medusa: Petrifying Gaze (CON save or Petrified on hit)
				if (c.petrify_dc > 0 and !target.has_condition(COND_PETRIFIED)) {
					int pet_roll = random(1, 20);
					int pet_bonus = target.get_save_bonus(ABILITY_CON);
					int pet_total = pet_roll + pet_bonus;
					bool pet_saved = pet_total >= c.petrify_dc;
					broadcast_roll(target.name, "CON save vs Petrifying Gaze", pet_roll, pet_bonus, pet_total, pet_saved ? "Resists!" : "Petrified!");
					if (!pet_saved) {
						target.add_condition(COND_PETRIFIED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Petrified"}});
						broadcast_announce(c.name + "'s gaze turns " + target.name + " to stone!", true);
					}
				}
				// SRD Ghoul: Claws paralyze target (CON save or Paralyzed, 1 minute).
				// Condition immunity check is handled by add_condition.
				if (c.paralyze_dc > 0 and !target.has_condition(COND_PARALYZED)) {
					int par_roll = random(1, 20);
					int par_bonus = target.get_save_bonus(ABILITY_CON);
					int par_total = par_roll + par_bonus;
					bool par_saved = par_total >= c.paralyze_dc;
					broadcast_roll(target.name, "CON save vs paralyzing touch", par_roll, par_bonus, par_total, par_saved ? "Resists!" : "Paralyzed!");
					if (!par_saved) {
						target.add_condition(COND_PARALYZED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Paralyzed"}});
						broadcast_announce(c.name + "'s attack paralyzes " + target.name + "!", true);
					}
				}
			}

			// PHB 2024 Weapon Mastery properties (paras 10335-10352). Only fire on
			// weapon attacks (not spells) when the attacker has mastery for their weapon.
			if (pr.is_weapon_attack and !pr.is_spell_effect and c.main_hand_mastery != MASTERY_NONE and !target.is_dead) {
				int mastery = c.main_hand_mastery;
				// PHB 2024 Fighter L9 Tactical Master (para 5125-5126): override mastery
				if (c.tactical_master_active) {
					mastery = c.tactical_master_mastery;
					c.tactical_master_active = false;
					c.tactical_master_mastery = MASTERY_NONE;
				}
				// Push (para 10343): push target up to 10 ft straight away if Large or smaller
				if (mastery == MASTERY_PUSH and target.size <= SIZE_LARGE) {
					int push_dir_x = 0; int push_dir_y = 0;
					if (target.x > c.x) push_dir_x = 1;
					else if (target.x < c.x) push_dir_x = -1;
					if (target.y > c.y) push_dir_y = 1;
					else if (target.y < c.y) push_dir_y = -1;
					if (push_dir_x != 0 or push_dir_y != 0) {
						target.x += push_dir_x * 2; target.y += push_dir_y * 2; // 10 ft = 2 tiles
						broadcast_announce(c.name + "'s Push mastery shoves " + target.name + " 10 feet away!", false);
					}
				}
				// Sap (para 10345): target has Disadvantage on next attack before start of your next turn
				else if (mastery == MASTERY_SAP) {
					target.mastery_sap_active = true;
					broadcast_announce(c.name + "'s Sap mastery gives " + target.name + " disadvantage on its next attack!", false);
				}
				// Slow (para 10347): reduce target speed by 10 ft until start of your next turn
				else if (mastery == MASTERY_SLOW and !target.mastery_slow_applied) {
					target.mastery_slow_applied = true;
					if (target.speed >= 10) target.speed -= 10;
					if (target.movement_remaining >= 10) target.movement_remaining -= 10;
					broadcast_announce(c.name + "'s Slow mastery reduces " + target.name + "'s speed by 10 feet!", false);
				}
				// Topple (para 10349): CON save (DC 8 + ability mod + prof) or Prone
				else if (mastery == MASTERY_TOPPLE) {
					int atk_mod = get_weapon_attack_ability_mod(c);
					int tp_dc = 8 + atk_mod + c.proficiency;
					int tp_save = random(1, 20) + target.get_save_bonus(ABILITY_CON);
					if (tp_save < tp_dc) {
						target.add_condition(COND_PRONE);
						broadcast_announce(c.name + "'s Topple mastery knocks " + target.name + " prone! (save " + tp_save + " vs DC " + tp_dc + ")", true);
					} else {
						broadcast_announce(target.name + " resists Topple (save " + tp_save + " vs DC " + tp_dc + ").", false);
					}
				}
				// Vex (para 10351): advantage on next attack vs this target
				else if (mastery == MASTERY_VEX) {
					c.mastery_vex_active = true;
					c.mastery_vex_target_id = target.id;
				}
				// Cleave (para 10337): free melee attack vs second creature within 5 ft of
				// target and within attacker's reach, no ability mod to damage, once/turn
				else if (mastery == MASTERY_CLEAVE and !c.cleave_used_this_turn and !c.main_hand_is_ranged) {
					c.cleave_used_this_turn = true;
					combatant@ cleave_target = null;
					for (uint ct = 0; ct < combat.combatants.length(); ct++) {
						combatant@ ct_c = combat.combatants[ct];
						if (@ct_c == null or ct_c.is_dead or ct_c.id == target.id or ct_c.id == c.id) continue;
						if (!combat.are_hostile(c, ct_c)) continue;
						float ct_to_target = sqrt(float((ct_c.x - target.x) * (ct_c.x - target.x) + (ct_c.y - target.y) * (ct_c.y - target.y))) * 5.0f;
						float ct_to_attacker = sqrt(float((ct_c.x - c.x) * (ct_c.x - c.x) + (ct_c.y - c.y) * (ct_c.y - c.y))) * 5.0f;
						if (ct_to_target <= 5 and ct_to_attacker <= c.main_hand_range) {
							@cleave_target = ct_c;
							break;
						}
					}
					if (@cleave_target != null) {
						int cleave_atk = random(1, 20);
						int atk_mod = get_weapon_attack_ability_mod(c);
						int cleave_total = cleave_atk + atk_mod + c.proficiency;
						if (cleave_atk == 1) {
							broadcast_announce(c.name + "'s Cleave at " + cleave_target.name + " misses (natural 1).", false);
						} else if (cleave_atk == 20 or cleave_total >= cleave_target.armor_class) {
							int cleave_dmg = 0;
							for (int cd = 0; cd < c.main_hand_damage_count; cd++) cleave_dmg += random(1, c.main_hand_damage_dice);
							// No ability mod added per source: "don't add your ability modifier to that damage unless that modifier is negative"
							if (atk_mod < 0) cleave_dmg += atk_mod;
							if (cleave_dmg < 1) cleave_dmg = 1;
							combat.apply_damage(cleave_target, cleave_dmg, c.main_hand_damage_type, c);
							broadcast_announce(c.name + "'s Cleave hits " + cleave_target.name + " for " + cleave_dmg + " damage!", true);
						} else {
							broadcast_announce(c.name + "'s Cleave at " + cleave_target.name + " misses (roll " + cleave_total + " vs AC " + cleave_target.armor_class + ").", false);
						}
					}
				}
			}

			// PHB 2024 Eldritch Invocation: Repelling Blast (para 7831-7834): "When you hit
			// a Large or smaller creature with that cantrip, you can push the creature up to
			// 10 feet straight away from you." Applied per-beam for Eldritch Blast.
			if (c.repelling_blast and pr.spell_id == "eldritch_blast" and !target.is_dead and target.size <= SIZE_LARGE) {
				int rb_dir_x = 0; int rb_dir_y = 0;
				if (target.x > c.x) rb_dir_x = 1;
				else if (target.x < c.x) rb_dir_x = -1;
				if (target.y > c.y) rb_dir_y = 1;
				else if (target.y < c.y) rb_dir_y = -1;
				if (rb_dir_x != 0 or rb_dir_y != 0) {
					target.x += rb_dir_x * 2; target.y += rb_dir_y * 2; // 10 ft = 2 tiles
					broadcast_announce(c.name + "'s Repelling Blast pushes " + target.name + " 10 feet away!", false);
				}
			}

			// Check boss phase transitions after damage
			if (target.is_boss and !target.is_dead) check_boss_phase(target);
			maybe_apply_on_kill_features(c, target);
			if (target.wild_shape_just_ended) {
				broadcast_announce(target.name + "'s Wild Shape ends!", true);
				target.wild_shape_just_ended = false;
			}

			if (target.is_dead) {
				broadcast_announce(target.name + " has been slain!", true);
				broadcast_to_battle({{"type", message_types::creature_died}, {"name", target.name}, {"id", target.id}, {"killed_by", c.name}, {"was_full_hp", target_was_full_hp}, {"was_overkill", total_damage >= target.max_hp * 2}, {"was_stealth", attacker_was_hidden}});
				// Feat: Great Weapon Master — bonus action attack on kill with Heavy melee weapon
				if (!pr.is_spell_effect and c.has_feat("great_weapon_master") and !c.main_hand_is_ranged and c.has_bonus_action and weapon_qualifies_great_weapon_fighting(c.main_hand)) {
					c.has_bonus_action = false;
					c.used_bonus_action = true;
					broadcast_announce(c.name + "'s Great Weapon Master grants a bonus attack after the kill!", true);
				}
			} else if (target.current_hp == 0 and target.has_condition(COND_UNCONSCIOUS)) {
				broadcast_announce(target.name + " falls unconscious!", true);
			} else {
				broadcast_announce(target.name + " has " + target.current_hp + " of " + target.max_hp + " HP remaining.");
			}

			check_concentration(target, total_damage, c);
			apply_spell_hit_effects(c, target, pr);
			if (!pr.is_spell_effect and c.has_feat("tavern_brawler") and attack_name_is_unarmed(pr.attack_name) and !c.tavern_brawler_push_used and !target.is_dead) {
				int push_dx = 0;
				int push_dy = 0;
				if (target.x > c.x) push_dx = 1;
				else if (target.x < c.x) push_dx = -1;
				if (target.y > c.y) push_dy = 1;
				else if (target.y < c.y) push_dy = -1;
				target.x += push_dx;
				target.y += push_dy;
				c.tavern_brawler_push_used = true;
				broadcast_announce(c.name + " batters " + target.name + " back 5 feet with Tavern Brawler!", false);
			}

			// Xanathar's Arcane Archer L3 Arcane Shot (paras 1618-1646): apply shot
			// effect on weapon hit. Flag set via bonus action menu in users_dom.nvgt.
			if (c.arcane_shot_pending and !target.is_dead and pr.is_weapon_attack) {
				c.arcane_shot_pending = false;
				int as_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
				string shot = c.arcane_shot_type;
				// Xanathar's Arcane Archer L18 (para 1647): "extra damage increases to 4d6"
				int shot_dice = c.level >= 18 ? 4 : 2;
				if (shot == "bursting") {
					// Bursting Arrow (Evocation, para 1630): 2d6 force to all within 10ft
					int burst_dmg = 0;
					for (int bd = 0; bd < shot_dice; bd++) burst_dmg += random(1, 6);
					broadcast_announce(c.name + "'s Bursting Arrow explodes for " + burst_dmg + " force damage!", true);
					if (@combat != null) {
						for (uint bi = 0; bi < combat.combatants.length(); bi++) {
							combatant@ bt = combat.combatants[bi];
							if (@bt == null or bt.is_dead or bt.id == c.id) continue;
							if (feet_distance(bt.x, bt.y, target.x, target.y) <= 10) {
								combat.apply_damage(bt, burst_dmg, DMG_FORCE, c);
								if (bt.id != target.id) broadcast_announce(bt.name + " is caught in the blast for " + burst_dmg + " force damage!", false);
							}
						}
					}
				} else if (shot == "beguiling") {
					// Beguiling Arrow (Enchantment, para 1628): 2d6 psychic + WIS save or charmed
					int beg_dmg = 0;
					for (int bd = 0; bd < shot_dice; bd++) beg_dmg += random(1, 6);
					combat.apply_damage(target, beg_dmg, DMG_PSYCHIC, c);
					if (!target.is_dead) {
						int beg_nat = random(1, 20);
						apply_hound_save_disadvantage(target, c.id, beg_nat);
						int beg_bonus = target.get_save_bonus(ABILITY_WIS);
						int beg_bless = roll_bless_bonus(target);
						int beg_total = beg_nat + beg_bonus + beg_bless;
						bool beg_saved = beg_total >= as_dc;
						broadcast_roll(target.name, "WIS save vs Beguiling Arrow", beg_nat, beg_bonus + beg_bless, beg_total, beg_saved ? "Resists!" : "Charmed!");
						if (!beg_saved and try_arcane_deflection_save(target, as_dc, beg_total)) beg_saved = true;
						if (!beg_saved and try_countercharm_reroll(target, as_dc, beg_bonus + beg_bless, "WIS save vs Beguiling Arrow")) beg_saved = true;
						if (!beg_saved) { int fg = try_flash_of_genius(target, as_dc, beg_total, "WIS save vs Beguiling Arrow"); if (fg >= as_dc) beg_saved = true; }
						if (!beg_saved) { int mv = try_maverick_spirit(target, as_dc, beg_total, "WIS save vs Beguiling Arrow"); if (mv >= as_dc) beg_saved = true; }
						if (!beg_saved and (ABILITY_WIS == ABILITY_INT or ABILITY_WIS == ABILITY_WIS or ABILITY_WIS == ABILITY_CHA) and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) beg_saved = true;
						if (!beg_saved) { int bf = try_boon_of_fate_bonus(target, beg_total, as_dc); if (bf >= as_dc) beg_saved = true; }
						if (!beg_saved and try_stroke_of_luck_save(target, as_dc, beg_bonus + beg_bless)) beg_saved = true;
						if (!beg_saved) {
							target.add_condition(COND_CHARMED);
							target.charm_spell_caster_id = c.id;
							broadcast_announce(target.name + " is charmed by Beguiling Arrow!", true);
						}
					}
				} else if (shot == "shadow") {
					// Shadow Arrow (Illusion, para 1642): 2d6 psychic + WIS save or blinded
					int sha_dmg = 0;
					for (int sd = 0; sd < shot_dice; sd++) sha_dmg += random(1, 6);
					combat.apply_damage(target, sha_dmg, DMG_PSYCHIC, c);
					if (!target.is_dead) {
						int sha_nat = random(1, 20);
						apply_hound_save_disadvantage(target, c.id, sha_nat);
						int sha_bonus = target.get_save_bonus(ABILITY_WIS);
						int sha_bless = roll_bless_bonus(target);
						int sha_total = sha_nat + sha_bonus + sha_bless;
						bool sha_saved = sha_total >= as_dc;
						broadcast_roll(target.name, "WIS save vs Shadow Arrow", sha_nat, sha_bonus + sha_bless, sha_total, sha_saved ? "Resists!" : "Blinded!");
						if (!sha_saved and try_arcane_deflection_save(target, as_dc, sha_total)) sha_saved = true;
						if (!sha_saved) { int fg = try_flash_of_genius(target, as_dc, sha_total, "WIS save vs Shadow Arrow"); if (fg >= as_dc) sha_saved = true; }
						if (!sha_saved) { int mv = try_maverick_spirit(target, as_dc, sha_total, "WIS save vs Shadow Arrow"); if (mv >= as_dc) sha_saved = true; }
						if (!sha_saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) sha_saved = true;
						if (!sha_saved) { int bf = try_boon_of_fate_bonus(target, sha_total, as_dc); if (bf >= as_dc) sha_saved = true; }
						if (!sha_saved and try_stroke_of_luck_save(target, as_dc, sha_bonus + sha_bless)) sha_saved = true;
						if (!sha_saved) {
							target.add_condition(COND_BLINDED);
							broadcast_announce(target.name + " is blinded by Shadow Arrow!", true);
						}
					}
				} else if (shot == "banishing") {
					// Banishing Arrow (Abjuration, para 1625): 2d6 force + CHA save or banished
					int ban_dmg = 0;
					for (int bd = 0; bd < shot_dice; bd++) ban_dmg += random(1, 6);
					combat.apply_damage(target, ban_dmg, DMG_FORCE, c);
					if (!target.is_dead) {
						int ban_nat = random(1, 20);
						apply_hound_save_disadvantage(target, c.id, ban_nat);
						int ban_bonus = target.get_save_bonus(ABILITY_CHA);
						int ban_bless = roll_bless_bonus(target);
						int ban_total = ban_nat + ban_bonus + ban_bless;
						bool ban_saved = ban_total >= as_dc;
						broadcast_roll(target.name, "CHA save vs Banishing Arrow", ban_nat, ban_bonus + ban_bless, ban_total, ban_saved ? "Resists!" : "Banished!");
						if (!ban_saved and try_arcane_deflection_save(target, as_dc, ban_total)) ban_saved = true;
						if (!ban_saved) { int fg = try_flash_of_genius(target, as_dc, ban_total, "CHA save vs Banishing Arrow"); if (fg >= as_dc) ban_saved = true; }
						if (!ban_saved) { int mv = try_maverick_spirit(target, as_dc, ban_total, "CHA save vs Banishing Arrow"); if (mv >= as_dc) ban_saved = true; }
						if (!ban_saved) { int bf = try_boon_of_fate_bonus(target, ban_total, as_dc); if (bf >= as_dc) ban_saved = true; }
						if (!ban_saved and try_stroke_of_luck_save(target, as_dc, ban_bonus + ban_bless)) ban_saved = true;
						if (!ban_saved) {
							target.add_condition(COND_INCAPACITATED);
							target.movement_remaining = 0;
							target.arcane_banish_source = c.id;
							broadcast_announce(target.name + " is banished! Incapacitated, speed 0 until start of " + c.name + "'s next turn.", true);
						}
					}
				} else if (shot == "enfeebling") {
					// Enfeebling Arrow (Necromancy, para 1632): 2d6 necrotic + CON save or halved
					int enf_dmg = 0;
					for (int ed = 0; ed < shot_dice; ed++) enf_dmg += random(1, 6);
					combat.apply_damage(target, enf_dmg, DMG_NECROTIC, c);
					if (!target.is_dead) {
						int enf_nat = random(1, 20);
						apply_hound_save_disadvantage(target, c.id, enf_nat);
						int enf_bonus = target.get_save_bonus(ABILITY_CON);
						int enf_bless = roll_bless_bonus(target);
						int enf_total = enf_nat + enf_bonus + enf_bless;
						bool enf_saved = enf_total >= as_dc;
						broadcast_roll(target.name, "CON save vs Enfeebling Arrow", enf_nat, enf_bonus + enf_bless, enf_total, enf_saved ? "Resists!" : "Enfeebled!");
						if (!enf_saved and try_arcane_deflection_save(target, as_dc, enf_total)) enf_saved = true;
						if (!enf_saved) { int fg = try_flash_of_genius(target, as_dc, enf_total, "CON save vs Enfeebling Arrow"); if (fg >= as_dc) enf_saved = true; }
						if (!enf_saved) { int bf = try_boon_of_fate_bonus(target, enf_total, as_dc); if (bf >= as_dc) enf_saved = true; }
						if (!enf_saved and try_stroke_of_luck_save(target, as_dc, enf_bonus + enf_bless)) enf_saved = true;
						if (!enf_saved) {
							target.arcane_enfeeble_source = c.id;
							broadcast_announce(target.name + " is enfeebled! Weapon damage halved until start of " + c.name + "'s next turn.", true);
						}
					}
				} else if (shot == "grasping") {
					// Grasping Arrow (Conjuration, para 1634): 2d6 poison + -10ft speed + move dmg
					int gra_dmg = 0;
					for (int gd = 0; gd < shot_dice; gd++) gra_dmg += random(1, 6);
					combat.apply_damage(target, gra_dmg, DMG_POISON, c);
					if (!target.is_dead) {
						target.arcane_grasping_active = true;
						target.arcane_grasping_source = c.id;
						target.arcane_grasping_rounds = 10;
						if (target.speed >= 10) target.speed -= 10;
						broadcast_announce(c.name + "'s Grasping Arrow deals " + gra_dmg + " poison and ensnares " + target.name + " in thorny brambles! Speed -10ft for 1 minute.", true);
					}
				} else {
					broadcast_announce(c.name + "'s Arcane Shot (" + shot + ") strikes " + target.name + "!", false);
				}
			}

			broadcast_state();
			check_battle_end();
			if (@combat == null or !combat.battle_active) return;

			combatant@ attacker = combat.get_combatant(pr.combatant_id);
			if (@attacker != null and attacker.is_alive()) {
				if (pr.is_spell_effect and pr.attacks_remaining > 0) {
					if (start_followup_spell_attack(attacker, pr, target)) return;
				}
				else if (attacker.is_player and pr.resolution_tag == "flurry") {
					if (pr.attacks_remaining > 0 and !target.is_dead) {
						start_flurry_strike(attacker, target, pr.attacks_remaining - 1);
						return;
					}
				}
				else if (attacker.is_player and pr.resolution_tag == "swift_quiver") {
					if (pr.attacks_remaining > 0 and !target.is_dead) {
						start_swift_quiver_strike(attacker, target, pr.attacks_remaining - 1);
						return;
					}
				}
				else if (attacker.is_player and combatant_is_controlled_by_bot(attacker)) {
					continue_player_bot_turn_after_attack(attacker, target);
					if (pr.resolution_tag == "resume_current_turn" and @combat != null and combat.battle_active) {
						resume_current_turn_after_interrupt();
					}
					return;
				}
				else if (attacker.is_player and attacker.attacks_remaining_this_turn > 0) {
					broadcast_announce(attacker.name + " has " + attacker.attacks_remaining_this_turn + " extra attack" + (attacker.attacks_remaining_this_turn > 1 ? "s" : "") + " remaining.", false);
					user@ atk_user = find_user_for_combatant(attacker);
					if (@atk_user != null) {
						atk_user.send({{"type", message_types::announce}, {"text", attacker.attacks_remaining_this_turn + " extra attack" + (attacker.attacks_remaining_this_turn > 1 ? "s" : "") + " remaining. Press F to Attack again, move, or take another action."}, {"interrupt", false}});
					}
				}
				// PHB 2024 Nick mastery (para 10341): "When you make the extra attack of the
				// Light property, you can make it as part of the Attack action instead of as a
				// Bonus Action. You can make this extra attack only once per turn."
				else if (attacker.is_player and attacker.attacks_remaining_this_turn <= 0
					and attacker.used_action and !attacker.twf_attack_used_this_turn
					and attacker.off_hand != "" and attacker.main_hand_mastery == MASTERY_NICK) {
					combatant@ nick_target = target;
					if (@nick_target == null or nick_target.is_dead) {
						@nick_target = null;
						int best_nd = 9999;
						for (uint nt = 0; nt < combat.combatants.length(); nt++) {
							combatant@ nc = combat.combatants[nt];
							if (@nc == null or nc.is_dead or nc.id == attacker.id) continue;
							if (!combat.are_hostile(attacker, nc)) continue;
							int nd = feet_distance(attacker.x, attacker.y, nc.x, nc.y);
							if (nd <= attacker.off_hand_range and nd < best_nd) { best_nd = nd; @nick_target = nc; }
						}
					}
					if (@nick_target != null and nick_target.is_alive()) {
						broadcast_announce(attacker.name + " makes a free off-hand attack (Nick)!", false);
						start_twf_offhand_strike(attacker, nick_target);
						return;
					}
				}
				else if (!attacker.is_player and pr.attacks_remaining > 0 and !target.is_dead) {
					combatant@ next_target = target;
					if (@next_target == null or next_target.is_dead) @next_target = find_nearest_target_for_monster(attacker);
					if (@next_target != null and next_target.is_alive()) {
						if (!start_monster_attack_sequence(attacker, next_target, pr.attack_index + 1, pr.attacks_remaining - 1)) {
							broadcast_announce(attacker.name + " ends its turn.");
							advance_turn();
						}
					} else {
						broadcast_announce(attacker.name + " ends its turn.");
						advance_turn();
					}
				}
				else if (!attacker.is_player) {
					broadcast_announce(attacker.name + " ends its turn.");
					advance_turn();
				}
			}
			if (pr.resolution_tag == "resume_current_turn" and @combat != null and combat.battle_active) {
				resume_current_turn_after_interrupt();
				return;
			}
			if (pr.resume_turn_start and @combat != null and combat.battle_active) {
				continue_pending_turn_start();
			}
		}

		else if (pr.roll_type == ROLL_DEATH_SAVE) {
			string outcome = "";
			if (natural_roll == 20) outcome = "Natural 20! " + c.name + " regains 1 HP and is back in the fight!";
			else if (natural_roll == 1) outcome = "Natural 1! Two failures!";
			else if (total >= DEATH_SAVE_DC) outcome = "Success!";
			else outcome = "Failure!";

			broadcast_roll(c.name, "death saving throw", natural_roll, reported_modifier, total, outcome);
			// Tasha's Eloquence Unfailing/Infectious Inspiration check
			bool ds_success = (natural_roll == 20 or (natural_roll != 1 and total >= DEATH_SAVE_DC));
			check_eloquence_inspiration(c, pr, ds_success, bardic_bonus);
			combat.process_death_save(c, natural_roll, total);

			if (c.is_dead) {
				broadcast_announce(c.name + " has died.", true);
				broadcast_to_battle({{"type", message_types::creature_died}, {"name", c.name}, {"id", c.id}});
			} else if (c.is_stable) {
				broadcast_announce(c.name + " has stabilized.");
				broadcast_to_battle({{"type", message_types::creature_stabilized}, {"name", c.name}, {"id", c.id}});
			} else {
				broadcast_announce(c.name + " has " + c.death_save_successes + " successes and " + c.death_save_failures + " failures.");
			}

			broadcast_state();

			check_battle_end();
			if (!combat.battle_active) return;
			advance_turn();
		}

		else if (pr.roll_type == ROLL_CONCENTRATION) {
			int dc = pr.dc > 0 ? pr.dc : int(pr.target_id);
			bool success = total >= dc;
			// Fighter L9 Indomitable (PHB 2024 paras 5976-5977): "If you fail a saving
			// throw, you can reroll it with a bonus equal to your Fighter level. You must
			// use the new roll, and you can't use this feature again until you finish a
			// Long Rest."
			// Auto-applies on a failed CON save vs concentration if the fighter has uses
			// remaining and is a high-stakes save (concentration on a battle-defining spell).
			if (!success and c.class_name == "Fighter" and c.indomitable_uses > 0) {
				c.indomitable_uses--;
				int reroll = random(1, 20) + pr.modifier + bless_bonus + c.level;
				broadcast_announce(c.name + "'s Indomitable rerolls the failed save: " + reroll + " (used " + (c.indomitable_uses == 0 ? "last use" : "1 use, " + c.indomitable_uses + " remaining") + ").", true);
				if (reroll >= dc) {
					total = reroll;
					success = true;
				}
			}
			// Xanathar's Zealot L6 Fanatical Focus (para 443-444)
			if (!success) {
				int ff_total = try_fanatical_focus(c, dc, total, pr.modifier + bless_bonus, "CON save (concentration)");
				if (ff_total >= dc) { total = ff_total; success = true; }
			}
			// Tasha's Eloquence Unfailing/Infectious Inspiration check
			check_eloquence_inspiration(c, pr, success, bardic_bonus);
			string outcome = success ? "Maintains concentration!" : "Concentration broken!";
			broadcast_roll(c.name, "Constitution save (DC " + dc + ")", natural_roll, reported_modifier, total, outcome);

			if (!success) {
				string ended_spell = c.concentration_spell;
				clear_concentration_effects(c);
				c.is_concentrating = false;
				c.remove_condition(COND_CONCENTRATING);
				broadcast_announce(c.name + "'s concentration on " + ended_spell + " is broken!");
				broadcast_to_battle({{"type", message_types::concentration_check}, {"name", c.name}, {"spell", ended_spell}, {"broken", true}});
				c.concentration_spell = "";
			} else {
				broadcast_to_battle({{"type", message_types::concentration_check}, {"name", c.name}, {"spell", c.concentration_spell}, {"broken", false}});
			}
			broadcast_state();
		}

		else if (pr.roll_type == ROLL_ABILITY_CHECK) {
			if (pr.resolution_tag == "hide") {
				bool success = total >= pr.dc;
				broadcast_roll(c.name, "Hide", natural_roll, reported_modifier, total, success ? "Hidden!" : "Not hidden.");
				check_eloquence_inspiration(c, pr, success, bardic_bonus);
				if (success) {
					c.is_hidden = true;
					c.hide_dc = total;
					c.add_condition(COND_HIDDEN);
					broadcast_announce(c.name + " slips out of sight.", true);
				} else {
					c.is_hidden = false;
					c.hide_dc = 0;
					c.remove_condition(COND_HIDDEN);
					broadcast_announce(c.name + " fails to hide.", false);
				}
				broadcast_state();
			} else {
				bool check_success = (pr.dc > 0 and total >= pr.dc);
				broadcast_roll(c.name, pr.reason, natural_roll, reported_modifier, total, "Total: " + total + ".");
				check_eloquence_inspiration(c, pr, check_success, bardic_bonus);
			}
		}
	}

	void process_roll_result(int natural_roll) {
		if (@current_roll == null or @combat == null) return;

		pending_roll@ pr = current_roll;
		@current_roll = null;

		combatant@ c = combat.get_combatant(pr.combatant_id);
		if (@c == null) return;
		// Basic Rules 2024 Beacon of Hope (para 12201): "whenever a creature
		// regains Hit Points ... also has Advantage on ... Death Saving Throws"
		if (pr.roll_type == ROLL_DEATH_SAVE and c.beacon_of_hope_active) {
			int beacon_second = random(1, 20);
			int beacon_chosen = natural_roll > beacon_second ? natural_roll : beacon_second;
			broadcast_announce(c.name + "'s Beacon of Hope grants advantage — rolled " + natural_roll + " and " + beacon_second + ", using " + beacon_chosen + ".", false);
			natural_roll = beacon_chosen;
		}
		// Tasha's Phantom Rogue L9 Tokens of the Departed (para 3454-3460):
		// "you have advantage on death saving throws" while holding soul trinkets.
		if (pr.roll_type == ROLL_DEATH_SAVE and c.soul_trinkets > 0) {
			int trinket_second = random(1, 20);
			int trinket_chosen = natural_roll > trinket_second ? natural_roll : trinket_second;
			broadcast_announce(c.name + "'s soul trinkets grant advantage — rolled " + natural_roll + " and " + trinket_second + ", using " + trinket_chosen + ".", false);
			natural_roll = trinket_chosen;
		}
		int bless_bonus = 0;
		if (c.blessed and (pr.roll_type == ROLL_ATTACK or pr.roll_type == ROLL_CONCENTRATION or pr.roll_type == ROLL_DEATH_SAVE)) {
			bless_bonus = roll_bless_bonus(c);
			if (bless_bonus > 0) {
				broadcast_announce(c.name + "'s Bless adds " + bless_bonus + " to the roll.", false);
			}
		}
		if (maybe_prompt_bardic_inspiration(pr, c, natural_roll, bless_bonus)) return;
		if (try_reroll_prompts(pr, c, natural_roll, bless_bonus, 0)) return;
		finalize_roll_result(pr, natural_roll, bless_bonus, 0);
	}

	void handle_roll_result(user@ u) {
		if (@current_roll == null or @combat == null or @u == null) return;
		if (current_roll.player_username != u.username) return;

		pending_roll@ pr = current_roll;
		combatant@ roller = combat.get_combatant(pr.combatant_id);

		if (pr.roll_type == ROLL_DAMAGE) {
			bool stepwise_damage = pr.damage_dice_count > 1 or pr.savage_attacker_reroll or can_use_savage_attacker(pr.is_spell_effect ? null : roller, pr);
			if (stepwise_damage) {
				int die_roll = roll_single_attack_damage_die(pr.is_spell_effect ? null : roller, pr);
				pr.rolls_completed++;
				pr.accumulated_natural += die_roll;

				string roller_name = @roller != null ? roller.name : pr.player_username;
				string roll_text = roller_name + " rolls " + pr.reason + ". ";
				if (pr.damage_dice_count > 1) roll_text += "Die " + pr.rolls_completed + " of " + pr.damage_dice_count + ": " + die_roll + ".";
				else roll_text += die_roll + ".";
				if (pr.savage_attacker_reroll) roll_text += " Savage Attacker reroll.";
				broadcast_announce(roll_text, false);

				if (pr.rolls_completed < pr.damage_dice_count) {
					send_roll_request(u, pr);
					return;
				}

				int natural = pr.accumulated_natural;
				pr.rolls_completed = 0;
				pr.accumulated_natural = 0;

				if (!pr.savage_attacker_reroll and can_use_savage_attacker(pr.is_spell_effect ? null : roller, pr)) {
					pr.savage_attacker_first_total = natural;
					pr.savage_attacker_reroll = true;
					send_private_announce(u, "Savage Attacker lets you reroll the weapon damage and keep the higher total.", true);
					send_roll_request(u, pr);
					return;
				}

				if (pr.savage_attacker_reroll and @roller != null) {
					roller.savage_attacker_used = true;
					int chosen = natural > pr.savage_attacker_first_total ? natural : pr.savage_attacker_first_total;
					int replaced = natural > pr.savage_attacker_first_total ? pr.savage_attacker_first_total : natural;
					broadcast_announce(roller.name + " uses Savage Attacker and keeps " + chosen + " weapon damage instead of " + replaced + ".", false);
					natural = chosen;
					pr.savage_attacker_reroll = false;
					pr.savage_attacker_first_total = 0;
				}

				process_roll_result(natural);
				return;
			}
		}

		if ((pr.roll_type == ROLL_ATTACK or pr.roll_type == ROLL_ABILITY_CHECK or pr.roll_type == ROLL_INITIATIVE) and (has_effective_advantage(pr) or has_effective_disadvantage(pr))) {
			int die_roll = random(1, pr.dice_sides);
			string roller_name = @roller != null ? roller.name : pr.player_username;
			string mode = has_effective_advantage(pr) ? "advantage" : "disadvantage";
			if (pr.rolls_completed == 0) {
				pr.first_natural = die_roll;
				pr.rolls_completed = 1;
				broadcast_announce(roller_name + " rolls " + pr.reason + ". First d20 for " + mode + ": " + die_roll + ".", false);
				send_roll_request(u, pr);
				return;
			}

			int natural = pr.first_natural;
			if (has_effective_advantage(pr) and die_roll > natural) natural = die_roll;
			else if (has_effective_disadvantage(pr) and die_roll < natural) natural = die_roll;

			broadcast_announce(roller_name + " rolls " + pr.reason + ". Second d20 for " + mode + ": " + die_roll + ". Using " + natural + ".", false);
			pr.rolls_completed = 0;
			pr.first_natural = 0;
			process_roll_result(natural);
			return;
		}

		int natural = 0;
		if (pr.roll_type == ROLL_DAMAGE) {
			natural = roll_attack_damage_natural(pr.is_spell_effect ? null : roller, pr);
		} else {
			natural = random(1, pr.dice_sides);
		}
		process_roll_result(natural);
	}

	void handle_bardic_response(user@ u, json_object@ msg) {
		if (@current_bardic_prompt == null or @u == null) return;
		if (current_bardic_prompt.player_username != u.username) return;

		pending_bardic_prompt@ prompt = current_bardic_prompt;
		@current_bardic_prompt = null;

		pending_roll@ pr = prompt.roll;
		combatant@ c = @pr != null ? combat.get_combatant(pr.combatant_id) : null;
		if (@pr == null or @c == null) return;

		bool use_die = msg.exists("use") ? bool(msg["use"]) : false;
		int bardic_bonus = 0;
		if (use_die and c.bardic_inspiration_die > 0) {
			int die_size = c.bardic_inspiration_die;
			pr.bardic_source_id = c.bardic_inspiration_source_id; // Track for Eloquence features
			pr.bardic_die_used = die_size;
			bardic_bonus = random(1, die_size);
			clear_bardic_inspiration(c, false);
			broadcast_announce(c.name + " uses Bardic Inspiration (" + die_label(die_size) + ") and adds " + bardic_bonus + " to the roll.", false);
		}

		if (!try_reroll_prompts(pr, c, prompt.natural_roll, prompt.bless_bonus, bardic_bonus)) {
			finalize_roll_result(pr, prompt.natural_roll, prompt.bless_bonus, bardic_bonus);
		}
	}

	// ---- Lucky / Heroic Inspiration Reroll Prompts ----

	// Check if a d20 roll would fail given the current total.
	// Returns true if the roll is a failure that could benefit from a reroll.
	bool roll_would_fail(pending_roll@ pr, combatant@ c, int natural_roll, int total) {
		if (@pr == null or @c == null) return false;
		if (natural_roll == 20) return false; // nat 20 always succeeds
		if (pr.roll_type == ROLL_ATTACK) {
			if (natural_roll == 1) return true; // nat 1 always misses
			combatant@ target = combat.get_combatant(pr.target_id);
			if (@target == null) return false;
			return total < target.armor_class;
		}
		else if (pr.roll_type == ROLL_CONCENTRATION) {
			return total < pr.dc;
		}
		else if (pr.roll_type == ROLL_DEATH_SAVE) {
			if (natural_roll == 1) return true;
			return total < DEATH_SAVE_DC;
		}
		else if (pr.roll_type == ROLL_ABILITY_CHECK and pr.resolution_tag == "hide") {
			return total < pr.dc;
		}
		else if (pr.roll_type == ROLL_ABILITY_CHECK and pr.dc > 0) {
			return total < pr.dc;
		}
		return false;
	}

	// Try Lucky then Heroic then Tactical Mind. Returns true if a prompt was sent.
	bool try_reroll_prompts(pending_roll@ pr, combatant@ c, int natural_roll, int bless_bonus, int bardic_bonus) {
		if (@pr == null or @c == null) return false;
		int total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
		if (!roll_would_fail(pr, c, natural_roll, total)) return false;
		// Xanathar's Divine Soul L1 Favored by the Gods (para 2547-2548): "If you fail
		// a saving throw or miss with an attack roll, you can roll 2d4 and add it to the
		// total, possibly changing the outcome. Once you use this feature, you can't use
		// it again until you finish a short or long rest."
		if (c.favored_by_gods_available and (pr.roll_type == ROLL_ATTACK or pr.roll_type == ROLL_CONCENTRATION or pr.roll_type == ROLL_DEATH_SAVE or pr.roll_type == ROLL_ABILITY_CHECK)) {
			int fbg_bonus = random(1, 4) + random(1, 4);
			c.favored_by_gods_available = false;
			bardic_bonus += fbg_bonus; // piggyback on additive bonus path
			broadcast_announce(c.name + "'s Favored by the Gods adds +" + fbg_bonus + " to the roll!", true);
			// Recheck if this turned the failure into a success
			int new_total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
			if (!roll_would_fail(pr, c, natural_roll, new_total)) {
				finalize_roll_result(pr, natural_roll, bless_bonus, bardic_bonus);
				return true;
			}
		}
		if (maybe_prompt_lucky(pr, c, natural_roll, bless_bonus, bardic_bonus)) return true;
		if (maybe_prompt_heroic(pr, c, natural_roll, bless_bonus, bardic_bonus)) return true;
		if (maybe_prompt_tactical_mind(pr, c, natural_roll, bless_bonus, bardic_bonus)) return true;
		return false;
	}

	bool maybe_prompt_lucky(pending_roll@ pr, combatant@ c, int natural_roll, int bless_bonus, int bardic_bonus) {
		if (@pr == null or @c == null) return false;
		if (!c.has_lucky_feat or c.luck_points <= 0) return false;
		if (!c.is_player) return false;

		int total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
		string prompt_text = "";
		if (pr.roll_type == ROLL_ATTACK) {
			combatant@ target = combat.get_combatant(pr.target_id);
			prompt_text = "You missed" + (@target != null ? " " + target.name : "") + "!";
		}
		else if (pr.roll_type == ROLL_CONCENTRATION) {
			prompt_text = "You failed your concentration save!";
		}
		else if (pr.roll_type == ROLL_DEATH_SAVE) {
			prompt_text = "You failed your death save!";
		}
		else if (pr.roll_type == ROLL_ABILITY_CHECK) {
			prompt_text = "Your check failed!";
		}
		else {
			return false;
		}

		user@ roller_user = find_user_for_combatant(c);
		if (@roller_user == null or roller_user.is_bot) {
			// Bot auto-uses Lucky
			c.luck_points--;
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int new_natural = roll1 > roll2 ? roll1 : roll2;
			broadcast_announce(c.name + " spends a Luck Point to reroll! (" + c.luck_points + " remaining). Rolled " + roll1 + " and " + roll2 + ", using " + new_natural + ".", false);
			finalize_roll_result(pr, new_natural, bless_bonus, bardic_bonus);
			return true;
		}

		pending_lucky_prompt prompt;
		prompt.player_username = c.player_username;
		@prompt.roll = pr;
		prompt.natural_roll = natural_roll;
		prompt.bless_bonus = bless_bonus;
		prompt.bardic_bonus = bardic_bonus;
		@current_lucky_prompt = prompt;

		roller_user.send({
			{"type", message_types::lucky_prompt},
			{"text", prompt_text + " Use a Luck Point to reroll? " + c.luck_points + " points remaining. Press L to use or Escape to save."},
			{"points", c.luck_points}
		});
		return true;
	}

	bool maybe_prompt_heroic(pending_roll@ pr, combatant@ c, int natural_roll, int bless_bonus, int bardic_bonus) {
		if (@pr == null or @c == null) return false;
		if (!c.has_heroic_inspiration) return false;
		if (!c.is_player) return false;

		int total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
		string prompt_text = "";
		if (pr.roll_type == ROLL_ATTACK) {
			combatant@ target = combat.get_combatant(pr.target_id);
			prompt_text = "You missed" + (@target != null ? " " + target.name : "") + "!";
		}
		else if (pr.roll_type == ROLL_CONCENTRATION) {
			prompt_text = "You failed your concentration save!";
		}
		else if (pr.roll_type == ROLL_DEATH_SAVE) {
			prompt_text = "You failed your death save!";
		}
		else if (pr.roll_type == ROLL_ABILITY_CHECK) {
			prompt_text = "Your check failed!";
		}
		else {
			return false;
		}

		user@ roller_user = find_user_for_combatant(c);
		if (@roller_user == null or roller_user.is_bot) {
			// Bot auto-uses Heroic Inspiration
			c.has_heroic_inspiration = false;
			int new_natural = random(1, 20);
			broadcast_announce(c.name + " uses Heroic Inspiration to reroll! New roll: " + new_natural + ".", false);
			finalize_roll_result(pr, new_natural, bless_bonus, bardic_bonus);
			return true;
		}

		pending_heroic_prompt prompt;
		prompt.player_username = c.player_username;
		@prompt.roll = pr;
		prompt.natural_roll = natural_roll;
		prompt.bless_bonus = bless_bonus;
		prompt.bardic_bonus = bardic_bonus;
		@current_heroic_prompt = prompt;

		roller_user.send({
			{"type", message_types::heroic_prompt},
			{"text", prompt_text + " Use Heroic Inspiration to reroll? Press H to use or Escape to save."}
		});
		return true;
	}

	void handle_lucky_response(user@ u, json_object@ msg) {
		if (@current_lucky_prompt == null or @u == null) return;
		if (current_lucky_prompt.player_username != u.username) return;

		pending_lucky_prompt@ prompt = current_lucky_prompt;
		@current_lucky_prompt = null;

		pending_roll@ pr = prompt.roll;
		combatant@ c = @pr != null ? combat.get_combatant(pr.combatant_id) : null;
		if (@pr == null or @c == null) return;

		bool use_point = msg.exists("use") ? bool(msg["use"]) : false;
		if (use_point and c.luck_points > 0) {
			c.luck_points--;
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int new_natural = roll1 > roll2 ? roll1 : roll2;
			broadcast_announce(c.name + " spends a Luck Point to reroll with advantage! (" + c.luck_points + " remaining). Rolled " + roll1 + " and " + roll2 + ", using " + new_natural + ".", false);
			if (!try_reroll_prompts(pr, c, new_natural, prompt.bless_bonus, prompt.bardic_bonus)) {
				finalize_roll_result(pr, new_natural, prompt.bless_bonus, prompt.bardic_bonus);
			}
		} else {
			// Declined Lucky - try Heroic, then Tactical Mind, then finalize.
			if (!maybe_prompt_heroic(pr, c, prompt.natural_roll, prompt.bless_bonus, prompt.bardic_bonus)) {
				if (!maybe_prompt_tactical_mind(pr, c, prompt.natural_roll, prompt.bless_bonus, prompt.bardic_bonus)) {
					finalize_roll_result(pr, prompt.natural_roll, prompt.bless_bonus, prompt.bardic_bonus);
				}
			}
		}
	}

	void handle_heroic_response(user@ u, json_object@ msg) {
		if (@current_heroic_prompt == null or @u == null) return;
		if (current_heroic_prompt.player_username != u.username) return;

		pending_heroic_prompt@ prompt = current_heroic_prompt;
		@current_heroic_prompt = null;

		pending_roll@ pr = prompt.roll;
		combatant@ c = @pr != null ? combat.get_combatant(pr.combatant_id) : null;
		if (@pr == null or @c == null) return;

		bool use_it = msg.exists("use") ? bool(msg["use"]) : false;
		if (use_it and c.has_heroic_inspiration) {
			c.has_heroic_inspiration = false;
			int new_natural = random(1, 20);
			broadcast_announce(c.name + " uses Heroic Inspiration to reroll! New roll: " + new_natural + ".", false);
			// After the reroll, the new natural roll might still fail — try Tactical Mind chain.
			if (!try_reroll_prompts(pr, c, new_natural, prompt.bless_bonus, prompt.bardic_bonus)) {
				finalize_roll_result(pr, new_natural, prompt.bless_bonus, prompt.bardic_bonus);
			}
		} else {
			// Declined Heroic — try Tactical Mind next.
			if (!maybe_prompt_tactical_mind(pr, c, prompt.natural_roll, prompt.bless_bonus, prompt.bardic_bonus)) {
				finalize_roll_result(pr, prompt.natural_roll, prompt.bless_bonus, prompt.bardic_bonus);
			}
		}
	}

	// PHB 2024 Fighter L2 Tactical Mind (para 5113-5114): "When you fail an ability
	// check, you can expend a use of your Second Wind to push yourself toward
	// success. Rather than regaining Hit Points, you roll 1d10 and add the number
	// rolled to the ability check, potentially turning it into a success. If the
	// check still fails, this use of Second Wind isn't expended."
	bool maybe_prompt_tactical_mind(pending_roll@ pr, combatant@ c, int natural_roll, int bless_bonus, int bardic_bonus) {
		if (@pr == null or @c == null) return false;
		if (c.class_name != "Fighter") return false;
		if (c.level < 2) return false;
		if (c.second_wind_uses_remaining <= 0) return false;
		if (pr.roll_type != ROLL_ABILITY_CHECK) return false;
		if (pr.dc <= 0) return false;
		if (!c.is_player) return false;

		int total = natural_roll + pr.modifier + bless_bonus + bardic_bonus;
		if (total >= pr.dc) return false;
		int failure_margin = pr.dc - total;

		user@ roller_user = find_user_for_combatant(c);
		if (@roller_user == null or roller_user.is_bot) {
			// Bot heuristic: only use if 1d10 average (5.5) is enough to flip success.
			if (failure_margin > 5) return false;
			int tm_roll = random(1, 10);
			int new_total = total + tm_roll;
			bool succeeded = new_total >= pr.dc;
			if (succeeded) {
				c.second_wind_uses_remaining--;
				c.second_wind_available = (c.second_wind_uses_remaining > 0);
				broadcast_announce(c.name + "'s Tactical Mind rolls a " + tm_roll + " and turns the check into a success! " + c.second_wind_uses_remaining + " Second Wind use" + (c.second_wind_uses_remaining == 1 ? "" : "s") + " remain.", false);
				// Bypass dc-fail finalize: nudge total via bardic_bonus channel so it actually succeeds.
				finalize_roll_result(pr, natural_roll, bless_bonus, bardic_bonus + tm_roll);
			} else {
				// Use is NOT expended on a fail.
				broadcast_announce(c.name + "'s Tactical Mind rolls a " + tm_roll + " but the check still fails. The Second Wind use is not expended.", false);
				finalize_roll_result(pr, natural_roll, bless_bonus, bardic_bonus);
			}
			return true;
		}

		pending_tactical_mind_prompt prompt;
		prompt.player_username = c.player_username;
		@prompt.roll = pr;
		prompt.natural_roll = natural_roll;
		prompt.bless_bonus = bless_bonus;
		prompt.bardic_bonus = bardic_bonus;
		@current_tactical_mind_prompt = prompt;

		string label = pr.reason != "" ? pr.reason : "ability check";
		roller_user.send({
			{"type", message_types::tactical_mind_prompt},
			{"text", "Your " + label + " failed by " + failure_margin + ". Spend a Second Wind use on Tactical Mind to roll 1d10 and add it? Press T to use, Escape to skip. " + c.second_wind_uses_remaining + " Second Wind use" + (c.second_wind_uses_remaining == 1 ? "" : "s") + " remain."},
			{"uses", c.second_wind_uses_remaining}
		});
		return true;
	}

	void handle_tactical_mind_response(user@ u, json_object@ msg) {
		if (@current_tactical_mind_prompt == null or @u == null) return;
		if (current_tactical_mind_prompt.player_username != u.username) return;

		pending_tactical_mind_prompt@ prompt = current_tactical_mind_prompt;
		@current_tactical_mind_prompt = null;

		pending_roll@ pr = prompt.roll;
		combatant@ c = @pr != null ? combat.get_combatant(pr.combatant_id) : null;
		if (@pr == null or @c == null) return;

		bool use_it = msg.exists("use") ? bool(msg["use"]) : false;
		if (use_it and c.second_wind_uses_remaining > 0) {
			int tm_roll = random(1, 10);
			int total = prompt.natural_roll + pr.modifier + prompt.bless_bonus + prompt.bardic_bonus + tm_roll;
			bool succeeded = total >= pr.dc;
			if (succeeded) {
				c.second_wind_uses_remaining--;
				c.second_wind_available = (c.second_wind_uses_remaining > 0);
				broadcast_announce(c.name + "'s Tactical Mind rolls a " + tm_roll + " and turns the check into a success! " + c.second_wind_uses_remaining + " Second Wind use" + (c.second_wind_uses_remaining == 1 ? "" : "s") + " remain.", false);
				finalize_roll_result(pr, prompt.natural_roll, prompt.bless_bonus, prompt.bardic_bonus + tm_roll);
			} else {
				// Use is NOT expended on a fail per source.
				broadcast_announce(c.name + "'s Tactical Mind rolls a " + tm_roll + " but the check still fails. The Second Wind use is not expended.", false);
				finalize_roll_result(pr, prompt.natural_roll, prompt.bless_bonus, prompt.bardic_bonus);
			}
		} else {
			finalize_roll_result(pr, prompt.natural_roll, prompt.bless_bonus, prompt.bardic_bonus);
		}
	}

	// ---- Smite Response (Divine + Eldritch) ----
	void handle_smite_response(user@ u, json_object@ msg) {
		if (@current_smite_prompt == null or @u == null) return;
		if (current_smite_prompt.player_username != u.username) return;

		pending_smite_prompt@ sp = current_smite_prompt;
		@current_smite_prompt = null;

		pending_roll@ dmg_pr = sp.damage_roll;
		if (@dmg_pr == null) return;
		combatant@ c = combat.get_combatant(dmg_pr.combatant_id);
		if (@c == null) return;

		int slot_used = msg.exists("slot") ? int(msg["slot"]) : 0;
		bool smite_was_used = false;

		if (sp.smite_type == "divine") {
			// ---- Divine Smite resolution ----
			if (slot_used >= 1 and slot_used <= 5 and c.spell_slots_current[slot_used] > 0) {
				c.spell_slots_current[slot_used]--;
				// Divine Smite: (slot_level + 1)d8 radiant, doubled on crit
				int smite_dice = slot_used + 1;
				if (smite_dice > 5) smite_dice = 5; // Cap at 5d8
				if (sp.is_crit) smite_dice *= 2;
				// Add smite as extra damage on the pending damage roll
				dmg_pr.extra_damage_dice_count += smite_dice;
				dmg_pr.extra_damage_dice_sides = 8;
				dmg_pr.extra_damage_type = DMG_RADIANT;
				broadcast_announce(c.name + " channels Divine Smite! (" + smite_dice + "d8 radiant, level " + slot_used + " slot)", true);
				smite_was_used = true;
			}
			// Remove old divine_smite_pending flag if it was set
			c.divine_smite_pending = false;
			c.divine_smite_slot_level = 0;

			// Chain: after Divine Smite resolves, check if Eldritch Smite is also available
			// Only chain if the player actually used a smite (slot_used > 0 means they engaged, not skipped)
			if (slot_used > 0 and c.eldritch_smite and c.pact_of_the_blade
				and dmg_pr.is_weapon_attack and !c.eldritch_smite_used_this_turn) {
				combatant@ chain_target = combat.get_combatant(dmg_pr.target_id);
				if (@chain_target != null and !chain_target.is_dead) {
					int es_highest = 0;
					for (int sl = 5; sl >= 1; sl--) {
						if (c.spell_slots_current[sl] > 0) { es_highest = sl; break; }
					}
					if (es_highest > 0) {
						user@ esu = find_user_for_combatant(c);
						if (@esu != null and !esu.is_bot) {
							pending_smite_prompt esp;
							esp.player_username = c.player_username;
							@esp.damage_roll = dmg_pr;
							esp.is_crit = sp.is_crit;
							esp.highest_slot = es_highest;
							esp.smite_type = "eldritch";
							@current_smite_prompt = esp;
							string es_slots = "";
							for (int sl = 1; sl <= 5; sl++) {
								if (c.spell_slots_current[sl] > 0) {
									int es_dice = 1 + sl;
									if (sp.is_crit) es_dice *= 2;
									if (es_slots != "") es_slots += ", ";
									es_slots += "Level " + sl + " (" + es_dice + "d8 force + Prone, " + c.spell_slots_current[sl] + " slots)";
								}
							}
							esu.send({{"type", message_types::smite_prompt}, {"slots", es_slots}, {"is_crit", sp.is_crit}, {"target", chain_target.name}, {"smite_type", "eldritch"}});
							return; // Wait for second smite_response
						}
					}
				}
			}
		} else if (sp.smite_type == "eldritch") {
			// ---- Eldritch Smite resolution ----
			if (slot_used >= 1 and slot_used <= 5 and c.spell_slots_current[slot_used] > 0) {
				c.eldritch_smite_used_this_turn = true;
				c.spell_slots_current[slot_used]--;
				// Eldritch Smite: (1 + slot_level)d8 force damage
				int smite_dice = 1 + slot_used;
				if (sp.is_crit) smite_dice *= 2;
				// Add smite as extra damage on the pending damage roll
				dmg_pr.extra_damage_dice_count += smite_dice;
				dmg_pr.extra_damage_dice_sides = 8;
				dmg_pr.extra_damage_type = DMG_FORCE;
				broadcast_announce(c.name + " unleashes Eldritch Smite! (" + smite_dice + "d8 force, level " + slot_used + " slot)", true);
				// Prone if target is Huge or smaller
				combatant@ es_target = combat.get_combatant(dmg_pr.target_id);
				if (@es_target != null and es_target.size <= SIZE_HUGE and !es_target.has_condition(COND_PRONE)) {
					es_target.add_condition(COND_PRONE);
					broadcast_announce(es_target.name + " is knocked prone by the Eldritch Smite!", true);
				}
				smite_was_used = true;
			}

			// Chain: after Eldritch Smite resolves, check if Divine Smite is also available
			// Only chain if the player actually used a smite (slot_used > 0)
			if (slot_used > 0 and c.class_name == "Paladin" and !c.divine_smite_pending
				and dmg_pr.is_weapon_attack and !c.main_hand_is_ranged and get_attack_range(c, false) <= 5) {
				int ds_highest = 0;
				for (int sl = 5; sl >= 1; sl--) {
					if (c.spell_slots_current[sl] > 0) { ds_highest = sl; break; }
				}
				if (ds_highest > 0) {
					combatant@ chain_target2 = combat.get_combatant(dmg_pr.target_id);
					if (@chain_target2 != null and !chain_target2.is_dead) {
						user@ dsu = find_user_for_combatant(c);
						if (@dsu != null and !dsu.is_bot) {
							pending_smite_prompt dsp;
							dsp.player_username = c.player_username;
							@dsp.damage_roll = dmg_pr;
							dsp.is_crit = sp.is_crit;
							dsp.highest_slot = ds_highest;
							dsp.smite_type = "divine";
							@current_smite_prompt = dsp;
							string ds_slots = "";
							for (int sl = 1; sl <= 5; sl++) {
								if (c.spell_slots_current[sl] > 0) {
									int ds_dice = sl + 1;
									if (ds_dice > 5) ds_dice = 5;
									if (sp.is_crit) ds_dice *= 2;
									if (ds_slots != "") ds_slots += ", ";
									ds_slots += "Level " + sl + " (" + ds_dice + "d8, " + c.spell_slots_current[sl] + " slots)";
								}
							}
							dsu.send({{"type", message_types::smite_prompt}, {"slots", ds_slots}, {"is_crit", sp.is_crit}, {"target", chain_target2.name}, {"smite_type", "divine"}});
							return; // Wait for second smite_response
						}
					}
				}
			}
		}

		// Resume damage roll
		@current_roll = dmg_pr;
		user@ du = find_user_for_combatant(c);
		if (@du != null and !du.is_bot and c.is_player) {
			send_roll_request(du, dmg_pr);
		} else {
			process_roll_result(roll_attack_damage_natural(c, dmg_pr));
		}
	}

	// ---- Reaction Prompt Response ----
	void handle_reaction_response(user@ u, json_object@ msg) {
		if (@current_reaction_prompt == null or @u == null) return;
		if (current_reaction_prompt.defender_username != u.username) return;

		pending_reaction_prompt@ rp = current_reaction_prompt;
		@current_reaction_prompt = null;

		combatant@ defender = combat.get_combatant(rp.defender_id);
		combatant@ attacker = combat.get_combatant(rp.attacker_id);
		if (@defender == null or @attacker == null) return;

		string choice = msg.exists("choice") ? string(msg["choice"]) : "none";

		if (choice == "shield" and defender.is_player) {
			// Shield spell: +5 AC until start of next turn, consumes reaction + level 1 slot
			int slot_used = -1;
			for (int sl = 1; sl <= 9; sl++) {
				if (defender.spell_slots_current[sl] > 0) { slot_used = sl; break; }
			}
			if (slot_used > 0) {
				defender.spell_slots_current[slot_used]--;
				defender.has_reaction = false;
				clear_shield_effect(defender, false);
				defender.shield_active = true;
				defender.shield_ac_bonus = 5;
				defender.armor_class += 5;
				broadcast_announce(defender.name + " casts Shield as a reaction! AC increased by 5.", true);
			}
		}
		else if (choice == "cutting_words" and defender.is_player) {
			// Cutting Words (Lore Bard): subtract inspiration die from attack roll
			if (defender.bardic_inspiration_uses > 0) {
				defender.bardic_inspiration_uses--;
				defender.has_reaction = false;
				int cut = random(1, defender.bardic_inspiration_die);
				rp.attack_total -= cut;
				broadcast_announce(defender.name + " uses Cutting Words! Attack roll reduced by " + cut + ".", true);
			}
		}
		else if (choice == "warding_flare" and defender.is_player) {
			// Warding Flare (Light Cleric): impose disadvantage on the attack (re-roll attack, take lower)
			if (defender.warding_flare_uses > 0) {
				defender.warding_flare_uses--;
				defender.has_reaction = false;
				int second_roll = random(1, 20);
				if (second_roll < rp.natural_roll) {
					int atk_bonus = rp.attack_total - rp.natural_roll;
					rp.attack_total = second_roll + atk_bonus;
					rp.natural_roll = second_roll;
				}
				broadcast_announce(defender.name + " uses Warding Flare! Attacker rerolls: " + rp.natural_roll + ".", true);
			}
		}
		else if (choice == "defensive_duelist" and defender.is_player) {
			// Feat: Defensive Duelist — add Proficiency Bonus to AC for this attack
			if (defender.has_feat("defensive_duelist")) {
				defender.has_reaction = false;
				// Apply AC bonus by increasing the threshold the attack must beat
				int temp_ac_bonus = defender.proficiency;
				defender.armor_class += temp_ac_bonus;
				broadcast_announce(defender.name + " uses Defensive Duelist! +" + temp_ac_bonus + " AC against this attack.", true);
				// Revert the AC bonus after resolving this attack (done in resume_attack_after_reaction)
				// We'll track this with a temporary field
				defender.temp_ac_bonus_this_attack = temp_ac_bonus;
			}
		}
		else if (choice == "restore_balance" and defender.is_player) {
			// Tasha's Clockwork Soul L1 Restore Balance (para 3993-3996): "When a creature
			// you can see within 60 feet of you is about to roll a d20 with advantage or
			// disadvantage, you can use your reaction to prevent the roll from being affected
			// by advantage and disadvantage." Reroll a single d20 to replace the advantaged
			// roll (since the advantage roll already resolved, we substitute a flat d20).
			if (defender.restore_balance_uses > 0) {
				defender.restore_balance_uses--;
				defender.has_reaction = false;
				int reroll = random(1, 20);
				int diff = rp.natural_roll - reroll;
				rp.natural_roll = reroll;
				rp.attack_total -= diff;
				broadcast_announce(defender.name + " invokes Restore Balance! Advantage canceled — rerolled to " + reroll + ". (" + defender.restore_balance_uses + " uses remain)", true);
			}
		}
		else if (choice == "spirit_shield" and defender.is_player) {
			// Xanathar's Ancestral Guardian L6 Spirit Shield (para 391-393): reduce
			// incoming damage by 2d6/3d6/4d6.
			if (defender.raging and defender.class_name == "Barbarian" and defender.subclass == "Ancestral Guardian") {
				defender.has_reaction = false;
				int reduction = random(1, 6) + random(1, 6);
				if (defender.level >= 10) reduction += random(1, 6);
				if (defender.level >= 14) reduction += random(1, 6);
				defender.spirit_shield_reduction = reduction;
				broadcast_announce(defender.name + " summons Spirit Shield! Next damage reduced by " + reduction + ".", true);
				// Xanathar's Ancestral Guardian L14 Vengeful Ancestors (para 397-398):
				// "the attacker takes an amount of force damage equal to the damage that
				// your Spirit Shield prevents."
				if (defender.level >= 14 and @combat != null) {
					combatant@ ss_attacker = combat.get_combatant(rp.attacker_id);
					if (@ss_attacker != null and !ss_attacker.is_dead) {
						combat.apply_damage(ss_attacker, reduction, DMG_FORCE, defender);
						broadcast_announce(defender.name + "'s Vengeful Ancestors deal " + reduction + " force damage to " + ss_attacker.name + "!", true);
					}
				}
			}
		}
		else if (choice == "entropic_ward" and defender.is_player) {
			// Great Old One: Entropic Ward — turn a hit into a miss
			if (defender.class_name == "Warlock" and defender.subclass == "Great Old One Patron") {
				defender.has_reaction = false;
				defender.entropic_ward_pending = false;
				// Force the attack to miss
				rp.attack_total = 0;
				broadcast_announce(defender.name + " invokes Entropic Ward! The attack misses.", true);
			}
		}
		else if (choice == "arcane_deflection" and defender.is_player) {
			// Xanathar's War Magic L2 Arcane Deflection (para 2932-2934): "When you are hit
			// by an attack... you can use your reaction to gain a +2 bonus to your AC against
			// that attack." (NOT +4 — +4 is for saving throws only.)
			if (defender.class_name == "Wizard" and defender.subclass == "War Magic") {
				defender.has_reaction = false;
				defender.armor_class += 2;
				defender.temp_ac_bonus_this_attack = 2;
				broadcast_announce(defender.name + " invokes Arcane Deflection! +2 AC against this attack.", true);
				// L14 Deflecting Shroud (para 2943-2944): "When you use your Arcane Deflection,
				// up to three creatures of your choice within 60 feet take force damage equal
				// to half your wizard level."
				if (defender.deflecting_shroud_active and defender.level >= 14) {
					int shroud_dmg = defender.level / 2;
					if (shroud_dmg < 1) shroud_dmg = 1;
					int targets_hit = 0;
					for (uint dsi = 0; dsi < combat.combatants.length(); dsi++) {
						if (targets_hit >= 3) break;
						combatant@ ds_target = combat.combatants[dsi];
						if (@ds_target == null or ds_target.is_dead) continue;
						if (ds_target.is_player == defender.is_player) continue; // Only enemies
						float dsx = float(ds_target.x - defender.x);
						float dsy = float(ds_target.y - defender.y);
						float ds_dist = sqrt(dsx * dsx + dsy * dsy) * 5.0f;
						if (ds_dist <= 60) {
							combat.apply_damage(ds_target, shroud_dmg, DMG_FORCE, defender);
							broadcast_announce(ds_target.name + " takes " + shroud_dmg + " force damage from Deflecting Shroud!", false);
							targets_hit++;
						}
					}
				}
			}
		}
		else if (choice == "warding_maneuver" and defender.is_player) {
			// Xanathar's Cavalier L7 Warding Maneuver (para 1674-1676): "roll 1d8 as a
			// reaction [...] add the number rolled to the target's AC. If the attack still
			// hits, the target has resistance against the attack's damage."
			if (defender.class_name == "Fighter" and defender.subclass == "Cavalier" and defender.warding_maneuver_uses > 0) {
				defender.has_reaction = false;
				defender.warding_maneuver_uses--;
				int ward_roll = random(1, 8);
				if (rp.attack_total < defender.armor_class + ward_roll) {
					rp.attack_total = 0; // miss
					broadcast_announce(defender.name + "'s Warding Maneuver rolls +" + ward_roll + " AC — the attack misses! (" + defender.warding_maneuver_uses + " uses remaining)", true);
				} else {
					defender.warding_maneuver_resistance = true;
					broadcast_announce(defender.name + "'s Warding Maneuver rolls +" + ward_roll + " AC — attack still hits, but grants resistance! (" + defender.warding_maneuver_uses + " uses remaining)", true);
				}
			}
		}
		else if (choice == "armor_of_hexes" and defender.is_player) {
			// Xanathar's Hexblade L10 Armor of Hexes (para 2792-2793): "you can use your
			// reaction to roll a d6. On a 4 or higher, the attack instead misses you."
			if (defender.class_name == "Warlock" and defender.subclass == "The Hexblade" and defender.armor_of_hexes_active) {
				defender.has_reaction = false;
				int hex_roll = random(1, 6);
				if (hex_roll >= 4) {
					rp.attack_total = 0;
					broadcast_announce(defender.name + "'s Armor of Hexes rolls " + hex_roll + " — the attack misses!", true);
				} else {
					broadcast_announce(defender.name + "'s Armor of Hexes rolls " + hex_roll + " — not enough to deflect.", false);
				}
			}
		}
		else if (choice == "deflect_attacks" and defender.is_player) {
			// PHB 2024 Monk L3 Deflect Attacks (para 5337-5339): "you can take a Reaction
			// to reduce the attack's total damage against you. The reduction equals 1d10
			// plus your Dexterity modifier and Monk level."
			if (defender.class_name == "Monk" and defender.level >= 3) {
				defender.has_reaction = false;
				int reduction = random(1, 10) + defender.get_ability_mod(ABILITY_DEX) + defender.level;
				if (reduction < 0) reduction = 0;
				defender.deflect_attacks_reduction = reduction;
				// Cache damage type so if the reduction zeroes out, a later redirect uses
				// the correct type (same as source attack per para 5339).
				int dtype = (@rp.attack_roll != null and rp.attack_roll.damage_dice_count > 0)
					? rp.attack_roll.damage_type
					: get_attack_damage_type(attacker, false);
				defender.deflect_attacks_orig_damage_type = dtype;
				broadcast_announce(defender.name + " uses Deflect Attacks! Incoming damage reduced by " + reduction + ".", true);
			}
		}
		else if (choice == "uncanny_dodge" and defender.is_player) {
			// PHB 2024 Rogue L5 Uncanny Dodge (para 6561-6562): "halve the attack's
			// damage against you (round down)." Reaction-gated; halving is applied
			// when the damage roll resolves in apply_damage.
			if (defender.class_name == "Rogue" and defender.level >= 5 and !defender.has_condition(COND_INCAPACITATED)) {
				defender.has_reaction = false;
				defender.uncanny_dodge_pending = true;
				broadcast_announce(defender.name + " uses Uncanny Dodge! Incoming damage will be halved.", true);
			}
		}
		else if (choice == "shadowy_dodge" and defender.is_player) {
			// Xanathar's Gloom Stalker L15 Shadowy Dodge (para 2162-2163): "you can use
			// your reaction to impose disadvantage on it." Roll a second d20 and take
			// the lower of the two to simulate imposed disadvantage.
			if (defender.shadowy_dodge_active) {
				defender.has_reaction = false;
				int second_roll = random(1, 20);
				int original_roll = rp.natural_roll;
				int lower_roll = (second_roll < original_roll) ? second_roll : original_roll;
				int diff = original_roll - lower_roll;
				rp.natural_roll = lower_roll;
				rp.attack_total -= diff;
				broadcast_announce(defender.name + " uses Shadowy Dodge! Second d20: " + second_roll + " (takes lower: " + lower_roll + "). New attack total: " + rp.attack_total + ".", true);
			}
		}
		else if (choice == "spectral_defense" and defender.is_player) {
			// Xanathar's Horizon Walker L15 Spectral Defense (para 2208-2209): "When
			// you take damage from an attack, you can use your reaction to give yourself
			// resistance to all of that attack's damage on this turn."
			if (defender.spectral_defense_active) {
				defender.has_reaction = false;
				// Set a temporary flag that apply_damage will read to halve damage
				defender.warding_maneuver_resistance = true; // reuse existing resistance flag
				broadcast_announce(defender.name + " uses Spectral Defense! Resistance to all damage from this attack.", true);
			}
		}
		else if (choice == "storms_fury" and defender.is_player) {
			// Xanathar's Storm Sorcery L14 Storm's Fury (para 2635-2636): "when you
			// are hit by a melee attack, you can use your reaction to deal lightning
			// damage to the attacker. The damage equals your sorcerer level. The
			// attacker must also make a Strength saving throw against your sorcerer
			// spell save DC. On a failed save, the attacker is pushed in a straight
			// line up to 20 feet away from you."
			if (defender.storms_fury_active and defender.class_name == "Sorcerer" and defender.level >= 14) {
				defender.has_reaction = false;
				int sf_damage = defender.level;
				combat.apply_damage(attacker, sf_damage, DMG_LIGHTNING, defender);
				broadcast_announce(defender.name + "'s Storm's Fury deals " + sf_damage + " lightning damage to " + attacker.name + "!", true);
				if (attacker.is_dead) {
					broadcast_to_battle({{"type", message_types::creature_died}, {"name", attacker.name}, {"is_player", attacker.is_player}, {"killed_by", defender.name}, {"was_full_hp", false}, {"was_overkill", false}, {"was_stealth", false}});
				} else {
					int spell_dc = 8 + defender.proficiency + defender.get_ability_mod(ABILITY_CHA);
					int str_save = random(1, 20) + attacker.get_ability_mod(ABILITY_STR);
					if (str_save < spell_dc) {
						broadcast_announce(attacker.name + " fails the STR save (DC " + spell_dc + ") and is pushed 20 feet!", false);
						// Push 20 ft away from defender
						int dx = attacker.x - defender.x;
						int dy = attacker.y - defender.y;
						if (dx == 0 and dy == 0) dx = 1; // default push direction
						int push_dist = 20;
						if (dx != 0 or dy != 0) {
							float mag = sqrt(float(dx * dx + dy * dy));
							attacker.x += int(float(dx) / mag * float(push_dist));
							attacker.y += int(float(dy) / mag * float(push_dist));
						}
					} else {
						broadcast_announce(attacker.name + " resists the push (STR save " + str_save + " vs DC " + spell_dc + ").", false);
					}
				}
			}
		}

		// Resume attack resolution with potentially modified attack total
		// Re-check hit with updated values
		resume_attack_after_reaction(rp);
	}

	void resume_attack_after_reaction(pending_reaction_prompt@ rp) {
		pending_roll@ pr = rp.attack_roll;
		if (@pr == null) return;
		combatant@ c = combat.get_combatant(pr.combatant_id);
		combatant@ target = combat.get_combatant(rp.defender_id);
		if (@c == null or @target == null) return;

		int natural_roll = rp.natural_roll;
		int total = rp.attack_total;
		bool is_crit = (natural_roll >= get_critical_threshold(c, pr));
		bool is_fumble = (natural_roll == 1);
		bool hit = false;

		if (is_crit) {
			hit = true;
		} else if (is_fumble) {
			hit = false;
		} else {
			hit = total >= target.armor_class;
		}

		// Revert Defensive Duelist temporary AC bonus after this attack resolves
		if (target.temp_ac_bonus_this_attack > 0) {
			target.armor_class -= target.temp_ac_bonus_this_attack;
			target.temp_ac_bonus_this_attack = 0;
		}

		string outcome = "";
		if (is_crit) outcome = "Critical hit!";
		else if (is_fumble) outcome = "Miss!";
		else if (hit) outcome = "Hit!";
		else outcome = "Miss! (AC " + target.armor_class + ")";

		if (hit) {
			// Build damage roll and proceed (same as normal hit flow)
			int dmg_count = pr.damage_dice_count > 0 ? pr.damage_dice_count : get_attack_damage_count(c, false);
			int dmg_sides = pr.damage_dice_sides > 0 ? pr.damage_dice_sides : get_attack_damage_dice(c, false);
			int dmg_mod = pr.damage_dice_count > 0 ? pr.damage_modifier : get_damage_modifier_for_attack(c, false);
			int dmg_type = pr.damage_dice_count > 0 ? pr.damage_type : get_attack_damage_type(c, false);
			string dmg_attack_name = pr.attack_name != "" ? pr.attack_name : get_attack_name(c, false);

			pending_roll dmg_pr;
			dmg_pr.combatant_id = c.id;
			dmg_pr.player_username = c.is_player ? c.player_username : c.name;
			dmg_pr.roll_type = ROLL_DAMAGE;
			dmg_pr.dice_sides = dmg_sides;
			dmg_pr.modifier = dmg_mod;
			dmg_pr.reason = dmg_attack_name + " damage";
			dmg_pr.target_id = target.id;
			dmg_pr.attack_name = dmg_attack_name;
			dmg_pr.attack_index = pr.attack_index;
			dmg_pr.damage_dice_count = is_crit ? dmg_count * 2 : dmg_count;
			dmg_pr.damage_dice_sides = dmg_sides;
			dmg_pr.damage_modifier = dmg_mod;
			dmg_pr.damage_type = dmg_type;
			dmg_pr.is_weapon_attack = pr.is_weapon_attack;
			dmg_pr.is_crit = is_crit;
			dmg_pr.is_spell_effect = pr.is_spell_effect;
			dmg_pr.attacks_remaining = pr.attacks_remaining;
			dmg_pr.resolution_tag = pr.resolution_tag;
			dmg_pr.resume_turn_start = pr.resume_turn_start;

			// Check for Divine Smite prompt (Paladin melee hit, only if not pre-cast)
			if (c.class_name == "Paladin" and c.is_player and !c.divine_smite_pending and pr.is_weapon_attack and !pr.is_spell_effect and !c.main_hand_is_ranged and get_attack_range(c, false) <= 5) {
				int highest_slot = 0;
				for (int sl = 5; sl >= 1; sl--) {
					if (c.spell_slots_current[sl] > 0) { highest_slot = sl; break; }
				}
				if (highest_slot > 0) {
					user@ su = find_user_for_combatant(c);
					if (@su != null and !su.is_bot) {
						pending_smite_prompt sp;
						sp.player_username = c.player_username;
						@sp.damage_roll = dmg_pr;
						sp.is_crit = is_crit;
						sp.highest_slot = highest_slot;
						@current_smite_prompt = sp;
						string slots_info = "";
						for (int sl = 1; sl <= 5; sl++) {
							if (c.spell_slots_current[sl] > 0) {
								int smite_dice = sl + 1;
								if (is_crit) smite_dice *= 2;
								if (slots_info != "") slots_info += ", ";
								slots_info += "Level " + sl + " (" + smite_dice + "d8, " + c.spell_slots_current[sl] + " slots)";
							}
						}
						su.send({{"type", message_types::smite_prompt}, {"slots", slots_info}, {"is_crit", is_crit}, {"target", target.name}});
						return;
					}
				}
			}

			@current_roll = dmg_pr;
			user@ u = find_user_for_combatant(c);
			if (@u != null and !u.is_bot and c.is_player) {
				send_roll_request(u, dmg_pr);
			} else {
				process_roll_result(roll_attack_damage_natural(pr.is_spell_effect ? null : c, dmg_pr));
			}
		} else {
			// Attack missed after reaction
			broadcast_announce("The attack misses " + target.name + " after the reaction!", false);
			broadcast_state();
		}
	}

	// ---- Mid-Spell Player Choice (warm/chill, radiant/necrotic, halve/double, ...) ----
	// Pauses spell finalisation, prompts the caster, and dispatches to apply_spell_choice
	// when the response arrives. Bots auto-pick the first option so combat keeps moving.
	bool has_pending_spell_choice() {
		return @current_spell_choice != null;
	}

	void send_spell_choice_prompt(combatant@ c, pending_spell_choice@ sc) {
		if (@c == null or @sc == null) return;
		user@ pu = find_user_for_combatant(c);
		// Bots and NPC casters auto-pick the first option (deterministic, keeps combat moving).
		if (@pu == null or pu.is_bot or !c.is_player) {
			if (sc.choice_kind == "distribution") {
				// Bot fallback: send all projectiles at the first available target.
				string[] bot_picks;
				if (sc.option_keys.length() > 0) {
					for (int i = 0; i < sc.distribution_count; i++) bot_picks.insert_last(sc.option_keys[0]);
				}
				apply_distribution_spell_choice(c, sc, bot_picks);
			} else {
				string default_key = sc.option_keys.length() > 0 ? sc.option_keys[0] : "";
				apply_spell_choice(c, sc, default_key);
			}
			broadcast_state();
			check_battle_end();
			return;
		}
		@current_spell_choice = sc;
		json_object payload;
		payload["type"] = message_types::spell_choice_prompt;
		payload["text"] = sc.prompt_text;
		payload["spell"] = sc.spell_id;
		payload["kind"] = sc.choice_kind;
		payload["count"] = sc.distribution_count;
		json_array opts;
		for (uint i = 0; i < sc.option_keys.length() and i < sc.option_labels.length(); i++) {
			json_object o;
			o["key"] = sc.option_keys[i];
			o["label"] = sc.option_labels[i];
			opts.add(o);
		}
		payload["options"] = opts;
		try { pu.send(payload); } catch {}
	}

	void handle_spell_choice_response(user@ u, json_object@ msg) {
		if (@current_spell_choice == null or @u == null) return;
		if (current_spell_choice.player_username != u.username) return;
		pending_spell_choice@ sc = current_spell_choice;
		@current_spell_choice = null;
		combatant@ c = combat.get_combatant(sc.caster_id);
		if (@c == null) return;
		if (sc.choice_kind == "distribution") {
			// Distribution: extract targets array from response. Pad with first option if
			// the client sent fewer than required (defensive — keeps the spell from being lost).
			string[] picks;
			if (msg.exists("targets")) {
				json_array@ arr = cast<json_array@>(msg["targets"]);
				if (@arr != null) {
					for (uint i = 0; i < arr.size(); i++) {
						string pid = string(arr[i]);
						picks.insert_last(pid);
					}
				}
			}
			while (int(picks.length()) < sc.distribution_count and sc.option_keys.length() > 0) {
				picks.insert_last(sc.option_keys[0]);
			}
			apply_distribution_spell_choice(c, sc, picks);
		} else {
			string choice = msg.exists("choice") ? string(msg["choice"]) : "";
			// Validate the choice is one of the offered keys; fall back to first option if not.
			bool valid = false;
			for (uint i = 0; i < sc.option_keys.length(); i++) {
				if (sc.option_keys[i] == choice) { valid = true; break; }
			}
			if (!valid and sc.option_keys.length() > 0) choice = sc.option_keys[0];
			apply_spell_choice(c, sc, choice);
		}
		broadcast_state();
		check_battle_end();
	}

	void apply_spell_choice(combatant@ c, pending_spell_choice@ sc, string choice) {
		if (@c == null or @sc == null) return;
		// Per-spell finalisation. Each branch sets the chosen variant on the caster (or
		// target) and broadcasts a source-accurate announcement.
		if (sc.spell_id == "fire_shield") {
			// PHB Basic Rules para 13322: "The flames provide you with a warm shield or a
			// chill shield, as you choose. The warm shield grants you Resistance to Cold
			// damage, and the chill shield grants you Resistance to Fire damage."
			c.fire_shield_active = true;
			c.fire_shield_warm = (choice == "warm");
			if (c.fire_shield_warm) c.cold_resistance = true;
			else c.fire_resistance = true;
			string variant = c.fire_shield_warm ? "warm" : "chill";
			string resist = c.fire_shield_warm ? "cold" : "fire";
			string reflect = c.fire_shield_warm ? "fire" : "cold";
			broadcast_announce(c.name + " is wreathed in " + variant + " flames! " + resist + " resistance gained. Melee attackers within 5 feet take 2d8 " + reflect + " damage.", true);
		}
		else if (sc.spell_id == "spirit_guardians") {
			// PHB Basic Rules para 15123-15124: damage type is alignment-based (good/neutral
			// = radiant, evil = necrotic). Game does not track alignment so we prompt the
			// caster to declare which form their spirits take.
			c.spirit_guardians_active = true;
			c.spirit_guardians_slot_level = sc.cast_slot_level;
			c.spirit_guardians_necrotic = (choice == "necrotic");
			string dtype = c.spirit_guardians_necrotic ? "necrotic" : "radiant";
			string form = c.spirit_guardians_necrotic ? "fiendish" : "angelic";
			broadcast_announce(c.name + " is surrounded by " + form + " Spirit Guardians! Enemies within 15 feet take " + dtype + " damage and have their speed halved.", true);
		}
		else if (sc.spell_id == "enlarge_reduce") {
			// Basic Rules 2024 Enlarge/Reduce (para 12795-12800): Unwilling targets get CON
			// save. On success, no effect. On failure (or willing), apply Enlarge or Reduce.
			combatant@ tgt = combat.get_combatant(sc.primary_target_id);
			if (@tgt == null or tgt.is_dead) return;
			bool hostile = (tgt.is_player != c.is_player) or combat.mode == "pvp";
			// Unwilling targets make a CON save to resist
			if (hostile) {
				int save_dc = spell_save_dc(c);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(tgt, c.id, save_roll);
				int save_bonus = tgt.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(tgt);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				string effect_label = (choice == "enlarge") ? "Enlarge" : "Reduce";
				// Save failure chain (CON — condition, no Mage Slayer)
				if (!saved and try_arcane_deflection_save(tgt, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(tgt, save_dc, save_total, save_bonus + bless_bonus, "CON save vs " + effect_label); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(tgt, save_dc, save_total, "CON save vs " + effect_label); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(tgt, save_dc, save_total, "CON save vs " + effect_label); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(tgt, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(tgt, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(tgt.name, "CON save vs " + effect_label, save_roll, save_bonus + bless_bonus, save_total, saved ? "Resisted!" : effect_label + "d!");
				if (saved) return; // Spell has no effect on successful save
			}
			// Apply the chosen effect
			tgt.enlarge_reduce_caster_id = c.id;
			tgt.enlarge_original_size = tgt.size;
			if (choice == "enlarge") {
				tgt.enlarge_active = true;
				tgt.reduce_active = false;
				tgt.size += 1;
				broadcast_announce(c.name + " casts Enlarge on " + tgt.name + "! Size increases, weapons deal +1d4 damage, advantage on Strength.", true);
			} else {
				tgt.reduce_active = true;
				tgt.enlarge_active = false;
				tgt.size -= 1;
				if (tgt.size < SIZE_TINY) tgt.size = SIZE_TINY;
				broadcast_announce(c.name + " casts Reduce on " + tgt.name + "! Size decreases, weapons deal -1d4 damage, disadvantage on Strength.", true);
			}
		}
		else if (sc.spell_id == "hex") {
			// Basic Rules 2024 Hex (para 13730): "choose one ability when you cast the
			// spell. The target has Disadvantage on ability checks made with the chosen
			// ability." Store the chosen ability on the caster alongside hex_target_id.
			combatant@ tgt = combat.get_combatant(sc.primary_target_id);
			if (@tgt == null or tgt.is_dead) return;
			c.hex_target_id = tgt.id;
			// Map choice key to ability ID
			if (choice == "str") c.hex_cursed_ability = ABILITY_STR;
			else if (choice == "dex") c.hex_cursed_ability = ABILITY_DEX;
			else if (choice == "con") c.hex_cursed_ability = ABILITY_CON;
			else if (choice == "int") c.hex_cursed_ability = ABILITY_INT;
			else if (choice == "wis") c.hex_cursed_ability = ABILITY_WIS;
			else if (choice == "cha") c.hex_cursed_ability = ABILITY_CHA;
			else c.hex_cursed_ability = ABILITY_STR; // fallback
			string ability_name = "Strength";
			if (c.hex_cursed_ability == ABILITY_DEX) ability_name = "Dexterity";
			else if (c.hex_cursed_ability == ABILITY_CON) ability_name = "Constitution";
			else if (c.hex_cursed_ability == ABILITY_INT) ability_name = "Intelligence";
			else if (c.hex_cursed_ability == ABILITY_WIS) ability_name = "Wisdom";
			else if (c.hex_cursed_ability == ABILITY_CHA) ability_name = "Charisma";
			broadcast_announce(c.name + " curses " + tgt.name + " with Hex! Disadvantage on " + ability_name + " checks.", true);
		}
		else if (sc.spell_id == "eyebite") {
			// Basic Rules 2024 Eyebite (para 13145-13151): WIS save, then apply chosen
			// effect. Asleep = Unconscious (wakes on damage), Panicked = Frightened,
			// Sickened = disadvantage on attacks + ability checks (≈ Poisoned).
			combatant@ tgt = combat.get_combatant(sc.primary_target_id);
			if (@tgt == null or tgt.is_dead) return;
			int save_dc = spell_save_dc(c);
			int save_roll = random(1, 20);
			apply_hound_save_disadvantage(tgt, c.id, save_roll);
			if (tgt.charm_frighten_save_advantage and (choice == "panicked" or choice == "asleep")) {
				int r2 = random(1, 20);
				if (r2 > save_roll) save_roll = r2;
			}
			int save_bonus = tgt.get_save_bonus(ABILITY_WIS);
			int bless_bonus = roll_bless_bonus(tgt);
			int save_total = save_roll + save_bonus + bless_bonus;
			bool saved = save_total >= save_dc;
			string effect_label = "Panicked";
			if (choice == "asleep") effect_label = "Asleep";
			else if (choice == "sickened") effect_label = "Sickened";
			// Full save failure chain (WIS — condition, Mage Slayer applies)
			if (!saved and try_arcane_deflection_save(tgt, save_dc, save_total)) saved = true;
			if (!saved and (choice == "panicked" or choice == "asleep") and try_countercharm_reroll(tgt, save_dc, save_bonus + bless_bonus, "WIS save vs Eyebite")) saved = true;
			if (!saved) { int ds = try_disciplined_survivor_reroll(tgt, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Eyebite " + effect_label); if (ds >= save_dc) saved = true; }
			if (!saved) { int fg = try_flash_of_genius(tgt, save_dc, save_total, "WIS save vs Eyebite"); if (fg >= save_dc) { saved = true; save_total = fg; } }
			if (!saved) { int mv = try_maverick_spirit(tgt, save_dc, save_total, "WIS save vs Eyebite"); if (mv >= save_dc) { saved = true; save_total = mv; } }
			if (!saved and try_mage_slayer_guarded_mind(tgt, ABILITY_WIS)) saved = true;
			if (!saved) { int bf = try_boon_of_fate_bonus(tgt, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
			if (!saved and try_stroke_of_luck_save(tgt, save_dc, save_bonus + bless_bonus)) saved = true;
			broadcast_roll(tgt.name, "WIS save vs Eyebite (" + effect_label + ")", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : effect_label + "!");
			if (!saved) {
				if (choice == "panicked") {
					tgt.add_condition(COND_FRIGHTENED);
					tgt.frightened_source_id = c.id;
					broadcast_announce(tgt.name + " is Panicked by " + c.name + "'s Eyebite! Cannot approach the caster.", true);
				} else if (choice == "asleep") {
					tgt.add_condition(COND_UNCONSCIOUS);
					tgt.add_condition(COND_INCAPACITATED);
					tgt.eyebite_asleep_source_id = c.id;
					broadcast_announce(tgt.name + " falls Asleep from " + c.name + "'s Eyebite! Wakes if damaged.", true);
				} else { // sickened
					tgt.add_condition(COND_POISONED);
					tgt.eyebite_sickened_source_id = c.id;
					broadcast_announce(tgt.name + " is Sickened by " + c.name + "'s Eyebite! Disadvantage on attacks and ability checks.", true);
				}
			}
		}
		else if (sc.spell_id == "bestow_curse") {
			// Basic Rules 2024 Bestow Curse (para 12219-12222): WIS save, then apply
			// the chosen curse effect. Touch range (5 ft), concentration at L3.
			combatant@ tgt = combat.get_combatant(sc.primary_target_id);
			if (@tgt == null or tgt.is_dead) return;
			int save_dc = spell_save_dc(c);
			int save_roll = random(1, 20);
			apply_hound_save_disadvantage(tgt, c.id, save_roll);
			int save_bonus = tgt.get_save_bonus(ABILITY_WIS);
			int bless_bonus = roll_bless_bonus(tgt);
			int save_total = save_roll + save_bonus + bless_bonus;
			bool saved = save_total >= save_dc;
			// Full save failure chain (WIS — condition, Mage Slayer applies)
			if (!saved and try_arcane_deflection_save(tgt, save_dc, save_total)) saved = true;
			if (!saved) { int ds = try_disciplined_survivor_reroll(tgt, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Bestow Curse"); if (ds >= save_dc) saved = true; }
			if (!saved) { int fg = try_flash_of_genius(tgt, save_dc, save_total, "WIS save vs Bestow Curse"); if (fg >= save_dc) { saved = true; save_total = fg; } }
			if (!saved) { int mv = try_maverick_spirit(tgt, save_dc, save_total, "WIS save vs Bestow Curse"); if (mv >= save_dc) { saved = true; save_total = mv; } }
			if (!saved and try_mage_slayer_guarded_mind(tgt, ABILITY_WIS)) saved = true;
			if (!saved) { int bf = try_boon_of_fate_bonus(tgt, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
			if (!saved and try_stroke_of_luck_save(tgt, save_dc, save_bonus + bless_bonus)) saved = true;
			broadcast_roll(tgt.name, "WIS save vs Bestow Curse", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Cursed!");
			if (!saved) {
				tgt.bestow_curse_type = choice;
				tgt.bestow_curse_source_id = c.id;
				if (choice == "extra_damage") {
					broadcast_announce(c.name + " curses " + tgt.name + "! Attacks and spells against them deal extra 1d8 necrotic damage.", true);
				} else if (choice == "attack_disadv") {
					broadcast_announce(c.name + " curses " + tgt.name + "! They have disadvantage on attack rolls against " + c.name + ".", true);
				} else if (choice == "forced_dodge") {
					broadcast_announce(c.name + " curses " + tgt.name + "! They must succeed on a WIS save each turn or be forced to Dodge.", true);
				} else {
					// ability_str through ability_cha
					string ab_name = choice;
					if (choice == "ability_str") ab_name = "Strength";
					else if (choice == "ability_dex") ab_name = "Dexterity";
					else if (choice == "ability_con") ab_name = "Constitution";
					else if (choice == "ability_int") ab_name = "Intelligence";
					else if (choice == "ability_wis") ab_name = "Wisdom";
					else if (choice == "ability_cha") ab_name = "Charisma";
					broadcast_announce(c.name + " curses " + tgt.name + "! Disadvantage on " + ab_name + " checks and saves.", true);
				}
			}
		}
		else if (sc.spell_id == "adjust_density") {
			// Wildemount p.5428: target's weight is halved (+10 ft speed, disadvantage on
			// STR) or doubled (-10 ft speed, advantage on STR) for up to 1 minute or until
			// concentration ends. The flags live on the AFFECTED creature, not the caster,
			// with a back-reference (adjust_density_caster_id) for concentration cleanup.
			combatant@ tgt = combat.get_combatant(sc.primary_target_id);
			if (@tgt == null or tgt.is_dead) return;
			if (tgt.adjust_density_active) clear_adjust_density(tgt, false);
			tgt.adjust_density_active = true;
			tgt.adjust_density_mode = (choice == "double") ? 1 : 0;
			tgt.adjust_density_caster_id = c.id;
			if (tgt.adjust_density_mode == 0) {
				tgt.speed += 10;
				tgt.adjust_density_speed_delta = 10;
				broadcast_announce(c.name + " halves " + tgt.name + "'s density. Speed increases by 10 feet; disadvantage on Strength checks and saves.", true);
			} else {
				int reduce = tgt.speed >= 10 ? 10 : tgt.speed;
				tgt.speed -= reduce;
				tgt.adjust_density_speed_delta = -reduce;
				broadcast_announce(c.name + " doubles " + tgt.name + "'s density. Speed decreases by " + reduce + " feet; advantage on Strength checks and saves.", true);
			}
		}
		else if (sc.spell_id == "protection_from_energy") {
			// Basic Rules 2024 Protection from Energy (para 14707): "the willing
			// creature you touch has Resistance to one damage type of your choice:
			// Acid, Cold, Fire, Lightning, or Thunder." Concentration, level 3.
			combatant@ tgt = combat.get_combatant(sc.primary_target_id);
			if (@tgt == null or tgt.is_dead) return;
			int dmg_type = DMG_FIRE; // default
			string type_name = "Fire";
			if (choice == "acid") { dmg_type = DMG_ACID; type_name = "Acid"; }
			else if (choice == "cold") { dmg_type = DMG_COLD; type_name = "Cold"; }
			else if (choice == "fire") { dmg_type = DMG_FIRE; type_name = "Fire"; }
			else if (choice == "lightning") { dmg_type = DMG_LIGHTNING; type_name = "Lightning"; }
			else if (choice == "thunder") { dmg_type = DMG_THUNDER; type_name = "Thunder"; }
			tgt.protection_from_energy_active = true;
			tgt.protection_from_energy_type = dmg_type;
			broadcast_announce(c.name + " grants " + tgt.name + " resistance to " + type_name + " damage with Protection from Energy!", true);
		}
	}

	void clear_adjust_density(combatant@ target, bool announce = false) {
		if (@target == null or !target.adjust_density_active) return;
		// Reverse the speed change so concentration drop returns the creature to baseline.
		target.speed -= target.adjust_density_speed_delta;
		if (target.speed < 0) target.speed = 0;
		target.adjust_density_speed_delta = 0;
		target.adjust_density_active = false;
		target.adjust_density_mode = 0;
		target.adjust_density_caster_id = 0;
		if (announce) broadcast_announce(target.name + "'s density returns to normal.", false);
	}

	// Returns visible hostile combatants within max_range_feet of caster, sorted closest first.
	// Used to populate the candidate list for distribution spell prompts.
	combatant@[] visible_hostiles_within_range(combatant@ caster, int max_range_feet) {
		combatant@[] hits;
		if (@caster == null or @combat == null) return hits;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ other = combat.combatants[i];
			if (@other == null or other.id == caster.id or other.is_dead) continue;
			if (!combat.are_hostile(caster, other)) continue;
			if (!combat.can_see(caster, other)) continue;
			int dist = feet_distance(caster.x, caster.y, other.x, other.y);
			if (max_range_feet > 0 and dist > max_range_feet) continue;
			hits.insert_last(other);
		}
		// Insertion sort by distance — small list, simplicity over perf.
		for (uint i = 1; i < hits.length(); i++) {
			combatant@ key = hits[i];
			int key_dist = feet_distance(caster.x, caster.y, key.x, key.y);
			int j = int(i) - 1;
			while (j >= 0 and feet_distance(caster.x, caster.y, hits[j].x, hits[j].y) > key_dist) {
				@hits[j + 1] = hits[j];
				j--;
			}
			@hits[j + 1] = key;
		}
		return hits;
	}

	// Build a distribution prompt for a multi-projectile spell. Caller specifies projectile
	// count, attack/damage stats, and whether the spell uses an attack roll.
	bool prompt_target_distribution(combatant@ caster, spell_def@ spell, int projectile_count, int max_range_feet,
									int attack_bonus, int damage_count, int damage_sides, int damage_modifier,
									int damage_type, bool uses_attack_roll, int cast_slot_level, string prompt_text) {
		if (@caster == null or @spell == null) return false;
		combatant@[] candidates = visible_hostiles_within_range(caster, max_range_feet);
		if (candidates.length() == 0) return false;
		pending_spell_choice sc;
		sc.player_username = caster.player_username;
		sc.caster_id = caster.id;
		sc.spell_id = spell.id;
		sc.cast_slot_level = cast_slot_level;
		sc.choice_kind = "distribution";
		sc.distribution_count = projectile_count;
		sc.dist_attack_bonus = attack_bonus;
		sc.dist_damage_count = damage_count;
		sc.dist_damage_sides = damage_sides;
		sc.dist_damage_modifier = damage_modifier;
		sc.dist_damage_type = damage_type;
		sc.dist_uses_attack_roll = uses_attack_roll;
		uint cap = candidates.length();
		if (cap > 9) cap = 9; // Client UI uses keys 1..9
		for (uint i = 0; i < cap; i++) {
			combatant@ cand = candidates[i];
			int dist = feet_distance(caster.x, caster.y, cand.x, cand.y);
			sc.option_keys.insert_last("" + cand.id);
			sc.option_labels.insert_last(cand.name + " (" + dist + " ft, HP " + cand.current_hp + ")");
		}
		sc.prompt_text = prompt_text;
		send_spell_choice_prompt(caster, sc);
		return true;
	}

	void apply_distribution_spell_choice(combatant@ c, pending_spell_choice@ sc, string[]@ picks) {
		if (@c == null or @sc == null or @picks == null) return;
		if (picks.length() == 0) return;

		// Magic Missile: auto-hit, each dart deals 1d4+1 force damage independently.
		// Source (Basic Rules para 14089): "Each dart strikes a creature of your choice
		// that you can see within range. A dart deals 1d4 + 1 Force damage to its target.
		// The darts all strike simultaneously, and you can direct them to hit one creature
		// or several."
		if (sc.spell_id == "magic_missile") {
			dictionary per_target_damage;
			dictionary per_target_count;
			for (uint i = 0; i < picks.length(); i++) {
				string id_str = picks[i];
				uint tid = uint(parse_nonnegative_int(id_str));
				combatant@ tgt = combat.get_combatant(tid);
				if (@tgt == null or tgt.is_dead) continue;
				int dmg = random(1, sc.dist_damage_sides) + sc.dist_damage_modifier;
				int existing = 0;
				int existing_count = 0;
				if (per_target_damage.exists(id_str)) per_target_damage.get(id_str, existing);
				if (per_target_count.exists(id_str)) per_target_count.get(id_str, existing_count);
				per_target_damage.set(id_str, existing + dmg);
				per_target_count.set(id_str, existing_count + 1);
			}
			string[]@ keys = per_target_damage.get_keys();
			for (uint i = 0; i < keys.length(); i++) {
				string id_str = keys[i];
				uint tid = uint(parse_nonnegative_int(id_str));
				combatant@ tgt = combat.get_combatant(tid);
				if (@tgt == null or tgt.is_dead) continue;
				int total_dmg = 0;
				int dart_count = 0;
				per_target_damage.get(id_str, total_dmg);
				per_target_count.get(id_str, dart_count);
				combat.apply_damage(tgt, total_dmg, sc.dist_damage_type, c);
				broadcast_announce(c.name + "'s Magic Missile strikes " + tgt.name + " with " + dart_count + " dart" + (dart_count == 1 ? "" : "s") + " for " + total_dmg + " force damage.", true);
			}
			return;
		}

		// Attack-roll distribution (Scorching Ray, Eldritch Blast). Queue the FIRST attack
		// at picks[0] and stash the remaining IDs in next_target_ids_csv on the pending_roll.
		// start_followup_spell_attack consumes the CSV front-to-back so each subsequent
		// ray/beam targets the next id.
		if (sc.dist_uses_attack_roll) {
			spell_def@ spell = get_spell(sc.spell_id);
			if (@spell == null) return;
			user@ pu = find_user_for_combatant(c);
			if (@pu == null) return;
			// First target
			uint first_id = uint(parse_nonnegative_int(picks[0]));
			combatant@ first_target = combat.get_combatant(first_id);
			if (@first_target == null or first_target.is_dead) {
				// Skip dead — pull next from picks
				for (uint p = 1; p < picks.length(); p++) {
					uint pid = uint(parse_nonnegative_int(picks[p]));
					combatant@ pt = combat.get_combatant(pid);
					if (@pt != null and !pt.is_dead) { @first_target = pt; break; }
				}
			}
			if (@first_target == null) return;
			// Build the CSV of remaining target IDs (everything after picks[0])
			string remaining_csv = "";
			for (uint p = 1; p < picks.length(); p++) {
				if (remaining_csv != "") remaining_csv += ",";
				remaining_csv += picks[p];
			}
			int dist = feet_distance(c.x, c.y, first_target.x, first_target.y);
			bool adv = false;
			bool disadv = false;
			apply_attack_advantage_state(c, first_target, dist, true, adv, disadv);
			queue_spell_attack_roll(pu, c, first_target, spell, sc.dist_attack_bonus,
									 sc.dist_damage_count, sc.dist_damage_sides, sc.dist_damage_modifier,
									 int(picks.length()) - 1, adv, disadv, remaining_csv);
			return;
		}
	}

	// ---- Action Handlers ----

	void handle_attack(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		// PHB 2024 Incapacitated (para 16225): "An Incapacitated creature can't take
		// any action, Bonus Action, or Reaction."
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}
		// Gun Slinger Class Jam Weapon (para 736-738): jammed weapon can't attack.
		if (c.weapon_jammed) {
			u.send({{"type", message_types::error}, {"text", "Your weapon is jammed! Use your action to fix it (choose Unjam Weapon from the action menu)."}});
			return;
		}
		// Allow attack if: has action (fresh), OR has remaining attacks from Extra Attack.
		if (!c.has_action and c.attacks_remaining_this_turn <= 0) {
			u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}});
			return;
		}

		uint target_id = 0;
		if (msg.exists("target_id")) target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) { u.send({{"type", message_types::error}, {"text", "Invalid target. Use I J K L to scan and Enter to lock a target."}});  return; }

		// Basic Rules 2024 Sanctuary (para 14826): "If the warded creature makes an
		// attack, casts a spell that affects an enemy, or deals damage to another
		// creature, this spell ends." Before the attacker can target a Sanctuary'd
		// creature, they must succeed on a WIS save vs the spell DC or choose a
		// different target (the attack is wasted).
		if (target.sanctuary_active and target.sanctuary_dc > 0) {
			int sanc_roll = random(1, 20);
			int sanc_bonus = c.get_save_bonus(ABILITY_WIS);
			int sanc_total = sanc_roll + sanc_bonus;
			if (sanc_total >= target.sanctuary_dc) {
				broadcast_announce(c.name + " resists " + target.name + "'s Sanctuary (WIS " + sanc_total + " vs DC " + target.sanctuary_dc + ").", false);
			} else {
				broadcast_announce(c.name + " is deterred by " + target.name + "'s Sanctuary! (WIS " + sanc_total + " vs DC " + target.sanctuary_dc + ")", true);
				return;
			}
		}

		// Xanathar's College of Glamour Bard L14 Unbreakable Majesty (para 562-565):
		// "whenever any creature tries to attack you for the first time on a turn,
		// the attacker must make a Charisma saving throw against your spell save DC.
		// On a failed save, it can't attack you on this turn."
		if (target.unbreakable_majesty_active) {
			int um_dc = spell_save_dc(target);
			int um_roll = random(1, 20);
			int um_bonus = c.get_save_bonus(ABILITY_CHA);
			int um_total = um_roll + um_bonus;
			if (um_total < um_dc) {
				broadcast_roll(c.name, "CHA save vs Unbreakable Majesty", um_roll, um_bonus, um_total, "Fails!");
				broadcast_announce(c.name + " is awed by " + target.name + "'s Unbreakable Majesty and cannot attack!", true);
				return;
			}
			broadcast_roll(c.name, "CHA save vs Unbreakable Majesty", um_roll, um_bonus, um_total, "Resists!");
		}

		// Basic Rules 2024 Geas (para 13062-13072): "the creature takes 5d10 Psychic
		// damage each time it acts in a manner directly counter to your instructions."
		// Attacking while charmed by Geas triggers the punishment damage.
		if (c.geas_source_id != 0 and !c.is_dead) {
			int geas_dmg = 0;
			for (int gdi = 0; gdi < 5; gdi++) geas_dmg += random(1, 10);
			combatant@ geas_caster = combat.get_combatant(c.geas_source_id);
			combat.apply_damage(c, geas_dmg, DMG_PSYCHIC, @geas_caster != null ? geas_caster : c);
			broadcast_announce(c.name + " defies the Geas and takes " + geas_dmg + " psychic damage!", true);
			if (c.is_dead) { broadcast_state(); check_battle_end(); return; }
		}

		// Range check.
		int dist = feet_distance(c.x, c.y, target.x, target.y);
		if (dist > c.main_hand_range) {
			u.send({{"type", message_types::error}, {"text", "Target is out of range. Distance: " + dist + " feet, range: " + c.main_hand_range + " feet. Move closer with W A S D or choose a ranged option."}});
			return;
		}

		// Basic Rules 2024 Sanctuary (para 14826): "If the warded creature makes an
		// attack... this spell ends." Self-break when the protected creature attacks.
		if (c.sanctuary_active) {
			c.sanctuary_active = false;
			c.sanctuary_dc = 0;
			c.sanctuary_source_id = 0;
			broadcast_announce(c.name + "'s Sanctuary ends — they chose to attack!", false);
		}

		// Track attacks: first attack starts the Attack action, extras use remaining count.
		if (c.attacks_remaining_this_turn > 0) {
			// Using an extra attack from the Attack action.
			c.attacks_remaining_this_turn--;
		} else {
			// First attack: consume the action and set up extra attacks.
			c.has_action = false;
			c.used_action = true;
			c.attacks_remaining_this_turn = c.extra_attacks; // e.g. Fighter lv5 = 1 extra
			// Basic Rules 2024 Haste (para 13688): "it gains an additional action
			// on each of its turns. That action can be used only to take the Attack
			// (one weapon attack only)..." Approximated as +1 extra weapon attack.
			if (c.hasted) c.attacks_remaining_this_turn += 1;
			// PHB 2024 Boon of Dimensional Travel (para 7876): Blink Steps available
			if (c.has_feat("boon_of_dimensional_travel")) c.blink_steps_available = true;
			// Xanathar's Gloom Stalker L3 Dread Ambusher (para 2154): "If you take
			// the Attack action on that turn, you can make one additional weapon attack
			// as part of that action." First round only, once per combat.
			if (c.class_name == "Ranger" and c.subclass == "Gloom Stalker" and c.level >= 3
				and @combat != null and combat.round_number == 1 and !c.dread_ambusher_extra_attack_used) {
				c.dread_ambusher_extra_attack_used = true;
				c.attacks_remaining_this_turn++;
			}
			// Xanathar's College of Swords L3 Blade Flourish (para 1497): "Whenever
			// you take the Attack action on your turn, your walking speed increases by
			// 10 feet until the end of the turn." Free, no BI cost.
			if (c.class_name == "Bard" and c.subclass == "College of Swords" and c.level >= 3 and !c.blade_flourish_speed_applied) {
				c.blade_flourish_speed_applied = true;
				c.movement_remaining += 10;
			}
			// PHB 2024 Sentinel Guardian — fire on Attack action against non-sentinel target
			check_sentinel_guardian(c, target);
			if (c.is_dead or @combat == null or !combat.battle_active) return;
		}

		int atk_bonus = get_attack_bonus_for_roll(c, false);

		bool adv = false;
		bool disadv = false;
		apply_attack_advantage_state(c, target, dist, c.main_hand_is_ranged, adv, disadv);
		// Xanathar's Samurai L15 Rapid Strike (paras 1710-1711): "If you take the Attack
		// action on your turn and have advantage on an attack roll against one of the targets,
		// you can forgo the advantage for that attack to make one additional weapon attack
		// against that target, as part of the same action. You can do so no more than once per turn."
		if (c.rapid_strike_active and !c.rapid_strike_used_this_turn and adv and !disadv) {
			c.rapid_strike_used_this_turn = true;
			adv = false; // Forgo advantage
			c.attacks_remaining_this_turn++; // Gain one extra attack
			broadcast_announce(c.name + " uses Rapid Strike — forgoing advantage for an extra attack!", false);
		}
		// Can't attack what you can't see
		if (!combat.can_see(c, target)) {
			u.send({{"type", message_types::announce}, {"text", "You cannot see that target."}, {"interrupt", true}});
			// Refund: if this was the first attack, give back the action.
			if (c.attacks_remaining_this_turn == c.extra_attacks) {
				c.has_action = true;
				c.used_action = false;
				c.attacks_remaining_this_turn = 0;
			} else {
				c.attacks_remaining_this_turn++;
			}
			return;
		}
		// PHB 2024 Skulker (para 7783): "If you make an attack roll while Hidden and
		// the attack misses, making the attack roll doesn't end the Hidden condition."
		// Defer reveal for ranged attacks with Skulker; reveal on hit in finalize_roll_result.
		// Basic Rules 2024 Greater Invisibility (para 13658): does NOT break on attack.
		if (!c.greater_invisibility_active and !(c.is_hidden and c.has_feat("skulker") and c.main_hand_is_ranged)) {
			reveal_hidden_combatant(c, "making an attack");
		}

		// Store attack context in pending roll.
		pending_roll pr;
		pr.combatant_id = c.id;
		pr.player_username = c.player_username;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = atk_bonus;
		pr.reason = c.main_hand + " attack against " + target.name;
		pr.target_id = target_id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.attack_name = c.main_hand;
		pr.damage_dice_count = get_attack_damage_count(c, false);
		pr.damage_dice_sides = get_attack_damage_dice(c, false);
		pr.damage_modifier = get_damage_modifier_for_attack(c, false);
		pr.damage_type = c.main_hand_damage_type;
		pr.is_weapon_attack = true;
		pr.attacks_remaining = 0; // Not used for player auto-chain anymore
		@current_roll = pr;

		// Request the roll.
		send_roll_request(u, pr);
	}

	void handle_move(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;

		// PHB 2024 Grappled (para 16216): "A Grappled creature's Speed is 0"
		// PHB 2024 Restrained (para 16241): "A Restrained creature's Speed is 0"
		if (c.has_condition(COND_GRAPPLED) or c.has_condition(COND_RESTRAINED)) {
			string reason = c.has_condition(COND_GRAPPLED) ? "Grappled" : "Restrained";
			u.send({{"type", message_types::error}, {"text", "You are " + reason + " and cannot move!"}});
			return;
		}

		// Basic Rules 2024 Levitate (para 13989): "The target can move only by
		// pushing or pulling against a fixed object or surface within reach."
		// Block horizontal movement while levitated.
		if (c.levitate_active) {
			u.send({{"type", message_types::error}, {"text", "You are levitating and cannot move horizontally!"}});
			return;
		}

		int dx = 0, dy = 0;
		if (msg.exists("dx")) dx = int(msg["dx"]);
		if (msg.exists("dy")) dy = int(msg["dy"]);

		// PHB 2024 Frightened (para 16222): "The creature can't willingly move
		// closer to the source of its fear."
		if (c.has_condition(COND_FRIGHTENED) and c.frightened_source_id > 0) {
			combatant@ fear_source = combat.get_combatant(c.frightened_source_id);
			if (@fear_source != null and !fear_source.is_dead) {
				int old_fear_dist = feet_distance(c.x, c.y, fear_source.x, fear_source.y);
				int new_fear_dist = feet_distance(c.x + dx, c.y + dy, fear_source.x, fear_source.y);
				if (new_fear_dist < old_fear_dist) {
					u.send({{"type", message_types::error}, {"text", "You are Frightened and cannot move closer to " + fear_source.name + "!"}});
					return;
				}
			}
		}

		// PHB 2024 Prone condition (para 16240): "The creature can crawl or spend
		// half its movement to stand up and thereby end the condition." Standing
		// costs half total speed; deducted before the move.
		// PHB 2024 Athlete (para 7557): standing from prone costs 0 movement.
		if (c.has_condition(COND_PRONE)) {
			int stand_cost = c.has_feat("athlete") ? 0 : c.speed / 2;
			// Xanathar's Drunken Master L6 Leap to Your Feet (para 1798): "When
			// you're prone, you can stand up by spending only 5 feet of movement,
			// rather than half your speed."
			if (stand_cost > 5 and c.class_name == "Monk" and c.subclass == "Way of the Drunken Master" and c.level >= 6) stand_cost = 5;
			if (c.movement_remaining < stand_cost + 5) {
				u.send({{"type", message_types::error}, {"text", "You need " + (stand_cost + 5) + " feet of movement to stand up and move (" + stand_cost + " to stand, 5 to move). " + c.movement_remaining + " feet remaining."}});
				return;
			}
			if (stand_cost > 0) c.movement_remaining -= stand_cost;
			c.remove_condition(COND_PRONE);
			string stand_msg = c.name + " stands up";
			if (stand_cost == 0) stand_msg += " instantly (Athlete)";
			else if (c.class_name == "Monk" and c.subclass == "Way of the Drunken Master" and c.level >= 6) stand_msg += " nimbly (5 ft — Leap to Your Feet)";
			else stand_msg += " (" + stand_cost + " ft used)";
			broadcast_announce(stand_msg + ".", false);
		}

		int move_cost = (dx != 0 and dy != 0) ? 5 : 5;  // Simplified: 5 ft per tile.
		if (c.movement_remaining < move_cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough movement. " + c.movement_remaining + " feet remaining."}});
			return;
		}

		int new_x = c.x + dx;
		int new_y = c.y + dy;
		if (new_x < 0 or new_x >= combat.map_width or new_y < 0 or new_y >= combat.map_height) {
			u.send({{"type", message_types::error}, {"text", "Cannot move outside the battlefield."}});
			return;
		}

		// Basic Rules 2024 Antilife Shell (para 11796-11803): "The aura prevents creatures
		// other than Constructs and Undead from passing or reaching through it."
		// Block hostile creatures from entering the 10ft emanation of the shell caster.
		if (@combat != null) {
			for (uint asi = 0; asi < combat.combatants.length(); asi++) {
				combatant@ as_src = combat.combatants[asi];
				if (@as_src == null or as_src.is_dead or !as_src.antilife_shell_active) continue;
				if (!combat.are_hostile(c, as_src)) continue; // Only blocks hostiles
				if (c.creature_type == "construct" or c.creature_type == "undead") continue; // Constructs/Undead pass through
				int new_dist = feet_distance(new_x, new_y, as_src.x, as_src.y);
				int old_dist = feet_distance(c.x, c.y, as_src.x, as_src.y);
				if (new_dist <= 10 and old_dist > 10) {
					u.send({{"type", message_types::error}, {"text", as_src.name + "'s Antilife Shell blocks your path!"}});
					return;
				}
			}
		}

		// Xanathar's Investiture of Ice: "The ground in a 10-foot radius around you
		// is icy and is difficult terrain for creatures other than you."
		// Doubles movement cost when entering the icy area.
		if (@combat != null) {
			for (uint ici = 0; ici < combat.combatants.length(); ici++) {
				combatant@ ice_src = combat.combatants[ici];
				if (@ice_src == null or ice_src.is_dead or !ice_src.investiture_ice_active) continue;
				if (ice_src.id == c.id) continue; // Caster is not affected by own ice
				if (feet_distance(new_x, new_y, ice_src.x, ice_src.y) <= 10) {
					move_cost = 10; // Double movement cost in icy terrain (5ft -> 10ft)
					break;
				}
			}
		}

		int old_x = c.x;
		int old_y = c.y;
		c.x = new_x;
		c.y = new_y;
		c.movement_remaining -= move_cost;
		c.has_moved = true;
		announce_movement_to_visible_players(c, dx, dy, move_cost);
		refresh_paladin_auras(); // Position changed — update aura coverage

		// Basic Rules 2024 Antilife Shell (para 11796-11803): "If you move so that an
		// affected creature is forced to pass through the barrier, the spell ends."
		// If the moving caster has Antilife Shell and an enemy is now within 10ft, end the spell.
		if (c.antilife_shell_active and @combat != null) {
			for (uint asci = 0; asci < combat.combatants.length(); asci++) {
				combatant@ asc = combat.combatants[asci];
				if (@asc == null or asc.is_dead) continue;
				if (!combat.are_hostile(c, asc)) continue;
				if (asc.creature_type == "construct" or asc.creature_type == "undead") continue;
				int new_as_dist = feet_distance(c.x, c.y, asc.x, asc.y);
				int old_as_dist = feet_distance(old_x, old_y, asc.x, asc.y);
				if (new_as_dist <= 10 and old_as_dist > 10) {
					broadcast_announce(c.name + "'s Antilife Shell ends — a creature was forced through the barrier!", true);
					clear_concentration_effects(c);
					c.is_concentrating = false;
					c.concentration_spell = "";
					break;
				}
			}
		}

		// Check for opportunity attacks from enemies.
		check_opportunity_attacks(c, old_x, old_y, new_x, new_y);
		if (@current_roll != null) {
			broadcast_state();
			return;
		}

		// Basic Rules 2024 Spirit Guardians (para 15123-15126): "the first time on
		// a turn [the creature] enters the Emanation." Trigger when moving INTO the
		// 15ft aura of a hostile Spirit Guardians caster.
		if (!c.spirit_guardians_damaged_this_turn and !c.is_dead) {
			for (uint sgi = 0; sgi < combat.combatants.length(); sgi++) {
				combatant@ sg_caster = combat.combatants[sgi];
				if (@sg_caster == null or sg_caster.is_dead or !sg_caster.spirit_guardians_active) continue;
				if (sg_caster.id == c.id) continue;
				if (sg_caster.is_player == c.is_player) continue;
				int old_dist = feet_distance(old_x, old_y, sg_caster.x, sg_caster.y);
				int new_dist = feet_distance(new_x, new_y, sg_caster.x, sg_caster.y);
				if (old_dist > 15 and new_dist <= 15) {
					int sg_dice = 3 + (sg_caster.spirit_guardians_slot_level - 3);
					if (sg_dice < 3) sg_dice = 3;
					int sg_save_roll = random(1, 20);
					int sg_save_bonus = c.get_save_bonus(ABILITY_WIS);
					int sg_dc = spell_save_dc(sg_caster, "spirit_guardians");
					bool sg_saved = (sg_save_roll + sg_save_bonus) >= sg_dc;
					broadcast_roll(c.name, "WIS save vs Spirit Guardians", sg_save_roll, sg_save_bonus, sg_save_roll + sg_save_bonus, sg_saved ? "Saved! Half damage." : "Failed!");
					int sg_dmg = 0;
					for (int sd = 0; sd < sg_dice; sd++) sg_dmg += random(1, 8);
					if (sg_saved) sg_dmg /= 2;
					if (sg_dmg < 1) sg_dmg = 1;
					int sg_damage_type = sg_caster.spirit_guardians_necrotic ? DMG_NECROTIC : DMG_RADIANT;
					string sg_type_name = sg_caster.spirit_guardians_necrotic ? "necrotic" : "radiant";
					combat.apply_damage(c, sg_dmg, sg_damage_type, sg_caster);
					broadcast_announce(c.name + " enters " + sg_caster.name + "'s Spirit Guardians and takes " + sg_dmg + " " + sg_type_name + " damage!", true);
					c.spirit_guardians_damaged_this_turn = true;
					// Basic Rules 2024 Spirit Guardians (para 15126): "Speeds are halved in the Emanation."
					c.movement_remaining = c.movement_remaining / 2;
					check_concentration(c, sg_dmg, sg_caster);
					if (c.is_dead) {
						broadcast_state();
						check_battle_end();
						return;
					}
					break;
				}
			}
		}

		// Xanathar's Arcane Archer Grasping Arrow (paras 1618-1646): "it takes 2d6
		// slashing damage each time it moves 1 foot or more without teleporting."
		// Triggers once per turn on voluntary movement.
		if (c.arcane_grasping_active and !c.arcane_grasping_damaged_this_turn and !c.is_dead) {
			int grasp_dmg = random(1, 6) + random(1, 6);
			combatant@ grasp_src = combat.get_combatant(c.arcane_grasping_source);
			combat.apply_damage(c, grasp_dmg, DMG_SLASHING, @grasp_src != null ? grasp_src : c);
			broadcast_announce(c.name + " takes " + grasp_dmg + " slashing damage from Grasping Arrow thorns!", true);
			c.arcane_grasping_damaged_this_turn = true;
			if (c.is_dead) {
				broadcast_state();
				check_battle_end();
				return;
			}
		}

		broadcast_state();
	}

	void handle_dodge(user@ u) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }

		c.has_action = false;
		c.used_action = true;
		c.is_dodging = true;
		c.add_condition(COND_DODGING);
		broadcast_announce(c.name + " takes the Dodge action.");
		broadcast_state();
	}

	void handle_dash(user@ u) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }

		c.has_action = false;
		c.used_action = true;
		int dash_speed = c.speed;
		// Charger feat (PHB para 7557) - Improved Dash: "When you take the Dash action,
		// your Speed increases by 10 feet for that action."
		if (c.has_feat("charger")) {
			dash_speed += 10;
			c.charger_dash_active = true; // Charge Attack: +1d8 on next melee hit
		}
		c.movement_remaining += dash_speed;
		broadcast_announce(c.name + " takes the Dash action. " + c.movement_remaining + " feet of movement remaining.");
		broadcast_state();
	}

	void handle_disengage(user@ u) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }

		c.has_action = false;
		c.used_action = true;
		c.took_disengage = true;
		// Valda's Spire Gunslinger White Hat L10 Long Arm of the Law (paras 462-463):
		// "The creature can't move on its next turn unless it first takes the
		// Disengage action." Disengage clears the lockout and restores movement.
		if (c.cant_move_until_disengage) {
			c.cant_move_until_disengage = false;
			c.movement_remaining = c.speed;
			broadcast_announce(c.name + " breaks free of Long Arm of the Law via Disengage — movement restored.", true);
		}
		broadcast_announce(c.name + " takes the Disengage action.");
		broadcast_state();
	}

	void handle_help(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }
		if (!msg.exists("target_id")) { u.send({{"type", message_types::error}, {"text", "Choose an enemy to distract."}}); return; }
		if (combat.mode == "pvp") { u.send({{"type", message_types::error}, {"text", "Help is not available in free-for-all PvP."}}); return; }

		combatant@ target = combat.get_combatant(uint(msg["target_id"]));
		if (@target == null or target.is_dead) { u.send({{"type", message_types::error}, {"text", "Invalid target."}}); return; }
		if (!combat.are_hostile(c, target)) { u.send({{"type", message_types::error}, {"text", "Help an ally by distracting an enemy target."}}); return; }
		int dist = feet_distance(c.x, c.y, target.x, target.y);
		if (dist > 5) { u.send({{"type", message_types::error}, {"text", "The enemy must be within 5 feet to Help against it."}}); return; }

		c.has_action = false;
		c.used_action = true;
		reveal_hidden_combatant(c, "taking the Help action");
		clear_help_effect(c, false);
		c.help_target_id = target.id;
		broadcast_announce(c.name + " takes the Help action, distracting " + target.name + " for the next allied attack.", true);
		broadcast_state();
	}

	void request_hide_check(user@ u, combatant@ c) {
		if (@combat == null or @u == null or @c == null) return;
		// PHB 2024 para 388: "Hide. Make a Dexterity (Stealth) check." DC = highest visible
		// hostile passive Perception. Pulls Stealth advantage from skill_check_advantage
		// flags (Blessing of the Trickster, future Skulker feat, etc.) and Pass Without
		// Trace +10 stack via the standard request_skill_check helper.
		int highest_passive = 1;
		for (uint i = 0; i < combat.combatants.length(); i++) {
			combatant@ enemy = combat.combatants[i];
			if (@enemy == null or enemy.id == c.id or enemy.is_dead) continue;
			if (!combat.are_hostile(c, enemy)) continue;
			int passive = get_passive_perception(enemy);
			if (passive > highest_passive) highest_passive = passive;
		}
		// Use the skill check helper but with the legacy "hide" resolution tag so the
		// existing finalize_roll_result hide branch still applies the COND_HIDDEN state.
		request_skill_check(u, c, "Stealth", highest_passive, "hide", false, false);
		broadcast_announce(c.name + " attempts to hide (DC " + highest_passive + ").", false);
	}

	void handle_hide(user@ u) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }

		c.has_action = false;
		c.used_action = true;
		request_hide_check(u, c);
		broadcast_state();
	}

	void handle_ready(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }
		if (!c.has_reaction) { u.send({{"type", message_types::error}, {"text", "You need your reaction available to ready an attack."}}); return; }
		if (!msg.exists("target_id")) { u.send({{"type", message_types::error}, {"text", "Choose a target to ready an attack against."}}); return; }

		uint target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) { u.send({{"type", message_types::error}, {"text", "Invalid target."}}); return; }
		if (combat.mode != "pvp" and target.is_player == c.is_player) {
			u.send({{"type", message_types::error}, {"text", "Ready an attack against an enemy target."}});
			return;
		}

		c.has_action = false;
		c.used_action = true;
		c.attacks_remaining_this_turn = 0;
		c.divine_smite_pending = false;
		c.divine_smite_slot_level = 0;
		c.readied_action = READIED_ACTION_ATTACK;
		c.readied_target_id = target.id;
		c.readied_trigger = "start of " + target.name + "'s turn";

		broadcast_announce(c.name + " readies an attack against " + target.name + ".", false);
		broadcast_state();
	}

	void handle_shove(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }

		uint target_id = 0;
		if (msg.exists("target_id")) target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) { u.send({{"type", message_types::error}, {"text", "Invalid target."}}); return; }

		int dist = feet_distance(c.x, c.y, target.x, target.y);
		if (dist > 5) { u.send({{"type", message_types::error}, {"text", "Target must be within 5 feet."}}); return; }

		// 2024 PHB: Target can be no more than one size larger
		if (target.size > c.size + 1) { u.send({{"type", message_types::error}, {"text", "That creature is too large to shove."}}); return; }

		c.has_action = false;
		c.used_action = true;

		// 2024 PHB: Shove is part of Unarmed Strike. Target makes STR or DEX save (their choice).
		// DC = 8 + attacker STR mod + proficiency bonus
		int shove_dc = 8 + c.get_ability_mod(ABILITY_STR) + c.proficiency;
		int str_save = target.get_save_bonus(ABILITY_STR);
		int dex_save = target.get_save_bonus(ABILITY_DEX);
		int best_save = str_save > dex_save ? str_save : dex_save;
		string save_type = str_save > dex_save ? "STR" : "DEX";
		int save_ability_id = str_save > dex_save ? ABILITY_STR : ABILITY_DEX;

		int save_roll = random(1, 20);
		int save_total = target.apply_indomitable_might(save_roll + best_save, save_ability_id);
		bool saved = save_total >= shove_dc;

		broadcast_roll(target.name, save_type + " save vs Shove (DC " + shove_dc + ")", save_roll, best_save, save_total, saved ? "Resisted!" : "Shoved!");

		if (!saved) {
			bool knock_prone = true;
			if (msg.exists("push") and bool(msg["push"])) knock_prone = false;

			if (knock_prone) {
				target.add_condition(COND_PRONE);
				broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Prone"}});
				broadcast_announce(c.name + " shoves " + target.name + " prone!");
			} else {
				int push_dx = 0, push_dy = 0;
				if (target.x > c.x) push_dx = 1;
				else if (target.x < c.x) push_dx = -1;
				if (target.y > c.y) push_dy = 1;
				else if (target.y < c.y) push_dy = -1;
				target.x += push_dx;
				target.y += push_dy;
				broadcast_announce(c.name + " pushes " + target.name + " back 5 feet!");
			}
		} else {
			broadcast_announce(target.name + " resists the shove from " + c.name + ".");
		}
		broadcast_state();
	}

	void handle_grapple(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }

		uint target_id = 0;
		if (msg.exists("target_id")) target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) { u.send({{"type", message_types::error}, {"text", "Invalid target."}}); return; }

		int dist = feet_distance(c.x, c.y, target.x, target.y);
		if (dist > 5) { u.send({{"type", message_types::error}, {"text", "Target must be within 5 feet."}}); return; }

		// 2024 PHB: Target can be no more than one size larger, and you need a free hand
		if (target.size > c.size + 1) { u.send({{"type", message_types::error}, {"text", "That creature is too large to grapple."}}); return; }

		c.has_action = false;
		c.used_action = true;

		// 2024 PHB: Grapple is part of Unarmed Strike. Target makes STR or DEX save (their choice).
		// DC = 8 + attacker STR mod + proficiency bonus
		int grapple_dc = 8 + c.get_ability_mod(ABILITY_STR) + c.proficiency;
		int str_save = target.get_save_bonus(ABILITY_STR);
		int dex_save = target.get_save_bonus(ABILITY_DEX);
		int best_save = str_save > dex_save ? str_save : dex_save;
		string save_type = str_save > dex_save ? "STR" : "DEX";
		int save_ability_id = str_save > dex_save ? ABILITY_STR : ABILITY_DEX;

		int save_roll = random(1, 20);
		int save_total = target.apply_indomitable_might(save_roll + best_save, save_ability_id);
		bool saved = save_total >= grapple_dc;

		broadcast_roll(target.name, save_type + " save vs Grapple (DC " + grapple_dc + ")", save_roll, best_save, save_total, saved ? "Escaped!" : "Grappled!");

		if (!saved) {
			target.add_condition(COND_GRAPPLED);
			target.grapple_source_id = c.id;
			broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Grappled"}});
			broadcast_announce(c.name + " grapples " + target.name + "!");
		} else {
			broadcast_announce(target.name + " breaks free from " + c.name + "'s grapple attempt.");
		}
		broadcast_state();
	}

	// PHB 2024 Grappled (para 16216): "Escape. The Grappled creature can use its
	// action to make a Strength (Athletics) or Dexterity (Acrobatics) check against
	// the grapple's escape DC (8 + grappler's STR mod + grappler's proficiency)."
	void handle_grapple_escape(user@ u) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_condition(COND_GRAPPLED)) {
			u.send({{"type", message_types::error}, {"text", "You are not grappled."}});
			return;
		}
		if (!c.has_action) {
			u.send({{"type", message_types::error}, {"text", "You've already used your action this turn."}});
			return;
		}
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}

		c.has_action = false;
		c.used_action = true;

		combatant@ grappler = combat.get_combatant(c.grapple_source_id);
		int escape_dc = 8;
		if (@grappler != null and !grappler.is_dead) {
			escape_dc = 8 + grappler.get_ability_mod(ABILITY_STR) + grappler.proficiency;
		}

		// Use the better of Athletics (STR) or Acrobatics (DEX)
		int str_bonus = c.get_ability_mod(ABILITY_STR);
		int dex_bonus = c.get_ability_mod(ABILITY_DEX);
		// Add proficiency if proficient in Athletics or Acrobatics
		bool str_prof = false;
		bool dex_prof = false;
		for (uint sp = 0; sp < c.skill_proficiencies.length(); sp++) {
			if (c.skill_proficiencies[sp] == "Athletics") str_prof = true;
			if (c.skill_proficiencies[sp] == "Acrobatics") dex_prof = true;
		}
		if (str_prof) str_bonus += c.proficiency;
		if (dex_prof) dex_bonus += c.proficiency;
		// Check expertise
		for (uint se = 0; se < c.skill_expertise.length(); se++) {
			if (c.skill_expertise[se] == "Athletics" and str_prof) str_bonus += c.proficiency;
			if (c.skill_expertise[se] == "Acrobatics" and dex_prof) dex_bonus += c.proficiency;
		}
		// Jack of All Trades
		if (c.jack_of_all_trades) {
			if (!str_prof) str_bonus += c.proficiency / 2;
			if (!dex_prof) dex_bonus += c.proficiency / 2;
		}

		int best_bonus = str_bonus > dex_bonus ? str_bonus : dex_bonus;
		string check_type = str_bonus > dex_bonus ? "Athletics (STR)" : "Acrobatics (DEX)";

		int check_roll = random(1, 20);
		int check_total = check_roll + best_bonus;
		bool escaped = check_total >= escape_dc;

		broadcast_roll(c.name, check_type + " check to Escape Grapple (DC " + escape_dc + ")", check_roll, best_bonus, check_total, escaped ? "Escaped!" : "Still grappled!");

		if (escaped) {
			c.remove_condition(COND_GRAPPLED);
			c.grapple_source_id = 0;
			broadcast_to_battle({{"type", message_types::condition_removed}, {"target", c.name}, {"condition", "Grappled"}});
			broadcast_announce(c.name + " breaks free from the grapple!");
		} else {
			broadcast_announce(c.name + " fails to escape the grapple.");
		}
		broadcast_state();
	}

	// PHB 2024 (para 4525): "With an action, you can use a Wisdom (Medicine) check
	// to try to stabilize a creature that has 0 Hit Points and isn't stable. The DC
	// is 10." On success, the creature becomes stable.
	void handle_stabilize(user@ u, json_object@ msg) {
		if (@combat == null or @u == null or @msg == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.has_action) {
			u.send({{"type", message_types::error}, {"text", "You've already used your action this turn."}});
			return;
		}
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}

		uint target_id = 0;
		if (msg.exists("target_id")) target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) {
			u.send({{"type", message_types::error}, {"text", "Invalid target."}});
			return;
		}
		if (target.current_hp > 0 or target.is_stable) {
			u.send({{"type", message_types::error}, {"text", target.name + " is not dying."}});
			return;
		}
		int dist = feet_distance(c.x, c.y, target.x, target.y);
		if (dist > 5) {
			u.send({{"type", message_types::error}, {"text", "You must be within 5 feet to stabilize " + target.name + ". Current distance: " + dist + " ft."}});
			return;
		}

		c.has_action = false;
		c.used_action = true;

		// WIS (Medicine) check DC 10
		int med_bonus = c.get_ability_mod(ABILITY_WIS);
		bool prof = false;
		for (uint sp = 0; sp < c.skill_proficiencies.length(); sp++) {
			if (c.skill_proficiencies[sp] == "Medicine") { prof = true; break; }
		}
		if (prof) {
			med_bonus += c.proficiency;
			for (uint se = 0; se < c.skill_expertise.length(); se++) {
				if (c.skill_expertise[se] == "Medicine") { med_bonus += c.proficiency; break; }
			}
		} else if (c.jack_of_all_trades) {
			med_bonus += c.proficiency / 2;
		}

		int check_roll = random(1, 20);
		int check_total = check_roll + med_bonus;
		bool success = check_total >= 10;

		broadcast_roll(c.name, "Medicine check to Stabilize " + target.name + " (DC 10)", check_roll, med_bonus, check_total, success ? "Stabilized!" : "Failed!");

		if (success) {
			target.is_stable = true;
			target.death_save_successes = 0;
			target.death_save_failures = 0;
			broadcast_announce(c.name + " stabilizes " + target.name + "!", true);
			broadcast_to_battle({{"type", message_types::creature_stabilized}, {"target", target.name}});
		} else {
			broadcast_announce(c.name + " fails to stabilize " + target.name + ".", false);
		}
		broadcast_state();
	}

	// Basic Rules 2024 Call Lightning (para 12321-12323): "On each of your subsequent
	// turns, you can use your action to call down lightning in this way again,
	// targeting the same point or a different one."
	void handle_call_lightning_bolt(user@ u, json_object@ msg) {
		if (@combat == null or @u == null or @msg == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.call_lightning_active or c.call_lightning_dice_count == 0) {
			u.send({{"type", message_types::error}, {"text", "You don't have an active Call Lightning."}});
			return;
		}
		if (!c.has_action) {
			u.send({{"type", message_types::error}, {"text", "You've already used your action this turn."}});
			return;
		}
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}

		uint target_id = 0;
		if (msg.exists("target_id")) target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) {
			u.send({{"type", message_types::error}, {"text", "Invalid target."}});
			return;
		}

		c.has_action = false;
		c.used_action = true;

		int center_x = target.x;
		int center_y = target.y;
		int total_damage = 0;
		for (int d = 0; d < c.call_lightning_dice_count; d++) total_damage += random(1, 10);
		int cl_dc = spell_save_dc(c, "call_lightning");
		broadcast_announce(c.name + " calls another bolt of lightning!", true);
		for (uint ti = 0; ti < combat.combatants.length(); ti++) {
			combatant@ t = combat.combatants[ti];
			if (@t == null or t.is_dead or t.id == c.id) continue;
			if (feet_distance(center_x, center_y, t.x, t.y) > 5) continue;
			int save_roll = random(1, 20);
			apply_hound_save_disadvantage(t, c.id, save_roll);
			int save_bonus = t.get_save_bonus(ABILITY_DEX);
			int bless_bonus = roll_bless_bonus(t);
			int save_total = save_roll + save_bonus + bless_bonus;
			bool saved = save_total >= cl_dc;
			broadcast_roll(t.name, "DEX save vs Call Lightning", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
			if (!saved and try_arcane_deflection_save(t, cl_dc, save_total)) saved = true;
			if (!saved) { int fg = try_flash_of_genius(t, cl_dc, save_total, "DEX save vs Call Lightning"); if (fg >= cl_dc) saved = true; }
			if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, cl_dc); if (bf >= cl_dc) saved = true; }
			if (!saved and try_stroke_of_luck_save(t, cl_dc, save_bonus + bless_bonus)) saved = true;
			int dmg = saved ? total_damage / 2 : total_damage;
			if (dmg < 1) dmg = 1;
			combat.apply_damage(t, dmg, DMG_LIGHTNING, c);
			check_concentration(t, dmg, c);
		}
		broadcast_state();
		check_battle_end();
	}

	// Basic Rules 2024 Flame Blade (para 13334-13343): "As a Magic action, you can
	// make a melee spell attack with the fiery blade. On a hit, the target takes
	// Fire damage equal to 3d6 plus your spellcasting ability modifier."
	void handle_unjam_weapon(user@ u) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.weapon_jammed) {
			u.send({{"type", message_types::error}, {"text", "Your weapon is not jammed."}});
			return;
		}
		if (!c.has_action) {
			u.send({{"type", message_types::error}, {"text", "You need an action to unjam your weapon."}});
			return;
		}
		c.weapon_jammed = false;
		c.has_action = false;
		c.used_action = true;
		broadcast_announce(c.name + " spends their action to unjam their weapon!", true);
		broadcast_state();
	}

	void handle_flame_blade_attack(user@ u, json_object@ msg) {
		if (@combat == null or @u == null or @msg == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.flame_blade_active or c.flame_blade_dice == 0) {
			u.send({{"type", message_types::error}, {"text", "You don't have an active Flame Blade."}});
			return;
		}
		if (!c.has_action) {
			u.send({{"type", message_types::error}, {"text", "You've already used your action this turn."}});
			return;
		}
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}
		uint target_id = 0;
		if (msg.exists("target_id")) target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) {
			u.send({{"type", message_types::error}, {"text", "Invalid target."}});
			return;
		}
		int dist = feet_distance(c.x, c.y, target.x, target.y);
		if (dist > 5) {
			u.send({{"type", message_types::error}, {"text", "Target is " + dist + " feet away. Flame Blade is a melee attack (5 ft range)."}});
			return;
		}
		c.has_action = false;
		c.used_action = true;
		// Queue melee spell attack roll
		int spell_atk = spell_attack_bonus(c);
		bool adv = false, disadv = false;
		apply_attack_advantage_state(c, target, dist, false, adv, disadv, true);
		int spell_mod = get_spellcasting_ability_mod(c);
		pending_roll pr;
		pr.combatant_id = c.id;
		pr.player_username = c.player_username;
		pr.roll_type = ROLL_ATTACK;
		pr.dice_sides = 20;
		pr.modifier = spell_atk;
		pr.reason = "Flame Blade melee spell attack against " + target.name;
		pr.target_id = target.id;
		pr.has_advantage = adv;
		pr.has_disadvantage = disadv;
		pr.is_spell_effect = true;
		pr.spell_uses_attack_roll = true;
		pr.spell_id = "flame_blade";
		pr.attack_name = "Flame Blade";
		pr.damage_dice_count = c.flame_blade_dice;
		pr.damage_dice_sides = 6;
		pr.damage_modifier = spell_mod;
		pr.damage_type = DMG_FIRE;
		pr.is_weapon_attack = false;
		pr.resolution_tag = "flame_blade";
		@current_roll = pr;
		if (@u != null and !u.is_bot and c.is_player) {
			send_roll_request(u, pr);
		} else {
			process_roll_result(random(1, 20));
		}
	}

	// Xanathar's Investiture of Ice action ability: "As an action, you can create a
	// 15-foot cone of freezing wind extending from your outstretched hand. Each
	// creature in the cone must make a Constitution saving throw. A creature takes
	// 4d6 cold damage on a failed save, or half as much on a successful one."
	void handle_investiture_ice_cone(user@ u, json_object@ msg) {
		if (@combat == null or @u == null or @msg == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.investiture_ice_active) {
			u.send({{"type", message_types::error}, {"text", "You don't have an active Investiture of Ice."}});
			return;
		}
		if (!c.has_action) {
			u.send({{"type", message_types::error}, {"text", "You've already used your action this turn."}});
			return;
		}
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}
		uint target_id = 0;
		if (msg.exists("target_id")) target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) {
			u.send({{"type", message_types::error}, {"text", "Invalid target."}});
			return;
		}
		c.has_action = false;
		c.used_action = true;
		// 15ft cone from caster toward target — hit all hostiles within 15ft in that direction
		int ice_dc = spell_save_dc(c, "investiture_of_ice");
		int total_damage = 0;
		for (int d = 0; d < 4; d++) total_damage += random(1, 6);
		broadcast_announce(c.name + " unleashes a 15-foot cone of freezing wind!", true);
		for (uint ti = 0; ti < combat.combatants.length(); ti++) {
			combatant@ t = combat.combatants[ti];
			if (@t == null or t.is_dead or t.id == c.id) continue;
			if (!combat.are_hostile(c, t)) continue;
			if (feet_distance(c.x, c.y, t.x, t.y) > 15) continue;
			int save_roll = random(1, 20);
			apply_hound_save_disadvantage(t, c.id, save_roll);
			int save_bonus = t.get_save_bonus(ABILITY_CON);
			int bless_bonus = roll_bless_bonus(t);
			int save_total = save_roll + save_bonus + bless_bonus;
			bool saved = save_total >= ice_dc;
			broadcast_roll(t.name, "CON save vs Investiture of Ice", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
			if (!saved and try_arcane_deflection_save(t, ice_dc, save_total)) saved = true;
			if (!saved) { int fg = try_flash_of_genius(t, ice_dc, save_total, "CON save vs Investiture of Ice"); if (fg >= ice_dc) { saved = true; save_total = fg; } }
			if (!saved) { int mv = try_maverick_spirit(t, ice_dc, save_total, "CON save vs Investiture of Ice"); if (mv >= ice_dc) { saved = true; save_total = mv; } }
			if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, ice_dc); if (bf >= ice_dc) { saved = true; save_total = bf; } }
			if (!saved and try_stroke_of_luck_save(t, ice_dc, save_bonus + bless_bonus)) saved = true;
			int dmg = saved ? total_damage / 2 : total_damage;
			if (dmg < 1) dmg = 1;
			combat.apply_damage(t, dmg, DMG_COLD, c);
			check_concentration(t, dmg, c);
		}
		broadcast_state();
		check_battle_end();
	}

	// Xanathar's Investiture of Stone action ability: "As an action, you can create
	// a small earthquake on the ground in a 15-foot radius centered on you. Other
	// creatures on that ground must succeed on a Dexterity saving throw or be
	// knocked prone."
	void handle_investiture_stone_quake(user@ u) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.investiture_stone_active) {
			u.send({{"type", message_types::error}, {"text", "You don't have an active Investiture of Stone."}});
			return;
		}
		if (!c.has_action) {
			u.send({{"type", message_types::error}, {"text", "You've already used your action this turn."}});
			return;
		}
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}
		c.has_action = false;
		c.used_action = true;
		int stone_dc = spell_save_dc(c, "investiture_of_stone");
		broadcast_announce(c.name + " slams the ground, causing a localized earthquake!", true);
		for (uint ti = 0; ti < combat.combatants.length(); ti++) {
			combatant@ t = combat.combatants[ti];
			if (@t == null or t.is_dead or t.id == c.id) continue;
			if (feet_distance(c.x, c.y, t.x, t.y) > 15) continue;
			int save_roll = random(1, 20);
			apply_hound_save_disadvantage(t, c.id, save_roll);
			int save_bonus = t.get_save_bonus(ABILITY_DEX);
			int bless_bonus = roll_bless_bonus(t);
			int save_total = save_roll + save_bonus + bless_bonus;
			bool saved = save_total >= stone_dc;
			broadcast_roll(t.name, "DEX save vs Investiture of Stone", save_roll, save_bonus + bless_bonus, save_total, saved ? "Keeps footing!" : "Prone!");
			if (!saved and try_arcane_deflection_save(t, stone_dc, save_total)) saved = true;
			if (!saved) { int fg = try_flash_of_genius(t, stone_dc, save_total, "DEX save vs Investiture of Stone"); if (fg >= stone_dc) { saved = true; save_total = fg; } }
			if (!saved) { int mv = try_maverick_spirit(t, stone_dc, save_total, "DEX save vs Investiture of Stone"); if (mv >= stone_dc) { saved = true; save_total = mv; } }
			if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, stone_dc); if (bf >= stone_dc) { saved = true; save_total = bf; } }
			if (!saved and try_stroke_of_luck_save(t, stone_dc, save_bonus + bless_bonus)) saved = true;
			if (!saved) {
				t.add_condition(COND_PRONE);
				broadcast_announce(t.name + " is knocked prone by the earthquake!", false);
			}
		}
		broadcast_state();
	}

	// Xanathar's Investiture of Wind action ability: "As an action, you can create a
	// 15-foot cube of swirling wind centered on a point you can see within 60 feet.
	// Each creature in that area must make a Constitution saving throw. A creature
	// takes 2d10 bludgeoning damage on a failed save, or half on a successful one.
	// If a Large or smaller creature fails the save, it is also pushed up to 10
	// feet away from the center of the cube."
	void handle_investiture_wind_blast(user@ u, json_object@ msg) {
		if (@combat == null or @u == null or @msg == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (!c.investiture_wind_active) {
			u.send({{"type", message_types::error}, {"text", "You don't have an active Investiture of Wind."}});
			return;
		}
		if (!c.has_action) {
			u.send({{"type", message_types::error}, {"text", "You've already used your action this turn."}});
			return;
		}
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}
		uint target_id = 0;
		if (msg.exists("target_id")) target_id = uint(msg["target_id"]);
		combatant@ target = combat.get_combatant(target_id);
		if (@target == null or target.is_dead) {
			u.send({{"type", message_types::error}, {"text", "Invalid target."}});
			return;
		}
		int dist = feet_distance(c.x, c.y, target.x, target.y);
		if (dist > 60) {
			u.send({{"type", message_types::error}, {"text", "Target is " + dist + " feet away. Maximum range is 60 feet."}});
			return;
		}
		c.has_action = false;
		c.used_action = true;
		int wind_dc = spell_save_dc(c, "investiture_of_wind");
		int total_damage = random(1, 10) + random(1, 10);
		int center_x = target.x;
		int center_y = target.y;
		broadcast_announce(c.name + " conjures a 15-foot cube of swirling wind!", true);
		for (uint ti = 0; ti < combat.combatants.length(); ti++) {
			combatant@ t = combat.combatants[ti];
			if (@t == null or t.is_dead or t.id == c.id) continue;
			if (feet_distance(center_x, center_y, t.x, t.y) > 15) continue;
			int save_roll = random(1, 20);
			apply_hound_save_disadvantage(t, c.id, save_roll);
			int save_bonus = t.get_save_bonus(ABILITY_CON);
			int bless_bonus = roll_bless_bonus(t);
			int save_total = save_roll + save_bonus + bless_bonus;
			bool saved = save_total >= wind_dc;
			broadcast_roll(t.name, "CON save vs Investiture of Wind", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage + push!");
			if (!saved and try_arcane_deflection_save(t, wind_dc, save_total)) saved = true;
			if (!saved) { int fg = try_flash_of_genius(t, wind_dc, save_total, "CON save vs Investiture of Wind"); if (fg >= wind_dc) { saved = true; save_total = fg; } }
			if (!saved) { int mv = try_maverick_spirit(t, wind_dc, save_total, "CON save vs Investiture of Wind"); if (mv >= wind_dc) { saved = true; save_total = mv; } }
			if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, wind_dc); if (bf >= wind_dc) { saved = true; save_total = bf; } }
			if (!saved and try_stroke_of_luck_save(t, wind_dc, save_bonus + bless_bonus)) saved = true;
			int dmg = saved ? total_damage / 2 : total_damage;
			if (dmg < 1) dmg = 1;
			combat.apply_damage(t, dmg, DMG_BLUDGEONING, c);
			check_concentration(t, dmg, c);
			// Push Large or smaller creatures 10ft away from center on failed save
			if (!saved and t.size <= SIZE_LARGE and !t.is_dead) {
				int dx = t.x - center_x;
				int dy = t.y - center_y;
				if (dx == 0 and dy == 0) dx = 1; // Default push direction
				int push_dist = 10 / FEET_PER_TILE;
				if (dx != 0) t.x += (dx > 0 ? push_dist : -push_dist);
				else t.y += (dy > 0 ? push_dist : -push_dist);
				broadcast_announce(t.name + " is pushed 10 feet by the wind blast!", false);
			}
		}
		broadcast_state();
		check_battle_end();
	}

	// ---- Consumable Usage ----

	void handle_use_consumable(user@ u, json_object@ msg) {
		if (@combat == null or @u == null or @msg == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) {
			u.send({{"type", message_types::error}, {"text", "It is not your turn."}});
			return;
		}

		string consumable_id = msg.exists("consumable_id") ? string(msg["consumable_id"]) : "";
		uint target_id = msg.exists("target_id") ? uint(int(msg["target_id"])) : 0;

		init_consumable_catalog();
		consumable_def@ cdef = find_consumable(consumable_id);
		if (@cdef == null) {
			u.send({{"type", message_types::error}, {"text", "Unknown consumable."}});
			return;
		}

		// Check player has the consumable
		if (@u.account == null) { u.send({{"type", message_types::error}, {"text", "No account data."}}); return; }
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_consumables");
		if (@inv == null or get_consumable_quantity(inv, consumable_id) <= 0) {
			u.send({{"type", message_types::error}, {"text", "You do not have any " + cdef.name + "."}});
			return;
		}

		// Check action availability
		if (cdef.action_type == CONS_ACTION_BONUS) {
			if (!c.has_bonus_action) { u.send({{"type", message_types::error}, {"text", "No bonus action remaining."}}); return; }
		} else {
			if (!c.has_action) { u.send({{"type", message_types::error}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}}); return; }
		}

		// Check no_healing modifier
		if (active_modifier == "no_healing" and cdef.type == CONS_HEALING) {
			u.send({{"type", message_types::error}, {"text", "Healing is disabled by the No Healing modifier."}});
			return;
		}

		// Apply effects based on type
		if (cdef.type == CONS_HEALING) {
			int heal_total = 0;
			for (int hi = 0; hi < cdef.heal_count; hi++) heal_total += random(1, cdef.heal_dice);
			heal_total += cdef.heal_bonus;
			int healed = combat.apply_healing(c, heal_total);

			// Consume action
			if (cdef.action_type == CONS_ACTION_BONUS) { c.has_bonus_action = false; c.used_bonus_action = true; }
			else { c.has_action = false; c.used_action = true; }

			remove_consumable_from_inventory(inv, consumable_id);
			u.account.commit();

			broadcast_announce(c.name + " drinks " + cdef.name + " and heals " + healed + " HP! (Rolled " + heal_total + ")", true);
			broadcast_to_battle({{"type", message_types::healing_done}, {"healer", c.name}, {"target", c.name}, {"amount", healed}});
			if (c.is_player and c.player_username != "" and progression_enabled) add_run_healing(c.player_username, healed);
			broadcast_state();
		}
		else if (cdef.type == CONS_BUFF) {
			// Consume action
			if (cdef.action_type == CONS_ACTION_BONUS) { c.has_bonus_action = false; c.used_bonus_action = true; }
			else { c.has_action = false; c.used_action = true; }

			if (cdef.buff_stat == "damage") { c.potion_damage_bonus = cdef.buff_value; c.potion_damage_rounds = cdef.duration_rounds; }
			else if (cdef.buff_stat == "ac") { c.potion_ac_bonus = cdef.buff_value; c.armor_class += cdef.buff_value; c.potion_ac_rounds = cdef.duration_rounds; }
			else if (cdef.buff_stat == "speed") { c.potion_speed_bonus = cdef.buff_value; c.speed += cdef.buff_value; c.potion_speed_rounds = cdef.duration_rounds; }
			else if (cdef.buff_stat == "spell_dc") { c.potion_spell_dc_bonus = cdef.buff_value; c.potion_spell_dc_rounds = cdef.duration_rounds; }

			remove_consumable_from_inventory(inv, consumable_id);
			u.account.commit();

			broadcast_announce(c.name + " drinks " + cdef.name + "! " + cdef.description, true);
			broadcast_state();
		}
		else if (cdef.type == CONS_THROWABLE) {
			combatant@ target = combat.get_combatant(target_id);
			if (@target == null or target.is_dead) {
				u.send({{"type", message_types::error}, {"text", "Choose a valid target."}});
				return;
			}

			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (cdef.range > 0 and dist > cdef.range) {
				u.send({{"type", message_types::error}, {"text", "Target is out of range. Range: " + cdef.range + " feet, distance: " + dist + " feet."}});
				return;
			}

			// Consume action
			c.has_action = false;
			c.used_action = true;

			remove_consumable_from_inventory(inv, consumable_id);
			u.account.commit();

			// (Smoke bomb special case removed in 2026-04-08 audit — fabricated item, not in PHB/DMG)

			// Roll damage
			int throw_damage = 0;
			for (int tdi = 0; tdi < cdef.damage_count; tdi++) throw_damage += random(1, cdef.damage_dice);

			// Target makes save (DC 13)
			int save_dc = 13;
			bool saved = false;
			if (cdef.save_type >= 0) {
				int save_roll = random(1, 20);
				int save_mod = target.get_save_bonus(cdef.save_type);
				int save_total = save_roll + save_mod;
				saved = save_total >= save_dc;
				string save_name = cdef.save_type < int(ABILITY_NAMES.length()) ? ABILITY_NAMES[cdef.save_type] : "Ability";
				broadcast_roll(target.name, save_name + " save (DC " + save_dc + ")", save_roll, save_mod, save_total, saved ? "Saved! Half damage." : "Failed!");
			}

			if (saved) throw_damage /= 2;
			if (throw_damage < 1) throw_damage = 1;

			// Apply modifier damage adjustments
			if (active_modifier == "glass_cannon") throw_damage *= 2;

			broadcast_announce(c.name + " throws " + cdef.name + " at " + target.name + " for " + throw_damage + " damage!", true);
			bool throw_target_was_full = (target.current_hp == target.max_hp);
			combat.apply_damage(target, throw_damage, cdef.damage_type, c);

			if (target.is_dead) {
				broadcast_announce(target.name + " has been slain!", true);
				broadcast_to_battle({{"type", message_types::creature_died}, {"name", target.name}, {"id", target.id}, {"killed_by", c.name}, {"was_full_hp", throw_target_was_full}, {"was_overkill", throw_damage >= target.max_hp * 2}, {"was_stealth", false}});
			} else if (target.current_hp == 0 and target.has_condition(COND_UNCONSCIOUS)) {
				broadcast_announce(target.name + " falls unconscious!", true);
			} else {
				broadcast_announce(target.name + " has " + target.current_hp + " of " + target.max_hp + " HP remaining.");
			}

			broadcast_state();
			check_battle_end();
		}
		else if (cdef.type == CONS_SCROLL) {
			// Consume action
			if (cdef.action_type == CONS_ACTION_BONUS) { c.has_bonus_action = false; c.used_bonus_action = true; }
			else { c.has_action = false; c.used_action = true; }

			remove_consumable_from_inventory(inv, consumable_id);
			u.account.commit();

			if (cdef.spell_id == "shield") {
				// Shield scroll: +5 AC for 1 round
				c.potion_ac_bonus = cdef.buff_value;
				c.armor_class += cdef.buff_value;
				c.potion_ac_rounds = cdef.duration_rounds;
				broadcast_announce(c.name + " uses " + cdef.name + "! Plus " + cdef.buff_value + " AC until next turn.", true);
				broadcast_state();
			}
			else if (cdef.spell_id == "misty_step") {
				// Teleport 30 feet toward target or random safe position
				combatant@ target = combat.get_combatant(target_id);
				int new_x = c.x;
				int new_y = c.y;
				if (@target != null and !target.is_dead) {
					int dx = target.x - c.x;
					int dy = target.y - c.y;
					if (dx != 0) dx = dx > 0 ? 1 : -1;
					if (dy != 0) dy = dy > 0 ? 1 : -1;
					new_x = c.x + dx * 6; // 30 feet = 6 tiles
					new_y = c.y + dy * 6;
				} else {
					new_x = c.x + random(-6, 6);
					new_y = c.y + random(-6, 6);
				}
				if (new_x < 0) new_x = 0;
				if (new_x >= combat.map_width) new_x = combat.map_width - 1;
				if (new_y < 0) new_y = 0;
				if (new_y >= combat.map_height) new_y = combat.map_height - 1;
				c.x = new_x;
				c.y = new_y;
				broadcast_announce(c.name + " uses " + cdef.name + " and teleports!", true);
				broadcast_state();
			}
			else if (cdef.spell_id == "fireball") {
				// AoE fire damage - use spell handler
				json_object cast_msg;
				cast_msg["spell"] = "fireball";
				cast_msg["target_id"] = target_id;
				// Restore the action we consumed since handle_cast will consume one
				if (cdef.action_type == CONS_ACTION_BONUS) { c.has_bonus_action = true; c.used_bonus_action = false; }
				else { c.has_action = true; c.used_action = false; }
				// Temporarily give a fireball spell slot and knowledge so handle_cast works
				bool already_knows = c.knows_spell("fireball");
				if (!already_knows) c.prepared_spells.insert_last("fireball");
				// Ensure spell slot available
				bool had_slot = false;
				for (int sl = 3; sl <= 9; sl++) {
					if (c.spell_slots_current[sl] > 0) { had_slot = true; break; }
				}
				if (!had_slot) { c.spell_slots_current[3]++; }
				handle_cast(u, cast_msg);
				if (!already_knows) {
					for (int si = int(c.prepared_spells.length()) - 1; si >= 0; si--) {
						if (c.prepared_spells[si] == "fireball") { c.prepared_spells.remove_at(si); break; }
					}
				}
			}
			else {
				broadcast_announce(c.name + " uses " + cdef.name + "!", true);
				broadcast_state();
			}
		}
	}

	// ---- Spell Casting ----

	void handle_cast(user@ u, json_object@ msg) {
		if (@combat == null or @u == null) return;
		combatant@ c = combat.current_combatant();
		if (@c == null or !c.is_player or c.player_username != u.username) return;
		if (c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take actions."}, {"interrupt", true}});
			return;
		}
		// PHB 2024 Druid L18 Beast Spells (para 4449): can cast spells in Wild Shape
		if (c.wild_shape_active and !c.beast_spells_active) {
			u.send({{"type", message_types::announce}, {"text", "You cannot cast spells while in Wild Shape."}, {"interrupt", true}});
			return;
		}

		string spell_id = msg.exists("spell") ? string(msg["spell"]) : "";
		uint target_id = msg.exists("target_id") ? uint(int(msg["target_id"])) : (msg.exists("target") ? uint(int(msg["target"])) : 0);

		spell_def@ spell = get_spell(spell_id);
		if (@spell == null) {
			u.send({{"type", message_types::announce}, {"text", "Unknown spell."}, {"interrupt", true}});
			return;
		}
		if (!c.knows_spell(spell_id)) {
			u.send({{"type", message_types::announce}, {"text", "That spell is not prepared or known by your character."}, {"interrupt", true}});
			return;
		}
		// War Magic Arcane Deflection restriction (para 2933-2934): "If you use
		// Arcane Deflection, you can't cast spells other than cantrips until the
		// end of your next turn."
		if (c.arcane_deflection_no_spell_turns > 0 and spell.level > 0) {
			u.send({{"type", message_types::announce}, {"text", "Arcane Deflection restricts you to cantrips until end of your next turn."}, {"interrupt", true}});
			return;
		}

		// Basic Rules 2024 Silence: block casting with verbal components inside a silence zone.
		// Nearly all spells have verbal components; only Subtle Spell metamagic bypasses this.
		if (!c.metamagic_subtle_active) {
			bool in_silence = false;
			for (uint si = 0; si < combat.combatants.length(); si++) {
				combatant@ sc = combat.combatants[si];
				if (@sc == null or sc.is_dead or !sc.silence_active) continue;
				if (feet_distance(sc.silence_x, sc.silence_y, c.x, c.y) <= 20) {
					in_silence = true;
					break;
				}
			}
			if (in_silence) {
				u.send({{"type", message_types::announce}, {"text", "You are inside a Silence zone and cannot cast spells with verbal components!"}, {"interrupt", true}});
				return;
			}
		}

		// Basic Rules 2024 Antimagic Field (para 11938-11945): "No one can cast
		// spells, take Magic actions, or create other magical effects inside the
		// aura." Block spellcasting for anyone within 10ft of an antimagic field
		// source. The caster's own field doesn't block themselves.
		{
			bool in_antimagic = false;
			for (uint ami = 0; ami < combat.combatants.length(); ami++) {
				combatant@ amc = combat.combatants[ami];
				if (@amc == null or amc.is_dead or !amc.antimagic_field_active) continue;
				if (amc.id == c.id) continue; // Own field doesn't block self
				if (feet_distance(amc.x, amc.y, c.x, c.y) <= 10) {
					in_antimagic = true;
					break;
				}
			}
			if (in_antimagic) {
				u.send({{"type", message_types::announce}, {"text", "You are inside an Antimagic Field and cannot cast spells!"}, {"interrupt", true}});
				return;
			}
		}

		// Basic Rules 2024 Globe of Invulnerability (para 13549-13550): "Any spell of
		// level 5 or lower cast from outside the barrier can't affect anything within it."
		// Check if the targeted creature is inside a Globe and the caster is outside.
		combatant@ target = combat.get_combatant(target_id);
		if (@target != null and !target.is_dead and spell.level > 0 and spell.level <= 9) {
			for (uint gi2 = 0; gi2 < combat.combatants.length(); gi2++) {
				combatant@ globe_src = combat.combatants[gi2];
				if (@globe_src == null or globe_src.is_dead or !globe_src.globe_of_invulnerability_active) continue;
				// Target must be within the 10ft emanation
				if (feet_distance(globe_src.x, globe_src.y, target.x, target.y) > 10) continue;
				// Caster must be OUTSIDE the 10ft emanation (spells from inside work normally)
				if (feet_distance(globe_src.x, globe_src.y, c.x, c.y) <= 10) continue;
				// Spell level must be at or below the globe's protection level
				if (spell.level <= globe_src.globe_of_invulnerability_level) {
					u.send({{"type", message_types::announce}, {"text", target.name + " is protected by a Globe of Invulnerability! Spells of level " + globe_src.globe_of_invulnerability_level + " or lower from outside cannot affect them."}, {"interrupt", true}});
					return;
				}
			}
		}
		if (spell.id == "true_strike") {
			if (@target == null or target.is_dead) {
				u.send({{"type", message_types::announce}, {"text", "Choose a living target for True Strike."}, {"interrupt", true}});
				return;
			}
			if (!combat.can_see(c, target)) {
				u.send({{"type", message_types::announce}, {"text", "You cannot see that target for True Strike."}, {"interrupt", true}});
				return;
			}
			int weapon_range = c.main_hand_range > 0 ? c.main_hand_range : 5;
			int true_strike_dist = feet_distance(c.x, c.y, target.x, target.y);
			if (true_strike_dist > weapon_range) {
				u.send({{"type", message_types::announce}, {"text", "True Strike must target a creature within your weapon's range."}, {"interrupt", true}});
				return;
			}
		}
		else if (spell.id == "spiritual_weapon" and @target != null) {
			if (!combat.can_see(c, target)) {
				u.send({{"type", message_types::announce}, {"text", "You cannot see that target for Spiritual Weapon."}, {"interrupt", true}});
				return;
			}
			int spiritual_dist = feet_distance(c.x, c.y, target.x, target.y);
			if (spiritual_dist > 60) {
				u.send({{"type", message_types::announce}, {"text", "That target is out of range for Spiritual Weapon."}, {"interrupt", true}});
				return;
			}
		}
		else if (@target != null and spell.range > 0) {
			int effective_range = spell.range;
			// Metamagic: Distant Spell — double range (para 6983-6984)
			if (c.metamagic_distant_active and spell.range >= 5) effective_range = spell.range * 2;
			// Basic Rules 2024 Eldritch Spear (para 7830-7832): increase range by 30*level
			if (c.eldritch_spear and spell.id == "eldritch_blast") effective_range += 30 * c.level;
			int target_dist = feet_distance(c.x, c.y, target.x, target.y);
			if (target_dist > effective_range) {
				u.send({{"type", message_types::announce}, {"text", "That target is out of range for " + spell.name + "."}, {"interrupt", true}});
				return;
			}
		}

		// Metamagic: Quickened Spell — action spell cast as bonus action (para 6993-6996)
		bool quickened_this_cast = false;
		if (c.metamagic_quickened_active and spell.casting_time == 0 and spell.level > 0) {
			quickened_this_cast = true;
		}

		// PHB 2024 Bonus Action Spell rule (para 7986-7989): "If you cast a spell
		// that has a casting time of Bonus Action, you can't cast another spell during
		// the same turn except a cantrip that has a casting time of an action."
		bool is_ba_cast = (spell.casting_time == 1 or quickened_this_cast);
		if (is_ba_cast and spell.level > 0 and c.cast_leveled_spell_this_turn) {
			u.send({{"type", message_types::announce}, {"text", "You already cast a leveled spell this turn. You can only cast a cantrip as a bonus action."}, {"interrupt", true}});
			return;
		}
		if (!is_ba_cast and spell.casting_time == 0 and spell.level > 0 and c.cast_ba_spell_this_turn) {
			u.send({{"type", message_types::announce}, {"text", "You cast a bonus action spell this turn. You can only cast a cantrip with your action."}, {"interrupt", true}});
			return;
		}

		// Check casting time: 0=action, 1=bonus action, 2=reaction
		if (spell.casting_time == 0 and !quickened_this_cast and !c.has_action) {
			u.send({{"type", message_types::announce}, {"text", "You've already used your action this turn. Press F and choose End Turn, or press B for a bonus action."}, {"interrupt", true}});
			return;
		}
		if (spell.casting_time == 1 and !c.has_bonus_action) {
			u.send({{"type", message_types::announce}, {"text", "No bonus action remaining. Press F for standard actions or End Turn."}, {"interrupt", true}});
			return;
		}
		if (spell.casting_time == 2 and !c.has_reaction) {
			u.send({{"type", message_types::announce}, {"text", "No reaction remaining."}, {"interrupt", true}});
			return;
		}
		// Check spell slots (cantrips = level 0, free)
		int cast_slot_level = spell.level;
		bool used_free_cast = false;
		bool slot_consumed = false; // tracks whether an actual spell slot was decremented
		bool used_divine_intervention = false;
		if (spell.level > 0) {
			// PHB 2024 Cleric L10 Divine Intervention (para 3621-3622): "As part of the
			// same action, you cast that spell without expending a spell slot or needing
			// Material components." If the Cleric activated Divine Intervention this
			// battle and the spell is a Cleric spell of level <=5, the flag bypasses
			// slot consumption.
			bool used_spell_mastery = false;
			bool used_signature_spell = false;
			bool used_boon_of_spell_recall = false;
			if (c.divine_intervention_ready and c.class_name == "Cleric" and spell.level <= 5) {
				c.divine_intervention_ready = false;
				used_divine_intervention = true;
				cast_slot_level = spell.level;
			} else if (c.get_free_cast_uses_remaining(spell.id) > 0) {
				used_free_cast = c.use_free_cast(spell.id);
				cast_slot_level = spell.level;
			} else if (c.class_name == "Wizard" and c.spell_mastery_active and spell.level == 1 and spell.id == c.spell_mastery_l1_spell_id) {
				// PHB 2024 Wizard L18 Spell Mastery (paras 8629-8631): designated L1
				// spell can be cast at base level without expending a slot.
				used_spell_mastery = true;
				cast_slot_level = 1;
			} else if (c.class_name == "Wizard" and c.spell_mastery_active and spell.level == 2 and spell.id == c.spell_mastery_l2_spell_id) {
				// Designated L2 Spell Mastery spell.
				used_spell_mastery = true;
				cast_slot_level = 2;
			} else if (c.class_name == "Wizard" and spell.level == 3 and spell.id == c.signature_spell_a_id and !c.signature_spell_a_used_this_rest) {
				// PHB 2024 Wizard L20 Signature Spells (para 8634-8635): first
				// designated L3 spell, free at L3 once per Short Rest.
				c.signature_spell_a_used_this_rest = true;
				if (c.signature_spells_charges_remaining > 0) c.signature_spells_charges_remaining--;
				used_signature_spell = true;
				cast_slot_level = 3;
			} else if (c.class_name == "Wizard" and spell.level == 3 and spell.id == c.signature_spell_b_id and !c.signature_spell_b_used_this_rest) {
				// Second designated L3 Signature Spell.
				c.signature_spell_b_used_this_rest = true;
				if (c.signature_spells_charges_remaining > 0) c.signature_spells_charges_remaining--;
				used_signature_spell = true;
				cast_slot_level = 3;
			} else if (c.has_feat("boon_of_spell_recall") and !c.boon_of_spell_recall_used) {
				// PHB 2024 Boon of Spell Recall (para 7882): "You can cast any spell you
				// have prepared without expending a spell slot. Once you use this benefit,
				// you can't do so again until you finish a Long Rest."
				c.boon_of_spell_recall_used = true;
				used_boon_of_spell_recall = true;
				cast_slot_level = spell.level;
			} else {
				int slot_used = -1;
				for (int sl = spell.level; sl <= 9; sl++) {
					if (c.spell_slots_current[sl] > 0) {
						slot_used = sl;
						break;
					}
				}
				if (slot_used < 0) {
					u.send({{"type", message_types::announce}, {"text", "No spell slots available for " + spell.name + "."}, {"interrupt", true}});
					return;
				}
				c.spell_slots_current[slot_used]--;
				slot_consumed = true;
				cast_slot_level = slot_used;
			}
			reveal_hidden_combatant(c, "casting a spell");
			if (used_divine_intervention) broadcast_announce(c.name + " casts " + spell.name + " through Divine Intervention — no spell slot consumed!", true);
			else if (used_free_cast) broadcast_announce(c.name + " casts " + spell.name + " using a free casting.", false);
			else if (used_spell_mastery) broadcast_announce(c.name + " casts " + spell.name + " through Spell Mastery — no spell slot consumed!", true);
			else if (used_signature_spell) broadcast_announce(c.name + " unleashes " + spell.name + " as a Signature Spell — no spell slot consumed!", true);
			else if (used_boon_of_spell_recall) broadcast_announce(c.name + " invokes Boon of Spell Recall to cast " + spell.name + " — no spell slot consumed!", true);
			else broadcast_announce(c.name + " casts " + spell.name + " using a level " + cast_slot_level + " spell slot.", false);

			// Wild Magic Sorcerer: Wild Magic Surge (d20, on 1 trigger a random effect)
			if (c.class_name == "Sorcerer" and c.subclass == "Wild Magic Sorcery" and spell.level >= 1) {
				int surge_roll = random(1, 20);
				if (surge_roll == 1) {
					int surge = random(1, 8);
					if (surge == 1) {
						broadcast_announce("Wild Magic Surge! " + c.name + " is surrounded by a burst of fire damage to all within 10ft!", true);
						for (uint wi = 0; wi < combat.combatants.length(); wi++) {
							combatant@ wt = combat.combatants[wi];
							if (@wt == null or wt.is_dead or wt.id == c.id) continue;
							if (feet_distance(c.x, c.y, wt.x, wt.y) <= 10) {
								int fire_dmg = random(1, 6) + random(1, 6);
								combat.apply_damage(wt, fire_dmg, DMG_FIRE, c);
							}
						}
					} else if (surge == 2) {
						broadcast_announce("Wild Magic Surge! " + c.name + "'s skin changes color for 24 hours!", false);
					} else if (surge == 3) {
						c.temp_hp += c.level;
						broadcast_announce("Wild Magic Surge! " + c.name + " gains " + c.level + " temporary hit points!", true);
					} else if (surge == 4) {
						int heal = random(1, 6) + 5;
						combat.apply_healing(c, heal);
						broadcast_announce("Wild Magic Surge! " + c.name + " is healed for " + heal + " HP!", true);
					} else if (surge == 5) {
						c.has_reaction = false;
						c.has_bonus_action = false;
						broadcast_announce("Wild Magic Surge! " + c.name + "'s magic disrupts their action economy!", false);
					} else if (surge == 6) {
						broadcast_announce("Wild Magic Surge! " + c.name + " becomes invisible until they attack!", true);
						c.is_hidden = true;
					} else if (surge == 7) {
						broadcast_announce("Wild Magic Surge! " + c.name + " regains a level 1 spell slot!", true);
						if (c.spell_slots_current[1] < c.spell_slots_max[1]) c.spell_slots_current[1]++;
					} else {
						broadcast_announce("Wild Magic Surge! A magical wind blows through the battle!", false);
					}
				}
			}
		} else {
			reveal_hidden_combatant(c, "casting a spell");
			broadcast_announce(c.name + " casts " + spell.name + ".", false);
		}

		// Consume action/bonus action
		if (quickened_this_cast) {
			// Metamagic: Quickened Spell — consume bonus action instead of action
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.metamagic_quickened_active = false;
			broadcast_announce(c.name + " uses Quickened Spell to cast " + spell.name + " as a bonus action!", false);
		}
		else if (spell.casting_time == 0) {
			c.has_action = false; c.used_action = true;
			// PHB 2024 Boon of Dimensional Travel (para 7876): Blink Steps after Magic action
			if (c.has_feat("boon_of_dimensional_travel")) c.blink_steps_available = true;
		}
		else if (spell.casting_time == 1) { c.has_bonus_action = false; c.used_bonus_action = true; }
		else if (spell.casting_time == 2) { c.has_reaction = false; }

		// PHB 2024 Bonus Action Spell tracking: record what was cast this turn
		if (quickened_this_cast or spell.casting_time == 1) {
			if (spell.level > 0) c.cast_ba_spell_this_turn = true;
		} else if (spell.casting_time == 0 and spell.level > 0) {
			c.cast_leveled_spell_this_turn = true;
		}

		// Basic Rules 2024 Sanctuary (para 14826): "If the warded creature makes an
		// attack, casts a spell that affects an enemy, or deals damage to another
		// creature, this spell ends on that creature."
		if (c.sanctuary_active) {
			bool spell_affects_enemy = (spell.damage_count > 0 or spell.save_type >= 0);
			if (!spell_affects_enemy and @target != null and combat.are_hostile(c, target)) spell_affects_enemy = true;
			if (spell_affects_enemy) {
				c.sanctuary_active = false;
				c.sanctuary_dc = 0;
				c.sanctuary_source_id = 0;
				broadcast_announce(c.name + "'s Sanctuary ends — they cast a spell affecting an enemy!", false);
			}
		}

		// PHB 2024 Sorcerer Metamagic: Twinned Spell (para 7043-7044)
		// "When you cast a spell that targets only one creature and doesn't have a
		// range of Self, you can spend a number of Sorcery Points equal to the spell's
		// level (1 SP for a cantrip) to target a second creature in range with the
		// same spell." Capture flag + find second target before clearing metamagics.
		bool was_twinned = c.metamagic_twinned_active;
		combatant@ twinned_target = null;
		if (was_twinned and !spell.is_aoe and spell.range > 0) {
			// Find nearest valid second target (enemy for offensive, ally for buff/heal)
			bool is_offensive = (spell.damage_count > 0 or spell.save_type >= 0);
			int effective_range = spell_effective_range(c, spell);
			combatant@ best = null;
			int best_dist = 9999;
			for (uint ti = 0; ti < combat.combatants.length(); ti++) {
				combatant@ candidate = combat.combatants[ti];
				if (@candidate == null or candidate.is_dead) continue;
				if (@target != null and candidate.id == target.id) continue; // skip primary target
				if (candidate.id == c.id) continue; // skip self
				if (is_offensive) {
					if (!combat.are_hostile(c, candidate)) continue;
				} else {
					if (combat.are_hostile(c, candidate)) continue;
				}
				int d = feet_distance(c.x, c.y, candidate.x, candidate.y);
				if (effective_range > 0 and d > effective_range) continue;
				if (!combat.can_see(c, candidate)) continue;
				if (d < best_dist) { @best = candidate; best_dist = d; }
			}
			@twinned_target = best;
			if (@twinned_target != null) {
				// Deduct extra SP (spell level - 1, since 1 was already charged at toggle)
				int extra_sp = spell.level > 1 ? spell.level - 1 : 0;
				if (extra_sp > 0) {
					if (c.sorcery_points >= extra_sp) {
						c.sorcery_points -= extra_sp;
					} else {
						@twinned_target = null; // Can't afford
						broadcast_announce(c.name + " doesn't have enough Sorcery Points to twin " + spell.name + ".", false);
					}
				}
			}
			if (@twinned_target != null) {
				broadcast_announce(c.name + "'s Twinned Spell targets " + twinned_target.name + " as well!", true);
			}
		}

		// Clear non-stacking metamagic flags after cast (consumed on use)
		if (c.metamagic_careful_active) { c.metamagic_careful_active = false; }
		if (c.metamagic_distant_active) { c.metamagic_distant_active = false; }
		if (c.metamagic_extended_active) { c.metamagic_extended_active = false; }
		if (c.metamagic_heightened_active) { c.metamagic_heightened_active = false; }
		if (c.metamagic_subtle_active) { c.metamagic_subtle_active = false; }
		if (c.metamagic_transmuted_active) { c.metamagic_transmuted_active = false; }
		if (c.metamagic_twinned_active) { c.metamagic_twinned_active = false; }
		// Empowered and Seeking persist until consumed in damage/attack resolution

		// Basic Rules 2024 Counterspell (para 12677): "You attempt to interrupt a
		// creature in the process of casting a spell. The creature makes a Constitution
		// saving throw. On a failed save, the spell dissipates with no effect, and the
		// action, Bonus Action, or Reaction used to cast it is wasted."
		// Check if any hostile with counterspell_pending and reaction is within 60 ft.
		// Auto-resolve the CON save server-side. Cantrips cannot be countered.
		if (spell.level >= 1) {
			for (uint csi = 0; csi < combat.combatants.length(); csi++) {
				combatant@ cs_caster = combat.combatants[csi];
				if (@cs_caster == null or cs_caster.is_dead) continue;
				if (!cs_caster.counterspell_pending) continue;
				if (!cs_caster.has_reaction) continue;
				if (!combat.are_hostile(cs_caster, c)) continue;
				if (feet_distance(cs_caster.x, cs_caster.y, c.x, c.y) > 60) continue;
				// Fire counterspell
				cs_caster.counterspell_pending = false;
				cs_caster.has_reaction = false;
				int cs_dc = spell_save_dc(cs_caster);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(c, c.id, save_roll);
				int save_bonus = c.get_save_bonus(ABILITY_CON);
				int save_total = save_roll + save_bonus;
				bool cs_saved = save_total >= cs_dc;
				broadcast_announce(cs_caster.name + " unleashes Counterspell on " + c.name + "'s " + spell.name + "!", true);
				broadcast_roll(c.name, "CON save vs Counterspell", save_roll, save_bonus, save_total, cs_saved ? "Spell goes through!" : "Spell countered!");
				if (!cs_saved) {
					// Spell is countered — action consumed, but slot is preserved per source
					broadcast_announce(c.name + "'s " + spell.name + " fizzles!", true);
					// Basic Rules 2024 Counterspell (para 12678): "If that spell was
					// cast with a spell slot, the slot isn't expended."
					if (slot_consumed) {
						c.spell_slots_current[cast_slot_level]++;
						slot_consumed = false;
						broadcast_announce(c.name + "'s spell slot is preserved.", false);
					}
					// War Magic Power Surge on successful counterspell
					if (cs_caster.class_name == "Wizard" and cs_caster.subclass == "War Magic" and cs_caster.level >= 6 and cs_caster.power_surge_charges < cs_caster.power_surge_max) {
						cs_caster.power_surge_charges++;
						broadcast_announce(cs_caster.name + " stores a Power Surge! (" + cs_caster.power_surge_charges + "/" + cs_caster.power_surge_max + ")", false);
					}
					broadcast_state();
					return;
				}
				break; // Only one counterspell per cast
			}
		}

		// Xanathar's Storm Sorcery L6 Heart of the Storm (para 2629-2630): "whenever you
		// start casting a spell of 1st level or higher that deals lightning or thunder damage,
		// stormy magic erupts from you. This eruption causes creatures of your choice that you
		// can see within 10 feet of you to take lightning or thunder damage (choose each time
		// this ability activates) equal to half your sorcerer level."
		if (c.heart_of_the_storm_active and spell.level >= 1 and c.class_name == "Sorcerer") {
			// Check if the spell deals lightning or thunder damage
			bool spell_has_lightning_or_thunder = false;
			if (spell.damage_type == DMG_LIGHTNING or spell.damage_type == DMG_THUNDER) spell_has_lightning_or_thunder = true;
			if (spell_has_lightning_or_thunder) {
				int eruption_damage = c.level / 2;
				if (eruption_damage < 1) eruption_damage = 1;
				int eruption_type = spell.damage_type; // match the spell's damage type
				string eruption_type_name = (eruption_type == DMG_LIGHTNING) ? "lightning" : "thunder";
				int eruption_count = 0;
				for (uint hi = 0; hi < combat.combatants.length(); hi++) {
					combatant@ ht = combat.combatants[hi];
					if (@ht == null or ht.is_dead or ht.id == c.id) continue;
					if (ht.is_player == c.is_player and combat.mode != "pvp") continue; // skip allies
					if (feet_distance(c.x, c.y, ht.x, ht.y) <= 10 and combat.can_see(c, ht)) {
						combat.apply_damage(ht, eruption_damage, eruption_type, c);
						eruption_count++;
						if (ht.is_dead) {
							broadcast_to_battle({{"type", message_types::creature_died}, {"name", ht.name}, {"is_player", ht.is_player}, {"killed_by", c.name}, {"was_full_hp", false}, {"was_overkill", false}, {"was_stealth", false}});
						}
					}
				}
				if (eruption_count > 0) {
					broadcast_announce(c.name + "'s Heart of the Storm erupts for " + eruption_damage + " " + eruption_type_name + " damage to " + eruption_count + " nearby " + (eruption_count == 1 ? "creature" : "creatures") + "!", true);
				}
			}
		}

		// Order Domain Cleric: Voice of Authority - if targeting an ally with a 1st+ level spell, that ally can make a weapon attack as a reaction
		if (c.class_name == "Cleric" and c.subclass == "Order Domain" and spell.level >= 1 and @target != null and target.id != c.id and target.is_player == c.is_player and !target.is_dead and target.has_reaction) {
			// Find a hostile target the ally can reach
			combatant@ enemy = null;
			int best_dist = 999;
			for (uint vai = 0; vai < combat.combatants.length(); vai++) {
				combatant@ vt = combat.combatants[vai];
				if (@vt == null or vt.is_dead or vt.is_player == target.is_player) continue;
				int d = feet_distance(target.x, target.y, vt.x, vt.y);
				int weapon_range = target.main_hand_range > 0 ? target.main_hand_range : 5;
				if (d <= weapon_range and d < best_dist) {
					@enemy = vt;
					best_dist = d;
				}
			}
			if (@enemy != null) {
				int va_atk_bonus = get_attack_bonus_for_roll(target, false);
				int va_roll = random(1, 20);
				int va_total = va_roll + va_atk_bonus;
				broadcast_announce(c.name + "'s Voice of Authority compels " + target.name + " to strike " + enemy.name + "!", true);
				broadcast_roll(target.name, "Voice of Authority attack vs " + enemy.name, va_roll, va_atk_bonus, va_total, va_total >= enemy.armor_class ? "Hit!" : "Miss!");
				if (va_total >= enemy.armor_class or va_roll == 20) {
					int va_dmg = random(1, target.main_hand_damage_dice) * target.main_hand_damage_count;
					va_dmg += target.get_ability_mod(target.main_hand_finesse and target.get_ability_mod(ABILITY_DEX) > target.get_ability_mod(ABILITY_STR) ? ABILITY_DEX : ABILITY_STR);
					if (va_roll == 20) va_dmg *= 2;
					if (va_dmg < 1) va_dmg = 1;
					combat.apply_damage(enemy, va_dmg, target.main_hand_damage_type, target);
					broadcast_announce(target.name + " hits " + enemy.name + " for " + va_dmg + " damage!", true);
				}
				target.has_reaction = false;
			}
		}

		// Handle concentration: drop old concentration if starting new
		if (spell.concentration and c.is_concentrating) {
			string ended_spell = c.concentration_spell;
			clear_concentration_effects(c);
			c.is_concentrating = false;
			c.remove_condition(COND_CONCENTRATING);
			c.concentration_spell = "";
			broadcast_announce(c.name + " loses concentration on " + ended_spell + ".", false);
		}
		if (spell.concentration) {
			c.is_concentrating = true;
			c.concentration_spell = spell.name;
			c.add_condition(COND_CONCENTRATING);
			// PHB 2024 Sorcerer Metamagic Extended Spell (para 7029): advantage on
			// concentration saves for this spell.
			if (c.metamagic_extended_active) {
				c.extended_spell_concentration = true;
			} else {
				c.extended_spell_concentration = false;
			}
			// Xanathar's War Magic L10 Durable Magic (para 2941-2942): "While you maintain
			// concentration on a spell, you have a +2 bonus to AC..."
			if (c.durable_magic_active) c.armor_class += 2;
		}

		// Calculate spell attack bonus and save DC
		int spell_atk = spell_attack_bonus(c, spell.id);
		int save_dc = spell_save_dc(c, spell.id);
		int spell_mod = spell_atk - c.proficiency; // just the ability mod
		int healing_bonus = get_life_domain_healing_bonus(c, spell, cast_slot_level);
		int upcast_levels = cast_slot_level - spell.level;
		if (upcast_levels < 0) upcast_levels = 0;

		// RESOLVE SPELL EFFECTS

		// Healing spells
		if (spell.is_healing and spell.healing_count > 0) {
			if (@target == null) @target = c; // heal self if no target
			int healing_dice_count = spell.healing_count;
			if (spell.upcast_extra_dice > 0 and upcast_levels > 0) healing_dice_count += upcast_levels * spell.upcast_extra_dice;

			// AoE healing (Mass Cure Wounds, Mass Healing Word)
			if (spell.is_aoe and spell.max_targets > 1) {
				combatant@[] heal_targets;
				int center_x = target.x;
				int center_y = target.y;
				for (uint hi = 0; hi < combat.combatants.length() and heal_targets.length() < uint(spell.max_targets); hi++) {
					combatant@ ht = combat.combatants[hi];
					if (@ht == null or ht.is_dead) continue;
					if (ht.is_player != c.is_player) continue;
					if (feet_distance(center_x, center_y, ht.x, ht.y) > spell.aoe_radius) continue;
					heal_targets.insert_last(ht);
				}
				int heal_amount = 0;
				for (int d = 0; d < healing_dice_count; d++) {
					int die_roll = random(1, spell.healing_dice);
					if (c.has_feat("healer") and die_roll == 1) die_roll = random(1, spell.healing_dice);
					heal_amount += die_roll;
				}
				heal_amount += spell_mod;
				heal_amount += healing_bonus;
				if (heal_amount < 1) heal_amount = 1;
				broadcast_roll(c.name, spell.name + " healing", heal_amount, spell_mod, heal_amount, "");
				for (uint hi = 0; hi < heal_targets.length(); hi++) {
					combatant@ ht = heal_targets[hi];
					int eff = combat.apply_healing(ht, heal_amount);
					record_effective_healing(c.player_username, eff);
					broadcast_to_battle({{"type", message_types::healing_done}, {"source", c.name}, {"target", ht.name}, {"amount", heal_amount}});
					broadcast_announce(ht.name + " healed for " + heal_amount + ". Now at " + ht.current_hp + " of " + ht.max_hp + " HP.", false);
				}
			} else {
				int heal_amount = 0;
				for (int d = 0; d < healing_dice_count; d++) {
					int die_roll = random(1, spell.healing_dice);
					if (c.has_feat("healer") and die_roll == 1) die_roll = random(1, spell.healing_dice);
					heal_amount += die_roll;
				}
				heal_amount += spell_mod;
				heal_amount += healing_bonus;
				if (heal_amount < 1) heal_amount = 1;
				int effective_heal = combat.apply_healing(target, heal_amount);
				record_effective_healing(c.player_username, effective_heal);
				if (healing_bonus > 0) {
					broadcast_announce(c.name + "'s Life Domain adds " + healing_bonus + " extra healing.", false);
				}
				broadcast_roll(c.name, spell.name + " healing", heal_amount, spell_mod, heal_amount, "");
				broadcast_to_battle({{"type", message_types::healing_done}, {"source", c.name}, {"target", target.name}, {"amount", heal_amount}});
				broadcast_announce(target.name + " healed for " + heal_amount + ". Now at " + target.current_hp + " of " + target.max_hp + " HP.", false);
				// Twinned Spell: apply same healing to second target
				if (was_twinned and @twinned_target != null and !twinned_target.is_dead and twinned_target.id != target.id) {
					int twin_heal = combat.apply_healing(twinned_target, heal_amount);
					record_effective_healing(c.player_username, twin_heal);
					broadcast_to_battle({{"type", message_types::healing_done}, {"source", c.name}, {"target", twinned_target.name}, {"amount", heal_amount}});
					broadcast_announce(twinned_target.name + " healed for " + heal_amount + " (Twinned). Now at " + twinned_target.current_hp + " of " + twinned_target.max_hp + " HP.", false);
				}
			}
		}
		// Revivify special case
		else if (spell.id == "revivify" and @target != null and (target.is_dead or target.current_hp == 0)) {
			target.is_dead = false;
			target.current_hp = 1;
			target.remove_condition(COND_UNCONSCIOUS);
			target.death_save_successes = 0;
			target.death_save_failures = 0;
			target.is_stable = false;
			broadcast_announce(target.name + " is revived with 1 HP!", true);
		}
		// Heal spell (flat 70 HP)
		else if (spell.id == "heal" and @target != null) {
			int heal_amount = 70 + healing_bonus;
			int effective_heal = combat.apply_healing(target, heal_amount);
			record_effective_healing(c.player_username, effective_heal);
			if (target.has_condition(COND_BLINDED)) {
				target.remove_condition(COND_BLINDED);
				broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", "Blinded"}});
			}
			if (target.has_condition(COND_DEAFENED)) {
				target.remove_condition(COND_DEAFENED);
				broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", "Deafened"}});
			}
			if (healing_bonus > 0) {
				broadcast_announce(c.name + "'s Life Domain adds " + healing_bonus + " extra healing.", false);
			}
			broadcast_announce(target.name + " healed for " + heal_amount + " HP! Now at " + target.current_hp + ".", true);
			try_unicorn_totem_heal(c);
			try_chalice_healing(c);
		}
		else if (spell.id == "spiritual_weapon") {
			clear_spiritual_weapon_effect(c, false);
			c.spiritual_weapon_active = true;
			c.spiritual_weapon_slot_level = cast_slot_level;
			if (@target != null and !target.is_dead and start_spiritual_weapon_attack(c, target)) {
				broadcast_announce(c.name + " summons a Spiritual Weapon and strikes at " + target.name + "!", true);
			} else {
				broadcast_announce(c.name + " summons a Spiritual Weapon.", true);
			}
		}
		else if (spell.id == "true_strike") {
			if (!start_true_strike_attack(c, target)) {
				u.send({{"type", message_types::announce}, {"text", "True Strike cannot reach that target right now."}, {"interrupt", true}});
			}
		}
		// Ice Storm: 2d8 bludgeoning + 4d6 cold, DEX save, AoE
		else if (spell.id == "ice_storm") {
			int bludgeon_count = 2 + upcast_levels;
			int cold_count = 4;
			int total_damage = 0;
			for (int d = 0; d < bludgeon_count; d++) total_damage += random(1, 8);
			for (int d = 0; d < cold_count; d++) total_damage += random(1, 6);
			// Apply to all targets in AoE
			combatant@[] targets_hit;
			for (uint ti = 0; ti < combat.combatants.length(); ti++) {
				combatant@ t = combat.combatants[ti];
				if (@t == null or t.is_dead or t.id == c.id) continue;
				if (t.is_player == c.is_player and combat.mode != "pvp") continue;
				if (@target != null and feet_distance(target.x, target.y, t.x, t.y) <= 20) targets_hit.insert_last(t);
				else if (@target == null and feet_distance(c.x, c.y, t.x, t.y) <= 20) targets_hit.insert_last(t);
			}
			if (targets_hit.length() == 0 and @target != null) targets_hit.insert_last(target);
			for (uint ti = 0; ti < targets_hit.length(); ti++) {
				combatant@ t = targets_hit[ti];
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(t, c.id, save_roll);
				int save_bonus = t.get_save_bonus(ABILITY_DEX);
				int bless_bonus = roll_bless_bonus(t);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain
				if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Ice Storm"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Ice Storm"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
				broadcast_roll(t.name, "DEX save vs Ice Storm", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
				combat.apply_damage(t, dmg, DMG_COLD, c);
				broadcast_announce(t.name + " takes " + dmg + " damage from Ice Storm.", false);
			}
			broadcast_state();
			check_battle_end();
			return;
		}
		// Finger of Death: 7d8 + 30 necrotic, CON save, single target
		else if (spell.id == "finger_of_death" and @target != null and !target.is_dead) {
			int total_damage = 30;
			for (int d = 0; d < 7; d++) total_damage += random(1, 8);
			int save_roll = random(1, 20);
			apply_hound_save_disadvantage(target, c.id, save_roll);
			int save_bonus = target.get_save_bonus(ABILITY_CON);
			int bless_bonus = roll_bless_bonus(target);
			int save_total = save_roll + save_bonus + bless_bonus;
			bool saved = save_total >= save_dc;
			// Save failure chain
			if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
			if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "CON save vs Finger of Death"); if (fg >= save_dc) { saved = true; save_total = fg; } }
			if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "CON save vs Finger of Death"); if (mv >= save_dc) { saved = true; save_total = mv; } }
			if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
			if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
			int dmg = saved ? total_damage / 2 : total_damage;
			if (dmg < 1) dmg = 1;
			if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
			broadcast_roll(target.name, "CON save vs Finger of Death", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
			combat.apply_damage(target, dmg, DMG_NECROTIC, c);
			broadcast_announce(target.name + " takes " + dmg + " necrotic damage from Finger of Death!", true);
			broadcast_state();
			check_battle_end();
			return;
		}
		// Basic Rules 2024 Power Word Stun (para 14671-14673): "If the target has
		// 150 Hit Points or fewer, it has the Stunned condition. Otherwise, its Speed
		// is 0 until the start of your next turn. The Stunned target makes a Constitution
		// saving throw at the end of each of its turns, ending the condition on a success."
		else if (spell.id == "power_word_stun" and @target != null and !target.is_dead) {
			if (target.current_hp <= 150) {
				target.add_condition(COND_STUNNED);
				target.power_word_stun_caster_id = c.id;
				broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Stunned"}});
				broadcast_announce(c.name + " utters a Power Word! " + target.name + " is Stunned! (CON save at end of each turn to break free)", true);
			} else {
				// >150 HP: Speed = 0 until start of caster's next turn
				target.power_word_stun_speed_zero = true;
				target.power_word_stun_speed_source = c.id;
				target.movement_remaining = 0;
				broadcast_announce(c.name + " utters a Power Word! " + target.name + " resists the stun but their Speed is reduced to 0 until " + c.name + "'s next turn.", true);
			}
			broadcast_state();
			return;
		}
		// Damage spells with save
		else if (spell.damage_count > 0 and spell.save_type >= 0) {
			int damage_count = get_spell_damage_dice_count_for_cast(spell, c, cast_slot_level);
			int damage_sides = get_spell_damage_die_sides_for_cast(spell, target);
			queue_spell_damage_roll(u, c, target, spell, damage_count, damage_sides, 0, true, spell.save_type, save_dc);
			// Twinned Spell: tag the pending_roll with the second target
			if (was_twinned and @twinned_target != null and @current_roll != null) {
				current_roll.twinned_target_id = twinned_target.id;
			}
			broadcast_state();
			return;
		}
		// Magic Missile: auto-hit, distribute darts among visible enemies. Source (Basic
		// Rules para 14089): "You create three glowing darts of magical force. Each dart
		// strikes a creature of your choice that you can see within range. A dart deals
		// 1d4 + 1 Force damage to its target. The darts all strike simultaneously, and
		// you can direct them to hit one creature or several. Using a Higher-Level Spell
		// Slot: The spell creates one more dart for each spell slot level above 1."
		else if (spell.id == "magic_missile") {
			int darts = 3;
			if (upcast_levels > 0) darts += upcast_levels;
			int range = spell.range > 0 ? spell.range : 120;
			string prompt = "Magic Missile: distribute " + darts + " dart" + (darts == 1 ? "" : "s") + ". Press 1-9 to assign each dart to a visible enemy (you may pick the same enemy multiple times). Each dart deals 1d4+1 force damage.";
			if (!prompt_target_distribution(c, spell, darts, range, 0, 1, 4, 1, DMG_FORCE, false, cast_slot_level, prompt)) {
				u.send({{"type", message_types::announce}, {"text", "No visible targets within range for Magic Missile."}, {"interrupt", true}});
				return;
			}
			broadcast_state();
			return;
		}
		// Damage spells with attack roll (no save)
		else if (spell.damage_count > 0 and spell.save_type < 0) {
			if (@target == null or target.is_dead) {
				u.send({{"type", message_types::announce}, {"text", "No valid target."}, {"interrupt", true}});
				// Refund action
				if (spell.casting_time == 0) { c.has_action = true; c.used_action = false; }
				return;
			}

			int effective_range = spell_effective_range(c, spell);
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (effective_range > 0 and dist > effective_range) {
				u.send({{"type", message_types::announce}, {"text", "Target is out of range for " + spell.name + ". Distance: " + dist + " feet, range: " + effective_range + " feet."}, {"interrupt", true}});
				return;
			}
			if (!combat.can_see(c, target)) {
				u.send({{"type", message_types::announce}, {"text", "You cannot see that target."}, {"interrupt", true}});
				return;
			}

			int damage_count = get_spell_damage_dice_count_for_cast(spell, c, cast_slot_level);
			int damage_sides = get_spell_damage_die_sides_for_cast(spell, target);
			int attack_instances = get_spell_attack_instance_count(spell, c, cast_slot_level);

			// Distribution intercept: Scorching Ray (always 3+ rays) and Eldritch Blast
			// (2+ beams from L5+) let the caster pick a different target per ray/beam.
			// Source (Scorching Ray, Basic Rules para 14851): "You hurl three fiery rays.
			// You can hurl them at one target within range or at several. Make a ranged
			// spell attack for each ray." Source (Eldritch Blast, Basic Rules para 13047):
			// "You can direct the beams at the same target or at different ones. Make a
			// separate attack roll for each beam."
			if (attack_instances > 1 and (spell.id == "scorching_ray" or spell.id == "eldritch_blast")) {
				string prompt;
				if (spell.id == "scorching_ray") {
					prompt = "Scorching Ray: distribute " + attack_instances + " ray" + (attack_instances == 1 ? "" : "s") + ". Press 1-9 to assign each ray to a visible enemy. Each ray deals " + damage_count + "d" + damage_sides + " fire damage on hit.";
				} else {
					prompt = "Eldritch Blast: distribute " + attack_instances + " beam" + (attack_instances == 1 ? "" : "s") + ". Press 1-9 to assign each beam to a visible enemy. Each beam deals " + damage_count + "d" + damage_sides + " force damage on hit.";
				}
				if (prompt_target_distribution(c, spell, attack_instances, effective_range, spell_atk, damage_count, damage_sides, 0, spell.damage_type, true, cast_slot_level, prompt)) {
					broadcast_state();
					return;
				}
				// Falls through to single-target attack if no candidates available.
			}

			bool adv = false;
			bool disadv = false;
			apply_attack_advantage_state(c, target, dist, spell_attack_is_ranged(c, spell, effective_range), adv, disadv, true);
			int remaining = attack_instances - 1;
			string twin_csv = "";
			// Twinned Spell: add one more attack targeting the second creature
			if (was_twinned and @twinned_target != null) {
				remaining++;
				twin_csv = "" + twinned_target.id;
			}
			queue_spell_attack_roll(u, c, target, spell, spell_atk, damage_count, damage_sides, 0, remaining, adv, disadv, twin_csv);
			broadcast_state();
			return;
		}
		// Utility spells (no damage, no healing)
		else {
			// Handle specific utility spells
			if (spell.id == "shield") {
				clear_shield_effect(c, false);
				c.shield_active = true;
				c.shield_ac_bonus = 5;
				c.armor_class += c.shield_ac_bonus;
				broadcast_announce(c.name + " casts Shield! AC increased by 5 until the start of the next turn.", true);
			}
			else if (spell.id == "longstrider") {
				if (@target == null) @target = c;
				if (target.longstrider_bonus > 0) target.speed -= target.longstrider_bonus;
				target.longstrider_bonus = 10;
				target.speed += target.longstrider_bonus;
				broadcast_announce(target.name + " gains 10 feet of speed from Longstrider.", true);
			}
			else if (spell.id == "misty_step") {
				// PHB 2024 Misty Step: teleport up to 30 feet to an unoccupied space you can see
				combatant@ ms_target = @target;
				if (@ms_target == null or ms_target.is_dead) @ms_target = find_nearest_hostile_target(c);
				int new_x = c.x;
				int new_y = c.y;
				if (@ms_target != null and !ms_target.is_dead) {
					int dx = ms_target.x - c.x;
					int dy = ms_target.y - c.y;
					if (dx != 0) dx = dx > 0 ? 1 : -1;
					if (dy != 0) dy = dy > 0 ? 1 : -1;
					new_x = c.x + dx * 6; // 30 feet = 6 tiles
					new_y = c.y + dy * 6;
				} else {
					new_x = c.x + random(-6, 6);
					new_y = c.y + random(-6, 6);
				}
				if (new_x < 0) new_x = 0;
				if (new_x >= combat.map_width) new_x = combat.map_width - 1;
				if (new_y < 0) new_y = 0;
				if (new_y >= combat.map_height) new_y = combat.map_height - 1;
				c.x = new_x;
				c.y = new_y;
				broadcast_announce(c.name + " teleports 30 feet with Misty Step!", true);
			}
			else if (spell.id == "bless") {
				combatant@[] blessed_targets;
				blessed_targets.insert_last(c);
				if (@target != null and target.id != c.id and target.is_player == c.is_player and combat.mode != "pvp") {
					blessed_targets.insert_last(target);
				}
				for (uint bi = 0; bi < combat.combatants.length() and blessed_targets.length() < 3; bi++) {
					combatant@ ally = combat.combatants[bi];
					if (@ally == null or ally.id == c.id or ally.is_dead) continue;
					if (combat.mode == "pvp") continue;
					if (ally.is_player != c.is_player) continue;
					bool already_added = false;
					for (uint existing = 0; existing < blessed_targets.length(); existing++) {
						if (blessed_targets[existing].id == ally.id) {
							already_added = true;
							break;
						}
					}
					if (!already_added) blessed_targets.insert_last(ally);
				}

				string[] blessed_names;
				for (uint bi = 0; bi < blessed_targets.length(); bi++) {
					clear_bless_effect(blessed_targets[bi], false);
					blessed_targets[bi].blessed = true;
					blessed_targets[bi].bless_source_id = c.id;
					blessed_names.insert_last(blessed_targets[bi].name);
				}

				string bless_text = blessed_names.length() > 0 ? blessed_names[0] : c.name;
				for (uint bi = 1; bi < blessed_names.length(); bi++) {
					if (bi == blessed_names.length() - 1) bless_text += " and " + blessed_names[bi];
					else bless_text += ", " + blessed_names[bi];
				}
				broadcast_announce(c.name + " casts Bless on " + bless_text + "! They add 1d4 to attack rolls and saving throws.", true);
			}
			else if (spell.id == "lesser_restoration") {
				if (@target == null) @target = c;
				bool removed_any = false;
				if (target.has_condition(COND_BLINDED)) {
					target.remove_condition(COND_BLINDED);
					broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", "Blinded"}});
					removed_any = true;
				}
				if (target.has_condition(COND_DEAFENED)) {
					target.remove_condition(COND_DEAFENED);
					broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", "Deafened"}});
					removed_any = true;
				}
				if (target.has_condition(COND_PARALYZED)) {
					target.remove_condition(COND_PARALYZED);
					broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", "Paralyzed"}});
					removed_any = true;
				}
				if (target.has_condition(COND_POISONED)) {
					target.remove_condition(COND_POISONED);
					broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", "Poisoned"}});
					removed_any = true;
				}
				if (removed_any) broadcast_announce(c.name + " restores " + target.name + " with Lesser Restoration.", true);
				else broadcast_announce(c.name + " casts Lesser Restoration, but there is nothing for it to cure on " + target.name + ".", false);
			}
			else if (spell.id == "pass_without_trace") {
				string[] hidden_names;
				for (uint pi = 0; pi < combat.combatants.length(); pi++) {
					combatant@ ally = combat.combatants[pi];
					if (@ally == null or ally.is_dead) continue;
					if (combat.mode == "pvp" and ally.id != c.id) continue;
					if (combat.mode != "pvp" and ally.is_player != c.is_player) continue;
					clear_pass_without_trace_effect(ally, false);
					ally.pass_without_trace_bonus = 10;
					ally.pass_without_trace_source_id = c.id;
					hidden_names.insert_last(ally.name);
				}
				string trace_text = hidden_names.length() > 0 ? hidden_names[0] : c.name;
				for (uint pi = 1; pi < hidden_names.length(); pi++) {
					trace_text += pi == hidden_names.length() - 1 ? " and " : ", ";
					trace_text += hidden_names[pi];
				}
				broadcast_announce(c.name + " veils " + trace_text + " with Pass without Trace. Hide checks gain +10.", true);
			}
			else if (spell.id == "haste" and @target != null) {
				clear_haste_effect(target, false, false);
				target.hasted = true;
				target.haste_source_id = c.id;
				target.speed *= 2;
				target.armor_class += 2;
				broadcast_announce(target.name + " is Hasted! Double speed, +2 AC, extra action.", true);
				// Twinned Spell: Haste a second ally
				if (was_twinned and @twinned_target != null and !twinned_target.is_dead and twinned_target.id != target.id) {
					clear_haste_effect(twinned_target, false, false);
					twinned_target.hasted = true;
					twinned_target.haste_source_id = c.id;
					twinned_target.speed *= 2;
					twinned_target.armor_class += 2;
					broadcast_announce(twinned_target.name + " is also Hasted (Twinned)! Double speed, +2 AC, extra action.", true);
				}
			}
			else if (spell.id == "heroism") {
				if (@target == null) @target = c;
				clear_heroism_effect(target, false);
				target.heroism_source_id = c.id;
				target.heroism_temp_hp_amount = spell_mod > 0 ? spell_mod : 1;
				target.remove_condition(COND_FRIGHTENED);
				if (target.temp_hp < target.heroism_temp_hp_amount) target.temp_hp = target.heroism_temp_hp_amount;
				broadcast_announce(target.name + " is filled with Heroism and gains temporary hit points each turn.", true);
			}
			else if (spell.id == "hex" and @target != null) {
				// Basic Rules 2024 Hex (para 13730): "choose one ability when you cast the
				// spell. The target has Disadvantage on ability checks made with the chosen
				// ability." Prompt the caster for the ability choice.
				pending_spell_choice sc;
				sc.player_username = c.player_username;
				sc.caster_id = c.id;
				sc.spell_id = "hex";
				sc.cast_slot_level = cast_slot_level;
				sc.primary_target_id = target.id;
				sc.option_keys = {"str", "dex", "con", "int", "wis", "cha"};
				sc.option_labels = {"Strength", "Dexterity", "Constitution", "Intelligence", "Wisdom", "Charisma"};
				sc.prompt_text = "Hex: choose an ability for disadvantage on checks. Press 1 for Strength, 2 for Dexterity, 3 for Constitution, 4 for Intelligence, 5 for Wisdom, or 6 for Charisma.";
				send_spell_choice_prompt(c, sc);
			}
			else if (spell.id == "hunters_mark" and @target != null) {
				c.hunters_mark_target_id = target.id;
				broadcast_announce(c.name + " marks " + target.name + " with Hunter's Mark.", true);
			}
			else if (spell.id == "mage_armor") {
				if (@target == null) @target = c;
				if (target.mage_armor_bonus > 0) target.armor_class -= target.mage_armor_bonus;
				int desired_ac = 13 + target.get_ability_mod(ABILITY_DEX);
				target.mage_armor_bonus = 0;
				if (desired_ac > target.armor_class) {
					target.mage_armor_bonus = desired_ac - target.armor_class;
					target.armor_class = desired_ac;
				}
				broadcast_announce(target.name + " is protected by Mage Armor.", true);
			}
			else if (spell.id == "web") {
				// AoE DEX save or restrained
				combatant@[] targets_hit;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (@target != null and feet_distance(target.x, target.y, t.x, t.y) <= 20) targets_hit.insert_last(t);
					else if (@target == null and feet_distance(c.x, c.y, t.x, t.y) <= 20) targets_hit.insert_last(t);
				}
				if (targets_hit.length() == 0 and @target != null) targets_hit.insert_last(target);
				for (uint ti = 0; ti < targets_hit.length(); ti++) {
					combatant@ t = targets_hit[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(t.name, "DEX save vs Web", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Restrained!");
					if (!saved) {
						t.add_condition(COND_RESTRAINED);
						t.restrained_spell_caster_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Restrained"}});
					}
				}
			}
			else if (spell.id == "blindness_deafness" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (CON save — no Countercharm, no Mage Slayer)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "CON save vs Blindness/Deafness"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "CON save vs Blindness/Deafness"); if (fg >= save_dc) saved = true; }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "CON save vs Blindness/Deafness"); if (mv >= save_dc) saved = true; }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
				broadcast_roll(target.name, "CON save vs Blindness/Deafness", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Blinded!");
				if (!saved) {
					target.add_condition(COND_BLINDED);
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Blinded"}});
				}
			}
			else if (spell.id == "animate_dead") {
				// Spawn a skeleton combatant on the caster's side
				monster_def@ skel_def = get_monster_def("skeleton");
				if (@skel_def != null) {
					combatant@ minion = create_monster_combatant(skel_def, c.x + 5, c.y);
					if (@minion != null) {
						minion.name = c.name + "'s Skeleton";
						minion.is_player = false;
						minion.summoner_id = c.id;
						combat.combatants.insert_last(minion);
						broadcast_announce(c.name + " raises a Skeleton to fight!", true);
					}
				}
			}
			else if (spell.id == "fear") {
				// AoE WIS save or frightened
				combatant@[] targets_hit;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(c.x, c.y, t.x, t.y) <= 30) targets_hit.insert_last(t);
				}
				for (uint ti = 0; ti < targets_hit.length(); ti++) {
					combatant@ t = targets_hit[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					if (t.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(t.name, "WIS save vs Fear", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Frightened!");
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved and try_countercharm_reroll(t, save_dc, save_bonus + bless_bonus, "WIS save vs Fear")) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Fear"); if (ds >= save_dc) saved = true; }
					if (!saved) { int new_total = try_flash_of_genius(t, save_dc, save_total, "WIS save vs Fear"); if (new_total >= save_dc) saved = true; }
				if (!saved) { int ms_total = try_maverick_spirit(t, save_dc, save_total, "WIS save vs Fear"); if (ms_total >= save_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf > 0) saved = true; }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					if (!saved) {
						t.add_condition(COND_FRIGHTENED);
						t.frightened_source_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Frightened"}});
					}
				}
			}
			else if (spell.id == "hypnotic_pattern") {
				// AoE WIS save or charmed + incapacitated
				combatant@[] targets_hit;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (@target != null and feet_distance(target.x, target.y, t.x, t.y) <= 30) targets_hit.insert_last(t);
					else if (@target == null and feet_distance(c.x, c.y, t.x, t.y) <= 30) targets_hit.insert_last(t);
				}
				if (targets_hit.length() == 0 and @target != null) targets_hit.insert_last(target);
				for (uint ti = 0; ti < targets_hit.length(); ti++) {
					combatant@ t = targets_hit[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					if (t.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(t.name, "WIS save vs Hypnotic Pattern", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved and try_countercharm_reroll(t, save_dc, save_bonus + bless_bonus, "WIS save vs Hypnotic Pattern")) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Hypnotic Pattern"); if (ds >= save_dc) saved = true; }
					if (!saved) { int new_total = try_flash_of_genius(t, save_dc, save_total, "WIS save vs Hypnotic Pattern"); if (new_total >= save_dc) saved = true; }
				if (!saved) { int ms_total = try_maverick_spirit(t, save_dc, save_total, "WIS save vs Hypnotic Pattern"); if (ms_total >= save_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf > 0) saved = true; }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					if (!saved) {
						t.add_condition(COND_CHARMED);
						t.add_condition(COND_INCAPACITATED);
						t.charm_spell_caster_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Charmed"}});
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Incapacitated"}});
					}
				}
			}
			else if (spell.id == "polymorph" and @target != null) {
				// WIS save for unwilling targets; on fail reduce AC by 5 and set HP to 30
				bool is_enemy = target.is_player != c.is_player or combat.mode == "pvp";
				bool saved = false;
				if (is_enemy) {
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(target, c.id, save_roll);
					int save_bonus = target.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(target);
					int save_total = save_roll + save_bonus + bless_bonus;
					saved = save_total >= save_dc;
					// Save failure chain (WIS — Mage Slayer applies; skip Countercharm: COND_CHARMED is implementation marker)
					if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Polymorph"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Polymorph"); if (fg >= save_dc) saved = true; }
					if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Polymorph"); if (mv >= save_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) saved = true; }
					if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
					if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(target.name, "WIS save vs Polymorph", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Polymorphed!");
				}
				if (!saved) {
					target.polymorph_original_hp = target.current_hp;
					target.polymorph_original_ac = target.armor_class;
					target.polymorph_caster_id = c.id;
					target.armor_class -= 5;
					if (target.armor_class < 5) target.armor_class = 5;
					target.current_hp = 30;
					target.add_condition(COND_CHARMED);
					broadcast_announce(target.name + " is polymorphed into a beast!", true);
				}
			}
			else if (spell.id == "wall_of_force") {
				broadcast_announce(c.name + " conjures an invisible Wall of Force! Nothing can physically pass through it.", true);
			}
			else if (spell.id == "hold_person" and @target != null) {
				// Primary target
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
				broadcast_roll(target.name, "WIS save vs Hold Person", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Paralyzed!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Hold Person")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Hold Person"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Hold Person"); if (fg >= save_dc) saved = true; }
				if (!saved) { int ms = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Hold Person"); if (ms >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_PARALYZED);
					target.hold_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Paralyzed"}});
				}
				// Twinned Spell: Hold Person on second target
				if (was_twinned and @twinned_target != null and !twinned_target.is_dead and twinned_target.id != target.id) {
					int t2_roll = random(1, 20);
					int t2_bonus = twinned_target.get_save_bonus(ABILITY_WIS);
					int t2_bless = roll_bless_bonus(twinned_target);
					int t2_total = t2_roll + t2_bonus + t2_bless;
					bool t2_saved = t2_total >= save_dc;
					if (t2_bless > 0) broadcast_announce(twinned_target.name + "'s Bless adds " + t2_bless + " to the save.", false);
					broadcast_roll(twinned_target.name, "WIS save vs Hold Person (Twinned)", t2_roll, t2_bonus + t2_bless, t2_total, t2_saved ? "Saved!" : "Paralyzed!");
					if (!t2_saved and try_arcane_deflection_save(twinned_target, save_dc, t2_total)) t2_saved = true;
					if (!t2_saved and try_countercharm_reroll(twinned_target, save_dc, t2_bonus + t2_bless, "WIS save vs Hold Person")) t2_saved = true;
					if (!t2_saved) { int ds2 = try_disciplined_survivor_reroll(twinned_target, save_dc, t2_total, t2_bonus + t2_bless, "WIS save vs Hold Person"); if (ds2 >= save_dc) t2_saved = true; }
					if (!t2_saved) { int fg2 = try_flash_of_genius(twinned_target, save_dc, t2_total, "WIS save vs Hold Person"); if (fg2 >= save_dc) t2_saved = true; }
					if (!t2_saved) { int ms2 = try_maverick_spirit(twinned_target, save_dc, t2_total, "WIS save vs Hold Person"); if (ms2 >= save_dc) t2_saved = true; }
					if (!t2_saved and try_mage_slayer_guarded_mind(twinned_target, ABILITY_WIS)) t2_saved = true;
					if (!t2_saved) { int bf2 = try_boon_of_fate_bonus(twinned_target, t2_total, save_dc); if (bf2 > 0) t2_saved = true; }
					if (!t2_saved and try_stroke_of_luck_save(twinned_target, save_dc, t2_bonus + t2_bless)) t2_saved = true;
					if (!t2_saved) {
						twinned_target.add_condition(COND_PARALYZED);
						twinned_target.hold_spell_caster_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", twinned_target.name}, {"condition", "Paralyzed"}});
					}
				}
			}
			else if (spell.id == "hold_monster" and @target != null) {
				// Basic Rules para 13781: "Choose a creature that you can see within range.
				// The target must succeed on a Wisdom saving throw or have the Paralyzed
				// condition for the duration. At the end of each of its turns, the target
				// repeats the save, ending the spell on itself on a success."
				// Upcast adds extra targets - one additional creature per slot above 5.
				combatant@[] hm_targets;
				hm_targets.insert_last(target);
				int extra_targets = upcast_levels;
				for (uint hi = 0; hi < combat.combatants.length() and int(hm_targets.length()) < 1 + extra_targets; hi++) {
					combatant@ extra = combat.combatants[hi];
					if (@extra == null or extra.id == c.id or extra.id == target.id or extra.is_dead) continue;
					if (!combat.are_hostile(c, extra)) continue;
					if (feet_distance(c.x, c.y, extra.x, extra.y) > 90) continue;
					if (!combat.can_see(c, extra)) continue;
					hm_targets.insert_last(extra);
				}
				for (uint hi = 0; hi < hm_targets.length(); hi++) {
					combatant@ hm_t = hm_targets[hi];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(hm_t, c.id, save_roll);
					int save_bonus = hm_t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(hm_t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (bless_bonus > 0) broadcast_announce(hm_t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(hm_t.name, "WIS save vs Hold Monster", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Paralyzed!");
					if (!saved) {
						hm_t.add_condition(COND_PARALYZED);
						hm_t.hold_spell_caster_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", hm_t.name}, {"condition", "Paralyzed"}});
					}
				}
			}
			else if (spell.id == "cloudkill") {
				// Basic Rules para 12408-12410: "You create a 20-foot-radius Sphere of
				// yellow-green fog... Each creature in the Sphere makes a Constitution
				// saving throw, taking 5d8 Poison damage on a failed save or half as much
				// damage on a successful one." Upcast adds 1d8/level above 5.
				int dice_count = 5 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				combatant@[] ck_targets;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) <= 20) ck_targets.insert_last(t);
				}
				broadcast_announce(c.name + " conjures a 20-foot Cloudkill of poisonous fog!", true);
				for (uint ti = 0; ti < ck_targets.length(); ti++) {
					combatant@ t = ck_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Cloudkill"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Cloudkill"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Cloudkill", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_POISON, c);
					broadcast_announce(t.name + " takes " + dmg + " poison damage from the Cloudkill.", false);
				}
				// Track AoE center for per-turn damage in advance_turn
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "wall_of_fire") {
				// Basic Rules para 15545-15547: "You create a wall of fire on a solid surface
				// within range... When the wall appears, each creature in its area makes a
				// Dexterity saving throw, taking 5d8 Fire damage on a failed save or half as
				// much damage on a successful one. One side of the wall... deals 5d8 Fire
				// damage to each creature that ends its turn within 10 feet of that side or
				// inside the wall." Upcast adds 1d8/level above 4.
				// Wall positioning is approximated as a 60ft line centered on the target.
				int dice_count = 5 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				combatant@[] wf_targets;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) <= 30) wf_targets.insert_last(t);
				}
				broadcast_announce(c.name + " conjures a Wall of Fire 60 feet long!", true);
				for (uint ti = 0; ti < wf_targets.length(); ti++) {
					combatant@ t = wf_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Wall of Fire", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_FIRE, c);
					broadcast_announce(t.name + " takes " + dmg + " fire damage from the Wall of Fire.", false);
				}
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "stinking_cloud") {
				// Basic Rules para 15152-15153: "You create a 20-foot-radius Sphere of
				// yellow, nauseating gas... Each creature that starts its turn in the Sphere
				// must succeed on a Constitution saving throw or have the Poisoned condition
				// until the end of the current turn. While Poisoned in this way, the
				// creature can't take an action or a Bonus Action."
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				combatant@[] sc_targets;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) <= 20) sc_targets.insert_last(t);
				}
				// Track AoE center for per-turn Poisoned in advance_turn
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_announce(c.name + " conjures a 20-foot Stinking Cloud of nauseating gas!", true);
				for (uint ti = 0; ti < sc_targets.length(); ti++) {
					combatant@ t = sc_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (CON condition — no Mage Slayer)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "CON save vs Stinking Cloud"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Stinking Cloud"); if (fg >= save_dc) saved = true; }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Stinking Cloud"); if (mv >= save_dc) saved = true; }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) saved = true; }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "CON save vs Stinking Cloud", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Poisoned!");
					if (!saved) {
						t.add_condition(COND_POISONED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Poisoned"}});
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "holy_weapon") {
				// Xanathar's para 4936: "You imbue a weapon you touch with holy power...
				// weapon attacks made with it deal an extra 2d8 radiant damage on a hit."
				// Bonus action cast on self.
				c.holy_weapon_active = true;
				broadcast_announce(c.name + " imbues their weapon with Holy Weapon. +2d8 radiant damage on weapon hits until concentration ends.", true);
			}
			else if (spell.id == "sickening_radiance") {
				// Xanathar's paras 5226-5227: "Dim, greenish light spreads within a 30-foot-
				// radius sphere centered on a point you choose within range... When a
				// creature moves into the spell's area for the first time on a turn or
				// starts its turn there, that creature must succeed on a Constitution
				// saving throw or take 4d10 radiant damage, suffer one level of exhaustion."
				int dice_count = 4;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				broadcast_announce(c.name + " conjures a 30-foot Sickening Radiance!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 30) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (CON — exhaustion condition, no Mage Slayer)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "CON save vs Sickening Radiance"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Sickening Radiance"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Sickening Radiance"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "CON save vs Sickening Radiance", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Damage + exhaustion!");
					if (!saved) {
						combat.apply_damage(t, total_damage, DMG_RADIANT, c);
						t.exhaustion_level += 1;
						broadcast_announce(t.name + " takes " + total_damage + " radiant damage and gains 1 level of exhaustion (level " + t.exhaustion_level + ").", false);
						// PHB 2024 Exhaustion (para 16254): "You die if your Exhaustion level is 6."
						if (t.exhaustion_level >= 6 and !t.is_dead) {
							t.is_dead = true;
							t.current_hp = 0;
							broadcast_announce(t.name + " dies from exhaustion!", true);
							broadcast_to_battle({{"type", message_types::creature_died}, {"name", t.name}, {"id", t.id}});
						}
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "storm_sphere") {
				// Xanathar's para 5288: "A 20-foot-radius sphere of whirling air springs
				// into existence, centered on a point you choose within range... Each
				// creature in the sphere when it appears or that ends its turn there must
				// succeed on a Strength saving throw or take 2d6 bludgeoning damage."
				int dice_count = 2 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " summons a 20-foot Storm Sphere of whirling air!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_STR);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = t.apply_indomitable_might(save_roll + save_bonus + bless_bonus, ABILITY_STR);
					bool saved = save_total >= save_dc;
					// Save failure chain (STR — bludgeoning damage)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "STR save vs Storm Sphere"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "STR save vs Storm Sphere"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "STR save vs Storm Sphere", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Damaged!");
					if (!saved) {
						combat.apply_damage(t, total_damage, DMG_BLUDGEONING, c);
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "investiture_of_flame") {
				// Xanathar's paras 4992-4993: "You are immune to fire damage and have
				// resistance to cold damage. Any creature that moves within 5 feet of you
				// for the first time on a turn or ends its turn there takes 1d10 fire damage."
				c.fire_resistance = true; // Game doesn't have immunity tier - approximated as resistance
				c.cold_resistance = true;
				c.investiture_flame_active = true;
				c.is_concentrating = true;
				c.add_condition(COND_CONCENTRATING);
				c.concentration_spell = spell.name;
				broadcast_announce(c.name + " is wreathed in flame from Investiture of Flame! Fire immunity and cold resistance. Adjacent creatures take 1d10 fire damage.", true);
			}
			else if (spell.id == "investiture_of_ice") {
				// Xanathar's Investiture of Ice: "You are immune to cold damage and have
				// resistance to fire damage. The ground in a 10-foot radius around you is
				// icy and is difficult terrain for creatures other than you."
				// Concentration. Action ability (15ft cone 4d6 cold) deferred.
				c.cold_resistance = true; // Approximating immunity as resistance
				c.fire_resistance = true;
				c.investiture_ice_active = true;
				c.is_concentrating = true;
				c.add_condition(COND_CONCENTRATING);
				c.concentration_spell = spell.name;
				broadcast_announce(c.name + " is wreathed in ice from Investiture of Ice! Cold immunity, fire resistance. 10ft icy difficult terrain around caster.", true);
			}
			else if (spell.id == "investiture_of_stone") {
				// Xanathar's Investiture of Stone: "You have resistance to bludgeoning,
				// piercing, and slashing damage from nonmagical attacks."
				// Concentration. Action ability (15ft earthquake, DEX save or Prone) deferred.
				c.resist_bps_nonmagical = true;
				c.investiture_stone_active = true;
				c.is_concentrating = true;
				c.add_condition(COND_CONCENTRATING);
				c.concentration_spell = spell.name;
				broadcast_announce(c.name + " is armored in stone from Investiture of Stone! Resistance to nonmagical B/P/S damage.", true);
			}
			else if (spell.id == "investiture_of_wind") {
				// Xanathar's Investiture of Wind: "Ranged weapon attacks made against you
				// have disadvantage on the attack roll. You gain a flying speed of 60 feet."
				// Concentration. Action ability (15ft cube 2d10 bludgeoning + push) deferred.
				c.investiture_wind_active = true;
				c.speed += 30; // Approximate fly speed boost (base + 30 extra)
				c.movement_remaining += 30;
				c.is_concentrating = true;
				c.add_condition(COND_CONCENTRATING);
				c.concentration_spell = spell.name;
				broadcast_announce(c.name + " is surrounded by howling wind from Investiture of Wind! Ranged attacks have disadvantage, speed increased by 30ft.", true);
			}
			else if (spell.id == "cause_fear" and @target != null) {
				// Xanathar's para 4655: "The target must succeed on a Wisdom saving throw
				// or become frightened of you until the spell ends. A construct or an
				// undead is immune to this effect."
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				if (target.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				broadcast_roll(target.name, "WIS save vs Cause Fear", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Frightened!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Cause Fear")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Cause Fear"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Cause Fear"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Cause Fear"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_FRIGHTENED);
					target.frightened_source_id = c.id;
					broadcast_announce(target.name + " awakens to their own mortality and is Frightened of " + c.name + "!", true);
				}
			}
			else if (spell.id == "forcecage" and @target != null) {
				// Basic Rules paras 13410-13411: "An immobile, Invisible, Cube-shaped prison
				// composed of magical force springs into existence around an area you choose
				// within range. The prison can be a cage or a solid box, as you choose."
				// Approximation: applies COND_RESTRAINED to the target.
				target.add_condition(COND_RESTRAINED);
				broadcast_announce(c.name + " conjures a Forcecage around " + target.name + "! They are imprisoned by walls of magical force.", true);
			}
			else if (spell.id == "raise_dead" and @target != null) {
				// Basic Rules para 14695: "With a touch, you revive a dead creature if it
				// has been dead no longer than 10 days... The creature returns to life
				// with 1 Hit Point."
				if (target.is_dead) {
					target.is_dead = false;
					target.current_hp = 1;
					target.death_save_successes = 0;
					target.death_save_failures = 0;
					target.is_stable = false;
					target.remove_condition(COND_UNCONSCIOUS);
					broadcast_announce(c.name + " casts Raise Dead — " + target.name + " returns to life with 1 hit point!", true);
				} else {
					broadcast_announce(c.name + " casts Raise Dead, but " + target.name + " isn't dead.", false);
				}
			}
			else if (spell.id == "resurrection" and @target != null) {
				// Basic Rules para 14797: "The creature returns to life with all its Hit
				// Points. This spell also neutralizes any poisons that affected the creature
				// at the time of death. This spell closes all mortal wounds and restores
				// any missing body parts."
				if (target.is_dead) {
					target.is_dead = false;
					target.current_hp = target.max_hp;
					target.death_save_successes = 0;
					target.death_save_failures = 0;
					target.is_stable = false;
					target.remove_condition(COND_UNCONSCIOUS);
					target.remove_condition(COND_POISONED);
					broadcast_announce(c.name + " casts Resurrection — " + target.name + " is fully restored to life with " + target.max_hp + " HP!", true);
				} else {
					broadcast_announce(c.name + " casts Resurrection, but " + target.name + " isn't dead.", false);
				}
			}
			else if (spell.id == "true_resurrection" and @target != null) {
				// Basic Rules para 15469: "You touch a creature that has been dead for no
				// longer than 200 years and that died for any reason except old age. The
				// creature is revived with all its Hit Points."
				if (target.is_dead) {
					target.is_dead = false;
					target.current_hp = target.max_hp;
					target.death_save_successes = 0;
					target.death_save_failures = 0;
					target.is_stable = false;
					target.remove_condition(COND_UNCONSCIOUS);
					target.remove_condition(COND_POISONED);
					target.remove_condition(COND_BLINDED);
					target.remove_condition(COND_DEAFENED);
					broadcast_announce(c.name + " casts True Resurrection — " + target.name + " is perfectly restored, free of all afflictions!", true);
				} else {
					broadcast_announce(c.name + " casts True Resurrection, but " + target.name + " isn't dead.", false);
				}
			}
			else if (spell.id == "reincarnate" and @target != null) {
				// Basic Rules para 14749: "You touch a dead Humanoid or a piece of one. If
				// the creature has been dead no longer than 10 days, the spell forms a new
				// body for it and calls the soul to enter that body."
				if (target.is_dead) {
					target.is_dead = false;
					target.current_hp = target.max_hp / 2;
					target.death_save_successes = 0;
					target.death_save_failures = 0;
					target.is_stable = false;
					target.remove_condition(COND_UNCONSCIOUS);
					broadcast_announce(c.name + " casts Reincarnate — " + target.name + " is reborn in a new body with " + target.current_hp + " HP!", true);
				}
			}
			else if (spell.id == "mordenkainens_sword") {
				// Basic Rules paras 14361-14362: "You create a spectral sword that hovers
				// within range. It lasts for the duration. When the sword appears, you
				// make a melee spell attack against a target within 5 feet of the sword.
				// On a hit, the target takes Force damage equal to 4d12 plus your
				// spellcasting ability modifier."
				if (@target == null or target.is_dead) {
					u.send({{"type", message_types::announce}, {"text", "No valid target."}, {"interrupt", true}});
					return;
				}
				int mod = get_spellcasting_ability_mod(c);
				int total_damage = mod;
				for (int d = 0; d < 4; d++) total_damage += random(1, 12);
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Mordenkainen's Sword attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					combat.apply_damage(target, total_damage, DMG_FORCE, c);
					broadcast_announce(c.name + "'s spectral sword strikes " + target.name + " for " + total_damage + " force damage!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "conjure_animals") {
				// Basic Rules paras 12512-12513: "You conjure nature spirits that appear
				// as a Large pack of spectral, intangible animals in an unoccupied space
				// you can see within range... You have Advantage on Strength saving throws
				// while you're within 5 feet of the pack, and when you move on your turn,
				// you can also move the pack up to 30 feet to an unoccupied space."
				// Spawn the pack as a companion entity acting on caster's turn.
				int pack_hp = 5 * c.level;
				int wis_mod_ca = c.get_ability_mod(ABILITY_WIS);
				int pack_attack = c.proficiency + wis_mod_ca;
				combatant@ pack = spawn_companion(c, "conjure_animals_pack", c.name + "'s Animal Pack", pack_hp, 13 + c.proficiency, 40, pack_attack, 2, 6, c.proficiency, DMG_PIERCING, 0);
				if (@pack != null) {
					broadcast_announce(c.name + " conjures a pack of spectral animals! HP " + pack_hp + ", AC " + (13 + c.proficiency) + ", 2d6+PB piercing.", true);
				}
			}
			else if (spell.id == "detect_thoughts" or spell.id == "locate_object" or spell.id == "locate_creature") {
				// Divination spells, no combat effect. Announce-only.
				broadcast_announce(c.name + " casts " + spell.name + ".", false);
			}
			else if (spell.id == "ray_of_sickness" and @target != null) {
				// Basic Rules para 14732: "You shoot a greenish ray at a creature within
				// range. Make a ranged spell attack against the target. On a hit, the
				// target takes 2d8 Poison damage and has the Poisoned condition until the
				// end of your next turn."
				int dice_count = 2 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Ray of Sickness attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					combat.apply_damage(target, total_damage, DMG_POISON, c);
					target.add_condition(COND_POISONED);
					broadcast_announce(c.name + "'s Ray of Sickness deals " + total_damage + " poison damage to " + target.name + " and poisons them!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "gaseous_form" and @target != null) {
				// Basic Rules paras 13440-13441: "A willing creature you touch shape-shifts,
				// along with everything it's wearing and carrying, into a misty cloud for
				// the duration... While in this form, the target's only method of movement
				// is a Fly Speed of 10 feet, and it can hover... The target has Resistance
				// to Bludgeoning, Piercing, and Slashing damage from nonmagical attacks."
				target.bludgeoning_resistance = true;
				target.piercing_resistance = true;
				target.slashing_resistance = true;
				target.flying_speed = 10;
				broadcast_announce(c.name + " transforms " + target.name + " into Gaseous Form! 10 ft fly speed and resistance to nonmagical B/P/S damage.", true);
			}
			else if (spell.id == "gust_of_wind") {
				// Basic Rules para 13659: "A Line of strong wind 60 feet long and 10 feet
				// wide blasts from you in a direction you choose for the duration. Each
				// creature in the Line must succeed on a Strength saving throw or be
				// pushed 15 feet away from you in a direction following the line."
				broadcast_announce(c.name + " conjures a Gust of Wind — a 60-foot line of strong wind!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 60) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_STR);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = t.apply_indomitable_might(save_roll + save_bonus + bless_bonus, ABILITY_STR);
					bool saved = save_total >= save_dc;
					// Save failure chain (STR — push effect)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "STR save vs Gust of Wind"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "STR save vs Gust of Wind"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "STR save vs Gust of Wind", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Pushed!");
					if (!saved) {
						// Push 15 ft (3 tiles) directly away from caster
						int dx = 0;
						int dy = 0;
						if (t.x > c.x) dx = 3;
						else if (t.x < c.x) dx = -3;
						if (t.y > c.y) dy = 3;
						else if (t.y < c.y) dy = -3;
						int new_x = t.x + dx;
						int new_y = t.y + dy;
						if (new_x >= 0 and new_x < combat.map_width and new_y >= 0 and new_y < combat.map_height) {
							t.x = new_x;
							t.y = new_y;
						}
					}
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "dragons_breath" and @target != null) {
				// Basic Rules para 12991: "You touch one willing creature, and choose Acid,
				// Cold, Fire, Lightning, or Poison. Until the spell ends, the target can
				// take a Magic action to exhale a 15-foot Cone. Each creature in that area
				// makes a Dexterity saving throw, taking 3d6 damage on a failed save or
				// half as much damage on a successful one."
				// Approximation: applies the breath weapon immediately as a one-shot AoE
				// since the game doesn't currently track multi-turn cast-on-ally toggles.
				int dice_count = 3 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(target.name + " is empowered with Dragon's Breath — exhales a 15-foot cone of fire!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == target.id or t.id == c.id) continue;
					if (feet_distance(target.x, target.y, t.x, t.y) > 15) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Dragon's Breath", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_FIRE, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "searing_smite") {
				// Basic Rules para 14887: "As you hit the target, it takes an extra 1d6
				// Fire damage from the attack. At the start of each of its turns until
				// the spell ends, the target takes 1d6 Fire damage and then makes a
				// Constitution saving throw."
				// Marked as a pending smite rider; the next melee hit applies the damage.
				c.searing_smite_pending = true;
				c.searing_smite_dice = 1 + upcast_levels;
				broadcast_announce(c.name + " casts Searing Smite — their next weapon hit deals +" + c.searing_smite_dice + "d6 fire damage.", true);
			}
			else if (spell.id == "hellish_rebuke" and @target != null) {
				// Basic Rules para 13744: "The creature that damaged you is momentarily
				// surrounded by green flames. It makes a Dexterity saving throw, taking
				// 2d10 Fire damage on a failed save or half as much damage on a successful one."
				int dice_count = 2 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_DEX);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				broadcast_roll(target.name, "DEX save vs Hellish Rebuke", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
				combat.apply_damage(target, dmg, DMG_FIRE, c);
				broadcast_announce(c.name + "'s Hellish Rebuke surrounds " + target.name + " with green flames for " + dmg + " fire damage!", true);
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "detect_magic" or spell.id == "detect_evil_and_good") {
				// Basic Rules paras 12815, 12824: divination utility spells with no
				// combat effect. Announce-only.
				broadcast_announce(c.name + " casts " + spell.name + " and senses their surroundings.", false);
			}
			else if (spell.id == "counterspell") {
				// Basic Rules para 12677: "You attempt to interrupt a creature in the
				// process of casting a spell. The creature makes a Constitution saving
				// throw. On a failed save, the spell dissipates with no effect, and the
				// action, Bonus Action, or Reaction used to cast it is wasted."
				// Cast as a reaction; combat does not currently track in-progress spells,
				// so this is a noted-but-no-effect spell that can be queued for the next
				// enemy spell. Marked with a flag for future intercept logic.
				c.counterspell_pending = true;
				broadcast_announce(c.name + " readies Counterspell. The next enemy spell within 60 feet may be interrupted.", true);
			}
			else if (spell.id == "dispel_magic" and @target != null) {
				// Basic Rules 2024 Dispel Magic (para 12905-12906):
				// "Choose one creature, object, or magical effect within range.
				// Any ongoing spell of level 3 or lower on the target ends.
				// For each ongoing spell of level 4 or higher on the target,
				// make an ability check using your spellcasting ability
				// (DC 10 plus that spell's level). On a successful check, the spell ends.
				// Using a Higher-Level Spell Slot. You automatically end a spell on the
				// target if the spell's level is equal to or less than the level of the
				// spell slot you use."
				int max_auto = cast_slot_level; // auto-dispel threshold
				int dm_spell_mod = spell_attack_bonus(c) - c.proficiency; // spellcasting ability mod
				int dispelled = 0;

				// L1 spells: Bless, Heroism, Bane, Shield — always auto-dispelled (L1 <= L3 base)
				if (target.blessed) { clear_bless_effect(target, true); dispelled++; }
				if (target.heroism_source_id != 0) { clear_heroism_effect(target, true); dispelled++; }
				if (target.baned) { target.baned = false; dispelled++; }
				if (target.shield_active) { clear_shield_effect(target, true); dispelled++; }

				// L3 spells: Haste, Fly — always auto-dispelled at base Dispel Magic L3
				if (target.hasted) { clear_haste_effect(target, false, true); dispelled++; }
				if (target.fly_active) { target.fly_active = false; target.flying_speed = 0; dispelled++; }

				// L4 spells: Stoneskin, Resilient Sphere — need ability check at base L3
				if (target.stoneskin_active) {
					bool dispel_ok = (max_auto >= 4);
					if (!dispel_ok) {
						int dr = random(1, 20); int dt = dr + dm_spell_mod; int ddc = 14;
						dispel_ok = dt >= ddc;
						broadcast_roll(c.name, "dispel check vs Stoneskin (L4)", dr, dm_spell_mod, dt, dispel_ok ? "Dispelled!" : "Failed to dispel.");
					}
					if (dispel_ok) { target.stoneskin_active = false; dispelled++; }
				}
				if (target.resilient_sphere_trapped) {
					bool dispel_ok = (max_auto >= 4);
					if (!dispel_ok) {
						int dr = random(1, 20); int dt = dr + dm_spell_mod; int ddc = 14;
						dispel_ok = dt >= ddc;
						broadcast_roll(c.name, "dispel check vs Resilient Sphere (L4)", dr, dm_spell_mod, dt, dispel_ok ? "Dispelled!" : "Failed to dispel.");
					}
					if (dispel_ok) {
						target.resilient_sphere_trapped = false;
						target.resilient_sphere_source_id = 0;
						target.resilient_sphere_rounds = 0;
						target.remove_condition(COND_INCAPACITATED);
						broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", "Incapacitated"}});
						broadcast_announce(c.name + "'s Dispel Magic shatters " + target.name + "'s Resilient Sphere!", true);
						dispelled++;
					}
				}

				// Concentration spell on the target — look up base level from spell catalog
				if (target.is_concentrating and target.concentration_spell != "") {
					int conc_level = 0;
					for (uint dsi = 0; dsi < SPELL_DEFS.length(); dsi++) {
						if (SPELL_DEFS[dsi].name == target.concentration_spell) {
							conc_level = SPELL_DEFS[dsi].level;
							break;
						}
					}
					if (conc_level < 1) conc_level = 3; // fallback if not found
					bool dispel_ok = (max_auto >= conc_level);
					if (!dispel_ok) {
						int dr = random(1, 20); int dt = dr + dm_spell_mod; int ddc = 10 + conc_level;
						dispel_ok = dt >= ddc;
						broadcast_roll(c.name, "dispel check vs " + target.concentration_spell + " (L" + conc_level + ")", dr, dm_spell_mod, dt, dispel_ok ? "Dispelled!" : "Failed to dispel.");
					}
					if (dispel_ok) {
						string ended = target.concentration_spell;
						clear_concentration_effects(target);
						target.is_concentrating = false;
						target.remove_condition(COND_CONCENTRATING);
						target.concentration_spell = "";
						broadcast_announce(c.name + "'s Dispel Magic ends " + target.name + "'s concentration on " + ended + "!", true);
						dispelled++;
					}
				}

				if (dispelled > 0) {
					broadcast_announce(c.name + "'s Dispel Magic strips " + dispelled + " magical effect" + (dispelled == 1 ? "" : "s") + " from " + target.name + "!", true);
					// Xanathar's War Magic L6 Power Surge (para 2939): "You gain one power surge
					// whenever you successfully end a spell with dispel magic or counterspell."
					if (c.class_name == "Wizard" and c.subclass == "War Magic" and c.level >= 6 and c.power_surge_charges < c.power_surge_max) {
						c.power_surge_charges++;
						broadcast_announce(c.name + " stores a Power Surge! (" + c.power_surge_charges + "/" + c.power_surge_max + ")", false);
					}
				} else {
					broadcast_announce(c.name + "'s Dispel Magic finds no magic to dispel on " + target.name + ".", false);
				}
			}
			else if (spell.id == "tongues" and @target != null) {
				// Basic Rules para 15428: "This spell grants the creature you touch the
				// ability to understand any spoken or signed language that it hears or sees."
				// Mostly out-of-combat utility; flagged for future use.
				broadcast_announce(c.name + " grants " + target.name + " the gift of Tongues for 1 hour.", true);
			}
			else if (spell.id == "vicious_mockery" and @target != null) {
				// Basic Rules para 15527: "You unleash a string of insults laced with
				// subtle enchantments at one creature you can see or hear within range.
				// The target must succeed on a Wisdom saving throw or take 1d6 Psychic
				// damage and have Disadvantage on the next attack roll it makes before
				// the end of its next turn."
				// Cantrip scaling: 1d6/2d6/3d6/4d6 at 1/5/11/17.
				int dice_count = 1;
				if (c.level >= 17) dice_count = 4;
				else if (c.level >= 11) dice_count = 3;
				else if (c.level >= 5) dice_count = 2;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (WIS — damage + baned)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Vicious Mockery"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Vicious Mockery"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "WIS save vs Vicious Mockery", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Mocked!");
				if (!saved) {
					combat.apply_damage(target, total_damage, DMG_PSYCHIC, c);
					// Basic Rules 2024 Vicious Mockery: "Disadvantage on the next attack roll"
					target.vicious_mockery_disadv = true;
					broadcast_announce(c.name + "'s Vicious Mockery cuts " + target.name + " for " + total_damage + " psychic damage and shakes their composure!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "mirror_image") {
				// Basic Rules paras 14259-14260: "Three illusory duplicates of yourself
				// appear in your space. Until the spell ends, the duplicates move with you
				// and mimic your actions... Each time a creature hits you with an attack
				// roll during the spell's duration, roll a d6 for each of your remaining
				// duplicates. If any of the d6s rolls a 3 or higher, one of the duplicates
				// is hit instead of you."
				c.mirror_images = 3;
				broadcast_announce(c.name + " casts Mirror Image — three illusory duplicates appear and shift around them!", true);
			}
			else if (spell.id == "blink") {
				// Basic Rules paras 12284-12285: "Roll 1d6 at the end of each of your turns
				// for the duration. On a roll of 4-6, you vanish from your current plane of
				// existence and appear in the Ethereal Plane."
				// Approximation: 50% chance of being untouchable each round.
				c.blink_active = true;
				broadcast_announce(c.name + " casts Blink — they may vanish into the Ethereal Plane between turns.", true);
			}
			else if (spell.id == "dimension_door" and @target != null) {
				// Basic Rules para 12854: "You teleport to a location within range. You
				// arrive at exactly the spot desired."
				int dist = feet_distance(c.x, c.y, target.x, target.y);
				if (dist > 500) {
					u.send({{"type", message_types::announce}, {"text", "Target out of Dimension Door range (500 feet)."}, {"interrupt", true}});
					return;
				}
				// Teleport to a tile adjacent to the target
				int new_x = target.x;
				int new_y = target.y - 1;
				if (new_y < 0) new_y = target.y + 1;
				c.x = new_x;
				c.y = new_y;
				broadcast_announce(c.name + " casts Dimension Door, teleporting next to " + target.name + "!", true);
			}
			else if (spell.id == "globe_of_invulnerability") {
				// Basic Rules paras 13549-13550: "An immobile, shimmering barrier appears
				// in a 10-foot Emanation around you and remains for the duration. Any
				// spell of level 5 or lower cast from outside the barrier can't affect
				// anything within it."
				c.globe_of_invulnerability_active = true;
				c.globe_of_invulnerability_level = 5 + upcast_levels;
				broadcast_announce(c.name + " summons a Globe of Invulnerability — spells of level " + c.globe_of_invulnerability_level + " or lower from outside cannot affect anything inside!", true);
			}
			else if (spell.id == "holy_aura") {
				// Basic Rules para 13799: "For the duration, you emit an aura in a 30-foot
				// Emanation. While in the aura, creatures of your choice have Advantage on
				// all saving throws, and other creatures have Disadvantage on attack rolls
				// against them."
				c.holy_aura_active = true;
				broadcast_announce(c.name + " casts Holy Aura — allies within 30 feet have advantage on saves and enemies have disadvantage on attacks against them!", true);
			}
			else if (spell.id == "calm_emotions") {
				// Basic Rules paras 12323-12325: "Each Humanoid in a 20-foot-radius Sphere
				// centered on a point you choose within range must succeed on a Charisma
				// saving throw or be affected by... The creature has Immunity to the
				// Charmed and Frightened conditions until the spell ends."
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int affected = 0;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CHA);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (!saved) {
						t.remove_condition(COND_CHARMED);
						t.remove_condition(COND_FRIGHTENED);
						affected++;
					}
				}
				broadcast_announce(c.name + " casts Calm Emotions, suppressing Charmed and Frightened on " + affected + " creature" + (affected == 1 ? "" : "s") + " in a 20-foot sphere.", true);
			}
			else if (spell.id == "chromatic_orb" and @target != null) {
				// Basic Rules para 12370: "You hurl an orb of energy at a target within
				// range. Choose Acid, Cold, Fire, Lightning, Poison, or Thunder for the
				// type of orb you create, and then make a ranged spell attack against the
				// target. On a hit, the target takes 3d8 damage of the chosen type."
				// Defaults to Fire damage since the source mandates a player choice.
				int dice_count = 3 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Chromatic Orb attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					combat.apply_damage(target, total_damage, DMG_FIRE, c);
					broadcast_announce(c.name + "'s Chromatic Orb deals " + total_damage + " fire damage to " + target.name + "!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "magic_weapon" and @target != null) {
				// Basic Rules para 14108: "You touch a nonmagical weapon. Until the spell
				// ends, that weapon becomes a magic weapon with a +1 bonus to attack rolls
				// and damage rolls."
				// Approximation: target's main hand becomes magical (treats damage as
				// magical) and +1 to attack/damage. Stored as a flat bonus.
				int bonus_amt = 1;
				if (cast_slot_level >= 3 and cast_slot_level <= 5) bonus_amt = 2;
				else if (cast_slot_level >= 6) bonus_amt = 3;
				target.magic_weapon_bonus = bonus_amt;
				broadcast_announce(c.name + " enchants " + target.name + "'s weapon with Magic Weapon. +" + bonus_amt + " to attack and damage rolls.", true);
			}
			else if (spell.id == "divine_favor") {
				// Basic Rules para 12922: "Until the spell ends, your attacks with weapons
				// deal an extra 1d4 Radiant damage on a hit."
				c.divine_favor_active = true;
				broadcast_announce(c.name + " casts Divine Favor — weapon attacks deal +1d4 radiant damage until concentration ends.", true);
			}
			else if (spell.id == "lightning_bolt") {
				// Basic Rules para 13996: "A stroke of lightning forming a 100-foot-long,
				// 5-foot-wide Line blasts out from you in a direction you choose. Each
				// creature in the Line makes a Dexterity saving throw, taking 8d6
				// Lightning damage on a failed save or half as much damage on a
				// successful one."
				int dice_count = 8 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " unleashes a Lightning Bolt — a 100-foot stroke of electricity!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 100) continue;
					if (!combat.can_see(c, t)) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Lightning Bolt", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_LIGHTNING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "thunderwave") {
				// Basic Rules para 15409: "Each creature in a 15-foot Cube originating
				// from you makes a Constitution saving throw. On a failed save, a creature
				// takes 2d8 Thunder damage and is pushed 10 feet away from you."
				int dice_count = 2 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				broadcast_announce(c.name + " unleashes Thunderwave — a thunderous boom in a 15-foot cube!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 15) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Thunderwave", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Pushed!");
					combat.apply_damage(t, dmg, DMG_THUNDER, c);
					if (!saved) {
						// Push 10 ft (2 tiles) directly away from caster
						int dx = 0;
						int dy = 0;
						if (t.x > c.x) dx = 2;
						else if (t.x < c.x) dx = -2;
						if (t.y > c.y) dy = 2;
						else if (t.y < c.y) dy = -2;
						int new_x = t.x + dx;
						int new_y = t.y + dy;
						if (new_x >= 0 and new_x < combat.map_width and new_y >= 0 and new_y < combat.map_height) {
							t.x = new_x;
							t.y = new_y;
						}
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "cure_wounds" and @target != null) {
				// Basic Rules para 12738: "A creature you touch regains a number of Hit
				// Points equal to 2d8 plus your spellcasting ability modifier."
				int dice_count = 2 + (upcast_levels * 2);
				int heal = 0;
				// Basic Rules 2024 Beacon of Hope (para 12201): "regains the maximum
				// number of Hit Points possible from any healing."
				if (target.beacon_of_hope_active) {
					heal = dice_count * 8;
				} else {
					for (int d = 0; d < dice_count; d++) heal += random(1, 8);
					heal = apply_empowered_healing(c, heal, dice_count, 8);
				}
				heal += get_spellcasting_ability_mod(c);
				heal += get_life_domain_healing_bonus(c, spell, cast_slot_level);
				if (heal < 1) heal = 1;
				int effective = combat.apply_healing(target, heal);
				record_effective_healing(c.player_username, effective);
				broadcast_announce(c.name + " heals " + target.name + " for " + heal + " HP with Cure Wounds.", true);
				try_unicorn_totem_heal(c);
				try_chalice_healing(c);
			}
			else if (spell.id == "fireball") {
				// Basic Rules para 13302: "Each creature in a 20-foot-radius Sphere
				// centered on that point makes a Dexterity saving throw, taking 8d6 Fire
				// damage on a failed save or half as much damage on a successful one."
				int dice_count = 8 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " hurls a Fireball into a 20-foot sphere!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Fireball", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_FIRE, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "dissonant_whispers" and @target != null) {
				// Basic Rules para 12895: "One creature of your choice that you can see
				// within range hears a discordant melody in its mind. The target makes a
				// Wisdom saving throw. On a failed save, it takes 3d6 Psychic damage and
				// must immediately use its Reaction, if available, to move as far as its
				// Speed allows away from you."
				int dice_count = 3 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				broadcast_roll(target.name, "WIS save vs Dissonant Whispers", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Half damage + flee!");
				combat.apply_damage(target, dmg, DMG_PSYCHIC, c);
				if (!saved and target.has_reaction) {
					// Move target away from caster up to its speed
					target.has_reaction = false;
					int dx = 0;
					int dy = 0;
					if (target.x > c.x) dx = 1;
					else if (target.x < c.x) dx = -1;
					if (target.y > c.y) dy = 1;
					else if (target.y < c.y) dy = -1;
					int move_distance = target.speed / 5; // tiles
					target.x += dx * move_distance;
					target.y += dy * move_distance;
					if (target.x < 0) target.x = 0;
					if (target.y < 0) target.y = 0;
					if (target.x >= combat.map_width) target.x = combat.map_width - 1;
					if (target.y >= combat.map_height) target.y = combat.map_height - 1;
					broadcast_announce(target.name + " uses their reaction to flee " + target.speed + " feet away from " + c.name + "!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "false_life") {
				// Basic Rules para 13176: "You gain 2d4 + 4 Temporary Hit Points."
				int temp = 4;
				for (int d = 0; d < 2; d++) temp += random(1, 4);
				temp += 5 * upcast_levels;
				if (c.temp_hp < temp) c.temp_hp = temp;
				broadcast_announce(c.name + " casts False Life — gains " + temp + " temporary hit points.", true);
			}
			else if (spell.id == "inflict_wounds" and @target != null) {
				// Basic Rules para 13890: "A creature you touch makes a Constitution
				// saving throw, taking 2d10 Necrotic damage on a failed save or half as
				// much damage on a successful one."
				int dice_count = 2 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				broadcast_roll(target.name, "CON save vs Inflict Wounds", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
				combat.apply_damage(target, dmg, DMG_NECROTIC, c);
				broadcast_announce(c.name + "'s Inflict Wounds deals " + dmg + " necrotic damage to " + target.name + ".", true);
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "burning_hands") {
				// Basic Rules para 12301: "A thin sheet of flames shoots forth from you.
				// Each creature in a 15-foot Cone makes a Dexterity saving throw, taking
				// 3d6 Fire damage on a failed save or half as much damage on a successful one."
				int dice_count = 3 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " unleashes Burning Hands — a 15-foot cone of fire!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 15) continue;
					if (!combat.can_see(c, t)) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Burning Hands", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_FIRE, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "phantasmal_killer" and @target != null) {
				// Basic Rules paras 14448-14449: "The target makes a Wisdom saving throw.
				// On a failed save, the target takes 4d10 Psychic damage and has the
				// Frightened condition for the duration. For the duration, the target
				// makes a Wisdom saving throw at the end of each of its turns. On a failed
				// save, it takes the Psychic damage again."
				int dice_count = 4 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				if (target.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				broadcast_roll(target.name, "WIS save vs Phantasmal Killer", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Frightened!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Phantasmal Killer")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Phantasmal Killer"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Phantasmal Killer"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Phantasmal Killer"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					combat.apply_damage(target, total_damage, DMG_PSYCHIC, c);
					target.add_condition(COND_FRIGHTENED);
					target.frightened_source_id = c.id;
					broadcast_announce(c.name + "'s Phantasmal Killer terrifies " + target.name + " for " + total_damage + " psychic damage!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "shatter") {
				// Basic Rules para 14946: "A loud noise erupts from a point of your choice
				// within range. Each creature in a 10-foot-radius Sphere centered there
				// makes a Constitution saving throw, taking 3d8 Thunder damage on a failed
				// save or half as much damage on a successful one."
				int dice_count = 3 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				broadcast_announce(c.name + " casts Shatter — a loud noise erupts in a 10-foot sphere!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 10) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Shatter", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_THUNDER, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "wall_of_ice") {
				// Basic Rules para 15566: "If the wall cuts through a creature's space when
				// it appears, the creature is pushed to one side of the wall (you choose
				// which side) and makes a Dexterity saving throw, taking 10d6 Cold damage
				// on a failed save or half as much damage on a successful one."
				int dice_count = 10 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " creates a Wall of Ice — a frozen barrier crashes down!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 30) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Wall of Ice", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_COLD, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "heat_metal" and @target != null) {
				// Basic Rules paras 13734-13735: "Choose a manufactured metal object...
				// You cause the object to glow red-hot. Any creature in physical contact
				// with the object takes 2d8 Fire damage when you cast the spell. Until
				// the spell ends, you can take a Bonus Action on each of your turns to
				// cause this damage again. If a creature is holding or wearing the object
				// and takes the damage from it, the creature must succeed on a Constitution
				// saving throw or drop the object."
				// Approximation: damage hits any target wearing metal armor (chain_mail,
				// plate, splint, half_plate, scale_mail, breastplate, ring_mail).
				bool wearing_metal = (target.armor_type == "chain_mail" or target.armor_type == "plate" or target.armor_type == "splint" or target.armor_type == "half_plate" or target.armor_type == "scale_mail" or target.armor_type == "breastplate" or target.armor_type == "ring_mail" or target.armor_type == "chain_shirt");
				if (!wearing_metal) {
					broadcast_announce(target.name + " isn't wearing any metal — Heat Metal has no effect.", false);
				} else {
					int dice_count = 2 + upcast_levels;
					int hm_dmg = 0;
					for (int d = 0; d < dice_count; d++) hm_dmg += random(1, 8);
					combat.apply_damage(target, hm_dmg, DMG_FIRE, c);
					broadcast_announce(c.name + "'s Heat Metal sears " + target.name + " for " + hm_dmg + " fire damage!", true);
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(target, c.id, save_roll);
					int save_bonus = target.get_save_bonus(ABILITY_CON);
					int save_total = save_roll + save_bonus;
					if (save_total < save_dc) {
						// Basic Rules 2024 Heat Metal (para 13734): "the creature has
						// disadvantage on attack rolls and ability checks until the
						// start of your next turn."
						target.heat_metal_disadv = true;
						broadcast_announce(target.name + " can't drop the searing metal! Disadvantage on attacks and ability checks.", true);
					}
					// Track for BA re-damage on subsequent turns (concentration)
					c.heat_metal_active = true;
					c.heat_metal_target_id = target.id;
					c.heat_metal_dice_count = dice_count;
				}
			}
			else if (spell.id == "faerie_fire") {
				// Basic Rules paras 13167-13168: "Objects in a 20-foot Cube within range
				// are outlined in blue, green, or violet light... Each creature in the
				// Cube is also outlined if it fails a Dexterity saving throw. For the
				// duration, objects and affected creatures shed Dim Light in a 10-foot
				// radius and can't benefit from being Invisible. Attack rolls against an
				// affected creature or object have Advantage if the attacker can see it."
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int affected = 0;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (DEX — Outlined condition)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "DEX save vs Faerie Fire"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Faerie Fire"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Faerie Fire"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "DEX save vs Faerie Fire", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Outlined!");
					if (!saved) {
						// Faerie Fire: persistent advantage on ALL attacks against outlined targets for duration
						// (NOT single-use like Guiding Bolt — persists until concentration breaks)
						t.faerie_fire_outlined = true;
						t.faerie_fire_source_id = c.id;
						t.remove_condition(COND_INVISIBLE);
						affected++;
					}
				}
				broadcast_announce(c.name + " casts Faerie Fire — " + affected + " creature" + (affected == 1 ? "" : "s") + " outlined in colorful light. Attacks against them have advantage.", true);
				broadcast_state();
				return;
			}
			else if (spell.id == "bestow_curse" and @target != null) {
				// Basic Rules 2024 Bestow Curse (para 12219-12222): Caster chooses curse type.
				// 4 main options + 6 ability sub-options = 9 total choices.
				pending_spell_choice sc;
				sc.player_username = c.player_username;
				sc.caster_id = c.id;
				sc.spell_id = "bestow_curse";
				sc.cast_slot_level = cast_slot_level;
				sc.primary_target_id = target.id;
				sc.option_keys = {"extra_damage", "attack_disadv", "forced_dodge", "ability_str", "ability_dex", "ability_con", "ability_int", "ability_wis", "ability_cha"};
				sc.option_labels = {"Extra 1d8 necrotic on your attacks vs target", "Target has disadvantage on attacks against you", "Target must Dodge or waste their turn each round", "Target disadv on STR checks and saves", "Target disadv on DEX checks and saves", "Target disadv on CON checks and saves", "Target disadv on INT checks and saves", "Target disadv on WIS checks and saves", "Target disadv on CHA checks and saves"};
				sc.prompt_text = "Bestow Curse: choose an effect. 1 for extra damage, 2 for attack disadvantage, 3 for forced dodge, 4 through 9 for ability disadvantage (4 STR, 5 DEX, 6 CON, 7 INT, 8 WIS, 9 CHA).";
				send_spell_choice_prompt(c, sc);
			}
			else if (spell.id == "vampiric_touch") {
				// Basic Rules para 15517: "Make a melee spell attack against one creature
				// within reach. On a hit, the target takes 3d6 Necrotic damage, and you
				// regain Hit Points equal to half the necrotic damage dealt."
				if (@target == null or target.is_dead) {
					u.send({{"type", message_types::announce}, {"text", "No valid target."}, {"interrupt", true}});
					return;
				}
				int dist = feet_distance(c.x, c.y, target.x, target.y);
				if (dist > 5) {
					u.send({{"type", message_types::announce}, {"text", "Vampiric Touch requires a target within 5 feet."}, {"interrupt", true}});
					return;
				}
				// Roll spell attack
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Vampiric Touch attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					int dice_count = 3 + upcast_levels;
					int total_damage = 0;
					for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
					combat.apply_damage(target, total_damage, DMG_NECROTIC, c);
					int heal = total_damage / 2;
					int effective = combat.apply_healing(c, heal);
					record_effective_healing(c.player_username, effective);
					broadcast_announce(c.name + "'s Vampiric Touch drains " + total_damage + " HP from " + target.name + " and heals " + c.name + " for " + heal + ".", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "plant_growth") {
				// Basic Rules para 14499: "Choose a point within range. All normal plants
				// in a 100-foot-radius Sphere centered on that point become thick and
				// overgrown. A creature moving through that area must spend 4 feet of
				// movement for every 1 foot it moves." Approximation: cuts movement of
				// all hostiles in the area to 1/4 for the next round.
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int affected = 0;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 100) continue;
					if (!combat.are_hostile(c, t)) continue;
					t.movement_remaining = t.movement_remaining / 4;
					affected++;
				}
				broadcast_announce(c.name + " channels Plant Growth — overgrowth covers a 100-foot area, slowing " + affected + " hostile" + (affected == 1 ? "" : "s") + " to 1/4 movement.", true);
			}
			else if (spell.id == "disintegrate" and @target != null) {
				// Basic Rules para 12875: "A creature targeted by this spell makes a
				// Dexterity saving throw. On a failed save, the target takes 10d6 + 40
				// Force damage. If this damage reduces it to 0 Hit Points, it and
				// everything nonmagical it is wearing and carrying are disintegrated."
				int dice_count = 10 + (3 * upcast_levels);
				int total_damage = 40;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_DEX);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "DEX save vs Disintegrate"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "DEX save vs Disintegrate"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "DEX save vs Disintegrate", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "DISINTEGRATED!");
				if (!saved) {
					combat.apply_damage(target, total_damage, DMG_FORCE, c);
					broadcast_announce(c.name + "'s green ray strikes " + target.name + " for " + total_damage + " force damage!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "cone_of_cold") {
				// Basic Rules para 12483: "Each creature in a 60-foot Cone originating
				// from you makes a Constitution saving throw, taking 8d8 Cold damage on
				// a failed save or half as much damage on a successful one."
				int dice_count = 8 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				broadcast_announce(c.name + " unleashes a 60-foot Cone of Cold!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 60) continue;
					if (!combat.can_see(c, t)) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Cone of Cold"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Cone of Cold"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Cone of Cold", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_COLD, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "chain_lightning" and @target != null) {
				// Basic Rules paras 12333-12334: "You launch a lightning bolt toward a
				// target you can see within range. Three bolts then leap from that target
				// to as many as three other targets of your choice... Each target makes
				// a Dexterity saving throw, taking 10d8 Lightning damage on a failed save
				// or half as much damage on a successful one."
				int dice_count = 10;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				int extra_bolts = 3 + upcast_levels;
				combatant@[] cl_targets;
				cl_targets.insert_last(target);
				// Find up to 3 more targets within 30 ft of the primary target
				for (uint ti = 0; ti < combat.combatants.length() and int(cl_targets.length()) < 1 + extra_bolts; ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id or t.id == target.id) continue;
					if (!combat.are_hostile(c, t)) continue;
					if (feet_distance(target.x, target.y, t.x, t.y) > 30) continue;
					cl_targets.insert_last(t);
				}
				broadcast_announce(c.name + " unleashes Chain Lightning! " + cl_targets.length() + " creatures struck.", true);
				for (uint ti = 0; ti < cl_targets.length(); ti++) {
					combatant@ t = cl_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Chain Lightning"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Chain Lightning"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Chain Lightning", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_LIGHTNING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "meteor_swarm") {
				// Basic Rules para 14211: "Blazing orbs of fire plummet to the ground at
				// four different points you can see within range. Each creature in a
				// 40-foot-radius Sphere centered on each of those points makes a Dexterity
				// saving throw. A creature takes 20d6 Fire damage and 20d6 Bludgeoning
				// damage on a failed save, or half as much damage on a successful one."
				int fire_dice = 20;
				int bludg_dice = 20;
				int total_damage = 0;
				for (int d = 0; d < fire_dice; d++) total_damage += random(1, 6);
				int bludg_damage = 0;
				for (int d = 0; d < bludg_dice; d++) bludg_damage += random(1, 6);
				broadcast_announce(c.name + " calls down a Meteor Swarm! Four 40-foot fire spheres devastate the area!", true);
				// All hostiles within 40 ft of caster get hit (single big AoE approximation)
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 80) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Meteor Swarm"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Meteor Swarm"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int fire_dmg = saved ? total_damage / 2 : total_damage;
					int b_dmg = saved ? bludg_damage / 2 : bludg_damage;
					if (fire_dmg < 1) fire_dmg = 1;
					if (b_dmg < 1) b_dmg = 1;
					broadcast_roll(t.name, "DEX save vs Meteor Swarm", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, fire_dmg, DMG_FIRE, c);
					combat.apply_damage(t, b_dmg, DMG_BLUDGEONING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "maze" and @target != null) {
				// Basic Rules paras 14164-14166: "You banish a creature that you can see
				// within range into a labyrinthine demiplane. The target remains there
				// for the duration or until it escapes the maze. The target can take a
				// Study action to try to escape... DC 20 Intelligence (Investigation) check."
				// Approximation: apply COND_INCAPACITATED until concentration ends
				target.add_condition(COND_INCAPACITATED);
				broadcast_announce(c.name + " banishes " + target.name + " into a labyrinthine demiplane! They can attempt to escape on each of their turns (DC 20 INT check).", true);
			}
			else if (spell.id == "mass_suggestion") {
				// Basic Rules para 14155: "Each target must succeed on a Wisdom saving
				// throw or have the Charmed condition for the duration or until you or
				// your allies deal damage to the target." Up to 12 visible creatures.
				int count = 0;
				for (uint ti = 0; ti < combat.combatants.length() and count < 12; ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 60) continue;
					if (!combat.can_see(c, t)) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved and try_countercharm_reroll(t, save_dc, save_bonus + bless_bonus, "WIS save vs Mass Suggestion")) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Mass Suggestion"); if (ds >= save_dc) saved = true; }
					if (!saved) { int new_total = try_flash_of_genius(t, save_dc, save_total, "WIS save vs Mass Suggestion"); if (new_total >= save_dc) saved = true; }
				if (!saved) { int ms_total = try_maverick_spirit(t, save_dc, save_total, "WIS save vs Mass Suggestion"); if (ms_total >= save_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf > 0) saved = true; }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					if (!saved) {
						t.add_condition(COND_CHARMED);
						count++;
					}
				}
				broadcast_announce(c.name + " casts Mass Suggestion, charming " + count + " creature" + (count == 1 ? "" : "s") + ".", true);
			}
			else if (spell.id == "command" and @target != null) {
				// Basic Rules 2024 Command (para 12421-12433): "You speak a one-word
				// command to a creature you can see within range. The target must succeed
				// on a Wisdom saving throw or follow the command on its next turn."
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				broadcast_roll(target.name, "WIS save vs Command", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Commanded!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Command")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Command"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Command"); if (new_total >= save_dc) saved = true; }
				if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Command"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					// Basic Rules 2024 Command effects (para 12427-12433):
					// Auto-pick for bots: Grovel (most universally useful)
					// Player choice via pending_spell_choice deferred — auto-pick Grovel.
					string cmd = "grovel";
					// AI pick: Halt for casters, Grovel for melee
					if (!c.is_player) {
						if (target.is_concentrating) cmd = "halt";
					}
					target.command_effect = cmd;
					target.command_source_id = c.id;
					string cmd_label = "Grovel";
					if (cmd == "halt") cmd_label = "Halt";
					else if (cmd == "flee") cmd_label = "Flee";
					else if (cmd == "approach") cmd_label = "Approach";
					else if (cmd == "drop") cmd_label = "Drop";
					broadcast_announce(c.name + " commands " + target.name + ": " + cmd_label + "! They must obey on their next turn.", true);
				}
			}
			else if (spell.id == "suggestion" and @target != null) {
				// Basic Rules para 15191: "The target must succeed on a Wisdom saving throw
				// or have the Charmed condition for the duration or until you or your allies
				// deal damage to the target."
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				broadcast_roll(target.name, "WIS save vs Suggestion", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Suggestion")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Suggestion"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Suggestion"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Suggestion"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_CHARMED);
					broadcast_announce(target.name + " is charmed by " + c.name + "'s Suggestion. The charm ends if you or an ally damages them.", true);
				}
			}
			else if (spell.id == "power_word_heal" and @target != null) {
				// Basic Rules para 14528: "A wave of healing energy washes over one creature
				// you can see within range. The target regains all its Hit Points. If the
				// creature has the Charmed, Frightened, Paralyzed, Poisoned, or Stunned
				// condition, the condition ends."
				int needed = target.max_hp - target.current_hp;
				int effective = combat.apply_healing(target, needed);
				record_effective_healing(c.player_username, effective);
				target.remove_condition(COND_CHARMED);
				target.remove_condition(COND_FRIGHTENED);
				target.remove_condition(COND_PARALYZED);
				target.remove_condition(COND_POISONED);
				target.remove_condition(COND_STUNNED);
				broadcast_announce(c.name + "'s Power Word Heal restores " + target.name + " to full health and ends Charmed/Frightened/Paralyzed/Poisoned/Stunned!", true);
				// PHB 2024 Bard L20 Words of Creation (paras 2764-2765): "When you cast
				// either spell, you can target a second creature with it if that creature
				// is within 10 feet of the first target." Auto-pick the most-injured ally
				// within 10 ft of the first target.
				if (c.words_of_creation_active) {
					combatant@ second = null;
					int best_need = 0;
					for (uint wi = 0; wi < combat.combatants.length(); wi++) {
						combatant@ wt = combat.combatants[wi];
						if (@wt == null or wt.is_dead or wt.id == target.id or wt.id == c.id) continue;
						if (wt.is_player != target.is_player and combat.mode != "pvp") continue;
						if (feet_distance(target.x, target.y, wt.x, wt.y) > 10) continue;
						int need = wt.max_hp - wt.current_hp;
						if (need > best_need) { best_need = need; @second = wt; }
					}
					if (@second != null) {
						int s_eff = combat.apply_healing(second, second.max_hp - second.current_hp);
						record_effective_healing(c.player_username, s_eff);
						second.remove_condition(COND_CHARMED);
						second.remove_condition(COND_FRIGHTENED);
						second.remove_condition(COND_PARALYZED);
						second.remove_condition(COND_POISONED);
						second.remove_condition(COND_STUNNED);
						broadcast_announce(c.name + "'s Words of Creation echoes Power Word Heal onto " + second.name + " — full health restored!", true);
					}
				}
				try_chalice_healing(c);
			}
			else if (spell.id == "sunburst") {
				// Basic Rules para 15267: "Brilliant sunlight flashes in a 60-foot-radius
				// Sphere centered on a point you choose within range. Each creature in the
				// Sphere makes a Constitution saving throw. On a failed save, a creature
				// takes 12d6 Radiant damage and has the Blinded condition for 1 minute."
				int dice_count = 12;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " unleashes a Sunburst — brilliant sunlight in a 60-foot sphere!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 60) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (CON — Blinded condition, no Mage Slayer)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "CON save vs Sunburst"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Sunburst"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Sunburst"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Sunburst", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Blinded!");
					combat.apply_damage(t, dmg, DMG_RADIANT, c);
					if (!saved) {
						t.add_condition(COND_BLINDED);
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "greater_restoration" and @target != null) {
				// Basic Rules paras 13601-13604: "You touch a creature and magically remove
				// one of the following effects from it: 1 Exhaustion level; the Charmed or
				// Petrified condition; a curse, including the target's Attunement to a
				// cursed magic item." Removes the most serious condition first.
				if (target.has_condition(COND_PETRIFIED)) {
					target.remove_condition(COND_PETRIFIED);
					broadcast_announce(c.name + "'s Greater Restoration cures " + target.name + "'s petrification!", true);
				} else if (target.has_condition(COND_CHARMED)) {
					target.remove_condition(COND_CHARMED);
					broadcast_announce(c.name + "'s Greater Restoration cures " + target.name + "'s charm!", true);
				} else if (target.exhaustion_level > 0) {
					target.exhaustion_level--;
					broadcast_announce(c.name + "'s Greater Restoration removes 1 exhaustion level from " + target.name + ".", true);
				} else {
					broadcast_announce(c.name + " casts Greater Restoration on " + target.name + ", but no eligible condition to cure.", false);
				}
			}
			else if (spell.id == "bane") {
				// Basic Rules para 12174: "Up to three creatures of your choice that you
				// can see within range must each make a Charisma saving throw. Whenever a
				// target that fails this save makes an attack roll or a saving throw before
				// the spell ends, the target must subtract 1d4 from the roll."
				int targets_wanted = 3 + upcast_levels;
				int banned = 0;
				for (uint bi = 0; bi < combat.combatants.length() and banned < targets_wanted; bi++) {
					combatant@ t = combat.combatants[bi];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (!combat.are_hostile(c, t)) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 30) continue;
					if (!combat.can_see(c, t)) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CHA);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (CHA — Baned condition)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "CHA save vs Bane"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CHA save vs Bane"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CHA save vs Bane"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_CHA)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "CHA save vs Bane", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Baned!");
					if (!saved) {
						t.baned = true;
						t.bane_source_id = c.id;
						banned++;
					}
				}
				broadcast_announce(c.name + " casts Bane on " + banned + " creature" + (banned == 1 ? "" : "s") + ". They subtract 1d4 from attack rolls and saves.", true);
			}
			else if (spell.id == "healing_word" and @target != null) {
				// Basic Rules para 13725: "A creature of your choice that you can see within
				// range regains Hit Points equal to 2d4 plus your spellcasting ability modifier."
				int dice_count = 2 + (upcast_levels * 2);
				int heal = 0;
				// Basic Rules 2024 Beacon of Hope (para 12201): max healing
				if (target.beacon_of_hope_active) {
					heal = dice_count * 4;
				} else {
					for (int d = 0; d < dice_count; d++) heal += random(1, 4);
					heal = apply_empowered_healing(c, heal, dice_count, 4);
				}
				heal += get_spellcasting_ability_mod(c);
				if (heal < 1) heal = 1;
				int effective = combat.apply_healing(target, heal);
				record_effective_healing(c.player_username, effective);
				broadcast_announce(c.name + " heals " + target.name + " for " + heal + " HP with Healing Word.", true);
				try_unicorn_totem_heal(c);
				try_chalice_healing(c);
			}
			else if (spell.id == "mass_healing_word") {
				// Basic Rules para 14145: "Up to six creatures of your choice that you can
				// see within range regain Hit Points equal to 2d4 plus your spellcasting
				// ability modifier."
				int dice_count = 2 + (upcast_levels > 0 ? upcast_levels : 0);
				int heal = 0;
				for (int d = 0; d < dice_count; d++) heal += random(1, 4);
				heal = apply_empowered_healing(c, heal, dice_count, 4);
				heal += get_spellcasting_ability_mod(c);
				if (heal < 1) heal = 1;
				// Basic Rules 2024 Beacon of Hope (para 12201): per-target max healing
				int heal_beacon = dice_count * 4 + get_spellcasting_ability_mod(c);
				if (heal_beacon < 1) heal_beacon = 1;
				int healed = 0;
				for (uint mi = 0; mi < combat.combatants.length() and healed < 6; mi++) {
					combatant@ ally = combat.combatants[mi];
					if (@ally == null or ally.is_dead) continue;
					if (ally.is_player != c.is_player and ally.id != c.id) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) continue;
					int effective = combat.apply_healing(ally, ally.beacon_of_hope_active ? heal_beacon : heal);
					record_effective_healing(c.player_username, effective);
					healed++;
				}
				broadcast_announce(c.name + " casts Mass Healing Word, healing " + healed + " ally" + (healed == 1 ? "" : "ies") + " for " + heal + " HP each.", true);
				try_unicorn_totem_heal(c);
				try_chalice_healing(c);
			}
			else if (spell.id == "feeblemind" and @target != null) {
				// Basic Rules (not quoted — using the 2024 version): target INT save or
				// take 4d6 psychic damage. On failure, INT and CHA become 1 until the
				// spell is dispelled or removed. No concentration.
				int dice_count = 4;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_INT);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (INT — Mage Slayer applies)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "INT save vs Feeblemind"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "INT save vs Feeblemind"); if (fg >= save_dc) saved = true; }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "INT save vs Feeblemind"); if (mv >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_INT)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "INT save vs Feeblemind", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Feebleminded!");
				int dmg = total_damage;
				combat.apply_damage(target, dmg, DMG_PSYCHIC, c);
				if (!saved) {
					// Set INT and CHA to 1 (feeblemind effect)
					target.ability_scores[ABILITY_INT] = 1;
					target.ability_scores[ABILITY_CHA] = 1;
					broadcast_announce(target.name + " is Feebleminded! INT and CHA become 1.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "eyebite" and @target != null) {
				// Basic Rules 2024 Eyebite (para 13145-13151): "One creature of your choice
				// within 60 feet of you that you can see must succeed on a Wisdom saving throw
				// or be affected by one of the following effects of your choice for the duration."
				// 3 options: Asleep (Unconscious), Panicked (Frightened), Sickened (disadvantage).
				// Prompt the caster for which effect to apply.
				pending_spell_choice sc;
				sc.player_username = c.player_username;
				sc.caster_id = c.id;
				sc.spell_id = "eyebite";
				sc.cast_slot_level = cast_slot_level;
				sc.primary_target_id = target.id;
				sc.option_keys = {"panicked", "asleep", "sickened"};
				sc.option_labels = {"Panicked (Frightened — can't approach caster)", "Asleep (Unconscious — wakes on damage)", "Sickened (disadvantage on attacks and ability checks)"};
				sc.prompt_text = "Eyebite: choose an effect for " + target.name + ". Press 1 for Panicked (Frightened), 2 for Asleep (Unconscious), or 3 for Sickened (disadvantage on attacks).";
				send_spell_choice_prompt(c, sc);
			}
			else if (spell.id == "mass_heal") {
				// Basic Rules para 14137: "A flood of healing energy flows from you into
				// creatures around you. You restore up to 700 Hit Points, divided as you
				// choose among any number of creatures that you can see within range.
				// Creatures healed by this spell also have the Blinded, Deafened, and
				// Poisoned conditions removed."
				// Approximation: 700 HP pool split evenly among visible ally targets
				// within 60 ft who are below max HP (prioritising those most hurt).
				int pool = 700;
				combatant@[] wounded;
				for (uint mi = 0; mi < combat.combatants.length(); mi++) {
					combatant@ ally = combat.combatants[mi];
					if (@ally == null or ally.is_dead) continue;
					if (ally.is_player != c.is_player and ally.id != c.id) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) continue;
					if (ally.current_hp < ally.max_hp) wounded.insert_last(ally);
				}
				broadcast_announce(c.name + " unleashes Mass Heal — 700 HP of divine energy!", true);
				while (pool > 0 and wounded.length() > 0) {
					combatant@ most_hurt = wounded[0];
					uint most_hurt_idx = 0;
					for (uint wi = 1; wi < wounded.length(); wi++) {
						int a_deficit = wounded[wi].max_hp - wounded[wi].current_hp;
						int b_deficit = most_hurt.max_hp - most_hurt.current_hp;
						if (a_deficit > b_deficit) { @most_hurt = wounded[wi]; most_hurt_idx = wi; }
					}
					int needed = most_hurt.max_hp - most_hurt.current_hp;
					int granted = needed < pool ? needed : pool;
					int effective = combat.apply_healing(most_hurt, granted);
					record_effective_healing(c.player_username, effective);
					pool -= granted;
					most_hurt.remove_condition(COND_BLINDED);
					most_hurt.remove_condition(COND_DEAFENED);
					most_hurt.remove_condition(COND_POISONED);
					broadcast_announce(most_hurt.name + " heals for " + granted + " HP.", false);
					wounded.remove_at(most_hurt_idx);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "slow") {
				// Basic Rules paras 15047-15049: "You alter time around up to six creatures
				// of your choice in a 40-foot Cube within range. Each target must succeed
				// on a Wisdom saving throw or be affected by this spell for the duration.
				// An affected target's Speed is halved, it takes a -2 penalty to AC and
				// Dexterity saving throws, and it can't take Reactions."
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int affected = 0;
				for (uint ti = 0; ti < combat.combatants.length() and affected < 6; ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (WIS — Mage Slayer applies)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Slow"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "WIS save vs Slow"); if (fg >= save_dc) saved = true; }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "WIS save vs Slow"); if (mv >= save_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) saved = true; }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "WIS save vs Slow", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Slowed!");
					if (!saved) {
						t.slow_original_speed = t.speed;
						t.slow_spell_caster_id = c.id;
						t.speed = t.speed / 2;
						t.armor_class -= 2;
						t.has_reaction = false;
						affected++;
					}
				}
				broadcast_announce(c.name + " slows " + affected + " creature" + (affected == 1 ? "" : "s") + " with the flow of time.", true);
				broadcast_state();
				return;
			}
			else if (spell.id == "power_word_kill" and @target != null) {
				// Basic Rules para 14536: "You compel one creature you can see within range
				// to die. If the target has 100 Hit Points or fewer, it dies. Otherwise,
				// it takes 12d12 Psychic damage."
				if (target.current_hp <= 100) {
					broadcast_announce(c.name + "'s Power Word Kill slays " + target.name + "!", true);
					combat.apply_damage(target, target.current_hp + 999, DMG_PSYCHIC, c);
				} else {
					int pwk_dmg = 0;
					for (int d = 0; d < 12; d++) pwk_dmg += random(1, 12);
					combat.apply_damage(target, pwk_dmg, DMG_PSYCHIC, c);
					broadcast_announce(c.name + "'s Power Word Kill deals " + pwk_dmg + " psychic damage to " + target.name + ".", true);
				}
				// PHB 2024 Bard L20 Words of Creation (paras 2764-2765): "When you cast
				// either spell, you can target a second creature with it if that creature
				// is within 10 feet of the first target." Auto-pick the lowest-HP enemy
				// within 10 ft of the first target (highest kill chance).
				if (c.words_of_creation_active) {
					combatant@ second = null;
					int best_hp = 999999;
					for (uint wi = 0; wi < combat.combatants.length(); wi++) {
						combatant@ wt = combat.combatants[wi];
						if (@wt == null or wt.is_dead or wt.id == target.id or wt.id == c.id) continue;
						if (!combat.are_hostile(c, wt)) continue;
						if (feet_distance(target.x, target.y, wt.x, wt.y) > 10) continue;
						if (wt.current_hp < best_hp) { best_hp = wt.current_hp; @second = wt; }
					}
					if (@second != null) {
						if (second.current_hp <= 100) {
							broadcast_announce(c.name + "'s Words of Creation echoes Power Word Kill onto " + second.name + " — slain!", true);
							combat.apply_damage(second, second.current_hp + 999, DMG_PSYCHIC, c);
						} else {
							int pwk2 = 0;
							for (int d = 0; d < 12; d++) pwk2 += random(1, 12);
							combat.apply_damage(second, pwk2, DMG_PSYCHIC, c);
							broadcast_announce(c.name + "'s Words of Creation echoes Power Word Kill onto " + second.name + " for " + pwk2 + " psychic damage.", true);
						}
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "earthquake") {
				// Basic Rules paras 13033-13034: "an intense tremor rips through the
				// ground in a 100-foot-radius circle centered on that point. The ground
				// there is Difficult Terrain. When you cast this spell and at the end of
				// each of your turns for the duration, each creature on the ground in the
				// area makes a Dexterity saving throw. On a failed save, a creature has
				// the Prone condition, and its Concentration is broken."
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int affected = 0;
				broadcast_announce(c.name + " triggers a massive Earthquake in a 100-foot radius!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 100) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (DEX — Prone condition)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "DEX save vs Earthquake"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Earthquake"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Earthquake"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "DEX save vs Earthquake", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Prone!");
					if (!saved) {
						t.add_condition(COND_PRONE);
						if (t.is_concentrating) {
							clear_concentration_effects(t);
							t.is_concentrating = false;
							t.remove_condition(COND_CONCENTRATING);
							broadcast_announce(t.name + "'s concentration is broken by the quake.", false);
						}
						affected++;
					}
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "guardian_of_faith") {
				// Basic Rules paras 13614-13615: "A Large spectral guardian appears and
				// hovers for the duration in an unoccupied space that you can see within
				// range. The guardian occupies that space and is invulnerable... Any enemy
				// that moves to a space within 10 feet of the guardian for the first time
				// on a turn or starts its turn there makes a Dexterity saving throw,
				// taking 20 Radiant damage on a failed save or half as much damage on a
				// successful one."
				// Spawned as a companion entity with very high HP (invulnerable proxy)
				// and a radiant aura encoded as its attack.
				int guardian_x = @target != null ? target.x : c.x;
				int guardian_y = @target != null ? target.y : c.y;
				combatant@ guardian = spawn_companion(c, "guardian_of_faith", c.name + "'s Guardian of Faith", 9999, 20, 0, c.proficiency + get_spellcasting_ability_mod(c), 0, 0, 20, DMG_RADIANT, 0);
				if (@guardian != null) {
					guardian.x = guardian_x;
					guardian.y = guardian_y;
					broadcast_announce(c.name + " summons a spectral Guardian of Faith! Enemies within 10 feet take 20 radiant damage.", true);
				}
			}
			else if (spell.id == "bigbys_hand") {
				// Basic Rules para 12232: "You create a Large hand of shimmering magical
				// energy in an unoccupied space that you can see within range. The hand
				// lasts for the duration, and it moves at your command... The hand is an
				// object that has AC 20 and Hit Points equal to your Hit Point maximum."
				// Wired as a companion entity per source - the hand can clenched fist /
				// forceful hand / grasping hand / interposing hand. Default to Clenched
				// Fist (4d8 force damage at touch range).
				combatant@ hand = spawn_companion(c, "bigbys_hand", c.name + "'s Bigby's Hand", c.max_hp, 20, 30, c.proficiency + get_spellcasting_ability_mod(c), 4, 8, 0, DMG_FORCE, 0);
				if (@hand != null) {
					broadcast_announce(c.name + " summons Bigby's Hand! AC 20, HP " + c.max_hp + ", 4d8 force damage on Clenched Fist.", true);
				}
			}
			else if (spell.id == "tsunami") {
				// Basic Rules para 15497: "When the wall appears, each creature in its
				// area makes a Strength saving throw, taking 6d10 Bludgeoning damage on
				// a failed save or half as much damage on a successful one."
				int dice_count = 6;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				broadcast_announce(c.name + " summons a Tsunami! A 300-foot wall of water crashes down.", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 60) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_STR);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = t.apply_indomitable_might(save_roll + save_bonus + bless_bonus, ABILITY_STR);
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "STR save vs Tsunami", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_BLUDGEONING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "death_ward" and @target != null) {
				// Basic Rules para 12784: "You touch a creature and grant it a measure of
				// protection from death. The first time the target would drop to 0 Hit
				// Points before the spell ends, the target instead drops to 1 Hit Point,
				// and the spell ends."
				target.death_ward_active = true;
				broadcast_announce(c.name + " grants " + target.name + " Death Ward. The first time they would drop to 0 hit points, they drop to 1 instead.", true);
			}
			else if (spell.id == "spike_growth") {
				// Basic Rules para 15114: "The ground in a 20-foot-radius Sphere centered
				// on a point within range sprouts hard spikes and thorns. The area becomes
				// Difficult Terrain for the duration. When a creature moves into or within
				// the area, it takes 2d4 Piercing damage for every 5 feet it travels."
				// Approximation: deal immediate 2d4 to all creatures in the area as a
				// per-cast effect (the per-foot tracking would need a movement hook).
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				// Track AoE center for per-turn damage in advance_turn
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_announce(c.name + " conjures Spike Growth in a 20-foot sphere of difficult terrain.", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int sg_dmg = random(1, 4) + random(1, 4);
					combat.apply_damage(t, sg_dmg, DMG_PIERCING, c);
					broadcast_announce(t.name + " takes " + sg_dmg + " piercing damage from the spikes.", false);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "wind_wall") {
				// Basic Rules para 15658: "When the wall appears, each creature in its area
				// makes a Strength saving throw, taking 4d8 Bludgeoning damage on a failed
				// save or half as much damage on a successful one."
				int dice_count = 4;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				broadcast_announce(c.name + " summons a 50-foot Wind Wall!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 25) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_STR);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = t.apply_indomitable_might(save_roll + save_bonus + bless_bonus, ABILITY_STR);
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "STR save vs Wind Wall", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_BLUDGEONING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "wall_of_thorns") {
				// Basic Rules para 15591: "When the wall appears, each creature in its area
				// makes a Dexterity saving throw, taking 7d8 Piercing damage on a failed
				// save or half as much damage on a successful one."
				int dice_count = 7 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				broadcast_announce(c.name + " conjures a Wall of Thorns up to 60 feet long!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 30) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Wall of Thorns", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_PIERCING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "sunbeam") {
				// Basic Rules para 15257: "You launch a sunbeam in a 5-foot-wide, 60-foot-
				// long Line. Each creature in the Line makes a Constitution saving throw.
				// On a failed save, a creature takes 6d8 Radiant damage and has the Blinded
				// condition until the start of your next turn."
				int dice_count = 6;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				broadcast_announce(c.name + " launches a 60-foot Sunbeam!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 60) continue;
					// Approximate the line by hitting any visible target within 60 ft
					if (!combat.can_see(c, t)) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (CON — Blinded condition, no Mage Slayer)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "CON save vs Sunbeam"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Sunbeam"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Sunbeam"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Sunbeam", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Blinded!");
					combat.apply_damage(t, dmg, DMG_RADIANT, c);
					if (!saved) {
						t.add_condition(COND_BLINDED);
						t.blinded_spell_caster_id = c.id;
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "reverse_gravity") {
				// Basic Rules para 14807: "This spell reverses gravity in a 50-foot-radius,
				// 100-foot high Cylinder centered on a point within range. All creatures
				// and objects in that area that aren't anchored to the ground fall upward."
				// Combat approximation: each affected creature takes 6d6 falling damage on
				// the way back down at the end of the spell, with a STR save to resist.
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				broadcast_announce(c.name + " casts Reverse Gravity! Creatures in a 50-foot cylinder fall upward.", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 50) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int save_total = save_roll + save_bonus;
					bool saved = save_total >= save_dc;
					int fall_dmg = 0;
					for (int d = 0; d < 6; d++) fall_dmg += random(1, 6);
					if (saved) fall_dmg /= 2;
					if (fall_dmg < 1) fall_dmg = 1;
					broadcast_roll(t.name, "DEX save vs Reverse Gravity", save_roll, save_bonus, save_total, saved ? "Half fall damage" : "Full fall damage");
					combat.apply_damage(t, fall_dmg, DMG_BLUDGEONING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "wall_of_stone") {
				// Basic Rules para 15577-15578: "A nonmagical wall of solid stone springs
				// into existence at a point you choose within range... If the wall cuts
				// through a creature's space when it appears, the creature is pushed to one
				// side of the wall."
				// Approximation: places a wall flag at the cast target tile and pushes
				// the target 5 ft away. The wall blocks line of sight and movement (TODO).
				if (@target != null) {
					int dx = 0;
					int dy = 0;
					if (target.x > c.x) dx = 1;
					else if (target.x < c.x) dx = -1;
					if (target.y > c.y) dy = 1;
					else if (target.y < c.y) dy = -1;
					if (dx == 0 and dy == 0) dy = 1;
					int new_x = target.x + dx;
					int new_y = target.y + dy;
					if (new_x >= 0 and new_x < combat.map_width and new_y >= 0 and new_y < combat.map_height) {
						target.x = new_x;
						target.y = new_y;
					}
					broadcast_announce(c.name + " conjures a Wall of Stone at " + target.name + "'s location, pushing them aside.", true);
				} else {
					broadcast_announce(c.name + " conjures a Wall of Stone.", true);
				}
			}
			else if (spell.id == "beacon_of_hope") {
				// Basic Rules para 12201: "Choose any number of creatures within range. For
				// the duration, each target has Advantage on Wisdom saving throws and Death
				// Saving Throws and regains the maximum number of Hit Points possible from
				// any healing."
				int affected = 0;
				for (uint bi = 0; bi < combat.combatants.length(); bi++) {
					combatant@ ally = combat.combatants[bi];
					if (@ally == null or ally.is_dead) continue;
					if (ally.is_player != c.is_player) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) continue;
					ally.beacon_of_hope_active = true;
					ally.beacon_of_hope_caster_id = c.id;
					affected++;
				}
				broadcast_announce(c.name + " casts Beacon of Hope, granting " + affected + " ally" + (affected == 1 ? "" : "ies") + " advantage on Wisdom and Death saves and maximum healing.", true);
			}
			else if (spell.id == "insect_plague") {
				// Basic Rules paras 13899-13901: "Swarming locusts fill a 20-foot-radius
				// Sphere centered on a point you choose within range... When the swarm
				// appears, each creature in it makes a Constitution saving throw, taking
				// 4d10 Piercing damage on a failed save or half as much damage on a
				// successful one. The damage increases by 1d10 for each spell slot level
				// above 5."
				int dice_count = 4 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				combatant@[] ip_targets;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) <= 20) ip_targets.insert_last(t);
				}
				// Track AoE center for per-turn damage in advance_turn
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_announce(c.name + " summons an Insect Plague — a 20-foot swarm of locusts!", true);
				for (uint ti = 0; ti < ip_targets.length(); ti++) {
					combatant@ t = ip_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (CON — damage only)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Insect Plague"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Insect Plague"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Insect Plague", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_PIERCING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "sleet_storm") {
				// Basic Rules paras 15038-15039: "sleet falls in a 40-foot-tall, 20-foot-
				// radius Cylinder centered on a point you choose within range... When a
				// creature enters the Cylinder for the first time on a turn or starts its
				// turn there, it must succeed on a Dexterity saving throw or have the
				// Prone condition and lose Concentration on any spells."
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				combatant@[] ss_targets;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) <= 20) ss_targets.insert_last(t);
				}
				broadcast_announce(c.name + " conjures a Sleet Storm in a 20-foot cylinder!", true);
				for (uint ti = 0; ti < ss_targets.length(); ti++) {
					combatant@ t = ss_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (DEX — Prone condition)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "DEX save vs Sleet Storm"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Sleet Storm"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Sleet Storm"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "DEX save vs Sleet Storm", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Prone!");
					if (!saved) {
						t.add_condition(COND_PRONE);
						if (t.is_concentrating) {
							clear_concentration_effects(t);
							t.is_concentrating = false;
							t.remove_condition(COND_CONCENTRATING);
							broadcast_announce(t.name + "'s concentration is lost in the Sleet Storm.", false);
						}
					}
				}
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "dominate_person" and @target != null) {
				// Basic Rules para 12980: "One Humanoid you can see within range must succeed
				// on a Wisdom saving throw or have the Charmed condition for the duration."
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				if (target.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
				broadcast_roll(target.name, "WIS save vs Dominate Person", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Dominate Person")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Dominate Person"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Dominate Person"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Dominate Person"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_CHARMED);
					target.charm_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Charmed"}});
					broadcast_announce(target.name + " is dominated by " + c.name + "!", true);
				}
			}
			else if (spell.id == "banishment" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_CHA);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
				broadcast_roll(target.name, "CHA save vs Banishment", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Banished!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "CHA save vs Banishment"); if (ds >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_CHA)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_INCAPACITATED);
					broadcast_announce(target.name + " is banished to a harmless demiplane!", true);
				}
			}
			else if (spell.id == "charm_person" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				if (target.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
				broadcast_roll(target.name, "WIS save vs Charm Person", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Charm Person")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Charm Person"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Charm Person"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Charm Person"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_CHARMED);
					target.charm_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Charmed"}});
					broadcast_announce(target.name + " is charmed by " + c.name + "!", true);
				}
			}
			else if (spell.id == "sleep") {
				// 2024 PHB: WIS save or Incapacitated, repeat save at end of turn -> Unconscious on second fail
				// 5-foot radius Sphere, Concentration up to 1 minute
				combatant@[] targets_hit;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					int dist = @target != null ? feet_distance(target.x, target.y, t.x, t.y) : feet_distance(c.x, c.y, t.x, t.y);
					if (dist <= 5) targets_hit.insert_last(t);
				}
				if (targets_hit.length() == 0 and @target != null) targets_hit.insert_last(target);
				for (uint ti = 0; ti < targets_hit.length(); ti++) {
					combatant@ t = targets_hit[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (WIS — Incapacitated condition)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Sleep"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "WIS save vs Sleep"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "WIS save vs Sleep"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(t.name, "WIS save vs Sleep", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Incapacitated!");
					if (!saved) {
						t.add_condition(COND_INCAPACITATED);
						t.incap_spell_caster_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Incapacitated"}});
						broadcast_announce(t.name + " is lulled by Sleep! Must save again at end of turn or fall Unconscious.", false);
					}
				}
			}
			else if (spell.id == "color_spray") {
				// 2024 PHB: 15-foot Cone, CON save or Blinded until end of caster's next turn
				combatant@[] targets_hit;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(c.x, c.y, t.x, t.y) <= 15) targets_hit.insert_last(t);
				}
				for (uint ti = 0; ti < targets_hit.length(); ti++) {
					combatant@ t = targets_hit[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(t.name, "CON save vs Color Spray", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Blinded!");
					if (!saved) {
						t.add_condition(COND_BLINDED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Blinded"}});
					}
				}
			}
			else if (spell.id == "tashas_hideous_laughter" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (WIS — Incapacitated+Prone condition)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Tasha's Hideous Laughter"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Tasha's Hideous Laughter"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Tasha's Hideous Laughter"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
				broadcast_roll(target.name, "WIS save vs Tasha's Hideous Laughter", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Incapacitated!");
				if (!saved) {
					target.add_condition(COND_PRONE);
					target.add_condition(COND_INCAPACITATED);
					target.laughter_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Prone"}});
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Incapacitated"}});
					broadcast_announce(target.name + " falls prone laughing uncontrollably!", true);
				}
			}
			else if (spell.id == "ensnaring_strike") {
				// 2024 PHB: Bonus Action cast IMMEDIATELY after hitting with a weapon.
				// Grasping vines appear on the target — STR save or Restrained.
				// Large+ creatures have advantage. 1d6 piercing/turn while restrained.
				// Since this triggers on a hit that just happened, apply immediately to current target.
				if (@target != null and !target.is_dead) {
					bool adv_save = (target.size >= SIZE_LARGE);
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(target, c.id, save_roll);
					if (adv_save) {
						int save_roll2 = random(1, 20);
						if (save_roll2 > save_roll) save_roll = save_roll2;
					}
					int save_bonus = target.get_save_bonus(ABILITY_STR);
					int bless_bonus = roll_bless_bonus(target);
					int save_total = target.apply_indomitable_might(save_roll + save_bonus + bless_bonus, ABILITY_STR);
					bool saved = save_total >= save_dc;
					string adv_text = adv_save ? " (with advantage)" : "";
					if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(target.name, "STR save vs Ensnaring Strike" + adv_text, save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Restrained!");
					if (!saved) {
						target.add_condition(COND_RESTRAINED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Restrained"}});
						broadcast_announce(target.name + " is restrained by grasping vines!", true);
					} else {
						broadcast_announce("The vines shrivel away.", false);
					}
				}
			}
			else if (spell.id == "sanctuary" and @target != null) {
				if (@target == null) @target = c;
				target.sanctuary_active = true;
				target.sanctuary_dc = save_dc;
				target.sanctuary_source_id = c.id;
				broadcast_announce(target.name + " is protected by Sanctuary. Attackers must make a Wisdom save to target them.", true);
			}
			else if (spell.id == "aid") {
				// Aid: +5 HP at level 2, +5 per slot level above 2 (so 5/10/15/20/25/30/35/40 at levels 2-9)
				int aid_bonus = 5 + (cast_slot_level - 2) * 5;
				if (aid_bonus < 5) aid_bonus = 5;
				if (@target == null) @target = c;
				target.max_hp += aid_bonus;
				target.current_hp += aid_bonus;
				broadcast_announce(c.name + "'s Aid grants " + target.name + " " + aid_bonus + " bonus HP.", true);
				// Apply to nearby allies as well (up to 3 targets total within 30ft of caster)
				int affected = 1;
				for (uint ai = 0; ai < combat.combatants.length() and affected < 3; ai++) {
					combatant@ ally = combat.combatants[ai];
					if (@ally == null or ally.is_dead or ally.id == target.id or ally.id == c.id) continue;
					if (ally.is_player != c.is_player) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) continue;
					ally.max_hp += aid_bonus;
					ally.current_hp += aid_bonus;
					broadcast_announce(c.name + "'s Aid grants " + ally.name + " " + aid_bonus + " bonus HP.", false);
					affected++;
				}
			}
			else if (spell.id == "stoneskin") {
				// Stoneskin: resistance to bludgeoning, piercing, and slashing (1 hour concentration, touch)
				if (@target == null) @target = c;
				target.piercing_resistance = true;
				target.bludgeoning_resistance = true;
				target.slashing_resistance = true;
				target.stoneskin_active = true;
				broadcast_announce(target.name + "'s skin turns to stone, gaining resistance to bludgeoning, piercing, and slashing damage!", true);
			}
			else if (spell.id == "greater_invisibility" and @target != null) {
				// Basic Rules 2024 Greater Invisibility (para 13658): concentration,
				// 1 min. Target is Invisible and STAYS invisible even after attacking.
				target.add_condition(COND_INVISIBLE);
				target.is_hidden = true;
				target.greater_invisibility_active = true;
				target.greater_invisibility_caster_id = c.id;
				broadcast_announce(target.name + " becomes Greater Invisible! They remain invisible even after attacking.", true);
			}
			else if (spell.id == "fly" and @target != null) {
				target.flying_speed = 60;
				target.fly_active = true;
				broadcast_announce(target.name + " gains a flying speed of 60 feet!", true);
			}
			else if (spell.id == "fire_shield") {
				// PHB Basic Rules para 13322: "The flames provide you with a warm shield or
				// a chill shield, as you choose." Prompt the caster instead of auto-picking.
				pending_spell_choice sc;
				sc.player_username = c.player_username;
				sc.caster_id = c.id;
				sc.spell_id = "fire_shield";
				sc.cast_slot_level = cast_slot_level;
				sc.option_keys = {"warm", "chill"};
				sc.option_labels = {"Warm shield (cold resistance, reflects fire)", "Chill shield (fire resistance, reflects cold)"};
				sc.prompt_text = "Fire Shield: choose warm or chill. Press 1 for warm shield (cold resistance, reflects 2d8 fire), or 2 for chill shield (fire resistance, reflects 2d8 cold).";
				send_spell_choice_prompt(c, sc);
			}
			else if (spell.id == "spirit_guardians") {
				// PHB Basic Rules para 15123-15124: damage type is alignment-based. Since
				// the game does not track alignment, prompt the caster to declare which
				// form their spirits manifest in.
				pending_spell_choice sc;
				sc.player_username = c.player_username;
				sc.caster_id = c.id;
				sc.spell_id = "spirit_guardians";
				sc.cast_slot_level = cast_slot_level;
				sc.option_keys = {"radiant", "necrotic"};
				sc.option_labels = {"Angelic / fey spirits (radiant damage)", "Fiendish spirits (necrotic damage)"};
				sc.prompt_text = "Spirit Guardians: which form do they take? Press 1 for angelic or fey (radiant damage), or 2 for fiendish (necrotic damage).";
				send_spell_choice_prompt(c, sc);
			}
			else if (spell.id == "fog_cloud") {
				// Fog Cloud: blocks line of sight in 20ft radius
				c.fog_cloud_active = true;
				broadcast_announce(c.name + " conjures a Fog Cloud, obscuring vision in a 20-foot radius!", true);
			}
			else if (spell.id == "darkness") {
				// Darkness: heavily obscures area
				c.darkness_active = true;
				broadcast_announce(c.name + " conjures magical Darkness in a 15-foot radius.", true);
			}
			// ==== UTILITY / BUFF SPELL HANDLERS (batch) ====
			// Cantrips
			else if (spell.id == "blade_ward") {
				// PHB 2024 Blade Ward (cantrip): "Until the start of your next turn, you have
				// Resistance to Bludgeoning, Piercing, and Slashing damage."
				c.blade_ward_active = true;
				broadcast_announce(c.name + " casts Blade Ward, gaining resistance to Bludgeoning, Piercing, and Slashing damage until the start of their next turn.", true);
			}
			else if (spell.id == "dancing_lights") {
				broadcast_announce(c.name + " conjures Dancing Lights, creating up to four torch-sized lights.", true);
			}
			else if (spell.id == "druidcraft") {
				broadcast_announce(c.name + " casts Druidcraft, producing a minor nature effect.", true);
			}
			else if (spell.id == "friends") {
				broadcast_announce(c.name + " casts Friends, gaining advantage on Charisma checks for 1 minute.", true);
			}
			else if (spell.id == "guidance" and @target != null) {
				// Basic Rules 2024 Guidance (para 13659): "Once before the spell ends,
				// the target can add 1d4 to one ability check. The spell then ends."
				// Concentration cantrip. Sets guidance_active on target; consumed in
				// finalize_roll_result on next ROLL_ABILITY_CHECK.
				target.guidance_active = true;
				broadcast_announce(c.name + " casts Guidance on " + target.name + ". They gain 1d4 to their next ability check.", true);
			}
			else if (spell.id == "guidance") {
				// Self-cast variant
				c.guidance_active = true;
				broadcast_announce(c.name + " casts Guidance, gaining 1d4 to the next ability check.", true);
			}
			else if (spell.id == "light") {
				broadcast_announce(c.name + " casts Light, causing an object to shed bright light in a 20-foot radius.", true);
			}
			else if (spell.id == "mage_hand") {
				broadcast_announce(c.name + " conjures a spectral Mage Hand.", true);
			}
			else if (spell.id == "mending") {
				broadcast_announce(c.name + " casts Mending, repairing a small break or tear.", true);
			}
			else if (spell.id == "message") {
				broadcast_announce(c.name + " casts Message, sending a whispered conversation.", true);
			}
			else if (spell.id == "minor_illusion") {
				broadcast_announce(c.name + " casts Minor Illusion, creating a sound or image.", true);
			}
			else if (spell.id == "prestidigitation") {
				broadcast_announce(c.name + " casts Prestidigitation, producing a minor magical effect.", true);
			}
			else if (spell.id == "resistance" and @target != null) {
				// Basic Rules 2024 Resistance (para 14772): "Once before the spell ends,
				// the target can add 1d4 to one saving throw. The spell then ends."
				// Concentration cantrip. Sets resistance_active on target; consumed in
				// get_save_bonus on next saving throw.
				target.resistance_active = true;
				broadcast_announce(c.name + " casts Resistance on " + target.name + ". They gain 1d4 to their next saving throw.", true);
			}
			else if (spell.id == "resistance") {
				// Self-cast variant
				c.resistance_active = true;
				broadcast_announce(c.name + " casts Resistance, gaining 1d4 to the next saving throw.", true);
			}
			else if (spell.id == "spare_the_dying" and @target != null) {
				// Stabilizes a creature at 0 HP
				if (target.current_hp == 0 and !target.is_dead) {
					target.is_stable = true;
					target.death_save_successes = 0;
					target.death_save_failures = 0;
					broadcast_announce(c.name + " casts Spare the Dying on " + target.name + ", stabilizing them.", true);
				} else {
					broadcast_announce(c.name + " casts Spare the Dying on " + target.name + ".", true);
				}
			}
			else if (spell.id == "spare_the_dying") {
				broadcast_announce(c.name + " casts Spare the Dying.", true);
			}
			else if (spell.id == "thaumaturgy") {
				broadcast_announce(c.name + " casts Thaumaturgy, manifesting a minor wonder.", true);
			}
			// Level 1
			else if (spell.id == "alarm") {
				broadcast_announce(c.name + " casts Alarm, warding a 20-foot area.", true);
			}
			else if (spell.id == "animal_friendship") {
				broadcast_announce(c.name + " casts Animal Friendship.", true);
			}
			else if (spell.id == "comprehend_languages") {
				broadcast_announce(c.name + " casts Comprehend Languages.", true);
			}
			else if (spell.id == "create_or_destroy_water") {
				broadcast_announce(c.name + " casts Create or Destroy Water.", true);
			}
			else if (spell.id == "detect_poison_and_disease") {
				broadcast_announce(c.name + " casts Detect Poison and Disease.", true);
			}
			else if (spell.id == "disguise_self") {
				broadcast_announce(c.name + " casts Disguise Self, altering their appearance.", true);
			}
			else if (spell.id == "entangle") {
				// DEX save, restrained in 20 ft square (concentration)
				combatant@[] entangle_targets;
				int ecenter_x = @target != null ? target.x : c.x;
				int ecenter_y = @target != null ? target.y : c.y;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(ecenter_x, ecenter_y, t.x, t.y) <= 20) entangle_targets.insert_last(t);
				}
				broadcast_announce(c.name + " casts Entangle, causing grasping weeds to erupt from the ground!", true);
				for (uint ti = 0; ti < entangle_targets.length(); ti++) {
					combatant@ t = entangle_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_STR);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = t.apply_indomitable_might(save_roll + save_bonus + bless_bonus, ABILITY_STR);
					bool saved = save_total >= save_dc;
					if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(t.name, "STR save vs Entangle", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Restrained!");
					if (!saved) {
						t.add_condition(COND_RESTRAINED);
						t.restrained_spell_caster_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Restrained"}});
					}
				}
			}
			else if (spell.id == "expeditious_retreat") {
				// Basic Rules 2024 Expeditious Retreat (para 13159): "You take the Dash
				// action, and until the spell ends, you can take that action again as a
				// Bonus Action." Concentration.
				c.expeditious_retreat_active = true;
				c.is_concentrating = true;
				c.concentration_spell = spell.name;
				// Immediate Dash: double remaining movement this turn
				c.movement_remaining += c.speed;
				broadcast_announce(c.name + " casts Expeditious Retreat! They dash forward and can Dash as a bonus action each turn.", true);
			}
			else if (spell.id == "feather_fall") {
				broadcast_announce(c.name + " casts Feather Fall, slowing the descent of up to 5 creatures.", true);
			}
			else if (spell.id == "find_familiar") {
				// Basic Rules 2024 Find Familiar (para 13276-13290): "You gain the
				// service of a familiar, a spirit that takes an animal form you choose."
				// Familiar can't attack but aids in combat. Approximated as a low-HP
				// companion with a nominal 1 damage attack (Help action effect from
				// adjacency granting allies advantage is handled by pack_tactics-like
				// proximity — companions count as allies for flanking checks).
				// Dismiss any existing familiar first
				for (uint ff = 0; ff < combat.combatants.length(); ff++) {
					combatant@ old_fam = combat.combatants[ff];
					if (@old_fam != null and old_fam.is_companion and old_fam.owner_id == c.id and old_fam.companion_subclass == "find_familiar") {
						dismiss_companion(old_fam, true);
						break;
					}
				}
				int fam_hp = 1 + c.level; // Scales slightly with caster level
				int fam_ac = 11 + c.proficiency;
				combatant@ familiar = spawn_companion(c, "find_familiar", c.name + "'s Familiar", fam_hp, fam_ac, 30, c.proficiency, 1, 1, 0, DMG_BLUDGEONING, 0);
				if (@familiar != null) {
					familiar.size = SIZE_TINY;
					broadcast_announce(c.name + " summons a spirit familiar! HP " + fam_hp + ", AC " + fam_ac + ". The familiar aids nearby allies.", true);
				}
			}
			else if (spell.id == "goodberry") {
				// Basic Rules 2024 Goodberry (para 13617): "Ten berries appear in your
				// hand... A creature can take a Bonus Action to eat one berry. Eating a
				// berry restores 1 Hit Point." In combat, instantly heal caster 10 HP
				// as a practical approximation (no inventory system for individual berries).
				int gb_heal = 10;
				int old_hp = c.current_hp;
				c.current_hp += gb_heal;
				if (c.current_hp > c.max_hp) c.current_hp = c.max_hp;
				int actual_heal = c.current_hp - old_hp;
				if (actual_heal > 0) {
					broadcast_announce(c.name + " casts Goodberry and eats the berries, healing " + actual_heal + " HP!", true);
				} else {
					broadcast_announce(c.name + " casts Goodberry, but is already at full health.", true);
				}
				try_chalice_healing(c);
			}
			else if (spell.id == "grease") {
				// DEX save in 10 ft area, prone on fail
				combatant@[] grease_targets;
				int gcenter_x = @target != null ? target.x : c.x;
				int gcenter_y = @target != null ? target.y : c.y;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(gcenter_x, gcenter_y, t.x, t.y) <= 10) grease_targets.insert_last(t);
				}
				broadcast_announce(c.name + " conjures a patch of Grease on the ground!", true);
				for (uint ti = 0; ti < grease_targets.length(); ti++) {
					combatant@ t = grease_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(t.name, "DEX save vs Grease", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Prone!");
					if (!saved) {
						t.add_condition(COND_PRONE);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Prone"}});
					}
				}
			}
			else if (spell.id == "identify") {
				broadcast_announce(c.name + " casts Identify, learning the properties of a magic item.", true);
			}
			else if (spell.id == "jump") {
				broadcast_announce(c.name + " casts Jump, tripling their jump distance.", true);
			}
			else if (spell.id == "protection_from_evil_and_good") {
				// Basic Rules 2024 Protection from Evil and Good (para 14688-14691):
				// "one willing creature you touch is protected against Aberrations,
				// Celestials, Elementals, Fey, Fiends, and Undead. Creatures of those
				// types have Disadvantage on attack rolls against the target. The target
				// also can't be possessed by or gain the Charmed or Frightened conditions
				// from them." Concentration.
				combatant@ pfeg_target = (@target != null) ? target : c;
				pfeg_target.protection_from_evil_and_good_active = true;
				pfeg_target.pfeg_source_id = c.id;
				c.is_concentrating = true;
				c.concentration_spell = spell.name;
				broadcast_announce(c.name + " casts Protection from Evil and Good on " + pfeg_target.name + ". Aberrations, celestials, elementals, fey, fiends, and undead have disadvantage on attacks against them and cannot charm or frighten them.", true);
			}
			else if (spell.id == "purify_food_and_drink") {
				broadcast_announce(c.name + " casts Purify Food and Drink.", true);
			}
			else if (spell.id == "shield_of_faith" and @target != null) {
				// Basic Rules 2024 Shield of Faith (para 15004): "A shimmering field
				// appears and surrounds a creature of your choice within range,
				// granting it a +2 bonus to AC for the duration."
				// Uses dedicated fields — shield_active/shield_ac_bonus are shared
				// with Shield reaction and cleared at turn start.
				if (target.shield_of_faith_active) {
					target.armor_class -= 2;
					target.shield_of_faith_active = false;
					target.shield_of_faith_caster_id = 0;
				}
				target.armor_class += 2;
				target.shield_of_faith_active = true;
				target.shield_of_faith_caster_id = c.id;
				broadcast_announce(c.name + " casts Shield of Faith on " + target.name + ". Their AC increases by 2.", true);
			}
			else if (spell.id == "shield_of_faith") {
				// Self-cast variant
				if (c.shield_of_faith_active) {
					c.armor_class -= 2;
					c.shield_of_faith_active = false;
					c.shield_of_faith_caster_id = 0;
				}
				c.armor_class += 2;
				c.shield_of_faith_active = true;
				c.shield_of_faith_caster_id = c.id;
				broadcast_announce(c.name + " casts Shield of Faith, gaining +2 AC.", true);
			}
			else if (spell.id == "silent_image") {
				broadcast_announce(c.name + " casts Silent Image, creating a visual illusion.", true);
			}
			else if (spell.id == "speak_with_animals") {
				broadcast_announce(c.name + " casts Speak with Animals.", true);
			}
			else if (spell.id == "unseen_servant") {
				broadcast_announce(c.name + " casts Unseen Servant, conjuring an invisible force to perform tasks.", true);
			}
			else if (spell.id == "tensers_floating_disk") {
				broadcast_announce(c.name + " casts Tenser's Floating Disk.", true);
			}
			// Level 2
			else if (spell.id == "alter_self") {
				// Basic Rules 2024 Alter Self: L2 Transmutation, Concentration, 1 hour.
				// Combat-relevant option: Natural Weapons — unarmed strike deals 1d6
				// (slashing/piercing/bludgeoning), uses spellcasting ability mod.
				// Aquatic Adaptation has no combat effect in the arena.
				// Implementation: auto-pick Natural Weapons (the only combat option).
				c.is_concentrating = true;
				c.concentration_spell = "Alter Self";
				// Natural Weapons: override unarmed strike damage to 1d6
				// This uses the unarmed_fighting_active flag and overrides the damage
				// die to d6 with spellcasting ability mod instead of STR.
				c.alter_self_natural_weapons = true;
				broadcast_announce(c.name + " casts Alter Self, growing natural weapons! Unarmed strikes deal 1d6 damage using spellcasting ability.", true);
			}
			else if (spell.id == "arcane_lock") {
				broadcast_announce(c.name + " casts Arcane Lock.", true);
			}
			else if (spell.id == "barkskin" and @target != null) {
				// Source: PHB Basic Rules - Barkskin. AC becomes 16 (PHB 2024) / 17 for 1 hour.
				target.equip_ac_bonus += 2;
				broadcast_announce(c.name + " casts Barkskin on " + target.name + ". Their skin hardens like bark, increasing their AC.", true);
			}
			else if (spell.id == "barkskin") {
				c.equip_ac_bonus += 2;
				broadcast_announce(c.name + " casts Barkskin, their skin hardening like bark.", true);
			}
			else if (spell.id == "blur") {
				// PHB 2024 Blur (Level 2, Concentration): "Your body becomes blurred. For
				// the duration, any creature that can see you has Disadvantage on attack
				// rolls against you."
				c.blur_active = true;
				broadcast_announce(c.name + " casts Blur. Their form wavers, imposing Disadvantage on attacks against them.", true);
			}
			else if (spell.id == "continual_flame") {
				broadcast_announce(c.name + " casts Continual Flame, creating a flame that needs no fuel.", true);
			}
			else if (spell.id == "darkvision" and @target != null) {
				target.darkvision = true;
				if (target.darkvision_range < 60) target.darkvision_range = 60;
				broadcast_announce(c.name + " casts Darkvision on " + target.name + ", granting 60 feet of darkvision for 8 hours.", true);
			}
			else if (spell.id == "darkvision") {
				c.darkvision = true;
				if (c.darkvision_range < 60) c.darkvision_range = 60;
				broadcast_announce(c.name + " casts Darkvision, gaining 60 feet of darkvision.", true);
			}
			else if (spell.id == "enhance_ability" and @target != null) {
				target.enhance_ability_active = true;
				target.enhance_ability_caster_id = c.id;
				c.is_concentrating = true;
				c.concentration_spell = "Enhance Ability";
				c.add_condition(COND_CONCENTRATING);
				broadcast_announce(c.name + " casts Enhance Ability on " + target.name + ", granting advantage on all ability checks.", true);
			}
			else if (spell.id == "enhance_ability") {
				c.enhance_ability_active = true;
				c.enhance_ability_caster_id = c.id;
				c.is_concentrating = true;
				c.concentration_spell = "Enhance Ability";
				c.add_condition(COND_CONCENTRATING);
				broadcast_announce(c.name + " casts Enhance Ability on themselves, gaining advantage on all ability checks.", true);
			}
			else if (spell.id == "find_steed") {
				// Basic Rules 2024 Find Steed (para 13291-13297): "You summon a spirit
				// that assumes the form of an Otherworldly Steed." HP = 5+5*level,
				// AC = 10+spellcasting mod, Speed 60, Hooves 1d8+spell_mod.
				// NOT concentration. Dismiss existing steed first.
				for (uint fs = 0; fs < combat.combatants.length(); fs++) {
					combatant@ old_steed = combat.combatants[fs];
					if (@old_steed != null and old_steed.is_companion and old_steed.owner_id == c.id and (old_steed.companion_subclass == "find_steed" or old_steed.companion_subclass == "find_greater_steed")) {
						dismiss_companion(old_steed, true);
						break;
					}
				}
				int spell_mod = get_spellcasting_ability_mod(c);
				int steed_hp = 5 + 5 * c.level;
				int steed_ac = 10 + spell_mod;
				if (steed_ac < 10) steed_ac = 10;
				int steed_atk = c.proficiency + spell_mod;
				combatant@ steed = spawn_companion(c, "find_steed", c.name + "'s Steed", steed_hp, steed_ac, 60, steed_atk, 1, 8, spell_mod, DMG_BLUDGEONING, 0);
				if (@steed != null) {
					steed.size = SIZE_LARGE;
					broadcast_announce(c.name + " summons an otherworldly steed! HP " + steed_hp + ", AC " + steed_ac + ", Speed 60ft, Hooves 1d8+" + spell_mod + " bludgeoning.", true);
				}
			}
			else if (spell.id == "find_traps") {
				broadcast_announce(c.name + " casts Find Traps.", true);
			}
			else if (spell.id == "gentle_repose") {
				broadcast_announce(c.name + " casts Gentle Repose.", true);
			}
			else if (spell.id == "invisibility" and @target != null) {
				target.add_condition(COND_INVISIBLE);
				broadcast_announce(c.name + " casts Invisibility on " + target.name + ". They fade from view.", true);
				broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Invisible"}});
			}
			else if (spell.id == "invisibility") {
				c.add_condition(COND_INVISIBLE);
				broadcast_announce(c.name + " casts Invisibility on themselves and fades from view.", true);
				broadcast_to_battle({{"type", message_types::condition_applied}, {"target", c.name}, {"condition", "Invisible"}});
			}
			else if (spell.id == "knock") {
				broadcast_announce(c.name + " casts Knock, magically unlocking a target.", true);
			}
			else if (spell.id == "levitate") {
				// Basic Rules 2024 Levitate (para 13989-13992): "One creature or loose
				// object of your choice that you can see within range rises vertically up
				// to 20 feet and remains suspended there for the duration." CON save for
				// unwilling targets. Target can't move horizontally. Concentration.
				combatant@ lev_target = (@target != null) ? target : c;
				bool lev_hostile = combat.are_hostile(c, lev_target);
				bool lev_saved = false;
				if (lev_hostile) {
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(lev_target, c.id, save_roll);
					int save_bonus = lev_target.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(lev_target);
					int save_total = save_roll + save_bonus + bless_bonus;
					lev_saved = save_total >= save_dc;
					if (!lev_saved and try_arcane_deflection_save(lev_target, save_dc, save_total)) lev_saved = true;
					if (!lev_saved) { int ds = try_disciplined_survivor_reroll(lev_target, save_dc, save_total, save_bonus + bless_bonus, "CON save vs Levitate"); if (ds >= save_dc) lev_saved = true; }
					if (!lev_saved) { int fg = try_flash_of_genius(lev_target, save_dc, save_total, "CON save vs Levitate"); if (fg >= save_dc) lev_saved = true; }
					if (!lev_saved) { int mv = try_maverick_spirit(lev_target, save_dc, save_total, "CON save vs Levitate"); if (mv >= save_dc) lev_saved = true; }
					if (!lev_saved) { int bf = try_boon_of_fate_bonus(lev_target, save_total, save_dc); if (bf >= save_dc) lev_saved = true; }
					if (!lev_saved and try_stroke_of_luck_save(lev_target, save_dc, save_bonus + bless_bonus)) lev_saved = true;
					broadcast_roll(lev_target.name, "CON save vs Levitate", save_roll, save_bonus + bless_bonus, save_total, lev_saved ? "Saved!" : "Levitated!");
				}
				if (!lev_saved) {
					lev_target.levitate_active = true;
					lev_target.levitate_source_id = c.id;
					lev_target.movement_remaining = 0; // Can't move horizontally
					c.is_concentrating = true;
					c.concentration_spell = spell.name;
					broadcast_announce(c.name + " levitates " + lev_target.name + "! They rise 20 feet and cannot move horizontally.", true);
				}
			}
			else if (spell.id == "locate_animals_or_plants") {
				broadcast_announce(c.name + " casts Locate Animals or Plants.", true);
			}
			else if (spell.id == "magic_mouth") {
				broadcast_announce(c.name + " casts Magic Mouth.", true);
			}
			else if (spell.id == "protection_from_poison" and @target != null) {
				target.poison_resistance = true;
				broadcast_announce(c.name + " casts Protection from Poison on " + target.name + ", granting resistance to poison damage.", true);
			}
			else if (spell.id == "protection_from_poison") {
				c.poison_resistance = true;
				broadcast_announce(c.name + " casts Protection from Poison, gaining resistance to poison damage.", true);
			}
			else if (spell.id == "rope_trick") {
				broadcast_announce(c.name + " casts Rope Trick.", true);
			}
			else if (spell.id == "see_invisibility") {
				// Basic Rules 2024 See Invisibility (para 14864): "you see creatures and
				// objects that have the Invisible condition as if they were visible."
				// NOT concentration. Duration 1 hour.
				c.see_invisibility_active = true;
				broadcast_announce(c.name + " casts See Invisibility! They can now see invisible creatures.", true);
			}
			else if (spell.id == "silence") {
				// Basic Rules 2024 Silence: 20ft sphere, blocks spellcasting (verbal component),
				// Thunder immunity, Deafened inside. Centered on a chosen point.
				int sx = @target != null ? target.x : c.x;
				int sy = @target != null ? target.y : c.y;
				c.silence_active = true;
				c.silence_x = sx;
				c.silence_y = sy;
				c.is_concentrating = true;
				c.concentration_spell = "Silence";
				c.add_condition(COND_CONCENTRATING);
				broadcast_announce(c.name + " casts Silence! A 20-foot sphere of silence appears. No spells can be cast inside it.", true);
				// Apply Deafened to creatures currently inside
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead) continue;
					if (feet_distance(sx, sy, t.x, t.y) <= 20) {
						if (!t.has_condition(COND_DEAFENED)) {
							t.add_condition(COND_DEAFENED);
							broadcast_announce(t.name + " is Deafened by the Silence!", false);
						}
					}
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "spider_climb" and @target != null) {
				broadcast_announce(c.name + " casts Spider Climb on " + target.name + ", granting them a climb speed equal to their walking speed.", true);
			}
			else if (spell.id == "spider_climb") {
				c.climb_speed = c.speed;
				broadcast_announce(c.name + " casts Spider Climb, gaining a climb speed.", true);
			}
			else if (spell.id == "zone_of_truth") {
				broadcast_announce(c.name + " casts Zone of Truth, creating a 15-foot radius where creatures cannot speak lies.", true);
			}
			// Level 3
			else if (spell.id == "clairvoyance") {
				broadcast_announce(c.name + " casts Clairvoyance.", true);
			}
			else if (spell.id == "create_food_and_water") {
				broadcast_announce(c.name + " casts Create Food and Water.", true);
			}
			else if (spell.id == "daylight") {
				broadcast_announce(c.name + " casts Daylight, illuminating a 60-foot radius.", true);
			}
			else if (spell.id == "feign_death") {
				// Basic Rules 2024 Feign Death (para 13203-13212): "You touch a willing
				// creature and put it into a cataleptic state that is indistinguishable
				// from death. The target is Blinded and Incapacitated, and its Speed
				// becomes 0. The target has Resistance to all damage except Psychic damage."
				// NOT concentration. Ritual. 1 hour duration (effectively full combat).
				combatant@ fd_target = @target != null ? target : c;
				if (feet_distance(c.x, c.y, fd_target.x, fd_target.y) > 5) {
					user@ fu = find_user_for_combatant(c);
					if (@fu != null) fu.send({{"type", message_types::error}, {"text", "Feign Death requires touch range (5 feet). Target is " + feet_distance(c.x, c.y, fd_target.x, fd_target.y) + " feet away."}});
					return;
				}
				fd_target.feign_death_active = true;
				fd_target.feign_death_original_speed = fd_target.speed;
				fd_target.speed = 0;
				fd_target.movement_remaining = 0;
				fd_target.add_condition(COND_BLINDED);
				fd_target.add_condition(COND_INCAPACITATED);
				broadcast_announce(c.name + " casts Feign Death on " + fd_target.name + "! They appear dead — Blinded, Incapacitated, Speed 0, resistant to all damage except Psychic.", true);
			}
			else if (spell.id == "glyph_of_warding") {
				broadcast_announce(c.name + " casts Glyph of Warding.", true);
			}
			else if (spell.id == "magic_circle") {
				broadcast_announce(c.name + " casts Magic Circle.", true);
			}
			else if (spell.id == "meld_into_stone") {
				broadcast_announce(c.name + " casts Meld into Stone.", true);
			}
			else if (spell.id == "nondetection") {
				broadcast_announce(c.name + " casts Nondetection.", true);
			}
			else if (spell.id == "phantom_steed") {
				// Basic Rules 2024 Phantom Steed (para 14583-14590): "A Large quasi-real
				// horse-like creature appears on the ground. The creature uses the
				// Otherworldly Steed stat block with Speed 100 feet." Lasts 1 hour,
				// NOT concentration. Primarily a mount — in combat context, spawned
				// as a fast companion with decent HP.
				for (uint ps = 0; ps < combat.combatants.length(); ps++) {
					combatant@ old_ps = combat.combatants[ps];
					if (@old_ps != null and old_ps.is_companion and old_ps.owner_id == c.id and old_ps.companion_subclass == "phantom_steed") {
						dismiss_companion(old_ps, true);
						break;
					}
				}
				int ps_hp = 1;  // Source: quasi-real, disappears when hit
				int ps_ac = 13;
				combatant@ phantom = spawn_companion(c, "phantom_steed", c.name + "'s Phantom Steed", ps_hp, ps_ac, 100, c.proficiency, 1, 6, 0, DMG_BLUDGEONING, 0);
				if (@phantom != null) {
					phantom.size = SIZE_LARGE;
					broadcast_announce(c.name + " conjures a phantom steed! AC 13, Speed 100ft. The steed vanishes when struck.", true);
				}
			}
			else if (spell.id == "protection_from_energy" and @target != null) {
				// Basic Rules 2024 Protection from Energy (para 14707): "the willing
				// creature you touch has Resistance to one damage type of your choice:
				// Acid, Cold, Fire, Lightning, or Thunder." Concentration, level 3.
				// Prompt the caster to choose the damage type via the spell choice system.
				pending_spell_choice sc;
				sc.player_username = c.player_username;
				sc.caster_id = c.id;
				sc.spell_id = "protection_from_energy";
				sc.cast_slot_level = cast_slot_level;
				sc.primary_target_id = target.id;
				sc.option_keys = {"acid", "cold", "fire", "lightning", "thunder"};
				sc.option_labels = {"Acid", "Cold", "Fire", "Lightning", "Thunder"};
				sc.prompt_text = "Protection from Energy: choose a damage type. Press 1 for Acid, 2 for Cold, 3 for Fire, 4 for Lightning, or 5 for Thunder.";
				send_spell_choice_prompt(c, sc);
			}
			else if (spell.id == "protection_from_energy") {
				// Self-cast variant
				pending_spell_choice sc;
				sc.player_username = c.player_username;
				sc.caster_id = c.id;
				sc.spell_id = "protection_from_energy";
				sc.cast_slot_level = cast_slot_level;
				sc.primary_target_id = c.id;
				sc.option_keys = {"acid", "cold", "fire", "lightning", "thunder"};
				sc.option_labels = {"Acid", "Cold", "Fire", "Lightning", "Thunder"};
				sc.prompt_text = "Protection from Energy: choose a damage type. Press 1 for Acid, 2 for Cold, 3 for Fire, 4 for Lightning, or 5 for Thunder.";
				send_spell_choice_prompt(c, sc);
			}
			else if (spell.id == "remove_curse" and @target != null and !target.is_dead) {
				// Basic Rules 2024 Remove Curse (para 14774-14775): "At your touch, all
				// curses affecting one creature or object end." Touch = 5ft range.
				int rc_dist = feet_distance(c.x, c.y, target.x, target.y);
				if (rc_dist > 5) {
					broadcast_announce(target.name + " is too far away! Remove Curse requires touch (5 ft).", false);
					return;
				}
				bool removed_any = false;
				// Remove Bestow Curse
				if (target.bestow_curse_type != "") {
					// Find the caster of Bestow Curse and break their concentration
					if (target.bestow_curse_source_id != 0) {
						combatant@ bc_caster = combat.get_combatant(target.bestow_curse_source_id);
						if (@bc_caster != null and bc_caster.is_concentrating and bc_caster.concentration_spell == "Bestow Curse") {
							bc_caster.is_concentrating = false;
							bc_caster.concentration_spell = "";
						}
					}
					target.bestow_curse_type = "";
					target.bestow_curse_source_id = 0;
					broadcast_announce("Bestow Curse is lifted from " + target.name + "!", true);
					removed_any = true;
				}
				// Remove Hex curse
				for (uint rci = 0; rci < combat.combatants.length(); rci++) {
					combatant@ hex_c = combat.combatants[rci];
					if (@hex_c == null or hex_c.is_dead) continue;
					if (hex_c.hex_target_id == target.id) {
						hex_c.hex_target_id = 0;
						hex_c.hex_cursed_ability = -1;
						if (hex_c.is_concentrating and hex_c.concentration_spell == "Hex") {
							hex_c.is_concentrating = false;
							hex_c.concentration_spell = "";
						}
						broadcast_announce("Hex is lifted from " + target.name + "!", true);
						removed_any = true;
						break;
					}
				}
				// Remove Hexblade's Curse
				for (uint hbi = 0; hbi < combat.combatants.length(); hbi++) {
					combatant@ hb_c = combat.combatants[hbi];
					if (@hb_c == null or hb_c.is_dead) continue;
					if (hb_c.hexblade_curse_target == target.id) {
						hb_c.hexblade_curse_target = 0;
						broadcast_announce("Hexblade's Curse is lifted from " + target.name + "!", true);
						removed_any = true;
						break;
					}
				}
				if (!removed_any) {
					broadcast_announce(c.name + " casts Remove Curse on " + target.name + ", but no curses were found.", true);
				} else {
					broadcast_announce(c.name + " casts Remove Curse, freeing " + target.name + " from all curses!", true);
					broadcast_state();
				}
			}
			else if (spell.id == "sending") {
				broadcast_announce(c.name + " casts Sending, delivering a short telepathic message.", true);
			}
			else if (spell.id == "water_breathing") {
				broadcast_announce(c.name + " casts Water Breathing.", true);
			}
			else if (spell.id == "water_walk") {
				broadcast_announce(c.name + " casts Water Walk.", true);
			}
			// Level 4
			else if (spell.id == "arcane_eye") {
				broadcast_announce(c.name + " casts Arcane Eye.", true);
			}
			else if (spell.id == "compulsion") {
				// Basic Rules 2024 Compulsion (para 12594-12597): "Each creature of your
				// choice that you can see within range must succeed on a Wisdom saving throw
				// or have the Charmed condition until the spell ends." WIS save, AoE,
				// concentration. End-of-turn re-save.
				c.is_concentrating = true;
				c.concentration_spell = spell.name;
				int compulsion_hits = 0;
				for (uint ci = 0; ci < combat.combatants.length(); ci++) {
					combatant@ ct = combat.combatants[ci];
					if (@ct == null or ct.is_dead or ct.id == c.id) continue;
					if (!combat.are_hostile(c, ct)) continue;
					if (feet_distance(c.x, c.y, ct.x, ct.y) > 30) continue;
					if (!combat.can_see(c, ct)) continue;
					int save_roll = random(1, 20);
					if (ct.staggering_blow_active) { int sb2 = random(1, 20); if (sb2 < save_roll) save_roll = sb2; ct.staggering_blow_active = false; }
					apply_hound_save_disadvantage(ct, c.id, save_roll);
					int save_bonus = ct.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(ct);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					if (!saved and try_arcane_deflection_save(ct, save_dc, save_total)) saved = true;
					if (!saved and try_countercharm_reroll(ct, save_dc, save_bonus + bless_bonus, "WIS save vs Compulsion")) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(ct, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Compulsion"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(ct, save_dc, save_total, "WIS save vs Compulsion"); if (fg >= save_dc) saved = true; }
					if (!saved) { int mv = try_maverick_spirit(ct, save_dc, save_total, "WIS save vs Compulsion"); if (mv >= save_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(ct, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(ct, save_total, save_dc); if (bf >= save_dc) saved = true; }
					if (!saved and try_stroke_of_luck_save(ct, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(ct.name, "WIS save vs Compulsion", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
					if (!saved) {
						ct.add_condition(COND_CHARMED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", ct.name}, {"condition", "Charmed"}});
						compulsion_hits++;
					}
				}
				if (compulsion_hits > 0) {
					broadcast_announce(c.name + " casts Compulsion! " + compulsion_hits + " creature" + (compulsion_hits > 1 ? "s are" : " is") + " charmed and forced to move as directed.", true);
				} else {
					broadcast_announce(c.name + " casts Compulsion, but all targets resist!", true);
				}
			}
			else if (spell.id == "confusion") {
				// WIS save in 10 ft radius; on fail, target is incapacitated (confused)
				combatant@[] conf_targets;
				int ccenter_x = @target != null ? target.x : c.x;
				int ccenter_y = @target != null ? target.y : c.y;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(ccenter_x, ccenter_y, t.x, t.y) <= 10) conf_targets.insert_last(t);
				}
				broadcast_announce(c.name + " casts Confusion!", true);
				for (uint ti = 0; ti < conf_targets.length(); ti++) {
					combatant@ t = conf_targets[ti];
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (WIS — Confused/Incapacitated condition)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Confusion"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "WIS save vs Confusion"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "WIS save vs Confusion"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					if (bless_bonus > 0) broadcast_announce(t.name + "'s Bless adds " + bless_bonus + " to the save.", false);
					broadcast_roll(t.name, "WIS save vs Confusion", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Confused!");
					if (!saved) {
						t.add_condition(COND_INCAPACITATED);
						t.incap_spell_caster_id = c.id;
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Confused"}});
					}
				}
			}
			else if (spell.id == "control_water") {
				broadcast_announce(c.name + " casts Control Water.", true);
			}
			else if (spell.id == "divination") {
				broadcast_announce(c.name + " casts Divination.", true);
			}
			else if (spell.id == "freedom_of_movement" and @target != null) {
				// PHB 2024 Freedom of Movement (Level 4, non-concentration): "the target's
				// movement is unaffected by Difficult Terrain, and spells and other magical
				// effects can neither reduce the target's Speed nor cause the target to have
				// the Paralyzed or Restrained condition."
				target.freedom_of_movement_active = true;
				broadcast_announce(c.name + " casts Freedom of Movement on " + target.name + ". They are immune to Paralyzed and Restrained conditions and ignore speed reductions.", true);
			}
			else if (spell.id == "freedom_of_movement") {
				// Self-cast variant
				c.freedom_of_movement_active = true;
				broadcast_announce(c.name + " casts Freedom of Movement. They are immune to Paralyzed and Restrained conditions and ignore speed reductions.", true);
			}
			else if (spell.id == "locate_creature") {
				broadcast_announce(c.name + " casts Locate Creature.", true);
			}
			else if (spell.id == "private_sanctum") {
				broadcast_announce(c.name + " casts Private Sanctum.", true);
			}
			else if (spell.id == "resilient_sphere" and @target != null) {
				// Basic Rules 2024 Resilient Sphere (para 14777-14779): "A shimmering
				// sphere encloses a Large or smaller creature or object within range. An
				// unwilling creature must succeed on a Dexterity saving throw or be enclosed
				// for the duration. Nothing can pass through the barrier. The sphere is
				// immune to all damage." NOT concentration. 1 minute duration.
				bool rs_hostile = combat.are_hostile(c, target);
				bool rs_saved = false;
				if (rs_hostile) {
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(target, c.id, save_roll);
					int save_bonus = target.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(target);
					int save_total = save_roll + save_bonus + bless_bonus;
					rs_saved = save_total >= save_dc;
					if (!rs_saved and try_arcane_deflection_save(target, save_dc, save_total)) rs_saved = true;
					if (!rs_saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "DEX save vs Resilient Sphere"); if (ds >= save_dc) rs_saved = true; }
					if (!rs_saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "DEX save vs Resilient Sphere"); if (fg >= save_dc) rs_saved = true; }
					if (!rs_saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "DEX save vs Resilient Sphere"); if (mv >= save_dc) rs_saved = true; }
					if (!rs_saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) rs_saved = true; }
					if (!rs_saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) rs_saved = true;
					broadcast_roll(target.name, "DEX save vs Resilient Sphere", save_roll, save_bonus + bless_bonus, save_total, rs_saved ? "Saved!" : "Trapped!");
				}
				if (!rs_saved) {
					target.resilient_sphere_trapped = true;
					target.resilient_sphere_source_id = c.id;
					target.resilient_sphere_rounds = 10; // 1 minute = 10 rounds
					target.add_condition(COND_INCAPACITATED);
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Incapacitated"}});
					broadcast_announce(c.name + " traps " + target.name + " in a Resilient Sphere! They are immune to all damage but cannot act. (10 rounds)", true);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "resilient_sphere") {
				broadcast_announce(c.name + " casts Resilient Sphere but has no target.", false);
			}
			else if (spell.id == "secret_chest") {
				broadcast_announce(c.name + " casts Secret Chest.", true);
			}
			else if (spell.id == "stone_shape") {
				broadcast_announce(c.name + " casts Stone Shape.", true);
			}
			// Level 5
			else if (spell.id == "animate_objects") {
				// Basic Rules 2024 Animate Objects (para 11917): spawn Animated Object constructs
				// equal to spellcasting ability modifier (Tiny size, AC 14, HP 20).
				int spell_mod = c.get_ability_mod(ABILITY_INT);
				if (c.class_name == "Bard" or c.class_name == "Sorcerer" or c.class_name == "Warlock") spell_mod = c.get_ability_mod(ABILITY_CHA);
				else if (c.class_name == "Druid" or c.class_name == "Cleric" or c.class_name == "Ranger") spell_mod = c.get_ability_mod(ABILITY_WIS);
				if (spell_mod < 1) spell_mod = 1;
				if (spell_mod > 10) spell_mod = 10;
				c.is_concentrating = true;
				c.concentration_spell = "Animate Objects";
				c.add_condition(COND_CONCENTRATING);
				int ao_spawned = 0;
				for (int aoi = 0; aoi < spell_mod; aoi++) {
					combatant@ obj = spawn_companion(c, "animate_objects", "Animated Object", 20, 14, 30, c.proficiency + 4, 1, 4, 4, DMG_BLUDGEONING);
					if (@obj != null) ao_spawned++;
				}
				broadcast_announce(c.name + " casts Animate Objects! " + ao_spawned + " Tiny constructs spring to life!", true);
				broadcast_state();
				return;
			}
			else if (spell.id == "commune") {
				broadcast_announce(c.name + " casts Commune.", true);
			}
			else if (spell.id == "commune_with_nature") {
				broadcast_announce(c.name + " casts Commune with Nature.", true);
			}
			else if (spell.id == "creation") {
				broadcast_announce(c.name + " casts Creation.", true);
			}
			else if (spell.id == "dream") {
				broadcast_announce(c.name + " casts Dream.", true);
			}
			else if (spell.id == "geas" and @target != null) {
				// Basic Rules 2024 Geas (para 13062-13072): "If the target fails a Wisdom
				// saving throw, it becomes Charmed by you for the Duration. While Charmed,
				// the creature takes 5d10 Psychic damage each time it acts in a manner
				// directly counter to your instructions." WIS save, 30 days, NOT concentration.
				if (target.id == c.id) {
					user@ gu = find_user_for_combatant(c);
					if (@gu != null) gu.send({{"type", message_types::error}, {"text", "Geas must target another creature."}});
					return;
				}
				int geas_bonus = target.get_save_bonus(ABILITY_WIS);
				int geas_natural = random(1, 20);
				int geas_save = geas_natural + geas_bonus;
				int geas_dc = spell_save_dc(c, "geas");
				bool geas_saved = geas_save >= geas_dc;
				broadcast_roll(target.name, "WIS save vs Geas", geas_natural, geas_bonus, geas_save, geas_saved ? "Saved!" : "Failed! Charmed.");
				if (!geas_saved) {
					if (try_arcane_deflection_save(target, geas_dc, geas_save)) geas_saved = true;
					if (!geas_saved and try_countercharm_reroll(target, geas_dc, geas_bonus, "WIS save vs Geas")) geas_saved = true;
					if (!geas_saved) { int ds = try_disciplined_survivor_reroll(target, geas_dc, geas_save, geas_bonus, "WIS save vs Geas"); if (ds >= geas_dc) geas_saved = true; }
					if (!geas_saved) { int fg = try_flash_of_genius(target, geas_dc, geas_save, "WIS save vs Geas"); if (fg >= geas_dc) { geas_saved = true; geas_save = fg; } }
					if (!geas_saved) { int mv = try_maverick_spirit(target, geas_dc, geas_save, "WIS save vs Geas"); if (mv >= geas_dc) { geas_saved = true; geas_save = mv; } }
					if (!geas_saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) geas_saved = true;
					if (!geas_saved) { int bf = try_boon_of_fate_bonus(target, geas_save, geas_dc); if (bf >= geas_dc) { geas_saved = true; geas_save = bf; } }
					if (!geas_saved and try_stroke_of_luck_save(target, geas_dc, geas_bonus)) geas_saved = true;
					if (!geas_saved) {
						target.add_condition(COND_CHARMED);
						target.charm_spell_caster_id = c.id;
						target.geas_source_id = c.id;
						broadcast_announce(target.name + " is bound by Geas! Charmed, and will take 5d10 psychic damage for acting against the command.", true);
					}
				}
			}
			else if (spell.id == "legend_lore") {
				broadcast_announce(c.name + " casts Legend Lore.", true);
			}
			else if (spell.id == "mislead") {
				// Basic Rules 2024 Mislead (COMPLETE_SPELL_CATALOG): "You gain the Invisible
				// condition at the same time that an illusory double of you appears where you
				// are standing. The invisibility ends immediately after you make an attack
				// roll, deal damage, or cast a spell." Concentration, 1 hour.
				c.add_condition(COND_INVISIBLE);
				c.is_hidden = true;
				c.is_concentrating = true;
				c.add_condition(COND_CONCENTRATING);
				c.concentration_spell = spell.name;
				broadcast_announce(c.name + " vanishes and leaves behind an illusory double! Invisible until attacking, dealing damage, or casting a spell.", true);
			}
			else if (spell.id == "modify_memory") {
				broadcast_announce(c.name + " casts Modify Memory.", true);
			}
			else if (spell.id == "passwall") {
				broadcast_announce(c.name + " casts Passwall.", true);
			}
			else if (spell.id == "planar_binding") {
				broadcast_announce(c.name + " casts Planar Binding.", true);
			}
			else if (spell.id == "rary_telepathic_bond") {
				broadcast_announce(c.name + " casts Rary's Telepathic Bond.", true);
			}
			else if (spell.id == "scrying") {
				broadcast_announce(c.name + " casts Scrying.", true);
			}
			else if (spell.id == "seeming") {
				broadcast_announce(c.name + " casts Seeming.", true);
			}
			else if (spell.id == "swift_quiver") {
				// Basic Rules 2024 Swift Quiver (para 15218): concentration, bonus action
				// for 2 ranged weapon attacks each turn until the spell ends.
				if (!c.main_hand_is_ranged) {
					broadcast_announce(c.name + " casts Swift Quiver but has no ranged weapon equipped!", true);
				} else {
					c.swift_quiver_active = true;
					c.is_concentrating = true;
					c.add_condition(COND_CONCENTRATING);
					c.concentration_spell = "Swift Quiver";
					broadcast_announce(c.name + " casts Swift Quiver! Endless ammunition flows from their quiver. Bonus action for 2 ranged attacks each turn.", true);
				}
			}
			else if (spell.id == "telekinesis" and @target != null) {
				// Basic Rules 2024 Telekinesis (para 14871-14879): "You can try to move a
				// Huge or smaller creature. Make an ability check with your spellcasting
				// ability contested by the creature's Strength check. If you win the contest,
				// you move the creature up to 30 feet in any direction... Until the end of
				// your next turn, the creature is Restrained in your telekinetic grip."
				// Concentration. Approximated as STR save vs spell DC.
				if (target.size > SIZE_HUGE) {
					user@ tu = find_user_for_combatant(c);
					if (@tu != null) tu.send({{"type", message_types::error}, {"text", "Telekinesis can only affect Huge or smaller creatures."}});
					return;
				}
				int tk_bonus = target.get_save_bonus(ABILITY_STR);
				int tk_natural = random(1, 20);
				int tk_save = tk_natural + tk_bonus;
				int tk_dc = spell_save_dc(c, "telekinesis");
				bool tk_saved = tk_save >= tk_dc;
				broadcast_roll(target.name, "STR save vs Telekinesis", tk_natural, tk_bonus, tk_save, tk_saved ? "Resists!" : "Grabbed!");
				if (!tk_saved) {
					if (try_arcane_deflection_save(target, tk_dc, tk_save)) tk_saved = true;
					if (!tk_saved) { int fg = try_flash_of_genius(target, tk_dc, tk_save, "STR save vs Telekinesis"); if (fg >= tk_dc) { tk_saved = true; tk_save = fg; } }
					if (!tk_saved) { int bf = try_boon_of_fate_bonus(target, tk_save, tk_dc); if (bf >= tk_dc) { tk_saved = true; tk_save = bf; } }
					if (!tk_saved and try_stroke_of_luck_save(target, tk_dc, tk_bonus)) tk_saved = true;
					if (!tk_saved) {
						// Move target 30ft away from caster
						int tk_push_dist = 6; // 30ft = 6 tiles
						int tk_dx = target.x - c.x;
						int tk_dy = target.y - c.y;
						// Normalize to direction
						if (tk_dx > 0) tk_dx = 1;
						else if (tk_dx < 0) tk_dx = -1;
						if (tk_dy > 0) tk_dy = 1;
						else if (tk_dy < 0) tk_dy = -1;
						if (tk_dx == 0 and tk_dy == 0) tk_dx = 1; // Default push direction
						int tk_moved = 0;
						for (int tki = 0; tki < tk_push_dist; tki++) {
							int nx = target.x + tk_dx;
							int ny = target.y + tk_dy;
							if (nx < 0 or nx >= combat.map_width or ny < 0 or ny >= combat.map_height) break;
							target.x = nx;
							target.y = ny;
							tk_moved++;
						}
						target.add_condition(COND_RESTRAINED);
						target.restrained_spell_caster_id = c.id;
						target.telekinesis_source_id = c.id;
						c.is_concentrating = true;
						c.add_condition(COND_CONCENTRATING);
						c.concentration_spell = spell.name;
						broadcast_announce(c.name + " seizes " + target.name + " with Telekinesis! Moved " + (tk_moved * 5) + " feet and Restrained in telekinetic grip.", true);
					}
				} else {
					// Still set concentration even on save — caster can retry next turn
					c.is_concentrating = true;
					c.add_condition(COND_CONCENTRATING);
					c.concentration_spell = spell.name;
					broadcast_announce(c.name + " casts Telekinesis on " + target.name + " but they resist the grip!", true);
				}
			}
			else if (spell.id == "teleportation_circle") {
				broadcast_announce(c.name + " casts Teleportation Circle.", true);
			}
			else if (spell.id == "tree_stride") {
				broadcast_announce(c.name + " casts Tree Stride.", true);
			}
			// Level 6
			else if (spell.id == "find_the_path") {
				broadcast_announce(c.name + " casts Find the Path.", true);
			}
			else if (spell.id == "guards_and_wards") {
				broadcast_announce(c.name + " casts Guards and Wards.", true);
			}
			else if (spell.id == "heroes_feast") {
				// Basic Rules 2024 Heroes' Feast (para 13760-13763): "Up to twelve
				// creatures can partake of the feast. A creature that partakes gains
				// several benefits... Resistance to Poison damage, Immunity to the
				// Frightened and Poisoned conditions. Its Hit Point maximum also
				// increases by 2d10, and it gains the same number of Hit Points."
				// NOT concentration. 24 hours. Apply to all allies in combat.
				string feast_names = "";
				for (uint fi = 0; fi < combat.combatants.length(); fi++) {
					combatant@ fc = combat.combatants[fi];
					if (@fc == null or fc.is_dead) continue;
					if (combat.are_hostile(c, fc)) continue;
					if (fc.heroes_feast_active) continue; // Already feasting
					int feast_hp = random(1, 10) + random(1, 10);
					fc.heroes_feast_active = true;
					fc.heroes_feast_hp_bonus = feast_hp;
					fc.max_hp += feast_hp;
					fc.current_hp += feast_hp;
					// Remove existing poisoned/frightened conditions
					if (fc.has_condition(COND_POISONED)) fc.remove_condition(COND_POISONED);
					if (fc.has_condition(COND_FRIGHTENED)) fc.remove_condition(COND_FRIGHTENED);
					if (feast_names.length() > 0) feast_names += ", ";
					feast_names += fc.name + " (+" + feast_hp + " HP)";
				}
				broadcast_announce(c.name + " casts Heroes' Feast! Allies gain max HP, poison resistance, and immunity to fear and poison: " + feast_names, true);
			}
			else if (spell.id == "magic_jar") {
				broadcast_announce(c.name + " casts Magic Jar.", true);
			}
			else if (spell.id == "move_earth") {
				broadcast_announce(c.name + " casts Move Earth.", true);
			}
			else if (spell.id == "programmed_illusion") {
				broadcast_announce(c.name + " casts Programmed Illusion.", true);
			}
			else if (spell.id == "true_seeing") {
				// Basic Rules 2024 True Seeing (para 15368): NOT concentration per 2024.
				// Grants Truesight 120ft for 1 hour — see invisible, see through illusions.
				combatant@ ts_target = @target;
				if (@ts_target == null or ts_target.is_dead) @ts_target = c; // Self if no target
				ts_target.true_seeing_active = true;
				if (ts_target.id == c.id) {
					broadcast_announce(c.name + " casts True Seeing on themselves! Truesight 120 feet.", true);
				} else {
					broadcast_announce(c.name + " casts True Seeing on " + ts_target.name + "! Truesight 120 feet.", true);
				}
			}
			else if (spell.id == "word_of_recall") {
				broadcast_announce(c.name + " casts Word of Recall.", true);
			}
			// Level 7
			else if (spell.id == "etherealness") {
				broadcast_announce(c.name + " casts Etherealness.", true);
			}
			else if (spell.id == "mage_seeing") {
				broadcast_announce(c.name + " casts Mage Seeing.", true);
			}
			else if (spell.id == "magnificent_mansion") {
				broadcast_announce(c.name + " casts Magnificent Mansion.", true);
			}
			else if (spell.id == "mirage_arcane") {
				broadcast_announce(c.name + " casts Mirage Arcane.", true);
			}
			else if (spell.id == "plane_shift" and @target != null) {
				// Basic Rules 2024 Plane Shift (para 14601-14608): Unwilling target:
				// "Choose a creature within your reach and make a melee spell attack
				// against it. On a hit, the creature must make a CHA saving throw.
				// On a failed save, the creature is transported to a random location
				// on the plane you specify." Touch range (5ft). Instantaneous.
				if (feet_distance(c.x, c.y, target.x, target.y) > 5) {
					user@ psu = find_user_for_combatant(c);
					if (@psu != null) psu.send({{"type", message_types::error}, {"text", "Plane Shift requires touch range (5 feet). Target is " + feet_distance(c.x, c.y, target.x, target.y) + " feet away."}});
					return;
				}
				// Melee spell attack
				int ps_attack = random(1, 20) + spell_attack_bonus(c);
				bool ps_hit = ps_attack >= target.armor_class;
				broadcast_roll(c.name, "spell attack vs " + target.name, ps_attack - spell_attack_bonus(c), spell_attack_bonus(c), ps_attack, ps_hit ? "Hit!" : "Miss!");
				if (ps_hit) {
					int ps_bonus = target.get_save_bonus(ABILITY_CHA);
					int ps_natural = random(1, 20);
					int ps_save = ps_natural + ps_bonus;
					int ps_dc = spell_save_dc(c, "plane_shift");
					bool ps_saved = ps_save >= ps_dc;
					broadcast_roll(target.name, "CHA save vs Plane Shift", ps_natural, ps_bonus, ps_save, ps_saved ? "Resists!" : "Banished!");
					if (!ps_saved) {
						if (try_arcane_deflection_save(target, ps_dc, ps_save)) ps_saved = true;
						if (!ps_saved) { int fg = try_flash_of_genius(target, ps_dc, ps_save, "CHA save vs Plane Shift"); if (fg >= ps_dc) { ps_saved = true; ps_save = fg; } }
						if (!ps_saved) { int bf = try_boon_of_fate_bonus(target, ps_save, ps_dc); if (bf >= ps_dc) { ps_saved = true; ps_save = bf; } }
						if (!ps_saved and try_stroke_of_luck_save(target, ps_dc, ps_bonus)) ps_saved = true;
						if (!ps_saved) {
							broadcast_announce(target.name + " is transported to another plane by Plane Shift! Removed from combat!", true);
							target.current_hp = 0;
							target.is_dead = true;
							check_battle_end();
						}
					}
				}
			}
			else if (spell.id == "plane_shift" and @target == null) {
				// Self/willing cast — transport caster and allies out of combat
				broadcast_announce(c.name + " casts Plane Shift, transporting themselves to another plane!", true);
			}
			else if (spell.id == "project_image") {
				broadcast_announce(c.name + " casts Project Image.", true);
			}
			else if (spell.id == "sequester") {
				broadcast_announce(c.name + " casts Sequester.", true);
			}
			else if (spell.id == "simulacrum") {
				broadcast_announce(c.name + " casts Simulacrum.", true);
			}
			else if (spell.id == "teleport") {
				broadcast_announce(c.name + " casts Teleport.", true);
			}
			// Level 8
			else if (spell.id == "antimagic_field") {
				// Basic Rules 2024 Antimagic Field (para 11938-11945): "An aura of
				// antimagic surrounds you in 10-foot Emanation. No one can cast spells,
				// take Magic actions, or create other magical effects inside the aura."
				// Concentration. Spellcasting block is enforced in handle_cast.
				c.antimagic_field_active = true;
				c.is_concentrating = true;
				c.concentration_spell = spell.name;
				broadcast_announce(c.name + " activates an Antimagic Field! All magic is suppressed within 10 feet.", true);
			}
			else if (spell.id == "antipathy_sympathy") {
				broadcast_announce(c.name + " casts Antipathy/Sympathy.", true);
			}
			else if (spell.id == "clone") {
				broadcast_announce(c.name + " casts Clone.", true);
			}
			else if (spell.id == "control_weather") {
				broadcast_announce(c.name + " casts Control Weather.", true);
			}
			else if (spell.id == "demiplane") {
				broadcast_announce(c.name + " casts Demiplane.", true);
			}
			else if (spell.id == "dominate_monster" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				if (target.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				if (bless_bonus > 0) broadcast_announce(target.name + "'s Bless adds " + bless_bonus + " to the save.", false);
				broadcast_roll(target.name, "WIS save vs Dominate Monster", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Dominate Monster")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Dominate Monster"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Dominate Monster"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Dominate Monster"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_CHARMED);
					target.charm_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Charmed"}});
					broadcast_announce(target.name + " is dominated by " + c.name + "!", true);
				}
			}
			else if (spell.id == "glibness") {
				// Basic Rules 2024 Glibness (para 13139-13144): Level 8 Enchantment.
				// Self, 1 hour, NOT concentration. "when you make a Charisma check, you
				// can replace the number you roll with a 15."
				c.glibness_active = true;
				broadcast_announce(c.name + " casts Glibness! Charisma checks can't roll below 15.", true);
			}
			else if (spell.id == "mind_blank") {
				// Basic Rules 2024 Mind Blank (para 13755-13761): Level 8 Abjuration.
				// Touch, 24 hours, NOT concentration. "one willing creature you touch has
				// Immunity to Psychic damage and the Charmed condition."
				combatant@ mb_target = @target != null ? target : c;
				// Touch range check (5ft)
				if (@mb_target != c and feet_distance(c.x, c.y, mb_target.x, mb_target.y) > 5) {
					u.send({{"type", message_types::error}, {"text", c.name + " can't reach " + mb_target.name + " — Mind Blank requires Touch range (5 ft)."}});
					return;
				}
				mb_target.mind_blank_active = true;
				// Remove existing Charmed condition
				if (mb_target.has_condition(COND_CHARMED)) {
					mb_target.remove_condition(COND_CHARMED);
					broadcast_announce(mb_target.name + " is freed from charm!", false);
				}
				if (@mb_target == c) {
					broadcast_announce(c.name + " casts Mind Blank! Immune to Psychic damage and the Charmed condition.", true);
				} else {
					broadcast_announce(c.name + " casts Mind Blank on " + mb_target.name + "! Immune to Psychic damage and the Charmed condition.", true);
				}
			}
			// Level 9
			else if (spell.id == "astral_projection") {
				broadcast_announce(c.name + " casts Astral Projection.", true);
			}
			else if (spell.id == "foresight") {
				// Basic Rules 2024 Foresight (para 13025-13031): Level 9 Divination.
				// Touch, 8 hours, NOT concentration. "the target has Advantage on D20 Tests,
				// and other creatures have Disadvantage on attack rolls against it."
				combatant@ fs_target = @target != null ? target : c;
				// Touch range check (5ft)
				if (@fs_target != c and feet_distance(c.x, c.y, fs_target.x, fs_target.y) > 5) {
					u.send({{"type", message_types::error}, {"text", c.name + " can't reach " + fs_target.name + " — Foresight requires Touch range (5 ft)."}});
					return;
				}
				// "The spell ends early if you cast it again." — clear from any previous target
				if (@combat != null) {
					for (uint fsi = 0; fsi < combat.combatants.length(); fsi++) {
						combat.combatants[fsi].foresight_active = false;
					}
				}
				fs_target.foresight_active = true;
				if (@fs_target == c) {
					broadcast_announce(c.name + " casts Foresight! Advantage on all d20 tests, and enemies have disadvantage on attacks against " + c.name + ".", true);
				} else {
					broadcast_announce(c.name + " casts Foresight on " + fs_target.name + "! Advantage on all d20 tests, and enemies have disadvantage on attacks against " + fs_target.name + ".", true);
				}
			}
			else if (spell.id == "gate") {
				broadcast_announce(c.name + " casts Gate.", true);
			}
			else if (spell.id == "imprisonment") {
				broadcast_announce(c.name + " casts Imprisonment.", true);
			}
			else if (spell.id == "invulnerability" and @target != null) {
				broadcast_announce(c.name + " casts Invulnerability on " + target.name + ". They are immune to all damage for 10 minutes.", true);
			}
			else if (spell.id == "invulnerability") {
				broadcast_announce(c.name + " casts Invulnerability.", true);
			}
			else if (spell.id == "shapechange") {
				broadcast_announce(c.name + " casts Shapechange.", true);
			}
			else if (spell.id == "time_stop") {
				// Basic Rules 2024 Time Stop (para 15275-15277): "you take 1d4 + 1 turns
				// in a row, during which you can use actions and move as normal." Instantaneous.
				// Extra turns are granted by setting time_stop_turns_remaining and checking
				// in advance_turn to repeat the caster's turn instead of advancing initiative.
				int extra_turns = random(1, 4) + 1;
				c.time_stop_turns_remaining = extra_turns;
				broadcast_announce(c.name + " casts Time Stop! Time freezes for everyone else — " + c.name + " gains " + extra_turns + " extra turns!", true);
			}
			else if (spell.id == "true_polymorph") {
				broadcast_announce(c.name + " casts True Polymorph.", true);
			}
			// ==== ADDITIONAL SPELL HANDLERS (batch 2026-04-08) ====
			// Cantrips
			else if (spell.id == "aundairs_silent_sanctum") {
				broadcast_announce(c.name + " casts Aundair's Silent Sanctum, muffling sound in a 5-foot bubble.", true);
			}
			else if (spell.id == "bright_sparks" and @target != null) {
				int dice_count = cantrip_dice_count(1, c.level);
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Bright Sparks attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					int total_damage = 0;
					for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
					combat.apply_damage(target, total_damage, DMG_LIGHTNING, c);
					broadcast_announce(c.name + "'s Bright Sparks zap " + target.name + " for " + total_damage + " lightning damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "concealed_shot") {
				broadcast_announce(c.name + " casts Concealed Shot, making their next ranged attack supernaturally subtle.", true);
			}
			else if (spell.id == "drizzle") {
				int dice_count = cantrip_dice_count(1, c.level);
				broadcast_announce(c.name + " casts Drizzle, summoning a chilling spray!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 5) continue;
					int total_damage = 0;
					for (int d = 0; d < dice_count; d++) total_damage += random(1, 4);
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Drizzle", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_COLD, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "elementalism") {
				broadcast_announce(c.name + " casts Elementalism, creating a minor elemental effect.", true);
			}
			else if (spell.id == "finger_guns" and @target != null) {
				int dice_count = cantrip_dice_count(1, c.level);
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Finger Guns attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					int total_damage = 0;
					for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
					// Valda's Spire Gunslinger Spellslinger L3 Bang, You're Dead — Arcane
					// Shot (paras 423-426): "When you hit a target with a Finger Guns
					// attack, you can expend one Risk Die as a Bonus Action and add it to
					// the damage roll." Triggered via opt-in pending toggle so the player
					// chooses whether to spend a Risk Die on each Finger Guns hit.
					if (c.bang_youre_dead_active and c.bang_youre_dead_pending and c.risk_dice_current > 0 and c.has_bonus_action) {
						c.bang_youre_dead_pending = false;
						c.has_bonus_action = false;
						c.used_bonus_action = true;
						c.risk_dice_current--;
						int byd_roll = random(1, c.risk_die_size);
						total_damage += byd_roll;
						broadcast_announce(c.name + "'s Bang You're Dead spends a Risk Die for +" + byd_roll + " damage! (" + c.risk_dice_current + "/" + c.risk_dice_max + " Risk Dice remaining)", true);
					}
					combat.apply_damage(target, total_damage, DMG_FORCE, c);
					broadcast_announce(c.name + "'s Finger Guns blast " + target.name + " for " + total_damage + " force damage.", true);
				} else {
					// Clear the pending flag if the attack missed (don't carry over)
					c.bang_youre_dead_pending = false;
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "force_blast" and @target != null) {
				int dice_count = cantrip_dice_count(1, c.level);
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Force Blast attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					int total_damage = 0;
					for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
					combat.apply_damage(target, total_damage, DMG_FORCE, c);
					broadcast_announce(c.name + "'s Force Blast hammers " + target.name + " for " + total_damage + " force damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "holy_word" and @target != null) {
				int dice_count = cantrip_dice_count(1, c.level);
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (WIS — radiant damage)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Holy Word"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Holy Word"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "WIS save vs Holy Word", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
				if (!saved) {
					combat.apply_damage(target, total_damage, DMG_RADIANT, c);
					broadcast_announce(c.name + "'s Holy Word sears " + target.name + " for " + total_damage + " radiant damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "magecraft") {
				broadcast_announce(c.name + " casts Magecraft, channeling arcane talent through their tools.", true);
			}
			else if (spell.id == "mind_spike" and @target != null) {
				int dice_count = cantrip_dice_count(1, c.level);
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Mind Spike attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					int total_damage = 0;
					for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
					combat.apply_damage(target, total_damage, DMG_PSYCHIC, c);
					broadcast_announce(c.name + "'s Mind Spike pierces " + target.name + "'s mind for " + total_damage + " psychic damage. They have a penalty on their next save.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "obfuscate_object") {
				broadcast_announce(c.name + " casts Obfuscate Object, hiding it from divination.", true);
			}
			else if (spell.id == "poison_spray" and @target != null) {
				int dice_count = cantrip_dice_count(1, c.level);
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 12);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (CON — poison damage)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "CON save vs Poison Spray"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "CON save vs Poison Spray"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "CON save vs Poison Spray", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
				if (!saved) {
					combat.apply_damage(target, total_damage, DMG_POISON, c);
					broadcast_announce(c.name + "'s Poison Spray withers " + target.name + " for " + total_damage + " poison damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "produce_flame" and @target != null) {
				int dice_count = cantrip_dice_count(1, c.level);
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Produce Flame attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					int total_damage = 0;
					for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
					// PHB 2024 Druid L7 Elemental Fury — Potent Spellcasting (para 4432):
					// "Add your Wisdom modifier to the damage you deal with any Druid cantrip."
					int dpc_bonus = c.druid_potent_spellcasting_bonus();
					if (dpc_bonus > 0) total_damage += dpc_bonus;
					combat.apply_damage(target, total_damage, DMG_FIRE, c);
					broadcast_announce(c.name + "'s Produce Flame burns " + target.name + " for " + total_damage + " fire damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "produce_flame") {
				broadcast_announce(c.name + " conjures a Produce Flame in their hand, shedding light.", true);
			}
			else if (spell.id == "sacred_flame" and @target != null) {
				int dice_count = cantrip_dice_count(1, c.level);
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				// PHB 2024 Cleric L7 Blessed Strikes — Potent Spellcasting (para 3620):
				// "Add your Wisdom modifier to the damage you deal with any Cleric cantrip."
				int potent_bonus = c.potent_spellcasting_bonus();
				if (potent_bonus > 0) total_damage += potent_bonus;
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_DEX);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (DEX — radiant damage)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "DEX save vs Sacred Flame"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "DEX save vs Sacred Flame"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "DEX save vs Sacred Flame", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
				if (!saved) {
					combat.apply_damage(target, total_damage, DMG_RADIANT, c);
					broadcast_announce(c.name + "'s Sacred Flame engulfs " + target.name + " for " + total_damage + " radiant damage.", true);
					// PHB 2024 Cleric L14 Improved Blessed Strikes (para 3626): when
					// dealing damage with a cantrip, grant 2x WIS mod temp HP to self
					// (or ally within 60ft — auto-applied to self since the choice is
					// optional and self is the always-available default).
					int ipt = c.apply_improved_potent_temp_hp();
					if (ipt > 0) broadcast_announce(c.name + "'s Improved Blessed Strikes grants " + ipt + " temp HP.", false);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "shillelagh") {
				// Basic Rules 2024 Shillelagh (para 14966-14974): "A Club or Quarterstaff
				// you are holding is imbued with nature's power. For the duration, you can
				// use your spellcasting ability instead of Strength for the attack and damage
				// rolls of melee attacks using that weapon, and the weapon's damage die
				// becomes a d8." Cantrip Upgrade: d10 at L5, d12 at L11, 2d6 at L17.
				c.shillelagh_active = true;
				c.shillelagh_rounds = 10; // 1 minute
				// Set damage die based on cantrip scaling
				if (c.level >= 17) c.shillelagh_damage_die = 6; // 2d6 (count handled in get_attack_damage_count)
				else if (c.level >= 11) c.shillelagh_damage_die = 12;
				else if (c.level >= 5) c.shillelagh_damage_die = 10;
				else c.shillelagh_damage_die = 8;
				string die_label = "1d" + c.shillelagh_damage_die;
				if (c.level >= 17) die_label = "2d6";
				broadcast_announce(c.name + " casts Shillelagh, infusing their weapon with nature's power (" + die_label + " force damage).", true);
			}
			// Level 1
			else if (spell.id == "ballistic_smite") {
				// Gun Slinger Class (para 724-729): "The target hit by the attack takes
				// an extra 2d6 damage. Using a Higher-Level Spell Slot: +1d6 per level."
				c.ballistic_smite_pending = true;
				c.ballistic_smite_dice = 2 + upcast_levels;
				broadcast_announce(c.name + " casts Ballistic Smite — next ranged hit deals +" + c.ballistic_smite_dice + "d6 extra force damage.", true);
			}
			else if (spell.id == "concussive_burst") {
				broadcast_announce(c.name + " casts Concussive Burst, releasing a pulse of force!", true);
				int dice_count = 2;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 4);
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 5) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_STR);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = t.apply_indomitable_might(save_roll + save_bonus + bless_bonus, ABILITY_STR);
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "STR save vs Concussive Burst", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_FORCE, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "conjure_cover") {
				broadcast_announce(c.name + " casts Conjure Cover, creating a low cobblestone wall.", true);
			}
			else if (spell.id == "divine_smite") {
				broadcast_announce(c.name + " casts Divine Smite. Their next melee strike will deal radiant damage.", true);
			}
			else if (spell.id == "illusory_script") {
				broadcast_announce(c.name + " casts Illusory Script, weaving an illusion onto written words.", true);
			}
			else if (spell.id == "perforating_shot") {
				// Gun Slinger Class (para 730-735): Bonus Action after hitting or missing
				// with a ranged weapon attack. Transforms into a 5-foot-wide Line to weapon
				// range. Each creature in Line makes DEX save for weapon damage (half on
				// success). +1d8 per upcast. Implemented as an immediate line AoE from
				// caster through all enemies in a line to weapon's normal range.
				int ps_range = c.main_hand_range;
				if (ps_range < 30) ps_range = 30; // Minimum useful range
				int ps_base_dmg = 0;
				int ps_dice = c.main_hand_damage_count;
				int ps_die = c.main_hand_damage_dice;
				for (int d = 0; d < ps_dice; d++) ps_base_dmg += random(1, ps_die);
				// Upcast: +1d8 per slot level above 1
				for (int u = 0; u < upcast_levels; u++) ps_base_dmg += random(1, 8);
				int ps_dmg_type = c.main_hand_damage_type;
				broadcast_announce(c.name + " casts Perforating Shot! A line of piercing energy extends " + ps_range + " feet!", true);
				// Hit all enemies in range (line approximation: all hostiles within weapon range)
				for (uint psi = 0; psi < combat.combatants.length(); psi++) {
					combatant@ ps_t = combat.combatants[psi];
					if (@ps_t == null or ps_t.is_dead or ps_t.id == c.id) continue;
					if (ps_t.is_player == c.is_player and combat.mode != "pvp") continue;
					int ps_dist = feet_distance(c.x, c.y, ps_t.x, ps_t.y);
					if (ps_dist > ps_range) continue;
					int ps_save_roll = random(1, 20);
					apply_hound_save_disadvantage(ps_t, c.id, ps_save_roll);
					int ps_save_bonus = ps_t.get_save_bonus(ABILITY_DEX);
					int ps_bless = roll_bless_bonus(ps_t);
					int ps_save_total = ps_t.apply_indomitable_might(ps_save_roll + ps_save_bonus + ps_bless, ABILITY_DEX);
					bool ps_saved = ps_save_total >= save_dc;
					int ps_dmg = ps_saved ? ps_base_dmg / 2 : ps_base_dmg;
					if (ps_dmg < 1) ps_dmg = 1;
					broadcast_roll(ps_t.name, "DEX save vs Perforating Shot", ps_save_roll, ps_save_bonus + ps_bless, ps_save_total, ps_saved ? "Half damage!" : "Full damage!");
					if (!ps_saved and try_arcane_deflection_save(ps_t, save_dc, ps_save_total)) { ps_saved = true; ps_dmg = ps_base_dmg / 2; }
					if (!ps_saved) { int fg = try_flash_of_genius(ps_t, save_dc, ps_save_total, "DEX save vs Perforating Shot"); if (fg >= save_dc) { ps_saved = true; ps_dmg = ps_base_dmg / 2; } }
					if (!ps_saved) { int bf = try_boon_of_fate_bonus(ps_t, ps_save_total, save_dc); if (bf >= save_dc) { ps_saved = true; ps_dmg = ps_base_dmg / 2; } }
					if (!ps_saved and try_stroke_of_luck_save(ps_t, save_dc, ps_save_bonus + ps_bless)) { ps_saved = true; ps_dmg = ps_base_dmg / 2; }
					if (ps_dmg < 1) ps_dmg = 1;
					combat.apply_damage(ps_t, ps_dmg, ps_dmg_type, c);
					broadcast_announce(ps_t.name + " takes " + ps_dmg + " damage from the perforating energy!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			// Level 2
			else if (spell.id == "animal_messenger") {
				broadcast_announce(c.name + " casts Animal Messenger, dispatching a tiny beast with a message.", true);
			}
			else if (spell.id == "augury") {
				broadcast_announce(c.name + " casts Augury, seeking an omen about the next 30 minutes.", true);
			}
			else if (spell.id == "enthrall" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				broadcast_roll(target.name, "WIS save vs Enthrall", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Enthrall")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Enthrall"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Enthrall"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Enthrall"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_CHARMED);
					target.charm_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Charmed"}});
					broadcast_announce(c.name + " enthralls " + target.name + " for 1 minute.", true);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "flame_blade") {
				// Basic Rules 2024 Flame Blade (para 13334-13343): "You evoke a fiery blade
				// in your free hand." Bonus action cast, concentration, 10 minutes.
				// "As a Magic action, you can make a melee spell attack with the fiery blade."
				c.flame_blade_active = true;
				c.flame_blade_dice = 3 + (cast_slot_level > 2 ? cast_slot_level - 2 : 0);
				c.is_concentrating = true;
				c.concentration_spell = "Flame Blade";
				broadcast_announce(c.name + " casts Flame Blade, evoking a fiery scimitar (" + c.flame_blade_dice + "d6 fire). Use your action to attack with it!", true);
			}
			else if (spell.id == "homunculus_servant") {
				broadcast_announce(c.name + " casts Homunculus Servant, summoning a tiny construct ally.", true);
			}
			else if (spell.id == "jam_weapon" and @target != null and !target.is_dead) {
				// Gun Slinger Class (para 736-738): "The weapon you target suffers a
				// malfunction and the attack fails. A malfunctioning weapon can't be used
				// to make an attack until a creature takes the Utilize action to fix the
				// weapon malfunction." Source is Reaction timing; approximated as a cast
				// targeting a creature within 60ft. TODO: wire into reaction prompt on
				// enemy ranged attack.
				int jw_dist = feet_distance(c.x, c.y, target.x, target.y);
				if (jw_dist > 60) {
					broadcast_announce(target.name + " is too far away! Jam Weapon has a range of 60 feet.", false);
					return;
				}
				target.weapon_jammed = true;
				broadcast_announce(c.name + " casts Jam Weapon! " + target.name + "'s weapon malfunctions and can't be used to attack until fixed (costs an action)!", true);
				broadcast_state();
			}
			else if (spell.id == "jethros_instant_reload") {
				broadcast_announce(c.name + " casts Jethro's Instant Reload, enchanting a ranged weapon to reload itself.", true);
			}
			else if (spell.id == "melfs_acid_arrow" and @target != null) {
				int hit_dice = 4 + upcast_levels;
				int miss_dice = 2 + upcast_levels;
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Melf's Acid Arrow attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				int total_damage = 0;
				if (hit) {
					int combined = hit_dice + miss_dice;
					for (int d = 0; d < combined; d++) total_damage += random(1, 4);
					combat.apply_damage(target, total_damage, DMG_ACID, c);
					broadcast_announce(c.name + "'s Melf's Acid Arrow deals " + total_damage + " acid damage to " + target.name + ".", true);
				} else {
					for (int d = 0; d < miss_dice; d++) total_damage += random(1, 4);
					combat.apply_damage(target, total_damage, DMG_ACID, c);
					broadcast_announce(c.name + "'s Melf's Acid Arrow splashes " + target.name + " for " + total_damage + " acid damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "nystuls_magic_aura") {
				broadcast_announce(c.name + " casts Nystul's Magic Aura, masking the target's magical signature.", true);
			}
			else if (spell.id == "ray_of_enfeeblement" and @target != null) {
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Ray of Enfeeblement attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					broadcast_announce(c.name + "'s Ray of Enfeeblement saps " + target.name + "'s strength. They deal half damage with strength-based attacks.", true);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "shining_smite") {
				// Basic Rules 2024 Shining Smite (para 14976-14983): "The target hit by
				// the strike takes an extra 2d6 Radiant damage. Until the spell ends,
				// the target sheds Bright Light, attack rolls against it have Advantage,
				// and it can't benefit from the Invisible condition."
				c.shining_smite_pending = true;
				c.shining_smite_dice = 2 + upcast_levels;
				broadcast_announce(c.name + " casts Shining Smite — next weapon hit deals +" + c.shining_smite_dice + "d6 radiant damage with light aura.", true);
			}
			else if (spell.id == "warding_bond" and @target != null) {
				// Basic Rules 2024 Warding Bond (para 15561): touch range, 1 hour, non-conc.
				// Target gains +1 AC, +1 to all saves, resistance to all damage.
				// When target takes damage, caster takes the same amount.
				int dist = feet_distance(c.x, c.y, target.x, target.y);
				if (dist > 5) {
					u.send({{"type", message_types::announce}, {"text", "Warding Bond requires a target within 5 feet."}, {"interrupt", true}});
					return;
				}
				if (c.id == target.id) {
					u.send({{"type", message_types::announce}, {"text", "Warding Bond targets another creature, not yourself."}, {"interrupt", true}});
					return;
				}
				// Clear any existing bond the caster is providing
				if (c.warding_bond_target_id != 0) {
					combatant@ old_tgt = combat.get_combatant(c.warding_bond_target_id);
					if (@old_tgt != null and old_tgt.warding_bond_active and old_tgt.warding_bond_source_id == c.id) {
						old_tgt.armor_class -= 1;
						old_tgt.warding_bond_active = false;
						old_tgt.warding_bond_source_id = 0;
						broadcast_announce(old_tgt.name + "'s Warding Bond fades as a new one is cast.", false);
					}
					c.warding_bond_target_id = 0;
				}
				// Clear any existing bond on the target
				if (target.warding_bond_active) {
					combatant@ old_src = combat.get_combatant(target.warding_bond_source_id);
					if (@old_src != null) old_src.warding_bond_target_id = 0;
					target.armor_class -= 1;
					target.warding_bond_active = false;
					target.warding_bond_source_id = 0;
					broadcast_announce(target.name + "'s previous Warding Bond fades.", false);
				}
				target.warding_bond_active = true;
				target.warding_bond_source_id = c.id;
				c.warding_bond_target_id = target.id;
				target.armor_class += 1;
				broadcast_announce(c.name + " casts Warding Bond on " + target.name + "! +1 AC, +1 to all saves, resistance to all damage. " + c.name + " shares the damage.", true);
				broadcast_state();
				return;
			}
			// Level 3
			else if (spell.id == "conjure_cannonball") {
				broadcast_announce(c.name + " casts Conjure Cannonball, summoning a streaking cannonball!", true);
				int dice_count = 6 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Conjure Cannonball", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_BLUDGEONING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "leomunds_tiny_hut") {
				broadcast_announce(c.name + " casts Leomund's Tiny Hut, creating a 10-foot dome of force.", true);
			}
			else if (spell.id == "major_image") {
				broadcast_announce(c.name + " casts Major Image, conjuring a vivid illusion.", true);
			}
			else if (spell.id == "speak_with_dead") {
				broadcast_announce(c.name + " casts Speak with Dead, granting a corpse the semblance of life.", true);
			}
			else if (spell.id == "speak_with_plants") {
				broadcast_announce(c.name + " casts Speak with Plants, communing with nearby plant life.", true);
			}
			// Level 4
			else if (spell.id == "aura_of_life") {
				// Basic Rules 2024 Aura of Life (para 12166-12168): L4 Abjuration,
				// Concentration, 10 min. 30ft emanation: allies have Necrotic resistance,
				// HP max can't be reduced, ally at 0 HP regains 1 HP at turn start.
				c.aura_of_life_active = true;
				c.is_concentrating = true;
				c.concentration_spell = "Aura of Life";
				broadcast_announce(c.name + " casts Aura of Life! A life-preserving aura radiates 30 feet. Allies gain Necrotic resistance and can recover from 0 HP.", true);
			}
			else if (spell.id == "charm_monster" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				if (target.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				broadcast_roll(target.name, "WIS save vs Charm Monster", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Charm Monster")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Charm Monster"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Charm Monster"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Charm Monster"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_CHARMED);
					target.charm_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Charmed"}});
					broadcast_announce(c.name + " charms " + target.name + " with Charm Monster.", true);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "conjure_minor_elementals") {
				// Basic Rules 2024 Conjure Minor Elementals: 15ft caster-centered emanation,
				// +2d8 elemental damage on your attack hits within emanation, concentration.
				// +2d8 per upcast level above 4.
				c.conjure_minor_elementals_active = true;
				c.conjure_minor_elementals_slot_level = cast_slot_level;
				c.is_concentrating = true;
				c.concentration_spell = "Conjure Minor Elementals";
				c.add_condition(COND_CONCENTRATING);
				broadcast_announce(c.name + " casts Conjure Minor Elementals! Elemental spirits swirl in a 15-foot emanation — attacks deal extra 2d8 elemental damage to creatures in the aura.", true);
				broadcast_state();
				return;
			}
			else if (spell.id == "conjure_woodland_beings") {
				// Basic Rules 2024 Conjure Woodland Beings: 10ft caster-centered emanation,
				// WIS save or 5d8+upcast force damage (half on save), concentration.
				// Also grants Disengage as bonus action.
				c.conjure_woodland_active = true;
				c.conjure_woodland_slot_level = cast_slot_level;
				c.conjure_woodland_disengage = true;
				c.is_concentrating = true;
				c.concentration_spell = "Conjure Woodland Beings";
				c.add_condition(COND_CONCENTRATING);
				broadcast_announce(c.name + " casts Conjure Woodland Beings! Fey nature spirits swirl in a 10-foot emanation.", true);
				// Immediately apply to enemies already in range
				int cwb_dc = spell_save_dc(c, "conjure_woodland_beings");
				int cwb_dice = 5 + (cast_slot_level - 4);
				if (cwb_dice < 5) cwb_dice = 5;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (!combat.are_hostile(c, t)) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 10) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= cwb_dc;
					broadcast_roll(t.name, "WIS save vs Conjure Woodland Beings", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					if (!saved and try_arcane_deflection_save(t, cwb_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, cwb_dc, save_total, "WIS save vs Conjure Woodland Beings"); if (fg >= cwb_dc) saved = true; }
					if (!saved) { int ms = try_maverick_spirit(t, cwb_dc, save_total, "WIS save vs Conjure Woodland Beings"); if (ms >= cwb_dc) saved = true; }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, cwb_dc); if (bf > 0) saved = true; }
					if (!saved and try_stroke_of_luck_save(t, cwb_dc, save_bonus + bless_bonus)) saved = true;
					int cwb_dmg = 0;
					for (int d = 0; d < cwb_dice; d++) cwb_dmg += random(1, 8);
					if (saved) cwb_dmg /= 2;
					if (cwb_dmg < 1) cwb_dmg = 1;
					combat.apply_damage(t, cwb_dmg, DMG_FORCE, c);
					broadcast_announce(t.name + " takes " + cwb_dmg + " force damage from the woodland spirits!", true);
					if (t.is_dead) continue;
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "dominate_beast" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				if (target.charm_frighten_save_advantage) { int r2 = random(1, 20); if (r2 > save_roll) save_roll = r2; }
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				broadcast_roll(target.name, "WIS save vs Dominate Beast", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Charmed!");
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved and try_countercharm_reroll(target, save_dc, save_bonus + bless_bonus, "WIS save vs Dominate Beast")) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Dominate Beast"); if (ds >= save_dc) saved = true; }
				if (!saved) { int new_total = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Dominate Beast"); if (new_total >= save_dc) saved = true; }
			if (!saved) { int ms_total = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Dominate Beast"); if (ms_total >= save_dc) saved = true; }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf > 0) saved = true; }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				if (!saved) {
					target.add_condition(COND_CHARMED);
					target.charm_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Charmed"}});
					broadcast_announce(c.name + " dominates " + target.name + " with Dominate Beast.", true);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "fabricate") {
				broadcast_announce(c.name + " casts Fabricate, transforming raw materials into a finished product.", true);
			}
			else if (spell.id == "giant_insect") {
				// Basic Rules 2024 Giant Insect: AC 14+PB, HP 10*spell_level+20, Speed 40,
				// Multiattack (2 attacks), +spell_attack to hit, 1d6+3+PB piercing.
				int gi_hp = 10 * cast_slot_level + 20;
				int gi_ac = 14 + c.proficiency;
				int gi_atk = c.proficiency + c.get_ability_mod(ABILITY_WIS);
				if (c.class_name == "Wizard" or c.class_name == "Artificer") gi_atk = c.proficiency + c.get_ability_mod(ABILITY_INT);
				else if (c.class_name == "Bard" or c.class_name == "Sorcerer" or c.class_name == "Warlock") gi_atk = c.proficiency + c.get_ability_mod(ABILITY_CHA);
				int gi_dmg_mod = 3 + c.proficiency;
				c.is_concentrating = true;
				c.concentration_spell = "Giant Insect";
				c.add_condition(COND_CONCENTRATING);
				combatant@ insect = spawn_companion(c, "giant_insect", "Giant Insect", gi_hp, gi_ac, 40, gi_atk, 1, 6, gi_dmg_mod, DMG_PIERCING, 1);
				if (@insect != null) {
					broadcast_announce(c.name + " casts Giant Insect! A massive arthropod appears (HP " + gi_hp + ", AC " + gi_ac + ", 2 attacks per turn)!", true);
				} else {
					broadcast_announce(c.name + " casts Giant Insect, summoning an enormous arthropod ally.", true);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "hallucinatory_terrain") {
				broadcast_announce(c.name + " casts Hallucinatory Terrain, disguising the surrounding landscape.", true);
			}
			else if (spell.id == "leomunds_secret_chest") {
				broadcast_announce(c.name + " casts Leomund's Secret Chest, hiding it on the Ethereal Plane.", true);
			}
			else if (spell.id == "mordenkainens_faithful_hound") {
				int hound_hp = 60;
				combatant@ hound = spawn_companion(c, "mordenkainens_faithful_hound", c.name + "'s Faithful Hound", hound_hp, 18, 30, c.proficiency + get_spellcasting_ability_mod(c), 4, 8, 0, DMG_FORCE, 0);
				if (@hound != null) {
					broadcast_announce(c.name + " summons a Faithful Hound! HP " + hound_hp + ", AC 18, 4d8 force bite.", true);
				}
			}
			else if (spell.id == "mordenkainens_private_sanctum") {
				broadcast_announce(c.name + " casts Mordenkainen's Private Sanctum, securing the area against intrusion.", true);
			}
			else if (spell.id == "otilukes_resilient_sphere" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_DEX);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (DEX — Restrained condition)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "DEX save vs Otiluke's Resilient Sphere"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "DEX save vs Otiluke's Resilient Sphere"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "DEX save vs Otiluke's Resilient Sphere"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "DEX save vs Otiluke's Resilient Sphere", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Trapped!");
				if (!saved) {
					target.resilient_sphere_trapped = true;
					target.resilient_sphere_source_id = c.id;
					target.resilient_sphere_rounds = 10; // 1 minute = 10 rounds
					target.add_condition(COND_INCAPACITATED);
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Incapacitated"}});
					broadcast_announce(c.name + " traps " + target.name + " in Otiluke's Resilient Sphere! They are immune to all damage but cannot act. (10 rounds)", true);
				}
				broadcast_state();
				return;
			}
			// Level 5
			else if (spell.id == "antilife_shell") {
				// Basic Rules 2024 Antilife Shell (para 11796-11803): Level 5 Abjuration.
				// Self, Concentration up to 1 hour. "An aura extends from you in a 10-foot
				// Emanation for the duration. The aura prevents creatures other than Constructs
				// and Undead from passing or reaching through it."
				c.is_concentrating = true;
				c.concentration_spell = "Antilife Shell";
				c.antilife_shell_active = true;
				broadcast_announce(c.name + " casts Antilife Shell! A 10-foot barrier wards off living creatures. Ranged attacks and spells can still pass through.", true);
			}
			else if (spell.id == "awaken") {
				broadcast_announce(c.name + " casts Awaken, granting sentience to a beast or plant.", true);
			}
			else if (spell.id == "conjure_elemental") {
				int elem_hp = 50 + (5 * c.level);
				int spell_mod_local = get_spellcasting_ability_mod(c);
				int elem_attack = c.proficiency + spell_mod_local;
				combatant@ elem = spawn_companion(c, "conjure_elemental", c.name + "'s Elemental", elem_hp, 14 + c.proficiency, 40, elem_attack, 2, 8, spell_mod_local, DMG_FORCE, 0);
				if (@elem != null) {
					broadcast_announce(c.name + " summons an Elemental! HP " + elem_hp + ", AC " + (14 + c.proficiency) + ", 2d8+mod force.", true);
				}
			}
			else if (spell.id == "contact_other_plane" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_INT);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (INT — psychic damage)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "INT save vs Contact Other Plane"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "INT save vs Contact Other Plane"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "INT save vs Contact Other Plane", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
				if (!saved) {
					int total_damage = 0;
					for (int d = 0; d < 6; d++) total_damage += random(1, 6);
					combat.apply_damage(target, total_damage, DMG_PSYCHIC, c);
					broadcast_announce(c.name + "'s Contact Other Plane shatters " + target.name + "'s mind for " + total_damage + " psychic damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "dispel_evil_and_good") {
				broadcast_announce(c.name + " casts Dispel Evil and Good, warding against celestials, fiends, and undead.", true);
			}
			else if (spell.id == "hallow") {
				broadcast_announce(c.name + " casts Hallow, infusing an area with holy or unholy power.", true);
			}
			else if (spell.id == "rarys_telepathic_bond") {
				broadcast_announce(c.name + " casts Rary's Telepathic Bond, linking allies psychically.", true);
			}
			else if (spell.id == "summon_dragon") {
				int dragon_hp = 80 + (10 * c.level);
				int spell_mod_local = get_spellcasting_ability_mod(c);
				int dragon_attack = c.proficiency + spell_mod_local;
				combatant@ dragon = spawn_companion(c, "summon_dragon", c.name + "'s Draconic Spirit", dragon_hp, 16 + c.proficiency, 40, dragon_attack, 3, 8, spell_mod_local, DMG_FIRE, 1);
				if (@dragon != null) {
					broadcast_announce(c.name + " summons a Draconic Spirit! HP " + dragon_hp + ", AC " + (16 + c.proficiency) + ", 3d8+mod fire bite (multiattack).", true);
				}
			}
			// Level 6
			else if (spell.id == "antiballistics_field") {
				broadcast_announce(c.name + " casts Antiballistics Field, disrupting projectiles in a 40-foot aura.", true);
			}
			else if (spell.id == "conjure_fey") {
				int fey_hp = 60 + (5 * c.level);
				int spell_mod_local = get_spellcasting_ability_mod(c);
				int fey_attack = c.proficiency + spell_mod_local;
				combatant@ fey = spawn_companion(c, "conjure_fey", c.name + "'s Fey Spirit", fey_hp, 14 + c.proficiency, 40, fey_attack, 2, 10, spell_mod_local, DMG_PSYCHIC, 0);
				if (@fey != null) {
					broadcast_announce(c.name + " summons a Fey Spirit! HP " + fey_hp + ", AC " + (14 + c.proficiency) + ", 2d10+mod psychic.", true);
				}
			}
			else if (spell.id == "contingency") {
				broadcast_announce(c.name + " casts Contingency, storing a spell for later automatic activation.", true);
			}
			else if (spell.id == "create_undead") {
				int undead_hp = 30 + (3 * c.level);
				int spell_mod_local = get_spellcasting_ability_mod(c);
				int undead_attack = c.proficiency + spell_mod_local;
				combatant@ undead = spawn_companion(c, "create_undead", c.name + "'s Ghoul", undead_hp, 12 + c.proficiency, 30, undead_attack, 2, 6, spell_mod_local, DMG_PIERCING, 1);
				if (@undead != null) {
					broadcast_announce(c.name + " raises a Ghoul through Create Undead! HP " + undead_hp + ", AC " + (12 + c.proficiency) + ", 2d6+mod piercing claws (multiattack).", true);
				}
			}
			else if (spell.id == "drawmijs_instant_summons") {
				broadcast_announce(c.name + " casts Drawmij's Instant Summons, marking an object for instant recall.", true);
			}
			else if (spell.id == "flesh_to_stone" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (CON — Restrained/Petrifying condition)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "CON save vs Flesh to Stone"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "CON save vs Flesh to Stone"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "CON save vs Flesh to Stone"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "CON save vs Flesh to Stone", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Petrifying!");
				if (!saved) {
					target.add_condition(COND_RESTRAINED);
					target.restrained_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Restrained"}});
					broadcast_announce(c.name + " begins petrifying " + target.name + " with Flesh to Stone!", true);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "forbiddance") {
				broadcast_announce(c.name + " casts Forbiddance, warding the area against magical travel.", true);
			}
			else if (spell.id == "ottos_irresistible_dance" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_WIS);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (WIS — Incapacitated condition)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Otto's Irresistible Dance"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "WIS save vs Otto's Irresistible Dance"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "WIS save vs Otto's Irresistible Dance"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "WIS save vs Otto's Irresistible Dance", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Dancing!");
				if (!saved) {
					target.add_condition(COND_INCAPACITATED);
					target.incap_spell_caster_id = c.id;
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Incapacitated"}});
					broadcast_announce(c.name + " compels " + target.name + " to dance uncontrollably!", true);
				}
				broadcast_state();
				return;
			}
			else if (spell.id == "planar_ally") {
				broadcast_announce(c.name + " casts Planar Ally, beseeching an otherworldly entity for aid.", true);
			}
			else if (spell.id == "transport_via_plants") {
				broadcast_announce(c.name + " casts Transport via Plants, opening a portal between two large plants.", true);
			}
			else if (spell.id == "wind_walk") {
				broadcast_announce(c.name + " casts Wind Walk, transforming themselves and allies into wisps of cloud.", true);
			}
			// Level 7
			else if (spell.id == "delayed_blast_fireball") {
				broadcast_announce(c.name + " casts Delayed Blast Fireball, releasing a torrent of fire!", true);
				int dice_count = 12 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Delayed Blast Fireball", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_FIRE, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "divine_word") {
				broadcast_announce(c.name + " utters a Divine Word, smiting nearby enemies!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (t.is_player == c.is_player and combat.mode != "pvp") continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 30) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_WIS);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (WIS — Blinded/Stunned condition)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Divine Word"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "WIS save vs Divine Word"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "WIS save vs Divine Word"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved and try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "WIS save vs Divine Word", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Struck down!");
					if (!saved) {
						if (t.current_hp < 30) {
							t.add_condition(COND_BLINDED);
							t.add_condition(COND_DEAFENED);
							broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Blinded and Deafened"}});
							broadcast_announce(t.name + " is blinded and deafened by Divine Word!", true);
						} else if (t.current_hp < 50) {
							t.add_condition(COND_STUNNED);
							broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Stunned"}});
							broadcast_announce(t.name + " is stunned by Divine Word!", true);
						}
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "mordenkainens_magnificent_mansion") {
				broadcast_announce(c.name + " casts Mordenkainen's Magnificent Mansion, conjuring a shimmering door to an extradimensional dwelling.", true);
			}
			// Level 8
			else if (spell.id == "animal_shapes") {
				broadcast_announce(c.name + " casts Animal Shapes, transforming willing allies into beasts.", true);
			}
			else if (spell.id == "befuddlement" and @target != null) {
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_INT);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (INT — psychic damage)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int ds = try_disciplined_survivor_reroll(target, save_dc, save_total, save_bonus + bless_bonus, "INT save vs Befuddlement"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "INT save vs Befuddlement"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "INT save vs Befuddlement"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved and try_mage_slayer_guarded_mind(target, ABILITY_INT)) saved = true;
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "INT save vs Befuddlement", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
				if (!saved) {
					int total_damage = 0;
					for (int d = 0; d < 12; d++) total_damage += random(1, 6);
					combat.apply_damage(target, total_damage, DMG_PSYCHIC, c);
					broadcast_announce(c.name + "'s Befuddlement shatters " + target.name + "'s intellect for " + total_damage + " psychic damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			// Level 9
			else if (spell.id == "wish") {
				// Basic Rules 2024 Wish (para 15081-15097): Level 9 Conjuration.
				// Self, Instantaneous. Primary use: "duplicate any other spell of level 8
				// or lower." Combat option: Instant Health — "You allow yourself and up to
				// twenty creatures that you can see to regain all Hit Points, and you end
				// all effects on them listed in the Greater Restoration spell's description."
				// Implementation: Instant Health (most impactful in combat arena).
				// Greater Restoration removes: Charmed, Petrified, Stunned, curse reduction.
				if (@combat == null) return;
				int wish_healed = 0;
				for (uint wi = 0; wi < combat.combatants.length(); wi++) {
					combatant@ wt = combat.combatants[wi];
					if (@wt == null or wt.is_dead) continue;
					if (combat.are_hostile(c, wt)) continue; // Allies only
					int heal_amount = wt.max_hp - wt.current_hp;
					if (heal_amount > 0) {
						wt.current_hp = wt.max_hp;
						wish_healed++;
					}
					// Greater Restoration effects: remove Blinded, Deafened, Paralyzed, Petrified, Poisoned, Stunned, Charmed
					if (wt.has_condition(COND_BLINDED)) { wt.remove_condition(COND_BLINDED); broadcast_announce(wt.name + " is no longer Blinded!", false); }
					if (wt.has_condition(COND_DEAFENED)) { wt.remove_condition(COND_DEAFENED); broadcast_announce(wt.name + " is no longer Deafened!", false); }
					if (wt.has_condition(COND_PARALYZED)) { wt.remove_condition(COND_PARALYZED); broadcast_announce(wt.name + " is no longer Paralyzed!", false); }
					if (wt.has_condition(COND_PETRIFIED)) { wt.remove_condition(COND_PETRIFIED); broadcast_announce(wt.name + " is no longer Petrified!", false); }
					if (wt.has_condition(COND_POISONED)) { wt.remove_condition(COND_POISONED); broadcast_announce(wt.name + " is no longer Poisoned!", false); }
					if (wt.has_condition(COND_STUNNED)) { wt.remove_condition(COND_STUNNED); broadcast_announce(wt.name + " is no longer Stunned!", false); }
					if (wt.has_condition(COND_CHARMED)) { wt.remove_condition(COND_CHARMED); broadcast_announce(wt.name + " is no longer Charmed!", false); }
				}
				if (wish_healed > 0) {
					broadcast_announce(c.name + " casts Wish — Instant Health! All allies are restored to full Hit Points and freed from ailments!", true);
				} else {
					broadcast_announce(c.name + " casts Wish — Instant Health! All allies are freed from ailments!", true);
				}
			}
			// ==== END ADDITIONAL SPELL HANDLERS ====
			// ==== END UTILITY / BUFF SPELL HANDLERS ====
			else if (spell.id == "acid_splash" and @target != null) {
				// Basic Rules para 12067: DEX save, 1d6 acid. Scales at L5/11/17.
				int dice_count = cantrip_dice_count(1, c.level);
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_DEX);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (DEX — acid damage)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "DEX save vs Acid Splash"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "DEX save vs Acid Splash"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "DEX save vs Acid Splash", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
				if (!saved) {
					combat.apply_damage(target, total_damage, DMG_ACID, c);
					broadcast_announce(c.name + "'s Acid Splash deals " + total_damage + " acid damage to " + target.name + ".", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "mind_sliver" and @target != null) {
				// Basic Rules 2024 Mind Sliver (para 14174): INT save, 1d6 psychic.
				// Scales at L5/11/17. On failed save, target subtracts 1d4 from its
				// next saving throw (consumed on first save in get_save_bonus).
				int dice_count = cantrip_dice_count(1, c.level);
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_INT);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (INT — psychic damage)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "INT save vs Mind Sliver"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "INT save vs Mind Sliver"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				broadcast_roll(target.name, "INT save vs Mind Sliver", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
				if (!saved) {
					combat.apply_damage(target, total_damage, DMG_PSYCHIC, c);
					target.mind_sliver_penalty_active = true;
					broadcast_announce(c.name + "'s Mind Sliver deals " + total_damage + " psychic damage to " + target.name + ". -1d4 on their next saving throw!", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "thunderclap") {
				// Basic Rules: CON save, 1d6 thunder, all creatures within 5 ft. Scales at L5/11/17.
				int dice_count = cantrip_dice_count(1, c.level);
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " unleashes a Thunderclap!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 5) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (CON — thunder damage)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Thunderclap"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Thunderclap"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "CON save vs Thunderclap", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
					if (!saved) combat.apply_damage(t, total_damage, DMG_THUNDER, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "word_of_radiance") {
				// Basic Rules: CON save, 1d6 radiant, all creatures within 5 ft. Scales at L5/11/17.
				int dice_count = cantrip_dice_count(1, c.level);
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " speaks a Word of Radiance!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(c.x, c.y, t.x, t.y) > 5) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (CON — radiant damage)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Word of Radiance"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Word of Radiance"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "CON save vs Word of Radiance", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Hit!");
					if (!saved) combat.apply_damage(t, total_damage, DMG_RADIANT, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "ice_knife" and @target != null) {
				// Basic Rules: ranged spell attack, 1d10 piercing on primary target,
				// then 2d6 cold AoE in 5 ft radius of impact on DEX save. Upcast +1d6 cold per level.
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				int pierce_dmg = random(1, 10);
				broadcast_roll(c.name, "Ice Knife attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					combat.apply_damage(target, pierce_dmg, DMG_PIERCING, c);
					broadcast_announce(c.name + "'s Ice Knife pierces " + target.name + " for " + pierce_dmg + " piercing damage.", true);
				}
				int center_x = target.x;
				int center_y = target.y;
				int cold_dice = 2 + upcast_levels;
				int cold_dmg = 0;
				for (int d = 0; d < cold_dice; d++) cold_dmg += random(1, 6);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 5) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					int dmg = saved ? cold_dmg / 2 : cold_dmg;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Ice Knife shatter", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_COLD, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "acid_arrow" and @target != null) {
				// Basic Rules: ranged spell attack, 4d4 acid + 2d4 acid at end of target's next turn.
				// Simplified: 6d4 acid on hit, 4d4 on miss. Upcast +1d4 per level.
				int hit_dice = 4 + upcast_levels;
				int miss_dice = 2 + upcast_levels;
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Acid Arrow attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				int total_damage = 0;
				if (hit) {
					int combined = hit_dice + miss_dice;
					for (int d = 0; d < combined; d++) total_damage += random(1, 4);
					combat.apply_damage(target, total_damage, DMG_ACID, c);
					broadcast_announce(c.name + "'s Acid Arrow deals " + total_damage + " acid damage to " + target.name + ".", true);
				} else {
					for (int d = 0; d < miss_dice; d++) total_damage += random(1, 4);
					combat.apply_damage(target, total_damage, DMG_ACID, c);
					broadcast_announce(c.name + "'s Acid Arrow splashes " + target.name + " for " + total_damage + " acid damage.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "flaming_sphere" and @target != null) {
				// Basic Rules 2024 Flaming Sphere (para 13310-13312): "As a Bonus Action,
				// you can move the Sphere up to 30 feet, and when it moves within 5 feet
				// of a creature, that creature must make a DEX save." Concentration.
				int dice_count = 2 + upcast_levels;
				c.flaming_sphere_active = true;
				c.flaming_sphere_dice_count = dice_count;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_DEX);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				broadcast_roll(target.name, "DEX save vs Flaming Sphere", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
				combat.apply_damage(target, dmg, DMG_FIRE, c);
				c.conc_aoe_x = target.x;
				c.conc_aoe_y = target.y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "moonbeam" and @target != null) {
				// Basic Rules: CON save, 2d10 radiant, half on success.
				// Per-turn: creature starting turn in 5ft cylinder takes damage.
				c.moonbeam_active = true;
				c.moonbeam_x = target.x;
				c.moonbeam_y = target.y;
				c.moonbeam_slot_level = cast_slot_level;
				int dice_count = 2 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "CON save vs Moonbeam"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "CON save vs Moonbeam"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				broadcast_roll(target.name, "CON save vs Moonbeam", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
				combat.apply_damage(target, dmg, DMG_RADIANT, c);
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "phantasmal_force" and @target != null) {
				// Basic Rules: INT save, illusion deals 1d6 psychic per turn.
				// Simplified: one-shot 3d8 psychic, INT save, half on success.
				int total_damage = 0;
				for (int d = 0; d < 3; d++) total_damage += random(1, 8);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_INT);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (INT — damage only)
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "INT save vs Phantasmal Force"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "INT save vs Phantasmal Force"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				broadcast_roll(target.name, "INT save vs Phantasmal Force", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
				combat.apply_damage(target, dmg, DMG_PSYCHIC, c);
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "enlarge_reduce" and @target != null) {
				// Basic Rules 2024 Enlarge/Reduce (para 12795-12800): caster chooses Enlarge
				// or Reduce. Enlarge: size +1, advantage on STR checks/saves, +1d4 weapon damage.
				// Reduce: size -1, disadvantage on STR checks/saves, -1d4 weapon damage (min 1).
				// Unwilling targets get CON save to resist. Prompt caster for Enlarge vs Reduce.
				pending_spell_choice sc;
				sc.player_username = c.player_username;
				sc.caster_id = c.id;
				sc.spell_id = "enlarge_reduce";
				sc.cast_slot_level = cast_slot_level;
				sc.primary_target_id = target.id;
				sc.option_keys = {"enlarge", "reduce"};
				sc.option_labels = {"Enlarge (size +1, advantage on STR, +1d4 weapon damage)", "Reduce (size -1, disadvantage on STR, -1d4 weapon damage)"};
				// Bot AI: auto-pick Enlarge for allies, Reduce for hostiles
				bool hostile = (target.is_player != c.is_player) or combat.mode == "pvp";
				if (hostile) {
					sc.option_keys = {"reduce", "enlarge"};
					sc.option_labels = {"Reduce (size -1, disadvantage on STR, -1d4 weapon damage)", "Enlarge (size +1, advantage on STR, +1d4 weapon damage)"};
				}
				sc.prompt_text = "Enlarge or Reduce " + target.name + "? Press 1 for " + sc.option_labels[0] + ", or 2 for " + sc.option_labels[1] + ".";
				send_spell_choice_prompt(c, sc);
			}
			else if (spell.id == "prayer_of_healing") {
				// Basic Rules: heals up to 6 creatures for 2d8 + spellcasting mod.
				// Simplified: all friendly within 30 ft get 2d8 + mod. Upcast +1d8 per level.
				int dice_count = 2 + upcast_levels;
				int heal = 0;
				for (int d = 0; d < dice_count; d++) heal += random(1, 8);
				heal = apply_empowered_healing(c, heal, dice_count, 8);
				heal += get_spellcasting_ability_mod(c);
				heal += get_life_domain_healing_bonus(c, spell, cast_slot_level);
				if (heal < 1) heal = 1;
				// Basic Rules 2024 Beacon of Hope (para 12201): per-target max healing
				int heal_beacon = dice_count * 8 + get_spellcasting_ability_mod(c) + get_life_domain_healing_bonus(c, spell, cast_slot_level);
				if (heal_beacon < 1) heal_beacon = 1;
				int healed = 0;
				for (uint mi = 0; mi < combat.combatants.length() and healed < 6; mi++) {
					combatant@ ally = combat.combatants[mi];
					if (@ally == null or ally.is_dead) continue;
					if (ally.is_player != c.is_player and ally.id != c.id) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) continue;
					int effective = combat.apply_healing(ally, ally.beacon_of_hope_active ? heal_beacon : heal);
					record_effective_healing(c.player_username, effective);
					healed++;
				}
				broadcast_announce(c.name + " casts Prayer of Healing, restoring " + heal + " HP to " + healed + " ally" + (healed == 1 ? "" : "ies") + ".", true);
				try_chalice_healing(c);
			}
			else if (spell.id == "call_lightning") {
				// Basic Rules 2024 Call Lightning (para 12321-12323): DEX save, 3d10
				// lightning in 5 ft radius. Concentration. "On each of your subsequent
				// turns, you can use your action to call down lightning in this way again."
				int dice_count = 3 + upcast_levels;
				c.call_lightning_active = true;
				c.call_lightning_dice_count = dice_count;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 10);
				broadcast_announce(c.name + " calls a bolt of lightning from the storm!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 5) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Call Lightning"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Call Lightning"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Call Lightning", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_LIGHTNING, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "blight" and @target != null) {
				// Basic Rules: CON save, 8d8 necrotic on target, half on save. Upcast +1d8 per level.
				int dice_count = 8 + upcast_levels;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 8);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain
				if (!saved and try_arcane_deflection_save(target, save_dc, save_total)) saved = true;
				if (!saved) { int fg = try_flash_of_genius(target, save_dc, save_total, "CON save vs Blight"); if (fg >= save_dc) { saved = true; save_total = fg; } }
				if (!saved) { int mv = try_maverick_spirit(target, save_dc, save_total, "CON save vs Blight"); if (mv >= save_dc) { saved = true; save_total = mv; } }
				if (!saved) { int bf = try_boon_of_fate_bonus(target, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
				if (!saved and try_stroke_of_luck_save(target, save_dc, save_bonus + bless_bonus)) saved = true;
				int dmg = saved ? total_damage / 2 : total_damage;
				if (dmg < 1) dmg = 1;
				broadcast_roll(target.name, "CON save vs Blight", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
				combat.apply_damage(target, dmg, DMG_NECROTIC, c);
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "vitriolic_sphere") {
				// Basic Rules: DEX save, 10d4 acid + 5d4 next turn in 20 ft radius. Upcast +2d4 per level.
				// Simplified: 15d4 acid AoE. Upcast +2d4 per level.
				int dice_count = 15 + (upcast_levels * 2);
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 4);
				broadcast_announce(c.name + " hurls a Vitriolic Sphere into a 20-foot radius!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Vitriolic Sphere"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Vitriolic Sphere"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "DEX save vs Vitriolic Sphere", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_ACID, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "evards_black_tentacles") {
				// Basic Rules: DEX save, 3d6 bludgeoning and Restrained in 20 ft square.
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				// Track AoE center for per-turn damage in advance_turn
				c.conc_aoe_x = center_x;
				c.conc_aoe_y = center_y;
				c.conc_aoe_slot_level = cast_slot_level;
				broadcast_announce(c.name + " summons Evard's Black Tentacles!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 20) continue;
					int dmg = 0;
					for (int d = 0; d < 3; d++) dmg += random(1, 6);
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain (DEX condition — no Mage Slayer)
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int ds = try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "DEX save vs Black Tentacles"); if (ds >= save_dc) saved = true; }
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Black Tentacles"); if (fg >= save_dc) saved = true; }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Black Tentacles"); if (mv >= save_dc) saved = true; }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) saved = true; }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					broadcast_roll(t.name, "DEX save vs Black Tentacles", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Grabbed!");
					combat.apply_damage(t, dmg, DMG_BLUDGEONING, c);
					if (!saved) {
						t.add_condition(COND_RESTRAINED);
						broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Restrained"}});
					}
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "flame_strike") {
				// Basic Rules: DEX save, 4d6 fire + 4d6 radiant in 10 ft radius cylinder. Upcast +1d6 per type.
				int dice_fire = 4 + upcast_levels;
				int dice_rad = 4 + upcast_levels;
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int fire_total = 0;
				for (int d = 0; d < dice_fire; d++) fire_total += random(1, 6);
				int rad_total = 0;
				for (int d = 0; d < dice_rad; d++) rad_total += random(1, 6);
				broadcast_announce(c.name + " calls down a pillar of divine Flame Strike!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 10) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "DEX save vs Flame Strike"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "DEX save vs Flame Strike"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int fd = saved ? fire_total / 2 : fire_total;
					int rd = saved ? rad_total / 2 : rad_total;
					if (fd < 1) fd = 1;
					if (rd < 1) rd = 1;
					broadcast_roll(t.name, "DEX save vs Flame Strike", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, fd, DMG_FIRE, c);
					combat.apply_damage(t, rd, DMG_RADIANT, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "contagion" and @target != null) {
				// Basic Rules: melee spell attack, 3d8 necrotic + poisoned.
				int atk_roll = random(1, 20);
				int atk_total = atk_roll + spell_atk;
				bool hit = atk_total >= target.armor_class;
				broadcast_roll(c.name, "Contagion attack roll", atk_roll, spell_atk, atk_total, hit ? "Hit!" : "Missed!");
				if (hit) {
					int total_damage = 0;
					for (int d = 0; d < 3; d++) total_damage += random(1, 8);
					combat.apply_damage(target, total_damage, DMG_NECROTIC, c);
					target.add_condition(COND_POISONED);
					broadcast_to_battle({{"type", message_types::condition_applied}, {"target", target.name}, {"condition", "Poisoned"}});
					broadcast_announce(c.name + "'s Contagion deals " + total_damage + " necrotic damage to " + target.name + " and poisons them.", true);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "mass_cure_wounds") {
				// Basic Rules: heal up to 6 creatures for 3d8 + mod. Upcast +1d8 per level.
				int dice_count = 3 + upcast_levels;
				int heal = 0;
				for (int d = 0; d < dice_count; d++) heal += random(1, 8);
				heal = apply_empowered_healing(c, heal, dice_count, 8);
				heal += get_spellcasting_ability_mod(c);
				heal += get_life_domain_healing_bonus(c, spell, cast_slot_level);
				if (heal < 1) heal = 1;
				// Basic Rules 2024 Beacon of Hope (para 12201): per-target max healing
				int heal_beacon = dice_count * 8 + get_spellcasting_ability_mod(c) + get_life_domain_healing_bonus(c, spell, cast_slot_level);
				if (heal_beacon < 1) heal_beacon = 1;
				int healed = 0;
				for (uint mi = 0; mi < combat.combatants.length() and healed < 6; mi++) {
					combatant@ ally = combat.combatants[mi];
					if (@ally == null or ally.is_dead) continue;
					if (ally.is_player != c.is_player and ally.id != c.id) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) continue;
					int effective = combat.apply_healing(ally, ally.beacon_of_hope_active ? heal_beacon : heal);
					record_effective_healing(c.player_username, effective);
					healed++;
				}
				broadcast_announce(c.name + " casts Mass Cure Wounds, restoring " + heal + " HP to " + healed + " ally" + (healed == 1 ? "" : "ies") + ".", true);
				try_chalice_healing(c);
			}
			else if (spell.id == "circle_of_death") {
				// Basic Rules: CON save, 8d6 necrotic in 60 ft sphere. Upcast +2d6 per level.
				int dice_count = 8 + (upcast_levels * 2);
				int center_x = @target != null ? target.x : c.x;
				int center_y = @target != null ? target.y : c.y;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				broadcast_announce(c.name + " unleashes a Circle of Death in a 60-foot sphere!", true);
				for (uint ti = 0; ti < combat.combatants.length(); ti++) {
					combatant@ t = combat.combatants[ti];
					if (@t == null or t.is_dead or t.id == c.id) continue;
					if (feet_distance(center_x, center_y, t.x, t.y) > 60) continue;
					int save_roll = random(1, 20);
					apply_hound_save_disadvantage(t, c.id, save_roll);
					int save_bonus = t.get_save_bonus(ABILITY_CON);
					int bless_bonus = roll_bless_bonus(t);
					int save_total = save_roll + save_bonus + bless_bonus;
					bool saved = save_total >= save_dc;
					// Save failure chain
					if (!saved and try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
					if (!saved) { int fg = try_flash_of_genius(t, save_dc, save_total, "CON save vs Circle of Death"); if (fg >= save_dc) { saved = true; save_total = fg; } }
					if (!saved) { int mv = try_maverick_spirit(t, save_dc, save_total, "CON save vs Circle of Death"); if (mv >= save_dc) { saved = true; save_total = mv; } }
					if (!saved) { int bf = try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) { saved = true; save_total = bf; } }
					if (!saved and try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
					int dmg = saved ? total_damage / 2 : total_damage;
					if (dmg < 1) dmg = 1;
					broadcast_roll(t.name, "CON save vs Circle of Death", save_roll, save_bonus + bless_bonus, save_total, saved ? "Half damage!" : "Full damage!");
					combat.apply_damage(t, dmg, DMG_NECROTIC, c);
				}
				broadcast_state();
				check_battle_end();
				return;
			}
			else if (spell.id == "harm" and @target != null) {
				// Basic Rules: CON save, 14d6 necrotic single target, half on save.
				int dice_count = 14;
				int total_damage = 0;
				for (int d = 0; d < dice_count; d++) total_damage += random(1, 6);
				int save_roll = random(1, 20);
				apply_hound_save_disadvantage(target, c.id, save_roll);
				int save_bonus = target.get_save_bonus(ABILITY_CON);
				int bless_bonus = roll_bless_bonus(target);
				int save_total = save_roll + save_bonus + bless_bonus;
