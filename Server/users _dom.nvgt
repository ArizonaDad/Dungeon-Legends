		}

		else if (feature == "empowered_healing") {
			// Divine Soul: reroll healing dice
			if (c.class_name != "Sorcerer" or c.subclass != "Divine Soul") { u.send({{"type", message_types::announce}, {"text", "Only Divine Souls can use Empowered Healing."}, {"interrupt", true}}); return; }
			c.empowered_healing_active = true;
