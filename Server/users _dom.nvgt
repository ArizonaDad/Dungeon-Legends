			c.used_action = true;
			c.channel_divinity_uses--;
			c.emboldening_bond_active = true;
			u.room.bm.broadcast_announce(c.name + " forms an Emboldening Bond with allies! Bonds grant +1d4 to attacks and saves.", true);
		}

		else if (feature == "twilight_sanctuary") {
			// Twilight Domain Cleric: channel divinity creates a healing aura
			if (c.class_name != "Cleric" or c.subclass != "Twilight Domain") { u.send({{"type", message_types::announce}, {"text", "Only Twilight Domain clerics can use Twilight Sanctuary."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
