			c.channel_divinity_uses--;
			c.abjure_extraplanar_active = true;
			u.room.bm.broadcast_announce(c.name + " invokes Abjure the Extraplanar! Nearby aberrations, celestials, elementals, fey, and fiends must save vs fear.", true);
		}

		else if (feature == "insightful_fighting") {
			// Inquisitive Rogue: Study target to enable sneak attack without advantage
			if (c.class_name != "Rogue" or c.subclass != "Inquisitive") { u.send({{"type", message_types::announce}, {"text", "Only Inquisitive rogues can use Insightful Fighting."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.inquisitive_target = target_id;
			u.room.bm.broadcast_announce(c.name + " studies a target with Insightful Fighting!", false);
		}

		else if (feature == "mastermind_help") {
			// Mastermind Rogue: bonus action Help at 30ft range
			if (c.class_name != "Rogue" or c.subclass != "Mastermind") { u.send({{"type", message_types::announce}, {"text", "Only Mastermind rogues can use Mastermind Help."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.help_target_id = target_id;
			u.room.bm.broadcast_announce(c.name + " uses Master of Tactics to Help an ally as a bonus action!", false);
		}

		else if (feature == "fast_hands") {
			// Thief Rogue: Fast Hands bonus action (use object / use item)
			if (c.class_name != "Rogue" or c.subclass != "Thief") { u.send({{"type", message_types::announce}, {"text", "Only Thieves can use Fast Hands."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			u.room.bm.broadcast_announce(c.name + " uses Fast Hands to quickly manipulate an object.", false);
		}

		else if (feature == "radiant_sun_bolt") {
			// Way of the Sun Soul Monk: bonus action ranged attack using martial arts die
			if (c.class_name != "Monk" or c.subclass != "Way of the Sun Soul") { u.send({{"type", message_types::announce}, {"text", "Only Way of the Sun Soul monks can use Radiant Sun Bolt."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int dex_mod = c.get_ability_mod(ABILITY_DEX);
			int die_size = 4;
			if (c.level >= 5) die_size = 6;
			if (c.level >= 11) die_size = 8;
			if (c.level >= 17) die_size = 10;
			int atk_bonus = dex_mod + c.proficiency;
			int roll = random(1, 20);
			int total = roll + atk_bonus;
			if (total >= tgt.armor_class) {
				int dmg = random(1, die_size) + dex_mod;
				u.room.bm.combat.apply_damage(tgt, dmg, DMG_RADIANT, c);
				u.room.bm.broadcast_announce(c.name + "'s Radiant Sun Bolt hits for " + dmg + " radiant damage! (Rolled " + roll + ")", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Radiant Sun Bolt misses. (Rolled " + roll + " needed " + tgt.armor_class + ")", false);
			}
		}

		else if (feature == "kensei_weapon") {
			// Way of the Kensei Monk: choose kensei weapon (deflect missiles + accuracy)
			if (c.class_name != "Monk" or c.subclass != "Way of the Kensei") { u.send({{"type", message_types::announce}, {"text", "Only Way of the Kensei monks can use this."}, {"interrupt", true}}); return; }
			c.kensei_weapon_active = true;
			u.room.bm.broadcast_announce(c.name + " declares their Kensei weapon!", false);
		}

		else if (feature == "drunken_master_redirect") {
			// Way of the Drunken Master: Redirect Attack reaction (forces attacker to redirect)
			if (c.class_name != "Monk" or c.subclass != "Way of the Drunken Master") { u.send({{"type", message_types::announce}, {"text", "Only Drunken Master monks can Redirect Attack."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "No Focus Points remaining."}, {"interrupt", true}}); return; }
			c.focus_points--;
			c.has_reaction = false;
			c.drunken_master_opportunity = true;
			u.room.bm.broadcast_announce(c.name + " uses Redirect Attack!", false);
		}

		else if (feature == "breath_of_dragon") {
			// Way of the Ascendant Dragon Monk: breath weapon
			if (c.class_name != "Monk" or c.subclass != "Way of the Ascendant Dragon") { u.send({{"type", message_types::announce}, {"text", "Only Way of the Ascendant Dragon monks can use this."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "No Focus Points remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.focus_points--;
			c.has_action = false;
			c.used_action = true;
			// 20ft line or 15ft cone — deal martial arts die damage to all in area
			int die_size = 4;
			if (c.level >= 5) die_size = 6;
			if (c.level >= 11) die_size = 8;
			if (c.level >= 17) die_size = 10;
			int damage = random(1, die_size) * 2;
			u.room.bm.broadcast_announce(c.name + " unleashes a 15-foot cone of draconic breath for " + damage + " fire damage!", true);
			// Apply to enemies in range
			for (uint bi = 0; bi < u.room.bm.combat.combatants.length(); bi++) {
				combatant@ t = u.room.bm.combat.combatants[bi];
				if (@t == null or t.is_dead or t.id == c.id) continue;
				if (t.is_player == c.is_player and u.room.bm.combat.mode != "pvp") continue;
				int dist = feet_distance(c.x, c.y, t.x, t.y);
				if (dist <= 15) {
					// DEX save for half
					int save_roll = random(1, 20);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
					int dmg = (save_roll + save_bonus >= dc) ? damage / 2 : damage;
					u.room.bm.combat.apply_damage(t, dmg, DMG_FIRE, c);
				}
			}
		}

		else if (feature == "astral_arms") {
			// Way of the Astral Self Monk: manifest astral arms (bonus action, spend 1 Focus)
			if (c.class_name != "Monk" or c.subclass != "Way of the Astral Self") { u.send({{"type", message_types::announce}, {"text", "Only Astral Self monks can manifest astral arms."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "No Focus Points remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.focus_points--;
			u.room.bm.broadcast_announce(c.name + " manifests Astral Arms! Reach extended to 10ft, unarmed strikes deal force damage.", true);
		}

		else if (feature == "tentacle_of_deeps") {
			// The Fathomless Warlock: summon tentacle, or reactivate for attack
			if (c.class_name != "Warlock" or c.subclass != "The Fathomless") { u.send({{"type", message_types::announce}, {"text", "Only Fathomless warlocks can summon Tentacle of the Deeps."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt != null and !tgt.is_dead) {
				// Attack with tentacle — 1d8 cold damage + reduce speed
				int dex_mod = c.get_ability_mod(ABILITY_DEX);
				int atk_bonus = dex_mod + c.proficiency;
				int roll = random(1, 20);
				if (roll + atk_bonus >= tgt.armor_class) {
					int cold_dmg = random(1, 8);
					if (c.level >= 10) cold_dmg += random(1, 8);
					u.room.bm.combat.apply_damage(tgt, cold_dmg, DMG_COLD, c);
					tgt.speed -= 10;
					if (tgt.speed < 0) tgt.speed = 0;
					u.room.bm.broadcast_announce(c.name + "'s Tentacle of the Deeps strikes " + tgt.name + " for " + cold_dmg + " cold damage and reduces their speed!", true);
				} else {
					u.room.bm.broadcast_announce(c.name + "'s Tentacle of the Deeps misses " + tgt.name + ".", false);
				}
			}
			c.tentacle_of_deeps_active = true;
		}

		else if (feature == "genie_vessel") {
			// The Genie Warlock: retreat to vessel (flavor: temp HP + concealed)
			if (c.class_name != "Warlock" or c.subclass != "The Genie") { u.send({{"type", message_types::announce}, {"text", "Only Genie warlocks can enter their Vessel."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int temp_hp = c.proficiency + c.level;
			if (c.temp_hp < temp_hp) c.temp_hp = temp_hp;
			c.genie_vessel_active = true;
			u.room.bm.broadcast_announce(c.name + " retreats into their Genie's Vessel, gaining " + temp_hp + " temp HP!", true);
		}

		else if (feature == "form_of_dread") {
			// Undead Warlock: Form of Dread — bonus action, frighten on hit, temp HP
			if (c.class_name != "Warlock" or c.subclass != "The Undead") { u.send({{"type", message_types::announce}, {"text", "Only Undead warlocks can manifest Form of Dread."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int temp_hp = 1 + c.level;
			if (c.temp_hp < temp_hp) c.temp_hp = temp_hp;
			c.form_of_dread_active = true;
			c.form_of_dread_rounds = 10;
			u.room.bm.broadcast_announce(c.name + " manifests Form of Dread! Gains " + temp_hp + " temp HP, enemies hit may be frightened.", true);
		}

		else if (feature == "starry_form") {
			// Circle of Stars Druid: bonus action to assume Starry Form (Chalice/Archer/Dragon)
			if (c.class_name != "Druid" or c.subclass != "Circle of the Stars") { u.send({{"type", message_types::announce}, {"text", "Only Circle of the Stars druids can use Starry Form."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.starry_form_active = true;
			string form = msg.exists("form") ? string(msg["form"]) : "Chalice";
			c.starry_form_type = form;
			u.room.bm.broadcast_announce(c.name + " assumes Starry Form: " + form + "!", true);
		}

		else if (feature == "land_stride") {
			// Circle of the Land Druid: Land's Stride - ignore difficult terrain
			if (c.class_name != "Druid" or c.subclass != "Circle of the Land") { u.send({{"type", message_types::announce}, {"text", "Only Circle of the Land druids can use Land's Stride."}, {"interrupt", true}}); return; }
			c.land_stride_active = true;
			u.room.bm.broadcast_announce(c.name + "'s Land's Stride activates.", false);
		}

		else if (feature == "wildfire_spirit") {
			// Wildfire Druid: summon Wildfire Spirit (simplified: flag for temp HP + bonus damage)
			if (c.class_name != "Druid" or c.subclass != "Circle of Wildfire") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Wildfire druids can summon a Wildfire Spirit."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.wildfire_spirit_active = true;
			u.room.bm.broadcast_announce(c.name + " summons a Wildfire Spirit!", true);
		}

		else if (feature == "echo_knight_manifest") {
			// Echo Knight (Wildemount): Manifest Echo — bonus action, echo in unoccupied space within 15ft
			// Echo has 1 HP, AC = 14 + prof, immune to conditions, uses caster saves, same size as caster
			if (c.class_name != "Fighter" or c.subclass != "Echo Knight") { u.send({{"type", message_types::announce}, {"text", "Only Echo Knights can manifest echoes."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.echo_active = true;
			c.echo_hp = 1;
			// Place echo 5ft to the north (simplified)
			c.echo_x = c.x;
			c.echo_y = c.y + 5;
			u.room.bm.broadcast_announce(c.name + " manifests an Echo 5ft north. Echo has AC " + (14 + c.proficiency) + " and 1 HP.", true);
		}
		else if (feature == "unleash_incarnation") {
			// Echo Knight L3: after Attack action, bonus action for extra melee attack from echo's space
			if (c.class_name != "Fighter" or c.subclass != "Echo Knight") { u.send({{"type", message_types::announce}, {"text", "Only Echo Knights can unleash incarnation."}, {"interrupt", true}}); return; }
			if (!c.echo_active) { u.send({{"type", message_types::announce}, {"text", "You have no active echo."}, {"interrupt", true}}); return; }
			if (!c.used_action) { u.send({{"type", message_types::announce}, {"text", "You must first take the Attack action."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.unleash_incarnation_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Unleash Incarnation uses remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			int dist_echo = feet_distance(c.echo_x, c.echo_y, tgt.x, tgt.y);
			int weapon_reach = c.main_hand_range > 0 ? c.main_hand_range : 5;
			if (dist_echo > weapon_reach) { u.send({{"type", message_types::announce}, {"text", "Target out of echo's reach."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.unleash_incarnation_uses--;
			int atk_bonus = c.get_ability_mod(ABILITY_STR) + c.proficiency;
			int roll = random(1, 20);
			int total = roll + atk_bonus;
			u.room.bm.broadcast_announce(c.name + "'s echo lunges at " + tgt.name + "!", true);
			if (total >= tgt.armor_class or roll == 20) {
				int dmg = random(1, c.main_hand_damage_dice);
				if (roll == 20) dmg += random(1, c.main_hand_damage_dice);
				dmg += c.get_ability_mod(ABILITY_STR);
				if (dmg < 1) dmg = 1;
				u.room.bm.combat.apply_damage(tgt, dmg, c.main_hand_damage_type, c);
				u.room.bm.broadcast_announce("Echo hits " + tgt.name + " for " + dmg + " damage! Uses remaining: " + c.unleash_incarnation_uses, true);
			} else {
				u.room.bm.broadcast_announce("Echo's attack misses " + tgt.name + ".", false);
			}
		}
		else if (feature == "adjust_density") {
			// Wildemount p.5428: "As an action, you can magically alter the weight of one
			// object or creature you can see within 30 feet of you. The object or creature
			// must be Large or smaller. The target's weight is halved or doubled for up to
			// 1 minute or until your concentration ends." At L10 the size cap raises to Huge.
			// The choice (halve vs double) is the player's — never auto-pick.
			if (c.class_name != "Wizard" or c.subclass != "Graviturgy Magic") { u.send({{"type", message_types::announce}, {"text", "Only Graviturgy wizards can adjust density."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 feet)."}, {"interrupt", true}}); return; }
			// Adjust Density is concentration. Drop any prior concentration before establishing new.
			u.room.bm.clear_concentration_effects(c);
			c.has_action = false;
			c.used_action = true;
			pending_spell_choice sc;
			sc.player_username = c.player_username;
			sc.caster_id = c.id;
			sc.spell_id = "adjust_density";
			sc.cast_slot_level = 0;
			sc.primary_target_id = tgt.id;
			sc.option_keys = {"halve", "double"};
			sc.option_labels = {"Halve density (+10 ft speed, disadvantage on STR)", "Double density (-10 ft speed, advantage on STR)"};
			sc.prompt_text = "Adjust Density on " + tgt.name + ": press 1 to halve their density (+10 feet speed, disadvantage on Strength checks and saves), or 2 to double their density (-10 feet speed, advantage on Strength checks and saves).";
			u.room.bm.send_spell_choice_prompt(c, sc);
		}
		else if (feature == "event_horizon") {
			// Graviturgy Wizard L14: Action - 30ft aura, STR save or 2d10 force + speed 0, 1/LR
			if (c.class_name != "Wizard" or c.subclass != "Graviturgy Magic") { u.send({{"type", message_types::announce}, {"text", "Only Graviturgy wizards can create an Event Horizon."}, {"interrupt", true}}); return; }
			if (c.level < 14) { u.send({{"type", message_types::announce}, {"text", "Event Horizon unlocks at level 14."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.event_horizon_active = true;
			int ev_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
			for (uint evi = 0; evi < u.room.bm.combat.combatants.length(); evi++) {
				combatant@ evt = u.room.bm.combat.combatants[evi];
				if (@evt == null or evt.is_dead or evt.id == c.id) continue;
				if (evt.is_player == c.is_player) continue;
				if (feet_distance(c.x, c.y, evt.x, evt.y) > 30) continue;
				int save = random(1, 20) + evt.get_save_bonus(ABILITY_STR);
				int ev_dmg = random(1, 10) + random(1, 10);
				if (save >= ev_dc) ev_dmg /= 2;
				else evt.speed = 0;
				u.room.bm.combat.apply_damage(evt, ev_dmg, DMG_FORCE, c);
				u.room.bm.broadcast_announce(evt.name + (save >= ev_dc ? " resists" : " is crushed by") + " the Event Horizon: " + ev_dmg + " force damage.", true);
			}
		}
		else if (feature == "breath_of_the_dragon") {
			// Way of the Ascendant Dragon L3: replace one attack with 20ft cone or 30ft line
			// Deals 2 * Martial Arts die damage (acid/cold/fire/lightning/poison). Dex save for half.
			// PB uses/LR, or 2 ki points
			if (c.class_name != "Monk" or c.subclass != "Way of the Ascendant Dragon") { u.send({{"type", message_types::announce}, {"text", "Only Ascendant Dragon monks have this feature."}, {"interrupt", true}}); return; }
			if (!c.has_action and !c.used_action) { u.send({{"type", message_types::announce}, {"text", "You must take the Attack action."}, {"interrupt", true}}); return; }
			if (c.ascendant_dragon_breath_uses <= 0 and c.focus_points < 2) { u.send({{"type", message_types::announce}, {"text", "No uses remaining and insufficient Focus Points."}, {"interrupt", true}}); return; }
			if (c.ascendant_dragon_breath_uses <= 0) c.focus_points -= 2;
			else c.ascendant_dragon_breath_uses--;
			// Martial Arts die size
			int ma_die = 4;
			if (c.level >= 5) ma_die = 6;
			if (c.level >= 11) ma_die = 8;
			if (c.level >= 17) ma_die = 10;
			int breath_dice = 2;
			if (c.level >= 11) breath_dice = 3;
			int breath_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			// AoE: hit all enemies within 20ft (cone approximation)
			u.room.bm.broadcast_announce(c.name + " unleashes Breath of the Dragon!", true);
			for (uint bdi = 0; bdi < u.room.bm.combat.combatants.length(); bdi++) {
				combatant@ bdt = u.room.bm.combat.combatants[bdi];
				if (@bdt == null or bdt.is_dead or bdt.id == c.id) continue;
				if (bdt.is_player == c.is_player) continue;
				if (feet_distance(c.x, c.y, bdt.x, bdt.y) > 20) continue;
				int bd_dmg = 0;
				for (int bd = 0; bd < breath_dice; bd++) bd_dmg += random(1, ma_die);
				int save = random(1, 20) + bdt.get_save_bonus(ABILITY_DEX);
				if (save >= breath_dc) bd_dmg /= 2;
				if (bd_dmg < 1) bd_dmg = 1;
				u.room.bm.combat.apply_damage(bdt, bd_dmg, DMG_FIRE, c);
				u.room.bm.broadcast_announce(bdt.name + " takes " + bd_dmg + " fire damage (save " + save + " vs DC " + breath_dc + ")", false);
			}
		}
		else if (feature == "aspect_of_the_wyrm") {
			// Way of the Ascendant Dragon L11: bonus action aura 10ft, 1 min, frightful or resistance
			if (c.class_name != "Monk" or c.subclass != "Way of the Ascendant Dragon") { u.send({{"type", message_types::announce}, {"text", "Only Ascendant Dragon monks have this feature."}, {"interrupt", true}}); return; }
			if (c.level < 11) { u.send({{"type", message_types::announce}, {"text", "Aspect of the Wyrm unlocks at level 11."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.aspect_of_wyrm_used and c.focus_points < 3) { u.send({{"type", message_types::announce}, {"text", "Already used; need 3 Focus Points."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			if (c.aspect_of_wyrm_used) c.focus_points -= 3;
			c.aspect_of_wyrm_used = true;
			// Apply fire resistance to self and allies in 10ft
			for (uint awi = 0; awi < u.room.bm.combat.combatants.length(); awi++) {
				combatant@ awa = u.room.bm.combat.combatants[awi];
				if (@awa == null or awa.is_dead) continue;
				if (awa.is_player != c.is_player and awa.id != c.id) continue;
				if (feet_distance(c.x, c.y, awa.x, awa.y) > 10) continue;
				awa.fire_resistance = true;
			}
			u.room.bm.broadcast_announce(c.name + " activates Aspect of the Wyrm! 10ft aura grants fire resistance.", true);
		}
		else if (feature == "magic_coin") {
			// College of Mercantile L3: Action — ranged spell attack (CHA + prof) vs AC, 1d12 thunder (scales)
			if (c.class_name != "Bard" or c.subclass != "College of Mercantile") { u.send({{"type", message_types::announce}, {"text", "Only Mercantile bards can fling Magic Coins."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action this turn."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Target out of range (60ft)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			int mc_atk = random(1, 20) + c.get_ability_mod(ABILITY_CHA) + c.proficiency;
			int thunder_dice = 1;
			if (c.level >= 6) thunder_dice = 2;
			if (c.level >= 14) thunder_dice = 3;
			if (mc_atk >= tgt.armor_class or mc_atk >= 20) {
				int mc_dmg = 1; // 1 bludgeoning
				for (int td = 0; td < thunder_dice; td++) mc_dmg += random(1, 12);
				u.room.bm.combat.apply_damage(tgt, mc_dmg, DMG_THUNDER, c);
				u.room.bm.broadcast_announce(c.name + "'s Magic Coin strikes " + tgt.name + " for " + mc_dmg + " thunder damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Magic Coin misses " + tgt.name + ".", false);
			}
		}
		else if (feature == "create_void") {
			// Astral Domain L3: Bonus Action Channel Divinity — 15ft sphere within 60ft, Dex save or
			// 1d8 + cleric level force damage, pulled 15ft; half on success
			if (c.class_name != "Cleric" or c.subclass != "Astral Domain") { u.send({{"type", message_types::announce}, {"text", "Only Astral Clerics can Create Void."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected (center of void)."}, {"interrupt", true}}); return; }
			combatant@ center = u.room.bm.combat.get_combatant(target_id);
			if (@center == null) { u.send({{"type", message_types::announce}, {"text", "Invalid center target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, center.x, center.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Out of range (60ft)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			int cv_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			u.room.bm.broadcast_announce(c.name + " tears open a planar void centered on " + center.name + "!", true);
			for (uint cvi = 0; cvi < u.room.bm.combat.combatants.length(); cvi++) {
				combatant@ cvt = u.room.bm.combat.combatants[cvi];
				if (@cvt == null or cvt.is_dead) continue;
				if (feet_distance(center.x, center.y, cvt.x, cvt.y) > 15) continue;
				int save = random(1, 20) + cvt.get_save_bonus(ABILITY_DEX);
				int cv_dmg = random(1, 8) + c.level;
				bool saved = save >= cv_dc;
				if (saved) cv_dmg /= 2;
				u.room.bm.combat.apply_damage(cvt, cv_dmg, DMG_FORCE, c);
				// Pull toward center 15ft (simple direction)
				if (!saved) {
					if (cvt.x < center.x) cvt.x += 15;
					else if (cvt.x > center.x) cvt.x -= 15;
					if (cvt.y < center.y) cvt.y += 15;
					else if (cvt.y > center.y) cvt.y -= 15;
				}
				u.room.bm.broadcast_announce(cvt.name + " takes " + cv_dmg + " force damage from the void (save " + save + " vs DC " + cv_dc + ").", false);
			}
		}
		else if (feature == "mark_of_heretic") {
			// Oath of Zeal (Grim Hollow) L3 Channel Divinity: mark target, crit 19-20 vs them for 1 min,
			// reaction weapon attack at start of marked target's turn
			if (c.class_name != "Paladin" or c.subclass != "Oath of Zeal") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Zeal paladins can use Mark of the Heretic."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30ft)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.mark_of_heretic_active = true;
			c.mark_of_heretic_target = tgt.id;
			u.room.bm.broadcast_announce(c.name + " marks " + tgt.name + " with the Mark of the Heretic! Crit on 19+ and reactions.", true);
		}
		else if (feature == "summon_primal_companion") {
			// Tasha's Beast Master Ranger L3 Primal Companion: bonus action summon a Land/
			// Sea/Sky beast companion. Source stat block: HP = 5 + 5*ranger level, AC =
			// 13 + ranger PB, attack bonus = ranger PB + WIS mod, damage = 1d8 + ranger PB.
			// Default to Land beast (slashing damage); the Tasha's source has 3 variants.
			if (c.class_name != "Ranger" or c.subclass != "Beast Master") { u.send({{"type", message_types::announce}, {"text", "Only Beast Master rangers can summon a Primal Companion."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.beast_companion_id != 0) { u.send({{"type", message_types::announce}, {"text", "Your Primal Companion is already in the field."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int companion_hp = 5 + 5 * c.level;
			int companion_ac = 13 + c.proficiency;
			int wis_mod_bm = c.get_ability_mod(ABILITY_WIS);
			int companion_attack = c.proficiency + wis_mod_bm;
			int companion_dmg_mod = c.proficiency;
			combatant@ pet = u.room.bm.spawn_companion(c, "beast_master_land", c.name + "'s Land Beast", companion_hp, companion_ac, 40, companion_attack, 1, 8, companion_dmg_mod, DMG_SLASHING, 0);
			if (@pet != null) {
				c.beast_companion_id = pet.id;
				c.beast_companion_active = true;
				u.room.bm.broadcast_announce(c.name + " summons their Primal Land Beast! HP " + companion_hp + ", AC " + companion_ac + ".", true);
			}
		}
		else if (feature == "summon_steel_defender") {
			// Tasha's Battle Smith Artificer L3 Steel Defender: full stat block construct.
			// HP = 2 + 5*artificer level + INT mod (per Tasha's), AC = 15, speed 40.
			// Attack: rend, +PB+INT to hit, 1d8+PB force damage.
			if (c.class_name != "Artificer" or c.subclass != "Battle Smith") { u.send({{"type", message_types::announce}, {"text", "Only Battle Smith artificers can summon a Steel Defender."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.steel_defender_active) { u.send({{"type", message_types::announce}, {"text", "Your Steel Defender is already active."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int int_mod_bs = c.get_ability_mod(ABILITY_INT);
			int defender_hp = 2 + 5 * c.level + int_mod_bs;
			int defender_attack = c.proficiency + int_mod_bs;
			combatant@ defender = u.room.bm.spawn_companion(c, "battle_smith", c.name + "'s Steel Defender", defender_hp, 15, 40, defender_attack, 1, 8, c.proficiency, DMG_FORCE, 0);
			if (@defender != null) {
				c.steel_defender_active = true;
				u.room.bm.broadcast_announce(c.name + " activates their Steel Defender! HP " + defender_hp + ", AC 15.", true);
			}
		}
		else if (feature == "summon_drake_companion") {
			// Fizban's Drakewarden Ranger L3 Drake Companion: HP = 5 + 5*ranger level (matches
			// existing drake_max_hp init). AC = 14 + PB, speed 40. Bite attack +PB+WIS,
			// 1d6+PB damage of the chosen damage type (acid/cold/fire/lightning/poison).
			if (c.class_name != "Ranger" or c.subclass != "Drakewarden") { u.send({{"type", message_types::announce}, {"text", "Only Drakewarden rangers can summon a Drake."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.drake_companion_active) { u.send({{"type", message_types::announce}, {"text", "Your Drake is already in the field."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int drake_hp_now = c.drake_max_hp > 0 ? c.drake_max_hp : 5 + 5 * c.level;
			int wis_mod_dk = c.get_ability_mod(ABILITY_WIS);
			int drake_attack = c.proficiency + wis_mod_dk;
			// Map drake_damage_type int to DMG_ constant: 0=acid 1=cold 2=fire 3=lightning 4=poison
			int drake_dmg_type = DMG_FIRE;
			if (c.drake_damage_type == 0) drake_dmg_type = DMG_ACID;
			else if (c.drake_damage_type == 1) drake_dmg_type = DMG_COLD;
			else if (c.drake_damage_type == 2) drake_dmg_type = DMG_FIRE;
			else if (c.drake_damage_type == 3) drake_dmg_type = DMG_LIGHTNING;
			else if (c.drake_damage_type == 4) drake_dmg_type = DMG_POISON;
			combatant@ drake = u.room.bm.spawn_companion(c, "drakewarden", c.name + "'s Drake", drake_hp_now, 14 + c.proficiency, 40, drake_attack, 1, 6, c.proficiency, drake_dmg_type, 0);
			if (@drake != null) {
				c.drake_companion_active = true;
				c.drake_hp = drake_hp_now;
				u.room.bm.broadcast_announce(c.name + " summons their Drake Companion! HP " + drake_hp_now + ", AC " + (14 + c.proficiency) + ".", true);
			}
		}
		else if (feature == "telekinetic_shove") {
			// Telekinetic feat (PHB para 7813): "As a Bonus Action, you can telekinetically
			// shove one creature you can see within 30 feet of yourself. When you do so,
			// the target must succeed on a Strength saving throw (DC 8 plus the relevant
			// ability modifier and your Proficiency Bonus) or be moved 5 feet toward you
			// or away from you."
			if (!c.has_feat("telekinetic")) { u.send({{"type", message_types::announce}, {"text", "You don't have the Telekinetic feat."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 feet)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// "Relevant ability modifier" = the player's INT, WIS, or CHA (highest of the three)
			int int_mod = c.get_ability_mod(ABILITY_INT);
			int wis_mod = c.get_ability_mod(ABILITY_WIS);
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			int best_mod = int_mod;
			if (wis_mod > best_mod) best_mod = wis_mod;
			if (cha_mod > best_mod) best_mod = cha_mod;
			int dc = 8 + c.proficiency + best_mod;
			int save_roll = random(1, 20) + tgt.get_save_bonus(ABILITY_STR);
			if (save_roll < dc) {
				// Push 5 ft directly away from caster (one tile)
				int dx = 0;
				int dy = 0;
				if (tgt.x > c.x) dx = 1;
				else if (tgt.x < c.x) dx = -1;
				if (tgt.y > c.y) dy = 1;
				else if (tgt.y < c.y) dy = -1;
				if (dx == 0 and dy == 0) dy = 1; // Same square: arbitrary push direction
				int new_x = tgt.x + dx;
				int new_y = tgt.y + dy;
				if (new_x >= 0 and new_x < u.room.bm.combat.map_width and new_y >= 0 and new_y < u.room.bm.combat.map_height) {
					tgt.x = new_x;
					tgt.y = new_y;
				}
				u.room.bm.broadcast_announce(c.name + "'s telekinetic shove pushes " + tgt.name + " 5 feet away! (STR save " + save_roll + " vs DC " + dc + ")", true);
			} else {
				u.room.bm.broadcast_announce(tgt.name + " resists " + c.name + "'s telekinetic shove. (STR save " + save_roll + " vs DC " + dc + ")", true);
			}
		}
		else if (feature == "divine_initiative") {
			// Book of Ebon Tides paras 1088-1090, Keeper Domain L2 Channel Divinity:
			// "As an action, you present your holy symbol and choose a number of creatures
			// that you can see and that can see you within 60 feet of you, up to a number
			// equal to your Wisdom modifier (minimum of one). Each of them gains 5
			// temporary hit points. When a target gains these temporary hit points, they
			// can immediately use their reaction to make one weapon attack."
			// Temp HP scales: 5 (L2), 8 (L6), 11 (L8), 14 (L17).
			if (c.class_name != "Cleric" or c.subclass != "Keeper Domain") { u.send({{"type", message_types::announce}, {"text", "Only Keeper Domain clerics can use Divine Initiative."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int wis_mod = c.get_ability_mod(ABILITY_WIS);
			if (wis_mod < 1) wis_mod = 1;
			int temp_hp = 5;
			if (c.level >= 17) temp_hp = 14;
			else if (c.level >= 8) temp_hp = 11;
			else if (c.level >= 6) temp_hp = 8;
			int blessed_count = 0;
			for (uint i = 0; i < u.room.bm.combat.combatants.length() and blessed_count < wis_mod; i++) {
				combatant@ ally = u.room.bm.combat.combatants[i];
				if (@ally == null or ally.is_dead) continue;
				if (ally.is_player != c.is_player and ally.id != c.id) continue;
				if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) continue;
				if (ally.temp_hp < temp_hp) ally.temp_hp = temp_hp;
				blessed_count++;
				u.room.bm.broadcast_announce(ally.name + " gains " + temp_hp + " temporary hit points from Divine Initiative.", false);
			}
			u.room.bm.broadcast_announce(c.name + " presents their holy symbol and channels Divine Initiative for " + blessed_count + " allies.", true);
		}
		else if (feature == "creeping_fog") {
			// Book of Ebon Tides para 1200, Shadow Gnawer Barbarian L6:
			// "As an action, you magically teleport, along with any equipment you are
			// wearing or carrying, up to 60 feet to an unoccupied space you can see.
			// Before or after teleporting, you can make one melee attack."
			// Movement is approximated: places the barbarian adjacent to the chosen target
			// (if any) within 60 ft, then resolves a single melee attack.
			if (c.class_name != "Barbarian" or c.subclass != "Shadow Gnawer") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Gnawer barbarians can use Creeping Fog."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Creeping Fog unlocks at level 6."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Target out of range (60 feet)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			// Teleport adjacent to target on a free side
			int new_x = tgt.x;
			int new_y = tgt.y - 1;
			if (new_y < 0) new_y = tgt.y + 1;
			c.x = new_x;
			c.y = new_y;
			u.room.bm.broadcast_announce(c.name + " bursts into mist and reforms next to " + tgt.name + " with Creeping Fog.", true);
			// Resolve a single melee attack as part of the teleport (mirrors the source).
			pending_roll pr;
			pr.combatant_id = c.id;
			pr.player_username = c.player_username;
			pr.roll_type = ROLL_ATTACK;
			pr.dice_sides = 20;
			pr.modifier = u.room.bm.get_attack_bonus_for_roll(c, false);
			pr.reason = c.main_hand + " attack against " + tgt.name + " (Creeping Fog)";
			pr.target_id = tgt.id;
			pr.attack_name = c.main_hand;
			pr.damage_dice_count = u.room.bm.get_attack_damage_count(c, false);
			pr.damage_dice_sides = u.room.bm.get_attack_damage_dice(c, false);
			pr.damage_modifier = u.room.bm.get_damage_modifier_for_attack(c, false);
			pr.damage_type = c.main_hand_damage_type;
			pr.is_weapon_attack = true;
			@u.room.bm.current_roll = pr;
			u.room.bm.send_roll_request(u, pr);
		}
		else if (feature == "consume_darkness") {
			// Book of Ebon Tides paras 1202-1203, Shadow Gnawer L10:
			// "While in dim light or darkness, you can use a bonus action to regain hit
			// points equal to 1d12 + your Constitution modifier. For the duration of your
			// rage (up to 1 minute), you regain 1 hit point at the start of each of your
			// turns. Once you use this feature, you must finish a short or long rest
			// before you can use it again."
			if (c.class_name != "Barbarian" or c.subclass != "Shadow Gnawer") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Gnawer barbarians can consume darkness."}, {"interrupt", true}}); return; }
			if (c.level < 10) { u.send({{"type", message_types::announce}, {"text", "Consume Darkness unlocks at level 10."}, {"interrupt", true}}); return; }
			if (!c.raging) { u.send({{"type", message_types::announce}, {"text", "You must be raging to use Consume Darkness."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.consume_darkness_used) { u.send({{"type", message_types::announce}, {"text", "Consume Darkness has been used; rest to recover."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.consume_darkness_used = true;
			int heal = random(1, 12) + c.get_ability_mod(ABILITY_CON);
			if (heal < 1) heal = 1;
			c.current_hp += heal;
			if (c.current_hp > c.max_hp) c.current_hp = c.max_hp;
			c.consume_darkness_per_turn_heal = 1; // Drains over the rage duration
			u.room.bm.broadcast_announce(c.name + " consumes the surrounding darkness, regaining " + heal + " hit points and 1 HP at the start of each turn while raging.", true);
		}
		else if (feature == "umbral_form") {
			// Book of Ebon Tides para 1016, Circle of Shadows Druid L2:
			// "as a bonus action, you can expend a use of your Wild Shape feature to take
			// on a shadowy umbral form, rather than transforming into a beast. The form
			// lasts for 10 minutes."
			if (c.class_name != "Druid" or c.subclass != "Circle of Shadows") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Shadows druids can take Umbral Form."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.wild_shape_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Wild Shape uses remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.wild_shape_uses--;
			c.umbral_form_active = true;
			c.umbral_form_rounds = 100; // 10 minutes
			// L10 Shadow Mass: Umbral Form grants fly speed and B/P/S nonmagical resistance
			if (c.level >= 10) {
				c.bludgeoning_resistance = true;
				c.piercing_resistance = true;
				c.slashing_resistance = true;
				c.flying_speed = c.speed;
			}
			u.room.bm.broadcast_announce(c.name + " takes on a shadowy Umbral Form. They can hide as a bonus action in dim light or darkness." + (c.level >= 10 ? " Shadow Mass grants flight and physical resistance." : ""), true);
		}
		else if (feature == "darkness_falls") {
			// Book of Ebon Tides para 1049-1051, Circle of Shadows L14:
			// "you can use an action to emit a 15-foot-radius sphere of magical darkness
			// centered on yourself... lasts for 1 minute, until you are incapacitated, or
			// until it comes into contact with sunlight."
			if (c.class_name != "Druid" or c.subclass != "Circle of Shadows") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Shadows druids can call Darkness Falls."}, {"interrupt", true}}); return; }
			if (c.level < 14) { u.send({{"type", message_types::announce}, {"text", "Darkness Falls unlocks at level 14."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.darkness_falls_used) { u.send({{"type", message_types::announce}, {"text", "Darkness Falls has been used; rest to recover."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.darkness_falls_used = true;
			c.darkness_active = true;
			u.room.bm.broadcast_announce(c.name + " calls Darkness Falls! A 15-foot sphere of magical darkness surrounds them, dispelling lower-level light spells. (1 minute)", true);
		}
		else if (feature == "dark_transfusion") {
			// Book of Ebon Tides para 1157, Shadow Arcane Wizard L2:
			// "As a bonus action, you can expend two spell slots to recover one spell slot
			// equal to or less than the total combined value of the expended spell slots."
			if (c.class_name != "Wizard" or c.subclass != "Shadow Arcane Tradition") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Arcane wizards can perform Dark Transfusion."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			// Find two lowest-level slots to expend (greedy heuristic to maximize the recovered slot value).
			int first_slot = -1;
			int second_slot = -1;
			for (int sl = 1; sl <= 9; sl++) {
				if (c.spell_slots_current[sl] > 0) {
					if (first_slot < 0) { first_slot = sl; }
					else if (second_slot < 0) { second_slot = sl; break; }
				}
			}
			if (first_slot < 0 or second_slot < 0) { u.send({{"type", message_types::announce}, {"text", "You need at least two spell slots to perform Dark Transfusion."}, {"interrupt", true}}); return; }
			int combined = first_slot + second_slot;
			int recovered_slot = combined > 9 ? 9 : combined;
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.spell_slots_current[first_slot]--;
			c.spell_slots_current[second_slot]--;
			c.spell_slots_current[recovered_slot]++;
			u.room.bm.broadcast_announce(c.name + " performs Dark Transfusion: expends a level " + first_slot + " slot and a level " + second_slot + " slot to recover a level " + recovered_slot + " slot.", true);
		}
		else if (feature == "dancing_shadows") {
			// Book of Ebon Tides para 1056-1058, College of Shadow Bard L3:
			// "As a bonus action, you can expend a Bardic Inspiration to create a 20-foot-radius
			// sphere of shifting shadows centered on you. The sphere moves with you, spreads
			// around corners, and lasts for 1 minute or until you are incapacitated or die.
			// Allied creatures (including you) standing in the sphere have half cover, and
			// creatures outside the sphere have disadvantage on Wisdom (Perception) checks
			// made to perceive anything inside the sphere."
			if (c.class_name != "Bard" or c.subclass != "College of Shadow") { u.send({{"type", message_types::announce}, {"text", "Only College of Shadow bards can weave Dancing Shadows."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Bardic Inspiration remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			c.dancing_shadows_active = true;
			c.dancing_shadows_rounds = 10; // 1 minute
			u.room.bm.broadcast_announce(c.name + " expends a Bardic Inspiration to weave Dancing Shadows in a 20-foot sphere. Allies inside have half cover.", true);
		}
		else if (feature == "venomous_mark") {
			// Book of Ebon Tides para 1137, Mother of Sorrows Warlock L1:
			// "as a bonus action, choose one creature you can see within 30 feet of you.
			// The target is cursed for 1 minute. The curse ends early if the target dies,
			// you die, or you are incapacitated. Until the curse ends, you deal an extra
			// 1d6 poison damage to the target whenever you hit it with a spell attack."
			if (c.class_name != "Warlock" or c.subclass != "Mother of Sorrows") { u.send({{"type", message_types::announce}, {"text", "Only Mother of Sorrows warlocks can place a Venomous Mark."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 feet)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.venomous_mark_target_id = tgt.id;
			c.venomous_mark_rounds = 10; // 1 minute
			u.room.bm.broadcast_announce(c.name + " curses " + tgt.name + " with a Venomous Mark. +1d6 poison damage on each spell attack hit.", true);
		}
		else if (feature == "shadow_grasp") {
			// Book of Ebon Tides para 1186, Shadow Domain Cleric L2 Channel Divinity:
			// "As an action, choose one creature that you can see within 30 feet of you.
			// That creature must make a Strength saving throw. If the creature fails the
			// saving throw, it is restrained by its shadow until the end of your next turn.
			// If the creature succeeds, it is grappled by its shadow until the end of your
			// next turn." L17 Army of Shadow expands to proficiency bonus targets.
			if (c.class_name != "Cleric" or c.subclass != "Shadow Domain") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Domain clerics can use Shadow Grasp."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 feet)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			// L17 Army of Shadow: Shadow Grasp affects up to PB targets simultaneously
			int max_targets = c.level >= 17 ? c.proficiency : 1;
			combatant@[] targets;
			targets.insert_last(tgt);
			if (max_targets > 1) {
				for (uint i = 0; i < u.room.bm.combat.combatants.length() and int(targets.length()) < max_targets; i++) {
					combatant@ extra = u.room.bm.combat.combatants[i];
					if (@extra == null or extra.id == c.id or extra.id == tgt.id or extra.is_dead) continue;
					if (!u.room.bm.combat.are_hostile(c, extra)) continue;
					if (feet_distance(c.x, c.y, extra.x, extra.y) > 30) continue;
					if (!u.room.bm.combat.can_see(c, extra)) continue;
					targets.insert_last(extra);
				}
			}
			for (uint i = 0; i < targets.length(); i++) {
				combatant@ st = targets[i];
				int save_roll = random(1, 20) + st.get_save_bonus(ABILITY_STR);
				if (save_roll < save_dc) {
					st.add_condition(COND_RESTRAINED);
					u.room.bm.broadcast_announce(st.name + "'s shadow surges up and restrains them! (Strength save " + save_roll + " vs DC " + save_dc + ")", true);
				} else {
					st.add_condition(COND_GRAPPLED);
					u.room.bm.broadcast_announce(st.name + "'s shadow grips them, leaving them grappled. (Strength save " + save_roll + " vs DC " + save_dc + ")", true);
				}
			}
		}
		else if (feature == "fade_to_black") {
			// Book of Ebon Tides para 1188, Shadow Domain L6:
			// "As a bonus action when you are in dim light or darkness, you can magically
			// become invisible for 1 minute. This effect ends early if you attack or cast
			// a spell. You can use this feature a number of times equal to your proficiency
			// bonus. You regain all expended uses when you finish a long rest."
			if (c.class_name != "Cleric" or c.subclass != "Shadow Domain") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Domain clerics can fade to black."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Fade to Black unlocks at level 6."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.fade_to_black_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Fade to Black uses remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.fade_to_black_uses--;
			c.fade_to_black_active = true;
			c.add_condition(COND_INVISIBLE);
			c.is_hidden = true;
			u.room.bm.broadcast_announce(c.name + " fades into the shadows and becomes invisible. The effect ends if they attack or cast a spell.", true);
		}
		else if (feature == "flickering_aura") {
			// Book of Ebon Tides para 1107-1108, Light Weaver L1:
			// "While light-shifted you can use an action to emit an aura of bright light in
			// a 15-foot-radius sphere centered on yourself. While the aura persists, you
			// can use a bonus action to expand or reduce its radius of bright light by 5
			// feet, to a maximum of 30 feet each or a minimum of 10 feet."
			if (c.class_name != "Sorcerer" or c.subclass != "Light Weaver") { u.send({{"type", message_types::announce}, {"text", "Only Light Weaver sorcerers can manifest a Flickering Aura."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.light_weaver_aura_active = !c.light_weaver_aura_active;
			if (c.light_weaver_aura_active) {
				string variant = c.light_weaver_dark_shifted ? "darkness" : "bright light";
				u.room.bm.broadcast_announce(c.name + " emits a Flickering Aura of " + variant + " in a " + c.light_weaver_aura_radius + "-foot-radius sphere.", true);
			} else {
				u.room.bm.broadcast_announce(c.name + " dismisses their Flickering Aura.", true);
			}
		}
		else if (feature == "refraction_shield") {
			// Book of Ebon Tides para 1111, Light Weaver L6:
			// "As a bonus action, you can spend 3 sorcery points to magically create a
			// shield of light. While the shield is in place, whenever a creature within
			// 5 feet of you hits you with a melee attack, the shield flashes with searing
			// energy, and the attacker takes 2d8 radiant damage if you are light-shifted
			// or 2d8 necrotic damage if you are dark-shifted. The shield disappears if
			// you fall unconscious or after 10 minutes."
			if (c.class_name != "Sorcerer" or c.subclass != "Light Weaver") { u.send({{"type", message_types::announce}, {"text", "Only Light Weaver sorcerers can raise a Refraction Shield."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Refraction Shield unlocks at level 6."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.sorcery_points < 3) { u.send({{"type", message_types::announce}, {"text", "You need 3 sorcery points to cast Refraction Shield."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.sorcery_points -= 3;
			c.refraction_shield_active = true;
			string variant = c.light_weaver_dark_shifted ? "necrotic" : "radiant";
			u.room.bm.broadcast_announce(c.name + " conjures a Refraction Shield. Melee attackers within 5 feet take 2d8 " + variant + " damage on hit.", true);
		}
		else if (feature == "inquisitors_eye") {
			// Grim Hollow Player Pack para 434: "You can use your Channel Divinity to open
			// your senses to hidden signs of corruption and malfeasance. As a bonus action,
			// you grant yourself advantage on Intelligence (Investigation), Wisdom (Insight),
			// and Wisdom (Perception) ability checks for the next 10 minutes. During this
			// time, you can't be surprised."
			// 10 minutes = ~100 rounds = effectively the rest of any single combat encounter.
			if (c.class_name != "Paladin" or c.subclass != "Oath of Zeal") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Zeal paladins can use Inquisitor's Eye."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			// Grant per-skill advantage flags via the new skill check system.
			if (!c.has_skill_check_advantage("Investigation")) c.skill_check_advantage.insert_last("Investigation");
			if (!c.has_skill_check_advantage("Insight")) c.skill_check_advantage.insert_last("Insight");
			if (!c.has_skill_check_advantage("Perception")) c.skill_check_advantage.insert_last("Perception");
			c.inquisitors_eye_active = true;
			u.room.bm.broadcast_announce(c.name + "'s senses sharpen with Inquisitor's Eye. Advantage on Investigation, Insight, and Perception checks for 10 minutes; cannot be surprised.", true);
		}
		else if (feature == "feral_celerity_attack") {
			// Placeholder (granted automatically on rage entry)
		}
		else if (feature == "momentary_stasis") {
			// Chronurgy L6: Action, CON save, incapacitate + speed 0 until damage or end of next turn
			if (c.class_name != "Wizard" or c.subclass != "Chronurgy Magic") { u.send({{"type", message_types::announce}, {"text", "Only Chronurgy wizards can cast Momentary Stasis."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Momentary Stasis unlocks at level 6."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.momentary_stasis_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Momentary Stasis uses remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Target out of range (60ft)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.momentary_stasis_uses--;
			int ms_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
			int save = random(1, 20) + tgt.get_save_bonus(ABILITY_CON);
			if (save < ms_dc) {
				tgt.add_condition(COND_INCAPACITATED);
				tgt.speed = 0;
				u.room.bm.broadcast_announce(c.name + "'s Momentary Stasis traps " + tgt.name + " in a field! (save " + save + " vs DC " + ms_dc + ")", true);
			} else {
				u.room.bm.broadcast_announce(tgt.name + " resists " + c.name + "'s Momentary Stasis (save " + save + " vs DC " + ms_dc + ").", true);
			}
		}

		else if (feature == "rebuke_violent") {
			// Oath of Redemption Paladin: Rebuke the Violent reaction
			if (c.class_name != "Paladin" or c.subclass != "Oath of Redemption") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Redemption paladins can Rebuke the Violent."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			c.has_reaction = false;
			c.channel_divinity_uses--;
			c.rebuke_violent_ready = true;
			u.room.bm.broadcast_announce(c.name + " readies Rebuke the Violent! Next time an enemy damages an ally within 30ft, they take equal damage.", false);
		}

		else if (feature == "eldritch_cannon") {
			// Artillerist Artificer: summon Eldritch Cannon
			if (c.class_name != "Artificer" or c.subclass != "Artillerist") { u.send({{"type", message_types::announce}, {"text", "Only Artillerists can summon Eldritch Cannons."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.eldritch_cannon_active = true;
			c.eldritch_cannon_hp = 5 * c.level;
			u.room.bm.broadcast_announce(c.name + " creates an Eldritch Cannon with " + c.eldritch_cannon_hp + " HP!", true);
		}

		else if (feature == "cannon_fire") {
			// Artillerist: bonus action to command the cannon to fire
			if (c.class_name != "Artificer" or c.subclass != "Artillerist") { u.send({{"type", message_types::announce}, {"text", "Only Artillerists can fire cannons."}, {"interrupt", true}}); return; }
			if (!c.eldritch_cannon_active) { u.send({{"type", message_types::announce}, {"text", "No active cannon to fire."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Flamethrower: 2d8 fire, DEX save for half
			int dmg = random(1, 8) + random(1, 8);
			int save = random(1, 20) + tgt.get_save_bonus(ABILITY_DEX);
			int dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
			if (save >= dc) dmg /= 2;
			u.room.bm.combat.apply_damage(tgt, dmg, DMG_FIRE, c);
			u.room.bm.broadcast_announce(c.name + "'s Eldritch Cannon flamethrower fires at " + tgt.name + " for " + dmg + " fire damage!", true);
		}

		else if (feature == "steel_defender_attack") {
			// Battle Smith Artificer: command Steel Defender to attack
			if (c.class_name != "Artificer" or c.subclass != "Battle Smith") { u.send({{"type", message_types::announce}, {"text", "Only Battle Smiths have a Steel Defender."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int atk_bonus = c.proficiency + c.get_ability_mod(ABILITY_INT);
			int roll = random(1, 20) + atk_bonus;
			if (roll >= tgt.armor_class) {
				int dmg = random(1, 8) + c.proficiency;
				u.room.bm.combat.apply_damage(tgt, dmg, DMG_FORCE, c);
				u.room.bm.broadcast_announce(c.name + "'s Steel Defender attacks " + tgt.name + " for " + dmg + " force damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Steel Defender attacks " + tgt.name + " but misses.", false);
			}
			c.steel_defender_active = true;
		}

		else if (feature == "primal_companion") {
			// Beast Master Ranger: summon animal companion (simplified)
			if (c.class_name != "Ranger" or c.subclass != "Beast Master") { u.send({{"type", message_types::announce}, {"text", "Only Beast Masters have a Primal Companion."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Companion attacks with 1d8 + prof damage
			int atk_bonus = c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int roll = random(1, 20) + atk_bonus;
			if (roll >= tgt.armor_class) {
				int dmg = random(1, 8) + c.proficiency;
				u.room.bm.combat.apply_damage(tgt, dmg, DMG_PIERCING, c);
				u.room.bm.broadcast_announce(c.name + "'s Primal Companion attacks " + tgt.name + " for " + dmg + " damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Primal Companion misses " + tgt.name + ".", false);
			}
			c.beast_companion_active = true;
		}

		else if (feature == "drake_attack") {
			// Drakewarden Ranger: drake companion breath weapon
			if (c.class_name != "Ranger" or c.subclass != "Drakewarden") { u.send({{"type", message_types::announce}, {"text", "Only Drakewardens have a Drake Companion."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int atk_bonus = c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int roll = random(1, 20) + atk_bonus;
			if (roll >= tgt.armor_class) {
				int dmg = random(1, 6) + c.proficiency;
				u.room.bm.combat.apply_damage(tgt, dmg, DMG_FIRE, c);
				u.room.bm.broadcast_announce(c.name + "'s Drake breathes fire at " + tgt.name + " for " + dmg + " fire damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Drake misses " + tgt.name + ".", false);
			}
			c.drake_companion_active = true;
		}

		else if (feature == "slayers_prey") {
			// Monster Slayer Ranger: mark a target as prey for +1d6 damage per turn
			if (c.class_name != "Ranger" or c.subclass != "Monster Slayer") { u.send({{"type", message_types::announce}, {"text", "Only Monster Slayers can mark prey."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.monster_slayer_target = target_id;
			u.room.bm.broadcast_announce(c.name + " marks a target as their slayer prey!", false);
		}

		else if (feature == "swarmkeeper_shift") {
			// Swarmkeeper Ranger: bonus damage + move target with swarm
			if (c.class_name != "Ranger" or c.subclass != "Swarmkeeper") { u.send({{"type", message_types::announce}, {"text", "Only Swarmkeepers have a magical swarm."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			u.room.bm.broadcast_announce(c.name + " commands the swarm! Next attack deals bonus force damage.", false);
			c.swarmkeeper_swarm_active = true;
		}

		else if (feature == "chronal_shift") {
			// Chronurgy Wizard: force a roll to be rerolled (reaction equivalent)
			if (c.class_name != "Wizard" or c.subclass != "Chronurgy Magic") { u.send({{"type", message_types::announce}, {"text", "Only Chronurgy wizards can use Chronal Shift."}, {"interrupt", true}}); return; }
			if (c.chronal_shift_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Chronal Shift uses remaining."}, {"interrupt", true}}); return; }
			c.chronal_shift_uses--;
			u.room.bm.broadcast_announce(c.name + " uses Chronal Shift to manipulate time!", true);
		}

		else if (feature == "critical_shot") {
			// Gunslinger: Critical Shot — expend a use to add Risk Die damage to next hit
			if (c.class_name != "Gunslinger") { u.send({{"type", message_types::announce}, {"text", "Only Gunslingers can use Critical Shot."}, {"interrupt", true}}); return; }
			if (c.critical_shot_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Critical Shot uses remaining."}, {"interrupt", true}}); return; }
			c.critical_shot_uses--;
			c.critical_shot_pending = true;
			u.room.bm.broadcast_announce(c.name + " readies a Critical Shot! Next hit deals bonus damage.", false);
		}

		else if (feature == "gut_shot") {
			// Gunslinger: Gut Shot — spend a Risk Die to deal bonus damage
			if (c.class_name != "Gunslinger") { u.send({{"type", message_types::announce}, {"text", "Only Gunslingers can use Gut Shot."}, {"interrupt", true}}); return; }
			if (c.level < 5) { u.send({{"type", message_types::announce}, {"text", "Gut Shot unlocks at level 5."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice available."}, {"interrupt", true}}); return; }
			c.risk_dice_current--;
			c.gut_shot_active = true;
			u.room.bm.broadcast_announce(c.name + " readies a Gut Shot! Next hit will deal a Risk Die of bonus damage.", false);
		}

		else if (feature == "dodge_roll") {
			// Gunslinger maneuver: Dodge Roll — spend Risk Die, bonus action move half speed + Dodge
			if (c.class_name != "Gunslinger") { u.send({{"type", message_types::announce}, {"text", "Only Gunslingers can Dodge Roll."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice available."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.risk_dice_current--;
			c.is_dodging = true;
			c.add_condition(COND_DODGING);
			u.room.bm.broadcast_announce(c.name + " uses Dodge Roll! Takes Dodge action.", false);
		}

		else if (feature == "blindfire") {
			// Gunslinger maneuver: Blindfire — ignore disadvantage on next ranged attack
			if (c.class_name != "Gunslinger") { u.send({{"type", message_types::announce}, {"text", "Only Gunslingers can Blindfire."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice available."}, {"interrupt", true}}); return; }
			c.risk_dice_current--;
			u.room.bm.broadcast_announce(c.name + " uses Blindfire! Next ranged attack ignores disadvantage.", false);
		}

		else if (feature == "open_hand_technique") {
			// Warrior of the Open Hand: expend focus points on a Flurry hit to push/prone/no-reaction
			if (c.class_name != "Monk" or c.subclass != "Warrior of the Open Hand") { u.send({{"type", message_types::announce}, {"text", "Only Open Hand monks can use this technique."}, {"interrupt", true}}); return; }
			c.open_hand_ki_used = true;
			string effect = msg.exists("effect") ? string(msg["effect"]) : "prone";
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt != null and !tgt.is_dead) {
				if (effect == "prone") {
					tgt.add_condition(COND_PRONE);
					u.room.bm.broadcast_announce(c.name + "'s Open Hand Technique knocks " + tgt.name + " prone!", true);
				} else if (effect == "push") {
					int push_dx = 0, push_dy = 0;
					if (tgt.x > c.x) push_dx = 3;
					else if (tgt.x < c.x) push_dx = -3;
					if (tgt.y > c.y) push_dy = 3;
					else if (tgt.y < c.y) push_dy = -3;
					tgt.x += push_dx;
					tgt.y += push_dy;
					u.room.bm.broadcast_announce(c.name + "'s Open Hand Technique pushes " + tgt.name + " 15 feet away!", true);
				} else {
					// No reactions until end of turn
					tgt.has_reaction = false;
					u.room.bm.broadcast_announce(c.name + "'s Open Hand Technique prevents " + tgt.name + " from taking reactions!", true);
				}
			}
		}

		else if (feature == "mage_hand_legerdemain") {
			// Arcane Trickster Rogue: use Mage Hand for sneak attack or bonus action actions
			if (c.class_name != "Rogue" or c.subclass != "Arcane Trickster") { u.send({{"type", message_types::announce}, {"text", "Only Arcane Tricksters can use Mage Hand Legerdemain."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.arcane_trickster_mage_hand = target_id;
			u.room.bm.broadcast_announce(c.name + " commands a magical Mage Hand!", false);
		}

		else if (feature == "scout_skirmish") {
			// Scout Rogue: Skirmisher — half speed move as reaction when enemy ends turn nearby
			if (c.class_name != "Rogue" or c.subclass != "Scout") { u.send({{"type", message_types::announce}, {"text", "Only Scouts can skirmish."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			c.has_reaction = false;
			c.scout_skirmisher = true;
			c.movement_remaining += c.speed / 2;
			u.room.bm.broadcast_announce(c.name + " uses Skirmisher to move half their speed as a reaction!", false);
		}

		else if (feature == "blessing_of_the_trickster") {
			// PHB 2024 para 4697: "As a Magic action, you can choose yourself or a willing
			// creature within 30 feet of yourself to have Advantage on Dexterity (Stealth)
			// checks. This blessing lasts until you finish a Long Rest or you use this
			// feature again." No Channel Divinity cost.
			if (c.class_name != "Cleric" or c.subclass != "Trickery Domain") { u.send({{"type", message_types::announce}, {"text", "Only Trickery Clerics can grant this blessing."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action this turn."}, {"interrupt", true}}); return; }
			combatant@ ally = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@ally == null or ally.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (ally.is_player != c.is_player and ally.id != c.id) { u.send({{"type", message_types::announce}, {"text", "Target an ally or yourself."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target must be within 30 feet."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			// Apply proper Stealth advantage flag (replaces the +5 hide_dc approximation).
			// "Use again" replaces the previous blessing — clear any prior Stealth advantage
			// from a previous blessing (kept simple: we don't currently track which cleric
			// applied it, so a recast just re-applies the flag idempotently).
			bool already_has = ally.has_skill_check_advantage("Stealth");
			if (!already_has) ally.skill_check_advantage.insert_last("Stealth");
			u.room.bm.broadcast_announce(c.name + " grants Blessing of the Trickster to " + ally.name + ". They have Advantage on Dexterity (Stealth) checks until long rest.", true);
		}
		else if (feature == "spirit_totem_bear" or feature == "spirit_totem_hawk" or feature == "spirit_totem_unicorn") {
			// Circle of the Shepherd Druid: Spirit Totem (Bear/Hawk/Unicorn)
			// Bonus action, 30ft aura (simplified to around druid; source has it around a summoned point within 60ft)
			// 1 minute duration, recharges on short/long rest
			if (c.class_name != "Druid" or c.subclass != "Circle of the Shepherd") { u.send({{"type", message_types::announce}, {"text", "Only Shepherd Druids can summon spirit totems."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.shepherd_circle_active = true;
			if (feature == "spirit_totem_bear") {
				c.shepherd_totem_type = 0;
				int bear_temp = 5 + c.level;
				for (uint sti = 0; sti < u.room.bm.combat.combatants.length(); sti++) {
					combatant@ ally = u.room.bm.combat.combatants[sti];
					if (@ally == null or ally.is_dead or ally.is_player != c.is_player) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) continue;
					if (ally.temp_hp < bear_temp) ally.temp_hp = bear_temp;
				}
				u.room.bm.broadcast_announce(c.name + " summons the Bear Spirit Totem! Allies within 30ft gain " + bear_temp + " temp HP and advantage on STR checks.", true);
			} else if (feature == "spirit_totem_hawk") {
				c.shepherd_totem_type = 1;
				u.room.bm.broadcast_announce(c.name + " summons the Hawk Spirit Totem! You can use a reaction to grant advantage on attacks against targets in the aura.", true);
			} else {
				c.shepherd_totem_type = 2;
				u.room.bm.broadcast_announce(c.name + " summons the Unicorn Spirit Totem! Healing spells also heal chosen creatures in the aura.", true);
			}
		}
		else if (feature == "polearm_master_attack") {
			// Polearm Master: bonus action attack with opposite end (1d4 bludgeoning) immediately after Attack action
			if (!c.has_feat("polearm_master")) { u.send({{"type", message_types::announce}, {"text", "You don't have the Polearm Master feat."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (!c.used_action) { u.send({{"type", message_types::announce}, {"text", "You must first take the Attack action with a polearm."}, {"interrupt", true}}); return; }
			// Verify weapon is qualifying (quarterstaff, spear, or Heavy+Reach)
			string wname = c.main_hand.lower();
			bool qualifies = (wname.find("quarterstaff") >= 0 or wname.find("spear") >= 0 or wname.find("glaive") >= 0 or wname.find("halberd") >= 0 or wname.find("pike") >= 0);
			if (!qualifies) { u.send({{"type", message_types::announce}, {"text", "Polearm Master requires a quarterstaff, spear, glaive, halberd, or pike."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			int dist_pa = feet_distance(c.x, c.y, tgt.x, tgt.y);
			int pa_reach = c.main_hand_range > 0 ? c.main_hand_range : 5;
			if (dist_pa > pa_reach) { u.send({{"type", message_types::announce}, {"text", "Target out of weapon reach."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int pa_atk = random(1, 20) + c.get_ability_mod(ABILITY_STR) + c.proficiency;
			if (pa_atk >= tgt.armor_class) {
				int pa_dmg = random(1, 4) + c.get_ability_mod(ABILITY_STR);
				if (pa_dmg < 1) pa_dmg = 1;
				u.room.bm.combat.apply_damage(tgt, pa_dmg, DMG_BLUDGEONING, c);
				u.room.bm.broadcast_announce(c.name + "'s polearm butt hits " + tgt.name + " for " + pa_dmg + " bludgeoning damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s polearm butt swing misses " + tgt.name + ".", true);
			}
		}
		// Shield Master 2024: Shield Bash is no longer a bonus action — it's an automatic rider
		// triggered by melee hit during the Attack action, applied in battle_manager attack resolution.
		else if (feature == "jinx_target") {
			// Misfortune Bringer Rogue: jinx target for bonus damage
			if (c.class_name != "Rogue" or c.subclass != "Misfortune Bringer") { u.send({{"type", message_types::announce}, {"text", "Only Misfortune Bringer Rogues can jinx targets."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.misfortune_jinx_active = true;
			c.misfortune_jinx_target = tgt.id;
			u.room.bm.broadcast_announce(c.name + " curses " + tgt.name + " with a jinx of misfortune!", true);
		}
		else if (feature == "rune_tag") {
			// Runetagger Rogue: mark target with magical rune
			if (c.class_name != "Rogue" or c.subclass != "Runetagger") { u.send({{"type", message_types::announce}, {"text", "Only Runetagger Rogues can place runes."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.runetagger_marked = true;
			c.runetagger_target = tgt.id;
			u.room.bm.broadcast_announce(c.name + " tags " + tgt.name + " with a magical rune!", true);
		}
		else if (feature == "blade_breaker_stance") {
			// Blade Breaker Fighter: enter armor-crushing stance - reduce target AC on hit
			if (c.class_name != "Fighter" or c.subclass != "Blade Breaker") { u.send({{"type", message_types::announce}, {"text", "Only Blade Breakers can enter this stance."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.blade_breaker_stance = !c.blade_breaker_stance;
			u.room.bm.broadcast_announce(c.name + (c.blade_breaker_stance ? " enters Blade Breaker stance!" : " leaves Blade Breaker stance."), true);
		}
		else if (feature == "festus_blessing") {
			// Festus Domain Cleric: bestow festive blessing on allies
			if (c.class_name != "Cleric" or c.subclass != "Festus Domain") { u.send({{"type", message_types::announce}, {"text", "Only Festus Clerics can bless feasts."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.festus_blessing_active = true;
			c.festus_blessing_rounds = 3;
			// Heal all allies within 30ft
			for (uint fbi = 0; fbi < u.room.bm.combat.combatants.length(); fbi++) {
				combatant@ ally = u.room.bm.combat.combatants[fbi];
				if (@ally == null or ally.is_dead or ally.is_player != c.is_player) continue;
				if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) continue;
				int heal = c.proficiency + c.get_ability_mod(ABILITY_WIS);
				u.room.bm.combat.apply_healing(ally, heal);
			}
			u.room.bm.broadcast_announce(c.name + " grants the Festus Blessing! All nearby allies are healed.", true);
		}
		// Gunslinger subclass maneuvers (Valda's). Most are triggered from attack/miss events,
		// not standalone bonus actions. Lay Down the Law is the one bonus action here.
		else if (feature == "lay_down_the_law") {
			// White Hat Gunslinger L3: Bonus action, expend 1 Risk Die. Choose an ally within 60ft.
			// Ally gains Temp HP = Risk Die roll. Until start of next turn, if ally is hit, reaction ranged attack on attacker.
			if (c.class_name != "Gunslinger" or c.subclass != "White Hat") { u.send({{"type", message_types::announce}, {"text", "Only White Hat Gunslingers can use Lay Down the Law."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "Select an ally to mark."}, {"interrupt", true}}); return; }
			combatant@ ally = u.room.bm.combat.get_combatant(target_id);
			if (@ally == null or ally.is_dead or ally.is_player != c.is_player) { u.send({{"type", message_types::announce}, {"text", "Select a living ally."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Target must be within 60ft."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.risk_dice_current--;
			int temp = random(1, c.risk_die_size);
			if (ally.temp_hp < temp) ally.temp_hp = temp;
			c.white_hat_protection_active = true;
			c.white_hat_ally = ally.id;
			u.room.bm.broadcast_announce(c.name + " Lays Down the Law — " + ally.name + " gains " + temp + " temp HP; retaliation ready!", true);
		}
		else if (feature == "unsettling_words") {
			// College of Eloquence Bard: spend Bardic Inspiration to subtract from a creature's next save
			if (c.class_name != "Bard" or c.subclass != "College of Eloquence") { u.send({{"type", message_types::announce}, {"text", "Only Eloquence Bards can use Unsettling Words."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Bardic Inspiration remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			c.unsettling_words_pending = true;
			c.unsettling_words_target = tgt.id;
			u.room.bm.broadcast_announce(c.name + " speaks Unsettling Words to " + tgt.name + ", undermining their resolve!", true);
		}
		else if (feature == "orders_demand") {
			// Order Domain Cleric (Tasha's): Channel Divinity as an action — each creature of choice within 30ft
			// makes a WIS save vs cleric spell DC. Failed save: charmed until end of next turn or until they take damage.
			if (c.class_name != "Cleric" or c.subclass != "Order Domain") { u.send({{"type", message_types::announce}, {"text", "Only Order Domain Clerics can use Order's Demand."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action this turn."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int affected = 0;
			for (uint odi = 0; odi < u.room.bm.combat.combatants.length(); odi++) {
				combatant@ tgt = u.room.bm.combat.combatants[odi];
				if (@tgt == null or tgt.is_dead or tgt.id == c.id) continue;
				if (tgt.is_player == c.is_player) continue; // only enemies
				if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) continue;
				int save = random(1, 20) + tgt.get_save_bonus(ABILITY_WIS);
				if (save < dc) {
					tgt.add_condition(COND_CHARMED);
					// Note: Charmed condition will end automatically on damage via normal condition handling,
					// and at the end of the cleric's next turn (duration tracking TODO)
					u.room.bm.broadcast_announce(c.name + " issues an Order's Demand! " + tgt.name + " is charmed (save " + save + " vs DC " + dc + ").", true);
					affected++;
				} else {
					u.room.bm.broadcast_announce(tgt.name + " resists Order's Demand (save " + save + " vs DC " + dc + ").", false);
				}
			}
			if (affected == 0) {
				u.room.bm.broadcast_announce(c.name + "'s Order's Demand echoes, but no enemies are charmed.", false);
			}
		}
		else if (feature == "experimental_elixir") {
			// Alchemist Artificer: create an experimental elixir (random effect)
			if (c.class_name != "Artificer" or c.subclass != "Alchemist") { u.send({{"type", message_types::announce}, {"text", "Only Alchemists can create Experimental Elixirs."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int elixir = random(1, 6);
			int heal = random(1, 4) + 2 + c.get_ability_mod(ABILITY_INT);
			if (elixir == 1) {
				u.room.bm.combat.apply_healing(c, heal);
				u.room.bm.broadcast_announce(c.name + "'s Healing Elixir restores " + heal + " HP!", true);
			} else if (elixir == 2) {
				c.speed += 10;
				u.room.bm.broadcast_announce(c.name + "'s Swiftness Elixir grants +10 ft speed!", true);
			} else if (elixir == 3) {
				c.temp_hp += 2 + c.level;
				u.room.bm.broadcast_announce(c.name + "'s Resilience Elixir grants " + (2 + c.level) + " temp HP!", true);
			} else if (elixir == 4) {
				u.room.bm.broadcast_announce(c.name + "'s Boldness Elixir grants +1d4 to next attack!", true);
				c.emboldening_bond_active = true; // reuse bond field
			} else {
				u.room.bm.combat.apply_healing(c, heal);
				u.room.bm.broadcast_announce(c.name + "'s Flight of Fancy Elixir! (+heal " + heal + ")", true);
			}
			c.experimental_elixir_available = true;
		}

		else {
			u.send({{"type", message_types::announce}, {"text", "That bonus action is not available to your character."}, {"interrupt", true}});
			return;
		}
		u.room.bm.broadcast_state();
	}

	else if (msg_type == message_types::scan_direction) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_scan(u, msg);
	}
	else if (msg_type == message_types::bardic_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_bardic_response(u, msg);
	}
	else if (msg_type == message_types::lucky_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_lucky_response(u, msg);
	}
	else if (msg_type == message_types::heroic_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_heroic_response(u, msg);
	}
	else if (msg_type == message_types::smite_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_smite_response(u, msg);
	}
	else if (msg_type == message_types::reaction_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_reaction_response(u, msg);
	}
	else if (msg_type == message_types::spell_choice_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_spell_choice_response(u, msg);
	}
	else if (msg_type == message_types::action_cast) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_cast(u, msg);
		}
	}
	else if (msg_type == message_types::action_help) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_help(u, msg);
		}
	}
	else if (msg_type == message_types::action_hide) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_hide(u);
		}
	}
	else if (msg_type == message_types::action_ready) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_ready(u, msg);
		}
	}
	else if (msg_type == message_types::action_shove) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_shove(u, msg);
		}
	}
	else if (msg_type == message_types::action_grapple) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_grapple(u, msg);
		}
	}
	else if (msg_type == message_types::set_target) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_set_target(u, msg);
		}
	}

	// --- Game Invites ---

	else if (msg_type == message_types::game_invite and msg.exists("target")) {
		string target_name = string(msg["target"]);
		// Must be in a room to invite.
		if (@u.room == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "You must be in a room to invite players."}});
			return;
		}
		// Must be a friend.
		if (@u.account == null) return;
		json_object@ my_data = u.account.data;
		if (!my_data.exists("friends")) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not on your friends list."}});
			return;
		}
		json_array@ my_friends = my_data["friends"];
		bool is_friend = false;
		for (uint fi = 0; fi < my_friends.length(); fi++) {
			if (string(my_friends[fi]) == target_name) { is_friend = true; break; }
		}
		if (!is_friend) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not on your friends list."}});
			return;
		}
		// Target must be online.
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not online."}});
			return;
		}
		// Send invite to target.
		target.send({{"type", message_types::game_invite_received}, {"from", u.username}, {"room_name", u.room.name}, {"room_id", u.room.id}});
		u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Game invite sent to " + target_name + "!"}});
	}

	else if (msg_type == message_types::game_invite_response and msg.exists("accepted") and msg.exists("room_id")) {
		bool accepted = bool(msg["accepted"]);
		uint room_id = uint(msg["room_id"]);
		string from_name = msg.exists("from") ? string(msg["from"]) : "";
		if (!accepted) {
			// Notify the inviter.
			if (from_name != "") {
				user@ inviter = users.get_user_by_name(from_name);
				if (@inviter != null) {
					inviter.send({{"type", message_types::chat_message}, {"username", ""}, {"message", u.username + " declined your game invite."}});
				}
			}
			return;
		}
		// Find the room by ID.
		room@ target_room = null;
		for (uint ri = 0; ri < rooms.rooms.length(); ri++) {
			if (rooms.rooms[ri].id == room_id) {
				@target_room = rooms.rooms[ri];
				break;
			}
		}
		if (@target_room == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "That room no longer exists."}});
			return;
		}
		if (target_room.started) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "That game has already started."}});
			return;
		}
		// Join the room (bypasses password).
		u.join_room(target_room);
	}

	// ---- INVENTORY LIST ----
	else if (msg_type == message_types::inventory_list) {
		if (@u.account == null) return;
		init_item_catalog();
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		json_array items_arr;
		if (@inv != null) {
			for (uint ii = 0; ii < inv.length(); ii++) {
				json_object@ entry = inv[ii];
				if (@entry == null or !entry.exists("id")) continue;
				string item_id = string(entry["id"]);
				item_def@ item = find_item(item_id);
				if (@item == null) continue;
				json_object item_obj;
				item_obj["id"] = item.id;
				item_obj["name"] = item.name;
				item_obj["rarity"] = item.rarity;
				item_obj["slot"] = item.slot;
				item_obj["description"] = item.description;
				item_obj["stats"] = item_stat_summary(item);
				items_arr.add(item_obj);
			}
		}

		// Include equipped items info
		json_object equipped_info;
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ eq = character["equipped"];
			if (eq.exists("weapon")) equipped_info["weapon"] = eq["weapon"];
			if (eq.exists("armor")) equipped_info["armor"] = eq["armor"];
			if (eq.exists("ring")) equipped_info["ring"] = eq["ring"];
			if (eq.exists("amulet")) equipped_info["amulet"] = eq["amulet"];
		}

		u.send({
			{"type", message_types::inventory_list},
			{"items", items_arr},
			{"equipped", equipped_info}
		});
	}

	// ---- EQUIP ITEM ----
	else if (msg_type == message_types::equip_item and msg.exists("item_id")) {
		if (@u.account == null) return;
		init_item_catalog();
		string item_id = string(msg["item_id"]);

		// Validate the item exists in catalog
		item_def@ item = find_item(item_id);
		if (@item == null) {
			u.send({{"type", message_types::error}, {"text", "Unknown item."}});
			return;
		}

		// Derive slot from the item definition (no need for client to send it)
		string[] slot_key_map = {"weapon", "armor", "ring", "amulet"};
		if (item.slot < 0 or item.slot >= int(slot_key_map.length())) {
			u.send({{"type", message_types::error}, {"text", "Invalid item slot."}});
			return;
		}
		string expected_slot = slot_key_map[item.slot];

		// Validate item exists in player's inventory
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (!inventory_has_item(inv, item_id)) {
			u.send({{"type", message_types::error}, {"text", "You do not have that item."}});
			return;
		}

		// Get character and equipped data
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character == null) {
			u.send({{"type", message_types::error}, {"text", "No adventure character found."}});
			return;
		}
		json_object@ equipped = ensure_json_object_field(character, "equipped");

		// Toggle: if item is already equipped in this slot, unequip it
		if (equipped.exists(expected_slot) and string(equipped[expected_slot]) == item_id) {
			equipped[expected_slot] = "";
			u.account.commit();
			send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
			u.send({{"type", message_types::announce}, {"text", "Unequipped " + item.name + " from " + SLOT_NAMES[item.slot] + " slot."}, {"interrupt", false}});
		} else {
			equipped[expected_slot] = item_id;
			u.account.commit();
			send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
			u.send({{"type", message_types::announce}, {"text", "Equipped " + item.name + " in " + SLOT_NAMES[item.slot] + " slot."}, {"interrupt", false}});
		}
	}

	// ---- DISCARD ITEM ----
	else if (msg_type == message_types::discard_item and msg.exists("item_id")) {
		if (@u.account == null) return;
		init_item_catalog();
		string item_id = string(msg["item_id"]);

		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (!inventory_has_item(inv, item_id)) {
			u.send({{"type", message_types::error}, {"text", "You do not have that item."}});
			return;
		}

		// If the item is currently equipped, unequip it first
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ equipped = character["equipped"];
			string[] slot_keys = {"weapon", "armor", "ring", "amulet"};
			for (uint si = 0; si < slot_keys.length(); si++) {
				if (equipped.exists(slot_keys[si]) and string(equipped[slot_keys[si]]) == item_id) {
					equipped[slot_keys[si]] = "";
				}
			}
		}

		inventory_remove_item(inv, item_id);
		u.account.commit();

		item_def@ item = find_item(item_id);
		string item_name = @item != null ? item.name : item_id;
		u.send({{"type", message_types::announce}, {"text", "Discarded " + item_name + "."}, {"interrupt", false}});
		send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
	}

	// ---- UPGRADE ITEM ----
	else if (msg_type == message_types::upgrade_item and msg.exists("item_ids")) {
		if (@u.account == null) return;
		init_item_catalog();
		ensure_account_progression(u.account);

		json_array@ ids = msg["item_ids"];
		if (@ids == null or ids.length() != 3) {
			u.send({{"type", message_types::error}, {"text", "You must select exactly 3 items to upgrade."}});
			return;
		}

		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (@inv == null) {
			u.send({{"type", message_types::error}, {"text", "No inventory found."}});
			return;
		}

		// Validate all 3 items exist in inventory and have same rarity
		string[] item_ids;
		string[] item_names;
		int common_rarity = -1;
		for (uint ii = 0; ii < ids.length(); ii++) {
			string item_id = string(ids[ii]);
			if (!inventory_has_item(inv, item_id)) {
				u.send({{"type", message_types::error}, {"text", "You do not have item: " + item_id + "."}});
				return;
			}
			item_def@ item = find_item(item_id);
			if (@item == null) {
				u.send({{"type", message_types::error}, {"text", "Unknown item: " + item_id + "."}});
				return;
			}
			if (common_rarity == -1) {
				common_rarity = item.rarity;
			} else if (item.rarity != common_rarity) {
				u.send({{"type", message_types::error}, {"text", "All 3 items must be the same rarity."}});
				return;
			}
			item_ids.insert_last(item_id);
			item_names.insert_last(item.name);
		}

		// Check rarity is upgradeable (not legendary)
		if (common_rarity >= RARITY_LEGENDARY) {
			u.send({{"type", message_types::error}, {"text", "Legendary items cannot be upgraded further."}});
			return;
		}

		// Check glory cost
		int cost = get_upgrade_glory_cost(common_rarity);
		int current_glory = get_glory(u.account);
		if (current_glory < cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough Glory. Need " + cost + " but you have " + current_glory + "."}});
			return;
		}

		// Remove 3 items from inventory
		for (uint ii = 0; ii < item_ids.length(); ii++) {
			inventory_remove_item(inv, item_ids[ii]);
		}

		// Deduct glory
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			int new_glory = get_json_int(progress, "glory", 0) - cost;
			if (new_glory < 0) new_glory = 0;
			progress["glory"] = new_glory;
		}

		// Generate random item of next rarity
		int target_rarity = common_rarity + 1;
		item_def@ result_item = generate_upgrade_result(target_rarity);
		string result_name = "Unknown";
		if (@result_item != null) {
			inventory_add_item(inv, result_item.id);
			result_name = result_item.name;
		}

		u.account.commit();

		// Send updated inventory
		// Re-build inventory list
		json_array items_arr;
		for (uint ii = 0; ii < inv.length(); ii++) {
			json_object@ entry = inv[ii];
			if (@entry == null or !entry.exists("id")) continue;
			string iid = string(entry["id"]);
			item_def@ idef = find_item(iid);
			if (@idef == null) continue;
			json_object item_obj;
			item_obj["id"] = idef.id;
			item_obj["name"] = idef.name;
			item_obj["rarity"] = idef.rarity;
			item_obj["slot"] = idef.slot;
			item_obj["description"] = idef.description;
			item_obj["stats"] = item_stat_summary(idef);
			items_arr.add(item_obj);
		}
		json_object equipped_info;
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ eq = character["equipped"];
			if (eq.exists("weapon")) equipped_info["weapon"] = eq["weapon"];
			if (eq.exists("armor")) equipped_info["armor"] = eq["armor"];
			if (eq.exists("ring")) equipped_info["ring"] = eq["ring"];
			if (eq.exists("amulet")) equipped_info["amulet"] = eq["amulet"];
		}
		u.send({
			{"type", message_types::inventory_list},
			{"items", items_arr},
			{"equipped", equipped_info}
		});

		// Send glory update
		u.send({
			{"type", message_types::glory_update},
			{"glory", get_glory(u.account)}
		});

		// Announce the result
		string rarity_name = RARITY_NAMES[target_rarity];
		u.send({{"type", message_types::announce}, {"text", "Upgrade successful! Combined " + item_names[0] + ", " + item_names[1] + ", and " + item_names[2] + " into " + result_name + " (" + rarity_name + "). Cost: " + cost + " Glory."}, {"interrupt", true}});
	}

	// ---- PRESTIGE ACTION ----
	else if (msg_type == message_types::prestige_action) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress == null) {
			u.send({{"type", message_types::error}, {"text", "No adventure progress found."}});
			return;
		}

		int current_level = get_json_int(progress, "level", 1);
		int current_rank = get_prestige_rank(u.account);

		if (current_level < 20) {
			u.send({{"type", message_types::error}, {"text", "You must be level 20 to prestige."}});
			return;
		}
		if (current_rank >= 5) {
			u.send({{"type", message_types::error}, {"text", "You have already reached maximum prestige rank."}});
			return;
		}

		if (!apply_prestige(u.account)) {
			u.send({{"type", message_types::error}, {"text", "Prestige failed."}});
			return;
		}

		int new_rank = get_prestige_rank(u.account);
		string title = get_prestige_title(new_rank);
		int glory_reward = 100 * new_rank;
		add_glory(u.account, glory_reward);

		u.account.commit();

		u.send({{"type", message_types::announce}, {"text", "You have prestiged! You are now " + title + " (Rank " + new_rank + "). Level reset to 1. +" + glory_reward + " Glory!"}, {"interrupt", true}});
		send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
		send_adventure_progress_to_user(u, "Prestige complete! Rank " + new_rank + ": " + title + ".");
		u.send({
			{"type", message_types::glory_update},
			{"glory", get_glory(u.account)},
			{"gained", glory_reward}
		});
	}

	// ---- TRADING SYSTEM ----

	else if (msg_type == message_types::trade_request and msg.exists("target")) {
		string target_name = msg["target"];
		if (target_name == u.username) {
			u.send({{"type", message_types::error}, {"text", "You cannot trade with yourself."}});
			return;
		}
		// Check if already in a trade
		if (@find_trade_for_user(u) != null) {
			u.send({{"type", message_types::error}, {"text", "You are already in a trade."}});
			return;
		}
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.send({{"type", message_types::error}, {"text", target_name + " is not online."}});
			return;
		}
		if (target.is_bot) {
			u.send({{"type", message_types::error}, {"text", "You cannot trade with an AI player."}});
			return;
		}
		if (@find_trade_for_user(target) != null) {
			u.send({{"type", message_types::error}, {"text", target_name + " is already in a trade."}});
			return;
		}
		// Send trade request to the target
		target.send({{"type", message_types::trade_request}, {"from", u.username}});
		u.send({{"type", message_types::announce}, {"text", "Trade request sent to " + target_name + "."}, {"interrupt", false}});
		println("[TRADE] " + u.username + " sent trade request to " + target_name);
	}

	else if (msg_type == message_types::trade_accept and msg.exists("from")) {
		string from_name = msg["from"];
		user@ requester = users.get_user_by_name(from_name);
		if (@requester == null) {
			u.send({{"type", message_types::error}, {"text", from_name + " is no longer online."}});
			return;
		}
		if (@find_trade_for_user(u) != null or @find_trade_for_user(requester) != null) {
			u.send({{"type", message_types::error}, {"text", "Trade session conflict. Please try again."}});
			return;
		}
		// Create the trade session
		trade_session t;
		@t.player_a = requester;
		@t.player_b = u;
		active_trades.insert_last(t);
		// Send initial trade_update to both
		requester.send(build_trade_update(t, true));
		u.send(build_trade_update(t, false));
		println("[TRADE] Trade session started between " + requester.username + " and " + u.username);
	}

	else if (msg_type == message_types::trade_offer and msg.exists("items")) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) {
			u.send({{"type", message_types::error}, {"text", "You are not in an active trade."}});
			return;
		}
		// Reset confirmations when offer changes
		t.confirmed_a = false;
		t.confirmed_b = false;

		bool is_a = (@t.player_a is u);
		json_array@ items = msg["items"];
		string[] new_offer;
		if (@items != null and @u.account != null) {
			init_item_catalog();
			json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
			for (uint i = 0; i < items.length(); i++) {
				string item_id = string(items[i]);
				// Validate item exists in player's inventory
				if (inventory_has_item(inv, item_id)) {
					new_offer.insert_last(item_id);
				}
			}
		}

		if (is_a) t.offer_a = new_offer;
		else t.offer_b = new_offer;

		// Send updated trade state to both
		t.player_a.send(build_trade_update(t, true));
		t.player_b.send(build_trade_update(t, false));
	}

	else if (msg_type == message_types::trade_confirm) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) {
			u.send({{"type", message_types::error}, {"text", "You are not in an active trade."}});
			return;
		}
		bool is_a = (@t.player_a is u);
		if (is_a) t.confirmed_a = true;
		else t.confirmed_b = true;

		// Send updated state to both
		t.player_a.send(build_trade_update(t, true));
		t.player_b.send(build_trade_update(t, false));

		// If both confirmed, execute the trade
		if (t.confirmed_a and t.confirmed_b) {
			complete_trade(t);
		}
	}

	else if (msg_type == message_types::trade_cancel) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) return;
		cancel_trade(t, u.username + " cancelled the trade.");
	}

	// ---- WEEKLY CHALLENGES ----

	else if (msg_type == message_types::weekly_challenges) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ challenge_msg = build_weekly_challenges_message(u.account);
		if (@challenge_msg != null) u.send(challenge_msg);
	}

	// ---- GLORY SHOP ----

	else if (msg_type == message_types::glory_shop_list) {
		if (@u.account == null) return;
		init_glory_shop();
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		json_array@ owned_titles = @progress != null ? ensure_json_array_field(progress, "owned_titles") : null;

		json_array shop_arr;
		for (uint si = 0; si < GLORY_SHOP.length(); si++) {
			shop_entry@ e = GLORY_SHOP[si];
			json_object entry;
			entry["id"] = e.id;
			entry["name"] = e.name;
			entry["description"] = e.description;
			entry["type"] = e.type;
			entry["glory_cost"] = e.glory_cost;
			bool owned = false;
			if (e.type == SHOP_TYPE_TITLE and @owned_titles != null) {
				for (uint ti = 0; ti < owned_titles.length(); ti++) {
					if (string(owned_titles[ti]) == e.id) { owned = true; break; }
				}
			} else if (e.type == SHOP_TYPE_ITEM and @inv != null) {
				owned = inventory_has_item(inv, e.item_id);
			}
			entry["owned"] = owned;
			if (e.item_id != "") entry["item_id"] = e.item_id;
			shop_arr.add(entry);
		}
		u.send({{"type", message_types::glory_shop_list}, {"items", shop_arr}, {"glory", get_glory(u.account)}});
	}

	else if (msg_type == message_types::glory_shop_buy and msg.exists("shop_id")) {
		if (@u.account == null) return;
		init_glory_shop();
		ensure_account_progression(u.account);
		string shop_id = string(msg["shop_id"]);
		shop_entry@ e = find_shop_entry(shop_id);
		if (@e == null) {
			u.send({{"type", message_types::error}, {"text", "Item not found in the Glory Shop."}});
			return;
		}

		json_object@ progress = get_adventure_progress(u.account);
		int current_glory = get_glory(u.account);
		if (current_glory < e.glory_cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough Glory Points. You have " + current_glory + " but need " + e.glory_cost + "."}});
			return;
		}

		if (e.type == SHOP_TYPE_TITLE) {
			json_array@ owned_titles = ensure_json_array_field(progress, "owned_titles");
			// Check if already owned
			for (uint ti = 0; ti < owned_titles.length(); ti++) {
				if (string(owned_titles[ti]) == e.id) {
					u.send({{"type", message_types::error}, {"text", "You already own this title."}});
					return;
				}
			}
			owned_titles.add(e.id);
			progress["glory"] = current_glory - e.glory_cost;
			u.account.commit();
			u.send({{"type", message_types::glory_update}, {"glory", get_glory(u.account)}, {"gained", 0}});
			u.send({{"type", message_types::announce}, {"text", "You purchased the title: " + e.name + "!"}, {"interrupt", true}});
		} else if (e.type == SHOP_TYPE_ITEM) {
			json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
			if (inventory_has_item(inv, e.item_id)) {
				u.send({{"type", message_types::error}, {"text", "You already own this item."}});
				return;
			}
			if (int(inv.length()) >= MAX_INVENTORY) {
				u.send({{"type", message_types::error}, {"text", "Your inventory is full! Discard an item first."}});
				return;
			}
			inventory_add_item(inv, e.item_id);
			progress["glory"] = current_glory - e.glory_cost;
			u.account.commit();
			u.send({{"type", message_types::glory_update}, {"glory", get_glory(u.account)}, {"gained", 0}});
			u.send({{"type", message_types::announce}, {"text", "You purchased: " + e.name + "!"}, {"interrupt", true}});
		}
	}

	// ---- SET ACTIVE TITLE ----

	else if (msg_type == message_types::set_active_title and msg.exists("title_id")) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress == null) return;
		string title_id = string(msg["title_id"]);

		if (title_id == "") {
			// Clear active title
			progress["active_title"] = "";
			u.account.commit();
			u.send({{"type", message_types::announce}, {"text", "Title removed."}, {"interrupt", false}});
			return;
		}

		json_array@ owned_titles = ensure_json_array_field(progress, "owned_titles");
		bool found = false;
		for (uint ti = 0; ti < owned_titles.length(); ti++) {
			if (string(owned_titles[ti]) == title_id) { found = true; break; }
		}
		if (!found) {
			u.send({{"type", message_types::error}, {"text", "You do not own this title."}});
			return;
		}

		init_glory_shop();
		shop_entry@ se = find_shop_entry(title_id);
		progress["active_title"] = title_id;
		u.account.commit();
		string title_name = @se != null ? se.name : title_id;
		u.send({{"type", message_types::announce}, {"text", "Active title set to: " + title_name + "."}, {"interrupt", false}});
	}

	// ---- DAILY DUNGEON INFO ----

	else if (msg_type == message_types::daily_dungeon_info) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		string dungeon_id = get_daily_dungeon_id();
		string difficulty = get_daily_difficulty();
		string dungeon_name = get_dungeon_display_name(dungeon_id);
		bool claimable = can_claim_daily(u.account);
		u.send({{"type", message_types::daily_dungeon_info}, {"dungeon_id", dungeon_id}, {"dungeon_name", dungeon_name}, {"difficulty", difficulty}, {"can_claim", claimable}});
	}

	// ---- LEADERBOARDS ----

	else if (msg_type == message_types::leaderboard_request and msg.exists("category")) {
		string category = string(msg["category"]);
		json_array leaderboard;
		string my_username = u.username;
		int my_value = 0;
		int my_rank = -1;

		// Collect all player scores
		json_object@[] all_scores;
		string[] all_usernames;
		string[] all_prestige_titles;
		int[] all_values;

		for (uint ai = 0; ai < accounts.length(); ai++) {
			account@ acct = accounts[ai];
			if (@acct == null or @acct.data == null) continue;
			if (!acct.data.exists(ACCOUNT_KEY_ADVENTURE_PROGRESS)) continue;
			json_object@ prog = acct.data[ACCOUNT_KEY_ADVENTURE_PROGRESS];
			if (@prog == null) continue;

			int value = 0;
			if (category == "glory") value = get_json_int(prog, "glory", 0);
			else if (category == "endless") value = get_json_int(prog, "endless_best_wave", 0);
			else if (category == "kills") value = get_json_int(prog, "monster_kills", 0);
			else if (category == "prestige") value = get_json_int(prog, "prestige_rank", 0);
			else if (category == "dungeons") {
				int total = 0;
				if (prog.exists("dungeons_completed")) {
					json_object@ dc = prog["dungeons_completed"];
					if (@dc != null) {
						string[]@ keys = dc.get_keys();
						for (uint ki = 0; ki < keys.length(); ki++) {
							total += get_json_int(dc, keys[ki], 0);
						}
					}
				}
				value = total;
			}

			if (value <= 0) continue;

			all_usernames.insert_last(acct.username);
			all_values.insert_last(value);
			string pt = get_prestige_title(get_json_int(prog, "prestige_rank", 0));
			all_prestige_titles.insert_last(pt);
		}

		// Sort descending by value (simple insertion sort for small sets)
		for (int si = 1; si < int(all_values.length()); si++) {
			int key_val = all_values[si];
			string key_name = all_usernames[si];
			string key_pt = all_prestige_titles[si];
			int sj = si - 1;
			while (sj >= 0 and all_values[sj] < key_val) {
				all_values[sj + 1] = all_values[sj];
				all_usernames[sj + 1] = all_usernames[sj];
				all_prestige_titles[sj + 1] = all_prestige_titles[sj];
				sj--;
			}
			all_values[sj + 1] = key_val;
			all_usernames[sj + 1] = key_name;
			all_prestige_titles[sj + 1] = key_pt;
		}

		// Build top 10 and find requesting player
		int limit = int(all_values.length());
		if (limit > 10) limit = 10;
		for (int ri = 0; ri < limit; ri++) {
			json_object entry;
			entry["rank"] = ri + 1;
			entry["username"] = all_usernames[ri];
			entry["value"] = all_values[ri];
			entry["prestige_title"] = all_prestige_titles[ri];
			leaderboard.add(entry);
		}

		// Find requesting player's rank
		for (int ri = 0; ri < int(all_values.length()); ri++) {
			if (all_usernames[ri] == my_username) {
				my_rank = ri + 1;
				my_value = all_values[ri];
				break;
			}
		}

		u.send({{"type", message_types::leaderboard_data}, {"category", category}, {"entries", leaderboard}, {"my_rank", my_rank}, {"my_value", my_value}});
	}

	// ---- Consumable Shop ----
	else if (msg_type == message_types::shop_list) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		init_consumable_catalog();
		json_array@ cons_inv = ensure_json_array_field(u.account.data, "adventure_consumables");

		json_array shop_arr;
		for (uint si = 0; si < CONSUMABLE_CATALOG.length(); si++) {
			consumable_def@ cd = CONSUMABLE_CATALOG[si];
			json_object entry;
			entry["id"] = cd.id;
			entry["name"] = cd.name;
			entry["type"] = cd.type;
			entry["type_name"] = CONS_TYPE_NAMES[cd.type];
			entry["action_type"] = cd.action_type;
			entry["description"] = cd.description;
			entry["gold_cost"] = cd.gold_cost;
			entry["owned"] = get_consumable_quantity(cons_inv, cd.id);
			entry["max_stack"] = MAX_CONSUMABLE_STACK;
			shop_arr.add(entry);
		}
		u.send({{"type", message_types::shop_list}, {"items", shop_arr}, {"gold", get_gold(u.account)}});
	}

	else if (msg_type == message_types::shop_buy and msg.exists("consumable_id")) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		init_consumable_catalog();

		string buy_id = string(msg["consumable_id"]);
		consumable_def@ cd = find_consumable(buy_id);
		if (@cd == null) {
			u.send({{"type", message_types::error}, {"text", "Unknown item."}});
			return;
		}

		int current_gold = get_gold(u.account);
		if (current_gold < cd.gold_cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough gold. Need " + cd.gold_cost + ", have " + current_gold + "."}});
			return;
		}

		json_array@ cons_inv = ensure_json_array_field(u.account.data, "adventure_consumables");
		int current_qty = get_consumable_quantity(cons_inv, buy_id);
		if (current_qty >= MAX_CONSUMABLE_STACK) {
			u.send({{"type", message_types::error}, {"text", "Already at max stack (" + MAX_CONSUMABLE_STACK + ") for " + cd.name + "."}});
			return;
		}

		if (!spend_gold(u.account, cd.gold_cost)) {
			u.send({{"type", message_types::error}, {"text", "Failed to deduct gold."}});
			return;
		}

		if (!add_consumable_to_inventory(cons_inv, buy_id)) {
			// Refund gold if inventory add fails
			add_gold(u.account, cd.gold_cost);
			u.send({{"type", message_types::error}, {"text", "Inventory full."}});
			return;
		}

		u.account.commit();
		int new_qty = get_consumable_quantity(cons_inv, buy_id);
		u.send({{"type", message_types::announce}, {"text", "Purchased " + cd.name + "! You now have " + new_qty + ". Gold remaining: " + get_gold(u.account) + "."}, {"interrupt", false}});
		// Send updated shop list
		json_array updated_shop;
		for (uint si = 0; si < CONSUMABLE_CATALOG.length(); si++) {
			consumable_def@ ucd = CONSUMABLE_CATALOG[si];
			json_object entry;
			entry["id"] = ucd.id;
			entry["name"] = ucd.name;
			entry["type"] = ucd.type;
			entry["type_name"] = CONS_TYPE_NAMES[ucd.type];
			entry["action_type"] = ucd.action_type;
			entry["description"] = ucd.description;
			entry["gold_cost"] = ucd.gold_cost;
			entry["owned"] = get_consumable_quantity(cons_inv, ucd.id);
			entry["max_stack"] = MAX_CONSUMABLE_STACK;
			updated_shop.add(entry);
		}
		u.send({{"type", message_types::shop_list}, {"items", updated_shop}, {"gold", get_gold(u.account)}});
	}

	else if (msg_type == message_types::use_consumable) {
		if (@u.room == null or @u.room.bm == null) {
			u.send({{"type", message_types::error}, {"text", "Not in a battle."}});
			return;
		}
		u.room.bm.handle_use_consumable(u, msg);
	}

	// ---- GUILD SYSTEM HANDLERS ----

	else if (msg_type == message_types::create_guild and msg.exists("name")) {
		string guild_name = string(msg["name"]).trim_whitespace();
		// Validate name length.
		if (guild_name.length() < 3 or guild_name.length() > 30) {
			u.speak("Guild name must be between 3 and 30 characters.");
			return;
		}
		// Validate characters (letters, numbers, spaces only).
		string allowed = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 ";
		for (uint i = 0; i < guild_name.length(); i++) {
			if (allowed.find(guild_name[i]) < 0) {
				u.speak("Guild name can only contain letters, numbers, and spaces.");
				return;
			}
		}
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild. Leave your current guild first.");
			return;
		}
		// Check if guild name is taken.
		if (@find_guild(guild_name) != null) {
			u.speak("A guild with that name already exists.");
			return;
		}
		// Create the guild.
		guild@ g = guild(guild_name, u.username);
		guilds.insert_last(g);
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = guild_name;
			progress["guild_leader"] = u.username;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " created guild '" + guild_name + "'");
		// Send guild info back to confirm.
		json_object info;
		info["type"] = message_types::guild_info;
		info["name"] = g.name;
		info["leader"] = g.leader;
		json_array member_arr;
		for (uint i = 0; i < g.members.length(); i++) member_arr.add(g.members[i]);
		info["members"] = member_arr;
		info["member_count"] = int(g.members.length());
		info["total_glory"] = get_glory(u.account);
		u.send(info);
		u.speak("Guild '" + guild_name + "' created! You are the guild leader.");
	}

	else if (msg_type == message_types::join_guild and msg.exists("name")) {
		string guild_name = string(msg["name"]);
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild.");
			return;
		}
		guild@ g = find_guild(guild_name);
		if (@g == null) {
			u.speak("No guild found with that name.");
			return;
		}
		if (g.members.length() >= 20) {
			u.speak("That guild is full.");
			return;
		}
		if (!g.add_member(u.username)) {
			u.speak("Could not join the guild.");
			return;
		}
		guild_cache_add(u.username, g);
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = g.name;
			progress["guild_leader"] = g.leader;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " joined guild '" + g.name + "'");
		u.speak("You joined the guild '" + g.name + "'!");
		// Notify online guild members.
		for (uint i = 0; i < g.members.length(); i++) {
			if (g.members[i] == u.username) continue;
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) {
				member.send({{"type", message_types::announce}, {"text", u.username + " has joined the guild!"}, {"interrupt", false}});
			}
		}
	}

	else if (msg_type == message_types::leave_guild) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		string old_guild_name = g.name;
		bool was_leader = (g.leader == u.username);
		g.remove_member(u.username);
		guild_cache_remove(u.username);
		// Clear from account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = "";
			progress["guild_leader"] = "";
		}
		u.account.commit();
		if (g.members.length() == 0) {
			// Disband guild.
			int idx = guilds.find_by_ref(g);
			if (idx >= 0) guilds.remove_at(idx);
			println("[GUILDS] Guild '" + old_guild_name + "' disbanded (last member left).");
		} else if (was_leader) {
			// Transfer leadership to first remaining member.
			g.leader = g.members[0];
			// Update the new leader's account.
			account@ new_leader_acct = get_account(g.leader);
			if (@new_leader_acct != null) {
				ensure_account_progression(new_leader_acct);
				json_object@ lp = get_adventure_progress(new_leader_acct);
				if (@lp != null) lp["guild_leader"] = g.leader;
				new_leader_acct.commit();
			}
			// Notify online guild members.
			for (uint i = 0; i < g.members.length(); i++) {
				user@ member = users.get_user_by_name(g.members[i]);
				if (@member != null) {
					member.send({{"type", message_types::announce}, {"text", u.username + " has left the guild. " + g.leader + " is the new leader."}, {"interrupt", false}});
				}
			}
			println("[GUILDS] " + u.username + " left guild '" + old_guild_name + "'. New leader: " + g.leader);
		} else {
			// Notify online guild members.
			for (uint i = 0; i < g.members.length(); i++) {
				user@ member = users.get_user_by_name(g.members[i]);
				if (@member != null) {
					member.send({{"type", message_types::announce}, {"text", u.username + " has left the guild."}, {"interrupt", false}});
				}
			}
			println("[GUILDS] " + u.username + " left guild '" + old_guild_name + "'.");
		}
		u.send({{"type", message_types::leave_guild}});
		u.speak("You left the guild '" + old_guild_name + "'.");
	}

	else if (msg_type == message_types::guild_chat and msg.exists("message")) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		string chat_text = string(msg["message"]);
		// Broadcast to all online guild members.
		json_object@ chat_msg = {{"type", message_types::guild_chat}, {"from", u.username}, {"message", chat_text}};
		for (uint i = 0; i < g.members.length(); i++) {
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) member.send(chat_msg);
		}
	}

	else if (msg_type == message_types::guild_info) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.send({{"type", message_types::guild_info}});
			return;
		}
		json_object info;
		info["type"] = message_types::guild_info;
		info["name"] = g.name;
		info["leader"] = g.leader;
		json_array member_arr;
		int total_glory = 0;
		for (uint i = 0; i < g.members.length(); i++) {
			member_arr.add(g.members[i]);
			account@ macct = get_account(g.members[i]);
			if (@macct != null) total_glory += get_glory(macct);
		}
		info["members"] = member_arr;
		info["member_count"] = int(g.members.length());
		info["total_glory"] = total_glory;
		u.send(info);
	}

	else if (msg_type == message_types::guild_invite and msg.exists("target")) {
		string target_name = string(msg["target"]);
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.speak(target_name + " is not online.");
			return;
		}
		if (@find_guild_for_user(target_name) != null) {
			u.speak(target_name + " is already in a guild.");
			return;
		}
		// Send invite to target.
		target.send({{"type", message_types::guild_invite_received}, {"from", u.username}, {"guild_name", g.name}});
		u.speak("Guild invite sent to " + target_name + ".");
		println("[GUILDS] " + u.username + " invited " + target_name + " to guild '" + g.name + "'");
	}

	else if (msg_type == message_types::guild_invite_response and msg.exists("accepted") and msg.exists("guild_name")) {
		bool accepted = bool(msg["accepted"]);
		string guild_name = string(msg["guild_name"]);
		if (!accepted) {
			u.speak("Guild invite declined.");
			return;
		}
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild.");
			return;
		}
		guild@ g = find_guild(guild_name);
		if (@g == null) {
			u.speak("That guild no longer exists.");
			return;
		}
		if (g.members.length() >= 20) {
			u.speak("That guild is full.");
			return;
		}
		if (!g.add_member(u.username)) {
			u.speak("Could not join the guild.");
			return;
		}
		guild_cache_add(u.username, g);
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = g.name;
			progress["guild_leader"] = g.leader;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " accepted guild invite to '" + g.name + "'");
		u.speak("You joined the guild '" + g.name + "'!");
		// Notify online guild members.
		for (uint i = 0; i < g.members.length(); i++) {
			if (g.members[i] == u.username) continue;
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) {
				member.send({{"type", message_types::announce}, {"text", u.username + " has joined the guild!"}, {"interrupt", false}});
			}
		}
	}

	// ---- Player Stats ----
	else if (msg_type == message_types::player_stats) {
		if (@u.account != null) {
			ensure_account_progression(u.account);
			json_object@ stats_msg = build_player_stats_message(u.account);
			if (@stats_msg != null) u.send(stats_msg);
		}
	}

	else if (msg_type == message_types::inspect_player and msg.exists("target")) {
		string target_name = string(msg["target"]);
		if (target_name == "") {
			u.speak("No player specified.");
			return;
		}
		account@ target_acct = get_account(target_name);
		if (@target_acct == null) {
			u.speak("Player not found.");
			return;
		}
		ensure_account_progression(target_acct);
		json_object@ inspect_msg = build_player_inspect_message(target_acct, target_name);
		if (@inspect_msg != null) {
			u.send(inspect_msg);
		} else {
			u.speak("Could not retrieve stats for that player.");
		}
	}
}
