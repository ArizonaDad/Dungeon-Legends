//          private messaging, friend system, reporting, kick.

// ---- TRADE SESSION ----

class trade_session {
	user@ player_a;
	user@ player_b;
	string[] offer_a;
	string[] offer_b;
	bool confirmed_a = false;
	bool confirmed_b = false;
}

trade_session@[] active_trades;

trade_session@ find_trade_for_user(user@ u) {
	if (@u == null) return null;
	for (uint i = 0; i < active_trades.length(); i++) {
		if (@active_trades[i].player_a is u or @active_trades[i].player_b is u)
			return active_trades[i];
	}
	return null;
}

void cancel_trade(trade_session@ t, string reason) {
	if (@t == null) return;
	if (@t.player_a != null) t.player_a.send({{"type", message_types::trade_cancel}, {"reason", reason}});
	if (@t.player_b != null) t.player_b.send({{"type", message_types::trade_cancel}, {"reason", reason}});
	int idx = active_trades.find_by_ref(t);
	if (idx >= 0) active_trades.remove_at(idx);
}

void complete_trade(trade_session@ t) {
	if (@t == null or @t.player_a == null or @t.player_b == null) return;
	if (@t.player_a.account == null or @t.player_b.account == null) return;

	init_item_catalog();
	json_array@ inv_a = ensure_json_array_field(t.player_a.account.data, "adventure_inventory");
	json_array@ inv_b = ensure_json_array_field(t.player_b.account.data, "adventure_inventory");
	if (@inv_a == null or @inv_b == null) {
		cancel_trade(t, "Inventory error.");
		return;
	}

	// Remove offered items from each player's inventory
	for (uint i = 0; i < t.offer_a.length(); i++) {
		inventory_remove_item(inv_a, t.offer_a[i]);
	}
	for (uint i = 0; i < t.offer_b.length(); i++) {
		inventory_remove_item(inv_b, t.offer_b[i]);
	}

	// Add received items to each player's inventory
	json_array received_a;  // Items player A receives (from B's offer)
	for (uint i = 0; i < t.offer_b.length(); i++) {
		inventory_add_item(inv_a, t.offer_b[i]);
		item_def@ item = find_item(t.offer_b[i]);
		json_object entry;
		entry["id"] = t.offer_b[i];
		entry["name"] = @item != null ? item.name : t.offer_b[i];
		received_a.add(entry);
	}
	json_array received_b;  // Items player B receives (from A's offer)
	for (uint i = 0; i < t.offer_a.length(); i++) {
		inventory_add_item(inv_b, t.offer_a[i]);
		item_def@ item = find_item(t.offer_a[i]);
		json_object entry;
		entry["id"] = t.offer_a[i];
		entry["name"] = @item != null ? item.name : t.offer_a[i];
		received_b.add(entry);
	}

	t.player_a.account.commit();
	t.player_b.account.commit();

	t.player_a.send({{"type", message_types::trade_complete}, {"items", received_a}});
	t.player_b.send({{"type", message_types::trade_complete}, {"items", received_b}});

	int idx = active_trades.find_by_ref(t);
	if (idx >= 0) active_trades.remove_at(idx);
	println("[TRADE] Trade completed between " + t.player_a.username + " and " + t.player_b.username);
}

// Helper: build a trade_update message for one side of the trade.
json_object@ build_trade_update(trade_session@ t, bool for_player_a) {
	if (@t == null) return null;
	init_item_catalog();
	json_object msg;
	msg["type"] = message_types::trade_update;
	msg["partner"] = for_player_a ? t.player_b.username : t.player_a.username;

	// My offer
	string[]@ my_offer = for_player_a ? t.offer_a : t.offer_b;
	json_array my_arr;
	for (uint i = 0; i < my_offer.length(); i++) {
		item_def@ item = find_item(my_offer[i]);
		json_object entry;
		entry["id"] = my_offer[i];
		entry["name"] = @item != null ? item.name : my_offer[i];
		my_arr.add(entry);
	}
	msg["my_offer"] = my_arr;

	// Their offer
	string[]@ their_offer = for_player_a ? t.offer_b : t.offer_a;
	json_array their_arr;
	for (uint i = 0; i < their_offer.length(); i++) {
		item_def@ item = find_item(their_offer[i]);
		json_object entry;
		entry["id"] = their_offer[i];
		entry["name"] = @item != null ? item.name : their_offer[i];
		their_arr.add(entry);
	}
	msg["their_offer"] = their_arr;

	msg["my_confirmed"] = for_player_a ? t.confirmed_a : t.confirmed_b;
	msg["their_confirmed"] = for_player_a ? t.confirmed_b : t.confirmed_a;
	return msg;
}

// Helper: Remove the first occurrence of a string value from a json_array.
// Returns a new json_array with the element removed.
json_array@ json_array_remove_string(json_array@ arr, string value)
{
	json_array result;
	if (@arr == null) return result;
	bool removed = false;
	for (uint i = 0; i < arr.length(); i++) {
		if (!removed and string(arr[i]) == value) {
			removed = true;
			continue; // Skip this one.
		}
		result.add(arr[i]);
	}
	return result;
}

// ---- GUILD SYSTEM ----

class guild {
	string name;
	string leader;
	string[] members;

	guild(string guild_name, string leader_name) {
		name = guild_name;
		leader = leader_name;
		members.insert_last(leader_name);
	}

	bool is_member(string username) {
		for (uint i = 0; i < members.length(); i++) {
			if (members[i] == username) return true;
		}
		return false;
	}

	bool add_member(string username) {
		if (members.length() >= 20) return false;
		if (is_member(username)) return false;
		members.insert_last(username);
		return true;
	}

	bool remove_member(string username) {
		for (uint i = 0; i < members.length(); i++) {
			if (members[i] == username) {
				members.remove_at(i);
				return true;
			}
		}
		return false;
	}
}

guild@[] guilds;

guild@ find_guild(string name) {
	for (uint i = 0; i < guilds.length(); i++) {
		if (guilds[i].name.lower() == name.lower()) return guilds[i];
	}
	return null;
}

guild@ find_guild_for_user(string username) {
	for (uint i = 0; i < guilds.length(); i++) {
		if (guilds[i].is_member(username)) return guilds[i];
	}
	return null;
}

// Rebuild in-memory guild objects from all persisted account data.
// Called once after load_accounts() on server startup.
void rebuild_guilds_from_accounts() {
	guilds.resize(0);
	for (uint i = 0; i < accounts.length(); i++) {
		account@ acct = accounts[i];
		if (@acct == null or @acct.data == null) continue;
		ensure_account_progression(acct);
		json_object@ progress = ensure_json_object_field(acct.data, ACCOUNT_KEY_ADVENTURE_PROGRESS);
		if (@progress == null) continue;
		string gname = progress.exists("guild_name") ? string(progress["guild_name"]) : "";
		if (gname == "") continue;
		guild@ g = find_guild(gname);
		if (@g == null) {
			// First member seen for this guild becomes leader initially.
			// The actual leader is stored per-account; we correct below.
			@g = guild(gname, acct.username);
			guilds.insert_last(g);
		} else {
			g.add_member(acct.username);
		}
	}
	// Second pass: correct leaders from persisted guild_leader field.
	for (uint i = 0; i < accounts.length(); i++) {
		account@ acct = accounts[i];
		if (@acct == null or @acct.data == null) continue;
		json_object@ progress = ensure_json_object_field(acct.data, ACCOUNT_KEY_ADVENTURE_PROGRESS);
		if (@progress == null) continue;
		if (progress.exists("guild_leader") and string(progress["guild_leader"]) != "") {
			guild@ g = find_guild(string(progress["guild_name"]));
			if (@g != null) g.leader = string(progress["guild_leader"]);
		}
	}
	println("[GUILDS] Rebuilt " + guilds.length() + " guild(s) from account data.");
}

monster_def@ get_wild_shape_form_for_combatant(combatant@ c, string form_id)
{
	if (@c == null or c.class_name != "Druid" or c.level < 2) return null;
	bool moon = c.subclass == "Circle of the Moon";
	bool allow_swim = c.level >= 4;
	bool allow_fly = c.level >= 8;

	if (form_id == "wolf" or form_id == "giant_wolf_spider") return get_monster_def(form_id);
	if (form_id == "giant_bat" and allow_fly) return get_monster_def(form_id);
	if (form_id == "crocodile" and allow_swim) return get_monster_def(form_id);
	if (form_id == "dire_wolf" and (moon or c.level >= 8)) return get_monster_def(form_id);
	if (form_id == "giant_constrictor_snake" and moon and c.level >= 6) return get_monster_def(form_id);
	return null;
}

void apply_wild_shape_form(combatant@ c, monster_def@ def)
{
	if (@c == null or @def == null) return;

	c.wild_shape_saved_name = c.name;
	c.wild_shape_saved_size = c.size;
	c.wild_shape_saved_max_hp = c.max_hp;
	c.wild_shape_saved_current_hp = c.current_hp;
	c.wild_shape_saved_temp_hp = c.temp_hp;
	c.wild_shape_saved_armor_class = c.armor_class;
	c.wild_shape_saved_speed = c.speed;
	c.wild_shape_saved_strength = c.ability_scores[ABILITY_STR];
	c.wild_shape_saved_dexterity = c.ability_scores[ABILITY_DEX];
	c.wild_shape_saved_constitution = c.ability_scores[ABILITY_CON];
	c.wild_shape_saved_intelligence = c.ability_scores[ABILITY_INT];
	c.wild_shape_saved_wisdom = c.ability_scores[ABILITY_WIS];
	c.wild_shape_saved_charisma = c.ability_scores[ABILITY_CHA];
	c.wild_shape_saved_main_hand = c.main_hand;
	c.wild_shape_saved_main_hand_damage_dice = c.main_hand_damage_dice;
	c.wild_shape_saved_main_hand_damage_count = c.main_hand_damage_count;
	c.wild_shape_saved_main_hand_damage_type = c.main_hand_damage_type;
	c.wild_shape_saved_main_hand_range = c.main_hand_range;
	c.wild_shape_saved_main_hand_finesse = c.main_hand_finesse;
	c.wild_shape_saved_main_hand_is_ranged = c.main_hand_is_ranged;
	c.wild_shape_saved_monster_attack_bonus = c.monster_attack_bonus;
	c.wild_shape_saved_monster_attack_damage_mod = c.monster_attack_damage_mod;
	c.wild_shape_saved_monster_attack2_name = c.monster_attack2_name;
	c.wild_shape_saved_monster_attack2_bonus = c.monster_attack2_bonus;
	c.wild_shape_saved_monster_attack2_dice = c.monster_attack2_dice;
	c.wild_shape_saved_monster_attack2_count = c.monster_attack2_count;
	c.wild_shape_saved_monster_attack2_mod = c.monster_attack2_mod;
	c.wild_shape_saved_monster_attack2_type = c.monster_attack2_type;
	c.wild_shape_saved_monster_attack2_range = c.monster_attack2_range;
	c.wild_shape_saved_extra_attacks = c.extra_attacks;

	c.wild_shape_active = true;
	c.wild_shape_just_ended = false;
	c.wild_shape_form_id = def.id;
	c.name = c.wild_shape_saved_name + " (" + def.name + ")";
	c.size = def.size;
	c.max_hp = def.hp;
	c.current_hp = def.hp;
	c.temp_hp = 0;
	c.armor_class = def.ac;
	c.speed = def.speed;
	c.ability_scores[ABILITY_STR] = def.str;
	c.ability_scores[ABILITY_DEX] = def.dex;
	c.ability_scores[ABILITY_CON] = def.con;
	c.main_hand = def.attack_name;
	c.main_hand_damage_dice = def.damage_dice;
	c.main_hand_damage_count = def.damage_count;
	c.main_hand_damage_type = def.damage_type;
	c.main_hand_range = def.attack_range;
	c.main_hand_finesse = false;
	c.main_hand_is_ranged = false;
	c.monster_attack_bonus = def.attack_bonus;
	c.monster_attack_damage_mod = def.damage_mod;
	c.monster_attack2_name = def.attack2_name;
	c.monster_attack2_bonus = def.attack2_bonus;
	c.monster_attack2_dice = def.attack2_dice;
	c.monster_attack2_count = def.attack2_count;
	c.monster_attack2_mod = def.attack2_mod;
	c.monster_attack2_type = def.attack2_type;
	c.monster_attack2_range = def.attack2_range;
	c.extra_attacks = (def.has_multiattack and def.multiattack_count > 1) ? def.multiattack_count - 1 : 0;
	if (c.movement_remaining > c.speed) c.movement_remaining = c.speed;
}

void send_character_profile_to_user(user@ u, string profile)
{
	if (@u == null or @u.account == null) return;
	json_object@ msg = build_character_data_message(u.account, profile);
	if (@msg != null) u.send(msg);
}

void send_adventure_progress_to_user(user@ u, string summary = "", int gained = 0, int kill_xp = 0, int healing_xp = 0, int match_xp = 0, int achievement_xp = 0, int levels_gained = 0)
{
	if (@u == null or @u.account == null) return;
	u.send(build_progression_update_message(u.account, gained, kill_xp, healing_xp, match_xp, achievement_xp, levels_gained, summary));
}

int get_daily_bonus_xp(int streak) {
	if (streak <= 0) streak = 1;
	if (streak >= 7) return 200;
	int[] xp_table = {50, 75, 100, 125, 150, 175, 200};
	return xp_table[streak - 1];
}

void process_daily_bonus(user@ u)
{
	if (@u == null or @u.account == null) return;
	json_object@ data = u.account.data;
	uint64 now = ticks();
	uint64 last_login = data.exists("last_login_timestamp") ? uint64(int(data["last_login_timestamp"])) : 0;
	int streak = data.exists("login_streak") ? int(data["login_streak"]) : 0;
	uint64 elapsed = (last_login > 0 and now > last_login) ? now - last_login : 0;
	uint64 ms_24h = 86400000;
	uint64 ms_48h = 172800000;
	if (last_login > 0 and elapsed < ms_24h) {
		data["last_login_timestamp"] = int(now);
		return;
	}
	if (last_login > 0 and elapsed < ms_48h) {
		streak++;
	} else {
		streak = 1;
	}
	if (streak > 7) streak = 1;
	int bonus_xp = get_daily_bonus_xp(streak);
	data["last_login_timestamp"] = int(now);
	data["login_streak"] = streak;
	int levels_gained = 0;
	if (account_has_character_profile(u.account, GAME_TYPE_ADVENTURE)) {
		apply_adventure_xp(u.account, bonus_xp, levels_gained);
	}
	u.send({{"type", message_types::daily_bonus}, {"streak", streak}, {"xp", bonus_xp}});
	println("[DAILY] " + u.username + " day " + streak + " streak, +" + bonus_xp + " XP");
}

class user_manager
{
	user@[] user_list;       // Every connected user.
	dictionary user_dictionary; // Fast lookup by id / name / peer.
	int id = 0;              // Auto-incrementing user id for this session.

	// Create a new in-memory user tied to a persistent account.
	user@ create_user(account@ a, uint peer_id)
	{
		user new_user(a);
		this.id++;
		new_user.id = this.id;
		new_user.username = a.username;
		new_user.peer_id = peer_id;
		this.user_list.insert_last(new_user);
		// Dictionary allows O(1) lookup by id, name, or peer_id.
		this.user_dictionary.set("i/" + this.id, @new_user);
		this.user_dictionary.set("n/" + a.username, @new_user);
		this.user_dictionary.set("p/" + peer_id, @new_user);
		println("[USERS] User created: " + a.username + " (id=" + this.id + ", peer=" + peer_id + ")");
		return new_user;
	}

	// Fully remove a user  cleans up room and dictionary entries.
	bool remove_user(user@ u)
	{
		if (@u == null) {
			println("[USERS] WARNING: remove_user called with null user.");
			return false;
		}
		println("[USERS] Removing user: " + u.username + " (peer=" + u.peer_id + ")");

		// Record last-seen timestamp on their account for friends.
		if (@u.account != null) {
			u.account.data["last_seen"] = calendar().format(DATE_TIME_FORMAT_RFC822);
			u.account.data["last_seen_timestamp"] = ticks();
		}

		// Clean up active trades.
		trade_session@ t = find_trade_for_user(u);
		if (@t != null) cancel_trade(t, u.username + " disconnected.");

		// Clean up room membership.
		if (@u.room != null) {
			try { u.leave_room(u.room); } catch { println("[USERS] Exception removing player from room."); }
		}

		int list_index = user_list.find_by_ref(u);
		if (list_index > -1) user_list.remove_at(list_index);
		user_dictionary.delete("i/" + u.id);
		user_dictionary.delete("n/" + u.username);
		user_dictionary.delete("p/" + u.peer_id);
		return true;
	}

	user@ get_user_by_name(string username)
	{
		if (!user_dictionary.exists("n/" + username)) return null;
		return cast<user@>(user_dictionary["n/" + username]);
	}

	user@ get_user_by_peer(uint peer_id)
	{
		if (!user_dictionary.exists("p/" + peer_id)) return null;
		return cast<user@>(user_dictionary["p/" + peer_id]);
	}

	bool send(json_object@ message, uint channel = 0)
	{
		if (@message == null) return false;
		return net.send(0, message.stringify(), 0);
	}

	var@ opImplConv()
	{
		json_array output;
		for (uint i = 0; i < user_list.length(); i++) output.add(user_list[i]);
		return output;
	}

	uint get_total_users() const property { return user_list.length(); }
}

class user
{
	bool disconnected = false;         // True if player disconnected (awaiting reconnect).
	bool is_bot = false;               // True if this is an AI-controlled player.
	string[] saved_messages;

	int id;
	string status = "online";   // "online", "in_room", "in_game"
	string username;
	uint peer_id;

	private weakref<room> _room;
	private weakref<account> _account;

	room@ get_room() property { return @_room; }
	void set_room(room@ r) property { @_room = r; }
	account@ get_account() property { return @_account; }

	user(account@ a)
	{
		@_account = a;
	}

	room@ new_room(string name, string password, string game_type = "")
	{
		if (@room != null) {
			this.pop_text("You are already in a room!");
			return null;
		}
		room@ r = rooms.create_room(this, name, password, game_type);
		if (@r == null) this.pop_text("Failed to create room.");
		return r;
	}
	void send_to_room(json_object@ message, uint channel = 0)
	{
		if (@room == null or @message == null) return;
		for (uint i = 0; i < this.room.players.length(); i++) {
			try { this.room.players[i].send(message, channel); }
			catch { println("[USER] Exception sending to room member " + i); }
		}
	}
	bool join_room(room@ r)
	{
		if (@r == null) {
			this.pop_text("That room does not exist.");
			return false;
		}
		if (@room != null) {
			this.pop_text("You are already in a room!");
			return false;
		}
		if (rooms.rooms.find_by_ref(@r) == -1) {
			this.speak("This room has been closed.");
			return false;
		}

		r.players.insert_last(this);
		@room = r;
		this.status = "in_room";
		println("[ROOM] " + this.username + " joined room '" + r.name + "' (players=" + r.players.length() + ")");
		// Tell everyone in the room.
		this.send_to_room({{
			"type", message_types::chat_message},
			{"username", ""},
			{"message", this.username + " has joined the room!"},
			{"join", "join"}
		});

		// Tell the joining client whether they are the host or a guest.
		if (this.room.players.size() > 1)
			this.send({{"type", message_types::join_room}, {"username", this.username}, {"player", "player"}, {"game_type", this.room.game_type}});
		else
			this.send({{"type", message_types::join_room}, {"username", this.username}, {"host", "host"}, {"game_type", this.room.game_type}});

		// Send updated player list to everyone in the room.
		send_room_player_list();
		return true;
	}

	bool leave_room(room@ r)
	{
		if (@r == null or @room == null) return false;

		int list_index = r.players.find_by_ref(this);
		if (list_index < 0) {
			@room = null;
			return false;
		}

		println("[ROOM] " + this.username + " leaving room '" + r.name + "' (was index " + list_index + ")");

		if (r.players.size() == 1 or list_index == 0) {
			// Last player or host leaving - close the room for everyone.
			// Send close to all players so their menus exit.
			for (uint ci = 0; ci < r.players.length(); ci++) {
				try {
					r.players[ci].send({{"type", message_types::leave_room}, {"close", "close"}});
					r.players[ci].send({{"type", message_types::room_closed}, {"reason", this.username + " closed the room."}});
					if (int(ci) != list_index) {
						r.players[ci].status = "online";
						@r.players[ci].room = null;
					}
				} catch {}
			}
			r.players.resize(0);
			r.close_room();
		} else {
			// Non-host leaving  notify and remove.
			this.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", this.username + " has left the room."}});
			r.players.remove_at(list_index);
			// Send updated player list to remaining players.
			if (r.players.length() > 0) {
				try { r.players[0].send_room_player_list(); } catch {}
			}
		}

		r.on_player_leave(this);
		this.status = "online";
		@room = null;
		return true;
	}

	// Broadcasts the current list of usernames in the room to all room members.
	void send_room_player_list()
	{
		if (@room == null) return;
		json_array names;
		json_array bot_flags;
		for (uint i = 0; i < this.room.players.length(); i++) {
			names.add(this.room.players[i].username);
			bot_flags.add(this.room.players[i].is_bot);
		}
		// The first player in the list is always the host.
		string host_name = (this.room.players.length() > 0) ? this.room.players[0].username : "";
		json_object@ msg = {{"type", message_types::room_players}, {"players", names}, {"host", host_name}, {"bots", bot_flags}, {"game_type", this.room.game_type}};
		for (uint i = 0; i < this.room.players.length(); i++) {
			try { this.room.players[i].send(msg); }
			catch { println("[ROOM] Exception sending player list to " + i); }
		}
	}

	void on_login()
	{
		this.speak("Main menu, Welcome. Use page up and page down to adjust the volume.  Select an option.");

		if (@this.account != null) {
			json_object@ data = this.account.data;
			ensure_account_progression(this.account);
			if (data.exists("pending_friend_requests")) {
				json_array@ pending = data["pending_friend_requests"];
				if (pending.length() > 0) {
					this.send({{"type", message_types::announce}, {"text", "You have " + pending.length() + " pending friend request" + (pending.length() == 1 ? "" : "s") + "!"}, {"interrupt", false}});
				}
			}
			process_daily_bonus(this);
			send_character_profile_to_user(this, GAME_TYPE_SANDBOX);
			send_character_profile_to_user(this, GAME_TYPE_ADVENTURE);
			send_character_list_to_user(this, GAME_TYPE_ADVENTURE);
			send_character_list_to_user(this, GAME_TYPE_SANDBOX);
			send_adventure_progress_to_user(this);
			// Send daily dungeon info on login
			string daily_id = get_daily_dungeon_id();
			string daily_diff = get_daily_difficulty();
			string daily_name = get_dungeon_display_name(daily_id);
			bool daily_claimable = can_claim_daily(this.account);
			this.send({{"type", message_types::daily_dungeon_info}, {"dungeon_id", daily_id}, {"dungeon_name", daily_name}, {"difficulty", daily_diff}, {"can_claim", daily_claimable}});
			// Send guild info on login if player is in a guild.
			json_object@ gp = get_adventure_progress(this.account);
			string login_guild_name = (@gp != null and gp.exists("guild_name")) ? string(gp["guild_name"]) : "";
			if (login_guild_name != "") {
				guild@ login_guild = find_guild(login_guild_name);
				if (@login_guild != null) {
					json_object guild_login_info;
					guild_login_info["type"] = message_types::guild_info;
					guild_login_info["name"] = login_guild.name;
					guild_login_info["leader"] = login_guild.leader;
					json_array login_members;
					int login_glory = 0;
					for (uint gi = 0; gi < login_guild.members.length(); gi++) {
						login_members.add(login_guild.members[gi]);
						user@ gu = users.get_user_by_name(login_guild.members[gi]);
						if (@gu != null and @gu.account != null) login_glory += get_glory(gu.account);
					}
					guild_login_info["members"] = login_members;
					guild_login_info["member_count"] = int(login_guild.members.length());
					guild_login_info["total_glory"] = login_glory;
					this.send(guild_login_info);
				}
			}
			// Notify online friends that this player is now online
			if (data.exists("friends")) {
				json_array@ friends = data["friends"];
				for (uint fi = 0; fi < friends.length(); fi++) {
					string friend_name = string(friends[fi]);
					user@ friend_user = users.get_user_by_name(friend_name);
					if (@friend_user != null) {
						friend_user.send({{"type", message_types::friend_online}, {"username", this.username}});
					}
				}
			}
			this.account.commit();
		}
	}

	var@ opImplConv()
	{
		return json_object({{"username", this.username}});
	}
	bool send(json_object@ message, int channel = 0)
	{
		if (@message == null or disconnected) return false;
		if (is_bot) return true; // Bots don't have network peers; silently succeed.
		return svr.send(peer_id, message, channel);
	}

	void speak(string text)
	{
		json_object@ message = {{"type", message_types::chat_message}, {"username", ""}, {"message", text}};
		this.send(message);
	}

	void speak_else(string text)
	{
		if (@room == null) return;
		json_object@ message = {{"type", message_types::chat_message}, {"username", ""}, {"message", text}};
		int list_index = this.room.players.find_by_ref(this);
		for (int i = 0; i < this.room.players.length(); i++) {
			if (i != list_index) {
				try { this.room.players[i].send(message); } catch {}
			}
		}
	}

	void speak_all(string msg)
	{
		this.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", msg}});
	}

	void send_else(json_object@ message)
	{
		if (@room == null or @message == null) return;
		int list_index = this.room.players.find_by_ref(this);
		for (int i = 0; i < this.room.players.length(); i++) {
			if (i != list_index) {
				try { this.room.players[i].send(message); } catch {}
			}
		}
	}

	bool pop_text(string text, uint timeout = 0)
	{
		if (is_bot) return true;
		return svr.send_text_popout(peer_id, text, timeout);
	}
}

// handle_user_message  Dispatches authenticated user messages.
// This is the main router for all non-game-specific messages.

void handle_user_message(user@ u, json_object@ msg)
{
	// Safety: null checks.
	if (@u == null or @msg == null or !msg.exists("type")) return;

	string msg_type = msg["type"];

	if (msg_type == message_types::check_online) {
		u.send({{"type", message_types::check_online}, {"users", users}});
	}

	else if (msg_type == message_types::new_room and msg.exists("name") and msg.exists("password")) {
		string game_type = msg.exists("game_type") ? string(msg["game_type"]) : "";
		u.new_room(msg["name"], msg["password"], game_type);
	}

	else if (msg_type == message_types::list_rooms) {
		u.send({{"type", message_types::list_rooms}, {"rooms", rooms}});
	}

	else if (msg_type == message_types::chat_message and msg.exists("message")) {
		if (@u.room != null) {
			// In a room: broadcast to room.
			u.send_to_room({{"type", message_types::chat_message}, {"username", u.username}, {"message", msg["message"]}});
		} else {
			// Not in a room: broadcast to all players in the main menu (not in any room).
			json_object@ chat_msg = {{"type", message_types::chat_message}, {"username", u.username}, {"message", msg["message"]}};
			for (uint mm = 0; mm < users.user_list.length(); mm++) {
				try {
					if (@users.user_list[mm].room == null) {
						users.user_list[mm].send(chat_msg);
					}
				} catch {}
			}
		}
	}

	else if (msg_type == message_types::join_room and msg.exists("room")) {
		int room_index = int(msg["room"]);
		if (room_index < 0 or room_index >= rooms.rooms.length()) {
			u.speak("That room no longer exists.");
		} else {
			room@ target_room = rooms.rooms[room_index];
			// If the room is password-locked, require password.
			if (target_room.is_private) {
				if (msg.exists("password") and string(msg["password"]) == target_room.password) {
					u.join_room(target_room);
				} else {
					// Tell client a password is required.
					u.send({{"type", message_types::password_required}, {"room", room_index}});
				}
			} else {
				u.join_room(target_room);
			}
		}
	}

	else if (msg_type == message_types::password_submit and msg.exists("room") and msg.exists("password")) {
		int room_index = int(msg["room"]);
		if (room_index < 0 or room_index >= rooms.rooms.length()) {
			u.speak("That room no longer exists.");
		} else {
			room@ target_room = rooms.rooms[room_index];
			if (string(msg["password"]) == target_room.password) {
				u.join_room(target_room);
			} else {
				u.speak("Incorrect password.");
			}
		}
	}

	else if (msg_type == message_types::leave_room) {
		room@ temp_room = u.get_room();
		if (@temp_room != null) {
			if (msg.exists("leave")) {
				u.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", u.username + " has left the room."}});
			}
			u.leave_room(temp_room);
		}
	}

	else if (msg_type == message_types::leave_game) {
		// Player forfeited mid-battle. Kill their combatant so the battle can end.
		if (@u.room != null and @u.room.bm != null and u.room.started) {
			battle@ b = u.room.bm.combat;
			if (@b != null) {
				for (uint ci = 0; ci < b.combatants.length(); ci++) {
					if (b.combatants[ci].is_player and b.combatants[ci].player_username == u.username) {
						b.combatants[ci].current_hp = 0;
						b.combatants[ci].is_dead = true;
						u.room.bm.broadcast_announce(u.username + " has forfeited the battle.", true);
						u.room.bm.broadcast_state();
						break;
					}
				}
			}
		}
	}

	else if (msg_type == message_types::kick_player and msg.exists("target")) {
		string target_name = msg["target"];
		if (@u.room == null) {
			u.speak("You are not in a room.");
			return;
		}
		// Only the host (first player) can kick.
		if (u.room.players.length() == 0 or u.room.players[0].username != u.username) {
			u.speak("Only the host can kick players.");
			return;
		}
		// Find the target in the room.
		user@ target = null;
		for (uint i = 0; i < u.room.players.length(); i++) {
			if (u.room.players[i].username == target_name) {
				@target = u.room.players[i];
				break;
			}
		}
		if (@target == null) {
			u.speak(target_name + " is not in this room.");
			return;
		}
		if (target.username == u.username) {
			u.speak("You cannot kick yourself.");
			return;
		}
		println("[ROOM] Host " + u.username + " kicked " + target_name + " from room '" + u.room.name + "'");
		// Notify the kicked player.
		target.send({{"type", message_types::announce}, {"text", "You have been kicked from the room by the host."}, {"interrupt", true}});
		target.send({{"type", message_types::leave_room}, {"close", "close"}});
		// Remove from room.
		room@ r = u.room;
		int idx = r.players.find_by_ref(target);
		if (idx >= 0) {
			r.players.remove_at(idx);
			@target.room = null;
			target.status = "online";
		}
		// Notify remaining players.
		u.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " has been kicked from the room."}});
		u.send_room_player_list();
	}

	else if (msg_type == message_types::private_message and msg.exists("target") and msg.exists("message")) {
		string target_name = msg["target"];
		string pm_text = msg["message"];
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.speak(target_name + " is not online.");
			return;
		}
		println("[PM] " + u.username + " -> " + target_name + ": " + pm_text);
		string time_str = calendar().format(DATE_TIME_FORMAT_RFC822);
		u.saved_messages.insert_last("[" + time_str + "] To " + target_name + ": " + pm_text);
		target.saved_messages.insert_last("[" + time_str + "] From " + u.username + ": " + pm_text);
		// Deliver to target.
		target.send({{"type", message_types::private_message}, {"from", u.username}, {"message", pm_text}});
		// Confirm to sender.
		u.send({{"type", message_types::private_message}, {"from", "You"}, {"to", target_name}, {"message", pm_text}});
	}

	else if (msg_type == message_types::report_player and msg.exists("target") and msg.exists("reason")) {
		string target_name = msg["target"];
		string reason = msg["reason"];
		println("[REPORT] " + u.username + " reported " + target_name + ": " + reason);

		// Save report to the TARGET's account data (persists across sessions).
		account@ target_acct = get_account(target_name);
		if (@target_acct != null) {
			json_object@ data = target_acct.data;
			// Ensure reported_messages array exists.
			json_array@ reports;
			if (data.exists("reported_messages")) {
				@reports = data["reported_messages"];
			} else {
				json_array new_reports;
				data.set("reported_messages", new_reports);
				@reports = data["reported_messages"];
			}
			// Build the report entry.
			string entry = "Reported by " + u.username + " on " + calendar().format(DATE_TIME_FORMAT_RFC822) + ": " + reason;
			reports.add(entry);
			target_acct.commit();
			println("[REPORT] Saved report to " + target_name + "'s account. Total reports: " + reports.length());
		}
		u.send({{"type", message_types::report_confirm}, {"target", target_name}});
	}

	else if (msg_type == message_types::friend_request and msg.exists("target")) {
		string target_name = msg["target"];

		if (target_name == u.username) {
			u.speak("You cannot add yourself as a friend.");
			return;
		}

		// Get both accounts.
		account@ my_acct = u.account;
		account@ target_acct = get_account(target_name);
		if (@target_acct == null) {
			u.speak("No account found for " + target_name + ".");
			return;
		}

		// Check if already friends.
		json_object@ my_data = my_acct.data;
		if (!my_data.exists("friends")) my_data.set("friends", json_array());
		json_array@ my_friends = my_data["friends"];
		for (uint i = 0; i < my_friends.length(); i++) {
			if (string(my_friends[i]) == target_name) {
				u.speak(target_name + " is already your friend.");
				return;
			}
		}

		// Add to target's pending requests.
		json_object@ target_data = target_acct.data;
		if (!target_data.exists("pending_friend_requests")) target_data.set("pending_friend_requests", json_array());
		json_array@ pending = target_data["pending_friend_requests"];

		// Check for duplicates.
		for (uint i = 0; i < pending.length(); i++) {
			if (string(pending[i]) == u.username) {
				u.speak("You have already sent a friend request to " + target_name + ".");
				return;
			}
		}

		pending.add(u.username);
		target_acct.commit();
		println("[FRIENDS] " + u.username + " sent friend request to " + target_name);

		u.speak("Friend request sent to " + target_name + "!");

		// If target is online, notify them.
		user@ target_user = users.get_user_by_name(target_name);
		if (@target_user != null) {
			target_user.send({{"type", message_types::friend_request_received}, {"from", u.username}});
		}
	}

	else if (msg_type == message_types::friend_accept and msg.exists("target")) {
		string requester_name = msg["target"];
		account@ my_acct = u.account;
		account@ requester_acct = get_account(requester_name);

		if (@my_acct == null or @requester_acct == null) {
			u.speak("Could not find that account.");
			return;
		}

		// Remove from pending.
		json_object@ my_data = my_acct.data;
		if (my_data.exists("pending_friend_requests")) {
			json_array@ pending = my_data["pending_friend_requests"];
			my_data.set("pending_friend_requests", json_array_remove_string(pending, requester_name));
		}

		// Add each other to friends lists.
		if (!my_data.exists("friends")) my_data.set("friends", json_array());
		json_array@ my_friends = my_data["friends"];
		my_friends.add(requester_name);

		json_object@ req_data = requester_acct.data;
		if (!req_data.exists("friends")) req_data.set("friends", json_array());
		json_array@ req_friends = req_data["friends"];
		req_friends.add(u.username);

		my_acct.commit();
		requester_acct.commit();
		println("[FRIENDS] " + u.username + " accepted friend request from " + requester_name);

		u.speak("You and " + requester_name + " are now friends!");

		// Notify the requester if online.
		user@ requester_user = users.get_user_by_name(requester_name);
		if (@requester_user != null) {
			requester_user.send({{"type", message_types::announce}, {"text", u.username + " accepted your friend request!"}, {"interrupt", false}});
		}
	}

	else if (msg_type == message_types::friend_decline and msg.exists("target")) {
		string requester_name = msg["target"];
		account@ my_acct = u.account;
		if (@my_acct == null) return;

		json_object@ my_data = my_acct.data;
		if (my_data.exists("pending_friend_requests")) {
			json_array@ pending = my_data["pending_friend_requests"];
			my_data.set("pending_friend_requests", json_array_remove_string(pending, requester_name));
		}
		my_acct.commit();
		u.speak("Friend request from " + requester_name + " declined.");
		println("[FRIENDS] " + u.username + " declined friend request from " + requester_name);
	}

	else if (msg_type == message_types::friend_remove and msg.exists("target")) {
		string friend_name = msg["target"];
		account@ my_acct = u.account;
		account@ friend_acct = get_account(friend_name);

		if (@my_acct != null) {
			json_object@ my_data = my_acct.data;
			if (my_data.exists("friends")) {
				json_array@ my_friends = my_data["friends"];
				my_data.set("friends", json_array_remove_string(my_friends, friend_name));
			}
			my_acct.commit();
		}

		if (@friend_acct != null) {
			json_object@ fdata = friend_acct.data;
			if (fdata.exists("friends")) {
				json_array@ f_friends = fdata["friends"];
				fdata.set("friends", json_array_remove_string(f_friends, u.username));
			}
			friend_acct.commit();
		}

		u.speak(friend_name + " has been removed from your friends list.");
		println("[FRIENDS] " + u.username + " removed friend " + friend_name);
	}

	else if (msg_type == message_types::friend_list) {
		account@ my_acct = u.account;
		if (@my_acct == null) return;

		json_object@ my_data = my_acct.data;
		if (!my_data.exists("friends")) my_data.set("friends", json_array());
		json_array@ my_friends = my_data["friends"];

		// Build a detailed list with online status.
		json_array friend_details;
		for (uint i = 0; i < my_friends.length(); i++) {
			string fname = my_friends[i];
			user@ online_friend = users.get_user_by_name(fname);
			json_object entry;
			entry["username"] = fname;

			if (@online_friend != null) {
				entry["online"] = true;
				if (@online_friend.room != null) {
					entry["status"] = "in a room";
				} else {
					entry["status"] = "in main menu";
				}
			} else {
				entry["online"] = false;
				// Get last seen from their account.
				account@ facct = get_account(fname);
				if (@facct != null and facct.data.exists("last_seen_timestamp")) {
					uint64 last_ts = uint64(facct.data["last_seen_timestamp"]);
					uint64 now_ts = ticks();
					uint64 diff_ms = (now_ts > last_ts) ? (now_ts - last_ts) : 0;
					int diff_min = int(diff_ms / 60000);
					int diff_hr = diff_min / 60;
					int diff_day = diff_hr / 24;

					if (diff_day > 0) entry["last_seen"] = "" + diff_day + " day" + (diff_day == 1 ? "" : "s") + " ago";
					else if (diff_hr > 0) entry["last_seen"] = "" + diff_hr + " hour" + (diff_hr == 1 ? "" : "s") + " ago";
					else if (diff_min > 0) entry["last_seen"] = "" + diff_min + " minute" + (diff_min == 1 ? "" : "s") + " ago";
					else entry["last_seen"] = "just now";
				} else {
					entry["last_seen"] = "unknown";
				}
			}
			friend_details.add(entry);
		}
		u.send({{"type", message_types::friend_list}, {"friends", friend_details}});
	}

	else if (msg_type == message_types::pending_requests) {
		account@ my_acct = u.account;
		if (@my_acct == null) return;

		json_object@ my_data = my_acct.data;
		if (!my_data.exists("pending_friend_requests")) my_data.set("pending_friend_requests", json_array());
		json_array@ pending = my_data["pending_friend_requests"];
		u.send({{"type", message_types::pending_requests}, {"requests", pending}});
	}

	else if (msg_type == message_types::room_players) {
		u.send_room_player_list();
	}

	// --- AI Bot Management ---

	else if (msg_type == message_types::add_bot) {
		if (@u.room == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "You must be in a room to add an AI player."}});
			return;
		}
		// Only the host (first player) can add bots.
		if (u.room.players.length() == 0 or @u.room.players[0] != @u) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Only the host can add AI players."}});
			return;
		}
		if (u.room.started) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Cannot add bots after the game has started."}});
			return;
		}
		// Limit to reasonable number of total players.
		if (u.room.players.length() >= 4) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Room is full. Maximum 4 players."}});
			return;
		}
		// Generate unique silly bot name.
		string bot_name = generate_bot_name();
		// Ensure no duplicate names in the room.
		bool dupe = true;
		while (dupe) {
			dupe = false;
			for (uint bi = 0; bi < u.room.players.length(); bi++) {
				if (u.room.players[bi].username == bot_name) { dupe = true; bot_name = generate_bot_name(); break; }
			}
		}
		user@ bot = create_bot_user(bot_name);
		@bot.room = u.room;
		u.room.players.insert_last(bot);
		// Notify room.
		u.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", bot_name + " (AI) has joined the room!"}});
		u.send_room_player_list();
	}

	else if (msg_type == message_types::remove_bot and msg.exists("bot_name")) {
		if (@u.room == null) return;
		if (u.room.players.length() == 0 or @u.room.players[0] != @u) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Only the host can remove AI players."}});
			return;
		}
		string bot_name = string(msg["bot_name"]);
		for (uint bi = 0; bi < u.room.players.length(); bi++) {
			if (u.room.players[bi].is_bot and u.room.players[bi].username == bot_name) {
				u.room.players.remove_at(bi);
				u.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", bot_name + " (AI) has been removed from the room."}});
				u.send_room_player_list();
				break;
			}
		}
	}

	else if (msg_type == message_types::start_game) {
		if (@u.room == null) {
			u.send({{"type", message_types::error}, {"text", "You are not in a room."}});
			return;
		}
		if (u.room.players.length() == 0) {
			u.send({{"type", message_types::error}, {"text", "No players in the room."}});
			return;
		}
		if (u.room.started) {
			u.send({{"type", message_types::error}, {"text", "A game is already in progress."}});
			return;
		}
		// Only host can start (first player in room)
		if (u.room.players[0].username != u.username) {
			u.send({{"type", message_types::announce}, {"text", "Only the host can start the game."}, {"interrupt", true}});
			return;
		}
		string room_game_type = normalize_game_type(u.room.game_type);
		string required_profile = room_game_type;
		string[] missing_players;
		for (uint i = 0; i < u.room.players.length(); i++) {
			user@ participant = u.room.players[i];
			if (@participant == null or participant.is_bot or @participant.account == null) continue;
			ensure_account_progression(participant.account);
			if (!account_has_character_profile(participant.account, required_profile)) {
				missing_players.insert_last(participant.username);
				participant.send({{"type", message_types::announce}, {"text", "You need a " + display_game_type(required_profile) + " character before this lobby can start."}, {"interrupt", true}});
			}
		}
		if (missing_players.length() > 0) {
			string missing_text = "";
			for (uint i = 0; i < missing_players.length(); i++) {
				if (i > 0) missing_text += i == missing_players.length() - 1 ? " and " : ", ";
				missing_text += missing_players[i];
			}
			u.send({{"type", message_types::announce}, {"text", "Cannot start the " + display_game_type(room_game_type) + " lobby yet. Missing characters: " + missing_text + "."}, {"interrupt", true}});
			return;
		}
		u.room.started = true;
		string mode = msg.exists("mode") ? string(msg["mode"]) : "pvp";
		string scenario = msg.exists("scenario") ? string(msg["scenario"]) : "";
		string difficulty = msg.exists("difficulty") ? string(msg["difficulty"]) : "normal";
		// Send start_game to all players — client will enter combat loop
		for (uint i = 0; i < u.room.players.length(); i++) {
			u.room.players[i].send({{"type", message_types::start_game}, {"mode", mode}, {"scenario", scenario}});
		}
		// Create battle manager and start combat on server
		@u.room.bm = battle_manager();
		u.room.bm.start_game(u, mode, scenario, difficulty);
	}

	// --- Character Creation (save to account) ---
	else if (msg_type == message_types::character_create) {
		if (@u.account != null) {
			ensure_account_progression(u.account);
			json_object@ data = u.account.data;
			string profile = msg.exists("profile") ? normalize_game_type(string(msg["profile"])) : GAME_TYPE_SANDBOX;
			string storage_key = get_character_storage_key(profile);
			json_object char_data;
			if (msg.exists("name")) char_data["name"] = msg["name"];
			if (msg.exists("gender")) char_data["gender"] = msg["gender"];
			if (msg.exists("race")) char_data["race"] = msg["race"];
			if (msg.exists("class")) char_data["class"] = msg["class"];
			if (msg.exists("subclass")) char_data["subclass"] = msg["subclass"];
			if (msg.exists("background")) char_data["background"] = msg["background"];
			int stored_level = msg.exists("level") ? int(msg["level"]) : 1;
			if (profile == GAME_TYPE_ADVENTURE) {
				json_object@ progress = get_adventure_progress(u.account);
				stored_level = @progress != null ? get_json_int(progress, "level", 1) : 1;
				if (stored_level < 1) stored_level = 1;
				if (stored_level < 3) char_data["subclass"] = "";
			}
			char_data["level"] = stored_level;
			if (msg.exists("str")) char_data["str"] = msg["str"];
			if (msg.exists("dex")) char_data["dex"] = msg["dex"];
			if (msg.exists("con")) char_data["con"] = msg["con"];
			if (msg.exists("int")) char_data["int"] = msg["int"];
			if (msg.exists("wis")) char_data["wis"] = msg["wis"];
			if (msg.exists("cha")) char_data["cha"] = msg["cha"];
			if (msg.exists("base_str")) char_data["base_str"] = msg["base_str"];
			if (msg.exists("base_dex")) char_data["base_dex"] = msg["base_dex"];
			if (msg.exists("base_con")) char_data["base_con"] = msg["base_con"];
			if (msg.exists("base_int")) char_data["base_int"] = msg["base_int"];
			if (msg.exists("base_wis")) char_data["base_wis"] = msg["base_wis"];
			if (msg.exists("base_cha")) char_data["base_cha"] = msg["base_cha"];
			if (msg.exists("weapon")) char_data["weapon"] = msg["weapon"];
			if (msg.exists("feats")) char_data["feats"] = msg["feats"];
			if (msg.exists("skills")) char_data["skills"] = msg["skills"];
			if (msg.exists("tools")) char_data["tools"] = msg["tools"];
			if (msg.exists("spell_ability_overrides")) char_data["spell_ability_overrides"] = msg["spell_ability_overrides"];
			if (msg.exists("free_cast_spells")) char_data["free_cast_spells"] = msg["free_cast_spells"];
			if (msg.exists("cantrips")) char_data["cantrips"] = msg["cantrips"];
			if (msg.exists("spells")) char_data["spells"] = msg["spells"];
			// Append to character array (multi-character support, up to 40 per mode)
			ensure_character_array_format(u.account, profile);
			json_array@ chars = get_character_list(u.account, profile);
			if (@chars != null and int(chars.length()) >= MAX_CHARACTERS_PER_MODE) {
				u.send({{"type", message_types::error}, {"text", "Maximum " + MAX_CHARACTERS_PER_MODE + " characters per mode. Delete one first."}});
				return;
			}
			if (@chars == null) { json_array new_arr; data[get_character_list_key(profile)] = new_arr; @chars = get_character_list(u.account, profile); }
			chars.add(char_data);
			int new_slot = int(chars.length()) - 1;
			set_active_slot(u.account, profile, new_slot);
			// Also update legacy single-char key for backward compatibility
			data[storage_key] = char_data;
			if (!data.exists("first_login_done")) data["first_login_done"] = true;
			u.account.commit();
			send_character_profile_to_user(u, profile);
			send_character_list_to_user(u, profile);
			if (profile == GAME_TYPE_ADVENTURE) send_adventure_progress_to_user(u);
			u.send({{"type", message_types::announce}, {"text", display_game_type(profile) + " character saved. Slot " + (new_slot + 1) + " of " + chars.length() + "."}, {"interrupt", false}});
			println("[CHAR] " + u.username + " saved " + profile + " character slot " + new_slot + ": " + string(msg["name"]));
		}
	}

	// --- Character Select (change active slot) ---
	else if (msg_type == message_types::character_select) {
		if (@u.account != null) {
			string profile = msg.exists("profile") ? normalize_game_type(string(msg["profile"])) : GAME_TYPE_ADVENTURE;
			int slot = msg.exists("slot") ? int(msg["slot"]) : 0;
			ensure_character_array_format(u.account, profile);
			json_array@ chars = get_character_list(u.account, profile);
			if (@chars == null or slot < 0 or slot >= int(chars.length())) {
				u.send({{"type", message_types::error}, {"text", "Invalid character slot."}});
				return;
			}
			set_active_slot(u.account, profile, slot);
			u.account.commit();
			send_character_profile_to_user(u, profile);
			u.send({{"type", message_types::announce}, {"text", "Switched to character slot " + (slot + 1) + "."}, {"interrupt", false}});
		}
	}

	// --- Character Delete ---
	else if (msg_type == message_types::character_delete) {
		if (@u.account != null) {
			string profile = msg.exists("profile") ? normalize_game_type(string(msg["profile"])) : GAME_TYPE_ADVENTURE;
			int slot = msg.exists("slot") ? int(msg["slot"]) : -1;
			ensure_character_array_format(u.account, profile);
			json_array@ chars = get_character_list(u.account, profile);
			if (@chars == null or slot < 0 or slot >= int(chars.length())) {
				u.send({{"type", message_types::error}, {"text", "Invalid character slot."}});
				return;
			}
			string deleted_name = "Unknown";
			json_object@ del_char = chars[slot];
			if (@del_char != null and del_char.exists("name")) deleted_name = string(del_char["name"]);
			// Rebuild array without the deleted slot
			json_array new_chars;
			for (uint di = 0; di < chars.length(); di++) {
				if (int(di) != slot) new_chars.add(chars[di]);
			}
			u.account.data[get_character_list_key(profile)] = new_chars;
			@chars = get_character_list(u.account, profile);
			// Adjust active slot if needed
			int active = get_active_slot(u.account, profile);
			if (active >= int(new_chars.length())) set_active_slot(u.account, profile, int(new_chars.length()) > 0 ? int(new_chars.length()) - 1 : 0);
			else if (active > slot) set_active_slot(u.account, profile, active - 1);
			// Update legacy key
			json_object@ new_active = get_character_profile(u.account, profile);
			if (@new_active != null) u.account.data[get_character_storage_key(profile)] = new_active;
			u.account.commit();
			send_character_list_to_user(u, profile);
			if (chars.length() > 0) send_character_profile_to_user(u, profile);
			u.send({{"type", message_types::announce}, {"text", "Deleted " + deleted_name + "."}, {"interrupt", false}});
		}
	}

	else if (msg_type == message_types::level_up_response) {
		if (@u.account != null) {
			ensure_account_progression(u.account);
			json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
			if (@character != null) {
				if (msg.exists("subclass") and string(msg["subclass"]) != "") {
					character["subclass"] = msg["subclass"];
				}
				if (msg.exists("new_cantrips")) {
					json_array@ existing = null;
					if (character.exists("cantrips")) @existing = character["cantrips"];
					if (@existing == null) { json_array arr; character["cantrips"] = arr; @existing = character["cantrips"]; }
					json_array@ new_cantrips = msg["new_cantrips"];
					if (@new_cantrips != null) {
						for (uint i = 0; i < new_cantrips.length(); i++) existing.add(new_cantrips[i]);
					}
				}
				if (msg.exists("new_spells")) {
					json_array@ existing = null;
					if (character.exists("spells")) @existing = character["spells"];
					if (@existing == null) { json_array arr; character["spells"] = arr; @existing = character["spells"]; }
					json_array@ new_spells = msg["new_spells"];
					if (@new_spells != null) {
						for (uint i = 0; i < new_spells.length(); i++) existing.add(new_spells[i]);
					}
				}
				u.account.commit();
				send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
				u.send({{"type", message_types::announce}, {"text", "Level-up choices saved!"}, {"interrupt", false}});
			}
		}
	}

	// --- Combat Message Routing (forward to battle_manager) ---
	else if (msg_type == message_types::roll_result) {
		if (@u.room == null or @u.room.bm == null) {
			u.send({{"type", message_types::announce}, {"text", "Not in a battle."}, {"interrupt", false}});
			return;
		}
		if (@u.room.bm.current_roll == null) {
			u.send({{"type", message_types::announce}, {"text", "Not waiting for your roll right now. Please wait."}, {"interrupt", false}});
			return;
		}
		if (u.room.bm.current_roll.player_username != u.username) {
			u.send({{"type", message_types::announce}, {"text", "It is not your turn to roll."}, {"interrupt", false}});
			return;
		}
		u.room.bm.handle_roll_result(u);
	}
	else if (msg_type == message_types::turn_end) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_turn_end(u);
		}
	}
	else if (msg_type == message_types::action_attack) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_attack(u, msg);
		}
	}
	else if (msg_type == message_types::action_move) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_move(u, msg);
		}
	}
	else if (msg_type == message_types::action_dodge) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_dodge(u);
		}
	}
	else if (msg_type == message_types::action_dash) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_dash(u);
		}
	}
	else if (msg_type == message_types::action_disengage) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_disengage(u);
		}
	}
	else if (msg_type == message_types::bonus_action) {
		if (@u.room == null or @u.room.bm == null or @u.room.bm.combat == null) return;
		combatant@ c = u.room.bm.combat.current_combatant();
		if (@c == null or c.player_username != u.username) return;
		string feature = msg.exists("feature") ? string(msg["feature"]) : "";
		uint target_id = msg.exists("target_id") ? uint(int(msg["target_id"])) : (msg.exists("target") ? uint(int(msg["target"])) : 0);

		if (feature == "rage") {
			if (c.class_name != "Barbarian") { u.send({{"type", message_types::announce}, {"text", "Only barbarians can Rage."}, {"interrupt", true}}); return; }
			if (c.raging) { u.send({{"type", message_types::announce}, {"text", "You are already raging."}, {"interrupt", true}}); return; }
			if (c.rage_uses_remaining <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no Rages remaining this battle."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.rage_uses_remaining--;
			c.raging = true;
			c.rage_turns_remaining = 10;
			u.room.bm.broadcast_announce(c.name + " enters a Rage! Bonus damage and resistance to bludgeoning, piercing, and slashing. " + c.rage_uses_remaining + " use" + (c.rage_uses_remaining == 1 ? "" : "s") + " remain.", true);
		}
		else if (feature == "action_surge") {
			if (c.class_name != "Fighter") { u.send({{"type", message_types::announce}, {"text", "Only fighters can use Action Surge."}, {"interrupt", true}}); return; }
			if (c.action_surge_uses_remaining <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no Action Surge uses remaining this battle."}, {"interrupt", true}}); return; }
			// Action Surge is a free action (not bonus action). Restore action.
			c.action_surge_uses_remaining--;
			c.has_action = true;
			c.used_action = false;
			c.attacks_remaining_this_turn = 0; // Reset so new Attack action gets full extra attacks
			u.room.bm.broadcast_announce(c.name + " uses Action Surge! Extra action this turn. " + c.action_surge_uses_remaining + " use" + (c.action_surge_uses_remaining == 1 ? "" : "s") + " remain.", true);
		}
		else if (feature == "second_wind") {
			if (c.class_name != "Fighter") { u.send({{"type", message_types::announce}, {"text", "Only fighters can use Second Wind."}, {"interrupt", true}}); return; }
			if (!c.second_wind_available) { u.send({{"type", message_types::announce}, {"text", "You have already used Second Wind this battle."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.second_wind_available = false;
			int heal = random(1, 10) + c.level;
			int effective_heal = u.room.bm.combat.apply_healing(c, heal);
			u.room.bm.record_effective_healing(c.player_username, effective_heal);
			u.room.bm.broadcast_roll(c.name, "Second Wind healing", heal, c.level, heal, "");
			u.room.bm.broadcast_announce(c.name + " uses Second Wind! Healed " + effective_heal + " HP. Now at " + c.current_hp + ".", false);
		}
		else if (feature == "divine_smite") {
			if (c.class_name != "Paladin") { u.send({{"type", message_types::announce}, {"text", "Only paladins can prepare Divine Smite."}, {"interrupt", true}}); return; }
			// Find lowest available spell slot (1-5 for smite)
			int slot_used = -1;
			for (int sl = 1; sl <= 5; sl++) {
				if (c.spell_slots_current[sl] > 0) { slot_used = sl; break; }
			}
			if (slot_used < 0) {
				u.send({{"type", message_types::announce}, {"text", "No spell slots available for Divine Smite."}, {"interrupt", true}});
			} else {
				c.spell_slots_current[slot_used]--;
				c.divine_smite_pending = true;
				c.divine_smite_slot_level = slot_used;
				int smite_dice = slot_used + 1;
				u.room.bm.broadcast_announce(c.name + " prepares Divine Smite (level " + slot_used + " slot, " + smite_dice + "d8 radiant on next hit)!", false);
			}
		}
		else if (feature == "lay_on_hands") {
			if (c.class_name != "Paladin") { u.send({{"type", message_types::announce}, {"text", "Only paladins can use Lay on Hands."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a valid creature for Lay on Hands."}, {"interrupt", true}}); return; }
			if (target.id != c.id) {
				int dist = feet_distance(c.x, c.y, target.x, target.y);
				if (dist > 5) { u.send({{"type", message_types::announce}, {"text", "Lay on Hands requires touch range."}, {"interrupt", true}}); return; }
			}

			int heal = msg.exists("amount") ? int(msg["amount"]) : 0;
			if (heal < 0) heal = 0;
			string cleanse_csv = msg.exists("cleanse_conditions") ? string(msg["cleanse_conditions"]) : "";
			string[] requested_cleanses;
			if (cleanse_csv != "") {
				string[]@ parts = cleanse_csv.split(",");
				for (uint i = 0; i < parts.length(); i++) {
					if (parts[i] != "") requested_cleanses.insert_last(parts[i]);
				}
			}

			int cleanse_cost = 0;
			int[] conditions_to_remove;
			string[] condition_names;
			for (uint i = 0; i < requested_cleanses.length(); i++) {
				string cond_name = requested_cleanses[i].lower();
				int cond_id = 0;
				if (cond_name == "poisoned") cond_id = COND_POISONED;
				else if (c.level >= 14 and cond_name == "blinded") cond_id = COND_BLINDED;
				else if (c.level >= 14 and cond_name == "charmed") cond_id = COND_CHARMED;
				else if (c.level >= 14 and cond_name == "deafened") cond_id = COND_DEAFENED;
				else if (c.level >= 14 and cond_name == "frightened") cond_id = COND_FRIGHTENED;
				else if (c.level >= 14 and cond_name == "paralyzed") cond_id = COND_PARALYZED;
				else if (c.level >= 14 and cond_name == "stunned") cond_id = COND_STUNNED;
				if (cond_id == 0 or !target.has_condition(cond_id)) continue;

				bool already_added = false;
				for (uint ci = 0; ci < conditions_to_remove.length(); ci++) {
					if (conditions_to_remove[ci] == cond_id) { already_added = true; break; }
				}
				if (already_added) continue;
				conditions_to_remove.insert_last(cond_id);
				condition_names.insert_last(CONDITION_NAMES[cond_id]);
				cleanse_cost += 5;
			}

			int total_cost = heal + cleanse_cost;
			if (total_cost <= 0) { u.send({{"type", message_types::announce}, {"text", "Choose healing or conditions to remove."}, {"interrupt", true}}); return; }
			if (total_cost > c.lay_on_hands_pool) {
				u.send({{"type", message_types::announce}, {"text", "You only have " + c.lay_on_hands_pool + " Lay on Hands points remaining."}, {"interrupt", true}});
				return;
			}

			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.lay_on_hands_pool -= total_cost;
			if (heal > 0) {
				int effective_heal = u.room.bm.combat.apply_healing(target, heal);
				u.room.bm.record_effective_healing(c.player_username, effective_heal);
			}
			for (uint ci = 0; ci < conditions_to_remove.length(); ci++) {
				target.remove_condition(conditions_to_remove[ci]);
				u.room.bm.broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", condition_names[ci]}});
			}

			string text = c.name + " uses Lay on Hands on " + target.name + ".";
			if (heal > 0) text += " Restored " + heal + " hit points.";
			if (condition_names.length() > 0) {
				text += " Removed ";
				for (uint ci = 0; ci < condition_names.length(); ci++) {
					if (ci > 0) text += ci == condition_names.length() - 1 ? " and " : ", ";
					text += condition_names[ci];
				}
				text += ".";
			}
			text += " " + c.lay_on_hands_pool + " Lay on Hands points remain.";
			u.room.bm.broadcast_announce(text, true);
		}
		else if (feature == "cunning_action") {
			if (c.class_name != "Rogue" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Cunning Action."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			string action = msg.exists("action") ? string(msg["action"]) : "dash";
			if (action == "dash") {
				c.movement_remaining += c.speed;
				u.room.bm.broadcast_announce(c.name + " uses Cunning Action: Dash! " + c.movement_remaining + " feet of movement.", false);
			} else if (action == "disengage") {
				c.took_disengage = true;
				u.room.bm.broadcast_announce(c.name + " uses Cunning Action: Disengage!", false);
			} else if (action == "hide") {
				u.room.bm.request_hide_check(u, c);
			} else {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "That is not a valid Cunning Action choice."}, {"interrupt", true}});
				return;
			}
		}
		else if (feature == "flurry_of_blows") {
			if (c.class_name != "Monk" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Flurry of Blows."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "You need 1 Focus Point for Flurry of Blows."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "No target."}, {"interrupt", true}}); return; }
			int flurry_dist = feet_distance(c.x, c.y, target.x, target.y);
			if (flurry_dist > 5) { u.send({{"type", message_types::announce}, {"text", "Target must be within 5 feet for Flurry of Blows."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			if (!u.room.bm.start_flurry_strike(c, target, 1)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "You cannot make that Flurry attack right now."}, {"interrupt", true}});
				return;
			}
			c.focus_points--;
			u.room.bm.broadcast_announce(c.name + " spends 1 Focus Point and unleashes Flurry of Blows!", true);
		}
		else if (feature == "bardic_inspiration") {
			if (c.class_name != "Bard") { u.send({{"type", message_types::announce}, {"text", "Only bards can grant Bardic Inspiration."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (u.room.bm.combat.mode == "pvp") { u.send({{"type", message_types::announce}, {"text", "Bardic Inspiration requires an ally in this simulator."}, {"interrupt", true}}); return; }
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose an ally for Bardic Inspiration."}, {"interrupt", true}}); return; }
			if (target.id == c.id) { u.send({{"type", message_types::announce}, {"text", "You cannot inspire yourself."}, {"interrupt", true}}); return; }
			if (target.is_player != c.is_player) { u.send({{"type", message_types::announce}, {"text", "Choose an ally for Bardic Inspiration."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 60) { u.send({{"type", message_types::announce}, {"text", "That ally is out of range for Bardic Inspiration."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0 or c.bardic_inspiration_grant_die <= 0) {
				u.send({{"type", message_types::announce}, {"text", "You have no Bardic Inspiration uses remaining."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			u.room.bm.clear_bardic_inspiration(target, false);
			target.bardic_inspiration_die = c.bardic_inspiration_grant_die;
			target.bardic_inspiration_source_id = c.id;
			u.room.bm.broadcast_announce(c.name + " grants Bardic Inspiration (" + u.room.bm.die_label(c.bardic_inspiration_grant_die) + ") to " + target.name + ". " + c.bardic_inspiration_uses + " use" + (c.bardic_inspiration_uses == 1 ? "" : "s") + " remain.", true);
		}
		else if (feature == "spiritual_weapon_attack") {
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (!c.spiritual_weapon_active or c.spiritual_weapon_slot_level < 2) {
				u.send({{"type", message_types::announce}, {"text", "You do not currently have a Spiritual Weapon to command."}, {"interrupt", true}});
				return;
			}
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) {
				u.send({{"type", message_types::announce}, {"text", "Choose a valid target for Spiritual Weapon."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			if (!u.room.bm.start_spiritual_weapon_attack(c, target)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "Spiritual Weapon cannot strike that target right now."}, {"interrupt", true}});
				return;
			}
			u.room.bm.broadcast_announce(c.name + " commands Spiritual Weapon to strike " + target.name + "!", true);
		}
		else if (feature == "wild_shape") {
			if (c.class_name != "Druid" or c.level < 2) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Wild Shape yet."}, {"interrupt", true}});
				return;
			}

			string form_id = msg.exists("form") ? string(msg["form"]) : "";
			if (form_id == "revert") {
				if (!c.wild_shape_active) {
					u.send({{"type", message_types::announce}, {"text", "You are not currently in Wild Shape."}, {"interrupt", true}});
					return;
				}
				if (!c.has_bonus_action) {
					u.send({{"type", message_types::announce}, {"text", "You need a bonus action to revert from Wild Shape."}, {"interrupt", true}});
					return;
				}
				c.has_bonus_action = false;
				c.used_bonus_action = true;
				string form_name = "beast form";
				monster_def@ current_form = c.wild_shape_form_id != "" ? get_monster_def(c.wild_shape_form_id) : null;
				if (@current_form != null) form_name = current_form.name;
				u.room.bm.combat.restore_wild_shape(c, 0);
				c.wild_shape_just_ended = false;
				u.room.bm.broadcast_announce(c.name + " reverts from " + form_name + " form.", true);
			} else {
				bool moon = c.subclass == "Circle of the Moon";
				if (moon) {
					if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
				} else {
					if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
				}

				monster_def@ form = get_wild_shape_form_for_combatant(c, form_id);
				if (@form == null) {
					u.send({{"type", message_types::announce}, {"text", "That Wild Shape form is not available to this druid."}, {"interrupt", true}});
					return;
				}

				if (moon) {
					c.has_bonus_action = false;
					c.used_bonus_action = true;
				} else {
					c.has_action = false;
					c.used_action = true;
					c.attacks_remaining_this_turn = 0;
				}

				if (c.wild_shape_active) {
					u.room.bm.combat.restore_wild_shape(c, 0);
					c.wild_shape_just_ended = false;
				}

				string base_name = c.name;
				apply_wild_shape_form(c, form);
				string cost_text = moon ? "bonus action" : "action";
				u.room.bm.broadcast_announce(base_name + " uses Wild Shape as a " + cost_text + " and becomes a " + form.name + "!", true);
			}
		}
		// ---- Subclass Bonus Actions ----

		else if (feature == "frenzy_attack") {
			// Berserker: bonus action melee attack while raging with Frenzy
			if (c.class_name != "Barbarian" or c.subclass != "Berserker") { u.send({{"type", message_types::announce}, {"text", "Only Berserker barbarians can use Frenzy Attack."}, {"interrupt", true}}); return; }
			if (!c.raging or !c.has_frenzy) { u.send({{"type", message_types::announce}, {"text", "You must be raging with Frenzy to use this."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "No valid target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 5) { u.send({{"type", message_types::announce}, {"text", "Target must be within 5 feet for Frenzy Attack."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Start a melee attack against the target (uses the existing flurry strike mechanism for bonus attacks)
			if (!u.room.bm.start_flurry_strike(c, target, 0)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "Cannot make that attack right now."}, {"interrupt", true}});
				return;
			}
			u.room.bm.broadcast_announce(c.name + " makes a Frenzy attack!", true);
		}

		else if (feature == "channel_sacred_weapon") {
			// Devotion Paladin: Channel Divinity - Sacred Weapon
			if (c.class_name != "Paladin" or c.subclass != "Oath of Devotion") { u.send({{"type", message_types::announce}, {"text", "Only Devotion paladins can use Sacred Weapon."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.sacred_weapon_active) { u.send({{"type", message_types::announce}, {"text", "Sacred Weapon is already active."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.sacred_weapon_active = true;
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			if (cha_mod < 1) cha_mod = 1;
			u.room.bm.broadcast_announce(c.name + " channels Sacred Weapon! +" + cha_mod + " to attack rolls for 1 minute. " + c.channel_divinity_uses + " Channel Divinity use" + (c.channel_divinity_uses == 1 ? "" : "s") + " remain.", true);
		}

		else if (feature == "channel_vow_of_enmity") {
			// Vengeance Paladin: Channel Divinity - Vow of Enmity
			if (c.class_name != "Paladin" or c.subclass != "Oath of Vengeance") { u.send({{"type", message_types::announce}, {"text", "Only Vengeance paladins can use Vow of Enmity."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target for Vow of Enmity."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 10) { u.send({{"type", message_types::announce}, {"text", "Target must be within 10 feet."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.vow_of_enmity_target = target.id;
			u.room.bm.broadcast_announce(c.name + " swears a Vow of Enmity against " + target.name + "! Advantage on attack rolls against them. " + c.channel_divinity_uses + " Channel Divinity use" + (c.channel_divinity_uses == 1 ? "" : "s") + " remain.", true);
		}

		else if (feature == "channel_preserve_life") {
			// Life Cleric: Channel Divinity - Preserve Life
			if (c.class_name != "Cleric" or c.subclass != "Life Domain") { u.send({{"type", message_types::announce}, {"text", "Only Life Domain clerics can use Preserve Life."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining (Preserve Life uses your action)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int pool = c.level * 5;
			int total_healed = 0;
			// Heal allies below half HP within 30 feet
			for (uint pi = 0; pi < u.room.bm.combat.combatants.length(); pi++) {
				combatant@ ally = u.room.bm.combat.combatants[pi];
				if (@ally == null or ally.is_dead or !ally.is_player or ally.id == c.id) continue;
				if (u.room.bm.combat.are_hostile(c, ally)) continue;
				if (ally.current_hp >= ally.max_hp / 2) continue;
				int dist = feet_distance(c.x, c.y, ally.x, ally.y);
				if (dist > 30) continue;
				int deficit = (ally.max_hp / 2) - ally.current_hp;
				int heal_amount = deficit;
				if (heal_amount > pool) heal_amount = pool;
				if (heal_amount <= 0) continue;
				int healed = u.room.bm.combat.apply_healing(ally, heal_amount);
				u.room.bm.record_effective_healing(c.player_username, healed);
				pool -= heal_amount;
				total_healed += healed;
				u.room.bm.broadcast_announce(c.name + "'s Preserve Life heals " + ally.name + " for " + healed + " HP.", false);
				if (pool <= 0) break;
			}
			u.room.bm.broadcast_announce(c.name + " channels Preserve Life! Healed " + total_healed + " total HP among allies.", true);
		}

		else if (feature == "channel_natures_wrath") {
			// Ancients Paladin: Channel Divinity - Nature's Wrath (restrain a target)
			if (c.class_name != "Paladin" or c.subclass != "Oath of the Ancients") { u.send({{"type", message_types::announce}, {"text", "Only Ancients paladins can use Nature's Wrath."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target for Nature's Wrath."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 15) { u.send({{"type", message_types::announce}, {"text", "Target must be within 15 feet."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			// Target makes STR or DEX save (their choice, we use higher)
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_CHA);
			int str_save = random(1, 20) + target.get_save_bonus(ABILITY_STR);
			int dex_save = random(1, 20) + target.get_save_bonus(ABILITY_DEX);
			int save_total = str_save > dex_save ? str_save : dex_save;
			if (save_total < save_dc) {
				target.add_condition(COND_RESTRAINED);
				u.room.bm.broadcast_announce(c.name + "'s Nature's Wrath restrains " + target.name + " in spectral vines!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Nature's Wrath fails to restrain " + target.name + ".", true);
			}
		}

		else if (feature == "trip_attack") {
			// Battle Master: Trip Attack maneuver
			if (c.class_name != "Fighter" or c.subclass != "Battle Master") { u.send({{"type", message_types::announce}, {"text", "Only Battle Masters can use Trip Attack."}, {"interrupt", true}}); return; }
			if (c.superiority_dice <= 0) { u.send({{"type", message_types::announce}, {"text", "No superiority dice remaining."}, {"interrupt", true}}); return; }
			c.trip_attack_pending = true;
			u.room.bm.broadcast_announce(c.name + " prepares Trip Attack! Next weapon hit will add 1d8 damage and attempt to knock the target prone. (" + c.superiority_dice + " superiority dice remaining)", false);
		}

		else if (feature == "precision_attack") {
			// Battle Master: Precision Attack maneuver
			if (c.class_name != "Fighter" or c.subclass != "Battle Master") { u.send({{"type", message_types::announce}, {"text", "Only Battle Masters can use Precision Attack."}, {"interrupt", true}}); return; }
			if (c.superiority_dice <= 0) { u.send({{"type", message_types::announce}, {"text", "No superiority dice remaining."}, {"interrupt", true}}); return; }
			c.precision_attack_pending = true;
			u.room.bm.broadcast_announce(c.name + " prepares Precision Attack! Next attack roll will add 1d8. (" + c.superiority_dice + " superiority dice remaining)", false);
		}

		else if (feature == "riposte") {
			// Battle Master: Riposte maneuver (readied reaction)
			if (c.class_name != "Fighter" or c.subclass != "Battle Master") { u.send({{"type", message_types::announce}, {"text", "Only Battle Masters can use Riposte."}, {"interrupt", true}}); return; }
			if (c.superiority_dice <= 0) { u.send({{"type", message_types::announce}, {"text", "No superiority dice remaining."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			c.riposte_ready = true;
			u.room.bm.broadcast_announce(c.name + " readies Riposte! If an enemy misses, " + c.name + " will counterattack with an extra 1d8 damage.", false);
		}

		else if (feature == "shadow_step") {
			// Shadow Monk: teleport 60 ft to dim/dark location, advantage on next melee
			if (c.class_name != "Monk" or c.subclass != "Way of Shadow") { u.send({{"type", message_types::announce}, {"text", "Only Shadow monks can use Shadow Step."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Shadow Step requires level 6."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target to teleport near."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 60) { u.send({{"type", message_types::announce}, {"text", "Target is too far for Shadow Step (60 ft max)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Teleport adjacent to target
			int new_x = target.x;
			int new_y = target.y + 1;
			c.x = new_x;
			c.y = new_y;
			u.room.bm.broadcast_announce(c.name + " Shadow Steps to " + target.name + "! Advantage on next melee attack.", true);
		}

		else if (feature == "hands_of_healing") {
			// Mercy Monk: Hands of Healing
			if (c.class_name != "Monk" or c.subclass != "Way of Mercy") { u.send({{"type", message_types::announce}, {"text", "Only Mercy monks can use Hands of Healing."}, {"interrupt", true}}); return; }
			if (c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Hands of Healing requires level 3."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "You need 1 Focus Point."}, {"interrupt", true}}); return; }
			combatant@ target = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a valid target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 5 and target.id != c.id) { u.send({{"type", message_types::announce}, {"text", "Target must be within 5 feet."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.focus_points--;
			int martial_die = 4;
			if (c.level >= 17) martial_die = 12;
			else if (c.level >= 11) martial_die = 10;
			else if (c.level >= 5) martial_die = 8;
			else martial_die = 6;
			int heal = random(1, martial_die) + c.get_ability_mod(ABILITY_WIS);
			if (heal < 1) heal = 1;
			int effective = u.room.bm.combat.apply_healing(target, heal);
			u.room.bm.record_effective_healing(c.player_username, effective);
			u.room.bm.broadcast_announce(c.name + " uses Hands of Healing on " + target.name + ", restoring " + effective + " HP.", true);
		}

		else if (feature == "elemental_burst") {
			// Elements Monk: Elemental Burst (AoE ki attack)
			if (c.class_name != "Monk" or c.subclass != "Way of the Four Elements") { u.send({{"type", message_types::announce}, {"text", "Only Elements monks can use Elemental Burst."}, {"interrupt", true}}); return; }
			if (c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Elemental Burst requires level 3."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.focus_points < 2) { u.send({{"type", message_types::announce}, {"text", "You need 2 Focus Points."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 20) { u.send({{"type", message_types::announce}, {"text", "Target must be within 20 feet."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.focus_points -= 2;
			int martial_die = 6;
			if (c.level >= 17) martial_die = 12;
			else if (c.level >= 11) martial_die = 10;
			else if (c.level >= 5) martial_die = 8;
			int damage = random(1, martial_die) + random(1, martial_die) + c.get_ability_mod(ABILITY_WIS);
			if (damage < 1) damage = 1;
			// DEX save for half
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int save_roll = random(1, 20) + target.get_save_bonus(ABILITY_DEX);
			if (save_roll >= save_dc) damage = damage / 2;
			u.room.bm.combat.apply_damage(target, damage, DMG_FIRE, c);
			u.room.bm.broadcast_announce(c.name + " unleashes Elemental Burst on " + target.name + " for " + damage + " elemental damage!" + (save_roll >= save_dc ? " (saved for half)" : ""), true);
		}

		else if (feature == "healing_light") {
			// Celestial Warlock: Healing Light
			if (c.class_name != "Warlock" or c.subclass != "Celestial") { u.send({{"type", message_types::announce}, {"text", "Only Celestial warlocks can use Healing Light."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.healing_light_dice <= 0) { u.send({{"type", message_types::announce}, {"text", "No Healing Light dice remaining."}, {"interrupt", true}}); return; }
			combatant@ target = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a valid target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 60 and target.id != c.id) { u.send({{"type", message_types::announce}, {"text", "Target must be within 60 feet."}, {"interrupt", true}}); return; }
			int dice_to_use = msg.exists("dice_count") ? int(msg["dice_count"]) : 1;
			int max_dice = c.get_ability_mod(ABILITY_CHA);
			if (max_dice < 1) max_dice = 1;
			if (dice_to_use > max_dice) dice_to_use = max_dice;
			if (dice_to_use > c.healing_light_dice) dice_to_use = c.healing_light_dice;
			if (dice_to_use < 1) dice_to_use = 1;
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.healing_light_dice -= dice_to_use;
			int heal = 0;
			for (int di = 0; di < dice_to_use; di++) heal += random(1, 6);
			int effective = u.room.bm.combat.apply_healing(target, heal);
			u.room.bm.record_effective_healing(c.player_username, effective);
			u.room.bm.broadcast_announce(c.name + " uses Healing Light (" + dice_to_use + "d6) on " + target.name + ", restoring " + effective + " HP. " + c.healing_light_dice + " dice remain.", true);
		}

		else if (feature == "fey_presence") {
			// Archfey Warlock: Fey Presence (charm/frighten enemies in 10ft)
			if (c.class_name != "Warlock" or c.subclass != "Archfey") { u.send({{"type", message_types::announce}, {"text", "Only Archfey warlocks can use Fey Presence."}, {"interrupt", true}}); return; }
			if (c.fey_presence_used) { u.send({{"type", message_types::announce}, {"text", "You have already used Fey Presence this battle."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.fey_presence_used = true;
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_CHA);
			int affected = 0;
			for (uint pi = 0; pi < u.room.bm.combat.combatants.length(); pi++) {
				combatant@ enemy = u.room.bm.combat.combatants[pi];
				if (@enemy == null or enemy.is_dead or enemy.id == c.id) continue;
				if (!u.room.bm.combat.are_hostile(c, enemy)) continue;
				int dist = feet_distance(c.x, c.y, enemy.x, enemy.y);
				if (dist > 10) continue;
				int save_roll = random(1, 20) + enemy.get_save_bonus(ABILITY_WIS);
				if (save_roll < save_dc) {
					enemy.add_condition(COND_CHARMED);
					affected++;
					u.room.bm.broadcast_announce(enemy.name + " is charmed by " + c.name + "'s Fey Presence!", false);
				}
			}
			u.room.bm.broadcast_announce(c.name + " unleashes Fey Presence! " + affected + " creature" + (affected == 1 ? "" : "s") + " charmed.", true);
		}

		else if (feature == "mantle_of_inspiration") {
			// Glamour Bard: Mantle of Inspiration (temp HP to allies)
			if (c.class_name != "Bard" or c.subclass != "College of Glamour") { u.send({{"type", message_types::announce}, {"text", "Only Glamour bards can use Mantle of Inspiration."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Bardic Inspiration uses remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			int temp_hp = random(1, c.bardic_inspiration_grant_die) + c.get_ability_mod(ABILITY_CHA);
			if (temp_hp < 1) temp_hp = 1;
			int allies_affected = 0;
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			int max_allies = cha_mod > 0 ? cha_mod : 1;
			for (uint pi = 0; pi < u.room.bm.combat.combatants.length(); pi++) {
				if (allies_affected >= max_allies) break;
				combatant@ ally = u.room.bm.combat.combatants[pi];
				if (@ally == null or ally.is_dead or !ally.is_player) continue;
				if (u.room.bm.combat.are_hostile(c, ally)) continue;
				int dist = feet_distance(c.x, c.y, ally.x, ally.y);
				if (dist > 60) continue;
				if (ally.temp_hp < temp_hp) ally.temp_hp = temp_hp;
				allies_affected++;
			}
			u.room.bm.broadcast_announce(c.name + " inspires with Mantle of Inspiration! " + allies_affected + " allies gain " + temp_hp + " temporary HP.", true);
		}

		else if (feature == "psychic_blades") {
			// Soulknife Rogue: Psychic Blades (bonus action attack with psychic blade)
			if (c.class_name != "Rogue" or c.subclass != "Soulknife") { u.send({{"type", message_types::announce}, {"text", "Only Soulknife rogues can use Psychic Blades."}, {"interrupt", true}}); return; }
			if (c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Psychic Blades requires level 3."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 60) { u.send({{"type", message_types::announce}, {"text", "Target must be within 60 feet."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Psychic blade bonus attack: d4 + DEX/STR
			int atk_mod = c.get_ability_mod(ABILITY_DEX);
			int str_mod = c.get_ability_mod(ABILITY_STR);
			if (str_mod > atk_mod) atk_mod = str_mod;
			int atk_bonus = atk_mod + c.proficiency;
			int atk_roll = random(1, 20);
			int total = atk_roll + atk_bonus;
			bool hit = (atk_roll == 20) or (atk_roll != 1 and total >= target.armor_class);
			if (hit) {
				int dmg = random(1, 4) + atk_mod;
				if (dmg < 1) dmg = 1;
				if (atk_roll == 20) dmg += random(1, 4); // crit
				u.room.bm.combat.apply_damage(target, dmg, DMG_PSYCHIC, c);
				u.room.bm.broadcast_roll(c.name, "Psychic Blade attack", atk_roll, atk_bonus, total, "Hit!");
				u.room.bm.broadcast_announce(c.name + "'s Psychic Blade deals " + dmg + " psychic damage to " + target.name + "!", false);
			} else {
				u.room.bm.broadcast_roll(c.name, "Psychic Blade attack", atk_roll, atk_bonus, total, "Miss!");
			}
		}

		else if (feature == "war_priest_attack") {
			// War Cleric: War Priest bonus action attack
			if (c.class_name != "Cleric" or c.subclass != "War Domain") { u.send({{"type", message_types::announce}, {"text", "Only War Domain clerics can use War Priest."}, {"interrupt", true}}); return; }
			if (c.war_priest_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No War Priest uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "No valid target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > c.main_hand_range) { u.send({{"type", message_types::announce}, {"text", "Target out of weapon range."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.war_priest_uses--;
			// Make a weapon attack
			if (!u.room.bm.start_flurry_strike(c, target, 0)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				c.war_priest_uses++;
				u.send({{"type", message_types::announce}, {"text", "Cannot make that attack right now."}, {"interrupt", true}});
				return;
			}
			u.room.bm.broadcast_announce(c.name + " invokes War Priest for a bonus weapon attack! " + c.war_priest_uses + " use" + (c.war_priest_uses == 1 ? "" : "s") + " remain.", true);
		}

		else if (feature == "warding_flare") {
			// Light Cleric: Warding Flare (reaction - impose disadvantage on attacker)
			if (c.class_name != "Cleric" or c.subclass != "Light Domain") { u.send({{"type", message_types::announce}, {"text", "Only Light Domain clerics can use Warding Flare."}, {"interrupt", true}}); return; }
			if (c.warding_flare_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Warding Flare uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			c.warding_flare_uses--;
			u.room.bm.broadcast_announce(c.name + " readies Warding Flare! The next attack against them or an ally within 30 feet has disadvantage. " + c.warding_flare_uses + " use" + (c.warding_flare_uses == 1 ? "" : "s") + " remain.", false);
		}

		else {
			u.send({{"type", message_types::announce}, {"text", "That bonus action is not available to your character."}, {"interrupt", true}});
			return;
		}
		u.room.bm.broadcast_state();
	}

	else if (msg_type == message_types::scan_direction) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_scan(u, msg);
	}
	else if (msg_type == message_types::bardic_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_bardic_response(u, msg);
	}
	else if (msg_type == message_types::lucky_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_lucky_response(u, msg);
	}
	else if (msg_type == message_types::heroic_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_heroic_response(u, msg);
	}
	else if (msg_type == message_types::action_cast) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_cast(u, msg);
		}
	}
	else if (msg_type == message_types::action_help) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_help(u, msg);
		}
	}
	else if (msg_type == message_types::action_hide) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_hide(u);
		}
	}
	else if (msg_type == message_types::action_ready) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_ready(u, msg);
		}
	}
	else if (msg_type == message_types::action_shove) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_shove(u, msg);
		}
	}
	else if (msg_type == message_types::action_grapple) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_grapple(u, msg);
		}
	}
	else if (msg_type == message_types::set_target) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_set_target(u, msg);
		}
	}

	// --- Game Invites ---

	else if (msg_type == message_types::game_invite and msg.exists("target")) {
		string target_name = string(msg["target"]);
		// Must be in a room to invite.
		if (@u.room == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "You must be in a room to invite players."}});
			return;
		}
		// Must be a friend.
		if (@u.account == null) return;
		json_object@ my_data = u.account.data;
		if (!my_data.exists("friends")) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not on your friends list."}});
			return;
		}
		json_array@ my_friends = my_data["friends"];
		bool is_friend = false;
		for (uint fi = 0; fi < my_friends.length(); fi++) {
			if (string(my_friends[fi]) == target_name) { is_friend = true; break; }
		}
		if (!is_friend) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not on your friends list."}});
			return;
		}
		// Target must be online.
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not online."}});
			return;
		}
		// Send invite to target.
		target.send({{"type", message_types::game_invite_received}, {"from", u.username}, {"room_name", u.room.name}, {"room_id", u.room.id}});
		u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Game invite sent to " + target_name + "!"}});
	}

	else if (msg_type == message_types::game_invite_response and msg.exists("accepted") and msg.exists("room_id")) {
		bool accepted = bool(msg["accepted"]);
		uint room_id = uint(msg["room_id"]);
		string from_name = msg.exists("from") ? string(msg["from"]) : "";
		if (!accepted) {
			// Notify the inviter.
			if (from_name != "") {
				user@ inviter = users.get_user_by_name(from_name);
				if (@inviter != null) {
					inviter.send({{"type", message_types::chat_message}, {"username", ""}, {"message", u.username + " declined your game invite."}});
				}
			}
			return;
		}
		// Find the room by ID.
		room@ target_room = null;
		for (uint ri = 0; ri < rooms.rooms.length(); ri++) {
			if (rooms.rooms[ri].id == room_id) {
				@target_room = rooms.rooms[ri];
				break;
			}
		}
		if (@target_room == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "That room no longer exists."}});
			return;
		}
		if (target_room.started) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "That game has already started."}});
			return;
		}
		// Join the room (bypasses password).
		u.join_room(target_room);
	}

	// ---- INVENTORY LIST ----
	else if (msg_type == message_types::inventory_list) {
		if (@u.account == null) return;
		init_item_catalog();
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		json_array items_arr;
		if (@inv != null) {
			for (uint ii = 0; ii < inv.length(); ii++) {
				json_object@ entry = inv[ii];
				if (@entry == null or !entry.exists("id")) continue;
				string item_id = string(entry["id"]);
				item_def@ item = find_item(item_id);
				if (@item == null) continue;
				json_object item_obj;
				item_obj["id"] = item.id;
				item_obj["name"] = item.name;
				item_obj["rarity"] = item.rarity;
				item_obj["slot"] = item.slot;
				item_obj["description"] = item.description;
				item_obj["stats"] = item_stat_summary(item);
				items_arr.add(item_obj);
			}
		}

		// Include equipped items info
		json_object equipped_info;
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ eq = character["equipped"];
			if (eq.exists("weapon")) equipped_info["weapon"] = eq["weapon"];
			if (eq.exists("armor")) equipped_info["armor"] = eq["armor"];
			if (eq.exists("ring")) equipped_info["ring"] = eq["ring"];
			if (eq.exists("amulet")) equipped_info["amulet"] = eq["amulet"];
		}

		u.send({
			{"type", message_types::inventory_list},
			{"items", items_arr},
			{"equipped", equipped_info}
		});
	}

	// ---- EQUIP ITEM ----
	else if (msg_type == message_types::equip_item and msg.exists("item_id") and msg.exists("slot")) {
		if (@u.account == null) return;
		init_item_catalog();
		string item_id = string(msg["item_id"]);
		string slot_name = string(msg["slot"]);

		// Validate the item exists in catalog
		item_def@ item = find_item(item_id);
		if (@item == null) {
			u.send({{"type", message_types::error}, {"text", "Unknown item."}});
			return;
		}

		// Map item slot to the JSON key used in equipped object
		string[] slot_key_map = {"weapon", "armor", "ring", "amulet"};
		if (item.slot < 0 or item.slot >= int(slot_key_map.length())) {
			u.send({{"type", message_types::error}, {"text", "Invalid item slot."}});
			return;
		}
		string expected_slot = slot_key_map[item.slot];
		if (slot_name.lower() != expected_slot and slot_name != SLOT_NAMES[item.slot]) {
			u.send({{"type", message_types::error}, {"text", "That item cannot be equipped in that slot."}});
			return;
		}

		// Validate item exists in player's inventory
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (!inventory_has_item(inv, item_id)) {
			u.send({{"type", message_types::error}, {"text", "You do not have that item."}});
			return;
		}

		// Equip the item on the character
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character == null) {
			u.send({{"type", message_types::error}, {"text", "No adventure character found."}});
			return;
		}
		json_object@ equipped = ensure_json_object_field(character, "equipped");
		equipped[expected_slot] = item_id;

		u.account.commit();
		send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
		u.send({{"type", message_types::announce}, {"text", "Equipped " + item.name + " in " + SLOT_NAMES[item.slot] + " slot."}, {"interrupt", false}});
	}

	// ---- DISCARD ITEM ----
	else if (msg_type == message_types::discard_item and msg.exists("item_id")) {
		if (@u.account == null) return;
		init_item_catalog();
		string item_id = string(msg["item_id"]);

		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (!inventory_has_item(inv, item_id)) {
			u.send({{"type", message_types::error}, {"text", "You do not have that item."}});
			return;
		}

		// If the item is currently equipped, unequip it first
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ equipped = character["equipped"];
			string[] slot_keys = {"weapon", "armor", "ring", "amulet"};
			for (uint si = 0; si < slot_keys.length(); si++) {
				if (equipped.exists(slot_keys[si]) and string(equipped[slot_keys[si]]) == item_id) {
					equipped[slot_keys[si]] = "";
				}
			}
		}

		inventory_remove_item(inv, item_id);
		u.account.commit();

		item_def@ item = find_item(item_id);
		string item_name = @item != null ? item.name : item_id;
		u.send({{"type", message_types::announce}, {"text", "Discarded " + item_name + "."}, {"interrupt", false}});
		send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
	}

	// ---- UPGRADE ITEM ----
	else if (msg_type == message_types::upgrade_item and msg.exists("item_ids")) {
		if (@u.account == null) return;
		init_item_catalog();
		ensure_account_progression(u.account);

		json_array@ ids = msg["item_ids"];
		if (@ids == null or ids.length() != 3) {
			u.send({{"type", message_types::error}, {"text", "You must select exactly 3 items to upgrade."}});
			return;
		}

		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (@inv == null) {
			u.send({{"type", message_types::error}, {"text", "No inventory found."}});
			return;
		}

		// Validate all 3 items exist in inventory and have same rarity
		string[] item_ids;
		string[] item_names;
		int common_rarity = -1;
		for (uint ii = 0; ii < ids.length(); ii++) {
			string item_id = string(ids[ii]);
			if (!inventory_has_item(inv, item_id)) {
				u.send({{"type", message_types::error}, {"text", "You do not have item: " + item_id + "."}});
				return;
			}
			item_def@ item = find_item(item_id);
			if (@item == null) {
				u.send({{"type", message_types::error}, {"text", "Unknown item: " + item_id + "."}});
				return;
			}
			if (common_rarity == -1) {
				common_rarity = item.rarity;
			} else if (item.rarity != common_rarity) {
				u.send({{"type", message_types::error}, {"text", "All 3 items must be the same rarity."}});
				return;
			}
			item_ids.insert_last(item_id);
			item_names.insert_last(item.name);
		}

		// Check rarity is upgradeable (not legendary)
		if (common_rarity >= RARITY_LEGENDARY) {
			u.send({{"type", message_types::error}, {"text", "Legendary items cannot be upgraded further."}});
			return;
		}

		// Check glory cost
		int cost = get_upgrade_glory_cost(common_rarity);
		int current_glory = get_glory(u.account);
		if (current_glory < cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough Glory. Need " + cost + " but you have " + current_glory + "."}});
			return;
		}

		// Remove 3 items from inventory
		for (uint ii = 0; ii < item_ids.length(); ii++) {
			inventory_remove_item(inv, item_ids[ii]);
		}

		// Deduct glory
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			int new_glory = get_json_int(progress, "glory", 0) - cost;
			if (new_glory < 0) new_glory = 0;
			progress["glory"] = new_glory;
		}

		// Generate random item of next rarity
		int target_rarity = common_rarity + 1;
		item_def@ result_item = generate_upgrade_result(target_rarity);
		string result_name = "Unknown";
		if (@result_item != null) {
			inventory_add_item(inv, result_item.id);
			result_name = result_item.name;
		}

		u.account.commit();

		// Send updated inventory
		// Re-build inventory list
		json_array items_arr;
		for (uint ii = 0; ii < inv.length(); ii++) {
			json_object@ entry = inv[ii];
			if (@entry == null or !entry.exists("id")) continue;
			string iid = string(entry["id"]);
			item_def@ idef = find_item(iid);
			if (@idef == null) continue;
			json_object item_obj;
			item_obj["id"] = idef.id;
			item_obj["name"] = idef.name;
			item_obj["rarity"] = idef.rarity;
			item_obj["slot"] = idef.slot;
			item_obj["description"] = idef.description;
			item_obj["stats"] = item_stat_summary(idef);
			items_arr.add(item_obj);
		}
		json_object equipped_info;
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ eq = character["equipped"];
			if (eq.exists("weapon")) equipped_info["weapon"] = eq["weapon"];
			if (eq.exists("armor")) equipped_info["armor"] = eq["armor"];
			if (eq.exists("ring")) equipped_info["ring"] = eq["ring"];
			if (eq.exists("amulet")) equipped_info["amulet"] = eq["amulet"];
		}
		u.send({
			{"type", message_types::inventory_list},
			{"items", items_arr},
			{"equipped", equipped_info}
		});

		// Send glory update
		u.send({
			{"type", message_types::glory_update},
			{"glory", get_glory(u.account)}
		});

		// Announce the result
		string rarity_name = RARITY_NAMES[target_rarity];
		u.send({{"type", message_types::announce}, {"text", "Upgrade successful! Combined " + item_names[0] + ", " + item_names[1] + ", and " + item_names[2] + " into " + result_name + " (" + rarity_name + "). Cost: " + cost + " Glory."}, {"interrupt", true}});
	}

	// ---- PRESTIGE ACTION ----
	else if (msg_type == message_types::prestige_action) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress == null) {
			u.send({{"type", message_types::error}, {"text", "No adventure progress found."}});
			return;
		}

		int current_level = get_json_int(progress, "level", 1);
		int current_rank = get_prestige_rank(u.account);

		if (current_level < 20) {
			u.send({{"type", message_types::error}, {"text", "You must be level 20 to prestige."}});
			return;
		}
		if (current_rank >= 5) {
			u.send({{"type", message_types::error}, {"text", "You have already reached maximum prestige rank."}});
			return;
		}

		if (!apply_prestige(u.account)) {
			u.send({{"type", message_types::error}, {"text", "Prestige failed."}});
			return;
		}

		int new_rank = get_prestige_rank(u.account);
		string title = get_prestige_title(new_rank);
		int glory_reward = 100 * new_rank;
		add_glory(u.account, glory_reward);

		u.account.commit();

		u.send({{"type", message_types::announce}, {"text", "You have prestiged! You are now " + title + " (Rank " + new_rank + "). Level reset to 1. +" + glory_reward + " Glory!"}, {"interrupt", true}});
		send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
		send_adventure_progress_to_user(u, "Prestige complete! Rank " + new_rank + ": " + title + ".");
		u.send({
			{"type", message_types::glory_update},
			{"glory", get_glory(u.account)},
			{"gained", glory_reward}
		});
	}

	// ---- TRADING SYSTEM ----

	else if (msg_type == message_types::trade_request and msg.exists("target")) {
		string target_name = msg["target"];
		if (target_name == u.username) {
			u.send({{"type", message_types::error}, {"text", "You cannot trade with yourself."}});
			return;
		}
		// Check if already in a trade
		if (@find_trade_for_user(u) != null) {
			u.send({{"type", message_types::error}, {"text", "You are already in a trade."}});
			return;
		}
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.send({{"type", message_types::error}, {"text", target_name + " is not online."}});
			return;
		}
		if (target.is_bot) {
			u.send({{"type", message_types::error}, {"text", "You cannot trade with an AI player."}});
			return;
		}
		if (@find_trade_for_user(target) != null) {
			u.send({{"type", message_types::error}, {"text", target_name + " is already in a trade."}});
			return;
		}
		// Send trade request to the target
		target.send({{"type", message_types::trade_request}, {"from", u.username}});
		u.send({{"type", message_types::announce}, {"text", "Trade request sent to " + target_name + "."}, {"interrupt", false}});
		println("[TRADE] " + u.username + " sent trade request to " + target_name);
	}

	else if (msg_type == message_types::trade_accept and msg.exists("from")) {
		string from_name = msg["from"];
		user@ requester = users.get_user_by_name(from_name);
		if (@requester == null) {
			u.send({{"type", message_types::error}, {"text", from_name + " is no longer online."}});
			return;
		}
		if (@find_trade_for_user(u) != null or @find_trade_for_user(requester) != null) {
			u.send({{"type", message_types::error}, {"text", "Trade session conflict. Please try again."}});
			return;
		}
		// Create the trade session
		trade_session t;
		@t.player_a = requester;
		@t.player_b = u;
		active_trades.insert_last(t);
		// Send initial trade_update to both
		requester.send(build_trade_update(t, true));
		u.send(build_trade_update(t, false));
		println("[TRADE] Trade session started between " + requester.username + " and " + u.username);
	}

	else if (msg_type == message_types::trade_offer and msg.exists("items")) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) {
			u.send({{"type", message_types::error}, {"text", "You are not in an active trade."}});
			return;
		}
		// Reset confirmations when offer changes
		t.confirmed_a = false;
		t.confirmed_b = false;

		bool is_a = (@t.player_a is u);
		json_array@ items = msg["items"];
		string[] new_offer;
		if (@items != null and @u.account != null) {
			init_item_catalog();
			json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
			for (uint i = 0; i < items.length(); i++) {
				string item_id = string(items[i]);
				// Validate item exists in player's inventory
				if (inventory_has_item(inv, item_id)) {
					new_offer.insert_last(item_id);
				}
			}
		}

		if (is_a) t.offer_a = new_offer;
		else t.offer_b = new_offer;

		// Send updated trade state to both
		t.player_a.send(build_trade_update(t, true));
		t.player_b.send(build_trade_update(t, false));
	}

	else if (msg_type == message_types::trade_confirm) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) {
			u.send({{"type", message_types::error}, {"text", "You are not in an active trade."}});
			return;
		}
		bool is_a = (@t.player_a is u);
		if (is_a) t.confirmed_a = true;
		else t.confirmed_b = true;

		// Send updated state to both
		t.player_a.send(build_trade_update(t, true));
		t.player_b.send(build_trade_update(t, false));

		// If both confirmed, execute the trade
		if (t.confirmed_a and t.confirmed_b) {
			complete_trade(t);
		}
	}

	else if (msg_type == message_types::trade_cancel) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) return;
		cancel_trade(t, u.username + " cancelled the trade.");
	}

	// ---- WEEKLY CHALLENGES ----

	else if (msg_type == message_types::weekly_challenges) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ challenge_msg = build_weekly_challenges_message(u.account);
		if (@challenge_msg != null) u.send(challenge_msg);
	}

	// ---- GLORY SHOP ----

	else if (msg_type == message_types::glory_shop_list) {
		if (@u.account == null) return;
		init_glory_shop();
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		json_array@ owned_titles = @progress != null ? ensure_json_array_field(progress, "owned_titles") : null;

		json_array shop_arr;
		for (uint si = 0; si < GLORY_SHOP.length(); si++) {
			shop_entry@ e = GLORY_SHOP[si];
			json_object entry;
			entry["id"] = e.id;
			entry["name"] = e.name;
			entry["description"] = e.description;
			entry["type"] = e.type;
			entry["glory_cost"] = e.glory_cost;
			bool owned = false;
			if (e.type == SHOP_TYPE_TITLE and @owned_titles != null) {
				for (uint ti = 0; ti < owned_titles.length(); ti++) {
					if (string(owned_titles[ti]) == e.id) { owned = true; break; }
				}
			} else if (e.type == SHOP_TYPE_ITEM and @inv != null) {
				owned = inventory_has_item(inv, e.item_id);
			}
			entry["owned"] = owned;
			if (e.item_id != "") entry["item_id"] = e.item_id;
			shop_arr.add(entry);
		}
		u.send({{"type", message_types::glory_shop_list}, {"items", shop_arr}, {"glory", get_glory(u.account)}});
	}

	else if (msg_type == message_types::glory_shop_buy and msg.exists("shop_id")) {
		if (@u.account == null) return;
		init_glory_shop();
		ensure_account_progression(u.account);
		string shop_id = string(msg["shop_id"]);
		shop_entry@ e = find_shop_entry(shop_id);
		if (@e == null) {
			u.send({{"type", message_types::error}, {"text", "Item not found in the Glory Shop."}});
			return;
		}

		json_object@ progress = get_adventure_progress(u.account);
		int current_glory = get_glory(u.account);
		if (current_glory < e.glory_cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough Glory Points. You have " + current_glory + " but need " + e.glory_cost + "."}});
			return;
		}

		if (e.type == SHOP_TYPE_TITLE) {
			json_array@ owned_titles = ensure_json_array_field(progress, "owned_titles");
			// Check if already owned
			for (uint ti = 0; ti < owned_titles.length(); ti++) {
				if (string(owned_titles[ti]) == e.id) {
					u.send({{"type", message_types::error}, {"text", "You already own this title."}});
					return;
				}
			}
			owned_titles.add(e.id);
			progress["glory"] = current_glory - e.glory_cost;
			u.account.commit();
			u.send({{"type", message_types::glory_update}, {"glory", get_glory(u.account)}, {"gained", 0}});
			u.send({{"type", message_types::announce}, {"text", "You purchased the title: " + e.name + "!"}, {"interrupt", true}});
		} else if (e.type == SHOP_TYPE_ITEM) {
			json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
			if (inventory_has_item(inv, e.item_id)) {
				u.send({{"type", message_types::error}, {"text", "You already own this item."}});
				return;
			}
			if (int(inv.length()) >= MAX_INVENTORY) {
				u.send({{"type", message_types::error}, {"text", "Your inventory is full! Discard an item first."}});
				return;
			}
			inventory_add_item(inv, e.item_id);
			progress["glory"] = current_glory - e.glory_cost;
			u.account.commit();
			u.send({{"type", message_types::glory_update}, {"glory", get_glory(u.account)}, {"gained", 0}});
			u.send({{"type", message_types::announce}, {"text", "You purchased: " + e.name + "!"}, {"interrupt", true}});
		}
	}

	// ---- SET ACTIVE TITLE ----

	else if (msg_type == message_types::set_active_title and msg.exists("title_id")) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress == null) return;
		string title_id = string(msg["title_id"]);

		if (title_id == "") {
			// Clear active title
			progress["active_title"] = "";
			u.account.commit();
			u.send({{"type", message_types::announce}, {"text", "Title removed."}, {"interrupt", false}});
			return;
		}

		json_array@ owned_titles = ensure_json_array_field(progress, "owned_titles");
		bool found = false;
		for (uint ti = 0; ti < owned_titles.length(); ti++) {
			if (string(owned_titles[ti]) == title_id) { found = true; break; }
		}
		if (!found) {
			u.send({{"type", message_types::error}, {"text", "You do not own this title."}});
			return;
		}

		init_glory_shop();
		shop_entry@ se = find_shop_entry(title_id);
		progress["active_title"] = title_id;
		u.account.commit();
		string title_name = @se != null ? se.name : title_id;
		u.send({{"type", message_types::announce}, {"text", "Active title set to: " + title_name + "."}, {"interrupt", false}});
	}

	// ---- DAILY DUNGEON INFO ----

	else if (msg_type == message_types::daily_dungeon_info) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		string dungeon_id = get_daily_dungeon_id();
		string difficulty = get_daily_difficulty();
		string dungeon_name = get_dungeon_display_name(dungeon_id);
		bool claimable = can_claim_daily(u.account);
		u.send({{"type", message_types::daily_dungeon_info}, {"dungeon_id", dungeon_id}, {"dungeon_name", dungeon_name}, {"difficulty", difficulty}, {"can_claim", claimable}});
	}

	// ---- LEADERBOARDS ----

	else if (msg_type == message_types::leaderboard_request and msg.exists("category")) {
		string category = string(msg["category"]);
		json_array leaderboard;
		string my_username = u.username;
		int my_value = 0;
		int my_rank = -1;

		// Collect all player scores
		json_object@[] all_scores;
		string[] all_usernames;
		string[] all_prestige_titles;
		int[] all_values;

		for (uint ai = 0; ai < accounts.length(); ai++) {
			account@ acct = accounts[ai];
			if (@acct == null or @acct.data == null) continue;
			if (!acct.data.exists(ACCOUNT_KEY_ADVENTURE_PROGRESS)) continue;
			json_object@ prog = acct.data[ACCOUNT_KEY_ADVENTURE_PROGRESS];
			if (@prog == null) continue;

			int value = 0;
			if (category == "glory") value = get_json_int(prog, "glory", 0);
			else if (category == "endless") value = get_json_int(prog, "endless_best_wave", 0);
			else if (category == "kills") value = get_json_int(prog, "monster_kills", 0);
			else if (category == "prestige") value = get_json_int(prog, "prestige_rank", 0);
			else if (category == "dungeons") {
				int total = 0;
				if (prog.exists("dungeons_completed")) {
					json_object@ dc = prog["dungeons_completed"];
					if (@dc != null) {
						string[]@ keys = dc.get_keys();
						for (uint ki = 0; ki < keys.length(); ki++) {
							total += get_json_int(dc, keys[ki], 0);
						}
					}
				}
				value = total;
			}

			if (value <= 0) continue;

			all_usernames.insert_last(acct.username);
			all_values.insert_last(value);
			string pt = get_prestige_title(get_json_int(prog, "prestige_rank", 0));
			all_prestige_titles.insert_last(pt);
		}

		// Sort descending by value (simple insertion sort for small sets)
		for (int si = 1; si < int(all_values.length()); si++) {
			int key_val = all_values[si];
			string key_name = all_usernames[si];
			string key_pt = all_prestige_titles[si];
			int sj = si - 1;
			while (sj >= 0 and all_values[sj] < key_val) {
				all_values[sj + 1] = all_values[sj];
				all_usernames[sj + 1] = all_usernames[sj];
				all_prestige_titles[sj + 1] = all_prestige_titles[sj];
				sj--;
			}
			all_values[sj + 1] = key_val;
			all_usernames[sj + 1] = key_name;
			all_prestige_titles[sj + 1] = key_pt;
		}

		// Build top 10 and find requesting player
		int limit = int(all_values.length());
		if (limit > 10) limit = 10;
		for (int ri = 0; ri < limit; ri++) {
			json_object entry;
			entry["rank"] = ri + 1;
			entry["username"] = all_usernames[ri];
			entry["value"] = all_values[ri];
			entry["prestige_title"] = all_prestige_titles[ri];
			leaderboard.add(entry);
		}

		// Find requesting player's rank
		for (int ri = 0; ri < int(all_values.length()); ri++) {
			if (all_usernames[ri] == my_username) {
				my_rank = ri + 1;
				my_value = all_values[ri];
				break;
			}
		}

		u.send({{"type", message_types::leaderboard_data}, {"category", category}, {"entries", leaderboard}, {"my_rank", my_rank}, {"my_value", my_value}});
	}

	// ---- Consumable Shop ----
	else if (msg_type == message_types::shop_list) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		init_consumable_catalog();
		json_array@ cons_inv = ensure_json_array_field(u.account.data, "adventure_consumables");

		json_array shop_arr;
		for (uint si = 0; si < CONSUMABLE_CATALOG.length(); si++) {
			consumable_def@ cd = CONSUMABLE_CATALOG[si];
			json_object entry;
			entry["id"] = cd.id;
			entry["name"] = cd.name;
			entry["type"] = cd.type;
			entry["type_name"] = CONS_TYPE_NAMES[cd.type];
			entry["action_type"] = cd.action_type;
			entry["description"] = cd.description;
			entry["gold_cost"] = cd.gold_cost;
			entry["owned"] = get_consumable_quantity(cons_inv, cd.id);
			entry["max_stack"] = MAX_CONSUMABLE_STACK;
			shop_arr.add(entry);
		}
		u.send({{"type", message_types::shop_list}, {"items", shop_arr}, {"gold", get_gold(u.account)}});
	}

	else if (msg_type == message_types::shop_buy and msg.exists("consumable_id")) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		init_consumable_catalog();

		string buy_id = string(msg["consumable_id"]);
		consumable_def@ cd = find_consumable(buy_id);
		if (@cd == null) {
			u.send({{"type", message_types::error}, {"text", "Unknown item."}});
			return;
		}

		int current_gold = get_gold(u.account);
		if (current_gold < cd.gold_cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough gold. Need " + cd.gold_cost + ", have " + current_gold + "."}});
			return;
		}

		json_array@ cons_inv = ensure_json_array_field(u.account.data, "adventure_consumables");
		int current_qty = get_consumable_quantity(cons_inv, buy_id);
		if (current_qty >= MAX_CONSUMABLE_STACK) {
			u.send({{"type", message_types::error}, {"text", "Already at max stack (" + MAX_CONSUMABLE_STACK + ") for " + cd.name + "."}});
			return;
		}

		if (!spend_gold(u.account, cd.gold_cost)) {
			u.send({{"type", message_types::error}, {"text", "Failed to deduct gold."}});
			return;
		}

		if (!add_consumable_to_inventory(cons_inv, buy_id)) {
			// Refund gold if inventory add fails
			add_gold(u.account, cd.gold_cost);
			u.send({{"type", message_types::error}, {"text", "Inventory full."}});
			return;
		}

		u.account.commit();
		int new_qty = get_consumable_quantity(cons_inv, buy_id);
		u.send({{"type", message_types::announce}, {"text", "Purchased " + cd.name + "! You now have " + new_qty + ". Gold remaining: " + get_gold(u.account) + "."}, {"interrupt", false}});
		// Send updated shop list
		json_array updated_shop;
		for (uint si = 0; si < CONSUMABLE_CATALOG.length(); si++) {
			consumable_def@ ucd = CONSUMABLE_CATALOG[si];
			json_object entry;
			entry["id"] = ucd.id;
			entry["name"] = ucd.name;
			entry["type"] = ucd.type;
			entry["type_name"] = CONS_TYPE_NAMES[ucd.type];
			entry["action_type"] = ucd.action_type;
			entry["description"] = ucd.description;
			entry["gold_cost"] = ucd.gold_cost;
			entry["owned"] = get_consumable_quantity(cons_inv, ucd.id);
			entry["max_stack"] = MAX_CONSUMABLE_STACK;
			updated_shop.add(entry);
		}
		u.send({{"type", message_types::shop_list}, {"items", updated_shop}, {"gold", get_gold(u.account)}});
	}

	else if (msg_type == message_types::use_consumable) {
		if (@u.room == null or @u.room.bm == null) {
			u.send({{"type", message_types::error}, {"text", "Not in a battle."}});
			return;
		}
		u.room.bm.handle_use_consumable(u, msg);
	}

	// ---- GUILD SYSTEM HANDLERS ----

	else if (msg_type == message_types::create_guild and msg.exists("name")) {
		string guild_name = string(msg["name"]).trim_whitespace();
		// Validate name length.
		if (guild_name.length() < 3 or guild_name.length() > 30) {
			u.speak("Guild name must be between 3 and 30 characters.");
			return;
		}
		// Validate characters (letters, numbers, spaces only).
		string allowed = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 ";
		for (uint i = 0; i < guild_name.length(); i++) {
			if (allowed.find(guild_name[i]) < 0) {
				u.speak("Guild name can only contain letters, numbers, and spaces.");
				return;
			}
		}
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild. Leave your current guild first.");
			return;
		}
		// Check if guild name is taken.
		if (@find_guild(guild_name) != null) {
			u.speak("A guild with that name already exists.");
			return;
		}
		// Create the guild.
		guild@ g = guild(guild_name, u.username);
		guilds.insert_last(g);
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = guild_name;
			progress["guild_leader"] = u.username;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " created guild '" + guild_name + "'");
		// Send guild info back to confirm.
		json_object info;
		info["type"] = message_types::guild_info;
		info["name"] = g.name;
		info["leader"] = g.leader;
		json_array member_arr;
		for (uint i = 0; i < g.members.length(); i++) member_arr.add(g.members[i]);
		info["members"] = member_arr;
		info["member_count"] = int(g.members.length());
		info["total_glory"] = get_glory(u.account);
		u.send(info);
		u.speak("Guild '" + guild_name + "' created! You are the guild leader.");
	}

	else if (msg_type == message_types::join_guild and msg.exists("name")) {
		string guild_name = string(msg["name"]);
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild.");
			return;
		}
		guild@ g = find_guild(guild_name);
		if (@g == null) {
			u.speak("No guild found with that name.");
			return;
		}
		if (g.members.length() >= 20) {
			u.speak("That guild is full.");
			return;
		}
		if (!g.add_member(u.username)) {
			u.speak("Could not join the guild.");
			return;
		}
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = g.name;
			progress["guild_leader"] = g.leader;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " joined guild '" + g.name + "'");
		u.speak("You joined the guild '" + g.name + "'!");
		// Notify online guild members.
		for (uint i = 0; i < g.members.length(); i++) {
			if (g.members[i] == u.username) continue;
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) {
				member.send({{"type", message_types::announce}, {"text", u.username + " has joined the guild!"}, {"interrupt", false}});
			}
		}
	}

	else if (msg_type == message_types::leave_guild) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		string old_guild_name = g.name;
		bool was_leader = (g.leader == u.username);
		g.remove_member(u.username);
		// Clear from account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = "";
			progress["guild_leader"] = "";
		}
		u.account.commit();
		if (g.members.length() == 0) {
			// Disband guild.
			int idx = guilds.find_by_ref(g);
			if (idx >= 0) guilds.remove_at(idx);
			println("[GUILDS] Guild '" + old_guild_name + "' disbanded (last member left).");
		} else if (was_leader) {
			// Transfer leadership to first remaining member.
			g.leader = g.members[0];
			// Update the new leader's account.
			account@ new_leader_acct = get_account(g.leader);
			if (@new_leader_acct != null) {
				ensure_account_progression(new_leader_acct);
				json_object@ lp = get_adventure_progress(new_leader_acct);
				if (@lp != null) lp["guild_leader"] = g.leader;
				new_leader_acct.commit();
			}
			// Notify online guild members.
			for (uint i = 0; i < g.members.length(); i++) {
				user@ member = users.get_user_by_name(g.members[i]);
				if (@member != null) {
					member.send({{"type", message_types::announce}, {"text", u.username + " has left the guild. " + g.leader + " is the new leader."}, {"interrupt", false}});
				}
			}
			println("[GUILDS] " + u.username + " left guild '" + old_guild_name + "'. New leader: " + g.leader);
		} else {
			// Notify online guild members.
			for (uint i = 0; i < g.members.length(); i++) {
				user@ member = users.get_user_by_name(g.members[i]);
				if (@member != null) {
					member.send({{"type", message_types::announce}, {"text", u.username + " has left the guild."}, {"interrupt", false}});
				}
			}
			println("[GUILDS] " + u.username + " left guild '" + old_guild_name + "'.");
		}
		u.send({{"type", message_types::leave_guild}});
		u.speak("You left the guild '" + old_guild_name + "'.");
	}

	else if (msg_type == message_types::guild_chat and msg.exists("message")) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		string chat_text = string(msg["message"]);
		// Broadcast to all online guild members.
		json_object@ chat_msg = {{"type", message_types::guild_chat}, {"from", u.username}, {"message", chat_text}};
		for (uint i = 0; i < g.members.length(); i++) {
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) member.send(chat_msg);
		}
	}

	else if (msg_type == message_types::guild_info) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.send({{"type", message_types::guild_info}});
			return;
		}
		json_object info;
		info["type"] = message_types::guild_info;
		info["name"] = g.name;
		info["leader"] = g.leader;
		json_array member_arr;
		int total_glory = 0;
		for (uint i = 0; i < g.members.length(); i++) {
			member_arr.add(g.members[i]);
			account@ macct = get_account(g.members[i]);
			if (@macct != null) total_glory += get_glory(macct);
		}
		info["members"] = member_arr;
		info["member_count"] = int(g.members.length());
		info["total_glory"] = total_glory;
		u.send(info);
	}

	else if (msg_type == message_types::guild_invite and msg.exists("target")) {
		string target_name = string(msg["target"]);
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.speak(target_name + " is not online.");
			return;
		}
		if (@find_guild_for_user(target_name) != null) {
			u.speak(target_name + " is already in a guild.");
			return;
		}
		// Send invite to target.
		target.send({{"type", message_types::guild_invite_received}, {"from", u.username}, {"guild_name", g.name}});
		u.speak("Guild invite sent to " + target_name + ".");
		println("[GUILDS] " + u.username + " invited " + target_name + " to guild '" + g.name + "'");
	}

	else if (msg_type == message_types::guild_invite_response and msg.exists("accepted") and msg.exists("guild_name")) {
		bool accepted = bool(msg["accepted"]);
		string guild_name = string(msg["guild_name"]);
		if (!accepted) {
			u.speak("Guild invite declined.");
			return;
		}
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild.");
			return;
		}
		guild@ g = find_guild(guild_name);
		if (@g == null) {
			u.speak("That guild no longer exists.");
			return;
		}
		if (g.members.length() >= 20) {
			u.speak("That guild is full.");
			return;
		}
		if (!g.add_member(u.username)) {
			u.speak("Could not join the guild.");
			return;
		}
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = g.name;
			progress["guild_leader"] = g.leader;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " accepted guild invite to '" + g.name + "'");
		u.speak("You joined the guild '" + g.name + "'!");
		// Notify online guild members.
		for (uint i = 0; i < g.members.length(); i++) {
			if (g.members[i] == u.username) continue;
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) {
				member.send({{"type", message_types::announce}, {"text", u.username + " has joined the guild!"}, {"interrupt", false}});
			}
		}
	}

	// ---- Player Stats ----
	else if (msg_type == message_types::player_stats) {
		if (@u.account != null) {
			ensure_account_progression(u.account);
			json_object@ stats_msg = build_player_stats_message(u.account);
			if (@stats_msg != null) u.send(stats_msg);
		}
	}

	else if (msg_type == message_types::inspect_player and msg.exists("target")) {
		string target_name = string(msg["target"]);
		if (target_name == "") {
			u.speak("No player specified.");
			return;
		}
		account@ target_acct = get_account(target_name);
		if (@target_acct == null) {
			u.speak("Player not found.");
			return;
		}
		ensure_account_progression(target_acct);
		json_object@ inspect_msg = build_player_inspect_message(target_acct, target_name);
		if (@inspect_msg != null) {
			u.send(inspect_msg);
		} else {
			u.speak("Could not retrieve stats for that player.");
		}
	}
}
