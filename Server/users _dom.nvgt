		else if (feature == "giants_might") {
			// Rune Knight Fighter: become Large, +1d6 damage, advantage on STR checks
			if (c.class_name != "Fighter" or c.subclass != "Rune Knight") { u.send({{"type", message_types::announce}, {"text", "Only Rune Knights can use Giant's Might."}, {"interrupt", true}}); return; }
			if (c.giants_might_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Giant's Might uses remaining."}, {"interrupt", true}}); return; }
