//          private messaging, friend system, reporting, kick.

// ---- TRADE SESSION ----

class trade_session {
	user@ player_a;
	user@ player_b;
	string[] offer_a;
	string[] offer_b;
	bool confirmed_a = false;
	bool confirmed_b = false;
}

trade_session@[] active_trades;

trade_session@ find_trade_for_user(user@ u) {
	if (@u == null) return null;
	for (uint i = 0; i < active_trades.length(); i++) {
		if (@active_trades[i].player_a is u or @active_trades[i].player_b is u)
			return active_trades[i];
	}
	return null;
}

void cancel_trade(trade_session@ t, string reason) {
	if (@t == null) return;
	if (@t.player_a != null) t.player_a.send({{"type", message_types::trade_cancel}, {"reason", reason}});
	if (@t.player_b != null) t.player_b.send({{"type", message_types::trade_cancel}, {"reason", reason}});
	int idx = active_trades.find_by_ref(t);
	if (idx >= 0) active_trades.remove_at(idx);
}

void complete_trade(trade_session@ t) {
	if (@t == null or @t.player_a == null or @t.player_b == null) return;
	if (@t.player_a.account == null or @t.player_b.account == null) return;

	init_item_catalog();
	json_array@ inv_a = ensure_json_array_field(t.player_a.account.data, "adventure_inventory");
	json_array@ inv_b = ensure_json_array_field(t.player_b.account.data, "adventure_inventory");
	if (@inv_a == null or @inv_b == null) {
		cancel_trade(t, "Inventory error.");
		return;
	}

	// Re-validate that all offered items still exist in each player's inventory
	for (uint i = 0; i < t.offer_a.length(); i++) {
		if (!inventory_has_item(inv_a, t.offer_a[i])) {
			cancel_trade(t, t.player_a.username + " no longer has all offered items.");
			return;
		}
	}
	for (uint i = 0; i < t.offer_b.length(); i++) {
		if (!inventory_has_item(inv_b, t.offer_b[i])) {
			cancel_trade(t, t.player_b.username + " no longer has all offered items.");
			return;
		}
	}

	// Remove offered items from each player's inventory
	for (uint i = 0; i < t.offer_a.length(); i++) {
		inventory_remove_item(inv_a, t.offer_a[i]);
	}
	for (uint i = 0; i < t.offer_b.length(); i++) {
		inventory_remove_item(inv_b, t.offer_b[i]);
	}

	// Add received items to each player's inventory
	json_array received_a;  // Items player A receives (from B's offer)
	for (uint i = 0; i < t.offer_b.length(); i++) {
		inventory_add_item(inv_a, t.offer_b[i]);
		item_def@ item = find_item(t.offer_b[i]);
		json_object entry;
		entry["id"] = t.offer_b[i];
		entry["name"] = @item != null ? item.name : t.offer_b[i];
		received_a.add(entry);
	}
	json_array received_b;  // Items player B receives (from A's offer)
	for (uint i = 0; i < t.offer_a.length(); i++) {
		inventory_add_item(inv_b, t.offer_a[i]);
		item_def@ item = find_item(t.offer_a[i]);
		json_object entry;
		entry["id"] = t.offer_a[i];
		entry["name"] = @item != null ? item.name : t.offer_a[i];
		received_b.add(entry);
	}

	t.player_a.account.commit();
	t.player_b.account.commit();

	try { t.player_a.send({{"type", message_types::trade_complete}, {"items", received_a}}); } catch {}
	try { t.player_b.send({{"type", message_types::trade_complete}, {"items", received_b}}); } catch {}

	int idx = active_trades.find_by_ref(t);
	if (idx >= 0) active_trades.remove_at(idx);
	println("[TRADE] Trade completed between " + t.player_a.username + " and " + t.player_b.username);
}

// Helper: build a trade_update message for one side of the trade.
json_object@ build_trade_update(trade_session@ t, bool for_player_a) {
	if (@t == null) return null;
	init_item_catalog();
	json_object msg;
	msg["type"] = message_types::trade_update;
	msg["partner"] = for_player_a ? t.player_b.username : t.player_a.username;

	// My offer
	string[]@ my_offer = for_player_a ? t.offer_a : t.offer_b;
	json_array my_arr;
	for (uint i = 0; i < my_offer.length(); i++) {
		item_def@ item = find_item(my_offer[i]);
		json_object entry;
		entry["id"] = my_offer[i];
		entry["name"] = @item != null ? item.name : my_offer[i];
		my_arr.add(entry);
	}
	msg["my_offer"] = my_arr;

	// Their offer
	string[]@ their_offer = for_player_a ? t.offer_b : t.offer_a;
	json_array their_arr;
	for (uint i = 0; i < their_offer.length(); i++) {
		item_def@ item = find_item(their_offer[i]);
		json_object entry;
		entry["id"] = their_offer[i];
		entry["name"] = @item != null ? item.name : their_offer[i];
		their_arr.add(entry);
	}
	msg["their_offer"] = their_arr;

	msg["my_confirmed"] = for_player_a ? t.confirmed_a : t.confirmed_b;
	msg["their_confirmed"] = for_player_a ? t.confirmed_b : t.confirmed_a;
	return msg;
}

// Helper: Remove the first occurrence of a string value from a json_array.
// Returns a new json_array with the element removed.
json_array@ json_array_remove_string(json_array@ arr, string value)
{
	json_array result;
	if (@arr == null) return result;
	bool removed = false;
	for (uint i = 0; i < arr.length(); i++) {
		if (!removed and string(arr[i]) == value) {
			removed = true;
			continue; // Skip this one.
		}
		result.add(arr[i]);
	}
	return result;
}

// ---- GUILD SYSTEM ----

class guild {
	string name;
	string leader;
	string[] members;

	guild(string guild_name, string leader_name) {
		name = guild_name;
		leader = leader_name;
		members.insert_last(leader_name);
	}

	bool is_member(string username) {
		for (uint i = 0; i < members.length(); i++) {
			if (members[i] == username) return true;
		}
		return false;
	}

	bool add_member(string username) {
		if (members.length() >= 20) return false;
		if (is_member(username)) return false;
		members.insert_last(username);
		return true;
	}

	bool remove_member(string username) {
		for (uint i = 0; i < members.length(); i++) {
			if (members[i] == username) {
				members.remove_at(i);
				return true;
			}
		}
		return false;
	}
}

guild@[] guilds;
dictionary guild_user_cache; // username -> guild@ for O(1) lookup

void guild_cache_add(string username, guild@ g) { guild_user_cache.set(username, @g); }
void guild_cache_remove(string username) { guild_user_cache.delete(username); }
void guild_cache_rebuild() {
	string[]@ keys = guild_user_cache.get_keys();
	for (uint i = 0; i < keys.length(); i++) guild_user_cache.delete(keys[i]);
	for (uint i = 0; i < guilds.length(); i++) {
		for (uint j = 0; j < guilds[i].members.length(); j++) {
			guild_user_cache.set(guilds[i].members[j], @guilds[i]);
		}
	}
}

guild@ find_guild(string name) {
	for (uint i = 0; i < guilds.length(); i++) {
		if (guilds[i].name.lower() == name.lower()) return guilds[i];
	}
	return null;
}

guild@ find_guild_for_user(string username) {
	if (guild_user_cache.exists(username)) return cast<guild@>(guild_user_cache[username]);
	return null;
}

// Rebuild in-memory guild objects from all persisted account data.
// Called once after load_accounts() on server startup.
void rebuild_guilds_from_accounts() {
	guilds.resize(0);
	for (uint i = 0; i < accounts.length(); i++) {
		account@ acct = accounts[i];
		if (@acct == null or @acct.data == null) continue;
		ensure_account_progression(acct);
		json_object@ progress = ensure_json_object_field(acct.data, ACCOUNT_KEY_ADVENTURE_PROGRESS);
		if (@progress == null) continue;
		string gname = progress.exists("guild_name") ? string(progress["guild_name"]) : "";
		if (gname == "") continue;
		guild@ g = find_guild(gname);
		if (@g == null) {
			// First member seen for this guild becomes leader initially.
			// The actual leader is stored per-account; we correct below.
			@g = guild(gname, acct.username);
			guilds.insert_last(g);
		} else {
			g.add_member(acct.username);
		}
	}
	// Second pass: correct leaders from persisted guild_leader field.
	for (uint i = 0; i < accounts.length(); i++) {
		account@ acct = accounts[i];
		if (@acct == null or @acct.data == null) continue;
		json_object@ progress = ensure_json_object_field(acct.data, ACCOUNT_KEY_ADVENTURE_PROGRESS);
		if (@progress == null) continue;
		if (progress.exists("guild_leader") and string(progress["guild_leader"]) != "") {
			guild@ g = find_guild(string(progress["guild_name"]));
			if (@g != null) g.leader = string(progress["guild_leader"]);
		}
	}
	println("[GUILDS] Rebuilt " + guilds.length() + " guild(s) from account data.");
	guild_cache_rebuild();
}

monster_def@ get_wild_shape_form_for_combatant(combatant@ c, string form_id)
{
	if (@c == null or c.class_name != "Druid" or c.level < 2) return null;
	bool moon = c.subclass == "Circle of the Moon";
	bool allow_swim = c.level >= 4;
	bool allow_fly = c.level >= 8;

	if (form_id == "wolf" or form_id == "giant_wolf_spider") return get_monster_def(form_id);
	if (form_id == "giant_bat" and allow_fly) return get_monster_def(form_id);
	if (form_id == "crocodile" and allow_swim) return get_monster_def(form_id);
	if (form_id == "dire_wolf" and (moon or c.level >= 8)) return get_monster_def(form_id);
	if (form_id == "giant_constrictor_snake" and moon and c.level >= 6) return get_monster_def(form_id);
	return null;
}

void apply_wild_shape_form(combatant@ c, monster_def@ def)
{
	if (@c == null or @def == null) return;

	c.wild_shape_saved_name = c.name;
	c.wild_shape_saved_size = c.size;
	c.wild_shape_saved_max_hp = c.max_hp;
	c.wild_shape_saved_current_hp = c.current_hp;
	c.wild_shape_saved_temp_hp = c.temp_hp;
	c.wild_shape_saved_armor_class = c.armor_class;
	c.wild_shape_saved_speed = c.speed;
	c.wild_shape_saved_strength = c.ability_scores[ABILITY_STR];
	c.wild_shape_saved_dexterity = c.ability_scores[ABILITY_DEX];
	c.wild_shape_saved_constitution = c.ability_scores[ABILITY_CON];
	c.wild_shape_saved_intelligence = c.ability_scores[ABILITY_INT];
	c.wild_shape_saved_wisdom = c.ability_scores[ABILITY_WIS];
	c.wild_shape_saved_charisma = c.ability_scores[ABILITY_CHA];
	c.wild_shape_saved_main_hand = c.main_hand;
	c.wild_shape_saved_main_hand_damage_dice = c.main_hand_damage_dice;
	c.wild_shape_saved_main_hand_damage_count = c.main_hand_damage_count;
	c.wild_shape_saved_main_hand_damage_type = c.main_hand_damage_type;
	c.wild_shape_saved_main_hand_range = c.main_hand_range;
	c.wild_shape_saved_main_hand_finesse = c.main_hand_finesse;
	c.wild_shape_saved_main_hand_is_ranged = c.main_hand_is_ranged;
	c.wild_shape_saved_monster_attack_bonus = c.monster_attack_bonus;
	c.wild_shape_saved_monster_attack_damage_mod = c.monster_attack_damage_mod;
	c.wild_shape_saved_monster_attack2_name = c.monster_attack2_name;
	c.wild_shape_saved_monster_attack2_bonus = c.monster_attack2_bonus;
	c.wild_shape_saved_monster_attack2_dice = c.monster_attack2_dice;
	c.wild_shape_saved_monster_attack2_count = c.monster_attack2_count;
	c.wild_shape_saved_monster_attack2_mod = c.monster_attack2_mod;
	c.wild_shape_saved_monster_attack2_type = c.monster_attack2_type;
	c.wild_shape_saved_monster_attack2_range = c.monster_attack2_range;
	c.wild_shape_saved_extra_attacks = c.extra_attacks;

	c.wild_shape_active = true;
	c.wild_shape_just_ended = false;
	c.wild_shape_form_id = def.id;
	c.name = c.wild_shape_saved_name + " (" + def.name + ")";
	c.size = def.size;
	c.max_hp = def.hp;
	c.current_hp = def.hp;
	c.temp_hp = 0;
	c.armor_class = def.ac;
	c.speed = def.speed;
	c.ability_scores[ABILITY_STR] = def.str;
	c.ability_scores[ABILITY_DEX] = def.dex;
	c.ability_scores[ABILITY_CON] = def.con;
	c.main_hand = def.attack_name;
	c.main_hand_damage_dice = def.damage_dice;
	c.main_hand_damage_count = def.damage_count;
	c.main_hand_damage_type = def.damage_type;
	c.main_hand_range = def.attack_range;
	c.main_hand_finesse = false;
	c.main_hand_is_ranged = false;
	c.monster_attack_bonus = def.attack_bonus;
	c.monster_attack_damage_mod = def.damage_mod;
	c.monster_attack2_name = def.attack2_name;
	c.monster_attack2_bonus = def.attack2_bonus;
	c.monster_attack2_dice = def.attack2_dice;
	c.monster_attack2_count = def.attack2_count;
	c.monster_attack2_mod = def.attack2_mod;
	c.monster_attack2_type = def.attack2_type;
	c.monster_attack2_range = def.attack2_range;
	c.extra_attacks = (def.has_multiattack and def.multiattack_count > 1) ? def.multiattack_count - 1 : 0;
	if (c.movement_remaining > c.speed) c.movement_remaining = c.speed;
}

void send_character_profile_to_user(user@ u, string profile)
{
	if (@u == null or @u.account == null) return;
	json_object@ msg = build_character_data_message(u.account, profile);
	if (@msg != null) u.send(msg);
}

void send_adventure_progress_to_user(user@ u, string summary = "", int gained = 0, int kill_xp = 0, int healing_xp = 0, int match_xp = 0, int achievement_xp = 0, int levels_gained = 0)
{
	if (@u == null or @u.account == null) return;
	u.send(build_progression_update_message(u.account, gained, kill_xp, healing_xp, match_xp, achievement_xp, levels_gained, summary));
}

int get_daily_bonus_xp(int streak) {
	if (streak <= 0) streak = 1;
	if (streak >= 7) return 200;
	int[] xp_table = {50, 75, 100, 125, 150, 175, 200};
	return xp_table[streak - 1];
}

void process_daily_bonus(user@ u)
{
	if (@u == null or @u.account == null) return;
	json_object@ data = u.account.data;
	uint64 now = ticks();
	uint64 last_login = data.exists("last_login_timestamp") ? uint64(int(data["last_login_timestamp"])) : 0;
	int streak = data.exists("login_streak") ? int(data["login_streak"]) : 0;
	uint64 elapsed = (last_login > 0 and now > last_login) ? now - last_login : 0;
	uint64 ms_24h = 86400000;
	uint64 ms_48h = 172800000;
	if (last_login > 0 and elapsed < ms_24h) {
		data["last_login_timestamp"] = int(now);
		u.account.commit(); // Persist timestamp immediately to prevent double-claim
		return;
	}
	if (last_login > 0 and elapsed < ms_48h) {
		streak++;
	} else {
		streak = 1;
	}
	if (streak > 7) streak = 1;
	int bonus_xp = get_daily_bonus_xp(streak);
	data["last_login_timestamp"] = int(now);
	data["login_streak"] = streak;
	u.account.commit(); // Persist immediately to prevent double-claim on rapid re-login
	int levels_gained = 0;
	if (account_has_character_profile(u.account, GAME_TYPE_ADVENTURE)) {
		apply_adventure_xp(u.account, bonus_xp, levels_gained);
	}
	u.send({{"type", message_types::daily_bonus}, {"streak", streak}, {"xp", bonus_xp}});
	println("[DAILY] " + u.username + " day " + streak + " streak, +" + bonus_xp + " XP");
}

class user_manager
{
	user@[] user_list;       // Every connected user.
	dictionary user_dictionary; // Fast lookup by id / name / peer.
	int id = 0;              // Auto-incrementing user id for this session.

	// Create a new in-memory user tied to a persistent account.
	user@ create_user(account@ a, uint peer_id)
	{
		user new_user(a);
		this.id++;
		new_user.id = this.id;
		new_user.username = a.username;
		new_user.peer_id = peer_id;
		this.user_list.insert_last(new_user);
		// Dictionary allows O(1) lookup by id, name, or peer_id.
		this.user_dictionary.set("i/" + this.id, @new_user);
		this.user_dictionary.set("n/" + a.username, @new_user);
		this.user_dictionary.set("p/" + peer_id, @new_user);
		println("[USERS] User created: " + a.username + " (id=" + this.id + ", peer=" + peer_id + ")");
		return new_user;
	}

	// Fully remove a user  cleans up room and dictionary entries.
	bool remove_user(user@ u)
	{
		if (@u == null) {
			println("[USERS] WARNING: remove_user called with null user.");
			return false;
		}
		println("[USERS] Removing user: " + u.username + " (peer=" + u.peer_id + ")");

		// Record last-seen timestamp on their account for friends.
		if (@u.account != null) {
			u.account.data["last_seen"] = calendar().format(DATE_TIME_FORMAT_RFC822);
			u.account.data["last_seen_timestamp"] = ticks();
		}

		// Clean up active trades.
		trade_session@ t = find_trade_for_user(u);
		if (@t != null) cancel_trade(t, u.username + " disconnected.");

		// Clean up room membership.
		if (@u.room != null) {
			try { u.leave_room(u.room); } catch { println("[USERS] Exception removing player from room."); }
		}

		int list_index = user_list.find_by_ref(u);
		if (list_index > -1) user_list.remove_at(list_index);
		user_dictionary.delete("i/" + u.id);
		user_dictionary.delete("n/" + u.username);
		user_dictionary.delete("p/" + u.peer_id);
		return true;
	}

	user@ get_user_by_name(string username)
	{
		if (!user_dictionary.exists("n/" + username)) return null;
		return cast<user@>(user_dictionary["n/" + username]);
	}

	user@ get_user_by_peer(uint peer_id)
	{
		if (!user_dictionary.exists("p/" + peer_id)) return null;
		return cast<user@>(user_dictionary["p/" + peer_id]);
	}

	bool send(json_object@ message, uint channel = 0)
	{
		if (@message == null) return false;
		return net.send(0, message.stringify(), 0);
	}

	var@ opImplConv()
	{
		json_array output;
		for (uint i = 0; i < user_list.length(); i++) output.add(user_list[i]);
		return output;
	}

	uint get_total_users() const property { return user_list.length(); }
}

class user
{
	bool disconnected = false;         // True if player disconnected (awaiting reconnect).
	bool is_bot = false;               // True if this is an AI-controlled player.
	string[] saved_messages;
	uint64 last_friend_request_time = 0; // Rate limiting for friend requests

	int id;
	string status = "online";   // "online", "in_room", "in_game"
	string username;
	uint peer_id;

	private weakref<room> _room;
	private weakref<account> _account;

	room@ get_room() property { return @_room; }
	void set_room(room@ r) property { @_room = r; }
	account@ get_account() property { return @_account; }

	user(account@ a)
	{
		@_account = a;
	}

	room@ new_room(string name, string password, string game_type = "")
	{
		if (@room != null) {
			this.pop_text("You are already in a room!");
			return null;
		}
		room@ r = rooms.create_room(this, name, password, game_type);
		if (@r == null) this.pop_text("Failed to create room.");
		return r;
	}
	void send_to_room(json_object@ message, uint channel = 0)
	{
		if (@room == null or @message == null) return;
		for (uint i = 0; i < this.room.players.length(); i++) {
			try { this.room.players[i].send(message, channel); }
			catch { println("[USER] Exception sending to room member " + i); }
		}
	}
	bool join_room(room@ r)
	{
		if (@r == null) {
			this.pop_text("That room does not exist.");
			return false;
		}
		if (@room != null) {
			this.pop_text("You are already in a room!");
			return false;
		}
		if (rooms.rooms.find_by_ref(@r) == -1) {
			this.speak("This room has been closed.");
			return false;
		}

		r.players.insert_last(this);
		@room = r;
		this.status = "in_room";
		println("[ROOM] " + this.username + " joined room '" + r.name + "' (players=" + r.players.length() + ")");
		// Tell everyone in the room.
		this.send_to_room({{
			"type", message_types::chat_message},
			{"username", ""},
			{"message", this.username + " has joined the room!"},
			{"join", "join"}
		});

		// Tell the joining client whether they are the host or a guest.
		if (this.room.players.size() > 1)
			this.send({{"type", message_types::join_room}, {"username", this.username}, {"player", "player"}, {"game_type", this.room.game_type}});
		else
			this.send({{"type", message_types::join_room}, {"username", this.username}, {"host", "host"}, {"game_type", this.room.game_type}});

		// Send updated player list to everyone in the room.
		send_room_player_list();
		return true;
	}

	bool leave_room(room@ r)
	{
		if (@r == null or @room == null) return false;

		int list_index = r.players.find_by_ref(this);
		if (list_index < 0) {
			@room = null;
			return false;
		}

		println("[ROOM] " + this.username + " leaving room '" + r.name + "' (was index " + list_index + ")");

		if (r.players.size() == 1 or list_index == 0) {
			// Last player or host leaving - close the room for everyone.
			// Send close to all players so their menus exit.
			for (uint ci = 0; ci < r.players.length(); ci++) {
				try {
					r.players[ci].send({{"type", message_types::leave_room}, {"close", "close"}});
					r.players[ci].send({{"type", message_types::room_closed}, {"reason", this.username + " closed the room."}});
					if (int(ci) != list_index) {
						r.players[ci].status = "online";
						@r.players[ci].room = null;
					}
				} catch {}
			}
			r.players.resize(0);
			r.close_room();
		} else {
			// Non-host leaving  notify and remove.
			this.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", this.username + " has left the room."}});
			r.players.remove_at(list_index);
			// Send updated player list to remaining players.
			if (r.players.length() > 0) {
				try { r.players[0].send_room_player_list(); } catch {}
			}
		}

		r.on_player_leave(this);
		this.status = "online";
		@room = null;
		return true;
	}

	// Broadcasts the current list of usernames in the room to all room members.
	void send_room_player_list()
	{
		if (@room == null) return;
		json_array names;
		json_array bot_flags;
		for (uint i = 0; i < this.room.players.length(); i++) {
			names.add(this.room.players[i].username);
			bot_flags.add(this.room.players[i].is_bot);
		}
		// The first player in the list is always the host.
		string host_name = (this.room.players.length() > 0) ? this.room.players[0].username : "";
		json_object@ msg = {{"type", message_types::room_players}, {"players", names}, {"host", host_name}, {"bots", bot_flags}, {"game_type", this.room.game_type}};
		for (uint i = 0; i < this.room.players.length(); i++) {
			try { this.room.players[i].send(msg); }
			catch { println("[ROOM] Exception sending player list to " + i); }
		}
	}

	void on_login()
	{
		this.speak("Main menu, Welcome. Use page up and page down to adjust the volume.  Select an option.");

		if (@this.account != null) {
			json_object@ data = this.account.data;
			ensure_account_progression(this.account);
			if (data.exists("pending_friend_requests")) {
				json_array@ pending = data["pending_friend_requests"];
				if (pending.length() > 0) {
					this.send({{"type", message_types::announce}, {"text", "You have " + pending.length() + " pending friend request" + (pending.length() == 1 ? "" : "s") + "!"}, {"interrupt", false}});
				}
			}
			process_daily_bonus(this);
			send_character_profile_to_user(this, GAME_TYPE_SANDBOX);
			send_character_profile_to_user(this, GAME_TYPE_ADVENTURE);
			send_character_list_to_user(this, GAME_TYPE_ADVENTURE);
			send_character_list_to_user(this, GAME_TYPE_SANDBOX);
			send_adventure_progress_to_user(this);
			// Send daily dungeon info on login
			string daily_id = get_daily_dungeon_id();
			string daily_diff = get_daily_difficulty();
			string daily_name = get_dungeon_display_name(daily_id);
			bool daily_claimable = can_claim_daily(this.account);
			this.send({{"type", message_types::daily_dungeon_info}, {"dungeon_id", daily_id}, {"dungeon_name", daily_name}, {"difficulty", daily_diff}, {"can_claim", daily_claimable}});
			// Send guild info on login if player is in a guild.
			json_object@ gp = get_adventure_progress(this.account);
			string login_guild_name = (@gp != null and gp.exists("guild_name")) ? string(gp["guild_name"]) : "";
			if (login_guild_name != "") {
				guild@ login_guild = find_guild(login_guild_name);
				if (@login_guild != null) {
					json_object guild_login_info;
					guild_login_info["type"] = message_types::guild_info;
					guild_login_info["name"] = login_guild.name;
					guild_login_info["leader"] = login_guild.leader;
					json_array login_members;
					int login_glory = 0;
					for (uint gi = 0; gi < login_guild.members.length(); gi++) {
						login_members.add(login_guild.members[gi]);
						user@ gu = users.get_user_by_name(login_guild.members[gi]);
						if (@gu != null and @gu.account != null) login_glory += get_glory(gu.account);
					}
					guild_login_info["members"] = login_members;
					guild_login_info["member_count"] = int(login_guild.members.length());
					guild_login_info["total_glory"] = login_glory;
					this.send(guild_login_info);
				}
			}
			// Notify online friends that this player is now online
			if (data.exists("friends")) {
				json_array@ friends = data["friends"];
				for (uint fi = 0; fi < friends.length(); fi++) {
					string friend_name = string(friends[fi]);
					user@ friend_user = users.get_user_by_name(friend_name);
					if (@friend_user != null) {
						friend_user.send({{"type", message_types::friend_online}, {"username", this.username}});
					}
				}
			}
			this.account.commit();
		}
	}

	var@ opImplConv()
	{
		return json_object({{"username", this.username}});
	}
	bool send(json_object@ message, int channel = 0)
	{
		if (@message == null or disconnected) return false;
		if (is_bot) return true; // Bots don't have network peers; silently succeed.
		return svr.send(peer_id, message, channel);
	}

	void speak(string text)
	{
		json_object@ message = {{"type", message_types::chat_message}, {"username", ""}, {"message", text}};
		this.send(message);
	}

	void speak_else(string text)
	{
		if (@room == null) return;
		json_object@ message = {{"type", message_types::chat_message}, {"username", ""}, {"message", text}};
		int list_index = this.room.players.find_by_ref(this);
		for (int i = 0; i < this.room.players.length(); i++) {
			if (i != list_index) {
				try { this.room.players[i].send(message); } catch {}
			}
		}
	}

	void speak_all(string msg)
	{
		this.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", msg}});
	}

	void send_else(json_object@ message)
	{
		if (@room == null or @message == null) return;
		int list_index = this.room.players.find_by_ref(this);
		for (int i = 0; i < this.room.players.length(); i++) {
			if (i != list_index) {
				try { this.room.players[i].send(message); } catch {}
			}
		}
	}

	bool pop_text(string text, uint timeout = 0)
	{
		if (is_bot) return true;
		return svr.send_text_popout(peer_id, text, timeout);
	}
}

// handle_user_message  Dispatches authenticated user messages.
// This is the main router for all non-game-specific messages.

void handle_user_message(user@ u, json_object@ msg)
{
	// Safety: null checks.
	if (@u == null or @msg == null or !msg.exists("type")) return;

	string msg_type = msg["type"];

	if (msg_type == message_types::check_online) {
		u.send({{"type", message_types::check_online}, {"users", users}});
	}

	else if (msg_type == message_types::new_room and msg.exists("name") and msg.exists("password")) {
		string game_type = msg.exists("game_type") ? string(msg["game_type"]) : "";
		u.new_room(msg["name"], msg["password"], game_type);
	}

	else if (msg_type == message_types::list_rooms) {
		u.send({{"type", message_types::list_rooms}, {"rooms", rooms}});
	}

	else if (msg_type == message_types::chat_message and msg.exists("message")) {
		if (@u.room != null) {
			// In a room: broadcast to room.
			u.send_to_room({{"type", message_types::chat_message}, {"username", u.username}, {"message", msg["message"]}});
		} else {
			// Not in a room: broadcast to all players in the main menu (not in any room).
			json_object@ chat_msg = {{"type", message_types::chat_message}, {"username", u.username}, {"message", msg["message"]}};
			for (uint mm = 0; mm < users.user_list.length(); mm++) {
				try {
					if (@users.user_list[mm].room == null) {
						users.user_list[mm].send(chat_msg);
					}
				} catch {}
			}
		}
	}

	else if (msg_type == message_types::join_room and msg.exists("room")) {
		int room_index = int(msg["room"]);
		if (room_index < 0 or room_index >= rooms.rooms.length()) {
			u.speak("That room no longer exists.");
		} else {
			room@ target_room = rooms.rooms[room_index];
			// If the room is password-locked, require password.
			if (target_room.is_private) {
				if (msg.exists("password") and string(msg["password"]) == target_room.password) {
					u.join_room(target_room);
				} else {
					// Tell client a password is required.
					u.send({{"type", message_types::password_required}, {"room", room_index}});
				}
			} else {
				u.join_room(target_room);
			}
		}
	}

	else if (msg_type == message_types::password_submit and msg.exists("room") and msg.exists("password")) {
		int room_index = int(msg["room"]);
		if (room_index < 0 or room_index >= rooms.rooms.length()) {
			u.speak("That room no longer exists.");
		} else {
			room@ target_room = rooms.rooms[room_index];
			if (string(msg["password"]) == target_room.password) {
				u.join_room(target_room);
			} else {
				u.speak("Incorrect password.");
			}
		}
	}

	else if (msg_type == message_types::leave_room) {
		room@ temp_room = u.get_room();
		if (@temp_room != null) {
			if (msg.exists("leave")) {
				u.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", u.username + " has left the room."}});
			}
			u.leave_room(temp_room);
		}
	}

	else if (msg_type == message_types::leave_game) {
		// Player forfeited mid-battle. Kill their combatant so the battle can end.
		if (@u.room != null and @u.room.bm != null and u.room.started) {
			battle@ b = u.room.bm.combat;
			if (@b != null) {
				for (uint ci = 0; ci < b.combatants.length(); ci++) {
					if (b.combatants[ci].is_player and b.combatants[ci].player_username == u.username) {
						b.combatants[ci].current_hp = 0;
						b.combatants[ci].is_dead = true;
						u.room.bm.broadcast_announce(u.username + " has forfeited the battle.", true);
						u.room.bm.broadcast_state();
						break;
					}
				}
			}
		}
	}

	else if (msg_type == message_types::kick_player and msg.exists("target")) {
		string target_name = msg["target"];
		if (@u.room == null) {
			u.speak("You are not in a room.");
			return;
		}
		// Only the host (first player) can kick.
		if (u.room.players.length() == 0 or u.room.players[0].username != u.username) {
			u.speak("Only the host can kick players.");
			return;
		}
		// Find the target in the room.
		user@ target = null;
		for (uint i = 0; i < u.room.players.length(); i++) {
			if (u.room.players[i].username == target_name) {
				@target = u.room.players[i];
				break;
			}
		}
		if (@target == null) {
			u.speak(target_name + " is not in this room.");
			return;
		}
		if (target.username == u.username) {
			u.speak("You cannot kick yourself.");
			return;
		}
		println("[ROOM] Host " + u.username + " kicked " + target_name + " from room '" + u.room.name + "'");
		// Notify the kicked player.
		target.send({{"type", message_types::announce}, {"text", "You have been kicked from the room by the host."}, {"interrupt", true}});
		target.send({{"type", message_types::leave_room}, {"close", "close"}});
		// Remove from room.
		room@ r = u.room;
		int idx = r.players.find_by_ref(target);
		if (idx >= 0) {
			r.players.remove_at(idx);
			@target.room = null;
			target.status = "online";
		}
		// Notify remaining players.
		u.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " has been kicked from the room."}});
		u.send_room_player_list();
	}

	else if (msg_type == message_types::private_message and msg.exists("target") and msg.exists("message")) {
		string target_name = msg["target"];
		string pm_text = msg["message"];
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.speak(target_name + " is not online.");
			return;
		}
		println("[PM] " + u.username + " -> " + target_name + ": " + pm_text);
		string time_str = calendar().format(DATE_TIME_FORMAT_RFC822);
		u.saved_messages.insert_last("[" + time_str + "] To " + target_name + ": " + pm_text);
		target.saved_messages.insert_last("[" + time_str + "] From " + u.username + ": " + pm_text);
		// Deliver to target.
		target.send({{"type", message_types::private_message}, {"from", u.username}, {"message", pm_text}});
		// Confirm to sender.
		u.send({{"type", message_types::private_message}, {"from", "You"}, {"to", target_name}, {"message", pm_text}});
	}

	else if (msg_type == message_types::report_player and msg.exists("target") and msg.exists("reason")) {
		string target_name = msg["target"];
		string reason = msg["reason"];
		println("[REPORT] " + u.username + " reported " + target_name + ": " + reason);

		// Save report to the TARGET's account data (persists across sessions).
		account@ target_acct = get_account(target_name);
		if (@target_acct != null) {
			json_object@ data = target_acct.data;
			// Ensure reported_messages array exists.
			json_array@ reports;
			if (data.exists("reported_messages")) {
				@reports = data["reported_messages"];
			} else {
				json_array new_reports;
				data.set("reported_messages", new_reports);
				@reports = data["reported_messages"];
			}
			// Build the report entry.
			string entry = "Reported by " + u.username + " on " + calendar().format(DATE_TIME_FORMAT_RFC822) + ": " + reason;
			reports.add(entry);
			target_acct.commit();
			println("[REPORT] Saved report to " + target_name + "'s account. Total reports: " + reports.length());
		}
		u.send({{"type", message_types::report_confirm}, {"target", target_name}});
	}

	else if (msg_type == message_types::friend_request and msg.exists("target")) {
		string target_name = msg["target"];

		if (target_name == u.username) {
			u.speak("You cannot add yourself as a friend.");
			return;
		}

		// Rate limit: max 1 friend request per 5 seconds
		uint64 now = ticks();
		if (now - u.last_friend_request_time < 5000) {
			u.speak("Please wait a moment before sending another friend request.");
			return;
		}
		u.last_friend_request_time = now;

		// Get both accounts.
		account@ my_acct = u.account;
		account@ target_acct = get_account(target_name);
		if (@target_acct == null) {
			u.speak("No account found for " + target_name + ".");
			return;
		}

		// Check if already friends.
		json_object@ my_data = my_acct.data;
		if (!my_data.exists("friends")) my_data.set("friends", json_array());
		json_array@ my_friends = my_data["friends"];
		for (uint i = 0; i < my_friends.length(); i++) {
			if (string(my_friends[i]) == target_name) {
				u.speak(target_name + " is already your friend.");
				return;
			}
		}

		// Add to target's pending requests.
		json_object@ target_data = target_acct.data;
		if (!target_data.exists("pending_friend_requests")) target_data.set("pending_friend_requests", json_array());
		json_array@ pending = target_data["pending_friend_requests"];

		// Check for duplicates.
		for (uint i = 0; i < pending.length(); i++) {
			if (string(pending[i]) == u.username) {
				u.speak("You have already sent a friend request to " + target_name + ".");
				return;
			}
		}

		pending.add(u.username);
		target_acct.commit();
		println("[FRIENDS] " + u.username + " sent friend request to " + target_name);

		u.speak("Friend request sent to " + target_name + "!");

		// If target is online, notify them.
		user@ target_user = users.get_user_by_name(target_name);
		if (@target_user != null) {
			target_user.send({{"type", message_types::friend_request_received}, {"from", u.username}});
		}
	}

	else if (msg_type == message_types::friend_accept and msg.exists("target")) {
		string requester_name = msg["target"];
		account@ my_acct = u.account;
		account@ requester_acct = get_account(requester_name);

		if (@my_acct == null or @requester_acct == null) {
			u.speak("Could not find that account.");
			return;
		}

		// Remove from pending.
		json_object@ my_data = my_acct.data;
		if (my_data.exists("pending_friend_requests")) {
			json_array@ pending = my_data["pending_friend_requests"];
			my_data.set("pending_friend_requests", json_array_remove_string(pending, requester_name));
		}

		// Add each other to friends lists.
		if (!my_data.exists("friends")) my_data.set("friends", json_array());
		json_array@ my_friends = my_data["friends"];
		my_friends.add(requester_name);

		json_object@ req_data = requester_acct.data;
		if (!req_data.exists("friends")) req_data.set("friends", json_array());
		json_array@ req_friends = req_data["friends"];
		req_friends.add(u.username);

		my_acct.commit();
		requester_acct.commit();
		println("[FRIENDS] " + u.username + " accepted friend request from " + requester_name);

		u.speak("You and " + requester_name + " are now friends!");

		// Notify the requester if online.
		user@ requester_user = users.get_user_by_name(requester_name);
		if (@requester_user != null) {
			requester_user.send({{"type", message_types::announce}, {"text", u.username + " accepted your friend request!"}, {"interrupt", false}});
		}
	}

	else if (msg_type == message_types::friend_decline and msg.exists("target")) {
		string requester_name = msg["target"];
		account@ my_acct = u.account;
		if (@my_acct == null) return;

		json_object@ my_data = my_acct.data;
		if (my_data.exists("pending_friend_requests")) {
			json_array@ pending = my_data["pending_friend_requests"];
			my_data.set("pending_friend_requests", json_array_remove_string(pending, requester_name));
		}
		my_acct.commit();
		u.speak("Friend request from " + requester_name + " declined.");
		println("[FRIENDS] " + u.username + " declined friend request from " + requester_name);
	}

	else if (msg_type == message_types::friend_remove and msg.exists("target")) {
		string friend_name = msg["target"];
		account@ my_acct = u.account;
		account@ friend_acct = get_account(friend_name);

		if (@my_acct != null) {
			json_object@ my_data = my_acct.data;
			if (my_data.exists("friends")) {
				json_array@ my_friends = my_data["friends"];
				my_data.set("friends", json_array_remove_string(my_friends, friend_name));
			}
			my_acct.commit();
		}

		if (@friend_acct != null) {
			json_object@ fdata = friend_acct.data;
			if (fdata.exists("friends")) {
				json_array@ f_friends = fdata["friends"];
				fdata.set("friends", json_array_remove_string(f_friends, u.username));
			}
			friend_acct.commit();
		}

		u.speak(friend_name + " has been removed from your friends list.");
		println("[FRIENDS] " + u.username + " removed friend " + friend_name);
	}

	else if (msg_type == message_types::friend_list) {
		account@ my_acct = u.account;
		if (@my_acct == null) return;

		json_object@ my_data = my_acct.data;
		if (!my_data.exists("friends")) my_data.set("friends", json_array());
		json_array@ my_friends = my_data["friends"];

		// Build a detailed list with online status.
		json_array friend_details;
		for (uint i = 0; i < my_friends.length(); i++) {
			string fname = my_friends[i];
			user@ online_friend = users.get_user_by_name(fname);
			json_object entry;
			entry["username"] = fname;

			if (@online_friend != null) {
				entry["online"] = true;
				if (@online_friend.room != null) {
					entry["status"] = "in a room";
				} else {
					entry["status"] = "in main menu";
				}
			} else {
				entry["online"] = false;
				// Get last seen from their account.
				account@ facct = get_account(fname);
				if (@facct != null and facct.data.exists("last_seen_timestamp")) {
					uint64 last_ts = uint64(facct.data["last_seen_timestamp"]);
					uint64 now_ts = ticks();
					uint64 diff_ms = (now_ts > last_ts) ? (now_ts - last_ts) : 0;
					int diff_min = int(diff_ms / 60000);
					int diff_hr = diff_min / 60;
					int diff_day = diff_hr / 24;

					if (diff_day > 0) entry["last_seen"] = "" + diff_day + " day" + (diff_day == 1 ? "" : "s") + " ago";
					else if (diff_hr > 0) entry["last_seen"] = "" + diff_hr + " hour" + (diff_hr == 1 ? "" : "s") + " ago";
					else if (diff_min > 0) entry["last_seen"] = "" + diff_min + " minute" + (diff_min == 1 ? "" : "s") + " ago";
					else entry["last_seen"] = "just now";
				} else {
					entry["last_seen"] = "unknown";
				}
			}
			friend_details.add(entry);
		}
		u.send({{"type", message_types::friend_list}, {"friends", friend_details}});
	}

	else if (msg_type == message_types::pending_requests) {
		account@ my_acct = u.account;
		if (@my_acct == null) return;

		json_object@ my_data = my_acct.data;
		if (!my_data.exists("pending_friend_requests")) my_data.set("pending_friend_requests", json_array());
		json_array@ pending = my_data["pending_friend_requests"];
		u.send({{"type", message_types::pending_requests}, {"requests", pending}});
	}

	else if (msg_type == message_types::room_players) {
		u.send_room_player_list();
	}

	// --- AI Bot Management ---

	else if (msg_type == message_types::add_bot) {
		if (@u.room == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "You must be in a room to add an AI player."}});
			return;
		}
		// Only the host (first player) can add bots.
		if (u.room.players.length() == 0 or @u.room.players[0] != @u) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Only the host can add AI players."}});
			return;
		}
		if (u.room.started) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Cannot add bots after the game has started."}});
			return;
		}
		// Limit to reasonable number of total players.
		if (u.room.players.length() >= 4) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Room is full. Maximum 4 players."}});
			return;
		}
		// Generate unique silly bot name.
		string bot_name = generate_bot_name();
		// Ensure no duplicate names in the room.
		bool dupe = true;
		while (dupe) {
			dupe = false;
			for (uint bi = 0; bi < u.room.players.length(); bi++) {
				if (u.room.players[bi].username == bot_name) { dupe = true; bot_name = generate_bot_name(); break; }
			}
		}
		user@ bot = create_bot_user(bot_name);
		@bot.room = u.room;
		u.room.players.insert_last(bot);
		// Notify room.
		u.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", bot_name + " (AI) has joined the room!"}});
		u.send_room_player_list();
	}

	else if (msg_type == message_types::remove_bot and msg.exists("bot_name")) {
		if (@u.room == null) return;
		if (u.room.players.length() == 0 or @u.room.players[0] != @u) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Only the host can remove AI players."}});
			return;
		}
		string bot_name = string(msg["bot_name"]);
		for (uint bi = 0; bi < u.room.players.length(); bi++) {
			if (u.room.players[bi].is_bot and u.room.players[bi].username == bot_name) {
				u.room.players.remove_at(bi);
				u.send_to_room({{"type", message_types::chat_message}, {"username", ""}, {"message", bot_name + " (AI) has been removed from the room."}});
				u.send_room_player_list();
				break;
			}
		}
	}

	else if (msg_type == message_types::start_game) {
		if (@u.room == null) {
			u.send({{"type", message_types::error}, {"text", "You are not in a room."}});
			return;
		}
		if (u.room.players.length() == 0) {
			u.send({{"type", message_types::error}, {"text", "No players in the room."}});
			return;
		}
		if (u.room.started) {
			u.send({{"type", message_types::error}, {"text", "A game is already in progress."}});
			return;
		}
		// Only host can start (first player in room)
		if (u.room.players[0].username != u.username) {
			u.send({{"type", message_types::announce}, {"text", "Only the host can start the game."}, {"interrupt", true}});
			return;
		}
		// Set started flag early to prevent concurrent start messages
		u.room.started = true;
		string room_game_type = normalize_game_type(u.room.game_type);
		string required_profile = room_game_type;
		string[] missing_players;
		for (uint i = 0; i < u.room.players.length(); i++) {
			user@ participant = u.room.players[i];
			if (@participant == null or participant.is_bot or @participant.account == null) continue;
			ensure_account_progression(participant.account);
			if (!account_has_character_profile(participant.account, required_profile)) {
				missing_players.insert_last(participant.username);
				participant.send({{"type", message_types::announce}, {"text", "You need a " + display_game_type(required_profile) + " character before this lobby can start."}, {"interrupt", true}});
			}
		}
		if (missing_players.length() > 0) {
			u.room.started = false; // Reset if validation failed
			string missing_text = "";
			for (uint i = 0; i < missing_players.length(); i++) {
				if (i > 0) missing_text += i == missing_players.length() - 1 ? " and " : ", ";
				missing_text += missing_players[i];
			}
			u.send({{"type", message_types::announce}, {"text", "Cannot start the " + display_game_type(room_game_type) + " lobby yet. Missing characters: " + missing_text + "."}, {"interrupt", true}});
			return;
		}
		string mode = msg.exists("mode") ? string(msg["mode"]) : "pvp";
		string scenario = msg.exists("scenario") ? string(msg["scenario"]) : "";
		string difficulty = msg.exists("difficulty") ? string(msg["difficulty"]) : "normal";
		// Send start_game to all players — client will enter combat loop
		for (uint i = 0; i < u.room.players.length(); i++) {
			u.room.players[i].send({{"type", message_types::start_game}, {"mode", mode}, {"scenario", scenario}});
		}
		// Create battle manager and start combat on server
		@u.room.bm = battle_manager();
		u.room.bm.start_game(u, mode, scenario, difficulty);
	}

	// --- Character Creation (save to account) ---
	else if (msg_type == message_types::character_create) {
		if (@u.account != null) {
			ensure_account_progression(u.account);
			json_object@ data = u.account.data;
			string profile = msg.exists("profile") ? normalize_game_type(string(msg["profile"])) : GAME_TYPE_SANDBOX;
			string storage_key = get_character_storage_key(profile);
			json_object char_data;
			if (msg.exists("name")) char_data["name"] = msg["name"];
			if (msg.exists("gender")) char_data["gender"] = msg["gender"];
			if (msg.exists("race")) char_data["race"] = msg["race"];
			if (msg.exists("class")) char_data["class"] = msg["class"];
			if (msg.exists("subclass")) char_data["subclass"] = msg["subclass"];
			if (msg.exists("background")) char_data["background"] = msg["background"];
			int stored_level = msg.exists("level") ? int(msg["level"]) : 1;
			if (profile == GAME_TYPE_ADVENTURE) {
				json_object@ progress = get_adventure_progress(u.account);
				stored_level = @progress != null ? get_json_int(progress, "level", 1) : 1;
				if (stored_level < 1) stored_level = 1;
				if (stored_level < 3) char_data["subclass"] = "";
			}
			// Clamp level to valid D&D range regardless of profile
			if (stored_level < 1) stored_level = 1;
			if (stored_level > 20) stored_level = 20;
			char_data["level"] = stored_level;
			if (msg.exists("str")) char_data["str"] = msg["str"];
			if (msg.exists("dex")) char_data["dex"] = msg["dex"];
			if (msg.exists("con")) char_data["con"] = msg["con"];
			if (msg.exists("int")) char_data["int"] = msg["int"];
			if (msg.exists("wis")) char_data["wis"] = msg["wis"];
			if (msg.exists("cha")) char_data["cha"] = msg["cha"];
			if (msg.exists("base_str")) char_data["base_str"] = msg["base_str"];
			if (msg.exists("base_dex")) char_data["base_dex"] = msg["base_dex"];
			if (msg.exists("base_con")) char_data["base_con"] = msg["base_con"];
			if (msg.exists("base_int")) char_data["base_int"] = msg["base_int"];
			if (msg.exists("base_wis")) char_data["base_wis"] = msg["base_wis"];
			if (msg.exists("base_cha")) char_data["base_cha"] = msg["base_cha"];
			if (msg.exists("weapon")) char_data["weapon"] = msg["weapon"];
			if (msg.exists("feats")) char_data["feats"] = msg["feats"];
			if (msg.exists("skills")) char_data["skills"] = msg["skills"];
			if (msg.exists("tools")) char_data["tools"] = msg["tools"];
			if (msg.exists("spell_ability_overrides")) char_data["spell_ability_overrides"] = msg["spell_ability_overrides"];
			if (msg.exists("free_cast_spells")) char_data["free_cast_spells"] = msg["free_cast_spells"];
			if (msg.exists("cantrips")) char_data["cantrips"] = msg["cantrips"];
			if (msg.exists("spells")) char_data["spells"] = msg["spells"];
			// Phase 1 affiliations (Theros Piety, Tasha Group Patron, Ravnica Guild,
			// Grim Hollow Transformation, Ebon Tides Fey Court, Wildemount Heroic
			// Chronicle homeland) — chosen optionally during character creation.
			if (msg.exists("piety_god")) char_data["piety_god"] = msg["piety_god"];
			if (msg.exists("group_patron")) char_data["group_patron"] = msg["group_patron"];
			if (msg.exists("ravnica_guild")) char_data["ravnica_guild"] = msg["ravnica_guild"];
			if (msg.exists("transformation")) char_data["transformation"] = msg["transformation"];
			if (msg.exists("transformation_stage")) char_data["transformation_stage"] = msg["transformation_stage"];
			if (msg.exists("fey_court")) char_data["fey_court"] = msg["fey_court"];
			if (msg.exists("heroic_homeland")) char_data["heroic_homeland"] = msg["heroic_homeland"];
			// New Devotee characters who name a god start with piety score 1 per
			// Theros para 1242 (the source's recommended starting devotion level).
			if (msg.exists("piety_god") and string(msg["piety_god"]) != "" and !char_data.exists("piety_score")) char_data["piety_score"] = 1;
			// Append to character array (multi-character support, up to 40 per mode)
			ensure_character_array_format(u.account, profile);
			json_array@ chars = get_character_list(u.account, profile);
			if (@chars != null and int(chars.length()) >= MAX_CHARACTERS_PER_MODE) {
				u.send({{"type", message_types::error}, {"text", "Maximum " + MAX_CHARACTERS_PER_MODE + " characters per mode. Delete one first."}});
				return;
			}
			if (@chars == null) { json_array new_arr; data[get_character_list_key(profile)] = new_arr; @chars = get_character_list(u.account, profile); }
			chars.add(char_data);
			int new_slot = int(chars.length()) - 1;
			set_active_slot(u.account, profile, new_slot);
			// Also update legacy single-char key for backward compatibility
			data[storage_key] = char_data;
			if (!data.exists("first_login_done")) data["first_login_done"] = true;
			u.account.commit();
			send_character_profile_to_user(u, profile);
			send_character_list_to_user(u, profile);
			if (profile == GAME_TYPE_ADVENTURE) send_adventure_progress_to_user(u);
			u.send({{"type", message_types::announce}, {"text", display_game_type(profile) + " character saved. Slot " + (new_slot + 1) + " of " + chars.length() + "."}, {"interrupt", false}});
			println("[CHAR] " + u.username + " saved " + profile + " character slot " + new_slot + ": " + string(msg["name"]));
		}
	}

	// --- Character Select (change active slot) ---
	else if (msg_type == message_types::character_select) {
		if (@u.account != null) {
			string profile = msg.exists("profile") ? normalize_game_type(string(msg["profile"])) : GAME_TYPE_ADVENTURE;
			int slot = msg.exists("slot") ? int(msg["slot"]) : 0;
			ensure_character_array_format(u.account, profile);
			json_array@ chars = get_character_list(u.account, profile);
			if (@chars == null or slot < 0 or slot >= int(chars.length())) {
				u.send({{"type", message_types::error}, {"text", "Invalid character slot."}});
				return;
			}
			set_active_slot(u.account, profile, slot);
			u.account.commit();
			send_character_profile_to_user(u, profile);
			u.send({{"type", message_types::announce}, {"text", "Switched to character slot " + (slot + 1) + "."}, {"interrupt", false}});
		}
	}

	// --- Character Delete ---
	else if (msg_type == message_types::character_delete) {
		if (@u.account != null) {
			string profile = msg.exists("profile") ? normalize_game_type(string(msg["profile"])) : GAME_TYPE_ADVENTURE;
			int slot = msg.exists("slot") ? int(msg["slot"]) : -1;
			ensure_character_array_format(u.account, profile);
			json_array@ chars = get_character_list(u.account, profile);
			if (@chars == null or slot < 0 or slot >= int(chars.length())) {
				u.send({{"type", message_types::error}, {"text", "Invalid character slot."}});
				return;
			}
			string deleted_name = "Unknown";
			json_object@ del_char = chars[slot];
			if (@del_char != null and del_char.exists("name")) deleted_name = string(del_char["name"]);
			// Rebuild array without the deleted slot
			json_array new_chars;
			for (uint di = 0; di < chars.length(); di++) {
				if (int(di) != slot) new_chars.add(chars[di]);
			}
			u.account.data[get_character_list_key(profile)] = new_chars;
			@chars = get_character_list(u.account, profile);
			// Adjust active slot if needed
			int active = get_active_slot(u.account, profile);
			if (active >= int(new_chars.length())) set_active_slot(u.account, profile, int(new_chars.length()) > 0 ? int(new_chars.length()) - 1 : 0);
			else if (active > slot) set_active_slot(u.account, profile, active - 1);
			// Update legacy key
			json_object@ new_active = get_character_profile(u.account, profile);
			if (@new_active != null) u.account.data[get_character_storage_key(profile)] = new_active;
			u.account.commit();
			send_character_list_to_user(u, profile);
			if (chars.length() > 0) send_character_profile_to_user(u, profile);
			u.send({{"type", message_types::announce}, {"text", "Deleted " + deleted_name + "."}, {"interrupt", false}});
		}
	}

	else if (msg_type == message_types::level_up_response) {
		if (@u.account != null) {
			ensure_account_progression(u.account);
			json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
			if (@character != null) {
				if (msg.exists("subclass") and string(msg["subclass"]) != "") {
					character["subclass"] = msg["subclass"];
				}
				if (msg.exists("new_cantrips")) {
					json_array@ existing = null;
					if (character.exists("cantrips")) @existing = character["cantrips"];
					if (@existing == null) { json_array arr; character["cantrips"] = arr; @existing = character["cantrips"]; }
					json_array@ new_cantrips = msg["new_cantrips"];
					if (@new_cantrips != null) {
						for (uint i = 0; i < new_cantrips.length(); i++) existing.add(new_cantrips[i]);
					}
				}
				if (msg.exists("new_spells")) {
					json_array@ existing = null;
					if (character.exists("spells")) @existing = character["spells"];
					if (@existing == null) { json_array arr; character["spells"] = arr; @existing = character["spells"]; }
					json_array@ new_spells = msg["new_spells"];
					if (@new_spells != null) {
						for (uint i = 0; i < new_spells.length(); i++) existing.add(new_spells[i]);
					}
				}
				// Level-up selection choices: Fighting Style, Pact Boon, Metamagic
				if (msg.exists("fighting_style") and string(msg["fighting_style"]) != "") {
					character["fighting_style"] = msg["fighting_style"];
				}
				if (msg.exists("pact_boon") and string(msg["pact_boon"]) != "") {
					character["pact_boon"] = msg["pact_boon"];
				}
				if (msg.exists("metamagic_choices")) {
					json_array@ mc = msg["metamagic_choices"];
					if (@mc != null and mc.length() > 0) {
						// Append to existing metamagic choices
						json_array@ existing_mc = null;
						if (character.exists("metamagic_choices")) @existing_mc = character["metamagic_choices"];
						if (@existing_mc == null) { json_array arr; character["metamagic_choices"] = arr; @existing_mc = character["metamagic_choices"]; }
						for (uint i = 0; i < mc.length(); i++) existing_mc.add(mc[i]);
					}
				}
				if (msg.exists("invocation_choices")) {
					json_array@ ivc = msg["invocation_choices"];
					if (@ivc != null and ivc.length() > 0) {
						// Append to existing invocation choices
						json_array@ existing_ivc = null;
						if (character.exists("invocation_choices")) @existing_ivc = character["invocation_choices"];
						if (@existing_ivc == null) { json_array arr; character["invocation_choices"] = arr; @existing_ivc = character["invocation_choices"]; }
						for (uint i = 0; i < ivc.length(); i++) existing_ivc.add(ivc[i]);
					}
				}
				u.account.commit();
				send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
				u.send({{"type", message_types::announce}, {"text", "Level-up choices saved!"}, {"interrupt", false}});
			}
		}
	}

	// --- Combat Message Routing (forward to battle_manager) ---
	else if (msg_type == message_types::roll_result) {
		if (@u.room == null or @u.room.bm == null) {
			u.send({{"type", message_types::announce}, {"text", "Not in a battle."}, {"interrupt", false}});
			return;
		}
		if (@u.room.bm.current_roll == null) {
			u.send({{"type", message_types::announce}, {"text", "Not waiting for your roll right now. Please wait."}, {"interrupt", false}});
			return;
		}
		if (u.room.bm.current_roll.player_username != u.username) {
			u.send({{"type", message_types::announce}, {"text", "It is not your turn to roll."}, {"interrupt", false}});
			return;
		}
		u.room.bm.handle_roll_result(u);
	}
	else if (msg_type == message_types::turn_end) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_turn_end(u);
		}
	}
	else if (msg_type == message_types::action_attack) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_attack(u, msg);
		}
	}
	else if (msg_type == message_types::action_move) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_move(u, msg);
		}
	}
	else if (msg_type == message_types::action_dodge) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_dodge(u);
		}
	}
	else if (msg_type == message_types::action_dash) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_dash(u);
		}
	}
	else if (msg_type == message_types::action_disengage) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_disengage(u);
		}
	}
	else if (msg_type == message_types::bonus_action) {
		if (@u.room == null or @u.room.bm == null or @u.room.bm.combat == null) return;
		string feature = msg.exists("feature") ? string(msg["feature"]) : "";
		uint target_id = msg.exists("target_id") ? uint(int(msg["target_id"])) : (msg.exists("target") ? uint(int(msg["target"])) : 0);
		// Phase 1 config commands (set_*/query_phase1) work any time —
		// they don't require the player to be the current combatant.
		bool is_phase1_config = feature == "set_piety_god" or feature == "set_group_patron"
			or feature == "set_ravnica_guild" or feature == "set_transformation"
			or feature == "set_fey_court" or feature == "query_phase1"
			or feature == "set_divine_order" or feature == "set_blessed_strikes"
			or feature == "set_divine_strike_damage_type"
			or feature == "set_primal_order" or feature == "set_elemental_fury"
			or feature == "set_primal_strike_damage_type"
			or feature == "set_elemental_affinity"
			or feature == "set_divine_soul_affinity"
			or feature == "set_elemental_adept"
			or feature == "set_spell_mastery" or feature == "set_signature_spells";
		combatant@ c = null;
		if (is_phase1_config) {
			@c = u.room.bm.find_player_combatant(u.username);
		} else {
			@c = u.room.bm.combat.current_combatant();
		}
		if (@c == null or c.player_username != u.username) return;

		// PHB 2024 Incapacitated (para 16225): "An Incapacitated creature can't take
		// any action, Bonus Action, or Reaction." Phase 1 config commands bypass.
		if (!is_phase1_config and c.is_incapacitated_check()) {
			u.send({{"type", message_types::announce}, {"text", "You are incapacitated and cannot take bonus actions."}, {"interrupt", true}});
			return;
		}

		if (feature == "rage") {
			if (c.class_name != "Barbarian") { u.send({{"type", message_types::announce}, {"text", "Only barbarians can Rage."}, {"interrupt", true}}); return; }
			if (c.raging) { u.send({{"type", message_types::announce}, {"text", "You are already raging."}, {"interrupt", true}}); return; }
			if (c.rage_uses_remaining <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no Rages remaining this battle."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.rage_uses_remaining--;
			c.raging = true;
			// Xanathar's Zealot L6 Fanatical Focus (para 443-444): reset per-rage reroll
			c.fanatical_focus_used_this_rage = false;
			// PHB 2024 Barbarian L15 Persistent Rage (para 2349-2351): "your Rage is so
			// fierce that it now lasts for 10 minutes without you needing to do anything
			// to extend it from round to round." 10 minutes ≈ 100 combat rounds.
			if (c.level >= 15) {
				c.rage_turns_remaining = 100;
				c.persistent_rage_active = true;
			} else {
				c.rage_turns_remaining = 10;
				c.persistent_rage_active = false;
			}
			// Xanathar's Storm Herald L3 Storm Aura (para 416-418): "your aura has an
			// effect that activates when you enter your rage"
			if (c.subclass == "Storm Herald") {
				c.storm_aura_active = true;
				u.room.bm.broadcast_announce(c.name + "'s Storm Aura activates!", true);
				u.room.bm.apply_storm_aura_effect(c);
			}
			// Wild Heart: Beast animal bonuses
			if (c.subclass == "Wild Heart") {
				// Default to Bear if not chosen: resistance to all damage except psychic
				if (c.wild_heart_animal == "") c.wild_heart_animal = "Bear";
				if (c.wild_heart_animal == "Bear") {
					// Bear: resistance to all damage except psychic (approximation via multiple flags)
					c.cold_resistance = true;
					c.fire_resistance = true;
					c.lightning_resistance = true;
					c.necrotic_resistance = true;
					c.acid_resistance = true;
				}
				u.room.bm.broadcast_announce(c.name + " channels the " + c.wild_heart_animal + " spirit!", false);
			}
			// World Tree: Gain temp HP on rage
			if (c.subclass == "World Tree") {
				int temp_hp = 1 + c.level;
				if (c.temp_hp < temp_hp) c.temp_hp = temp_hp;
				c.world_tree_temp_hp = true;
				u.room.bm.broadcast_announce(c.name + "'s World Tree grants " + temp_hp + " temp HP!", false);
			}
			// Path of the Carrion Raven (Grim Hollow): Feral Celerity — free weapon attack on rage entry
			if (c.subclass == "Path of the Carrion Raven" and c.level >= 3) {
				u.room.bm.broadcast_announce(c.name + "'s Feral Celerity grants a free weapon attack on rage entry! Your next attack this turn doesn't use your action.", false);
				c.attacks_remaining_this_turn++; // Grant one extra free attack
			}
			// Path of the Glacier L6: Cold Fortress — gain 1d12 + CON mod temp HP on rage entry (unarmored)
			if (c.subclass == "Path of the Glacier" and c.level >= 6 and c.armor_type == "none") {
				int cold_temp = random(1, 12) + c.get_ability_mod(ABILITY_CON);
				if (cold_temp < 1) cold_temp = 1;
				if (c.temp_hp < cold_temp) c.temp_hp = cold_temp;
				u.room.bm.broadcast_announce(c.name + "'s Cold Fortress grants " + cold_temp + " temp HP!", false);
			}
			// PHB 2024 Barbarian Level 7: Instinctive Pounce (para 2336-2337):
			// "As part of the Bonus Action you take to enter your Rage, you can move up
			// to half your Speed."
			if (c.level >= 7) {
				int pounce_feet = c.speed / 2;
				c.movement_remaining += pounce_feet;
				u.room.bm.broadcast_announce(c.name + "'s Instinctive Pounce grants " + pounce_feet + " feet of free movement.", false);
			}
			u.room.bm.broadcast_announce(c.name + " enters a Rage! Bonus damage and resistance to bludgeoning, piercing, and slashing. " + c.rage_uses_remaining + " use" + (c.rage_uses_remaining == 1 ? "" : "s") + " remain.", true);
		}
		else if (feature == "action_surge") {
			if (c.class_name != "Fighter") { u.send({{"type", message_types::announce}, {"text", "Only fighters can use Action Surge."}, {"interrupt", true}}); return; }
			if (c.action_surge_uses_remaining <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no Action Surge uses remaining this battle."}, {"interrupt", true}}); return; }
			// Action Surge is a free action (not bonus action). Restore action.
			c.action_surge_uses_remaining--;
			c.has_action = true;
			c.used_action = false;
			c.attacks_remaining_this_turn = 0; // Reset so new Attack action gets full extra attacks
			u.room.bm.broadcast_announce(c.name + " uses Action Surge! Extra action this turn. " + c.action_surge_uses_remaining + " use" + (c.action_surge_uses_remaining == 1 ? "" : "s") + " remain.", true);
		}
		else if (feature == "second_wind") {
			// PHB 2024 Fighter L1 Second Wind (para 5103-5106): "As a Bonus Action,
			// you can use it to regain Hit Points equal to 1d10 plus your Fighter
			// level. You can use this feature twice... regain one expended use when
			// you finish a Short Rest, and all when you finish a Long Rest." 3 uses
			// at L4, 4 uses at L10 per the Fighter Features table (para 5016-5048).
			if (c.class_name != "Fighter") { u.send({{"type", message_types::announce}, {"text", "Only fighters can use Second Wind."}, {"interrupt", true}}); return; }
			if (c.second_wind_uses_remaining <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no Second Wind uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.second_wind_uses_remaining--;
			c.second_wind_available = (c.second_wind_uses_remaining > 0);
			int heal = random(1, 10) + c.level;
			int effective_heal = u.room.bm.combat.apply_healing(c, heal);
			u.room.bm.record_effective_healing(c.player_username, effective_heal);
			u.room.bm.broadcast_roll(c.name, "Second Wind healing", heal, c.level, heal, "");
			u.room.bm.broadcast_announce(c.name + " uses Second Wind! Healed " + effective_heal + " HP. Now at " + c.current_hp + ". " + c.second_wind_uses_remaining + " use" + (c.second_wind_uses_remaining == 1 ? "" : "s") + " remain.", false);
			// PHB 2024 Fighter L5 Tactical Shift (para 5121-5122): "Whenever you
			// activate your Second Wind with a Bonus Action, you can move up to
			// half your Speed without provoking Opportunity Attacks."
			if (c.level >= 5) {
				int shift_feet = c.speed / 2;
				c.movement_remaining += shift_feet;
				c.tactical_shift_feet_remaining = shift_feet;
				u.room.bm.broadcast_announce(c.name + "'s Tactical Shift grants " + shift_feet + " feet of movement that ignores Opportunity Attacks.", false);
			}
			// Sword Coast: Purple Dragon Knight Rallying Cry — heal up to 3 allies within 60ft
			if (c.purple_dragon_knight_active) {
				int allies_healed = 0;
				for (uint rci = 0; rci < u.room.bm.combat.combatants.length() and allies_healed < 3; rci++) {
					combatant@ ally = u.room.bm.combat.combatants[rci];
					if (@ally == null or ally.is_dead or ally.id == c.id) continue;
					if (ally.is_player != c.is_player) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) continue;
					int ally_heal = c.level;
					u.room.bm.combat.apply_healing(ally, ally_heal);
					u.room.bm.broadcast_announce(c.name + "'s Rallying Cry heals " + ally.name + " for " + ally_heal + " HP!", false);
					allies_healed++;
				}
			}
		}
		else if (feature == "tactical_master") {
			// PHB 2024 Fighter L9 Tactical Master (para 5125-5126): "When you attack with
			// a weapon whose mastery property you can use, you can replace that property
			// with the Push, Sap, or Slow property for that attack."
			if (c.class_name != "Fighter" or c.level < 9) { u.send({{"type", message_types::announce}, {"text", "Only L9+ Fighters can use Tactical Master."}, {"interrupt", true}}); return; }
			if (c.main_hand_mastery == MASTERY_NONE) { u.send({{"type", message_types::announce}, {"text", "Your weapon has no mastery property to replace."}, {"interrupt", true}}); return; }
			// The sub_choice field determines which mastery to swap to: "push", "sap", or "slow"
			string sub_choice = "";
			if (msg.exists("sub_choice")) sub_choice = string(msg["sub_choice"]);
			if (sub_choice == "push") {
				c.tactical_master_active = true;
				c.tactical_master_mastery = MASTERY_PUSH;
				u.room.bm.broadcast_announce(c.name + " activates Tactical Master — next attack uses Push mastery!", false);
			} else if (sub_choice == "sap") {
				c.tactical_master_active = true;
				c.tactical_master_mastery = MASTERY_SAP;
				u.room.bm.broadcast_announce(c.name + " activates Tactical Master — next attack uses Sap mastery!", false);
			} else if (sub_choice == "slow") {
				c.tactical_master_active = true;
				c.tactical_master_mastery = MASTERY_SLOW;
				u.room.bm.broadcast_announce(c.name + " activates Tactical Master — next attack uses Slow mastery!", false);
			} else {
				u.send({{"type", message_types::announce}, {"text", "Choose a mastery: push, sap, or slow."}, {"interrupt", true}});
				return;
			}
		}
		else if (feature == "divine_smite") {
			if (c.class_name != "Paladin") { u.send({{"type", message_types::announce}, {"text", "Only paladins can prepare Divine Smite."}, {"interrupt", true}}); return; }
			// PHB 2024 Paladin L2 Paladin's Smite (para 5656-5657): "You always have
			// the Divine Smite spell prepared. In addition, you can cast it without
			// expending a spell slot, but you must finish a Long Rest before you can
			// cast it in this way again."
			if (c.level >= 2 and !c.paladins_smite_free_cast_used) {
				c.paladins_smite_free_cast_used = true;
				c.divine_smite_pending = true;
				c.divine_smite_slot_level = 1; // Free cast = base spell level (2d8 radiant)
				u.room.bm.broadcast_announce(c.name + " uses Paladin's Smite (free cast, no slot)! Next melee hit deals 2d8 radiant damage.", false);
				return;
			}
			// Find lowest available spell slot (1-5 for smite)
			int slot_used = -1;
			for (int sl = 1; sl <= 5; sl++) {
				if (c.spell_slots_current[sl] > 0) { slot_used = sl; break; }
			}
			if (slot_used < 0) {
				u.send({{"type", message_types::announce}, {"text", "No spell slots available for Divine Smite."}, {"interrupt", true}});
			} else {
				c.spell_slots_current[slot_used]--;
				c.divine_smite_pending = true;
				c.divine_smite_slot_level = slot_used;
				int smite_dice = slot_used + 1;
				u.room.bm.broadcast_announce(c.name + " prepares Divine Smite (level " + slot_used + " slot, " + smite_dice + "d8 radiant on next hit)!", false);
			}
		}
		else if (feature == "lay_on_hands") {
			if (c.class_name != "Paladin") { u.send({{"type", message_types::announce}, {"text", "Only paladins can use Lay on Hands."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a valid creature for Lay on Hands."}, {"interrupt", true}}); return; }
			if (target.id != c.id) {
				int dist = feet_distance(c.x, c.y, target.x, target.y);
				if (dist > 5) { u.send({{"type", message_types::announce}, {"text", "Lay on Hands requires touch range."}, {"interrupt", true}}); return; }
			}

			int heal = msg.exists("amount") ? int(msg["amount"]) : 0;
			if (heal < 0) heal = 0;
			string cleanse_csv = msg.exists("cleanse_conditions") ? string(msg["cleanse_conditions"]) : "";
			string[] requested_cleanses;
			if (cleanse_csv != "") {
				string[]@ parts = cleanse_csv.split(",");
				for (uint i = 0; i < parts.length(); i++) {
					if (parts[i] != "") requested_cleanses.insert_last(parts[i]);
				}
			}

			int cleanse_cost = 0;
			int[] conditions_to_remove;
			string[] condition_names;
			for (uint i = 0; i < requested_cleanses.length(); i++) {
				string cond_name = requested_cleanses[i].lower();
				int cond_id = 0;
				if (cond_name == "poisoned") cond_id = COND_POISONED;
				else if (c.level >= 14 and cond_name == "blinded") cond_id = COND_BLINDED;
				else if (c.level >= 14 and cond_name == "charmed") cond_id = COND_CHARMED;
				else if (c.level >= 14 and cond_name == "deafened") cond_id = COND_DEAFENED;
				else if (c.level >= 14 and cond_name == "frightened") cond_id = COND_FRIGHTENED;
				else if (c.level >= 14 and cond_name == "paralyzed") cond_id = COND_PARALYZED;
				else if (c.level >= 14 and cond_name == "stunned") cond_id = COND_STUNNED;
				if (cond_id == 0 or !target.has_condition(cond_id)) continue;

				bool already_added = false;
				for (uint ci = 0; ci < conditions_to_remove.length(); ci++) {
					if (conditions_to_remove[ci] == cond_id) { already_added = true; break; }
				}
				if (already_added) continue;
				conditions_to_remove.insert_last(cond_id);
				condition_names.insert_last(CONDITION_NAMES[cond_id]);
				cleanse_cost += 5;
			}

			int total_cost = heal + cleanse_cost;
			if (total_cost <= 0) { u.send({{"type", message_types::announce}, {"text", "Choose healing or conditions to remove."}, {"interrupt", true}}); return; }
			if (total_cost > c.lay_on_hands_pool) {
				u.send({{"type", message_types::announce}, {"text", "You only have " + c.lay_on_hands_pool + " Lay on Hands points remaining."}, {"interrupt", true}});
				return;
			}

			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.lay_on_hands_pool -= total_cost;
			if (heal > 0) {
				int effective_heal = u.room.bm.combat.apply_healing(target, heal);
				u.room.bm.record_effective_healing(c.player_username, effective_heal);
			}
			for (uint ci = 0; ci < conditions_to_remove.length(); ci++) {
				target.remove_condition(conditions_to_remove[ci]);
				u.room.bm.broadcast_to_battle({{"type", message_types::condition_removed}, {"target", target.name}, {"condition", condition_names[ci]}});
			}

			string text = c.name + " uses Lay on Hands on " + target.name + ".";
			if (heal > 0) text += " Restored " + heal + " hit points.";
			if (condition_names.length() > 0) {
				text += " Removed ";
				for (uint ci = 0; ci < condition_names.length(); ci++) {
					if (ci > 0) text += ci == condition_names.length() - 1 ? " and " : ", ";
					text += condition_names[ci];
				}
				text += ".";
			}
			text += " " + c.lay_on_hands_pool + " Lay on Hands points remain.";
			u.room.bm.broadcast_announce(text, true);
		}
		else if (feature == "natures_veil") {
			// PHB 2024 Ranger L14 Nature's Veil (para 6184-6186): "You invoke spirits
			// of nature to magically hide yourself. As a Bonus Action, you can give
			// yourself the Invisible condition until the end of your next turn. You
			// can use this feature a number of times equal to your Wisdom modifier
			// (minimum of once), and you regain all expended uses when you finish a
			// Long Rest."
			if (c.class_name != "Ranger" or c.level < 14) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Nature's Veil."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.natures_veil_uses_remaining <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no Nature's Veil uses remaining (recovers on Long Rest)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.natures_veil_uses_remaining--;
			c.add_condition(COND_INVISIBLE);
			c.natures_veil_rounds_remaining = 2; // ticks down at start of each turn; ends at end of next turn
			u.room.bm.broadcast_announce(c.name + " invokes Nature's Veil and vanishes from sight! (" + c.natures_veil_uses_remaining + " uses remaining)", true);
			u.room.bm.broadcast_to_battle({{"type", message_types::condition_applied}, {"target", c.name}, {"condition", "Invisible"}});
		}
		else if (feature == "tireless_temp_hp") {
			// PHB 2024 Ranger L10 Tireless (para 6178-6180): "As a Magic action, you
			// can give yourself a number of Temporary Hit Points equal to 1d8 plus
			// your Wisdom modifier (minimum of 1). You can use this action a number
			// of times equal to your Wisdom modifier (minimum of once), and you
			// regain all expended uses when you finish a Long Rest." Implemented as
			// a bonus action menu entry — the action cost is treated as a Magic
			// action equivalent (consumes the standard action below).
			if (c.class_name != "Ranger" or c.level < 10) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Tireless."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action available (Tireless is a Magic action)."}, {"interrupt", true}}); return; }
			if (c.tireless_temp_hp_uses_remaining <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no Tireless uses remaining (recovers on Long Rest)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.tireless_temp_hp_uses_remaining--;
			int wis_mod_t = c.get_ability_mod(ABILITY_WIS);
			int t_grant = random(1, 8) + wis_mod_t;
			if (t_grant < 1) t_grant = 1;
			if (t_grant > c.temp_hp) c.temp_hp = t_grant;
			u.room.bm.broadcast_announce(c.name + "'s Tireless grants " + t_grant + " temporary HP. (" + c.tireless_temp_hp_uses_remaining + " uses remaining)", true);
		}
		else if (feature == "steady_aim") {
			// PHB 2024 Rogue L3 Steady Aim (para 6550-6551): "As a Bonus Action, you
			// give yourself Advantage on your next attack roll on the current turn.
			// You can use this feature only if you haven't moved during this turn,
			// and after you use it, your Speed is 0 until the end of the current
			// turn."
			if (c.class_name != "Rogue" or c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Steady Aim."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.movement_remaining < c.speed) { u.send({{"type", message_types::announce}, {"text", "Steady Aim requires that you have not moved this turn."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.steady_aim_pending = true;
			c.movement_remaining = 0; // Speed 0 until end of turn (cannot move further).
			u.room.bm.broadcast_announce(c.name + " uses Steady Aim. Their next attack has Advantage, but their Speed is 0 until the end of this turn.", true);
		}
		else if (feature == "innate_sorcery") {
			// PHB 2024 Sorcerer L1 Innate Sorcery (para 6963-6967): "As a Bonus Action,
			// you can unleash that magic for 1 minute, during which you gain the following
			// benefits: • The spell save DC of your Sorcerer spells increases by 1.
			// • You have Advantage on the attack rolls of Sorcerer spells you cast.
			// You can use this feature twice, and you regain all expended uses of it
			// when you finish a Long Rest."
			//
			// PHB 2024 Sorcerer L7 Sorcery Incarnate (para 7004-7006): "If you have no
			// uses of Innate Sorcery left, you can use it if you spend 2 Sorcery Points
			// when you take the Bonus Action to activate it."
			if (c.class_name != "Sorcerer" or c.level < 1) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Innate Sorcery."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.innate_sorcery_active) { u.send({{"type", message_types::announce}, {"text", "Innate Sorcery is already active."}, {"interrupt", true}}); return; }
			bool used_sp = false;
			if (c.innate_sorcery_uses_remaining > 0) {
				c.innate_sorcery_uses_remaining--;
			} else if (c.level >= 7 and c.sorcery_points >= 2) {
				// Sorcery Incarnate: spend 2 SP to activate when out of uses
				c.sorcery_points -= 2;
				used_sp = true;
			} else {
				u.send({{"type", message_types::announce}, {"text", c.level >= 7 ? "No uses of Innate Sorcery left and not enough Sorcery Points (need 2)." : "No uses of Innate Sorcery left."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.innate_sorcery_active = true;
			c.innate_sorcery_rounds_remaining = 10; // 1 minute = 10 rounds
			// PHB 2024 Sorcerer L7 Sorcery Incarnate (para 7004-7006): "While your Innate
			// Sorcery feature is active, you can use up to two Metamagic options on each spell."
			c.sorcery_incarnate_active = (c.level >= 7);
			string activate_msg = c.name + " unleashes Innate Sorcery! Spell save DC +1 and Advantage on Sorcerer spell attack rolls for 1 minute.";
			if (c.sorcery_incarnate_active) activate_msg += " Sorcery Incarnate: two Metamagic options per spell!";
			if (used_sp) activate_msg += " (2 Sorcery Points spent.)";
			u.room.bm.broadcast_announce(activate_msg, true);
		}
		else if (feature == "dragon_wings") {
			// PHB 2024 Sorcerer Draconic Sorcery L14 Dragon Wings (para 7561-7563):
			// "As a Bonus Action, you can cause draconic wings to appear on your back.
			// The wings last for 1 hour or until you dismiss them (no action required).
			// For the duration, you have a Fly Speed of 60 feet. Once you use this
			// feature, you can't use it again until you finish a Long Rest unless you
			// spend 3 Sorcery Points (no action required) to restore your use of it."
			if (c.class_name != "Sorcerer" or c.subclass != "Draconic Sorcery" or c.level < 14) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Dragon Wings."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.dragon_wings_active) { u.send({{"type", message_types::announce}, {"text", "Dragon Wings are already active."}, {"interrupt", true}}); return; }
			if (c.dragon_wings_used_this_rest) {
				u.send({{"type", message_types::announce}, {"text", "Dragon Wings already used this rest. Spend 3 Sorcery Points (use dragon_wings_restore) to restore the use."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.dragon_wings_active = true;
			c.dragon_wings_rounds_remaining = 600; // 1 hour ≈ 600 rounds (cap is just a long ceiling)
			c.dragon_wings_used_this_rest = true;
			c.flying_speed = 60;
			u.room.bm.broadcast_announce(c.name + " sprouts draconic wings and gains a Fly Speed of 60 feet for 1 hour!", true);
		}
		else if (feature == "dragon_wings_restore") {
			// PHB 2024 Sorcerer Draconic Sorcery L14 Dragon Wings refresh (para 7563):
			// "unless you spend 3 Sorcery Points (no action required) to restore your
			// use of it."
			if (c.class_name != "Sorcerer" or c.subclass != "Draconic Sorcery" or c.level < 14) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot restore Dragon Wings."}, {"interrupt", true}});
				return;
			}
			if (!c.dragon_wings_used_this_rest) {
				u.send({{"type", message_types::announce}, {"text", "Dragon Wings is not used yet — no need to restore it."}, {"interrupt", true}});
				return;
			}
			if (c.sorcery_points < 3) {
				u.send({{"type", message_types::announce}, {"text", "Need 3 Sorcery Points to restore Dragon Wings."}, {"interrupt", true}});
				return;
			}
			c.sorcery_points -= 3;
			c.dragon_wings_used_this_rest = false;
			u.room.bm.broadcast_announce(c.name + " spends 3 Sorcery Points to restore Dragon Wings.", true);
		}
		else if (feature == "summon_dragon_free") {
			// PHB 2024 Sorcerer Draconic Sorcery L18 Dragon Companion (para 7564-7566):
			// "You can cast Summon Dragon without a Material component. You can also
			// cast it once without a spell slot, and you regain the ability to cast it
			// in this way when you finish a Long Rest. Whenever you start casting the
			// spell, you can modify it so that it doesn't require Concentration. If you
			// do so, the spell's duration becomes 1 minute for that casting."
			if (c.class_name != "Sorcerer" or c.subclass != "Draconic Sorcery" or c.level < 18) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Dragon Companion."}, {"interrupt", true}});
				return;
			}
			if (c.dragon_companion_used_this_rest) {
				u.send({{"type", message_types::announce}, {"text", "Free Summon Dragon already used this rest."}, {"interrupt", true}});
				return;
			}
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining (Summon Dragon is an Action)."}, {"interrupt", true}}); return; }
			// Grant a phantom L5 slot for the next Summon Dragon cast and flag it as the free use.
			c.dragon_companion_used_this_rest = true;
			c.grant_free_cast("summon_dragon", 1);
			u.room.bm.broadcast_announce(c.name + "'s Dragon Companion grants a free Summon Dragon cast — use the cast menu to summon it.", true);
		}
		else if (feature == "overchannel") {
			// PHB 2024 Wizard Evoker L14 Overchannel (para 9265-9268): toggle a flag
			// that the next L1-5 damage spell will deal max damage. The first use is
			// free; subsequent uses deal escalating necrotic damage to the caster.
			if (c.class_name != "Wizard" or c.subclass != "Evoker" or c.level < 14) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Overchannel."}, {"interrupt", true}});
				return;
			}
			if (c.overchannel_pending) {
				u.send({{"type", message_types::announce}, {"text", "Overchannel is already pending for the next damage spell."}, {"interrupt", true}});
				return;
			}
			c.overchannel_pending = true;
			string warn = c.overchannel_uses_this_rest >= 1 ? " WARNING: this is use #" + (c.overchannel_uses_this_rest + 1) + " — you will take " + (2 + c.overchannel_uses_this_rest - 1) + "d12 necrotic damage per spell level after the cast." : " First use this rest is free.";
			u.room.bm.broadcast_announce(c.name + " primes Overchannel — your next L1-5 damage spell will deal maximum damage." + warn, true);
		}
		else if (feature == "otherworldly_wings") {
			// Xanathar's Divine Soul L14 Otherworldly Wings (para 2551-2553): "you can
			// use a bonus action to manifest a pair of spectral wings from your back.
			// While the wings are present, you have a flying speed of 30 feet. The wings
			// last until you're incapacitated, you die, or you dismiss them as a bonus action."
			if (c.class_name != "Sorcerer" or c.subclass != "Divine Soul" or c.level < 14) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Otherworldly Wings."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.otherworldly_wings_active) {
				// Dismiss
				c.otherworldly_wings_active = false;
				c.flying_speed = 0;
				u.room.bm.broadcast_announce(c.name + " dismisses their spectral wings.", false);
			} else {
				c.otherworldly_wings_active = true;
				c.flying_speed = 30;
				u.room.bm.broadcast_announce(c.name + " manifests spectral wings and gains a Fly Speed of 30 feet!", true);
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
		}
		else if (feature == "unearthly_recovery") {
			// Xanathar's Divine Soul L18 Unearthly Recovery (para 2554-2556): "As a
			// bonus action when you have fewer than half of your hit points remaining,
			// you can regain a number of hit points equal to half your hit point maximum.
			// Once you use this feature, you can't use it again until you finish a long rest."
			if (c.class_name != "Sorcerer" or c.subclass != "Divine Soul" or c.level < 18) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Unearthly Recovery."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (!c.unearthly_recovery_available) {
				u.send({{"type", message_types::announce}, {"text", "Unearthly Recovery already used this long rest."}, {"interrupt", true}});
				return;
			}
			if (c.current_hp >= c.max_hp / 2) {
				u.send({{"type", message_types::announce}, {"text", "You must be below half HP to use Unearthly Recovery."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.unearthly_recovery_available = false;
			int heal = c.max_hp / 2;
			u.room.bm.combat.apply_healing(c, heal);
			u.room.bm.broadcast_announce(c.name + " invokes Unearthly Recovery and regains " + heal + " hit points!", true);
		}
		else if (feature == "boon_of_recovery") {
			// PHB 2024 Boon of Recovery (para 7879): "You can use a Bonus Action to regain
			// a number of Hit Points equal to half your Hit Point Maximum (round down). Once
			// you use this benefit, you can't use it again until you finish a Long Rest."
			if (!c.has_feat("boon_of_recovery")) {
				u.send({{"type", message_types::announce}, {"text", "Your character does not have Boon of Recovery."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.boon_of_recovery_used) {
				u.send({{"type", message_types::announce}, {"text", "Boon of Recovery already used this long rest."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.boon_of_recovery_used = true;
			int heal = c.max_hp / 2;
			u.room.bm.combat.apply_healing(c, heal);
			u.room.bm.broadcast_announce(c.name + " invokes Boon of Recovery and regains " + heal + " hit points!", true);
		}
		else if (feature == "blink_steps") {
			// PHB 2024 Boon of Dimensional Travel (para 7876): "Immediately after you
			// take the Attack action or the Magic action, you can teleport up to 30 feet
			// to an unoccupied space you can see." Free action, 1/action.
			if (!c.has_feat("boon_of_dimensional_travel")) {
				u.send({{"type", message_types::announce}, {"text", "Your character does not have Boon of Dimensional Travel."}, {"interrupt", true}});
				return;
			}
			if (!c.blink_steps_available) {
				u.send({{"type", message_types::announce}, {"text", "Blink Steps requires taking the Attack or Magic action first."}, {"interrupt", true}});
				return;
			}
			if (c.blink_steps_used_this_turn) {
				u.send({{"type", message_types::announce}, {"text", "You already used Blink Steps this turn."}, {"interrupt", true}});
				return;
			}
			c.blink_steps_used_this_turn = true;
			c.blink_steps_available = false;
			// Teleport adjacent to current target, or nearest enemy if no target
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) @target = u.room.bm.find_nearest_hostile_target(c);
			if (@target != null and !target.is_dead) {
				int dist = feet_distance(c.x, c.y, target.x, target.y);
				if (dist <= 30) {
					c.x = target.x;
					c.y = target.y + 1;
					u.room.bm.broadcast_announce(c.name + " Blink Steps to " + target.name + "!", true);
				} else {
					// Move 30 ft toward the target
					int dx = target.x - c.x;
					int dy = target.y - c.y;
					int tiles = 6; // 30 ft / 5 ft per tile
					if (dx != 0 or dy != 0) {
						float fdist = sqrt(float(dx * dx + dy * dy));
						int move_x = int(float(dx) / fdist * tiles);
						int move_y = int(float(dy) / fdist * tiles);
						c.x += move_x;
						c.y += move_y;
					}
					u.room.bm.broadcast_announce(c.name + " Blink Steps 30 feet toward " + target.name + "!", true);
				}
			} else {
				u.room.bm.broadcast_announce(c.name + " Blink Steps but no valid target to teleport toward.", false);
			}
		}
		else if (feature == "hound_of_ill_omen") {
			// Xanathar's Shadow Magic L6 Hound of Ill Omen (para 2596-2602): "As a bonus
			// action, you can spend 3 sorcery points to magically summon a hound of ill
			// omen to target one creature you can see within 120 feet."
			// Uses dire wolf stats (Medium monstrosity, temp HP = half sorcerer level).
			if (c.class_name != "Sorcerer" or c.subclass != "Shadow Magic" or c.level < 6) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot summon a Hound of Ill Omen."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.sorcery_points < 3) { u.send({{"type", message_types::announce}, {"text", "You need 3 Sorcery Points to summon the Hound."}, {"interrupt", true}}); return; }
			// Find the target from client message
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead or target.id == c.id) { u.send({{"type", message_types::announce}, {"text", "No valid target for the Hound."}, {"interrupt", true}}); return; }
			float hdx = float(target.x - c.x); float hdy = float(target.y - c.y);
			float dist = sqrt(hdx * hdx + hdy * hdy) * 5.0f;
			if (dist > 120) { u.send({{"type", message_types::announce}, {"text", "Target is out of range (120 ft)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.sorcery_points -= 3;
			// Dire wolf stats: HP 37 (5d10+10), AC 14, Speed 50, Bite +5 1d6+3 piercing
			// Modified: Medium, temp HP = half sorcerer level, monstrosity
			int hound_hp = 37 + c.level / 2; // Base HP + temp HP baked in
			combatant@ hound = u.room.bm.spawn_companion(c, "hound_of_ill_omen", c.name + "'s Hound of Ill Omen", hound_hp, 14, 50, 5, 2, 6, 3, DMG_PIERCING, 0);
			if (@hound != null) {
				// Track hound target for save disadvantage
				target.hound_caster_id = c.id;
			}
			u.room.bm.broadcast_announce(c.name + " spends 3 SP and summons a Hound of Ill Omen to stalk " + target.name + "!", true);
		}
		else if (feature == "shadow_walk") {
			// Xanathar's Shadow Magic L14 Shadow Walk (para 2603-2604): "When you are in
			// dim light or darkness, as a bonus action, you can magically teleport up to
			// 120 feet to an unoccupied space you can see that is also in dim light or darkness."
			if (c.class_name != "Sorcerer" or c.subclass != "Shadow Magic" or c.level < 14) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Shadow Walk."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Teleport up to 120 ft toward locked target if one is provided
			combatant@ sw_target = u.room.bm.combat.get_combatant(target_id);
			if (@sw_target != null and !sw_target.is_dead and sw_target.id != c.id) {
				float sdx = float(sw_target.x - c.x); float sdy = float(sw_target.y - c.y);
				float dist = sqrt(sdx * sdx + sdy * sdy) * 5.0f;
				if (dist <= 120) {
					c.x = sw_target.x + 1;
					c.y = sw_target.y;
				}
			}
			u.room.bm.broadcast_announce(c.name + " steps through shadows, teleporting up to 120 feet!", true);
		}
		else if (feature == "shadow_umbral_form") {
			// Xanathar's Shadow Magic L18 Umbral Form (para 2605-2607): "you can spend 6
			// sorcery points as a bonus action to magically transform yourself into a shadowy
			// form. In this form, you have resistance to all damage except force and radiant,
			// and you can move through other creatures and objects as if they were difficult terrain."
			// Duration: 1 minute (10 rounds). Ends if incapacitated, die, or dismiss.
			if (c.class_name != "Sorcerer" or c.subclass != "Shadow Magic" or c.level < 18) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Umbral Form."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.shadow_umbral_active) {
				// Dismiss as BA
				c.shadow_umbral_active = false;
				c.shadow_umbral_rounds = 0;
				c.has_bonus_action = false;
				c.used_bonus_action = true;
				u.room.bm.broadcast_announce(c.name + " dismisses their Umbral Form.", false);
				return;
			}
			if (c.sorcery_points < 6) { u.send({{"type", message_types::announce}, {"text", "You need 6 Sorcery Points for Umbral Form."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.sorcery_points -= 6;
			c.shadow_umbral_active = true;
			c.shadow_umbral_rounds = 10;
			u.room.bm.broadcast_announce(c.name + " transforms into a shadowy Umbral Form — resistance to all damage except force and radiant for 1 minute!", true);
		}
		else if (feature == "revelation_in_flesh") {
			// Tasha's Aberrant Mind L14 Revelation in Flesh (para 3942-3948): "As a bonus
			// action, you can spend 1 or more sorcery points to magically transform your
			// body for 10 minutes. For each sorcery point you spend, you can gain one of
			// the following benefits: see invisible 60ft, fly speed = walk speed, swim 2x, squeeze."
			if (c.class_name != "Sorcerer" or c.subclass != "Aberrant Sorcery" or c.level < 14) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Revelation in Flesh."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			// Parse chosen option from msg: "see_invisible" or "fly" (1 SP each)
			string option = msg.exists("option") ? string(msg["option"]) : "fly";
			int sp_cost = 1;
			if (option == "both") sp_cost = 2; // Player chooses both
			if (c.sorcery_points < sp_cost) { u.send({{"type", message_types::announce}, {"text", "You need " + sp_cost + " SP for Revelation in Flesh."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.sorcery_points -= sp_cost;
			c.revelation_in_flesh_active = true;
			c.revelation_in_flesh_rounds = 100; // 10 minutes
			string effects = "";
			if (option == "see_invisible" or option == "both") {
				c.revelation_see_invisible = true;
				effects += "See Invisible 60 ft";
			}
			if (option == "fly" or option == "both") {
				c.revelation_fly = true;
				c.flying_speed = c.speed;
				if (effects != "") effects += " + ";
				effects += "Fly " + c.speed + " ft";
			}
			u.room.bm.broadcast_announce(c.name + " reveals their aberrant form — " + effects + " for 10 minutes!", true);
		}
		else if (feature == "warping_implosion") {
			// Tasha's Aberrant Mind L18 Warping Implosion (para 3949-3952): "As an action,
			// you can teleport to an unoccupied space you can see within 120 feet. Immediately
			// after, each creature within 30 feet of the space you left must make a STR save
			// vs spell DC. Fail: 3d10 force + pulled. Success: half + no pull."
			// 1/LR or 5 SP to reuse.
			if (c.class_name != "Sorcerer" or c.subclass != "Aberrant Sorcery" or c.level < 18) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Warping Implosion."}, {"interrupt", true}});
				return;
			}
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			bool used_sp = false;
			if (!c.warping_implosion_available) {
				// Try SP recharge
				if (c.sorcery_points >= 5) {
					c.sorcery_points -= 5;
					used_sp = true;
				} else {
					u.send({{"type", message_types::announce}, {"text", "Warping Implosion already used this rest. Costs 5 SP to reuse."}, {"interrupt", true}});
					return;
				}
			}
			c.has_action = false;
			if (!used_sp) c.warping_implosion_available = false;
			// Save original position
			int old_x = c.x;
			int old_y = c.y;
			// Teleport toward locked target or 120ft forward
			combatant@ wi_target = u.room.bm.combat.get_combatant(target_id);
			if (@wi_target != null and !wi_target.is_dead and wi_target.id != c.id) {
				float wdx = float(wi_target.x - c.x); float wdy = float(wi_target.y - c.y);
				float dist = sqrt(wdx * wdx + wdy * wdy) * 5.0f;
				if (dist <= 120) {
					c.x = wi_target.x + 1;
					c.y = wi_target.y;
				}
			}
			// AoE: 30ft around old position — 3d10 force + STR save
			int spell_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_CHA);
			int total_damage = random(1, 10) + random(1, 10) + random(1, 10);
			string cost_note = used_sp ? " (5 SP)" : "";
			u.room.bm.broadcast_announce(c.name + " unleashes Warping Implosion" + cost_note + " — teleporting 120 ft and causing a space-warping anomaly!", true);
			for (uint i = 0; i < u.room.bm.combat.combatants.length(); i++) {
				combatant@ t = u.room.bm.combat.combatants[i];
				if (@t == null or t.is_dead or t.id == c.id) continue;
				if (t.is_player == c.is_player) continue; // Skip allies — only hit enemies
				// Check distance from OLD position
				float dx = float(t.x - old_x);
				float dy = float(t.y - old_y);
				float d = sqrt(dx * dx + dy * dy) * 5.0f;
				if (d <= 30) {
					int str_save = random(1, 20) + t.get_ability_mod(ABILITY_STR);
					if (str_save >= spell_dc) {
						int half = (total_damage + 1) / 2;
						u.room.bm.combat.apply_damage(t, half, DMG_FORCE, c);
						u.room.bm.broadcast_announce(t.name + " resists the implosion! STR save " + str_save + " vs DC " + spell_dc + " — takes " + half + " force damage.", false);
					} else {
						u.room.bm.combat.apply_damage(t, total_damage, DMG_FORCE, c);
						u.room.bm.broadcast_announce(t.name + " is pulled by the implosion! STR save " + str_save + " vs DC " + spell_dc + " — takes " + total_damage + " force damage!", true);
					}
				}
			}
		}
		else if (feature == "bastion_of_law") {
			// Tasha's Clockwork Soul L6 Bastion of Law (para 3997-4000): "As an action,
			// you can expend 1 to 5 sorcery points to create a magical ward around yourself
			// or another creature you can see within 30 feet of you. The ward is represented
			// by a number of d8s equal to the number of sorcery points spent."
			if (c.class_name != "Sorcerer" or c.subclass != "Clockwork Sorcery" or c.level < 6) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Bastion of Law."}, {"interrupt", true}});
				return;
			}
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			int sp_cost = msg.exists("sp_cost") ? int(msg["sp_cost"]) : 1;
			if (sp_cost < 1) sp_cost = 1;
			if (sp_cost > 5) sp_cost = 5;
			if (c.sorcery_points < sp_cost) { u.send({{"type", message_types::announce}, {"text", "You need " + sp_cost + " SP for Bastion of Law."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.sorcery_points -= sp_cost;
			// Apply ward to self or ally
			combatant@ ward_target = u.room.bm.combat.get_combatant(target_id);
			if (@ward_target == null or ward_target.is_dead) @ward_target = c; // Default to self
			ward_target.bastion_of_law_dice = sp_cost;
			u.room.bm.broadcast_announce(c.name + " creates a Bastion of Law ward on " + ward_target.name + " with " + sp_cost + "d8 ward dice!", true);
		}
		else if (feature == "trance_of_order") {
			// Tasha's Clockwork Soul L14 Trance of Order (para 4001-4004): "As a bonus
			// action, you can enter this state for 1 minute. For the duration, attack rolls
			// against you can't benefit from advantage, and whenever you make an attack roll,
			// an ability check, or a saving throw, you can treat a roll of 9 or lower on
			// the d20 as a 10." 1/LR or 5 SP.
			if (c.class_name != "Sorcerer" or c.subclass != "Clockwork Sorcery" or c.level < 14) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Trance of Order."}, {"interrupt", true}});
				return;
			}
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.trance_of_order_active) {
				u.send({{"type", message_types::announce}, {"text", "Trance of Order is already active."}, {"interrupt", true}});
				return;
			}
			// Tasha's para 4003-4004: "Once you take this bonus action, you can't do so
			// again until you finish a long rest, unless you spend 5 sorcery points to
			// use it again."
			bool used_sp = false;
			if (c.trance_of_order_used) {
				if (c.sorcery_points >= 5) {
					c.sorcery_points -= 5;
					used_sp = true;
				} else {
					u.send({{"type", message_types::announce}, {"text", "Trance of Order already used this rest. Costs 5 SP to reuse."}, {"interrupt", true}});
					return;
				}
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.trance_of_order_active = true;
			c.trance_of_order_rounds = 10;
			if (!used_sp) c.trance_of_order_used = true;
			string cost_note = used_sp ? " (5 SP)" : "";
			u.room.bm.broadcast_announce(c.name + " enters a Trance of Order" + cost_note + " — attacks can't benefit from advantage, and d20 rolls of 9 or lower are treated as 10!", true);
		}
		else if (feature == "clockwork_cavalcade") {
			// Tasha's Clockwork Soul L18 Clockwork Cavalcade (para 4005-4011): "As an action,
			// you summon spirits of order in a 30-foot cube. The spirits restore up to 100 HP,
			// divided as you choose among any number of creatures of your choice in the cube.
			// Every spell of 6th level or lower ends on creatures and objects of your choice."
			// 1/LR or 7 SP.
			if (c.class_name != "Sorcerer" or c.subclass != "Clockwork Sorcery" or c.level < 18) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Clockwork Cavalcade."}, {"interrupt", true}});
				return;
			}
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			bool used_sp = false;
			if (!c.clockwork_cavalcade_available) {
				if (c.sorcery_points >= 7) {
					c.sorcery_points -= 7;
					used_sp = true;
				} else {
					u.send({{"type", message_types::announce}, {"text", "Clockwork Cavalcade already used. Costs 7 SP to reuse."}, {"interrupt", true}});
					return;
				}
			}
			c.has_action = false;
			if (!used_sp) c.clockwork_cavalcade_available = false;
			string cost_note = used_sp ? " (7 SP)" : "";
			// Heal allies within 30 ft: split 100 HP among injured allies (most injured first)
			int heal_pool = 100;
			u.room.bm.broadcast_announce(c.name + " invokes Clockwork Cavalcade" + cost_note + " — spirits of order restore vitality!", true);
			// Collect injured allies within 30 ft
			for (uint i = 0; i < u.room.bm.combat.combatants.length(); i++) {
				if (heal_pool <= 0) break;
				combatant@ t = u.room.bm.combat.combatants[i];
				if (@t == null or t.is_dead) continue;
				if (t.is_player != c.is_player) continue; // Only heal allies
				float cdx = float(t.x - c.x); float cdy = float(t.y - c.y);
				float d = sqrt(cdx * cdx + cdy * cdy) * 5.0f;
				if (d > 30) continue;
				int missing = t.max_hp - t.current_hp;
				if (missing <= 0) continue;
				int heal = missing;
				if (heal > heal_pool) heal = heal_pool;
				heal_pool -= heal;
				u.room.bm.combat.apply_healing(t, heal);
				u.room.bm.broadcast_announce(t.name + " is restored for " + heal + " HP by the Clockwork Cavalcade.", false);
			}
		}
		else if (feature == "font_of_magic_to_slot") {
			// PHB 2024 Sorcerer L2 Font of Magic — Creating Spell Slots (para 6973-6993):
			// "As a Bonus Action, you can transform unexpended Sorcery Points into one
			// spell slot." Cost table: L1=2 SP, L2=3 SP, L3=5 SP, L4=6 SP, L5=7 SP.
			if (c.class_name != "Sorcerer" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Font of Magic."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			int slot_level = msg.exists("slot_level") ? int(msg["slot_level"]) : 1;
			int sp_cost = 0;
			if (slot_level == 1) sp_cost = 2;
			else if (slot_level == 2) sp_cost = 3;
			else if (slot_level == 3) sp_cost = 5;
			else if (slot_level == 4) sp_cost = 6;
			else if (slot_level == 5) sp_cost = 7;
			else { u.send({{"type", message_types::announce}, {"text", "Invalid slot level (1-5 only)."}, {"interrupt", true}}); return; }
			// Source: minimum Sorcerer level (3=L3, 4=L5, 5=L7).
			int min_level = 2;
			if (slot_level == 3) min_level = 3;
			else if (slot_level == 4) min_level = 5;
			else if (slot_level == 5) min_level = 7;
			if (c.level < min_level) { u.send({{"type", message_types::announce}, {"text", "You must be level " + min_level + " to create a level " + slot_level + " spell slot."}, {"interrupt", true}}); return; }
			if (c.sorcery_points < sp_cost) { u.send({{"type", message_types::announce}, {"text", "You need " + sp_cost + " Sorcery Points to create a level " + slot_level + " spell slot."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.sorcery_points -= sp_cost;
			c.spell_slots_current[slot_level]++;
			u.room.bm.broadcast_announce(c.name + " converts " + sp_cost + " Sorcery Points into a level " + slot_level + " spell slot.", true);
		}
		else if (feature == "font_of_magic_to_sp") {
			// PHB 2024 Sorcerer L2 Font of Magic — Converting Spell Slots to Sorcery Points
			// (para 6972): "You can expend a spell slot to gain a number of Sorcery Points
			// equal to the slot's level (no action required)."
			if (c.class_name != "Sorcerer" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Font of Magic."}, {"interrupt", true}}); return; }
			int slot_level = msg.exists("slot_level") ? int(msg["slot_level"]) : 1;
			if (slot_level < 1 or slot_level > 9) { u.send({{"type", message_types::announce}, {"text", "Invalid slot level."}, {"interrupt", true}}); return; }
			if (c.spell_slots_current[slot_level] <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no level " + slot_level + " spell slots to convert."}, {"interrupt", true}}); return; }
			if (c.sorcery_points + slot_level > c.sorcery_points_max) { u.send({{"type", message_types::announce}, {"text", "You cannot exceed your Sorcery Point maximum of " + c.sorcery_points_max + "."}, {"interrupt", true}}); return; }
			c.spell_slots_current[slot_level]--;
			c.sorcery_points += slot_level;
			u.room.bm.broadcast_announce(c.name + " converts a level " + slot_level + " spell slot into " + slot_level + " Sorcery Points.", true);
		}
		else if (feature == "metamagic") {
			// PHB 2024 Sorcerer L2 Metamagic (para 6979-7020): toggle a metamagic option
			// before casting a spell. SP deducted on activation; effect applied on next cast.
			// Simplification: all 10 options available to all Sorcerers L2+ (source requires
			// learning 2/4/6 — player choice at level-up deferred to future UI batch).
			if (c.class_name != "Sorcerer" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Only Sorcerers of level 2+ can use Metamagic."}, {"interrupt", true}}); return; }
			string option = msg.exists("option") ? string(msg["option"]) : "";
			// PHB 2024 Sorcerer L2 Metamagic: validate option against player's chosen metamagic
			if (c.metamagic_choices.length() > 0) {
				bool option_known = false;
				for (uint mci = 0; mci < c.metamagic_choices.length(); mci++) {
					if (c.metamagic_choices[mci] == option) { option_known = true; break; }
				}
				if (!option_known) {
					u.send({{"type", message_types::announce}, {"text", "You haven't learned that Metamagic option. Choose new options at level-up."}, {"interrupt", true}});
					return;
				}
			}
			// Clear all pending metamagic first (only one at a time per source, except Empowered/Seeking)
			bool was_active = false;
			if (option == "careful" and c.metamagic_careful_active) was_active = true;
			if (option == "distant" and c.metamagic_distant_active) was_active = true;
			if (option == "empowered" and c.metamagic_empowered_active) was_active = true;
			if (option == "extended" and c.metamagic_extended_active) was_active = true;
			if (option == "heightened" and c.metamagic_heightened_active) was_active = true;
			if (option == "quickened" and c.metamagic_quickened_active) was_active = true;
			if (option == "seeking" and c.metamagic_seeking_active) was_active = true;
			if (option == "subtle" and c.metamagic_subtle_active) was_active = true;
			if (option == "transmuted" and c.metamagic_transmuted_active) was_active = true;
			if (option == "twinned" and c.metamagic_twinned_active) was_active = true;
			if (was_active) {
				// Deactivate the toggled metamagic (refund SP)
				int refund = 1;
				if (option == "heightened" or option == "quickened") refund = 2;
				c.sorcery_points += refund;
				if (option == "careful") c.metamagic_careful_active = false;
				else if (option == "distant") c.metamagic_distant_active = false;
				else if (option == "empowered") c.metamagic_empowered_active = false;
				else if (option == "extended") c.metamagic_extended_active = false;
				else if (option == "heightened") c.metamagic_heightened_active = false;
				else if (option == "quickened") c.metamagic_quickened_active = false;
				else if (option == "seeking") c.metamagic_seeking_active = false;
				else if (option == "subtle") c.metamagic_subtle_active = false;
				else if (option == "transmuted") c.metamagic_transmuted_active = false;
				else if (option == "twinned") c.metamagic_twinned_active = false;
				u.room.bm.broadcast_announce(c.name + " deactivates Metamagic: " + option + ". (" + refund + " SP refunded, " + c.sorcery_points + " SP remain)", false);
				return;
			}
			// SP cost check
			int cost = 1;
			if (option == "heightened" or option == "quickened") cost = 2;
			if (c.sorcery_points < cost) { u.send({{"type", message_types::announce}, {"text", "Not enough Sorcery Points. Need " + cost + ", have " + c.sorcery_points + "."}, {"interrupt", true}}); return; }
			// Clear existing primary metamagic (not Empowered/Seeking which can stack per source).
			// PHB 2024 Sorcery Incarnate (para 7004-7006): while Innate Sorcery is active at L7+,
			// allow two metamagic options per spell. Count active primary metamagics and only
			// clear if at the limit (1 normally, 2 with Sorcery Incarnate).
			if (option != "empowered" and option != "seeking") {
				int active_count = 0;
				if (c.metamagic_careful_active) active_count++;
				if (c.metamagic_distant_active) active_count++;
				if (c.metamagic_extended_active) active_count++;
				if (c.metamagic_heightened_active) active_count++;
				if (c.metamagic_quickened_active) active_count++;
				if (c.metamagic_subtle_active) active_count++;
				if (c.metamagic_transmuted_active) active_count++;
				if (c.metamagic_twinned_active) active_count++;
				int max_primary = c.sorcery_incarnate_active ? 2 : 1;
				if (active_count >= max_primary) {
					c.metamagic_careful_active = false;
					c.metamagic_distant_active = false;
					c.metamagic_extended_active = false;
					c.metamagic_heightened_active = false;
					c.metamagic_quickened_active = false;
					c.metamagic_subtle_active = false;
					c.metamagic_transmuted_active = false;
					c.metamagic_twinned_active = false;
				}
			}
			// Deduct SP and activate
			c.sorcery_points -= cost;
			string label = option;
			if (option == "careful") { c.metamagic_careful_active = true; label = "Careful Spell"; }
			else if (option == "distant") { c.metamagic_distant_active = true; label = "Distant Spell"; }
			else if (option == "empowered") { c.metamagic_empowered_active = true; label = "Empowered Spell"; }
			else if (option == "extended") { c.metamagic_extended_active = true; label = "Extended Spell"; }
			else if (option == "heightened") { c.metamagic_heightened_active = true; label = "Heightened Spell"; }
			else if (option == "quickened") { c.metamagic_quickened_active = true; label = "Quickened Spell"; }
			else if (option == "seeking") { c.metamagic_seeking_active = true; label = "Seeking Spell"; }
			else if (option == "subtle") { c.metamagic_subtle_active = true; label = "Subtle Spell"; }
			else if (option == "transmuted") {
				c.metamagic_transmuted_active = true; label = "Transmuted Spell";
				// Transmuted target type sent by client
				int ttype = msg.exists("damage_type") ? int(msg["damage_type"]) : DMG_FIRE;
				c.metamagic_transmuted_target_type = ttype;
			}
			else if (option == "twinned") { c.metamagic_twinned_active = true; label = "Twinned Spell"; }
			else { u.send({{"type", message_types::announce}, {"text", "Unknown Metamagic option: " + option}, {"interrupt", true}}); c.sorcery_points += cost; return; }
			u.room.bm.broadcast_announce(c.name + " activates Metamagic: " + label + "! (" + cost + " SP spent, " + c.sorcery_points + " SP remain)", true);
		}
		else if (feature == "magical_cunning") {
			// PHB 2024 Warlock L2 Magical Cunning (paras 7782-7783): "You can perform an
			// esoteric rite for 1 minute. At the end of it, you regain expended Pact Magic
			// spell slots but no more than a number equal to half your maximum (round up).
			// Once you use this feature, you can't do so again until you finish a Long Rest."
			// L20 Eldritch Master (paras 7798-7799): "When you use your Magical Cunning
			// feature, you regain all your expended Pact Magic spell slots."
			// Implementation: in combat we collapse the 1-minute rite into a Magic action
			// since 10 rounds of standing still is functionally unusable; the per-LR cap
			// preserves source balance.
			if (c.class_name != "Warlock" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Only Warlocks of level 2 or higher can use Magical Cunning."}, {"interrupt", true}}); return; }
			if (!c.magical_cunning_available) { u.send({{"type", message_types::announce}, {"text", "Magical Cunning has been used; finish a Long Rest to recover it."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining (Magical Cunning takes a Magic action in combat)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.magical_cunning_available = false;
			// Find the Pact Magic slot level (Warlocks have all slots at one level — the
			// highest slot level whose max > 0).
			int pact_slot_level = 0;
			int pact_slot_max = 0;
			for (int sl = 5; sl >= 1; sl--) {
				if (c.spell_slots_max[sl] > 0) {
					pact_slot_level = sl;
					pact_slot_max = c.spell_slots_max[sl];
					break;
				}
			}
			if (pact_slot_level == 0) { u.send({{"type", message_types::announce}, {"text", "You have no Pact Magic slots."}, {"interrupt", true}}); return; }
			int slots_to_recover = (pact_slot_max + 1) / 2; // half max round up
			if (c.level >= 20) slots_to_recover = pact_slot_max; // Eldritch Master: all
			int actually_recovered = 0;
			while (actually_recovered < slots_to_recover and c.spell_slots_current[pact_slot_level] < pact_slot_max) {
				c.spell_slots_current[pact_slot_level]++;
				actually_recovered++;
			}
			string suffix = (c.level >= 20) ? " (Eldritch Master: all slots restored!)" : "";
			u.room.bm.broadcast_announce(c.name + " performs an esoteric rite — Magical Cunning restores " + actually_recovered + " level " + pact_slot_level + " Pact Magic slot" + (actually_recovered == 1 ? "" : "s") + "." + suffix, true);
		}
		else if (feature == "mystic_arcanum") {
			// PHB 2024 Warlock L11+ Mystic Arcanum (paras 7791-7795): "You can cast your
			// arcanum spell once without expending a spell slot, and you must finish a Long
			// Rest before you can cast it in this way again."
			// Gained at L11 (level 6 spell), L13 (7), L15 (8), L17 (9). The actual spell
			// chosen is a player choice; this handler just marks the per-level slot as used
			// and the client should pair it with a cast of the chosen Warlock spell.
			if (c.class_name != "Warlock") { u.send({{"type", message_types::announce}, {"text", "Only Warlocks have Mystic Arcanum."}, {"interrupt", true}}); return; }
			int arc_level = msg.exists("arc_level") ? int(msg["arc_level"]) : 6;
			if (arc_level < 6 or arc_level > 9) { u.send({{"type", message_types::announce}, {"text", "Mystic Arcanum is for spell levels 6-9."}, {"interrupt", true}}); return; }
			bool available = false;
			if (arc_level == 6 and c.mystic_arcanum_6_available) available = true;
			else if (arc_level == 7 and c.mystic_arcanum_7_available) available = true;
			else if (arc_level == 8 and c.mystic_arcanum_8_available) available = true;
			else if (arc_level == 9 and c.mystic_arcanum_9_available) available = true;
			if (!available) { u.send({{"type", message_types::announce}, {"text", "Your Mystic Arcanum (level " + arc_level + ") is unavailable or not yet unlocked."}, {"interrupt", true}}); return; }
			// Mark the arcanum as used. The actual spell cast must follow as a normal
			// action_cast — the player's chosen spell at that level is consumed without
			// spending a Pact Magic slot. We grant a temporary phantom slot of that level.
			if (arc_level == 6) c.mystic_arcanum_6_available = false;
			else if (arc_level == 7) c.mystic_arcanum_7_available = false;
			else if (arc_level == 8) c.mystic_arcanum_8_available = false;
			else if (arc_level == 9) c.mystic_arcanum_9_available = false;
			// Grant one phantom slot at the arcanum level so the next spell cast at that
			// level consumes the phantom slot instead of a real one.
			c.spell_slots_current[arc_level]++;
			if (c.spell_slots_max[arc_level] < c.spell_slots_current[arc_level]) c.spell_slots_max[arc_level] = c.spell_slots_current[arc_level];
			u.room.bm.broadcast_announce(c.name + " unlocks a Mystic Arcanum (level " + arc_level + " spell available without expending a Pact slot until next cast).", true);
		}
		else if (feature == "contact_patron") {
			// PHB 2024 Warlock L9 Contact Patron (paras 7788-7790): "you always have the
			// Contact Other Plane spell prepared. With this feature, you can cast the spell
			// without expending a spell slot to contact your patron, and you automatically
			// succeed on the spell's saving throw. Once you cast the spell with this feature,
			// you can't do so in this way again until you finish a Long Rest."
			if (c.class_name != "Warlock" or c.level < 9) { u.send({{"type", message_types::announce}, {"text", "Only Warlocks of level 9 or higher can Contact Patron."}, {"interrupt", true}}); return; }
			if (!c.contact_patron_available) { u.send({{"type", message_types::announce}, {"text", "Contact Patron has already been used; finish a Long Rest."}, {"interrupt", true}}); return; }
			c.contact_patron_available = false;
			u.room.bm.broadcast_announce(c.name + " contacts their patron — Contact Other Plane is cast without a slot, automatically succeeding on the save.", true);
		}
		else if (feature == "cunning_action") {
			if (c.class_name != "Rogue" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Cunning Action."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			string action = msg.exists("action") ? string(msg["action"]) : "dash";
			if (action == "dash") {
				c.movement_remaining += c.speed;
				u.room.bm.broadcast_announce(c.name + " uses Cunning Action: Dash! " + c.movement_remaining + " feet of movement.", false);
			} else if (action == "disengage") {
				c.took_disengage = true;
				u.room.bm.broadcast_announce(c.name + " uses Cunning Action: Disengage!", false);
			} else if (action == "hide") {
				u.room.bm.request_hide_check(u, c);
			} else {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "That is not a valid Cunning Action choice."}, {"interrupt", true}});
				return;
			}
		}
		else if (feature == "empowered_strikes_toggle") {
			// PHB 2024 Monk L6 Empowered Strikes (para 5350-5351): toggle Force/normal.
			// Free action toggle (no bonus action cost).
			if (!c.empowered_strikes_active) { u.send({{"type", message_types::announce}, {"text", "Empowered Strikes requires Monk level 6+."}, {"interrupt", true}}); return; }
			c.empowered_strikes_force = !c.empowered_strikes_force;
			string mode = c.empowered_strikes_force ? "Force" : "normal bludgeoning";
			u.room.bm.broadcast_announce(c.name + "'s Empowered Strikes set to " + mode + " damage.", false);
		}
		else if (feature == "flurry_of_blows") {
			// PHB 2024 Monk L2 Flurry of Blows (para 5329): "You can expend 1 Focus
			// Point to make two Unarmed Strikes as a Bonus Action."
			// PHB 2024 Monk L10 Heightened Focus (para 5359): "You can expend 1 Focus
			// Point to use Flurry of Blows and make three Unarmed Strikes with it
			// instead of two." Implemented by passing 2 chained strikes (instead of 1)
			// to start_flurry_strike when heightened_focus_active is true.
			if (c.class_name != "Monk" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Flurry of Blows."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "You need 1 Focus Point for Flurry of Blows."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "No target."}, {"interrupt", true}}); return; }
			int flurry_dist = feet_distance(c.x, c.y, target.x, target.y);
			if (flurry_dist > 5) { u.send({{"type", message_types::announce}, {"text", "Target must be within 5 feet for Flurry of Blows."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int flurry_chain = c.heightened_focus_active ? 2 : 1;
			if (!u.room.bm.start_flurry_strike(c, target, flurry_chain)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "You cannot make that Flurry attack right now."}, {"interrupt", true}});
				return;
			}
			c.focus_points--;
			// Xanathar's Drunken Master L3 Drunken Technique (para 1796-1797):
			// "When you use Flurry of Blows, you gain the benefit of the Disengage
			// action, and your walking speed increases by 10 feet until the end of
			// the current turn."
			if (c.drunken_technique_active) {
				c.took_disengage = true;
				c.movement_remaining += 10;
			}
			string flurry_msg = c.heightened_focus_active
				? c.name + " spends 1 Focus Point and unleashes Flurry of Blows for three strikes (Heightened Focus)!"
				: c.name + " spends 1 Focus Point and unleashes Flurry of Blows!";
			if (c.drunken_technique_active) flurry_msg += " Drunken Technique: Disengage + 10 ft speed!";
			u.room.bm.broadcast_announce(flurry_msg, true);
		}
		else if (feature == "patient_defense") {
			// PHB 2024 Monk L2 Patient Defense (para 5330): "You can take the Disengage
			// action as a Bonus Action. Alternatively, you can expend 1 Focus Point to
			// take both the Disengage and the Dodge actions as a Bonus Action."
			// PHB 2024 Monk L10 Heightened Focus (para 5360): "When you expend a Focus
			// Point to use Patient Defense, you gain a number of Temporary Hit Points
			// equal to two rolls of your Martial Arts die."
			if (c.class_name != "Monk" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Patient Defense."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			bool spend_focus = msg.exists("spend_focus") ? bool(msg["spend_focus"]) : (c.focus_points > 0);
			if (spend_focus and c.focus_points <= 0) spend_focus = false;
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Always Disengage component (no opportunity attacks for the rest of turn).
			c.took_disengage = true;
			if (spend_focus) {
				c.focus_points--;
				c.is_dodging = true;
				c.add_condition(COND_DODGING);
				string heightened_msg = "";
				if (c.heightened_focus_active) {
					int ma_die = u.room.bm.monk_martial_arts_die(c);
					int thp = random(1, ma_die) + random(1, ma_die);
					if (thp > c.temp_hp) c.temp_hp = thp;
					heightened_msg = " (Heightened Focus: " + thp + " temporary HP)";
				}
				u.room.bm.broadcast_announce(c.name + " uses Patient Defense, taking Disengage and Dodge as a bonus action!" + heightened_msg, true);
			} else {
				u.room.bm.broadcast_announce(c.name + " uses Patient Defense to Disengage as a bonus action.", true);
			}
		}
		else if (feature == "step_of_the_wind") {
			// PHB 2024 Monk L2 Step of the Wind (para 5331): "You can take the Dash
			// action as a Bonus Action. Alternatively, you can expend 1 Focus Point to
			// take both the Disengage and Dash actions as a Bonus Action, and your jump
			// distance is doubled for the turn."
			// PHB 2024 Monk L10 Heightened Focus (para 5361): "When you expend a Focus
			// Point to use Step of the Wind, you can choose a willing creature within
			// 5 feet of yourself that is Large or smaller. You move the creature with
			// you until the end of your turn. The creature's movement doesn't provoke
			// Opportunity Attacks." (Ally-move flag deferred — no targeting prompt.)
			if (c.class_name != "Monk" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Step of the Wind."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			bool spend_focus = msg.exists("spend_focus") ? bool(msg["spend_focus"]) : (c.focus_points > 0);
			if (spend_focus and c.focus_points <= 0) spend_focus = false;
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Dash component: double remaining movement for the turn.
			c.movement_remaining += c.speed;
			if (spend_focus) {
				c.focus_points--;
				c.took_disengage = true;
				u.room.bm.broadcast_announce(c.name + " uses Step of the Wind, gaining Dash and Disengage as a bonus action!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + " uses Step of the Wind to Dash as a bonus action.", true);
			}
		}
		else if (feature == "martial_arts_unarmed_strike") {
			// PHB 2024 Monk L1 Martial Arts (para 5319): "Bonus Unarmed Strike. You
			// can make an Unarmed Strike as a Bonus Action." Free; no Focus cost.
			if (c.class_name != "Monk") { u.send({{"type", message_types::announce}, {"text", "Only Monks have the Martial Arts bonus unarmed strike."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "No target."}, {"interrupt", true}}); return; }
			int ma_dist = feet_distance(c.x, c.y, target.x, target.y);
			if (ma_dist > 5) { u.send({{"type", message_types::announce}, {"text", "Target must be within 5 feet for Martial Arts strike."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			if (!u.room.bm.start_flurry_strike(c, target, 0)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "You cannot make that strike right now."}, {"interrupt", true}});
				return;
			}
			u.room.bm.broadcast_announce(c.name + " makes a Martial Arts Bonus Unarmed Strike!", true);
		}
		else if (feature == "uncanny_metabolism") {
			// PHB 2024 Monk L2 Uncanny Metabolism (para 5334-5336): "When you roll
			// Initiative, you can regain all expended Focus Points. When you do so,
			// roll your Martial Arts die, and regain a number of Hit Points equal to
			// your Monk level plus the number rolled. Once you use this feature, you
			// can't use it again until you finish a Long Rest."
			// Note: source ties this to initiative, but the simulator's initiative
			// roll happens before the player has any input. We expose it as a free
			// once-per-rest bonus action so the player can decide whether to spend it.
			if (c.class_name != "Monk" or c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Uncanny Metabolism."}, {"interrupt", true}}); return; }
			if (!c.uncanny_metabolism_available) { u.send({{"type", message_types::announce}, {"text", "Uncanny Metabolism is not available until your next long rest."}, {"interrupt", true}}); return; }
			c.uncanny_metabolism_available = false;
			int regained = c.focus_points_max - c.focus_points;
			if (regained < 0) regained = 0;
			c.focus_points = c.focus_points_max;
			int ma_die = u.room.bm.monk_martial_arts_die(c);
			int heal_amt = c.level + random(1, ma_die);
			int effective = u.room.bm.combat.apply_healing(c, heal_amt);
			u.room.bm.broadcast_announce(c.name + " channels Uncanny Metabolism, regaining " + regained + " Focus Point" + (regained == 1 ? "" : "s") + " and recovering " + effective + " HP.", true);
		}
		else if (feature == "superior_defense") {
			// PHB 2024 Monk L18 Superior Defense (para 5372-5373): "At the start of
			// your turn, you can expend 3 Focus Points to bolster yourself against harm
			// for 1 minute or until you have the Incapacitated condition. During that
			// time, you have Resistance to all damage except Force damage."
			if (c.class_name != "Monk" or c.level < 18) { u.send({{"type", message_types::announce}, {"text", "Your character cannot use Superior Defense."}, {"interrupt", true}}); return; }
			if (c.focus_points < 3) { u.send({{"type", message_types::announce}, {"text", "You need 3 Focus Points for Superior Defense."}, {"interrupt", true}}); return; }
			if (c.superior_defense_active) { u.send({{"type", message_types::announce}, {"text", "Superior Defense is already active."}, {"interrupt", true}}); return; }
			c.focus_points -= 3;
			c.superior_defense_active = true;
			c.superior_defense_rounds_remaining = 10; // 1 minute = 10 rounds
			u.room.bm.broadcast_announce(c.name + " expends 3 Focus Points and invokes Superior Defense — Resistance to all damage except Force for 1 minute!", true);
		}
		else if (feature == "bardic_inspiration") {
			if (c.class_name != "Bard") { u.send({{"type", message_types::announce}, {"text", "Only bards can grant Bardic Inspiration."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (u.room.bm.combat.mode == "pvp") { u.send({{"type", message_types::announce}, {"text", "Bardic Inspiration requires an ally in this simulator."}, {"interrupt", true}}); return; }
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose an ally for Bardic Inspiration."}, {"interrupt", true}}); return; }
			if (target.id == c.id) { u.send({{"type", message_types::announce}, {"text", "You cannot inspire yourself."}, {"interrupt", true}}); return; }
			if (target.is_player != c.is_player) { u.send({{"type", message_types::announce}, {"text", "Choose an ally for Bardic Inspiration."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 60) { u.send({{"type", message_types::announce}, {"text", "That ally is out of range for Bardic Inspiration."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0 or c.bardic_inspiration_grant_die <= 0) {
				u.send({{"type", message_types::announce}, {"text", "You have no Bardic Inspiration uses remaining."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			u.room.bm.clear_bardic_inspiration(target, false);
			target.bardic_inspiration_die = c.bardic_inspiration_grant_die;
			target.bardic_inspiration_source_id = c.id;
			u.room.bm.broadcast_announce(c.name + " grants Bardic Inspiration (" + u.room.bm.die_label(c.bardic_inspiration_grant_die) + ") to " + target.name + ". " + c.bardic_inspiration_uses + " use" + (c.bardic_inspiration_uses == 1 ? "" : "s") + " remain.", true);
		}
		else if (feature == "font_of_inspiration") {
			// PHB 2024 Bard L5 Font of Inspiration (paras 2753-2755): "you can expend a
			// spell slot (no action required) to regain one expended use of Bardic
			// Inspiration." No action cost.
			if (c.class_name != "Bard" or !c.font_of_inspiration_active) { u.send({{"type", message_types::announce}, {"text", "Only L5+ Bards can use Font of Inspiration."}, {"interrupt", true}}); return; }
			int max_uses = c.get_ability_mod(ABILITY_CHA);
			if (max_uses < 1) max_uses = 1;
			if (c.bardic_inspiration_uses >= max_uses) { u.send({{"type", message_types::announce}, {"text", "Bardic Inspiration is already at maximum."}, {"interrupt", true}}); return; }
			// Find the lowest-level spell slot available to expend.
			int spent_level = 0;
			for (int sl = 1; sl <= 9; sl++) {
				if (c.spell_slots_current[sl] > 0) { spent_level = sl; break; }
			}
			if (spent_level == 0) { u.send({{"type", message_types::announce}, {"text", "No spell slots available to expend."}, {"interrupt", true}}); return; }
			c.spell_slots_current[spent_level]--;
			c.bardic_inspiration_uses++;
			u.room.bm.broadcast_announce(c.name + " channels Font of Inspiration — expends a level " + spent_level + " spell slot to regain one Bardic Inspiration use (" + c.bardic_inspiration_uses + " now available).", true);
		}
		else if (feature == "spiritual_weapon_attack") {
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (!c.spiritual_weapon_active or c.spiritual_weapon_slot_level < 2) {
				u.send({{"type", message_types::announce}, {"text", "You do not currently have a Spiritual Weapon to command."}, {"interrupt", true}});
				return;
			}
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) {
				u.send({{"type", message_types::announce}, {"text", "Choose a valid target for Spiritual Weapon."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			if (!u.room.bm.start_spiritual_weapon_attack(c, target)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "Spiritual Weapon cannot strike that target right now."}, {"interrupt", true}});
				return;
			}
			u.room.bm.broadcast_announce(c.name + " commands Spiritual Weapon to strike " + target.name + "!", true);
		}
		else if (feature == "flaming_sphere_redamage") {
			// Basic Rules 2024 Flaming Sphere (para 13310-13312): "As a Bonus Action,
			// you can move the Sphere up to 30 feet, and when it moves within 5 feet
			// of a creature, that creature must make the save against the sphere."
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (!c.flaming_sphere_active or c.flaming_sphere_dice_count == 0) {
				u.send({{"type", message_types::announce}, {"text", "You don't have an active Flaming Sphere."}, {"interrupt", true}});
				return;
			}
			combatant@ fs_target = u.room.bm.combat.get_combatant(target_id);
			if (@fs_target == null or fs_target.is_dead) {
				u.send({{"type", message_types::announce}, {"text", "Choose a valid target for Flaming Sphere."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int fs_dmg = 0;
			for (int d = 0; d < c.flaming_sphere_dice_count; d++) fs_dmg += random(1, 6);
			int fs_dc = spell_save_dc(c);
			int fs_save = random(1, 20) + fs_target.get_save_bonus(ABILITY_DEX);
			bool fs_saved = fs_save >= fs_dc;
			int fs_final = fs_saved ? fs_dmg / 2 : fs_dmg;
			if (fs_final < 1) fs_final = 1;
			u.room.bm.broadcast_roll(fs_target.name, "DEX save vs Flaming Sphere (DC " + fs_dc + ")", fs_save - fs_target.get_save_bonus(ABILITY_DEX), fs_target.get_save_bonus(ABILITY_DEX), fs_save, fs_saved ? "Half damage!" : "Full damage!");
			u.room.bm.combat.apply_damage(fs_target, fs_final, DMG_FIRE, c);
			u.room.bm.broadcast_announce(c.name + "'s Flaming Sphere rams into " + fs_target.name + " for " + fs_final + " fire damage!", true);
			u.room.bm.check_concentration(fs_target, fs_final, c);
			u.room.bm.broadcast_state();
			if (fs_target.is_dead) u.room.bm.check_battle_end();
		}
		else if (feature == "heat_metal_redamage") {
			// Basic Rules 2024 Heat Metal (para 13734-13735): "Until the spell ends,
			// you can take a Bonus Action on each of your turns to cause this damage again."
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (!c.heat_metal_active or c.heat_metal_target_id == 0) {
				u.send({{"type", message_types::announce}, {"text", "You don't have an active Heat Metal to re-trigger."}, {"interrupt", true}});
				return;
			}
			combatant@ hm_target = u.room.bm.combat.get_combatant(c.heat_metal_target_id);
			if (@hm_target == null or hm_target.is_dead) {
				c.heat_metal_active = false;
				c.heat_metal_target_id = 0;
				u.send({{"type", message_types::announce}, {"text", "The Heat Metal target is no longer valid."}, {"interrupt", true}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int hm_dmg = 0;
			for (int d = 0; d < c.heat_metal_dice_count; d++) hm_dmg += random(1, 8);
			u.room.bm.combat.apply_damage(hm_target, hm_dmg, DMG_FIRE, c);
			u.room.bm.broadcast_announce(c.name + "'s Heat Metal sears " + hm_target.name + " again for " + hm_dmg + " fire damage!", true);
			// CON save or disadvantage (approximation via bane)
			int hm_save_roll = random(1, 20);
			int hm_save_bonus = hm_target.get_save_bonus(ABILITY_CON);
			int hm_dc = spell_save_dc(c);
			int hm_save_total = hm_save_roll + hm_save_bonus;
			if (hm_save_total < hm_dc) {
				hm_target.baned = true;
				u.room.bm.broadcast_announce(hm_target.name + " can't drop the searing metal! Disadvantage on attacks and ability checks.", true);
			}
			u.room.bm.check_concentration(hm_target, hm_dmg, c);
			u.room.bm.broadcast_state();
			if (hm_target.is_dead) u.room.bm.check_battle_end();
		}
		else if (feature == "wild_shape") {
			if (c.class_name != "Druid" or c.level < 2) {
				u.send({{"type", message_types::announce}, {"text", "Your character cannot use Wild Shape yet."}, {"interrupt", true}});
				return;
			}

			string form_id = msg.exists("form") ? string(msg["form"]) : "";
			if (form_id == "revert") {
				if (!c.wild_shape_active) {
					u.send({{"type", message_types::announce}, {"text", "You are not currently in Wild Shape."}, {"interrupt", true}});
					return;
				}
				if (!c.has_bonus_action) {
					u.send({{"type", message_types::announce}, {"text", "You need a bonus action to revert from Wild Shape."}, {"interrupt", true}});
					return;
				}
				c.has_bonus_action = false;
				c.used_bonus_action = true;
				string form_name = "beast form";
				monster_def@ current_form = c.wild_shape_form_id != "" ? get_monster_def(c.wild_shape_form_id) : null;
				if (@current_form != null) form_name = current_form.name;
				u.room.bm.combat.restore_wild_shape(c, 0);
				c.wild_shape_just_ended = false;
				u.room.bm.broadcast_announce(c.name + " reverts from " + form_name + " form.", true);
			} else {
				bool moon = c.subclass == "Circle of the Moon";
				if (moon) {
					if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
				} else {
					if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
				}

				monster_def@ form = get_wild_shape_form_for_combatant(c, form_id);
				if (@form == null) {
					u.send({{"type", message_types::announce}, {"text", "That Wild Shape form is not available to this druid."}, {"interrupt", true}});
					return;
				}

				if (moon) {
					c.has_bonus_action = false;
					c.used_bonus_action = true;
				} else {
					c.has_action = false;
					c.used_action = true;
					c.attacks_remaining_this_turn = 0;
				}

				if (c.wild_shape_active) {
					u.room.bm.combat.restore_wild_shape(c, 0);
					c.wild_shape_just_ended = false;
				}

				string base_name = c.name;
				apply_wild_shape_form(c, form);
				string cost_text = moon ? "bonus action" : "action";
				u.room.bm.broadcast_announce(base_name + " uses Wild Shape as a " + cost_text + " and becomes a " + form.name + "!", true);
			}
		}
		// ---- Subclass Bonus Actions ----

		else if (feature == "frenzy_attack") {
			// Berserker: bonus action melee attack while raging with Frenzy
			if (c.class_name != "Barbarian" or c.subclass != "Berserker") { u.send({{"type", message_types::announce}, {"text", "Only Berserker barbarians can use Frenzy Attack."}, {"interrupt", true}}); return; }
			if (!c.raging or !c.has_frenzy) { u.send({{"type", message_types::announce}, {"text", "You must be raging with Frenzy to use this."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "No valid target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 5) { u.send({{"type", message_types::announce}, {"text", "Target must be within 5 feet for Frenzy Attack."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Start a melee attack against the target (uses the existing flurry strike mechanism for bonus attacks)
			if (!u.room.bm.start_flurry_strike(c, target, 0)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				u.send({{"type", message_types::announce}, {"text", "Cannot make that attack right now."}, {"interrupt", true}});
				return;
			}
			u.room.bm.broadcast_announce(c.name + " makes a Frenzy attack!", true);
		}

		else if (feature == "channel_sacred_weapon") {
			// Devotion Paladin: Channel Divinity - Sacred Weapon
			if (c.class_name != "Paladin" or c.subclass != "Oath of Devotion") { u.send({{"type", message_types::announce}, {"text", "Only Devotion paladins can use Sacred Weapon."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.sacred_weapon_active) { u.send({{"type", message_types::announce}, {"text", "Sacred Weapon is already active."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.sacred_weapon_active = true;
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			if (cha_mod < 1) cha_mod = 1;
			u.room.bm.broadcast_announce(c.name + " channels Sacred Weapon! +" + cha_mod + " to attack rolls for 1 minute. " + c.channel_divinity_uses + " Channel Divinity use" + (c.channel_divinity_uses == 1 ? "" : "s") + " remain.", true);
		}

		else if (feature == "channel_vow_of_enmity") {
			// Vengeance Paladin: Channel Divinity - Vow of Enmity
			if (c.class_name != "Paladin" or c.subclass != "Oath of Vengeance") { u.send({{"type", message_types::announce}, {"text", "Only Vengeance paladins can use Vow of Enmity."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target for Vow of Enmity."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 10) { u.send({{"type", message_types::announce}, {"text", "Target must be within 10 feet."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.vow_of_enmity_target = target.id;
			u.room.bm.broadcast_announce(c.name + " swears a Vow of Enmity against " + target.name + "! Advantage on attack rolls against them. " + c.channel_divinity_uses + " Channel Divinity use" + (c.channel_divinity_uses == 1 ? "" : "s") + " remain.", true);
		}

		else if (feature == "channel_abjure_foes") {
			// PHB 2024 Paladin L9 Abjure Foes (para 5655-5657): Magic action, expend 1 CD.
			// Up to CHA mod (min 1) creatures within 60 ft make WIS save or Frightened 1 min.
			if (c.class_name != "Paladin") { u.send({{"type", message_types::announce}, {"text", "Only Paladins can use Abjure Foes."}, {"interrupt", true}}); return; }
			if (c.level < 9) { u.send({{"type", message_types::announce}, {"text", "Abjure Foes requires level 9."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining (Abjure Foes uses your action)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			int max_targets = cha_mod > 0 ? cha_mod : 1;
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_CHA);
			// Auto-target nearest hostiles within 60 ft
			combatant@[] candidates;
			for (uint ci = 0; ci < u.room.bm.combat.combatants.length(); ci++) {
				combatant@ t = u.room.bm.combat.combatants[ci];
				if (@t == null or t.is_dead or t.id == c.id) continue;
				if (!u.room.bm.combat.are_hostile(c, t)) continue;
				if (feet_distance(c.x, c.y, t.x, t.y) > 60) continue;
				candidates.insert_last(t);
			}
			int affected = 0;
			for (uint ci = 0; ci < candidates.length() and affected < max_targets; ci++) {
				combatant@ t = candidates[ci];
				int save_roll = random(1, 20);
				int save_bonus = t.get_save_bonus(ABILITY_WIS);
				int bless_bonus = u.room.bm.roll_bless_bonus(t);
				int save_total = save_roll + save_bonus + bless_bonus;
				bool saved = save_total >= save_dc;
				// Save failure chain (WIS — Mage Slayer applies)
				if (!saved and u.room.bm.try_arcane_deflection_save(t, save_dc, save_total)) saved = true;
				if (!saved) { int ds = u.room.bm.try_disciplined_survivor_reroll(t, save_dc, save_total, save_bonus + bless_bonus, "WIS save vs Abjure Foes"); if (ds >= save_dc) saved = true; }
				if (!saved) { int fg = u.room.bm.try_flash_of_genius(t, save_dc, save_total, "WIS save vs Abjure Foes"); if (fg >= save_dc) saved = true; }
				if (!saved) { int mv = u.room.bm.try_maverick_spirit(t, save_dc, save_total, "WIS save vs Abjure Foes"); if (mv >= save_dc) saved = true; }
				if (!saved and u.room.bm.try_mage_slayer_guarded_mind(t, ABILITY_WIS)) saved = true;
				if (!saved) { int bf = u.room.bm.try_boon_of_fate_bonus(t, save_total, save_dc); if (bf >= save_dc) saved = true; }
				if (!saved and u.room.bm.try_stroke_of_luck_save(t, save_dc, save_bonus + bless_bonus)) saved = true;
				u.room.bm.broadcast_roll(t.name, "WIS save vs Abjure Foes", save_roll, save_bonus + bless_bonus, save_total, saved ? "Saved!" : "Frightened!");
				if (!saved) {
					t.add_condition(COND_FRIGHTENED);
					t.frightened_source_id = c.id;
					u.room.bm.broadcast_to_battle({{"type", message_types::condition_applied}, {"target", t.name}, {"condition", "Frightened"}});
					affected++;
				}
			}
			u.room.bm.broadcast_announce(c.name + " channels Abjure Foes! " + affected + " creature" + (affected == 1 ? "" : "s") + " frightened. " + c.channel_divinity_uses + " Channel Divinity use" + (c.channel_divinity_uses == 1 ? "" : "s") + " remain.", true);
			u.room.bm.broadcast_state();
		}

		else if (feature == "channel_preserve_life") {
			// Life Cleric: Channel Divinity - Preserve Life
			if (c.class_name != "Cleric" or c.subclass != "Life Domain") { u.send({{"type", message_types::announce}, {"text", "Only Life Domain clerics can use Preserve Life."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining (Preserve Life uses your action)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int pool = c.level * 5;
			int total_healed = 0;
			// Heal allies below half HP within 30 feet
			for (uint pi = 0; pi < u.room.bm.combat.combatants.length(); pi++) {
				combatant@ ally = u.room.bm.combat.combatants[pi];
				if (@ally == null or ally.is_dead or !ally.is_player or ally.id == c.id) continue;
				if (u.room.bm.combat.are_hostile(c, ally)) continue;
				if (ally.current_hp >= ally.max_hp / 2) continue;
				int dist = feet_distance(c.x, c.y, ally.x, ally.y);
				if (dist > 30) continue;
				int deficit = (ally.max_hp / 2) - ally.current_hp;
				int heal_amount = deficit;
				if (heal_amount > pool) heal_amount = pool;
				if (heal_amount <= 0) continue;
				int healed = u.room.bm.combat.apply_healing(ally, heal_amount);
				u.room.bm.record_effective_healing(c.player_username, healed);
				pool -= heal_amount;
				total_healed += healed;
				u.room.bm.broadcast_announce(c.name + "'s Preserve Life heals " + ally.name + " for " + healed + " HP.", false);
				if (pool <= 0) break;
			}
			u.room.bm.broadcast_announce(c.name + " channels Preserve Life! Healed " + total_healed + " total HP among allies.", true);
		}

		else if (feature == "channel_natures_wrath") {
			// Ancients Paladin: Channel Divinity - Nature's Wrath (restrain a target)
			if (c.class_name != "Paladin" or c.subclass != "Oath of the Ancients") { u.send({{"type", message_types::announce}, {"text", "Only Ancients paladins can use Nature's Wrath."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target for Nature's Wrath."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 15) { u.send({{"type", message_types::announce}, {"text", "Target must be within 15 feet."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			// Target makes STR or DEX save (their choice, we use higher)
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_CHA);
			int str_save = random(1, 20) + target.get_save_bonus(ABILITY_STR);
			int dex_save = random(1, 20) + target.get_save_bonus(ABILITY_DEX);
			int save_total = str_save > dex_save ? str_save : dex_save;
			if (save_total < save_dc) {
				target.add_condition(COND_RESTRAINED);
				u.room.bm.broadcast_announce(c.name + "'s Nature's Wrath restrains " + target.name + " in spectral vines!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Nature's Wrath fails to restrain " + target.name + ".", true);
			}
		}

		else if (feature == "inspiring_smite") {
			// Glory Paladin: Channel Divinity - Inspiring Smite (temp HP to nearby allies)
			if (c.class_name != "Paladin" or c.subclass != "Oath of Glory") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Glory paladins can use Inspiring Smite."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			int total_temp_hp = random(1, 8) + random(1, 8) + c.level;
			int distributed = 0;
			for (uint pi = 0; pi < u.room.bm.combat.combatants.length(); pi++) {
				combatant@ ally = u.room.bm.combat.combatants[pi];
				if (@ally == null or ally.is_dead or ally.id == c.id) continue;
				if (ally.is_player != c.is_player) continue;
				int dist = feet_distance(c.x, c.y, ally.x, ally.y);
				if (dist > 30) continue;
				int share = total_temp_hp / 2;
				if (share < 1) share = 1;
				if (share > ally.temp_hp) {
					ally.temp_hp = share;
					distributed++;
					u.room.bm.broadcast_announce(ally.name + " receives " + share + " temporary HP from Inspiring Smite!", false);
				}
			}
			u.room.bm.broadcast_announce(c.name + " channels Inspiring Smite! " + distributed + " ally" + (distributed == 1 ? "" : "ies") + " empowered.", true);
		}

		else if (feature == "trip_attack") {
			// Battle Master: Trip Attack maneuver
			if (c.class_name != "Fighter" or c.subclass != "Battle Master") { u.send({{"type", message_types::announce}, {"text", "Only Battle Masters can use Trip Attack."}, {"interrupt", true}}); return; }
			if (c.superiority_dice <= 0) { u.send({{"type", message_types::announce}, {"text", "No superiority dice remaining."}, {"interrupt", true}}); return; }
			c.trip_attack_pending = true;
			u.room.bm.broadcast_announce(c.name + " prepares Trip Attack! Next weapon hit will add 1d8 damage and attempt to knock the target prone. (" + c.superiority_dice + " superiority dice remaining)", false);
		}

		else if (feature == "precision_attack") {
			// Battle Master: Precision Attack maneuver
			if (c.class_name != "Fighter" or c.subclass != "Battle Master") { u.send({{"type", message_types::announce}, {"text", "Only Battle Masters can use Precision Attack."}, {"interrupt", true}}); return; }
			if (c.superiority_dice <= 0) { u.send({{"type", message_types::announce}, {"text", "No superiority dice remaining."}, {"interrupt", true}}); return; }
			c.precision_attack_pending = true;
			u.room.bm.broadcast_announce(c.name + " prepares Precision Attack! Next attack roll will add 1d8. (" + c.superiority_dice + " superiority dice remaining)", false);
		}

		else if (feature == "riposte") {
			// Battle Master: Riposte maneuver (readied reaction)
			if (c.class_name != "Fighter" or c.subclass != "Battle Master") { u.send({{"type", message_types::announce}, {"text", "Only Battle Masters can use Riposte."}, {"interrupt", true}}); return; }
			if (c.superiority_dice <= 0) { u.send({{"type", message_types::announce}, {"text", "No superiority dice remaining."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			c.riposte_ready = true;
			u.room.bm.broadcast_announce(c.name + " readies Riposte! If an enemy misses, " + c.name + " will counterattack with an extra 1d8 damage.", false);
		}

		else if (feature == "shadow_step") {
			// Shadow Monk: teleport 60 ft to dim/dark location, advantage on next melee
			if (c.class_name != "Monk" or c.subclass != "Way of Shadow") { u.send({{"type", message_types::announce}, {"text", "Only Shadow monks can use Shadow Step."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Shadow Step requires level 6."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target to teleport near."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 60) { u.send({{"type", message_types::announce}, {"text", "Target is too far for Shadow Step (60 ft max)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Teleport adjacent to target
			int new_x = target.x;
			int new_y = target.y + 1;
			c.x = new_x;
			c.y = new_y;
			u.room.bm.broadcast_announce(c.name + " Shadow Steps to " + target.name + "! Advantage on next melee attack.", true);
		}

		else if (feature == "hands_of_healing") {
			// Mercy Monk: Hands of Healing
			if (c.class_name != "Monk" or c.subclass != "Way of Mercy") { u.send({{"type", message_types::announce}, {"text", "Only Mercy monks can use Hands of Healing."}, {"interrupt", true}}); return; }
			if (c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Hands of Healing requires level 3."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "You need 1 Focus Point."}, {"interrupt", true}}); return; }
			combatant@ target = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a valid target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 5 and target.id != c.id) { u.send({{"type", message_types::announce}, {"text", "Target must be within 5 feet."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.focus_points--;
			int martial_die = 4;
			if (c.level >= 17) martial_die = 12;
			else if (c.level >= 11) martial_die = 10;
			else if (c.level >= 5) martial_die = 8;
			else martial_die = 6;
			int heal = random(1, martial_die) + c.get_ability_mod(ABILITY_WIS);
			if (heal < 1) heal = 1;
			int effective = u.room.bm.combat.apply_healing(target, heal);
			u.room.bm.record_effective_healing(c.player_username, effective);
			u.room.bm.broadcast_announce(c.name + " uses Hands of Healing on " + target.name + ", restoring " + effective + " HP.", true);
		}

		else if (feature == "elemental_burst") {
			// Elements Monk: Elemental Burst (AoE ki attack)
			if (c.class_name != "Monk" or c.subclass != "Way of the Four Elements") { u.send({{"type", message_types::announce}, {"text", "Only Elements monks can use Elemental Burst."}, {"interrupt", true}}); return; }
			if (c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Elemental Burst requires level 3."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.focus_points < 2) { u.send({{"type", message_types::announce}, {"text", "You need 2 Focus Points."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 20) { u.send({{"type", message_types::announce}, {"text", "Target must be within 20 feet."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.focus_points -= 2;
			int martial_die = 6;
			if (c.level >= 17) martial_die = 12;
			else if (c.level >= 11) martial_die = 10;
			else if (c.level >= 5) martial_die = 8;
			int damage = random(1, martial_die) + random(1, martial_die) + c.get_ability_mod(ABILITY_WIS);
			if (damage < 1) damage = 1;
			// DEX save for half
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int save_roll = random(1, 20) + target.get_save_bonus(ABILITY_DEX);
			if (save_roll >= save_dc) damage = damage / 2;
			u.room.bm.combat.apply_damage(target, damage, DMG_FIRE, c);
			u.room.bm.broadcast_announce(c.name + " unleashes Elemental Burst on " + target.name + " for " + damage + " elemental damage!" + (save_roll >= save_dc ? " (saved for half)" : ""), true);
		}

		else if (feature == "healing_light") {
			// Celestial Warlock: Healing Light
			if (c.class_name != "Warlock" or c.subclass != "Celestial Patron") { u.send({{"type", message_types::announce}, {"text", "Only Celestial warlocks can use Healing Light."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.healing_light_dice <= 0) { u.send({{"type", message_types::announce}, {"text", "No Healing Light dice remaining."}, {"interrupt", true}}); return; }
			combatant@ target = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a valid target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 60 and target.id != c.id) { u.send({{"type", message_types::announce}, {"text", "Target must be within 60 feet."}, {"interrupt", true}}); return; }
			int dice_to_use = msg.exists("dice_count") ? int(msg["dice_count"]) : 1;
			int max_dice = c.get_ability_mod(ABILITY_CHA);
			if (max_dice < 1) max_dice = 1;
			if (dice_to_use > max_dice) dice_to_use = max_dice;
			if (dice_to_use > c.healing_light_dice) dice_to_use = c.healing_light_dice;
			if (dice_to_use < 1) dice_to_use = 1;
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.healing_light_dice -= dice_to_use;
			int heal = 0;
			for (int di = 0; di < dice_to_use; di++) heal += random(1, 6);
			int effective = u.room.bm.combat.apply_healing(target, heal);
			u.room.bm.record_effective_healing(c.player_username, effective);
			u.room.bm.broadcast_announce(c.name + " uses Healing Light (" + dice_to_use + "d6) on " + target.name + ", restoring " + effective + " HP. " + c.healing_light_dice + " dice remain.", true);
		}

		else if (feature == "fey_presence") {
			// Archfey Warlock: Fey Presence (charm/frighten enemies in 10ft)
			if (c.class_name != "Warlock" or c.subclass != "Archfey Patron") { u.send({{"type", message_types::announce}, {"text", "Only Archfey warlocks can use Fey Presence."}, {"interrupt", true}}); return; }
			if (c.fey_presence_used) { u.send({{"type", message_types::announce}, {"text", "You have already used Fey Presence this battle."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.fey_presence_used = true;
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_CHA);
			int affected = 0;
			for (uint pi = 0; pi < u.room.bm.combat.combatants.length(); pi++) {
				combatant@ enemy = u.room.bm.combat.combatants[pi];
				if (@enemy == null or enemy.is_dead or enemy.id == c.id) continue;
				if (!u.room.bm.combat.are_hostile(c, enemy)) continue;
				int dist = feet_distance(c.x, c.y, enemy.x, enemy.y);
				if (dist > 10) continue;
				int save_roll = random(1, 20) + enemy.get_save_bonus(ABILITY_WIS);
				if (save_roll < save_dc) {
					enemy.add_condition(COND_CHARMED);
					affected++;
					u.room.bm.broadcast_announce(enemy.name + " is charmed by " + c.name + "'s Fey Presence!", false);
				}
			}
			u.room.bm.broadcast_announce(c.name + " unleashes Fey Presence! " + affected + " creature" + (affected == 1 ? "" : "s") + " charmed.", true);
		}

		else if (feature == "mantle_of_inspiration") {
			// Xanathar's Glamour Bard L3 Mantle of Inspiration (para 549-552): "each of
			// them gains 5 temporary hit points... increasing to 8 at 5th level, 11 at
			// 10th level, and 14 at 15th level." Costs 1 Bardic Inspiration use.
			if (c.class_name != "Bard" or c.subclass != "College of Glamour") { u.send({{"type", message_types::announce}, {"text", "Only Glamour bards can use Mantle of Inspiration."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Bardic Inspiration uses remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			int temp_hp = 5;
			if (c.level >= 15) temp_hp = 14;
			else if (c.level >= 10) temp_hp = 11;
			else if (c.level >= 5) temp_hp = 8;
			int allies_affected = 0;
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			int max_allies = cha_mod > 0 ? cha_mod : 1;
			for (uint pi = 0; pi < u.room.bm.combat.combatants.length(); pi++) {
				if (allies_affected >= max_allies) break;
				combatant@ ally = u.room.bm.combat.combatants[pi];
				if (@ally == null or ally.is_dead or !ally.is_player) continue;
				if (u.room.bm.combat.are_hostile(c, ally)) continue;
				int dist = feet_distance(c.x, c.y, ally.x, ally.y);
				if (dist > 60) continue;
				if (ally.temp_hp < temp_hp) ally.temp_hp = temp_hp;
				allies_affected++;
			}
			u.room.bm.broadcast_announce(c.name + " inspires with Mantle of Inspiration! " + allies_affected + " allies gain " + temp_hp + " temporary HP.", true);
		}

		else if (feature == "psychic_blades") {
			// Soulknife Rogue: Psychic Blades (bonus action attack with psychic blade)
			if (c.class_name != "Rogue" or c.subclass != "Soulknife") { u.send({{"type", message_types::announce}, {"text", "Only Soulknife rogues can use Psychic Blades."}, {"interrupt", true}}); return; }
			if (c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Psychic Blades requires level 3."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > 60) { u.send({{"type", message_types::announce}, {"text", "Target must be within 60 feet."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Psychic blade bonus attack: d4 + DEX/STR
			int atk_mod = c.get_ability_mod(ABILITY_DEX);
			int str_mod = c.get_ability_mod(ABILITY_STR);
			if (str_mod > atk_mod) atk_mod = str_mod;
			int atk_bonus = atk_mod + c.proficiency;
			int atk_roll = random(1, 20);
			int total = atk_roll + atk_bonus;
			bool hit = (atk_roll == 20) or (atk_roll != 1 and total >= target.armor_class);
			if (hit) {
				int dmg = random(1, 4) + atk_mod;
				if (dmg < 1) dmg = 1;
				if (atk_roll == 20) dmg += random(1, 4); // crit
				u.room.bm.combat.apply_damage(target, dmg, DMG_PSYCHIC, c);
				u.room.bm.broadcast_roll(c.name, "Psychic Blade attack", atk_roll, atk_bonus, total, "Hit!");
				u.room.bm.broadcast_announce(c.name + "'s Psychic Blade deals " + dmg + " psychic damage to " + target.name + "!", false);
			} else {
				u.room.bm.broadcast_roll(c.name, "Psychic Blade attack", atk_roll, atk_bonus, total, "Miss!");
			}
		}

		else if (feature == "war_priest_attack") {
			// War Cleric: War Priest bonus action attack
			if (c.class_name != "Cleric" or c.subclass != "War Domain") { u.send({{"type", message_types::announce}, {"text", "Only War Domain clerics can use War Priest."}, {"interrupt", true}}); return; }
			if (c.war_priest_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No War Priest uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action."}, {"interrupt", true}}); return; }
			combatant@ target = u.room.bm.combat.get_combatant(target_id);
			if (@target == null or target.is_dead) { u.send({{"type", message_types::announce}, {"text", "No valid target."}, {"interrupt", true}}); return; }
			int dist = feet_distance(c.x, c.y, target.x, target.y);
			if (dist > c.main_hand_range) { u.send({{"type", message_types::announce}, {"text", "Target out of weapon range."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.war_priest_uses--;
			// Make a weapon attack
			if (!u.room.bm.start_flurry_strike(c, target, 0)) {
				c.has_bonus_action = true;
				c.used_bonus_action = false;
				c.war_priest_uses++;
				u.send({{"type", message_types::announce}, {"text", "Cannot make that attack right now."}, {"interrupt", true}});
				return;
			}
			u.room.bm.broadcast_announce(c.name + " invokes War Priest for a bonus weapon attack! " + c.war_priest_uses + " use" + (c.war_priest_uses == 1 ? "" : "s") + " remain.", true);
		}

		else if (feature == "warding_flare") {
			// Light Cleric: Warding Flare (reaction - impose disadvantage on attacker)
			if (c.class_name != "Cleric" or c.subclass != "Light Domain") { u.send({{"type", message_types::announce}, {"text", "Only Light Domain clerics can use Warding Flare."}, {"interrupt", true}}); return; }
			if (c.warding_flare_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Warding Flare uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			c.warding_flare_uses--;
			u.room.bm.broadcast_announce(c.name + " readies Warding Flare! The next attack against them or an ally within 30 feet has disadvantage. " + c.warding_flare_uses + " use" + (c.warding_flare_uses == 1 ? "" : "s") + " remain.", false);
		}

		// === New Subclass Bonus Actions ===
		else if (feature == "planar_warrior") {
			// Horizon Walker Ranger: next weapon attack deals force damage + 1d8
			if (c.class_name != "Ranger" or c.subclass != "Horizon Walker") { u.send({{"type", message_types::announce}, {"text", "Only Horizon Walkers can use Planar Warrior."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.planar_warrior_active = true;
			u.room.bm.broadcast_announce(c.name + " marks a target for Planar Warrior! Next weapon attack deals bonus force damage.", false);
		}

		else if (feature == "path_to_grave") {
			// Xanathar's Grave Domain L2 Path to the Grave (para 794-796): "As an action,
			// you choose one creature you can see within 30 feet, cursing it until the end
			// of your next turn. The next time you or an ally hits the cursed creature with
			// an attack, the creature has vulnerability to all of that attack's damage."
			if (c.class_name != "Cleric" or c.subclass != "Grave Domain") { u.send({{"type", message_types::announce}, {"text", "Only Grave Domain clerics can use Path to the Grave."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			combatant@ ptg_target = u.room.bm.combat.get_combatant(target_id);
			if (@ptg_target == null) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			c.path_to_grave_target = target_id;
			ptg_target.path_to_grave_vulnerable = true;
			u.room.bm.broadcast_announce(c.name + " curses " + ptg_target.name + " with Path to the Grave! Next attack deals double damage.", true);
		}

		else if (feature == "hexblades_curse") {
			// Xanathar's Hexblade L1 Hexblade's Curse (para 2779-2784): "As a bonus action,
			// choose one creature you can see within 30 feet. The target is cursed. You gain
			// bonus to damage rolls against the cursed target equal to your proficiency bonus.
			// Attack rolls against the cursed target score a critical hit on 19 or 20.
			// If the cursed target dies, you regain hit points." 1/short or long rest.
			if (c.class_name != "Warlock" or c.subclass != "The Hexblade") { u.send({{"type", message_types::announce}, {"text", "Only Hexblade warlocks can use Hexblade's Curse."}, {"interrupt", true}}); return; }
			if (c.hexblade_curse_used) { u.send({{"type", message_types::announce}, {"text", "Hexblade's Curse already used this encounter."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.hexblade_curse_used = true;
			c.hexblade_curse_target = target_id;
			u.room.bm.broadcast_announce(c.name + " places Hexblade's Curse! +" + c.proficiency + " damage and crit on 19-20 vs target. Heal " + (c.level + c.get_ability_mod(ABILITY_CHA)) + " HP on kill.", true);
		}

		else if (feature == "fighting_spirit") {
			// Samurai Fighter: bonus action gives advantage on attacks + temp HP
			if (c.class_name != "Fighter" or c.subclass != "Samurai") { u.send({{"type", message_types::announce}, {"text", "Only Samurai can use Fighting Spirit."}, {"interrupt", true}}); return; }
			if (c.fighting_spirit_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Fighting Spirit uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.fighting_spirit_uses--;
			c.fighting_spirit_active = true;
			int temp_hp = 5;
			if (c.level >= 10) temp_hp = 10;
			if (c.level >= 15) temp_hp = 15;
			if (c.temp_hp < temp_hp) c.temp_hp = temp_hp;
			u.room.bm.broadcast_announce(c.name + " invokes Fighting Spirit! Advantage on attacks this turn and " + temp_hp + " temp HP.", true);
		}

		else if (feature == "symbiotic_entity") {
			// Circle of Spores Druid: expend Wild Shape use to gain +1d6 necrotic on attacks + temp HP
			if (c.class_name != "Druid" or c.subclass != "Circle of Spores") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Spores druids can use Symbiotic Entity."}, {"interrupt", true}}); return; }
			if (c.symbiotic_entity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Symbiotic Entity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.symbiotic_entity_uses--;
			c.symbiotic_entity_active = true;
			int temp_hp = 4 * c.level;
			if (c.temp_hp < temp_hp) c.temp_hp = temp_hp;
			u.room.bm.broadcast_announce(c.name + " activates Symbiotic Entity! Gains " + temp_hp + " temp HP and +1d6 necrotic on melee attacks.", true);
		}

		else if (feature == "blade_flourish") {
			// Xanathar's College of Swords L3 Blade Flourish (para 586-591)
			if (c.class_name != "Bard" or c.subclass != "College of Swords") { u.send({{"type", message_types::announce}, {"text", "Only College of Swords bards can use Blade Flourish."}, {"interrupt", true}}); return; }
			// Xanathar's L14 Master's Flourish (para 594-595): "you can roll a d6
			// and use it instead of expending a Bardic Inspiration die."
			bool masters = (c.level >= 14);
			if (!masters and c.bardic_inspiration_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Bardic Inspiration uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			if (!masters) c.bardic_inspiration_uses--;
			c.blade_flourish_active = true;
			c.masters_flourish_free = masters;
			string fl_msg = masters ? " prepares a Master's Flourish! (free d6, no BI spent)" : " prepares a Blade Flourish! Next weapon attack gets bonus damage.";
			u.room.bm.broadcast_announce(c.name + fl_msg, true);
		}

		else if (feature == "psychic_blades") {
			// College of Whispers Bard: next weapon attack adds psychic damage
			if (c.class_name != "Bard" or c.subclass != "College of Whispers") { u.send({{"type", message_types::announce}, {"text", "Only College of Whispers bards can use Psychic Blades."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Bardic Inspiration uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			c.psychic_blades_pending = true;
			u.room.bm.broadcast_announce(c.name + " readies Psychic Blades! Next weapon attack deals bonus psychic damage.", true);
		}

		else if (feature == "cavalier_retaliation") {
			// Xanathar's Cavalier L3 Unwavering Mark retaliation BA (para 1671-1672):
			// "you can make a special melee weapon attack against the marked creature as
			// a bonus action on your next turn. You have advantage on the attack roll, and
			// if it hits, the attack's weapon deals extra damage equal to half your fighter
			// level, rounded down."
			if (c.class_name != "Fighter" or c.subclass != "Cavalier") { u.send({{"type", message_types::announce}, {"text", "Only Cavaliers can retaliate."}, {"interrupt", true}}); return; }
			if (!c.cavalier_retaliation_available) { u.send({{"type", message_types::announce}, {"text", "No retaliation available — a marked creature must damage an ally first."}, {"interrupt", true}}); return; }
			if (c.unwavering_mark_ba_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Unwavering Mark uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ ret_target = u.room.bm.combat.get_combatant(c.cavalier_retaliation_target);
			if (@ret_target == null or ret_target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Retaliation target is gone."}, {"interrupt", true}}); return; }
			// Check melee range (5ft)
			float ret_dist = sqrt(float(c.x - ret_target.x) * float(c.x - ret_target.x) + float(c.y - ret_target.y) * float(c.y - ret_target.y)) * 5.0f;
			if (ret_dist > 5) { u.send({{"type", message_types::announce}, {"text", "Target not within melee range (5 ft). Move closer first."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.cavalier_retaliation_available = false;
			c.unwavering_mark_ba_uses--;
			// Roll attack with advantage
			int roll1 = random(1, 20);
			int roll2 = random(1, 20);
			int nat = roll1 > roll2 ? roll1 : roll2;
			int atk_mod = c.get_ability_mod(ABILITY_STR) + c.proficiency;
			int atk_total = nat + atk_mod;
			bool ret_hit = atk_total >= ret_target.armor_class or nat == 20;
			bool ret_crit = nat >= u.room.bm.get_critical_threshold(c);
			string ret_outcome = ret_hit ? (ret_crit ? "Critical hit!" : "Hit!") : "Miss.";
			u.room.bm.broadcast_roll(c.name, "Unwavering Mark retaliation vs " + ret_target.name + " (advantage)", nat, atk_mod, atk_total, ret_outcome);
			if (ret_hit) {
				int dmg_count = ret_crit ? 2 : 1;
				int dmg_sides = u.room.bm.get_attack_damage_dice(c, false);
				int dmg = 0;
				for (int di = 0; di < dmg_count; di++) dmg += random(1, dmg_sides);
				dmg += c.get_ability_mod(ABILITY_STR);
				int bonus_dmg = c.level / 2;
				dmg += bonus_dmg;
				if (dmg < 1) dmg = 1;
				int dmg_type = u.room.bm.get_attack_damage_type(c, false);
				u.room.bm.combat.apply_damage(ret_target, dmg, dmg_type, c);
				u.room.bm.broadcast_announce(c.name + "'s Unwavering Mark retaliation hits " + ret_target.name + " for " + dmg + " damage (+" + bonus_dmg + " bonus)! (" + c.unwavering_mark_ba_uses + "/" + c.unwavering_mark_ba_uses_max + " uses remaining)", true);
				if (ret_target.is_dead) {
					u.room.bm.broadcast_to_battle({{"type", message_types::creature_died}, {"name", ret_target.name}, {"is_player", ret_target.is_player}, {"killed_by", c.name}, {"was_full_hp", false}, {"was_overkill", false}, {"was_stealth", false}});
					u.room.bm.maybe_apply_on_kill_features(c, ret_target);
				}
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Unwavering Mark retaliation misses " + ret_target.name + ".", false);
			}
			u.room.bm.broadcast_state();
		}

		else if (feature == "balm_of_summer_court") {
			// Xanathar's Circle of Dreams L2 Balm of the Summer Court (paras 883-886):
			// "spend a number of those dice equal to half your druid level or less.
			// Roll the spent dice and add them together. The target regains a number of
			// hit points equal to the total. The target also gains 1 temporary hit point
			// per die spent."
			if (c.class_name != "Druid" or c.subclass != "Circle of Dreams") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Dreams druids can use Balm of the Summer Court."}, {"interrupt", true}}); return; }
			if (c.balm_of_summer_pool <= 0) { u.send({{"type", message_types::announce}, {"text", "Your Balm pool is empty."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			int max_dice = c.level / 2;
			if (max_dice < 1) max_dice = 1;
			int dice_count = 1;
			if (msg.exists("dice_count")) dice_count = int(msg["dice_count"]);
			if (dice_count < 1) dice_count = 1;
			if (dice_count > max_dice) dice_count = max_dice;
			if (dice_count > c.balm_of_summer_pool) dice_count = c.balm_of_summer_pool;
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.balm_of_summer_pool -= dice_count;
			int heal = 0;
			for (int bd = 0; bd < dice_count; bd++) heal += random(1, 6);
			int effective = u.room.bm.combat.apply_healing(tgt, heal);
			u.room.bm.record_effective_healing(c.player_username, effective);
			// +1 temp HP per die spent
			int balm_temp = dice_count;
			if (tgt.temp_hp < balm_temp) tgt.temp_hp = balm_temp;
			u.room.bm.broadcast_announce(c.name + " channels Balm of the Summer Court (" + dice_count + "d6)! " + tgt.name + " healed for " + heal + " and gains " + balm_temp + " temp HP.", true);
		}

		else if (feature == "hidden_paths") {
			// Xanathar's Circle of Dreams L10 Hidden Paths (paras 891-893):
			// "As a bonus action on your turn, you can teleport up to 60 feet to an
			// unoccupied space you can see."
			if (c.class_name != "Druid" or c.subclass != "Circle of Dreams") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Dreams druids can use Hidden Paths."}, {"interrupt", true}}); return; }
			if (c.level < 10) { u.send({{"type", message_types::announce}, {"text", "Hidden Paths requires level 10."}, {"interrupt", true}}); return; }
			if (c.hidden_paths_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Hidden Paths uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.hidden_paths_uses--;
			// Teleport 60ft (12 tiles) toward current target or random direction
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			int new_x = c.x;
			int new_y = c.y;
			if (@tgt != null and !tgt.is_dead) {
				int dx = tgt.x - c.x;
				int dy = tgt.y - c.y;
				if (dx != 0) dx = dx > 0 ? 1 : -1;
				if (dy != 0) dy = dy > 0 ? 1 : -1;
				new_x = c.x + dx * 12;
				new_y = c.y + dy * 12;
			} else {
				new_x = c.x + random(-12, 12);
				new_y = c.y + random(-12, 12);
			}
			if (new_x < 0) new_x = 0;
			if (new_x >= u.room.bm.combat.map_width) new_x = u.room.bm.combat.map_width - 1;
			if (new_y < 0) new_y = 0;
			if (new_y >= u.room.bm.combat.map_height) new_y = u.room.bm.combat.map_height - 1;
			c.x = new_x;
			c.y = new_y;
			u.room.bm.broadcast_announce(c.name + " steps through Hidden Paths and teleports 60 feet! (" + c.hidden_paths_uses + " uses remaining)", true);
			u.room.bm.broadcast_state();
		}

		else if (feature == "zealous_presence") {
			// Xanathar's Zealot L10 Zealous Presence (para 445-447): "As a bonus action,
			// you unleash a battle cry infused with divine energy. Up to ten other creatures
			// of your choice within 60 feet of you that can hear you gain advantage on
			// attack rolls and saving throws until the start of your next turn."
			if (c.class_name != "Barbarian" or c.subclass != "Zealot" or c.level < 10) {
				u.send({{"type", message_types::announce}, {"text", "Only Zealot Barbarians level 10+ can use Zealous Presence."}, {"interrupt", true}}); return;
			}
			if (!c.zealous_presence_available) {
				u.send({{"type", message_types::announce}, {"text", "Zealous Presence already used (1/long rest)."}, {"interrupt", true}}); return;
			}
			if (!c.has_bonus_action) {
				u.send({{"type", message_types::announce}, {"text", "No bonus action available."}, {"interrupt", true}}); return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.zealous_presence_available = false;
			int zp_count = 0;
			for (uint zpi = 0; zpi < u.room.bm.combat.combatants.length(); zpi++) {
				combatant@ ally = u.room.bm.combat.combatants[zpi];
				if (@ally == null or ally.is_dead or ally.id == c.id) continue;
				if (ally.is_player != c.is_player) continue; // allies only
				if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) continue;
				if (zp_count >= 10) break;
				ally.zealous_presence_buff_active = true;
				ally.zealous_presence_source_id = c.id;
				zp_count++;
			}
			u.room.bm.broadcast_announce(c.name + "'s Zealous Presence inspires " + zp_count + " allies! Advantage on attacks and saves until the start of " + c.name + "'s next turn.", true);
		}

		else if (feature == "guided_strike") {
			// Oath of Conquest Paladin: Channel Divinity — +10 to one attack roll
			if (c.class_name != "Paladin" or c.subclass != "Oath of Conquest") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Conquest paladins can use Guided Strike."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.guided_strike_pending = true;
			u.room.bm.broadcast_announce(c.name + " invokes Guided Strike! Next attack gets +10 bonus.", true);
		}

		else if (feature == "conquering_presence") {
			// Xanathar's Oath of Conquest L3 Conquering Presence (para 1988-1991):
			// "each creature of your choice that you can see within 30 feet of you
			// must make a Wisdom saving throw. On a failed save, a creature becomes
			// frightened of you for 1 minute."
			if (c.class_name != "Paladin" or c.subclass != "Oath of Conquest") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Conquest paladins can use Conquering Presence."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.channel_divinity_uses--;
			int cp_dc = spell_save_dc(c);
			int cp_hit = 0;
			for (uint cpi = 0; cpi < u.room.bm.combat.combatants.length(); cpi++) {
				combatant@ t = u.room.bm.combat.combatants[cpi];
				if (@t == null or t.is_dead or t.id == c.id) continue;
				if (t.is_player == c.is_player) continue;
				if (feet_distance(c.x, c.y, t.x, t.y) > 30) continue;
				int sr = random(1, 20);
				int sb = t.get_save_bonus(ABILITY_WIS);
				int st = sr + sb;
				bool saved = st >= cp_dc;
				u.room.bm.broadcast_roll(t.name, "WIS save vs Conquering Presence", sr, sb, st, saved ? "Resists!" : "Frightened!");
				if (!saved) { t.add_condition(COND_FRIGHTENED); t.frightened_source_id = c.id; cp_hit++; }
			}
			u.room.bm.broadcast_announce(c.name + "'s Conquering Presence frightens " + cp_hit + " creature(s)!", true);
		}

		else if (feature == "wrath_of_storms") {
			// Storm Sorcerer: Wrath of the Storms - reaction - deal lightning/thunder damage when hit
			// Implemented as on-hit passive (see damage application)
			u.send({{"type", message_types::announce}, {"text", "Wrath of the Storms triggers automatically when hit by melee attack."}, {"interrupt", true}});
		}

		else if (feature == "invincible_conqueror") {
			// Xanathar's Oath of Conquest L20 Invincible Conqueror (para 1998-2003):
			// "you gain resistance to all damage. When you take the Attack action,
			// you can make one additional weapon attack. Your melee weapon attacks
			// score a critical hit on a roll of 19 or 20." 1 min, 1/LR.
			if (c.class_name != "Paladin" or c.subclass != "Oath of Conquest" or c.level < 20) { u.send({{"type", message_types::announce}, {"text", "Requires Oath of Conquest Paladin level 20."}, {"interrupt", true}}); return; }
			if (c.invincible_conqueror_used) { u.send({{"type", message_types::announce}, {"text", "Invincible Conqueror already used this long rest."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.invincible_conqueror_used = true;
			c.invincible_conqueror_active = true;
			c.invincible_conqueror_rounds = 10;
			c.extra_attacks++;
			u.room.bm.broadcast_announce(c.name + " becomes an Invincible Conqueror! Resistance to all damage, extra attack, crit on 19-20 for 1 minute.", true);
		}

		else if (feature == "empowered_healing") {
			// Divine Soul: reroll healing dice
			if (c.class_name != "Sorcerer" or c.subclass != "Divine Soul") { u.send({{"type", message_types::announce}, {"text", "Only Divine Souls can use Empowered Healing."}, {"interrupt", true}}); return; }
			c.empowered_healing_active = true;
			u.room.bm.broadcast_announce(c.name + " prepares Empowered Healing. Next healing spell can reroll dice.", false);
		}

		else if (feature == "giants_might") {
			// Rune Knight Fighter: become Large, +1d6 damage, advantage on STR checks
			if (c.class_name != "Fighter" or c.subclass != "Rune Knight") { u.send({{"type", message_types::announce}, {"text", "Only Rune Knights can use Giant's Might."}, {"interrupt", true}}); return; }
			if (c.giants_might_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Giant's Might uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.giants_might_uses--;
			c.giants_might_active = true;
			c.size = SIZE_LARGE;
			u.room.bm.broadcast_announce(c.name + " grows with Giant's Might! Size increased to Large, +1d6 damage.", true);
		}

		else if (feature == "emboldening_bond") {
			// Peace Domain Cleric: Emboldening Bond channel divinity (allies get +1d4 to rolls)
			if (c.class_name != "Cleric" or c.subclass != "Peace Domain") { u.send({{"type", message_types::announce}, {"text", "Only Peace Domain clerics can use Emboldening Bond."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			c.emboldening_bond_active = true;
			u.room.bm.broadcast_announce(c.name + " forms an Emboldening Bond with allies! Bonds grant +1d4 to attacks and saves.", true);
		}

		else if (feature == "twilight_sanctuary") {
			// Twilight Domain Cleric: channel divinity creates a healing aura
			if (c.class_name != "Cleric" or c.subclass != "Twilight Domain") { u.send({{"type", message_types::announce}, {"text", "Only Twilight Domain clerics can use Twilight Sanctuary."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			c.twilight_sanctuary_active = true;
			c.twilight_sanctuary_rounds = 10;
			u.room.bm.broadcast_announce(c.name + " creates a Twilight Sanctuary! Allies in 30 feet gain 1d6 + cleric level temp HP each round.", true);
		}

		else if (feature == "arcane_shot") {
			// Xanathar's Arcane Archer L3 Arcane Shot (para 1618-1621): "Once per turn
			// when you fire an arrow [...] you can apply one of your Arcane Shot options."
			// NOT a bonus action — free action applied on hit. Pre-set here via menu.
			if (c.class_name != "Fighter" or c.subclass != "Arcane Archer") { u.send({{"type", message_types::announce}, {"text", "Only Arcane Archers can use Arcane Shot."}, {"interrupt", true}}); return; }
			if (c.arcane_shot_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Arcane Shot uses remaining."}, {"interrupt", true}}); return; }
			string shot_type = msg.exists("shot_type") ? string(msg["shot_type"]) : "bursting";
			c.arcane_shot_pending = true;
			c.arcane_shot_type = shot_type;
			c.arcane_shot_uses--;
			u.room.bm.broadcast_announce(c.name + " readies " + shot_type + " Arcane Shot! (" + c.arcane_shot_uses + " uses remaining)", false);
		}

		else if (feature == "abjure_extraplanar") {
			// Oath of Watchers Paladin: channel divinity frightens extraplanar creatures
			if (c.class_name != "Paladin" or c.subclass != "Oath of the Watchers") { u.send({{"type", message_types::announce}, {"text", "Only Oath of the Watchers paladins can use Abjure the Extraplanar."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			c.abjure_extraplanar_active = true;
			u.room.bm.broadcast_announce(c.name + " invokes Abjure the Extraplanar! Nearby aberrations, celestials, elementals, fey, and fiends must save vs fear.", true);
		}

		else if (feature == "insightful_fighting") {
			// Inquisitive Rogue: Study target to enable sneak attack without advantage
			if (c.class_name != "Rogue" or c.subclass != "Inquisitive") { u.send({{"type", message_types::announce}, {"text", "Only Inquisitive rogues can use Insightful Fighting."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.inquisitive_target = target_id;
			u.room.bm.broadcast_announce(c.name + " studies a target with Insightful Fighting!", false);
		}

		else if (feature == "mastermind_help") {
			// Mastermind Rogue: bonus action Help at 30ft range
			if (c.class_name != "Rogue" or c.subclass != "Mastermind") { u.send({{"type", message_types::announce}, {"text", "Only Mastermind rogues can use Mastermind Help."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.help_target_id = target_id;
			u.room.bm.broadcast_announce(c.name + " uses Master of Tactics to Help an ally as a bonus action!", false);
		}

		else if (feature == "fast_hands") {
			// Thief Rogue: Fast Hands bonus action (use object / use item)
			if (c.class_name != "Rogue" or c.subclass != "Thief") { u.send({{"type", message_types::announce}, {"text", "Only Thieves can use Fast Hands."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			u.room.bm.broadcast_announce(c.name + " uses Fast Hands to quickly manipulate an object.", false);
		}

		else if (feature == "radiant_sun_bolt") {
			// Way of the Sun Soul Monk: bonus action ranged attack using martial arts die
			if (c.class_name != "Monk" or c.subclass != "Way of the Sun Soul") { u.send({{"type", message_types::announce}, {"text", "Only Way of the Sun Soul monks can use Radiant Sun Bolt."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int dex_mod = c.get_ability_mod(ABILITY_DEX);
			int die_size = 4;
			if (c.level >= 5) die_size = 6;
			if (c.level >= 11) die_size = 8;
			if (c.level >= 17) die_size = 10;
			int atk_bonus = dex_mod + c.proficiency;
			int roll = random(1, 20);
			int total = roll + atk_bonus;
			if (total >= tgt.armor_class) {
				int dmg = random(1, die_size) + dex_mod;
				u.room.bm.combat.apply_damage(tgt, dmg, DMG_RADIANT, c);
				u.room.bm.broadcast_announce(c.name + "'s Radiant Sun Bolt hits for " + dmg + " radiant damage! (Rolled " + roll + ")", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Radiant Sun Bolt misses. (Rolled " + roll + " needed " + tgt.armor_class + ")", false);
			}
		}

		else if (feature == "kensei_weapon") {
			// Way of the Kensei Monk: choose kensei weapon (deflect missiles + accuracy)
			if (c.class_name != "Monk" or c.subclass != "Way of the Kensei") { u.send({{"type", message_types::announce}, {"text", "Only Way of the Kensei monks can use this."}, {"interrupt", true}}); return; }
			c.kensei_weapon_active = true;
			u.room.bm.broadcast_announce(c.name + " declares their Kensei weapon!", false);
		}

		else if (feature == "kensei_shot") {
			// Xanathar's Kensei L3 Kensei's Shot (para 1814-1817): "You can use a bonus
			// action on your turn to make your ranged attacks with a kensei weapon more
			// deadly. Any target you hit with a ranged attack using a kensei weapon takes
			// an extra 1d4 damage of the weapon's damage type."
			if (c.class_name != "Monk" or c.subclass != "Way of the Kensei") { u.send({{"type", message_types::announce}, {"text", "Only Way of the Kensei monks can use Kensei's Shot."}, {"interrupt", true}}); return; }
			if (c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Kensei's Shot requires level 3."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.kenseis_shot_active = true;
			u.room.bm.broadcast_announce(c.name + " activates Kensei's Shot! Ranged kensei attacks deal +1d4 damage this turn.", false);
		}

		else if (feature == "sharpen_the_blade") {
			// Xanathar's Kensei L11 Sharpen the Blade (para 1832-1835): "As a bonus action,
			// you can expend up to 3 ki points to grant one kensei weapon you touch a bonus
			// to attack and damage rolls when you attack with it. The bonus equals the number
			// of ki points you spent. This bonus lasts for 1 minute."
			if (c.class_name != "Monk" or c.subclass != "Way of the Kensei") { u.send({{"type", message_types::announce}, {"text", "Only Way of the Kensei monks can use Sharpen the Blade."}, {"interrupt", true}}); return; }
			if (c.level < 11) { u.send({{"type", message_types::announce}, {"text", "Sharpen the Blade requires level 11."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "No Focus Points remaining."}, {"interrupt", true}}); return; }
			// "This feature has no effect on a magic weapon that already has a bonus."
			if (c.magic_weapon_bonus > 0) { u.send({{"type", message_types::announce}, {"text", "Sharpen the Blade has no effect on a magic weapon that already has a bonus."}, {"interrupt", true}}); return; }
			int ki_to_spend = msg.exists("ki_amount") ? int(msg["ki_amount"]) : 1;
			if (ki_to_spend < 1) ki_to_spend = 1;
			if (ki_to_spend > 3) ki_to_spend = 3;
			if (ki_to_spend > c.focus_points) ki_to_spend = c.focus_points;
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.focus_points -= ki_to_spend;
			c.sharpen_the_blade_bonus = ki_to_spend;
			c.sharpen_the_blade_rounds = 10;
			u.room.bm.broadcast_announce(c.name + " sharpens their blade! +" + ki_to_spend + " to attack and damage rolls for 1 minute. (" + ki_to_spend + " Focus Points spent)", false);
		}

		else if (feature == "drunken_master_redirect") {
			// Way of the Drunken Master: Redirect Attack reaction (forces attacker to redirect)
			if (c.class_name != "Monk" or c.subclass != "Way of the Drunken Master") { u.send({{"type", message_types::announce}, {"text", "Only Drunken Master monks can Redirect Attack."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "No Focus Points remaining."}, {"interrupt", true}}); return; }
			c.focus_points--;
			c.has_reaction = false;
			c.drunken_master_opportunity = true;
			u.room.bm.broadcast_announce(c.name + " uses Redirect Attack!", false);
		}

		else if (feature == "breath_of_dragon") {
			// Way of the Ascendant Dragon Monk: breath weapon
			if (c.class_name != "Monk" or c.subclass != "Way of the Ascendant Dragon") { u.send({{"type", message_types::announce}, {"text", "Only Way of the Ascendant Dragon monks can use this."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "No Focus Points remaining."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.focus_points--;
			c.has_action = false;
			c.used_action = true;
			// 20ft line or 15ft cone — deal martial arts die damage to all in area
			int die_size = 4;
			if (c.level >= 5) die_size = 6;
			if (c.level >= 11) die_size = 8;
			if (c.level >= 17) die_size = 10;
			int damage = random(1, die_size) * 2;
			u.room.bm.broadcast_announce(c.name + " unleashes a 15-foot cone of draconic breath for " + damage + " fire damage!", true);
			// Apply to enemies in range
			for (uint bi = 0; bi < u.room.bm.combat.combatants.length(); bi++) {
				combatant@ t = u.room.bm.combat.combatants[bi];
				if (@t == null or t.is_dead or t.id == c.id) continue;
				if (t.is_player == c.is_player and u.room.bm.combat.mode != "pvp") continue;
				int dist = feet_distance(c.x, c.y, t.x, t.y);
				if (dist <= 15) {
					// DEX save for half
					int save_roll = random(1, 20);
					int save_bonus = t.get_save_bonus(ABILITY_DEX);
					int dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
					int dmg = (save_roll + save_bonus >= dc) ? damage / 2 : damage;
					u.room.bm.combat.apply_damage(t, dmg, DMG_FIRE, c);
				}
			}
		}

		else if (feature == "astral_arms") {
			// Way of the Astral Self Monk: manifest astral arms (bonus action, spend 1 Focus)
			if (c.class_name != "Monk" or c.subclass != "Way of the Astral Self") { u.send({{"type", message_types::announce}, {"text", "Only Astral Self monks can manifest astral arms."}, {"interrupt", true}}); return; }
			if (c.focus_points <= 0) { u.send({{"type", message_types::announce}, {"text", "No Focus Points remaining."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.focus_points--;
			u.room.bm.broadcast_announce(c.name + " manifests Astral Arms! Reach extended to 10ft, unarmed strikes deal force damage.", true);
		}

		else if (feature == "tentacle_of_deeps") {
			// The Fathomless Warlock: summon tentacle, or reactivate for attack
			if (c.class_name != "Warlock" or c.subclass != "The Fathomless") { u.send({{"type", message_types::announce}, {"text", "Only Fathomless warlocks can summon Tentacle of the Deeps."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt != null and !tgt.is_dead) {
				// Attack with tentacle — 1d8 cold damage + reduce speed
				int dex_mod = c.get_ability_mod(ABILITY_DEX);
				int atk_bonus = dex_mod + c.proficiency;
				int roll = random(1, 20);
				if (roll + atk_bonus >= tgt.armor_class) {
					int cold_dmg = random(1, 8);
					if (c.level >= 10) cold_dmg += random(1, 8);
					u.room.bm.combat.apply_damage(tgt, cold_dmg, DMG_COLD, c);
					tgt.speed -= 10;
					if (tgt.speed < 0) tgt.speed = 0;
					u.room.bm.broadcast_announce(c.name + "'s Tentacle of the Deeps strikes " + tgt.name + " for " + cold_dmg + " cold damage and reduces their speed!", true);
				} else {
					u.room.bm.broadcast_announce(c.name + "'s Tentacle of the Deeps misses " + tgt.name + ".", false);
				}
			}
			c.tentacle_of_deeps_active = true;
		}

		else if (feature == "genie_vessel") {
			// The Genie Warlock: retreat to vessel (flavor: temp HP + concealed)
			if (c.class_name != "Warlock" or c.subclass != "The Genie") { u.send({{"type", message_types::announce}, {"text", "Only Genie warlocks can enter their Vessel."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int temp_hp = c.proficiency + c.level;
			if (c.temp_hp < temp_hp) c.temp_hp = temp_hp;
			c.genie_vessel_active = true;
			u.room.bm.broadcast_announce(c.name + " retreats into their Genie's Vessel, gaining " + temp_hp + " temp HP!", true);
		}

		else if (feature == "form_of_dread") {
			// Undead Warlock: Form of Dread — bonus action, frighten on hit, temp HP
			if (c.class_name != "Warlock" or c.subclass != "The Undead") { u.send({{"type", message_types::announce}, {"text", "Only Undead warlocks can manifest Form of Dread."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int temp_hp = 1 + c.level;
			if (c.temp_hp < temp_hp) c.temp_hp = temp_hp;
			c.form_of_dread_active = true;
			c.form_of_dread_rounds = 10;
			u.room.bm.broadcast_announce(c.name + " manifests Form of Dread! Gains " + temp_hp + " temp HP, enemies hit may be frightened.", true);
		}

		else if (feature == "starry_form") {
			// Circle of Stars Druid: bonus action to assume Starry Form (Chalice/Archer/Dragon)
			if (c.class_name != "Druid" or c.subclass != "Circle of the Stars") { u.send({{"type", message_types::announce}, {"text", "Only Circle of the Stars druids can use Starry Form."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.starry_form_active = true;
			string form = msg.exists("form") ? string(msg["form"]) : "Chalice";
			c.starry_form_type = form;
			u.room.bm.broadcast_announce(c.name + " assumes Starry Form: " + form + "!", true);
		}

		else if (feature == "land_stride") {
			// Circle of the Land Druid: Land's Stride - ignore difficult terrain
			if (c.class_name != "Druid" or c.subclass != "Circle of the Land") { u.send({{"type", message_types::announce}, {"text", "Only Circle of the Land druids can use Land's Stride."}, {"interrupt", true}}); return; }
			c.land_stride_active = true;
			u.room.bm.broadcast_announce(c.name + "'s Land's Stride activates.", false);
		}

		else if (feature == "wildfire_spirit") {
			// Wildfire Druid: summon Wildfire Spirit (simplified: flag for temp HP + bonus damage)
			if (c.class_name != "Druid" or c.subclass != "Circle of Wildfire") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Wildfire druids can summon a Wildfire Spirit."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.wildfire_spirit_active = true;
			u.room.bm.broadcast_announce(c.name + " summons a Wildfire Spirit!", true);
		}

		else if (feature == "echo_knight_manifest") {
			// Wildemount paras 5370-5375 (Echo Knight L3 Manifest Echo):
			// "You can use a bonus action to magically manifest an echo of yourself in
			// an unoccupied space you can see within 15 feet of you. This echo is a
			// magical, translucent, gray image of you that lasts until it is destroyed,
			// until you dismiss it as a bonus action, until you manifest another echo,
			// or until you're more than 30 feet away from it... Your echo has AC 14 +
			// your proficiency bonus, 1 hit point, and immunity to all conditions."
			if (c.class_name != "Fighter" or c.subclass != "Echo Knight") { u.send({{"type", message_types::announce}, {"text", "Only Echo Knights can manifest echoes."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Spawn the echo as a real companion entity so it gets initiative, can be
			// attacked, and properly resolves opportunity attacks. The echo uses the
			// caster's weapon stats since attacks "originate from your space or the
			// echo's space" (the player can choose either when taking the Attack action).
			int echo_attack = c.get_ability_mod(ABILITY_STR) + c.proficiency;
			combatant@ echo = u.room.bm.spawn_companion(c, "echo_knight", c.name + "'s Echo", 1, 14 + c.proficiency, c.speed, echo_attack, c.main_hand_damage_count, c.main_hand_damage_dice, c.get_ability_mod(ABILITY_STR), c.main_hand_damage_type, 0);
			if (@echo != null) {
				c.echo_active = true;
				c.echo_hp = 1;
				c.echo_x = echo.x;
				c.echo_y = echo.y;
				u.room.bm.broadcast_announce(c.name + " manifests an Echo of themselves! AC " + (14 + c.proficiency) + ", 1 HP, immune to conditions. Lasts until destroyed or dismissed.", true);
			}
		}
		else if (feature == "unleash_incarnation") {
			// Echo Knight L3: after Attack action, bonus action for extra melee attack from echo's space
			if (c.class_name != "Fighter" or c.subclass != "Echo Knight") { u.send({{"type", message_types::announce}, {"text", "Only Echo Knights can unleash incarnation."}, {"interrupt", true}}); return; }
			if (!c.echo_active) { u.send({{"type", message_types::announce}, {"text", "You have no active echo."}, {"interrupt", true}}); return; }
			if (!c.used_action) { u.send({{"type", message_types::announce}, {"text", "You must first take the Attack action."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.unleash_incarnation_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Unleash Incarnation uses remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			int dist_echo = feet_distance(c.echo_x, c.echo_y, tgt.x, tgt.y);
			int weapon_reach = c.main_hand_range > 0 ? c.main_hand_range : 5;
			if (dist_echo > weapon_reach) { u.send({{"type", message_types::announce}, {"text", "Target out of echo's reach."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.unleash_incarnation_uses--;
			int atk_bonus = c.get_ability_mod(ABILITY_STR) + c.proficiency;
			int roll = random(1, 20);
			int total = roll + atk_bonus;
			u.room.bm.broadcast_announce(c.name + "'s echo lunges at " + tgt.name + "!", true);
			if (total >= tgt.armor_class or roll == 20) {
				int dmg = random(1, c.main_hand_damage_dice);
				if (roll == 20) dmg += random(1, c.main_hand_damage_dice);
				dmg += c.get_ability_mod(ABILITY_STR);
				if (dmg < 1) dmg = 1;
				u.room.bm.combat.apply_damage(tgt, dmg, c.main_hand_damage_type, c);
				u.room.bm.broadcast_announce("Echo hits " + tgt.name + " for " + dmg + " damage! Uses remaining: " + c.unleash_incarnation_uses, true);
			} else {
				u.room.bm.broadcast_announce("Echo's attack misses " + tgt.name + ".", false);
			}
		}
		else if (feature == "adjust_density") {
			// Wildemount p.5428: "As an action, you can magically alter the weight of one
			// object or creature you can see within 30 feet of you. The object or creature
			// must be Large or smaller. The target's weight is halved or doubled for up to
			// 1 minute or until your concentration ends." At L10 the size cap raises to Huge.
			// The choice (halve vs double) is the player's — never auto-pick.
			if (c.class_name != "Wizard" or c.subclass != "Graviturgy Magic") { u.send({{"type", message_types::announce}, {"text", "Only Graviturgy wizards can adjust density."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 feet)."}, {"interrupt", true}}); return; }
			// Adjust Density is concentration. Drop any prior concentration before establishing new.
			u.room.bm.clear_concentration_effects(c);
			c.has_action = false;
			c.used_action = true;
			pending_spell_choice sc;
			sc.player_username = c.player_username;
			sc.caster_id = c.id;
			sc.spell_id = "adjust_density";
			sc.cast_slot_level = 0;
			sc.primary_target_id = tgt.id;
			sc.option_keys = {"halve", "double"};
			sc.option_labels = {"Halve density (+10 ft speed, disadvantage on STR)", "Double density (-10 ft speed, advantage on STR)"};
			sc.prompt_text = "Adjust Density on " + tgt.name + ": press 1 to halve their density (+10 feet speed, disadvantage on Strength checks and saves), or 2 to double their density (-10 feet speed, advantage on Strength checks and saves).";
			u.room.bm.send_spell_choice_prompt(c, sc);
		}
		else if (feature == "event_horizon") {
			// Graviturgy Wizard L14: Action - 30ft aura, STR save or 2d10 force + speed 0, 1/LR
			if (c.class_name != "Wizard" or c.subclass != "Graviturgy Magic") { u.send({{"type", message_types::announce}, {"text", "Only Graviturgy wizards can create an Event Horizon."}, {"interrupt", true}}); return; }
			if (c.level < 14) { u.send({{"type", message_types::announce}, {"text", "Event Horizon unlocks at level 14."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.event_horizon_active = true;
			int ev_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
			for (uint evi = 0; evi < u.room.bm.combat.combatants.length(); evi++) {
				combatant@ evt = u.room.bm.combat.combatants[evi];
				if (@evt == null or evt.is_dead or evt.id == c.id) continue;
				if (evt.is_player == c.is_player) continue;
				if (feet_distance(c.x, c.y, evt.x, evt.y) > 30) continue;
				int save = random(1, 20) + evt.get_save_bonus(ABILITY_STR);
				int ev_dmg = random(1, 10) + random(1, 10);
				if (save >= ev_dc) ev_dmg /= 2;
				else evt.speed = 0;
				u.room.bm.combat.apply_damage(evt, ev_dmg, DMG_FORCE, c);
				u.room.bm.broadcast_announce(evt.name + (save >= ev_dc ? " resists" : " is crushed by") + " the Event Horizon: " + ev_dmg + " force damage.", true);
			}
		}
		else if (feature == "breath_of_the_dragon") {
			// Way of the Ascendant Dragon L3: replace one attack with 20ft cone or 30ft line
			// Deals 2 * Martial Arts die damage (acid/cold/fire/lightning/poison). Dex save for half.
			// PB uses/LR, or 2 ki points
			if (c.class_name != "Monk" or c.subclass != "Way of the Ascendant Dragon") { u.send({{"type", message_types::announce}, {"text", "Only Ascendant Dragon monks have this feature."}, {"interrupt", true}}); return; }
			if (!c.has_action and !c.used_action) { u.send({{"type", message_types::announce}, {"text", "You must take the Attack action."}, {"interrupt", true}}); return; }
			if (c.ascendant_dragon_breath_uses <= 0 and c.focus_points < 2) { u.send({{"type", message_types::announce}, {"text", "No uses remaining and insufficient Focus Points."}, {"interrupt", true}}); return; }
			if (c.ascendant_dragon_breath_uses <= 0) c.focus_points -= 2;
			else c.ascendant_dragon_breath_uses--;
			// Martial Arts die size
			int ma_die = 4;
			if (c.level >= 5) ma_die = 6;
			if (c.level >= 11) ma_die = 8;
			if (c.level >= 17) ma_die = 10;
			int breath_dice = 2;
			if (c.level >= 11) breath_dice = 3;
			int breath_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			// AoE: hit all enemies within 20ft (cone approximation)
			u.room.bm.broadcast_announce(c.name + " unleashes Breath of the Dragon!", true);
			for (uint bdi = 0; bdi < u.room.bm.combat.combatants.length(); bdi++) {
				combatant@ bdt = u.room.bm.combat.combatants[bdi];
				if (@bdt == null or bdt.is_dead or bdt.id == c.id) continue;
				if (bdt.is_player == c.is_player) continue;
				if (feet_distance(c.x, c.y, bdt.x, bdt.y) > 20) continue;
				int bd_dmg = 0;
				for (int bd = 0; bd < breath_dice; bd++) bd_dmg += random(1, ma_die);
				int save = random(1, 20) + bdt.get_save_bonus(ABILITY_DEX);
				if (save >= breath_dc) bd_dmg /= 2;
				if (bd_dmg < 1) bd_dmg = 1;
				u.room.bm.combat.apply_damage(bdt, bd_dmg, DMG_FIRE, c);
				u.room.bm.broadcast_announce(bdt.name + " takes " + bd_dmg + " fire damage (save " + save + " vs DC " + breath_dc + ")", false);
			}
		}
		else if (feature == "aspect_of_the_wyrm") {
			// Way of the Ascendant Dragon L11: bonus action aura 10ft, 1 min, frightful or resistance
			if (c.class_name != "Monk" or c.subclass != "Way of the Ascendant Dragon") { u.send({{"type", message_types::announce}, {"text", "Only Ascendant Dragon monks have this feature."}, {"interrupt", true}}); return; }
			if (c.level < 11) { u.send({{"type", message_types::announce}, {"text", "Aspect of the Wyrm unlocks at level 11."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.aspect_of_wyrm_used and c.focus_points < 3) { u.send({{"type", message_types::announce}, {"text", "Already used; need 3 Focus Points."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			if (c.aspect_of_wyrm_used) c.focus_points -= 3;
			c.aspect_of_wyrm_used = true;
			// Apply fire resistance to self and allies in 10ft
			for (uint awi = 0; awi < u.room.bm.combat.combatants.length(); awi++) {
				combatant@ awa = u.room.bm.combat.combatants[awi];
				if (@awa == null or awa.is_dead) continue;
				if (awa.is_player != c.is_player and awa.id != c.id) continue;
				if (feet_distance(c.x, c.y, awa.x, awa.y) > 10) continue;
				awa.fire_resistance = true;
			}
			u.room.bm.broadcast_announce(c.name + " activates Aspect of the Wyrm! 10ft aura grants fire resistance.", true);
		}
		else if (feature == "magic_coin") {
			// College of Mercantile L3: Action — ranged spell attack (CHA + prof) vs AC, 1d12 thunder (scales)
			if (c.class_name != "Bard" or c.subclass != "College of Mercantile") { u.send({{"type", message_types::announce}, {"text", "Only Mercantile bards can fling Magic Coins."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action this turn."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Target out of range (60ft)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			int mc_atk = random(1, 20) + c.get_ability_mod(ABILITY_CHA) + c.proficiency;
			int thunder_dice = 1;
			if (c.level >= 6) thunder_dice = 2;
			if (c.level >= 14) thunder_dice = 3;
			if (mc_atk >= tgt.armor_class or mc_atk >= 20) {
				int mc_dmg = 1; // 1 bludgeoning
				for (int td = 0; td < thunder_dice; td++) mc_dmg += random(1, 12);
				u.room.bm.combat.apply_damage(tgt, mc_dmg, DMG_THUNDER, c);
				u.room.bm.broadcast_announce(c.name + "'s Magic Coin strikes " + tgt.name + " for " + mc_dmg + " thunder damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Magic Coin misses " + tgt.name + ".", false);
			}
		}
		else if (feature == "create_void") {
			// Astral Domain L3: Bonus Action Channel Divinity — 15ft sphere within 60ft, Dex save or
			// 1d8 + cleric level force damage, pulled 15ft; half on success
			if (c.class_name != "Cleric" or c.subclass != "Astral Domain") { u.send({{"type", message_types::announce}, {"text", "Only Astral Clerics can Create Void."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected (center of void)."}, {"interrupt", true}}); return; }
			combatant@ center = u.room.bm.combat.get_combatant(target_id);
			if (@center == null) { u.send({{"type", message_types::announce}, {"text", "Invalid center target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, center.x, center.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Out of range (60ft)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			int cv_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			u.room.bm.broadcast_announce(c.name + " tears open a planar void centered on " + center.name + "!", true);
			for (uint cvi = 0; cvi < u.room.bm.combat.combatants.length(); cvi++) {
				combatant@ cvt = u.room.bm.combat.combatants[cvi];
				if (@cvt == null or cvt.is_dead) continue;
				if (feet_distance(center.x, center.y, cvt.x, cvt.y) > 15) continue;
				int save = random(1, 20) + cvt.get_save_bonus(ABILITY_DEX);
				int cv_dmg = random(1, 8) + c.level;
				bool saved = save >= cv_dc;
				if (saved) cv_dmg /= 2;
				u.room.bm.combat.apply_damage(cvt, cv_dmg, DMG_FORCE, c);
				// Pull toward center 15ft (simple direction)
				if (!saved) {
					if (cvt.x < center.x) cvt.x += 15;
					else if (cvt.x > center.x) cvt.x -= 15;
					if (cvt.y < center.y) cvt.y += 15;
					else if (cvt.y > center.y) cvt.y -= 15;
				}
				u.room.bm.broadcast_announce(cvt.name + " takes " + cv_dmg + " force damage from the void (save " + save + " vs DC " + cv_dc + ").", false);
			}
		}
		else if (feature == "mark_of_heretic") {
			// Oath of Zeal (Grim Hollow) L3 Channel Divinity: mark target, crit 19-20 vs them for 1 min,
			// reaction weapon attack at start of marked target's turn
			if (c.class_name != "Paladin" or c.subclass != "Oath of Zeal") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Zeal paladins can use Mark of the Heretic."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30ft)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.mark_of_heretic_active = true;
			c.mark_of_heretic_target = tgt.id;
			u.room.bm.broadcast_announce(c.name + " marks " + tgt.name + " with the Mark of the Heretic! Crit on 19+ and reactions.", true);
		}
		else if (feature == "turn_undead") {
			// PHB 2024 Cleric L2 Channel Divinity para 4211: "As a Magic action, you
			// present your Holy Symbol and censure Undead creatures. Each Undead of your
			// choice within 30 feet of you must make a Wisdom saving throw. If the creature
			// fails its save, it has the Frightened and Incapacitated conditions for 1
			// minute or until it takes any damage."
			// L5 Sear Undead: also deal WIS-mod d8 radiant damage to any undead that fails
			// the save.
			if (c.class_name != "Cleric") { u.send({{"type", message_types::announce}, {"text", "Only Clerics can Turn Undead."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int turn_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int turned = 0;
			int sear_count = 0;
			int wis_mod_tu = c.get_ability_mod(ABILITY_WIS);
			if (wis_mod_tu < 1) wis_mod_tu = 1;
			for (uint ti = 0; ti < u.room.bm.combat.combatants.length(); ti++) {
				combatant@ undead = u.room.bm.combat.combatants[ti];
				if (@undead == null or undead.is_dead) continue;
				if (undead.id == c.id) continue;
				// Detect undead by name keywords (since the game doesn't track creature type yet).
				string nm_lower = undead.name;
				bool is_undead = false;
				if (nm_lower.find("Skeleton") >= 0 or nm_lower.find("skeleton") >= 0) is_undead = true;
				if (nm_lower.find("Zombie") >= 0 or nm_lower.find("zombie") >= 0) is_undead = true;
				if (nm_lower.find("Ghoul") >= 0 or nm_lower.find("ghoul") >= 0) is_undead = true;
				if (nm_lower.find("Wight") >= 0 or nm_lower.find("wight") >= 0) is_undead = true;
				if (nm_lower.find("Lich") >= 0 or nm_lower.find("lich") >= 0) is_undead = true;
				if (nm_lower.find("Vampire") >= 0 or nm_lower.find("vampire") >= 0) is_undead = true;
				if (nm_lower.find("Wraith") >= 0 or nm_lower.find("wraith") >= 0) is_undead = true;
				if (nm_lower.find("Mummy") >= 0 or nm_lower.find("mummy") >= 0) is_undead = true;
				if (nm_lower.find("Specter") >= 0 or nm_lower.find("specter") >= 0) is_undead = true;
				if (nm_lower.find("Shadow") >= 0 or nm_lower.find("shadow") >= 0) is_undead = true;
				if (!is_undead) continue;
				if (feet_distance(c.x, c.y, undead.x, undead.y) > 30) continue;
				int save_roll = random(1, 20) + undead.get_save_bonus(ABILITY_WIS);
				if (save_roll < turn_dc) {
					undead.add_condition(COND_FRIGHTENED);
					undead.frightened_source_id = c.id;
					undead.add_condition(COND_INCAPACITATED);
					turned++;
					// L5 Sear Undead damage
					if (c.level >= 5) {
						int sear_dmg = 0;
						for (int sd = 0; sd < wis_mod_tu; sd++) sear_dmg += random(1, 8);
						u.room.bm.combat.apply_damage(undead, sear_dmg, DMG_RADIANT, c);
						sear_count++;
						u.room.bm.broadcast_announce(undead.name + " is turned and seared for " + sear_dmg + " radiant damage!", false);
					} else {
						u.room.bm.broadcast_announce(undead.name + " is turned and flees in fear!", false);
					}
				} else {
					u.room.bm.broadcast_announce(undead.name + " resists being turned. (save " + save_roll + " vs DC " + turn_dc + ")", false);
				}
			}
			u.room.bm.broadcast_announce(c.name + " channels divine energy to Turn Undead — " + turned + " creature" + (turned == 1 ? "" : "s") + " turned.", true);
		}
		else if (feature == "divine_spark_heal" or feature == "divine_spark_radiant" or feature == "divine_spark_necrotic") {
			// PHB 2024 Cleric L2 Channel Divinity: Divine Spark (para 3608-3609):
			// "As a Magic action, you point your Holy Symbol at another creature you can
			// see within 30 feet of yourself and focus divine energy at it. Roll 1d8 and
			// add your Wisdom modifier. You either restore Hit Points to the creature
			// equal to that total or force the creature to make a Constitution saving
			// throw. On a failed save, the creature takes Necrotic or Radiant damage
			// (your choice) equal to that total. On a successful save, the creature
			// takes half as much damage (round down).
			// You roll an additional d8 when you reach Cleric levels 7 (2d8), 13 (3d8),
			// and 18 (4d8)."
			if (c.class_name != "Cleric") { u.send({{"type", message_types::announce}, {"text", "Only Clerics can use Divine Spark."}, {"interrupt", true}}); return; }
			if (c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Divine Spark unlocks at Cleric L2."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			combatant@ ds_target = u.room.bm.combat.get_combatant(target_id);
			if (@ds_target == null or ds_target.is_dead) { u.send({{"type", message_types::announce}, {"text", "Choose a target for Divine Spark."}, {"interrupt", true}}); return; }
			if (ds_target.id == c.id) { u.send({{"type", message_types::announce}, {"text", "Divine Spark targets another creature."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, ds_target.x, ds_target.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 ft)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int ds_die_count = 1;
			if (c.level >= 18) ds_die_count = 4;
			else if (c.level >= 13) ds_die_count = 3;
			else if (c.level >= 7) ds_die_count = 2;
			int ds_total = c.get_ability_mod(ABILITY_WIS);
			for (int dsi = 0; dsi < ds_die_count; dsi++) ds_total += random(1, 8);
			if (ds_total < 1) ds_total = 1;
			if (feature == "divine_spark_heal") {
				int healed = u.room.bm.combat.apply_healing(ds_target, ds_total);
				u.room.bm.broadcast_announce(c.name + " channels Divine Spark to restore " + healed + " HP to " + ds_target.name + " (" + ds_die_count + "d8 + WIS).", true);
			} else {
				int dmg_type = (feature == "divine_spark_radiant") ? DMG_RADIANT : DMG_NECROTIC;
				string dmg_name = (feature == "divine_spark_radiant") ? "radiant" : "necrotic";
				int spell_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
				int save_roll = random(1, 20) + ds_target.get_save_bonus(ABILITY_CON);
				int dealt = ds_total;
				if (save_roll >= spell_dc) dealt = ds_total / 2;
				u.room.bm.combat.apply_damage(ds_target, dealt, dmg_type, c);
				if (save_roll >= spell_dc) {
					u.room.bm.broadcast_announce(c.name + " channels Divine Spark — " + ds_target.name + " saves (CON " + save_roll + " vs DC " + spell_dc + ") for " + dealt + " " + dmg_name + " damage (half of " + ds_die_count + "d8 + WIS).", true);
				} else {
					u.room.bm.broadcast_announce(c.name + " channels Divine Spark — " + ds_target.name + " fails CON save (" + save_roll + " vs DC " + spell_dc + ") for " + dealt + " " + dmg_name + " damage (" + ds_die_count + "d8 + WIS).", true);
				}
			}
		}
		else if (feature == "divine_intervention") {
			// PHB 2024 Cleric L10 Divine Intervention (para 3621-3622): "You can call on
			// your deity or pantheon to intervene on your behalf. As a Magic action,
			// choose any Cleric spell of level 5 or lower that doesn't require a Reaction
			// to cast. As part of the same action, you cast that spell without expending
			// a spell slot or needing Material components. You can't use this feature
			// again until you finish a Long Rest."
			// Implemented as a flag the player toggles on; the next Cleric spell of
			// level <=5 they cast within the same battle consumes the flag instead of a
			// spell slot. Player chooses the spell normally via the cast menu — no
			// auto-selection (per source-only mandate).
			if (c.class_name != "Cleric") { u.send({{"type", message_types::announce}, {"text", "Only Clerics can use Divine Intervention."}, {"interrupt", true}}); return; }
			if (c.level < 10) { u.send({{"type", message_types::announce}, {"text", "Divine Intervention unlocks at Cleric L10."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.divine_intervention_used_this_rest) { u.send({{"type", message_types::announce}, {"text", "Divine Intervention has already been used this rest."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.divine_intervention_ready = true;
			c.divine_intervention_used_this_rest = true;
			u.room.bm.broadcast_announce(c.name + " calls on their deity for Divine Intervention. Their next Cleric spell of level 5 or lower is cast without consuming a slot.", true);
		}
		else if (feature == "set_divine_order") {
			// PHB 2024 Cleric L1 Divine Order (para 3600-3603) — player chooses
			// "protector" or "thaumaturge". Stored on character; cannot be changed
			// after L1 per source ("you have dedicated yourself to one of the following").
			string order_choice = msg.exists("value") ? string(msg["value"]) : "";
			if (order_choice != "protector" and order_choice != "thaumaturge") {
				u.send({{"type", message_types::announce}, {"text", "Divine Order must be 'protector' or 'thaumaturge'."}, {"interrupt", true}});
				return;
			}
			if (c.class_name != "Cleric") { u.send({{"type", message_types::announce}, {"text", "Only Clerics have a Divine Order."}, {"interrupt", true}}); return; }
			c.divine_order = order_choice;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["divine_order"] = order_choice;
					u.account.commit();
				}
			}
			string label = (order_choice == "protector") ? "Protector (martial weapons + heavy armor training)" : "Thaumaturge (extra cantrip + WIS bonus to Arcana/Religion)";
			u.send({{"type", message_types::announce}, {"text", "Divine Order set to " + label + "."}, {"interrupt", true}});
		}
		else if (feature == "set_blessed_strikes") {
			// PHB 2024 Cleric L7 Blessed Strikes (para 3617-3620) — player chooses
			// "divine_strike" or "potent_spellcasting" once at L7.
			string bs_choice = msg.exists("value") ? string(msg["value"]) : "";
			if (bs_choice != "divine_strike" and bs_choice != "potent_spellcasting") {
				u.send({{"type", message_types::announce}, {"text", "Blessed Strikes must be 'divine_strike' or 'potent_spellcasting'."}, {"interrupt", true}});
				return;
			}
			if (c.class_name != "Cleric") { u.send({{"type", message_types::announce}, {"text", "Only Clerics have Blessed Strikes."}, {"interrupt", true}}); return; }
			if (c.level < 7) { u.send({{"type", message_types::announce}, {"text", "Blessed Strikes unlocks at Cleric L7."}, {"interrupt", true}}); return; }
			c.blessed_strikes_choice = bs_choice;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["blessed_strikes_choice"] = bs_choice;
					u.account.commit();
				}
			}
			string label2 = (bs_choice == "divine_strike") ? "Divine Strike (+1d8 necrotic/radiant on weapon hit, once per turn)" : "Potent Spellcasting (WIS modifier to Cleric cantrip damage)";
			u.send({{"type", message_types::announce}, {"text", "Blessed Strikes set to " + label2 + "."}, {"interrupt", true}});
		}
		else if (feature == "set_divine_strike_damage_type") {
			// Sub-choice for Divine Strike — player picks the damage type once.
			string dt_choice = msg.exists("value") ? string(msg["value"]) : "";
			if (dt_choice != "necrotic" and dt_choice != "radiant") {
				u.send({{"type", message_types::announce}, {"text", "Divine Strike damage type must be 'necrotic' or 'radiant'."}, {"interrupt", true}});
				return;
			}
			if (c.class_name != "Cleric") { u.send({{"type", message_types::announce}, {"text", "Only Clerics use Divine Strike."}, {"interrupt", true}}); return; }
			if (c.blessed_strikes_choice != "divine_strike") { u.send({{"type", message_types::announce}, {"text", "Pick Blessed Strikes Divine Strike first."}, {"interrupt", true}}); return; }
			c.divine_strike_damage_type = dt_choice;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["divine_strike_damage_type"] = dt_choice;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "Divine Strike damage type set to " + dt_choice + "."}, {"interrupt", true}});
		}
		else if (feature == "set_primal_order") {
			// PHB 2024 Druid L1 Primal Order (para 4387-4390) — player chooses
			// "magician" or "warden". Persisted to character.
			string po_choice = msg.exists("value") ? string(msg["value"]) : "";
			if (po_choice != "magician" and po_choice != "warden") {
				u.send({{"type", message_types::announce}, {"text", "Primal Order must be 'magician' or 'warden'."}, {"interrupt", true}});
				return;
			}
			if (c.class_name != "Druid") { u.send({{"type", message_types::announce}, {"text", "Only Druids have a Primal Order."}, {"interrupt", true}}); return; }
			c.primal_order = po_choice;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["primal_order"] = po_choice;
					u.account.commit();
				}
			}
			string po_label = (po_choice == "magician") ? "Magician (extra cantrip + WIS bonus to Arcana/Nature)" : "Warden (martial weapons + medium armor training)";
			u.send({{"type", message_types::announce}, {"text", "Primal Order set to " + po_label + "."}, {"interrupt", true}});
		}
		else if (feature == "set_elemental_fury") {
			// PHB 2024 Druid L7 Elemental Fury (para 4430-4433) — player chooses
			// "potent_spellcasting" or "primal_strike" once at L7.
			string ef_choice = msg.exists("value") ? string(msg["value"]) : "";
			if (ef_choice != "potent_spellcasting" and ef_choice != "primal_strike") {
				u.send({{"type", message_types::announce}, {"text", "Elemental Fury must be 'potent_spellcasting' or 'primal_strike'."}, {"interrupt", true}});
				return;
			}
			if (c.class_name != "Druid") { u.send({{"type", message_types::announce}, {"text", "Only Druids have Elemental Fury."}, {"interrupt", true}}); return; }
			if (c.level < 7) { u.send({{"type", message_types::announce}, {"text", "Elemental Fury unlocks at Druid L7."}, {"interrupt", true}}); return; }
			c.elemental_fury_choice = ef_choice;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["elemental_fury_choice"] = ef_choice;
					u.account.commit();
				}
			}
			string ef_label = (ef_choice == "primal_strike") ? "Primal Strike (+1d8 cold/fire/lightning/thunder on attack hit, once per turn)" : "Potent Spellcasting (WIS modifier to Druid cantrip damage)";
			u.send({{"type", message_types::announce}, {"text", "Elemental Fury set to " + ef_label + "."}, {"interrupt", true}});
		}
		else if (feature == "set_primal_strike_damage_type") {
			// Primal Strike damage type sub-choice — pick once.
			string pst = msg.exists("value") ? string(msg["value"]) : "";
			if (pst != "cold" and pst != "fire" and pst != "lightning" and pst != "thunder") {
				u.send({{"type", message_types::announce}, {"text", "Primal Strike damage type must be cold, fire, lightning, or thunder."}, {"interrupt", true}});
				return;
			}
			if (c.class_name != "Druid") { u.send({{"type", message_types::announce}, {"text", "Only Druids use Primal Strike."}, {"interrupt", true}}); return; }
			if (c.elemental_fury_choice != "primal_strike") { u.send({{"type", message_types::announce}, {"text", "Pick Elemental Fury Primal Strike first."}, {"interrupt", true}}); return; }
			c.primal_strike_damage_type = pst;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["primal_strike_damage_type"] = pst;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "Primal Strike damage type set to " + pst + "."}, {"interrupt", true}});
		}
		else if (feature == "set_elemental_affinity") {
			// PHB 2024 Sorcerer Draconic Sorcery L6 Elemental Affinity (para 7559-7560):
			// "Choose one of those types: Acid, Cold, Fire, Lightning, or Poison. You
			// have Resistance to that damage type, and when you cast a spell that deals
			// damage of that type, you can add your Charisma modifier to one damage
			// roll of that spell."
			string ea_choice = msg.exists("value") ? string(msg["value"]) : "";
			if (ea_choice != "acid" and ea_choice != "cold" and ea_choice != "fire" and ea_choice != "lightning" and ea_choice != "poison") {
				u.send({{"type", message_types::announce}, {"text", "Elemental Affinity must be acid, cold, fire, lightning, or poison."}, {"interrupt", true}});
				return;
			}
			if (c.class_name != "Sorcerer" or c.subclass != "Draconic Sorcery") {
				u.send({{"type", message_types::announce}, {"text", "Only Draconic Sorcery Sorcerers can choose Elemental Affinity."}, {"interrupt", true}});
				return;
			}
			if (c.level < 6) {
				u.send({{"type", message_types::announce}, {"text", "Elemental Affinity unlocks at Sorcerer L6."}, {"interrupt", true}});
				return;
			}
			c.elemental_affinity_type = ea_choice;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["elemental_affinity_type"] = ea_choice;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "Elemental Affinity set to " + ea_choice + ". You now have resistance to " + ea_choice + " damage and add CHA to one damage roll of " + ea_choice + " spells."}, {"interrupt", true}});
		}
		else if (feature == "set_divine_soul_affinity") {
			// Xanathar's Divine Soul L1 Divine Magic (para 2532-2546): "choose an
			// affinity for the source of your divine power: good, evil, law, chaos,
			// or neutrality. You learn an additional spell based on that affinity."
			string dsa = msg.exists("value") ? string(msg["value"]) : "";
			if (dsa != "good" and dsa != "evil" and dsa != "law" and dsa != "chaos" and dsa != "neutrality") {
				u.send({{"type", message_types::announce}, {"text", "Divine Soul affinity must be good, evil, law, chaos, or neutrality."}, {"interrupt", true}});
				return;
			}
			if (c.class_name != "Sorcerer" or c.subclass != "Divine Soul") {
				u.send({{"type", message_types::announce}, {"text", "Only Divine Soul Sorcerers can choose this."}, {"interrupt", true}});
				return;
			}
			c.divine_soul_affinity = dsa;
			// Also grant the affinity spell
			string affinity_spell = "";
			if (dsa == "good") affinity_spell = "cure_wounds";
			else if (dsa == "evil") affinity_spell = "inflict_wounds";
			else if (dsa == "law") affinity_spell = "bless";
			else if (dsa == "chaos") affinity_spell = "bane";
			else if (dsa == "neutrality") affinity_spell = "protection_from_evil_and_good";
			if (affinity_spell != "" and !c.knows_spell(affinity_spell)) {
				c.prepared_spells.insert_last(affinity_spell);
			}
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["divine_soul_affinity"] = dsa;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "Divine Soul affinity set to " + dsa + ". Affinity spell: " + affinity_spell + "."}, {"interrupt", true}});
		}
		else if (feature == "set_elemental_adept") {
			// PHB 2024 Elemental Adept (para 7610): player chooses one damage type
			// (Acid, Cold, Fire, Lightning, or Thunder). Persists to account.
			string ea_type = msg.exists("value") ? string(msg["value"]) : "";
			if (ea_type != "acid" and ea_type != "cold" and ea_type != "fire" and ea_type != "lightning" and ea_type != "thunder") {
				u.send({{"type", message_types::announce}, {"text", "Elemental Adept type must be acid, cold, fire, lightning, or thunder."}, {"interrupt", true}});
				return;
			}
			if (!c.has_feat("elemental_adept")) {
				u.send({{"type", message_types::announce}, {"text", "Your character does not have the Elemental Adept feat."}, {"interrupt", true}});
				return;
			}
			// Clear previous selection
			c.elemental_adept_acid = false;
			c.elemental_adept_cold = false;
			c.elemental_adept_fire = false;
			c.elemental_adept_lightning = false;
			c.elemental_adept_thunder = false;
			if (ea_type == "acid") c.elemental_adept_acid = true;
			else if (ea_type == "cold") c.elemental_adept_cold = true;
			else if (ea_type == "fire") c.elemental_adept_fire = true;
			else if (ea_type == "lightning") c.elemental_adept_lightning = true;
			else if (ea_type == "thunder") c.elemental_adept_thunder = true;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["elemental_adept_type"] = ea_type;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "Elemental Adept damage type set to " + ea_type + ". Your spells ignore " + ea_type + " resistance and treat 1s on damage dice as 2s."}, {"interrupt", true}});
		}
		// PHB 2024 Wizard L18 Spell Mastery (para 8629-8631): designate one L1 and one L2
		// Wizard spell that can be cast at will without expending a spell slot.
		else if (feature == "set_spell_mastery") {
			if (c.class_name != "Wizard") { u.send({{"type", message_types::announce}, {"text", "Only Wizards can designate Spell Mastery spells."}, {"interrupt", true}}); return; }
			if (c.level < 18) { u.send({{"type", message_types::announce}, {"text", "Spell Mastery unlocks at Wizard L18."}, {"interrupt", true}}); return; }
			string l1_id = msg.exists("l1_spell") ? string(msg["l1_spell"]) : "";
			string l2_id = msg.exists("l2_spell") ? string(msg["l2_spell"]) : "";
			if (l1_id == "" or l2_id == "") { u.send({{"type", message_types::announce}, {"text", "You must designate both a level-1 and a level-2 spell."}, {"interrupt", true}}); return; }
			// Validate spells exist and are correct level
			spell_def@ s1 = get_spell(l1_id);
			spell_def@ s2 = get_spell(l2_id);
			if (@s1 == null or s1.level != 1) { u.send({{"type", message_types::announce}, {"text", "Invalid level-1 spell: " + l1_id + "."}, {"interrupt", true}}); return; }
			if (@s2 == null or s2.level != 2) { u.send({{"type", message_types::announce}, {"text", "Invalid level-2 spell: " + l2_id + "."}, {"interrupt", true}}); return; }
			c.spell_mastery_l1_spell_id = l1_id;
			c.spell_mastery_l2_spell_id = l2_id;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["spell_mastery_l1_spell_id"] = l1_id;
					ch["spell_mastery_l2_spell_id"] = l2_id;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "Spell Mastery designated: " + s1.name + " (L1) and " + s2.name + " (L2). You can now cast these at will without a spell slot."}, {"interrupt", true}});
		}
		// PHB 2024 Wizard L20 Signature Spells (para 8634-8635): designate two L3 Wizard
		// spells castable once each per Short Rest without a spell slot.
		else if (feature == "set_signature_spells") {
			if (c.class_name != "Wizard") { u.send({{"type", message_types::announce}, {"text", "Only Wizards can designate Signature Spells."}, {"interrupt", true}}); return; }
			if (c.level < 20) { u.send({{"type", message_types::announce}, {"text", "Signature Spells unlock at Wizard L20."}, {"interrupt", true}}); return; }
			string a_id = msg.exists("spell_a") ? string(msg["spell_a"]) : "";
			string b_id = msg.exists("spell_b") ? string(msg["spell_b"]) : "";
			if (a_id == "" or b_id == "") { u.send({{"type", message_types::announce}, {"text", "You must designate two level-3 spells."}, {"interrupt", true}}); return; }
			if (a_id == b_id) { u.send({{"type", message_types::announce}, {"text", "Signature Spells must be two different spells."}, {"interrupt", true}}); return; }
			spell_def@ sa = get_spell(a_id);
			spell_def@ sb = get_spell(b_id);
			if (@sa == null or sa.level != 3) { u.send({{"type", message_types::announce}, {"text", "Invalid level-3 spell: " + a_id + "."}, {"interrupt", true}}); return; }
			if (@sb == null or sb.level != 3) { u.send({{"type", message_types::announce}, {"text", "Invalid level-3 spell: " + b_id + "."}, {"interrupt", true}}); return; }
			c.signature_spell_a_id = a_id;
			c.signature_spell_b_id = b_id;
			c.signature_spell_a_used_this_rest = false;
			c.signature_spell_b_used_this_rest = false;
			c.signature_spells_charges_remaining = c.signature_spells_charges_max;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["signature_spell_a_id"] = a_id;
					ch["signature_spell_b_id"] = b_id;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "Signature Spells designated: " + sa.name + " and " + sb.name + ". Each can be cast once per Short Rest without a spell slot."}, {"interrupt", true}});
		}
		else if (feature == "wild_companion") {
			// PHB 2024 Druid L2 Wild Companion (para 4420-4422): "As a Magic action, you
			// can expend a spell slot or a use of Wild Shape to cast the Find Familiar
			// spell without Material components." Find Familiar isn't a combat-relevant
			// spell so we just consume the resource and broadcast — the familiar lives
			// in the narrative, not the combat grid (matches no-pet-grid policy).
			if (c.class_name != "Druid") { u.send({{"type", message_types::announce}, {"text", "Only Druids can use Wild Companion."}, {"interrupt", true}}); return; }
			if (c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Wild Companion unlocks at Druid L2."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			// Player chooses the resource: prefer Wild Shape use if available, else lowest spell slot.
			bool used_ws = false;
			int ws_slot = 0;
			if (c.wild_shape_uses > 0) {
				c.wild_shape_uses--;
				used_ws = true;
			} else {
				for (int sl = 1; sl <= 9; sl++) {
					if (c.spell_slots_current[sl] > 0) { c.spell_slots_current[sl]--; ws_slot = sl; break; }
				}
				if (ws_slot == 0) { u.send({{"type", message_types::announce}, {"text", "No Wild Shape uses or spell slots available for Wild Companion."}, {"interrupt", true}}); return; }
			}
			c.has_action = false;
			c.used_action = true;
			string cost = used_ws ? "a use of Wild Shape" : ("a level " + ws_slot + " spell slot");
			u.room.bm.broadcast_announce(c.name + " expends " + cost + " to summon a fey familiar via Wild Companion.", true);
		}
		else if (feature == "wild_resurgence_slot_to_use") {
			// PHB 2024 Druid L5 Wild Resurgence (para 4427-4428): "Once on each of your
			// turns, if you have no uses of Wild Shape left, you can give yourself one
			// use by expending a spell slot (no action required)."
			if (c.class_name != "Druid") { u.send({{"type", message_types::announce}, {"text", "Only Druids can use Wild Resurgence."}, {"interrupt", true}}); return; }
			if (c.level < 5) { u.send({{"type", message_types::announce}, {"text", "Wild Resurgence unlocks at Druid L5."}, {"interrupt", true}}); return; }
			if (c.wild_shape_uses > 0) { u.send({{"type", message_types::announce}, {"text", "You still have Wild Shape uses; this option only works at 0 uses."}, {"interrupt", true}}); return; }
			if (c.wild_resurgence_slot_to_use_used_this_turn) { u.send({{"type", message_types::announce}, {"text", "Already used Wild Resurgence this turn."}, {"interrupt", true}}); return; }
			int wr_slot = 0;
			for (int sl = 1; sl <= 9; sl++) {
				if (c.spell_slots_current[sl] > 0) { c.spell_slots_current[sl]--; wr_slot = sl; break; }
			}
			if (wr_slot == 0) { u.send({{"type", message_types::announce}, {"text", "No spell slots available."}, {"interrupt", true}}); return; }
			c.wild_shape_uses++;
			c.wild_resurgence_slot_to_use_used_this_turn = true;
			u.room.bm.broadcast_announce(c.name + " channels Wild Resurgence — burns a level " + wr_slot + " slot to recover one Wild Shape use.", true);
		}
		else if (feature == "wild_resurgence_use_to_slot") {
			// PHB 2024 Druid L5 Wild Resurgence (para 4429): "you can expend one use of
			// Wild Shape (no action required) to give yourself a level 1 spell slot, but
			// you can't do so again until you finish a Long Rest."
			if (c.class_name != "Druid") { u.send({{"type", message_types::announce}, {"text", "Only Druids can use Wild Resurgence."}, {"interrupt", true}}); return; }
			if (c.level < 5) { u.send({{"type", message_types::announce}, {"text", "Wild Resurgence unlocks at Druid L5."}, {"interrupt", true}}); return; }
			if (c.wild_shape_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Wild Shape uses available."}, {"interrupt", true}}); return; }
			if (c.wild_resurgence_use_to_slot_used_this_rest) { u.send({{"type", message_types::announce}, {"text", "Already used the Wild Shape → spell slot conversion this rest."}, {"interrupt", true}}); return; }
			if (c.spell_slots_current[1] >= c.spell_slots_max[1]) { u.send({{"type", message_types::announce}, {"text", "Your level 1 spell slots are already full."}, {"interrupt", true}}); return; }
			c.wild_shape_uses--;
			c.spell_slots_current[1]++;
			c.wild_resurgence_use_to_slot_used_this_rest = true;
			u.room.bm.broadcast_announce(c.name + " channels Wild Resurgence — burns a Wild Shape use to recover a level 1 spell slot.", true);
		}
		else if (feature == "arcane_recovery") {
			// PHB 2024 Wizard L1 Arcane Recovery: "Once per day when you finish a Short
			// Rest, you can choose expended spell slots to recover. The slots can have a
			// combined level equal to no more than half your Wizard level (rounded up),
			// and none of the slots can be level 6 or higher."
			// Implemented as a bonus action available once per long rest (arcane_recovery_charges).
			if (c.class_name != "Wizard") { u.send({{"type", message_types::announce}, {"text", "Only Wizards can use Arcane Recovery."}, {"interrupt", true}}); return; }
			if (c.arcane_recovery_charges <= 0) { u.send({{"type", message_types::announce}, {"text", "You've already used Arcane Recovery today; rest to recover."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.arcane_recovery_charges--;
			// Recover slots summing to <= half level (rounded up), none L6+
			int budget = (c.level + 1) / 2;
			int recovered = 0;
			// Greedy: try to refill from highest slot level downward within budget
			for (int sl = 5; sl >= 1 and budget > 0; sl--) {
				while (budget >= sl and c.spell_slots_current[sl] < c.spell_slots_max[sl]) {
					c.spell_slots_current[sl]++;
					budget -= sl;
					recovered++;
				}
			}
			u.room.bm.broadcast_announce(c.name + " uses Arcane Recovery to restore " + recovered + " spell slot" + (recovered == 1 ? "" : "s") + " (combined level budget half wizard level, rounded up).", true);
		}
		else if (feature == "storm_aura") {
			// Xanathar's Storm Herald L3 Storm Aura (para 416-418): "you can activate
			// the effect again on each of your turns as a bonus action."
			if (c.class_name != "Barbarian" or c.subclass != "Storm Herald") { u.send({{"type", message_types::announce}, {"text", "Only Storm Herald barbarians can use Storm Aura."}, {"interrupt", true}}); return; }
			if (!c.storm_aura_active) { u.send({{"type", message_types::announce}, {"text", "Storm Aura is not active. Rage first."}, {"interrupt", true}}); return; }
			if (c.storm_aura_used_this_turn) { u.send({{"type", message_types::announce}, {"text", "Already used Storm Aura this turn."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.storm_aura_used_this_turn = true;
			u.room.bm.apply_storm_aura_effect(c);
		}

		else if (feature == "reckless_attack") {
			// PHB 2024 para 2785, Barbarian L2: "When you make your first attack roll on
			// your turn, you can decide to attack recklessly. Doing so gives you Advantage
			// on attack rolls using Strength until the start of your next turn, and attack
			// rolls against you have Advantage during that time."
			// Implemented as a turn-toggle flag (no action cost; declared instead of paid).
			if (c.class_name != "Barbarian") { u.send({{"type", message_types::announce}, {"text", "Only Barbarians can use Reckless Attack."}, {"interrupt", true}}); return; }
			if (c.level < 2) { u.send({{"type", message_types::announce}, {"text", "Reckless Attack unlocks at level 2."}, {"interrupt", true}}); return; }
			if (c.reckless_attack_active) { u.send({{"type", message_types::announce}, {"text", "Already attacking recklessly this turn."}, {"interrupt", true}}); return; }
			c.reckless_attack_active = true;
			u.room.bm.broadcast_announce(c.name + " attacks recklessly! Advantage on Strength attacks until next turn, but attacks against them also have advantage.", true);
		}
		// PHB 2024 Barbarian L9 Brutal Strike (para 2338-2341): toggle effect choice.
		// No action cost — declared before attacking, consumed on first qualifying hit.
		else if (feature == "brutal_strike") {
			if (c.class_name != "Barbarian") { u.send({{"type", message_types::announce}, {"text", "Only Barbarians can use Brutal Strike."}, {"interrupt", true}}); return; }
			if (c.level < 9) { u.send({{"type", message_types::announce}, {"text", "Brutal Strike unlocks at level 9."}, {"interrupt", true}}); return; }
			string effect = "";
			if (msg.exists("effect")) effect = string(msg["effect"]);
			string effect2 = "";
			if (msg.exists("effect2")) effect2 = string(msg["effect2"]);
			if (effect == "") { u.send({{"type", message_types::announce}, {"text", "No Brutal Strike effect chosen."}, {"interrupt", true}}); return; }
			// Validate effects are available at this level
			bool valid1 = (effect == "forceful" or effect == "hamstring");
			if (c.level >= 13) valid1 = valid1 or (effect == "staggering" or effect == "sundering");
			if (!valid1) { u.send({{"type", message_types::announce}, {"text", "Invalid Brutal Strike effect."}, {"interrupt", true}}); return; }
			// L17: two different effects
			if (effect2 != "" and c.level < 17) effect2 = "";
			if (effect2 == effect) effect2 = ""; // Must be different
			c.brutal_strike_active = true;
			c.brutal_strike_effect = effect;
			c.brutal_strike_effect2 = effect2;
			string desc = effect;
			if (effect2 != "") desc += " + " + effect2;
			u.room.bm.broadcast_announce(c.name + " prepares Brutal Strike: " + desc + "! (Forgoing Reckless advantage on next STR attack for +1d10 damage + effect)", false);
		}
		// PHB 2024 Rogue L5 Cunning Strike (para 6553-6560): toggle effect choice.
		// No action cost — declared before attacking, consumed when SA triggers.
		else if (feature == "cunning_strike") {
			if (c.class_name != "Rogue") { u.send({{"type", message_types::announce}, {"text", "Only Rogues can use Cunning Strike."}, {"interrupt", true}}); return; }
			if (c.level < 5) { u.send({{"type", message_types::announce}, {"text", "Cunning Strike unlocks at level 5."}, {"interrupt", true}}); return; }
			string effect = "";
			if (msg.exists("effect")) effect = string(msg["effect"]);
			string effect2 = "";
			if (msg.exists("effect2")) effect2 = string(msg["effect2"]);
			if (effect == "") {
				// Clear the toggle
				c.cunning_strike_effect = "";
				c.cunning_strike_effect2 = "";
				u.send({{"type", message_types::announce}, {"text", "Cunning Strike cleared."}, {"interrupt", true}});
				return;
			}
			// Validate effects at level
			bool valid1 = (effect == "poison" or effect == "trip" or effect == "withdraw");
			if (c.level >= 14) valid1 = valid1 or (effect == "daze" or effect == "knockout" or effect == "obscure");
			if (!valid1) { u.send({{"type", message_types::announce}, {"text", "Invalid Cunning Strike effect."}, {"interrupt", true}}); return; }
			// L11 Improved: two effects allowed
			if (effect2 != "" and c.level < 11) effect2 = "";
			c.cunning_strike_effect = effect;
			c.cunning_strike_effect2 = effect2;
			string desc = effect;
			if (effect2 != "") desc += " + " + effect2;
			int cost = 0;
			if (effect == "poison" or effect == "trip" or effect == "withdraw") cost += 1;
			else if (effect == "daze") cost += 2;
			else if (effect == "obscure") cost += 3;
			else if (effect == "knockout") cost += 6;
			if (effect2 == "poison" or effect2 == "trip" or effect2 == "withdraw") cost += 1;
			else if (effect2 == "daze") cost += 2;
			else if (effect2 == "obscure") cost += 3;
			else if (effect2 == "knockout") cost += 6;
			u.room.bm.broadcast_announce(c.name + " prepares Cunning Strike: " + desc + "! (Forfeiting " + cost + "d6 SA dice for rider effect on next Sneak Attack)", false);
		}
		else if (feature == "summon_primal_companion") {
			// Tasha's Beast Master Ranger L3 Primal Companion: bonus action summon a Land/
			// Sea/Sky beast companion. Source stat block: HP = 5 + 5*ranger level, AC =
			// 13 + ranger PB, attack bonus = ranger PB + WIS mod, damage = 1d8 + ranger PB.
			// Default to Land beast (slashing damage); the Tasha's source has 3 variants.
			if (c.class_name != "Ranger" or c.subclass != "Beast Master") { u.send({{"type", message_types::announce}, {"text", "Only Beast Master rangers can summon a Primal Companion."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.beast_companion_id != 0) { u.send({{"type", message_types::announce}, {"text", "Your Primal Companion is already in the field."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int companion_hp = 5 + 5 * c.level;
			int companion_ac = 13 + c.proficiency;
			int wis_mod_bm = c.get_ability_mod(ABILITY_WIS);
			int companion_attack = c.proficiency + wis_mod_bm;
			int companion_dmg_mod = c.proficiency;
			combatant@ pet = u.room.bm.spawn_companion(c, "beast_master_land", c.name + "'s Land Beast", companion_hp, companion_ac, 40, companion_attack, 1, 8, companion_dmg_mod, DMG_SLASHING, 0);
			if (@pet != null) {
				c.beast_companion_id = pet.id;
				c.beast_companion_active = true;
				u.room.bm.broadcast_announce(c.name + " summons their Primal Land Beast! HP " + companion_hp + ", AC " + companion_ac + ".", true);
			}
		}
		else if (feature == "summon_steel_defender") {
			// Tasha's Battle Smith Artificer L3 Steel Defender: full stat block construct.
			// HP = 2 + 5*artificer level + INT mod (per Tasha's), AC = 15, speed 40.
			// Attack: rend, +PB+INT to hit, 1d8+PB force damage.
			if (c.class_name != "Artificer" or c.subclass != "Battle Smith") { u.send({{"type", message_types::announce}, {"text", "Only Battle Smith artificers can summon a Steel Defender."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.steel_defender_active) { u.send({{"type", message_types::announce}, {"text", "Your Steel Defender is already active."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int int_mod_bs = c.get_ability_mod(ABILITY_INT);
			int defender_hp = 2 + 5 * c.level + int_mod_bs;
			int defender_attack = c.proficiency + int_mod_bs;
			combatant@ defender = u.room.bm.spawn_companion(c, "battle_smith", c.name + "'s Steel Defender", defender_hp, 15, 40, defender_attack, 1, 8, c.proficiency, DMG_FORCE, 0);
			if (@defender != null) {
				c.steel_defender_active = true;
				u.room.bm.broadcast_announce(c.name + " activates their Steel Defender! HP " + defender_hp + ", AC 15.", true);
			}
		}
		else if (feature == "summon_wildfire_spirit") {
			// Tasha's Cauldron Circle of Wildfire Druid L2: "you can summon the primal
			// spirit bound to your soul. As an action, you can expend one use of your Wild
			// Shape feature to summon your Wildfire Spirit, rather than assuming a Beast
			// form." Stat block per Tasha's: HP = 5 + 5*druid level, AC = 13, speed 30,
			// Flame Seed ranged attack +PB+WIS to hit, 1d6+PB fire damage.
			if (c.class_name != "Druid" or c.subclass != "Circle of Wildfire") { u.send({{"type", message_types::announce}, {"text", "Only Wildfire druids can summon a Wildfire Spirit."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.wild_shape_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Wild Shape uses remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.wild_shape_uses--;
			int spirit_hp = 5 + 5 * c.level;
			int wis_mod_wf = c.get_ability_mod(ABILITY_WIS);
			int spirit_attack = c.proficiency + wis_mod_wf;
			combatant@ spirit = u.room.bm.spawn_companion(c, "wildfire_spirit", c.name + "'s Wildfire Spirit", spirit_hp, 13, 30, spirit_attack, 1, 6, c.proficiency, DMG_FIRE, 0);
			if (@spirit != null) {
				u.room.bm.broadcast_announce(c.name + " summons their Wildfire Spirit! HP " + spirit_hp + ", AC 13, ranged Flame Seed attack.", true);
			}
		}
		else if (feature == "create_eldritch_cannon") {
			// Tasha's Cauldron Artillerist Artificer L3: "Using woodcarver's tools or
			// smith's tools, you can take a Magic action to magically create a Small or
			// Tiny Eldritch Cannon in an unoccupied space on a horizontal surface within
			// 5 feet of you." Stat block per Tasha's: HP = 5 * artificer level, AC = 18,
			// speed 15. Three modes: Flamethrower, Force Ballista, Protector. Default to
			// Force Ballista (1d8 force, 120 ft).
			if (c.class_name != "Artificer" or c.subclass != "Artillerist") { u.send({{"type", message_types::announce}, {"text", "Only Artillerist artificers can build an Eldritch Cannon."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.eldritch_cannon_active) { u.send({{"type", message_types::announce}, {"text", "Your Eldritch Cannon is already deployed."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			int cannon_hp = 5 * c.level;
			int int_mod_art = c.get_ability_mod(ABILITY_INT);
			int cannon_attack = c.proficiency + int_mod_art;
			combatant@ cannon = u.room.bm.spawn_companion(c, "artillerist_cannon", c.name + "'s Eldritch Cannon", cannon_hp, 18, 15, cannon_attack, 2, 8, 0, DMG_FORCE, 0);
			if (@cannon != null) {
				c.eldritch_cannon_active = true;
				c.eldritch_cannon_hp = cannon_hp;
				u.room.bm.broadcast_announce(c.name + " constructs an Eldritch Cannon (Force Ballista mode)! HP " + cannon_hp + ", AC 18, 2d8 force ranged attack.", true);
			}
		}
		else if (feature == "summon_drake_companion") {
			// Fizban's Drakewarden Ranger L3 Drake Companion: HP = 5 + 5*ranger level (matches
			// existing drake_max_hp init). AC = 14 + PB, speed 40. Bite attack +PB+WIS,
			// 1d6+PB damage of the chosen damage type (acid/cold/fire/lightning/poison).
			if (c.class_name != "Ranger" or c.subclass != "Drakewarden") { u.send({{"type", message_types::announce}, {"text", "Only Drakewarden rangers can summon a Drake."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.drake_companion_active) { u.send({{"type", message_types::announce}, {"text", "Your Drake is already in the field."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int drake_hp_now = c.drake_max_hp > 0 ? c.drake_max_hp : 5 + 5 * c.level;
			int wis_mod_dk = c.get_ability_mod(ABILITY_WIS);
			int drake_attack = c.proficiency + wis_mod_dk;
			// Map drake_damage_type int to DMG_ constant: 0=acid 1=cold 2=fire 3=lightning 4=poison
			int drake_dmg_type = DMG_FIRE;
			if (c.drake_damage_type == 0) drake_dmg_type = DMG_ACID;
			else if (c.drake_damage_type == 1) drake_dmg_type = DMG_COLD;
			else if (c.drake_damage_type == 2) drake_dmg_type = DMG_FIRE;
			else if (c.drake_damage_type == 3) drake_dmg_type = DMG_LIGHTNING;
			else if (c.drake_damage_type == 4) drake_dmg_type = DMG_POISON;
			combatant@ drake = u.room.bm.spawn_companion(c, "drakewarden", c.name + "'s Drake", drake_hp_now, 14 + c.proficiency, 40, drake_attack, 1, 6, c.proficiency, drake_dmg_type, 0);
			if (@drake != null) {
				c.drake_companion_active = true;
				c.drake_hp = drake_hp_now;
				u.room.bm.broadcast_announce(c.name + " summons their Drake Companion! HP " + drake_hp_now + ", AC " + (14 + c.proficiency) + ".", true);
			}
		}
		else if (feature == "set_piety_god") {
			// Client-side configuration: set the player's god (Theros Piety).
			// Persists to account data and updates active combatant if any.
			string god_name = msg.exists("value") ? string(msg["value"]) : "";
			if (god_name == "") { u.send({{"type", message_types::announce}, {"text", "No god specified."}, {"interrupt", true}}); return; }
			piety_god_def@ check = get_piety_god(god_name);
			if (@check == null) { u.send({{"type", message_types::announce}, {"text", "Unknown Theros god: " + god_name + ". Valid: Athreos, Ephara, Erebos, Heliod, Iroas, Karametra, Keranos, Klothys, Kruphix, Mogis, Nylea, Pharika, Phenax, Purphoros, Thassa."}, {"interrupt", true}}); return; }
			c.piety_god = god_name;
			if (c.piety_score < 1) c.piety_score = 1;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["piety_god"] = god_name;
					ch["piety_score"] = c.piety_score;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "You now worship " + god_name + " (" + check.title + "). Piety score: " + c.piety_score + "."}, {"interrupt", true}});
		}
		else if (feature == "set_group_patron") {
			string patron_name = msg.exists("value") ? string(msg["value"]) : "";
			if (patron_name == "") { u.send({{"type", message_types::announce}, {"text", "No patron specified."}, {"interrupt", true}}); return; }
			group_patron_def@ check = get_group_patron(patron_name);
			if (@check == null) { u.send({{"type", message_types::announce}, {"text", "Unknown patron: " + patron_name + ". Valid: Academy, Ancient Being, Aristocrat, Criminal Syndicate, Guild, Military Force, Religious Order, Sovereign."}, {"interrupt", true}}); return; }
			c.group_patron = patron_name;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["group_patron"] = patron_name;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "Your group patron is now: " + patron_name + "."}, {"interrupt", true}});
		}
		else if (feature == "set_ravnica_guild") {
			string guild_name = msg.exists("value") ? string(msg["value"]) : "";
			if (guild_name == "") { u.send({{"type", message_types::announce}, {"text", "No guild specified."}, {"interrupt", true}}); return; }
			ravnica_guild_def@ check = get_ravnica_guild(guild_name);
			if (@check == null) { u.send({{"type", message_types::announce}, {"text", "Unknown Ravnica guild: " + guild_name + ". Valid: Azorius Senate, Boros Legion, House Dimir, Golgari Swarm, Gruul Clans, Izzet League, Orzhov Syndicate, Cult of Rakdos, Selesnya Conclave, Simic Combine."}, {"interrupt", true}}); return; }
			c.ravnica_guild = guild_name;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["ravnica_guild"] = guild_name;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "You are now a member of " + guild_name + " (" + check.colors + ")."}, {"interrupt", true}});
		}
		else if (feature == "set_transformation") {
			string trans_name = msg.exists("value") ? string(msg["value"]) : "";
			int stage = msg.exists("stage") ? int(msg["stage"]) : 1;
			if (trans_name == "") {
				c.transformation = "";
				c.transformation_stage = 0;
				if (@u.account != null) {
					json_object@ data = u.account.data;
					string ckey = get_character_storage_key(u.room.game_type);
					if (data.exists(ckey)) {
						json_object@ ch = data[ckey];
						ch["transformation"] = "";
						ch["transformation_stage"] = 0;
						u.account.commit();
					}
				}
				u.send({{"type", message_types::announce}, {"text", "You are no longer undergoing any transformation."}, {"interrupt", true}});
				return;
			}
			transformation_def@ check = get_transformation(trans_name);
			if (@check == null) { u.send({{"type", message_types::announce}, {"text", "Unknown transformation: " + trans_name + ". Valid: Vampirism, Lycanthropy, Lichdom, Aberrant Horror, Demonic Pact, Seraphic Ascension."}, {"interrupt", true}}); return; }
			if (stage < 0) stage = 0;
			if (stage > 20) stage = 20;
			c.transformation = trans_name;
			c.transformation_stage = stage;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["transformation"] = trans_name;
					ch["transformation_stage"] = stage;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "You are now undergoing " + trans_name + " at stage " + transformation_stage_name(stage) + " (" + stage + "/20)."}, {"interrupt", true}});
		}
		else if (feature == "set_fey_court") {
			string court_name = msg.exists("value") ? string(msg["value"]) : "";
			if (court_name == "") { u.send({{"type", message_types::announce}, {"text", "No court specified."}, {"interrupt", true}}); return; }
			fey_court_def@ check = get_fey_court(court_name);
			if (@check == null) { u.send({{"type", message_types::announce}, {"text", "Unknown fey court: " + court_name + "."}, {"interrupt", true}}); return; }
			c.fey_court = court_name;
			if (@u.account != null) {
				json_object@ data = u.account.data;
				string ckey = get_character_storage_key(u.room.game_type);
				if (data.exists(ckey)) {
					json_object@ ch = data[ckey];
					ch["fey_court"] = court_name;
					u.account.commit();
				}
			}
			u.send({{"type", message_types::announce}, {"text", "You are now a member of the " + court_name + " (ruled by " + check.ruler + ")."}, {"interrupt", true}});
		}
		else if (feature == "query_phase1") {
			// List all current Phase 1 affiliations for this character
			string report = c.name + " Phase 1 Status:\n";
			report += "  Piety God: " + (c.piety_god != "" ? c.piety_god + " (score " + c.piety_score + ")" : "None") + "\n";
			report += "  Group Patron: " + (c.group_patron != "" ? c.group_patron : "None") + "\n";
			report += "  Ravnica Guild: " + (c.ravnica_guild != "" ? c.ravnica_guild : "None") + "\n";
			report += "  Transformation: " + (c.transformation != "" ? c.transformation + " (" + transformation_stage_name(c.transformation_stage) + ")" : "None") + "\n";
			report += "  Fey Court: " + (c.fey_court != "" ? c.fey_court : "None") + "\n";
			u.send({{"type", message_types::announce}, {"text", report}, {"interrupt", true}});
		}
		else if (feature == "invoke_devotee_trait") {
			// Theros Piety — Devotee trait (source para 1328-1329): The player casts
			// their god's devotee-trait spell for free, a number of times equal to
			// the god's chosen ability modifier per long rest.
			if (c.piety_god == "" or c.piety_score < 3) { u.send({{"type", message_types::announce}, {"text", "You must be a Devotee (Piety 3+) of a god to invoke this trait."}, {"interrupt", true}}); return; }
			if (c.piety_devotee_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "You have no Devotee trait uses remaining. Finish a long rest to recover them."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			piety_god_def@ god = get_piety_god(c.piety_god);
			if (@god == null or god.devotee_spell == "") { u.send({{"type", message_types::announce}, {"text", "Your god grants no castable Devotee spell."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.piety_devotee_uses--;
			u.room.bm.broadcast_announce(c.name + " calls on " + c.piety_god + "'s favor and casts " + god.devotee_spell + "! (Devotee uses remaining: " + c.piety_devotee_uses + ")", true);
			// Route to cast pipeline as a free cast of the god's spell
			json_object free_cast_msg;
			free_cast_msg["type"] = message_types::action_cast;
			free_cast_msg["spell_id"] = god.devotee_spell;
			free_cast_msg["target_id"] = target_id;
			free_cast_msg["slot_level"] = 1;  // Always L1 (free cast)
			free_cast_msg["is_free_cast"] = true;
			u.room.bm.handle_cast(u, free_cast_msg);
		}
		else if (feature == "group_assistance") {
			// Tasha's Group Patrons — Group Assistance (source para 4910): "Each member
			// of the party can add a d4 to one ability check, attack roll, or saving
			// throw they make. A player must decide to use this ability before rolling
			// the d20." Once per long rest.
			if (c.group_patron == "") { u.send({{"type", message_types::announce}, {"text", "You have no Group Patron to call upon for assistance."}, {"interrupt", true}}); return; }
			if (c.group_assistance_used_this_rest) { u.send({{"type", message_types::announce}, {"text", "You have already called on your Patron for assistance today."}, {"interrupt", true}}); return; }
			c.group_assistance_used_this_rest = true;
			// Grant a luck point as a proxy for the d4 assistance bonus (the luck
			// reroll pipeline is the closest existing match for a one-shot roll bonus).
			if (!c.has_lucky_feat) {
				c.has_lucky_feat = true;
				c.luck_points_max = 1;
			}
			c.luck_points = c.luck_points_max > 0 ? c.luck_points_max : 1;
			u.room.bm.broadcast_announce(c.name + " calls on their Patron (" + c.group_patron + ") for Group Assistance! They gain +1d4 to their next d20 roll this rest.", true);
		}
		else if (feature == "telekinetic_shove") {
			// Telekinetic feat (PHB para 7813): "As a Bonus Action, you can telekinetically
			// shove one creature you can see within 30 feet of yourself. When you do so,
			// the target must succeed on a Strength saving throw (DC 8 plus the relevant
			// ability modifier and your Proficiency Bonus) or be moved 5 feet toward you
			// or away from you."
			if (!c.has_feat("telekinetic")) { u.send({{"type", message_types::announce}, {"text", "You don't have the Telekinetic feat."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 feet)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// "Relevant ability modifier" = the player's INT, WIS, or CHA (highest of the three)
			int int_mod = c.get_ability_mod(ABILITY_INT);
			int wis_mod = c.get_ability_mod(ABILITY_WIS);
			int cha_mod = c.get_ability_mod(ABILITY_CHA);
			int best_mod = int_mod;
			if (wis_mod > best_mod) best_mod = wis_mod;
			if (cha_mod > best_mod) best_mod = cha_mod;
			int dc = 8 + c.proficiency + best_mod;
			int save_roll = random(1, 20) + tgt.get_save_bonus(ABILITY_STR);
			if (save_roll < dc) {
				// Push 5 ft directly away from caster (one tile)
				int dx = 0;
				int dy = 0;
				if (tgt.x > c.x) dx = 1;
				else if (tgt.x < c.x) dx = -1;
				if (tgt.y > c.y) dy = 1;
				else if (tgt.y < c.y) dy = -1;
				if (dx == 0 and dy == 0) dy = 1; // Same square: arbitrary push direction
				int new_x = tgt.x + dx;
				int new_y = tgt.y + dy;
				if (new_x >= 0 and new_x < u.room.bm.combat.map_width and new_y >= 0 and new_y < u.room.bm.combat.map_height) {
					tgt.x = new_x;
					tgt.y = new_y;
				}
				u.room.bm.broadcast_announce(c.name + "'s telekinetic shove pushes " + tgt.name + " 5 feet away! (STR save " + save_roll + " vs DC " + dc + ")", true);
			} else {
				u.room.bm.broadcast_announce(tgt.name + " resists " + c.name + "'s telekinetic shove. (STR save " + save_roll + " vs DC " + dc + ")", true);
			}
		}
		else if (feature == "divine_initiative") {
			// Book of Ebon Tides paras 1088-1090, Keeper Domain L2 Channel Divinity:
			// "As an action, you present your holy symbol and choose a number of creatures
			// that you can see and that can see you within 60 feet of you, up to a number
			// equal to your Wisdom modifier (minimum of one). Each of them gains 5
			// temporary hit points. When a target gains these temporary hit points, they
			// can immediately use their reaction to make one weapon attack."
			// Temp HP scales: 5 (L2), 8 (L6), 11 (L8), 14 (L17).
			if (c.class_name != "Cleric" or c.subclass != "Keeper Domain") { u.send({{"type", message_types::announce}, {"text", "Only Keeper Domain clerics can use Divine Initiative."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int wis_mod = c.get_ability_mod(ABILITY_WIS);
			if (wis_mod < 1) wis_mod = 1;
			int temp_hp = 5;
			if (c.level >= 17) temp_hp = 14;
			else if (c.level >= 8) temp_hp = 11;
			else if (c.level >= 6) temp_hp = 8;
			int blessed_count = 0;
			for (uint i = 0; i < u.room.bm.combat.combatants.length() and blessed_count < wis_mod; i++) {
				combatant@ ally = u.room.bm.combat.combatants[i];
				if (@ally == null or ally.is_dead) continue;
				if (ally.is_player != c.is_player and ally.id != c.id) continue;
				if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) continue;
				if (ally.temp_hp < temp_hp) ally.temp_hp = temp_hp;
				blessed_count++;
				u.room.bm.broadcast_announce(ally.name + " gains " + temp_hp + " temporary hit points from Divine Initiative.", false);
			}
			u.room.bm.broadcast_announce(c.name + " presents their holy symbol and channels Divine Initiative for " + blessed_count + " allies.", true);
		}
		else if (feature == "creeping_fog") {
			// Book of Ebon Tides para 1200, Shadow Gnawer Barbarian L6:
			// "As an action, you magically teleport, along with any equipment you are
			// wearing or carrying, up to 60 feet to an unoccupied space you can see.
			// Before or after teleporting, you can make one melee attack."
			// Movement is approximated: places the barbarian adjacent to the chosen target
			// (if any) within 60 ft, then resolves a single melee attack.
			if (c.class_name != "Barbarian" or c.subclass != "Shadow Gnawer") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Gnawer barbarians can use Creeping Fog."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Creeping Fog unlocks at level 6."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Target out of range (60 feet)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			// Teleport adjacent to target on a free side
			int new_x = tgt.x;
			int new_y = tgt.y - 1;
			if (new_y < 0) new_y = tgt.y + 1;
			c.x = new_x;
			c.y = new_y;
			u.room.bm.broadcast_announce(c.name + " bursts into mist and reforms next to " + tgt.name + " with Creeping Fog.", true);
			// Resolve a single melee attack as part of the teleport (mirrors the source).
			pending_roll pr;
			pr.combatant_id = c.id;
			pr.player_username = c.player_username;
			pr.roll_type = ROLL_ATTACK;
			pr.dice_sides = 20;
			pr.modifier = u.room.bm.get_attack_bonus_for_roll(c, false);
			pr.reason = c.main_hand + " attack against " + tgt.name + " (Creeping Fog)";
			pr.target_id = tgt.id;
			pr.attack_name = c.main_hand;
			pr.damage_dice_count = u.room.bm.get_attack_damage_count(c, false);
			pr.damage_dice_sides = u.room.bm.get_attack_damage_dice(c, false);
			pr.damage_modifier = u.room.bm.get_damage_modifier_for_attack(c, false);
			pr.damage_type = c.main_hand_damage_type;
			pr.is_weapon_attack = true;
			@u.room.bm.current_roll = pr;
			u.room.bm.send_roll_request(u, pr);
		}
		else if (feature == "consume_darkness") {
			// Book of Ebon Tides paras 1202-1203, Shadow Gnawer L10:
			// "While in dim light or darkness, you can use a bonus action to regain hit
			// points equal to 1d12 + your Constitution modifier. For the duration of your
			// rage (up to 1 minute), you regain 1 hit point at the start of each of your
			// turns. Once you use this feature, you must finish a short or long rest
			// before you can use it again."
			if (c.class_name != "Barbarian" or c.subclass != "Shadow Gnawer") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Gnawer barbarians can consume darkness."}, {"interrupt", true}}); return; }
			if (c.level < 10) { u.send({{"type", message_types::announce}, {"text", "Consume Darkness unlocks at level 10."}, {"interrupt", true}}); return; }
			if (!c.raging) { u.send({{"type", message_types::announce}, {"text", "You must be raging to use Consume Darkness."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.consume_darkness_used) { u.send({{"type", message_types::announce}, {"text", "Consume Darkness has been used; rest to recover."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.consume_darkness_used = true;
			int heal = random(1, 12) + c.get_ability_mod(ABILITY_CON);
			if (heal < 1) heal = 1;
			c.current_hp += heal;
			if (c.current_hp > c.max_hp) c.current_hp = c.max_hp;
			c.consume_darkness_per_turn_heal = 1; // Drains over the rage duration
			u.room.bm.broadcast_announce(c.name + " consumes the surrounding darkness, regaining " + heal + " hit points and 1 HP at the start of each turn while raging.", true);
		}
		else if (feature == "umbral_form") {
			// Book of Ebon Tides para 1016, Circle of Shadows Druid L2:
			// "as a bonus action, you can expend a use of your Wild Shape feature to take
			// on a shadowy umbral form, rather than transforming into a beast. The form
			// lasts for 10 minutes."
			if (c.class_name != "Druid" or c.subclass != "Circle of Shadows") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Shadows druids can take Umbral Form."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.wild_shape_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Wild Shape uses remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.wild_shape_uses--;
			c.umbral_form_active = true;
			c.umbral_form_rounds = 100; // 10 minutes
			// L10 Shadow Mass: Umbral Form grants fly speed and B/P/S nonmagical resistance
			if (c.level >= 10) {
				c.bludgeoning_resistance = true;
				c.piercing_resistance = true;
				c.slashing_resistance = true;
				c.flying_speed = c.speed;
			}
			u.room.bm.broadcast_announce(c.name + " takes on a shadowy Umbral Form. They can hide as a bonus action in dim light or darkness." + (c.level >= 10 ? " Shadow Mass grants flight and physical resistance." : ""), true);
		}
		else if (feature == "darkness_falls") {
			// Book of Ebon Tides para 1049-1051, Circle of Shadows L14:
			// "you can use an action to emit a 15-foot-radius sphere of magical darkness
			// centered on yourself... lasts for 1 minute, until you are incapacitated, or
			// until it comes into contact with sunlight."
			if (c.class_name != "Druid" or c.subclass != "Circle of Shadows") { u.send({{"type", message_types::announce}, {"text", "Only Circle of Shadows druids can call Darkness Falls."}, {"interrupt", true}}); return; }
			if (c.level < 14) { u.send({{"type", message_types::announce}, {"text", "Darkness Falls unlocks at level 14."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.darkness_falls_used) { u.send({{"type", message_types::announce}, {"text", "Darkness Falls has been used; rest to recover."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.darkness_falls_used = true;
			c.darkness_active = true;
			u.room.bm.broadcast_announce(c.name + " calls Darkness Falls! A 15-foot sphere of magical darkness surrounds them, dispelling lower-level light spells. (1 minute)", true);
		}
		else if (feature == "dark_transfusion") {
			// Book of Ebon Tides para 1157, Shadow Arcane Wizard L2:
			// "As a bonus action, you can expend two spell slots to recover one spell slot
			// equal to or less than the total combined value of the expended spell slots."
			if (c.class_name != "Wizard" or c.subclass != "Shadow Arcane Tradition") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Arcane wizards can perform Dark Transfusion."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			// Find two lowest-level slots to expend (greedy heuristic to maximize the recovered slot value).
			int first_slot = -1;
			int second_slot = -1;
			for (int sl = 1; sl <= 9; sl++) {
				if (c.spell_slots_current[sl] > 0) {
					if (first_slot < 0) { first_slot = sl; }
					else if (second_slot < 0) { second_slot = sl; break; }
				}
			}
			if (first_slot < 0 or second_slot < 0) { u.send({{"type", message_types::announce}, {"text", "You need at least two spell slots to perform Dark Transfusion."}, {"interrupt", true}}); return; }
			int combined = first_slot + second_slot;
			int recovered_slot = combined > 9 ? 9 : combined;
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.spell_slots_current[first_slot]--;
			c.spell_slots_current[second_slot]--;
			c.spell_slots_current[recovered_slot]++;
			u.room.bm.broadcast_announce(c.name + " performs Dark Transfusion: expends a level " + first_slot + " slot and a level " + second_slot + " slot to recover a level " + recovered_slot + " slot.", true);
		}
		else if (feature == "dancing_shadows") {
			// Book of Ebon Tides para 1056-1058, College of Shadow Bard L3:
			// "As a bonus action, you can expend a Bardic Inspiration to create a 20-foot-radius
			// sphere of shifting shadows centered on you. The sphere moves with you, spreads
			// around corners, and lasts for 1 minute or until you are incapacitated or die.
			// Allied creatures (including you) standing in the sphere have half cover, and
			// creatures outside the sphere have disadvantage on Wisdom (Perception) checks
			// made to perceive anything inside the sphere."
			if (c.class_name != "Bard" or c.subclass != "College of Shadow") { u.send({{"type", message_types::announce}, {"text", "Only College of Shadow bards can weave Dancing Shadows."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Bardic Inspiration remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			c.dancing_shadows_active = true;
			c.dancing_shadows_rounds = 10; // 1 minute
			u.room.bm.broadcast_announce(c.name + " expends a Bardic Inspiration to weave Dancing Shadows in a 20-foot sphere. Allies inside have half cover.", true);
		}
		else if (feature == "venomous_mark") {
			// Book of Ebon Tides para 1137, Mother of Sorrows Warlock L1:
			// "as a bonus action, choose one creature you can see within 30 feet of you.
			// The target is cursed for 1 minute. The curse ends early if the target dies,
			// you die, or you are incapacitated. Until the curse ends, you deal an extra
			// 1d6 poison damage to the target whenever you hit it with a spell attack."
			if (c.class_name != "Warlock" or c.subclass != "Mother of Sorrows") { u.send({{"type", message_types::announce}, {"text", "Only Mother of Sorrows warlocks can place a Venomous Mark."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 feet)."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.venomous_mark_target_id = tgt.id;
			c.venomous_mark_rounds = 10; // 1 minute
			u.room.bm.broadcast_announce(c.name + " curses " + tgt.name + " with a Venomous Mark. +1d6 poison damage on each spell attack hit.", true);
		}
		else if (feature == "shadow_grasp") {
			// Book of Ebon Tides para 1186, Shadow Domain Cleric L2 Channel Divinity:
			// "As an action, choose one creature that you can see within 30 feet of you.
			// That creature must make a Strength saving throw. If the creature fails the
			// saving throw, it is restrained by its shadow until the end of your next turn.
			// If the creature succeeds, it is grappled by its shadow until the end of your
			// next turn." L17 Army of Shadow expands to proficiency bonus targets.
			if (c.class_name != "Cleric" or c.subclass != "Shadow Domain") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Domain clerics can use Shadow Grasp."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target out of range (30 feet)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int save_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			// L17 Army of Shadow: Shadow Grasp affects up to PB targets simultaneously
			int max_targets = c.level >= 17 ? c.proficiency : 1;
			combatant@[] targets;
			targets.insert_last(tgt);
			if (max_targets > 1) {
				for (uint i = 0; i < u.room.bm.combat.combatants.length() and int(targets.length()) < max_targets; i++) {
					combatant@ extra = u.room.bm.combat.combatants[i];
					if (@extra == null or extra.id == c.id or extra.id == tgt.id or extra.is_dead) continue;
					if (!u.room.bm.combat.are_hostile(c, extra)) continue;
					if (feet_distance(c.x, c.y, extra.x, extra.y) > 30) continue;
					if (!u.room.bm.combat.can_see(c, extra)) continue;
					targets.insert_last(extra);
				}
			}
			for (uint i = 0; i < targets.length(); i++) {
				combatant@ st = targets[i];
				int save_roll = random(1, 20) + st.get_save_bonus(ABILITY_STR);
				if (save_roll < save_dc) {
					st.add_condition(COND_RESTRAINED);
					u.room.bm.broadcast_announce(st.name + "'s shadow surges up and restrains them! (Strength save " + save_roll + " vs DC " + save_dc + ")", true);
				} else {
					st.add_condition(COND_GRAPPLED);
					u.room.bm.broadcast_announce(st.name + "'s shadow grips them, leaving them grappled. (Strength save " + save_roll + " vs DC " + save_dc + ")", true);
				}
			}
		}
		else if (feature == "fade_to_black") {
			// Book of Ebon Tides para 1188, Shadow Domain L6:
			// "As a bonus action when you are in dim light or darkness, you can magically
			// become invisible for 1 minute. This effect ends early if you attack or cast
			// a spell. You can use this feature a number of times equal to your proficiency
			// bonus. You regain all expended uses when you finish a long rest."
			if (c.class_name != "Cleric" or c.subclass != "Shadow Domain") { u.send({{"type", message_types::announce}, {"text", "Only Shadow Domain clerics can fade to black."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Fade to Black unlocks at level 6."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.fade_to_black_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Fade to Black uses remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.fade_to_black_uses--;
			c.fade_to_black_active = true;
			c.add_condition(COND_INVISIBLE);
			c.is_hidden = true;
			u.room.bm.broadcast_announce(c.name + " fades into the shadows and becomes invisible. The effect ends if they attack or cast a spell.", true);
		}
		else if (feature == "flickering_aura") {
			// Book of Ebon Tides para 1107-1108, Light Weaver L1:
			// "While light-shifted you can use an action to emit an aura of bright light in
			// a 15-foot-radius sphere centered on yourself. While the aura persists, you
			// can use a bonus action to expand or reduce its radius of bright light by 5
			// feet, to a maximum of 30 feet each or a minimum of 10 feet."
			if (c.class_name != "Sorcerer" or c.subclass != "Light Weaver") { u.send({{"type", message_types::announce}, {"text", "Only Light Weaver sorcerers can manifest a Flickering Aura."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.light_weaver_aura_active = !c.light_weaver_aura_active;
			if (c.light_weaver_aura_active) {
				string variant = c.light_weaver_dark_shifted ? "darkness" : "bright light";
				u.room.bm.broadcast_announce(c.name + " emits a Flickering Aura of " + variant + " in a " + c.light_weaver_aura_radius + "-foot-radius sphere.", true);
			} else {
				u.room.bm.broadcast_announce(c.name + " dismisses their Flickering Aura.", true);
			}
		}
		else if (feature == "refraction_shield") {
			// Book of Ebon Tides para 1111, Light Weaver L6:
			// "As a bonus action, you can spend 3 sorcery points to magically create a
			// shield of light. While the shield is in place, whenever a creature within
			// 5 feet of you hits you with a melee attack, the shield flashes with searing
			// energy, and the attacker takes 2d8 radiant damage if you are light-shifted
			// or 2d8 necrotic damage if you are dark-shifted. The shield disappears if
			// you fall unconscious or after 10 minutes."
			if (c.class_name != "Sorcerer" or c.subclass != "Light Weaver") { u.send({{"type", message_types::announce}, {"text", "Only Light Weaver sorcerers can raise a Refraction Shield."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Refraction Shield unlocks at level 6."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.sorcery_points < 3) { u.send({{"type", message_types::announce}, {"text", "You need 3 sorcery points to cast Refraction Shield."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.sorcery_points -= 3;
			c.refraction_shield_active = true;
			string variant = c.light_weaver_dark_shifted ? "necrotic" : "radiant";
			u.room.bm.broadcast_announce(c.name + " conjures a Refraction Shield. Melee attackers within 5 feet take 2d8 " + variant + " damage on hit.", true);
		}
		else if (feature == "inquisitors_eye") {
			// Grim Hollow Player Pack para 434: "You can use your Channel Divinity to open
			// your senses to hidden signs of corruption and malfeasance. As a bonus action,
			// you grant yourself advantage on Intelligence (Investigation), Wisdom (Insight),
			// and Wisdom (Perception) ability checks for the next 10 minutes. During this
			// time, you can't be surprised."
			// 10 minutes = ~100 rounds = effectively the rest of any single combat encounter.
			if (c.class_name != "Paladin" or c.subclass != "Oath of Zeal") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Zeal paladins can use Inquisitor's Eye."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			// Grant per-skill advantage flags via the new skill check system.
			if (!c.has_skill_check_advantage("Investigation")) c.skill_check_advantage.insert_last("Investigation");
			if (!c.has_skill_check_advantage("Insight")) c.skill_check_advantage.insert_last("Insight");
			if (!c.has_skill_check_advantage("Perception")) c.skill_check_advantage.insert_last("Perception");
			c.inquisitors_eye_active = true;
			u.room.bm.broadcast_announce(c.name + "'s senses sharpen with Inquisitor's Eye. Advantage on Investigation, Insight, and Perception checks for 10 minutes; cannot be surprised.", true);
		}
		else if (feature == "feral_celerity_attack") {
			// Placeholder (granted automatically on rage entry)
		}
		else if (feature == "momentary_stasis") {
			// Chronurgy L6: Action, CON save, incapacitate + speed 0 until damage or end of next turn
			if (c.class_name != "Wizard" or c.subclass != "Chronurgy Magic") { u.send({{"type", message_types::announce}, {"text", "Only Chronurgy wizards can cast Momentary Stasis."}, {"interrupt", true}}); return; }
			if (c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Momentary Stasis unlocks at level 6."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action."}, {"interrupt", true}}); return; }
			if (c.momentary_stasis_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Momentary Stasis uses remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Target out of range (60ft)."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.momentary_stasis_uses--;
			int ms_dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
			int save = random(1, 20) + tgt.get_save_bonus(ABILITY_CON);
			if (save < ms_dc) {
				tgt.add_condition(COND_INCAPACITATED);
				tgt.speed = 0;
				u.room.bm.broadcast_announce(c.name + "'s Momentary Stasis traps " + tgt.name + " in a field! (save " + save + " vs DC " + ms_dc + ")", true);
			} else {
				u.room.bm.broadcast_announce(tgt.name + " resists " + c.name + "'s Momentary Stasis (save " + save + " vs DC " + ms_dc + ").", true);
			}
		}

		else if (feature == "rebuke_violent") {
			// Oath of Redemption Paladin: Rebuke the Violent reaction
			if (c.class_name != "Paladin" or c.subclass != "Oath of Redemption") { u.send({{"type", message_types::announce}, {"text", "Only Oath of Redemption paladins can Rebuke the Violent."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity uses remaining."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			c.has_reaction = false;
			c.channel_divinity_uses--;
			c.rebuke_violent_ready = true;
			u.room.bm.broadcast_announce(c.name + " readies Rebuke the Violent! Next time an enemy damages an ally within 30ft, they take equal damage.", false);
		}

		else if (feature == "eldritch_cannon") {
			// Artillerist Artificer: summon Eldritch Cannon
			if (c.class_name != "Artificer" or c.subclass != "Artillerist") { u.send({{"type", message_types::announce}, {"text", "Only Artillerists can summon Eldritch Cannons."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "No action remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.eldritch_cannon_active = true;
			c.eldritch_cannon_hp = 5 * c.level;
			u.room.bm.broadcast_announce(c.name + " creates an Eldritch Cannon with " + c.eldritch_cannon_hp + " HP!", true);
		}

		else if (feature == "cannon_fire") {
			// Artillerist: bonus action to command the cannon to fire
			if (c.class_name != "Artificer" or c.subclass != "Artillerist") { u.send({{"type", message_types::announce}, {"text", "Only Artillerists can fire cannons."}, {"interrupt", true}}); return; }
			if (!c.eldritch_cannon_active) { u.send({{"type", message_types::announce}, {"text", "No active cannon to fire."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Flamethrower: 2d8 fire, DEX save for half
			int dmg = random(1, 8) + random(1, 8);
			int save = random(1, 20) + tgt.get_save_bonus(ABILITY_DEX);
			int dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_INT);
			if (save >= dc) dmg /= 2;
			u.room.bm.combat.apply_damage(tgt, dmg, DMG_FIRE, c);
			u.room.bm.broadcast_announce(c.name + "'s Eldritch Cannon flamethrower fires at " + tgt.name + " for " + dmg + " fire damage!", true);
		}

		else if (feature == "steel_defender_attack") {
			// Battle Smith Artificer: command Steel Defender to attack
			if (c.class_name != "Artificer" or c.subclass != "Battle Smith") { u.send({{"type", message_types::announce}, {"text", "Only Battle Smiths have a Steel Defender."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int atk_bonus = c.proficiency + c.get_ability_mod(ABILITY_INT);
			int roll = random(1, 20) + atk_bonus;
			if (roll >= tgt.armor_class) {
				int dmg = random(1, 8) + c.proficiency;
				u.room.bm.combat.apply_damage(tgt, dmg, DMG_FORCE, c);
				u.room.bm.broadcast_announce(c.name + "'s Steel Defender attacks " + tgt.name + " for " + dmg + " force damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Steel Defender attacks " + tgt.name + " but misses.", false);
			}
			c.steel_defender_active = true;
		}

		else if (feature == "primal_companion") {
			// Beast Master Ranger: summon animal companion (simplified)
			if (c.class_name != "Ranger" or c.subclass != "Beast Master") { u.send({{"type", message_types::announce}, {"text", "Only Beast Masters have a Primal Companion."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			// Companion attacks with 1d8 + prof damage
			int atk_bonus = c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int roll = random(1, 20) + atk_bonus;
			if (roll >= tgt.armor_class) {
				int dmg = random(1, 8) + c.proficiency;
				u.room.bm.combat.apply_damage(tgt, dmg, DMG_PIERCING, c);
				u.room.bm.broadcast_announce(c.name + "'s Primal Companion attacks " + tgt.name + " for " + dmg + " damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Primal Companion misses " + tgt.name + ".", false);
			}
			c.beast_companion_active = true;
		}

		else if (feature == "drake_attack") {
			// Drakewarden Ranger: drake companion breath weapon
			if (c.class_name != "Ranger" or c.subclass != "Drakewarden") { u.send({{"type", message_types::announce}, {"text", "Only Drakewardens have a Drake Companion."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int atk_bonus = c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int roll = random(1, 20) + atk_bonus;
			if (roll >= tgt.armor_class) {
				int dmg = random(1, 6) + c.proficiency;
				u.room.bm.combat.apply_damage(tgt, dmg, DMG_FIRE, c);
				u.room.bm.broadcast_announce(c.name + "'s Drake breathes fire at " + tgt.name + " for " + dmg + " fire damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s Drake misses " + tgt.name + ".", false);
			}
			c.drake_companion_active = true;
		}

		else if (feature == "slayers_prey") {
			// Monster Slayer Ranger: mark a target as prey for +1d6 damage per turn
			if (c.class_name != "Ranger" or c.subclass != "Monster Slayer") { u.send({{"type", message_types::announce}, {"text", "Only Monster Slayers can mark prey."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.monster_slayer_target = target_id;
			u.room.bm.broadcast_announce(c.name + " marks a target as their slayer prey!", false);
		}

		else if (feature == "swarmkeeper_shift") {
			// Swarmkeeper Ranger: bonus damage + move target with swarm
			if (c.class_name != "Ranger" or c.subclass != "Swarmkeeper") { u.send({{"type", message_types::announce}, {"text", "Only Swarmkeepers have a magical swarm."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			u.room.bm.broadcast_announce(c.name + " commands the swarm! Next attack deals bonus force damage.", false);
			c.swarmkeeper_swarm_active = true;
		}

		else if (feature == "chronal_shift") {
			// Chronurgy Wizard: force a roll to be rerolled (reaction equivalent)
			if (c.class_name != "Wizard" or c.subclass != "Chronurgy Magic") { u.send({{"type", message_types::announce}, {"text", "Only Chronurgy wizards can use Chronal Shift."}, {"interrupt", true}}); return; }
			if (c.chronal_shift_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Chronal Shift uses remaining."}, {"interrupt", true}}); return; }
			c.chronal_shift_uses--;
			u.room.bm.broadcast_announce(c.name + " uses Chronal Shift to manipulate time!", true);
		}

		// Valda's Spire Gunslinger L2 Critical Shot (paras 170-171) is a passive crit-range
		// expansion (19/18/17), not a use-based maneuver. Wired in get_critical_threshold.
		// Valda's Spire Gunslinger L5 Gut Shot (paras 184-185) is an automatic on-crit
		// effect against Large or smaller creatures. Wired in finalize_roll_result on crit.

		else if (feature == "dodge_roll") {
			// Valda's Spire Gunslinger maneuver Dodge Roll (paras 211-212):
			// "You can expend one Risk Die as a Bonus Action to move up to 15 feet and reload any
			//  Ranged weapon you are holding. This movement doesn't provoke Opportunity Attacks
			//  and is unaffected by Difficult Terrain."
			// Implementation: consumes a Risk Die + bonus action and grants +15 ft of movement.
			// OA-immunity and difficult-terrain-immunity for that movement segment are deferred
			// until per-segment movement tracking exists; the Risk Die is otherwise unrolled
			// since the maneuver itself doesn't add it to anything.
			if (c.class_name != "Gunslinger") { u.send({{"type", message_types::announce}, {"text", "Only Gunslingers can Dodge Roll."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice available."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.risk_dice_current--;
			c.movement_remaining += 15;
			u.room.bm.broadcast_announce(c.name + " uses Dodge Roll and gains 15 feet of extra movement! (" + c.risk_dice_current + "/" + c.risk_dice_max + " Risk Dice)", false);
		}

		else if (feature == "blindfire") {
			// Valda's Spire Gunslinger maneuver Blindfire (paras 209-210):
			// "You can take a Bonus Action and expend one Risk Die to gain Blindsight with a
			//  range of 30 feet until the end of the current turn."
			// Implementation: consumes a bonus action + Risk Die, sets blindfire_active flag
			// granting Blindsight 30 ft until end of turn (cleared in advance_turn).
			if (c.class_name != "Gunslinger") { u.send({{"type", message_types::announce}, {"text", "Only Gunslingers can Blindfire."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice available."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.risk_dice_current--;
			c.blindfire_active = true;
			u.room.bm.broadcast_announce(c.name + " uses Blindfire and gains Blindsight 30 ft until end of turn! (" + c.risk_dice_current + "/" + c.risk_dice_max + " Risk Dice)", false);
		}

		else if (feature == "bite_the_bullet") {
			// Valda's Spire Gunslinger maneuver Bite the Bullet (paras 207-208):
			// "You can expend one Risk Die as a Bonus Action to gain temporary hit points equal
			//  to the number rolled plus your Gunslinger level."
			if (c.class_name != "Gunslinger") { u.send({{"type", message_types::announce}, {"text", "Only Gunslingers can Bite the Bullet."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice available."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.risk_dice_current--;
			int btb_roll = random(1, c.risk_die_size);
			int btb_thp = btb_roll + c.level;
			if (btb_thp > c.temp_hp) c.temp_hp = btb_thp;
			u.room.bm.broadcast_announce(c.name + " bites the bullet! Rolls 1d" + c.risk_die_size + " (" + btb_roll + ") + level " + c.level + " = " + btb_thp + " temporary hit points. (" + c.risk_dice_current + "/" + c.risk_dice_max + " Risk Dice)", false);
		}

		else if (feature == "focused_shot") {
			// Valda's Spire Gunslinger Deadeye L14 Focused Shot (paras 252-253):
			// "When you take the Attack action, you can choose to make only one ranged
			//  attack roll using a weapon to make a Focused Shot. You have Advantage on
			//  this attack roll and, on a hit, score a Critical Hit." Toggle the pending
			//  flag — the next ranged attack will get Advantage and auto-crit on hit.
			if (c.class_name != "Gunslinger" or c.subclass != "Deadeye" or c.level < 14) { u.send({{"type", message_types::announce}, {"text", "Only L14+ Deadeye Gunslingers can Focused Shot."}, {"interrupt", true}}); return; }
			if (!c.main_hand_is_ranged) { u.send({{"type", message_types::announce}, {"text", "Focused Shot requires a ranged weapon."}, {"interrupt", true}}); return; }
			c.focused_shot_pending = true;
			u.room.bm.broadcast_announce(c.name + " takes aim for a Focused Shot — next ranged attack gains Advantage and is a Critical Hit on a hit!", true);
		}

		else if (feature == "risky_business") {
			// Valda's Spire Gunslinger High Roller L6 Risky Business (paras 265-266):
			// "Once per turn when you make an attack roll against an enemy and the roll
			//  doesn't have Disadvantage, you can choose to make the roll with Disadvantage.
			//  When you do, you regain one expended Risk Die." Toggle the pending flag —
			//  the next attack will be made with Disadvantage and refund 1 Risk Die.
			if (c.class_name != "Gunslinger" or c.subclass != "High Roller" or c.level < 6) { u.send({{"type", message_types::announce}, {"text", "Only L6+ High Roller Gunslingers can Risky Business."}, {"interrupt", true}}); return; }
			if (c.risky_business_used_this_turn) { u.send({{"type", message_types::announce}, {"text", "Risky Business already used this turn."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current >= c.risk_dice_max) { u.send({{"type", message_types::announce}, {"text", "Risk Dice already at maximum — no refund possible."}, {"interrupt", true}}); return; }
			c.risky_business_pending = true;
			u.room.bm.broadcast_announce(c.name + " takes a Risky Business shot — next attack will have Disadvantage and refund a Risk Die!", false);
		}

		else if (feature == "license_to_kill_one" or feature == "license_to_kill_two") {
			// Valda's Spire Gunslinger Secret Agent L14 License to Kill (paras 290-291):
			// "Whenever you deal damage with a Ranged weapon, you can expend either one
			//  or two Risk Dice and add them to the damage roll." Toggle the pending flag
			//  with the chosen die count — the next ranged weapon damage roll will spend
			//  Risk Dice with explosions on max.
			if (c.class_name != "Gunslinger" or c.subclass != "Secret Agent" or c.level < 14) { u.send({{"type", message_types::announce}, {"text", "Only L14+ Secret Agent Gunslingers have a License to Kill."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice available."}, {"interrupt", true}}); return; }
			int ltk_dice = (feature == "license_to_kill_two") ? 2 : 1;
			if (ltk_dice > c.risk_dice_current) ltk_dice = c.risk_dice_current;
			c.license_to_kill_pending = true;
			c.license_to_kill_dice_to_spend = ltk_dice;
			u.room.bm.broadcast_announce(c.name + " calls in their License to Kill — next ranged damage roll will spend " + ltk_dice + " Risk Die" + (ltk_dice == 1 ? "" : "s") + " (with explosions).", true);
		}

		else if (feature == "bang_youre_dead") {
			// Valda's Spire Gunslinger Spellslinger L3 Bang, You're Dead — Arcane Shot
			// (paras 423-426): "When you hit a target with a Finger Guns attack, you can
			//  expend one Risk Die as a Bonus Action and add it to the damage roll."
			//  Toggle the pending flag — the next Finger Guns hit will spend a Risk Die
			//  and add it to damage. Bonus action is consumed at hit time, not now.
			if (c.class_name != "Gunslinger" or c.subclass != "Spellslinger" or c.level < 3) { u.send({{"type", message_types::announce}, {"text", "Only Spellslinger Gunslingers can Bang You're Dead."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice available."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.bang_youre_dead_pending = true;
			u.room.bm.broadcast_announce(c.name + " readies a Bang You're Dead arcane shot — next Finger Guns hit will spend a Risk Die for bonus damage!", false);
		}

		else if (feature == "open_hand_technique") {
			// Warrior of the Open Hand: expend focus points on a Flurry hit to push/prone/no-reaction
			if (c.class_name != "Monk" or c.subclass != "Warrior of the Open Hand") { u.send({{"type", message_types::announce}, {"text", "Only Open Hand monks can use this technique."}, {"interrupt", true}}); return; }
			c.open_hand_ki_used = true;
			string effect = msg.exists("effect") ? string(msg["effect"]) : "prone";
			combatant@ tgt = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@tgt != null and !tgt.is_dead) {
				if (effect == "prone") {
					tgt.add_condition(COND_PRONE);
					u.room.bm.broadcast_announce(c.name + "'s Open Hand Technique knocks " + tgt.name + " prone!", true);
				} else if (effect == "push") {
					int push_dx = 0, push_dy = 0;
					if (tgt.x > c.x) push_dx = 3;
					else if (tgt.x < c.x) push_dx = -3;
					if (tgt.y > c.y) push_dy = 3;
					else if (tgt.y < c.y) push_dy = -3;
					tgt.x += push_dx;
					tgt.y += push_dy;
					u.room.bm.broadcast_announce(c.name + "'s Open Hand Technique pushes " + tgt.name + " 15 feet away!", true);
				} else {
					// No reactions until end of turn
					tgt.has_reaction = false;
					u.room.bm.broadcast_announce(c.name + "'s Open Hand Technique prevents " + tgt.name + " from taking reactions!", true);
				}
			}
		}

		else if (feature == "mage_hand_legerdemain") {
			// Arcane Trickster Rogue: use Mage Hand for sneak attack or bonus action actions
			if (c.class_name != "Rogue" or c.subclass != "Arcane Trickster") { u.send({{"type", message_types::announce}, {"text", "Only Arcane Tricksters can use Mage Hand Legerdemain."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.arcane_trickster_mage_hand = target_id;
			u.room.bm.broadcast_announce(c.name + " commands a magical Mage Hand!", false);
		}

		else if (feature == "scout_skirmish") {
			// Scout Rogue: Skirmisher — half speed move as reaction when enemy ends turn nearby
			if (c.class_name != "Rogue" or c.subclass != "Scout") { u.send({{"type", message_types::announce}, {"text", "Only Scouts can skirmish."}, {"interrupt", true}}); return; }
			if (!c.has_reaction) { u.send({{"type", message_types::announce}, {"text", "No reaction available."}, {"interrupt", true}}); return; }
			c.has_reaction = false;
			c.scout_skirmisher = true;
			c.movement_remaining += c.speed / 2;
			u.room.bm.broadcast_announce(c.name + " uses Skirmisher to move half their speed as a reaction!", false);
		}

		else if (feature == "blessing_of_the_trickster") {
			// PHB 2024 para 4697: "As a Magic action, you can choose yourself or a willing
			// creature within 30 feet of yourself to have Advantage on Dexterity (Stealth)
			// checks. This blessing lasts until you finish a Long Rest or you use this
			// feature again." No Channel Divinity cost.
			if (c.class_name != "Cleric" or c.subclass != "Trickery Domain") { u.send({{"type", message_types::announce}, {"text", "Only Trickery Clerics can grant this blessing."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action this turn."}, {"interrupt", true}}); return; }
			combatant@ ally = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : c;
			if (@ally == null or ally.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			if (ally.is_player != c.is_player and ally.id != c.id) { u.send({{"type", message_types::announce}, {"text", "Target an ally or yourself."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) { u.send({{"type", message_types::announce}, {"text", "Target must be within 30 feet."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			// Apply proper Stealth advantage flag (replaces the +5 hide_dc approximation).
			// "Use again" replaces the previous blessing — clear any prior Stealth advantage
			// from a previous blessing (kept simple: we don't currently track which cleric
			// applied it, so a recast just re-applies the flag idempotently).
			bool already_has = ally.has_skill_check_advantage("Stealth");
			if (!already_has) ally.skill_check_advantage.insert_last("Stealth");
			u.room.bm.broadcast_announce(c.name + " grants Blessing of the Trickster to " + ally.name + ". They have Advantage on Dexterity (Stealth) checks until long rest.", true);
		}
		else if (feature == "spirit_totem_bear" or feature == "spirit_totem_hawk" or feature == "spirit_totem_unicorn") {
			// Xanathar's Circle of the Shepherd L2 Spirit Totem (paras 916-923):
			// BA, 30ft aura (simplified to around druid), 1 min, 1/SR or LR
			if (c.class_name != "Druid" or c.subclass != "Circle of the Shepherd") { u.send({{"type", message_types::announce}, {"text", "Only Shepherd Druids can summon spirit totems."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.shepherd_circle_active = true;
			if (feature == "spirit_totem_bear") {
				// Para 921: "Each creature of your choice in the aura when the spirit
				// appears gains temporary hit points equal to 5 + your druid level.
				// In addition, you and your allies gain advantage on Strength checks
				// and Strength saving throws while in the aura."
				c.shepherd_totem_type = 0;
				int bear_temp = 5 + c.level;
				for (uint sti = 0; sti < u.room.bm.combat.combatants.length(); sti++) {
					combatant@ ally = u.room.bm.combat.combatants[sti];
					if (@ally == null or ally.is_dead or ally.is_player != c.is_player) continue;
					if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) continue;
					if (ally.temp_hp < bear_temp) ally.temp_hp = bear_temp;
					// STR check advantage
					if (ally.has_skill_check_advantage("Athletics") == false) {
						ally.skill_check_advantage.insert_last("Athletics");
					}
				}
				u.room.bm.broadcast_announce(c.name + " summons the Bear Spirit Totem! Allies within 30ft gain " + bear_temp + " temp HP and advantage on STR checks.", true);
			} else if (feature == "spirit_totem_hawk") {
				// Para 922: "When a creature makes an attack roll against a target in
				// the spirit's aura, you can use your reaction to grant advantage to
				// that attack roll." Hawk reaction deferred — needs reaction prompt
				// infrastructure.
				c.shepherd_totem_type = 1;
				u.room.bm.broadcast_announce(c.name + " summons the Hawk Spirit Totem! You can use a reaction to grant advantage on attacks against targets in the aura.", true);
			} else {
				// Para 923: "if you cast a spell using a spell slot that restores hit
				// points to any creature [...] each creature of your choice in the aura
				// also regains hit points equal to your druid level."
				c.shepherd_totem_type = 2;
				u.room.bm.broadcast_announce(c.name + " summons the Unicorn Spirit Totem! Healing spells also heal chosen creatures in the aura for " + c.level + " HP.", true);
			}
		}
		else if (feature == "polearm_master_attack") {
			// Polearm Master: bonus action attack with opposite end (1d4 bludgeoning) immediately after Attack action
			if (!c.has_feat("polearm_master")) { u.send({{"type", message_types::announce}, {"text", "You don't have the Polearm Master feat."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (!c.used_action) { u.send({{"type", message_types::announce}, {"text", "You must first take the Attack action with a polearm."}, {"interrupt", true}}); return; }
			// Verify weapon is qualifying (quarterstaff, spear, or Heavy+Reach)
			string wname = c.main_hand.lower();
			bool qualifies = (wname.find("quarterstaff") >= 0 or wname.find("spear") >= 0 or wname.find("glaive") >= 0 or wname.find("halberd") >= 0 or wname.find("pike") >= 0);
			if (!qualifies) { u.send({{"type", message_types::announce}, {"text", "Polearm Master requires a quarterstaff, spear, glaive, halberd, or pike."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			int dist_pa = feet_distance(c.x, c.y, tgt.x, tgt.y);
			int pa_reach = c.main_hand_range > 0 ? c.main_hand_range : 5;
			if (dist_pa > pa_reach) { u.send({{"type", message_types::announce}, {"text", "Target out of weapon reach."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int pa_atk = random(1, 20) + c.get_ability_mod(ABILITY_STR) + c.proficiency;
			if (pa_atk >= tgt.armor_class) {
				int pa_dmg = random(1, 4) + c.get_ability_mod(ABILITY_STR);
				if (pa_dmg < 1) pa_dmg = 1;
				u.room.bm.combat.apply_damage(tgt, pa_dmg, DMG_BLUDGEONING, c);
				u.room.bm.broadcast_announce(c.name + "'s polearm butt hits " + tgt.name + " for " + pa_dmg + " bludgeoning damage!", true);
			} else {
				u.room.bm.broadcast_announce(c.name + "'s polearm butt swing misses " + tgt.name + ".", true);
			}
		}
		// Shield Master 2024: Shield Bash is no longer a bonus action — it's an automatic rider
		// triggered by melee hit during the Attack action, applied in battle_manager attack resolution.
		else if (feature == "jinx_target") {
			// Misfortune Bringer Rogue: jinx target for bonus damage
			if (c.class_name != "Rogue" or c.subclass != "Misfortune Bringer") { u.send({{"type", message_types::announce}, {"text", "Only Misfortune Bringer Rogues can jinx targets."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.misfortune_jinx_active = true;
			c.misfortune_jinx_target = tgt.id;
			u.room.bm.broadcast_announce(c.name + " curses " + tgt.name + " with a jinx of misfortune!", true);
		}
		else if (feature == "rune_tag") {
			// Runetagger Rogue: mark target with magical rune
			if (c.class_name != "Rogue" or c.subclass != "Runetagger") { u.send({{"type", message_types::announce}, {"text", "Only Runetagger Rogues can place runes."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.runetagger_marked = true;
			c.runetagger_target = tgt.id;
			u.room.bm.broadcast_announce(c.name + " tags " + tgt.name + " with a magical rune!", true);
		}
		else if (feature == "blade_breaker_stance") {
			// Blade Breaker Fighter: enter armor-crushing stance - reduce target AC on hit
			if (c.class_name != "Fighter" or c.subclass != "Blade Breaker") { u.send({{"type", message_types::announce}, {"text", "Only Blade Breakers can enter this stance."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.blade_breaker_stance = !c.blade_breaker_stance;
			u.room.bm.broadcast_announce(c.name + (c.blade_breaker_stance ? " enters Blade Breaker stance!" : " leaves Blade Breaker stance."), true);
		}
		// PHB 2024 Shield Master (para 7797): toggle Push 5ft vs Prone preference.
		// No action cost — free preference toggle, applies on next Shield Master shove.
		else if (feature == "shield_master_toggle") {
			if (!c.has_feat("shield_master")) { u.send({{"type", message_types::announce}, {"text", "Requires Shield Master feat."}, {"interrupt", true}}); return; }
			string mode = "";
			if (msg.exists("mode")) mode = string(msg["mode"]);
			if (mode == "push") {
				c.shield_master_push_mode = true;
				u.room.bm.broadcast_announce(c.name + " sets Shield Master to Push 5 feet.", false);
			} else {
				c.shield_master_push_mode = false;
				u.room.bm.broadcast_announce(c.name + " sets Shield Master to knock Prone.", false);
			}
		}
		else if (feature == "festus_blessing") {
			// Festus Domain Cleric: bestow festive blessing on allies
			if (c.class_name != "Cleric" or c.subclass != "Festus Domain") { u.send({{"type", message_types::announce}, {"text", "Only Festus Clerics can bless feasts."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.channel_divinity_uses--;
			c.festus_blessing_active = true;
			c.festus_blessing_rounds = 3;
			// Heal all allies within 30ft
			for (uint fbi = 0; fbi < u.room.bm.combat.combatants.length(); fbi++) {
				combatant@ ally = u.room.bm.combat.combatants[fbi];
				if (@ally == null or ally.is_dead or ally.is_player != c.is_player) continue;
				if (feet_distance(c.x, c.y, ally.x, ally.y) > 30) continue;
				int heal = c.proficiency + c.get_ability_mod(ABILITY_WIS);
				u.room.bm.combat.apply_healing(ally, heal);
			}
			u.room.bm.broadcast_announce(c.name + " grants the Festus Blessing! All nearby allies are healed.", true);
		}
		// Gunslinger subclass maneuvers (Valda's). Most are triggered from attack/miss events,
		// not standalone bonus actions. Lay Down the Law is the one bonus action here.
		else if (feature == "lay_down_the_law") {
			// White Hat Gunslinger L3: Bonus action, expend 1 Risk Die. Choose an ally within 60ft.
			// Ally gains Temp HP = Risk Die roll. Until start of next turn, if ally is hit, reaction ranged attack on attacker.
			if (c.class_name != "Gunslinger" or c.subclass != "White Hat") { u.send({{"type", message_types::announce}, {"text", "Only White Hat Gunslingers can use Lay Down the Law."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.risk_dice_current <= 0) { u.send({{"type", message_types::announce}, {"text", "No Risk Dice remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "Select an ally to mark."}, {"interrupt", true}}); return; }
			combatant@ ally = u.room.bm.combat.get_combatant(target_id);
			if (@ally == null or ally.is_dead or ally.is_player != c.is_player) { u.send({{"type", message_types::announce}, {"text", "Select a living ally."}, {"interrupt", true}}); return; }
			if (feet_distance(c.x, c.y, ally.x, ally.y) > 60) { u.send({{"type", message_types::announce}, {"text", "Target must be within 60ft."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.risk_dice_current--;
			int temp = random(1, c.risk_die_size);
			if (ally.temp_hp < temp) ally.temp_hp = temp;
			c.lay_down_law_protection = true;
			c.lay_down_law_target_id = ally.id;
			u.room.bm.broadcast_announce(c.name + " Lays Down the Law — " + ally.name + " gains " + temp + " temp HP; retaliation ready!", true);
		}
		else if (feature == "unsettling_words") {
			// College of Eloquence Bard: spend Bardic Inspiration to subtract from a creature's next save
			if (c.class_name != "Bard" or c.subclass != "College of Eloquence") { u.send({{"type", message_types::announce}, {"text", "Only Eloquence Bards can use Unsettling Words."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			if (c.bardic_inspiration_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Bardic Inspiration remaining."}, {"interrupt", true}}); return; }
			if (target_id == 0) { u.send({{"type", message_types::announce}, {"text", "No target selected."}, {"interrupt", true}}); return; }
			combatant@ tgt = u.room.bm.combat.get_combatant(target_id);
			if (@tgt == null or tgt.is_dead) { u.send({{"type", message_types::announce}, {"text", "Invalid target."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.bardic_inspiration_uses--;
			c.unsettling_words_pending = true;
			c.unsettling_words_target = tgt.id;
			u.room.bm.broadcast_announce(c.name + " speaks Unsettling Words to " + tgt.name + ", undermining their resolve!", true);
		}
		else if (feature == "orders_demand") {
			// Order Domain Cleric (Tasha's): Channel Divinity as an action — each creature of choice within 30ft
			// makes a WIS save vs cleric spell DC. Failed save: charmed until end of next turn or until they take damage.
			if (c.class_name != "Cleric" or c.subclass != "Order Domain") { u.send({{"type", message_types::announce}, {"text", "Only Order Domain Clerics can use Order's Demand."}, {"interrupt", true}}); return; }
			if (!c.has_action) { u.send({{"type", message_types::announce}, {"text", "You've already used your action this turn."}, {"interrupt", true}}); return; }
			if (c.channel_divinity_uses <= 0) { u.send({{"type", message_types::announce}, {"text", "No Channel Divinity remaining."}, {"interrupt", true}}); return; }
			c.has_action = false;
			c.used_action = true;
			c.channel_divinity_uses--;
			int dc = 8 + c.proficiency + c.get_ability_mod(ABILITY_WIS);
			int affected = 0;
			for (uint odi = 0; odi < u.room.bm.combat.combatants.length(); odi++) {
				combatant@ tgt = u.room.bm.combat.combatants[odi];
				if (@tgt == null or tgt.is_dead or tgt.id == c.id) continue;
				if (tgt.is_player == c.is_player) continue; // only enemies
				if (feet_distance(c.x, c.y, tgt.x, tgt.y) > 30) continue;
				int save = random(1, 20) + tgt.get_save_bonus(ABILITY_WIS);
				if (save < dc) {
					tgt.add_condition(COND_CHARMED);
					// Charm ends on damage (handled in apply_damage) or at end of caster's next turn
					tgt.orders_demand_charmed_by = c.id;
					tgt.orders_demand_turns_left = 2; // 2 = survives this turn-end, expires at next turn-end
					u.room.bm.broadcast_announce(c.name + " issues an Order's Demand! " + tgt.name + " is charmed (save " + save + " vs DC " + dc + ").", true);
					affected++;
				} else {
					u.room.bm.broadcast_announce(tgt.name + " resists Order's Demand (save " + save + " vs DC " + dc + ").", false);
				}
			}
			if (affected == 0) {
				u.room.bm.broadcast_announce(c.name + "'s Order's Demand echoes, but no enemies are charmed.", false);
			}
		}
		else if (feature == "experimental_elixir") {
			// Alchemist Artificer: create an experimental elixir (random effect)
			if (c.class_name != "Artificer" or c.subclass != "Alchemist") { u.send({{"type", message_types::announce}, {"text", "Only Alchemists can create Experimental Elixirs."}, {"interrupt", true}}); return; }
			if (!c.has_bonus_action) { u.send({{"type", message_types::announce}, {"text", "No bonus action remaining."}, {"interrupt", true}}); return; }
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			int elixir = random(1, 6);
			int heal = random(1, 4) + 2 + c.get_ability_mod(ABILITY_INT);
			if (elixir == 1) {
				u.room.bm.combat.apply_healing(c, heal);
				u.room.bm.broadcast_announce(c.name + "'s Healing Elixir restores " + heal + " HP!", true);
			} else if (elixir == 2) {
				c.speed += 10;
				u.room.bm.broadcast_announce(c.name + "'s Swiftness Elixir grants +10 ft speed!", true);
			} else if (elixir == 3) {
				c.temp_hp += 2 + c.level;
				u.room.bm.broadcast_announce(c.name + "'s Resilience Elixir grants " + (2 + c.level) + " temp HP!", true);
			} else if (elixir == 4) {
				u.room.bm.broadcast_announce(c.name + "'s Boldness Elixir grants +1d4 to next attack!", true);
				c.emboldening_bond_active = true; // reuse bond field
			} else {
				u.room.bm.combat.apply_healing(c, heal);
				u.room.bm.broadcast_announce(c.name + "'s Flight of Fancy Elixir! (+heal " + heal + ")", true);
			}
			c.experimental_elixir_available = true;
		}

		// PHB 2024 Two-Weapon Fighting: off-hand attack as Bonus Action
		else if (feature == "cwb_disengage") {
			if (!c.conjure_woodland_disengage) {
				u.send({{"type", message_types::error}, {"text", "CWB Disengage not available."}});
				return;
			}
			if (!c.has_bonus_action) {
				u.send({{"type", message_types::error}, {"text", "No bonus action available."}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.took_disengage = true;
			u.room.bm.broadcast_announce(c.name + " uses a bonus action to Disengage (Conjure Woodland Beings)!", false);
			u.room.bm.broadcast_state();
		}
		else if (feature == "expeditious_retreat_dash") {
			// Basic Rules 2024 Expeditious Retreat (para 13159): "you can take
			// [the Dash] action again as a Bonus Action."
			if (!c.expeditious_retreat_active) {
				u.send({{"type", message_types::error}, {"text", "Expeditious Retreat not active."}});
				return;
			}
			if (!c.has_bonus_action) {
				u.send({{"type", message_types::error}, {"text", "No bonus action available."}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			c.movement_remaining += c.speed;
			u.room.bm.broadcast_announce(c.name + " dashes as a bonus action (Expeditious Retreat)! Movement increased by " + c.speed + " feet.", false);
			u.room.bm.broadcast_state();
		}
		else if (feature == "twf_offhand") {
			if (!c.has_bonus_action) {
				u.send({{"type", message_types::error}, {"text", "No bonus action available."}});
				return;
			}
			if (c.off_hand == "") {
				u.send({{"type", message_types::error}, {"text", "You don't have an off-hand weapon."}});
				return;
			}
			if (c.twf_attack_used_this_turn) {
				u.send({{"type", message_types::error}, {"text", "You already made an off-hand attack this turn."}});
				return;
			}
			// Find target: use target_id from message or nearest hostile
			combatant@ twf_target = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@twf_target == null or twf_target.is_dead) {
				int best_td = 9999;
				for (uint ti = 0; ti < u.room.bm.combat.combatants.length(); ti++) {
					combatant@ tc = u.room.bm.combat.combatants[ti];
					if (@tc == null or tc.is_dead or tc.id == c.id) continue;
					if (!u.room.bm.combat.are_hostile(c, tc)) continue;
					int td = feet_distance(c.x, c.y, tc.x, tc.y);
					if (td <= c.off_hand_range and td < best_td) { best_td = td; @twf_target = tc; }
				}
			}
			if (@twf_target == null or twf_target.is_dead) {
				u.send({{"type", message_types::error}, {"text", "No valid target in off-hand weapon range."}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			u.room.bm.broadcast_announce(c.name + " makes an off-hand attack!", false);
			u.room.bm.start_twf_offhand_strike(c, twf_target);
		}

		else if (feature == "swift_quiver_attack") {
			// Basic Rules 2024 Swift Quiver (para 15218): bonus action for 2 ranged attacks
			if (!c.swift_quiver_active) {
				u.send({{"type", message_types::error}, {"text", "Swift Quiver not active."}});
				return;
			}
			if (!c.has_bonus_action) {
				u.send({{"type", message_types::error}, {"text", "No bonus action available."}});
				return;
			}
			if (!c.main_hand_is_ranged) {
				u.send({{"type", message_types::error}, {"text", "Swift Quiver requires a ranged weapon."}});
				return;
			}
			// Find target: use target_id from message or nearest hostile in range
			combatant@ sq_target = target_id != 0 ? u.room.bm.combat.get_combatant(target_id) : null;
			if (@sq_target == null or sq_target.is_dead) {
				int best_sd = 9999;
				for (uint si = 0; si < u.room.bm.combat.combatants.length(); si++) {
					combatant@ sc = u.room.bm.combat.combatants[si];
					if (@sc == null or sc.is_dead or sc.id == c.id) continue;
					if (!u.room.bm.combat.are_hostile(c, sc)) continue;
					int sd = feet_distance(c.x, c.y, sc.x, sc.y);
					if (sd <= c.main_hand_range and sd < best_sd) { best_sd = sd; @sq_target = sc; }
				}
			}
			if (@sq_target == null or sq_target.is_dead) {
				u.send({{"type", message_types::error}, {"text", "No valid target in ranged weapon range."}});
				return;
			}
			c.has_bonus_action = false;
			c.used_bonus_action = true;
			u.room.bm.broadcast_announce(c.name + " uses Swift Quiver for 2 bonus ranged attacks!", false);
			u.room.bm.start_swift_quiver_strike(c, sq_target, 1); // 2 attacks: first with 1 remaining
		}

		else {
			u.send({{"type", message_types::announce}, {"text", "That bonus action is not available to your character."}, {"interrupt", true}});
			return;
		}
		u.room.bm.broadcast_state();
	}

	else if (msg_type == message_types::scan_direction) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_scan(u, msg);
	}
	else if (msg_type == message_types::bardic_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_bardic_response(u, msg);
	}
	else if (msg_type == message_types::lucky_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_lucky_response(u, msg);
	}
	else if (msg_type == message_types::heroic_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_heroic_response(u, msg);
	}
	else if (msg_type == message_types::tactical_mind_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_tactical_mind_response(u, msg);
	}
	else if (msg_type == message_types::smite_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_smite_response(u, msg);
	}
	else if (msg_type == message_types::reaction_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_reaction_response(u, msg);
	}
	else if (msg_type == message_types::spell_choice_response) {
		if (@u.room != null and @u.room.bm != null) u.room.bm.handle_spell_choice_response(u, msg);
	}
	else if (msg_type == message_types::action_cast) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_cast(u, msg);
		}
	}
	else if (msg_type == message_types::action_help) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_help(u, msg);
		}
	}
	else if (msg_type == message_types::action_hide) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_hide(u);
		}
	}
	else if (msg_type == message_types::action_ready) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_ready(u, msg);
		}
	}
	else if (msg_type == message_types::action_shove) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_shove(u, msg);
		}
	}
	else if (msg_type == message_types::action_grapple) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_grapple(u, msg);
		}
	}
	else if (msg_type == message_types::action_grapple_escape) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_grapple_escape(u);
		}
	}
	else if (msg_type == message_types::action_stabilize) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_stabilize(u, msg);
		}
	}
	else if (msg_type == message_types::action_call_lightning) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_call_lightning_bolt(u, msg);
		}
	}
	else if (msg_type == message_types::action_flame_blade) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_flame_blade_attack(u, msg);
		}
	}
	else if (msg_type == message_types::set_target) {
		if (@u.room != null and @u.room.bm != null) {
			u.room.bm.handle_set_target(u, msg);
		}
	}

	// --- Game Invites ---

	else if (msg_type == message_types::game_invite and msg.exists("target")) {
		string target_name = string(msg["target"]);
		// Must be in a room to invite.
		if (@u.room == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "You must be in a room to invite players."}});
			return;
		}
		// Must be a friend.
		if (@u.account == null) return;
		json_object@ my_data = u.account.data;
		if (!my_data.exists("friends")) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not on your friends list."}});
			return;
		}
		json_array@ my_friends = my_data["friends"];
		bool is_friend = false;
		for (uint fi = 0; fi < my_friends.length(); fi++) {
			if (string(my_friends[fi]) == target_name) { is_friend = true; break; }
		}
		if (!is_friend) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not on your friends list."}});
			return;
		}
		// Target must be online.
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", target_name + " is not online."}});
			return;
		}
		// Send invite to target.
		target.send({{"type", message_types::game_invite_received}, {"from", u.username}, {"room_name", u.room.name}, {"room_id", u.room.id}});
		u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "Game invite sent to " + target_name + "!"}});
	}

	else if (msg_type == message_types::game_invite_response and msg.exists("accepted") and msg.exists("room_id")) {
		bool accepted = bool(msg["accepted"]);
		uint room_id = uint(msg["room_id"]);
		string from_name = msg.exists("from") ? string(msg["from"]) : "";
		if (!accepted) {
			// Notify the inviter.
			if (from_name != "") {
				user@ inviter = users.get_user_by_name(from_name);
				if (@inviter != null) {
					inviter.send({{"type", message_types::chat_message}, {"username", ""}, {"message", u.username + " declined your game invite."}});
				}
			}
			return;
		}
		// Find the room by ID.
		room@ target_room = null;
		for (uint ri = 0; ri < rooms.rooms.length(); ri++) {
			if (rooms.rooms[ri].id == room_id) {
				@target_room = rooms.rooms[ri];
				break;
			}
		}
		if (@target_room == null) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "That room no longer exists."}});
			return;
		}
		if (target_room.started) {
			u.send({{"type", message_types::chat_message}, {"username", ""}, {"message", "That game has already started."}});
			return;
		}
		// Join the room (bypasses password).
		u.join_room(target_room);
	}

	// ---- INVENTORY LIST ----
	else if (msg_type == message_types::inventory_list) {
		if (@u.account == null) return;
		init_item_catalog();
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		json_array items_arr;
		if (@inv != null) {
			for (uint ii = 0; ii < inv.length(); ii++) {
				json_object@ entry = inv[ii];
				if (@entry == null or !entry.exists("id")) continue;
				string item_id = string(entry["id"]);
				item_def@ item = find_item(item_id);
				if (@item == null) continue;
				json_object item_obj;
				item_obj["id"] = item.id;
				item_obj["name"] = item.name;
				item_obj["rarity"] = item.rarity;
				item_obj["slot"] = item.slot;
				item_obj["description"] = item.description;
				item_obj["stats"] = item_stat_summary(item);
				items_arr.add(item_obj);
			}
		}

		// Include equipped items info
		json_object equipped_info;
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ eq = character["equipped"];
			if (eq.exists("weapon")) equipped_info["weapon"] = eq["weapon"];
			if (eq.exists("armor")) equipped_info["armor"] = eq["armor"];
			if (eq.exists("ring")) equipped_info["ring"] = eq["ring"];
			if (eq.exists("amulet")) equipped_info["amulet"] = eq["amulet"];
		}

		u.send({
			{"type", message_types::inventory_list},
			{"items", items_arr},
			{"equipped", equipped_info}
		});
	}

	// ---- EQUIP ITEM ----
	else if (msg_type == message_types::equip_item and msg.exists("item_id")) {
		if (@u.account == null) return;
		init_item_catalog();
		string item_id = string(msg["item_id"]);

		// Validate the item exists in catalog
		item_def@ item = find_item(item_id);
		if (@item == null) {
			u.send({{"type", message_types::error}, {"text", "Unknown item."}});
			return;
		}

		// Derive slot from the item definition (no need for client to send it)
		string[] slot_key_map = {"weapon", "armor", "ring", "amulet"};
		if (item.slot < 0 or item.slot >= int(slot_key_map.length())) {
			u.send({{"type", message_types::error}, {"text", "Invalid item slot."}});
			return;
		}
		string expected_slot = slot_key_map[item.slot];

		// Validate item exists in player's inventory
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (!inventory_has_item(inv, item_id)) {
			u.send({{"type", message_types::error}, {"text", "You do not have that item."}});
			return;
		}

		// Get character and equipped data
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character == null) {
			u.send({{"type", message_types::error}, {"text", "No adventure character found."}});
			return;
		}
		json_object@ equipped = ensure_json_object_field(character, "equipped");

		// Toggle: if item is already equipped in this slot, unequip it
		if (equipped.exists(expected_slot) and string(equipped[expected_slot]) == item_id) {
			equipped[expected_slot] = "";
			u.account.commit();
			send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
			u.send({{"type", message_types::announce}, {"text", "Unequipped " + item.name + " from " + SLOT_NAMES[item.slot] + " slot."}, {"interrupt", false}});
		} else {
			equipped[expected_slot] = item_id;
			u.account.commit();
			send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
			u.send({{"type", message_types::announce}, {"text", "Equipped " + item.name + " in " + SLOT_NAMES[item.slot] + " slot."}, {"interrupt", false}});
		}
	}

	// ---- DISCARD ITEM ----
	else if (msg_type == message_types::discard_item and msg.exists("item_id")) {
		if (@u.account == null) return;
		init_item_catalog();
		string item_id = string(msg["item_id"]);

		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (!inventory_has_item(inv, item_id)) {
			u.send({{"type", message_types::error}, {"text", "You do not have that item."}});
			return;
		}

		// If the item is currently equipped, unequip it first
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ equipped = character["equipped"];
			string[] slot_keys = {"weapon", "armor", "ring", "amulet"};
			for (uint si = 0; si < slot_keys.length(); si++) {
				if (equipped.exists(slot_keys[si]) and string(equipped[slot_keys[si]]) == item_id) {
					equipped[slot_keys[si]] = "";
				}
			}
		}

		inventory_remove_item(inv, item_id);
		u.account.commit();

		item_def@ item = find_item(item_id);
		string item_name = @item != null ? item.name : item_id;
		u.send({{"type", message_types::announce}, {"text", "Discarded " + item_name + "."}, {"interrupt", false}});
		send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
	}

	// ---- UPGRADE ITEM ----
	else if (msg_type == message_types::upgrade_item and msg.exists("item_ids")) {
		if (@u.account == null) return;
		init_item_catalog();
		ensure_account_progression(u.account);

		json_array@ ids = msg["item_ids"];
		if (@ids == null or ids.length() != 3) {
			u.send({{"type", message_types::error}, {"text", "You must select exactly 3 items to upgrade."}});
			return;
		}

		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		if (@inv == null) {
			u.send({{"type", message_types::error}, {"text", "No inventory found."}});
			return;
		}

		// Validate all 3 items exist in inventory and have same rarity
		string[] item_ids;
		string[] item_names;
		int common_rarity = -1;
		for (uint ii = 0; ii < ids.length(); ii++) {
			string item_id = string(ids[ii]);
			if (!inventory_has_item(inv, item_id)) {
				u.send({{"type", message_types::error}, {"text", "You do not have item: " + item_id + "."}});
				return;
			}
			item_def@ item = find_item(item_id);
			if (@item == null) {
				u.send({{"type", message_types::error}, {"text", "Unknown item: " + item_id + "."}});
				return;
			}
			if (common_rarity == -1) {
				common_rarity = item.rarity;
			} else if (item.rarity != common_rarity) {
				u.send({{"type", message_types::error}, {"text", "All 3 items must be the same rarity."}});
				return;
			}
			item_ids.insert_last(item_id);
			item_names.insert_last(item.name);
		}

		// Check rarity is upgradeable (not legendary)
		if (common_rarity >= RARITY_LEGENDARY) {
			u.send({{"type", message_types::error}, {"text", "Legendary items cannot be upgraded further."}});
			return;
		}

		// Check glory cost
		int cost = get_upgrade_glory_cost(common_rarity);
		int current_glory = get_glory(u.account);
		if (current_glory < cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough Glory. Need " + cost + " but you have " + current_glory + "."}});
			return;
		}

		// Remove 3 items from inventory
		for (uint ii = 0; ii < item_ids.length(); ii++) {
			inventory_remove_item(inv, item_ids[ii]);
		}

		// Deduct glory
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			int new_glory = get_json_int(progress, "glory", 0) - cost;
			if (new_glory < 0) new_glory = 0;
			progress["glory"] = new_glory;
		}

		// Generate random item of next rarity
		int target_rarity = common_rarity + 1;
		item_def@ result_item = generate_upgrade_result(target_rarity);
		string result_name = "Unknown";
		if (@result_item != null) {
			inventory_add_item(inv, result_item.id);
			result_name = result_item.name;
		}

		u.account.commit();

		// Send updated inventory
		// Re-build inventory list
		json_array items_arr;
		for (uint ii = 0; ii < inv.length(); ii++) {
			json_object@ entry = inv[ii];
			if (@entry == null or !entry.exists("id")) continue;
			string iid = string(entry["id"]);
			item_def@ idef = find_item(iid);
			if (@idef == null) continue;
			json_object item_obj;
			item_obj["id"] = idef.id;
			item_obj["name"] = idef.name;
			item_obj["rarity"] = idef.rarity;
			item_obj["slot"] = idef.slot;
			item_obj["description"] = idef.description;
			item_obj["stats"] = item_stat_summary(idef);
			items_arr.add(item_obj);
		}
		json_object equipped_info;
		json_object@ character = get_character_profile(u.account, GAME_TYPE_ADVENTURE);
		if (@character != null and character.exists("equipped")) {
			json_object@ eq = character["equipped"];
			if (eq.exists("weapon")) equipped_info["weapon"] = eq["weapon"];
			if (eq.exists("armor")) equipped_info["armor"] = eq["armor"];
			if (eq.exists("ring")) equipped_info["ring"] = eq["ring"];
			if (eq.exists("amulet")) equipped_info["amulet"] = eq["amulet"];
		}
		u.send({
			{"type", message_types::inventory_list},
			{"items", items_arr},
			{"equipped", equipped_info}
		});

		// Send glory update
		u.send({
			{"type", message_types::glory_update},
			{"glory", get_glory(u.account)}
		});

		// Announce the result
		string rarity_name = RARITY_NAMES[target_rarity];
		u.send({{"type", message_types::announce}, {"text", "Upgrade successful! Combined " + item_names[0] + ", " + item_names[1] + ", and " + item_names[2] + " into " + result_name + " (" + rarity_name + "). Cost: " + cost + " Glory."}, {"interrupt", true}});
	}

	// ---- PRESTIGE ACTION ----
	else if (msg_type == message_types::prestige_action) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress == null) {
			u.send({{"type", message_types::error}, {"text", "No adventure progress found."}});
			return;
		}

		int current_level = get_json_int(progress, "level", 1);
		int current_rank = get_prestige_rank(u.account);

		if (current_level < 20) {
			u.send({{"type", message_types::error}, {"text", "You must be level 20 to prestige."}});
			return;
		}
		if (current_rank >= 5) {
			u.send({{"type", message_types::error}, {"text", "You have already reached maximum prestige rank."}});
			return;
		}

		if (!apply_prestige(u.account)) {
			u.send({{"type", message_types::error}, {"text", "Prestige failed."}});
			return;
		}

		int new_rank = get_prestige_rank(u.account);
		string title = get_prestige_title(new_rank);
		int glory_reward = 100 * new_rank;
		add_glory(u.account, glory_reward);

		u.account.commit();

		u.send({{"type", message_types::announce}, {"text", "You have prestiged! You are now " + title + " (Rank " + new_rank + "). Level reset to 1. +" + glory_reward + " Glory!"}, {"interrupt", true}});
		send_character_profile_to_user(u, GAME_TYPE_ADVENTURE);
		send_adventure_progress_to_user(u, "Prestige complete! Rank " + new_rank + ": " + title + ".");
		u.send({
			{"type", message_types::glory_update},
			{"glory", get_glory(u.account)},
			{"gained", glory_reward}
		});
	}

	// ---- TRADING SYSTEM ----

	else if (msg_type == message_types::trade_request and msg.exists("target")) {
		string target_name = msg["target"];
		if (target_name == u.username) {
			u.send({{"type", message_types::error}, {"text", "You cannot trade with yourself."}});
			return;
		}
		// Check if already in a trade
		if (@find_trade_for_user(u) != null) {
			u.send({{"type", message_types::error}, {"text", "You are already in a trade."}});
			return;
		}
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.send({{"type", message_types::error}, {"text", target_name + " is not online."}});
			return;
		}
		if (target.is_bot) {
			u.send({{"type", message_types::error}, {"text", "You cannot trade with an AI player."}});
			return;
		}
		if (@find_trade_for_user(target) != null) {
			u.send({{"type", message_types::error}, {"text", target_name + " is already in a trade."}});
			return;
		}
		// Send trade request to the target
		target.send({{"type", message_types::trade_request}, {"from", u.username}});
		u.send({{"type", message_types::announce}, {"text", "Trade request sent to " + target_name + "."}, {"interrupt", false}});
		println("[TRADE] " + u.username + " sent trade request to " + target_name);
	}

	else if (msg_type == message_types::trade_accept and msg.exists("from")) {
		string from_name = msg["from"];
		user@ requester = users.get_user_by_name(from_name);
		if (@requester == null) {
			u.send({{"type", message_types::error}, {"text", from_name + " is no longer online."}});
			return;
		}
		if (@find_trade_for_user(u) != null or @find_trade_for_user(requester) != null) {
			u.send({{"type", message_types::error}, {"text", "Trade session conflict. Please try again."}});
			return;
		}
		// Create the trade session
		trade_session t;
		@t.player_a = requester;
		@t.player_b = u;
		active_trades.insert_last(t);
		// Send initial trade_update to both
		requester.send(build_trade_update(t, true));
		u.send(build_trade_update(t, false));
		println("[TRADE] Trade session started between " + requester.username + " and " + u.username);
	}

	else if (msg_type == message_types::trade_offer and msg.exists("items")) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) {
			u.send({{"type", message_types::error}, {"text", "You are not in an active trade."}});
			return;
		}
		// Reset confirmations when offer changes
		t.confirmed_a = false;
		t.confirmed_b = false;

		bool is_a = (@t.player_a is u);
		json_array@ items = msg["items"];
		string[] new_offer;
		if (@items != null and @u.account != null) {
			init_item_catalog();
			json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
			for (uint i = 0; i < items.length(); i++) {
				string item_id = string(items[i]);
				// Validate item exists in player's inventory
				if (inventory_has_item(inv, item_id)) {
					new_offer.insert_last(item_id);
				}
			}
		}

		if (is_a) t.offer_a = new_offer;
		else t.offer_b = new_offer;

		// Send updated trade state to both
		t.player_a.send(build_trade_update(t, true));
		t.player_b.send(build_trade_update(t, false));
	}

	else if (msg_type == message_types::trade_confirm) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) {
			u.send({{"type", message_types::error}, {"text", "You are not in an active trade."}});
			return;
		}
		bool is_a = (@t.player_a is u);
		if (is_a) t.confirmed_a = true;
		else t.confirmed_b = true;

		// Send updated state to both
		t.player_a.send(build_trade_update(t, true));
		t.player_b.send(build_trade_update(t, false));

		// If both confirmed, execute the trade
		if (t.confirmed_a and t.confirmed_b) {
			complete_trade(t);
		}
	}

	else if (msg_type == message_types::trade_cancel) {
		trade_session@ t = find_trade_for_user(u);
		if (@t == null) return;
		cancel_trade(t, u.username + " cancelled the trade.");
	}

	// ---- WEEKLY CHALLENGES ----

	else if (msg_type == message_types::weekly_challenges) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ challenge_msg = build_weekly_challenges_message(u.account);
		if (@challenge_msg != null) u.send(challenge_msg);
	}

	// ---- GLORY SHOP ----

	else if (msg_type == message_types::glory_shop_list) {
		if (@u.account == null) return;
		init_glory_shop();
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
		json_array@ owned_titles = @progress != null ? ensure_json_array_field(progress, "owned_titles") : null;

		json_array shop_arr;
		for (uint si = 0; si < GLORY_SHOP.length(); si++) {
			shop_entry@ e = GLORY_SHOP[si];
			json_object entry;
			entry["id"] = e.id;
			entry["name"] = e.name;
			entry["description"] = e.description;
			entry["type"] = e.type;
			entry["glory_cost"] = e.glory_cost;
			bool owned = false;
			if (e.type == SHOP_TYPE_TITLE and @owned_titles != null) {
				for (uint ti = 0; ti < owned_titles.length(); ti++) {
					if (string(owned_titles[ti]) == e.id) { owned = true; break; }
				}
			} else if (e.type == SHOP_TYPE_ITEM and @inv != null) {
				owned = inventory_has_item(inv, e.item_id);
			}
			entry["owned"] = owned;
			if (e.item_id != "") entry["item_id"] = e.item_id;
			shop_arr.add(entry);
		}
		u.send({{"type", message_types::glory_shop_list}, {"items", shop_arr}, {"glory", get_glory(u.account)}});
	}

	else if (msg_type == message_types::glory_shop_buy and msg.exists("shop_id")) {
		if (@u.account == null) return;
		init_glory_shop();
		ensure_account_progression(u.account);
		string shop_id = string(msg["shop_id"]);
		shop_entry@ e = find_shop_entry(shop_id);
		if (@e == null) {
			u.send({{"type", message_types::error}, {"text", "Item not found in the Glory Shop."}});
			return;
		}

		json_object@ progress = get_adventure_progress(u.account);
		int current_glory = get_glory(u.account);
		if (current_glory < e.glory_cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough Glory Points. You have " + current_glory + " but need " + e.glory_cost + "."}});
			return;
		}

		if (e.type == SHOP_TYPE_TITLE) {
			json_array@ owned_titles = ensure_json_array_field(progress, "owned_titles");
			// Check if already owned
			for (uint ti = 0; ti < owned_titles.length(); ti++) {
				if (string(owned_titles[ti]) == e.id) {
					u.send({{"type", message_types::error}, {"text", "You already own this title."}});
					return;
				}
			}
			owned_titles.add(e.id);
			progress["glory"] = current_glory - e.glory_cost;
			u.account.commit();
			u.send({{"type", message_types::glory_update}, {"glory", get_glory(u.account)}, {"gained", 0}});
			u.send({{"type", message_types::announce}, {"text", "You purchased the title: " + e.name + "!"}, {"interrupt", true}});
		} else if (e.type == SHOP_TYPE_ITEM) {
			json_array@ inv = ensure_json_array_field(u.account.data, "adventure_inventory");
			if (inventory_has_item(inv, e.item_id)) {
				u.send({{"type", message_types::error}, {"text", "You already own this item."}});
				return;
			}
			if (int(inv.length()) >= MAX_INVENTORY) {
				u.send({{"type", message_types::error}, {"text", "Your inventory is full! Discard an item first."}});
				return;
			}
			inventory_add_item(inv, e.item_id);
			progress["glory"] = current_glory - e.glory_cost;
			u.account.commit();
			u.send({{"type", message_types::glory_update}, {"glory", get_glory(u.account)}, {"gained", 0}});
			u.send({{"type", message_types::announce}, {"text", "You purchased: " + e.name + "!"}, {"interrupt", true}});
		}
	}

	// ---- SET ACTIVE TITLE ----

	else if (msg_type == message_types::set_active_title and msg.exists("title_id")) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress == null) return;
		string title_id = string(msg["title_id"]);

		if (title_id == "") {
			// Clear active title
			progress["active_title"] = "";
			u.account.commit();
			u.send({{"type", message_types::announce}, {"text", "Title removed."}, {"interrupt", false}});
			return;
		}

		json_array@ owned_titles = ensure_json_array_field(progress, "owned_titles");
		bool found = false;
		for (uint ti = 0; ti < owned_titles.length(); ti++) {
			if (string(owned_titles[ti]) == title_id) { found = true; break; }
		}
		if (!found) {
			u.send({{"type", message_types::error}, {"text", "You do not own this title."}});
			return;
		}

		init_glory_shop();
		shop_entry@ se = find_shop_entry(title_id);
		progress["active_title"] = title_id;
		u.account.commit();
		string title_name = @se != null ? se.name : title_id;
		u.send({{"type", message_types::announce}, {"text", "Active title set to: " + title_name + "."}, {"interrupt", false}});
	}

	// ---- DAILY DUNGEON INFO ----

	else if (msg_type == message_types::daily_dungeon_info) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		string dungeon_id = get_daily_dungeon_id();
		string difficulty = get_daily_difficulty();
		string dungeon_name = get_dungeon_display_name(dungeon_id);
		bool claimable = can_claim_daily(u.account);
		u.send({{"type", message_types::daily_dungeon_info}, {"dungeon_id", dungeon_id}, {"dungeon_name", dungeon_name}, {"difficulty", difficulty}, {"can_claim", claimable}});
	}

	// ---- LEADERBOARDS ----

	else if (msg_type == message_types::leaderboard_request and msg.exists("category")) {
		string category = string(msg["category"]);
		json_array leaderboard;
		string my_username = u.username;
		int my_value = 0;
		int my_rank = -1;

		// Collect all player scores
		json_object@[] all_scores;
		string[] all_usernames;
		string[] all_prestige_titles;
		int[] all_values;

		for (uint ai = 0; ai < accounts.length(); ai++) {
			account@ acct = accounts[ai];
			if (@acct == null or @acct.data == null) continue;
			if (!acct.data.exists(ACCOUNT_KEY_ADVENTURE_PROGRESS)) continue;
			json_object@ prog = acct.data[ACCOUNT_KEY_ADVENTURE_PROGRESS];
			if (@prog == null) continue;

			int value = 0;
			if (category == "glory") value = get_json_int(prog, "glory", 0);
			else if (category == "endless") value = get_json_int(prog, "endless_best_wave", 0);
			else if (category == "kills") value = get_json_int(prog, "monster_kills", 0);
			else if (category == "prestige") value = get_json_int(prog, "prestige_rank", 0);
			else if (category == "dungeons") {
				int total = 0;
				if (prog.exists("dungeons_completed")) {
					json_object@ dc = prog["dungeons_completed"];
					if (@dc != null) {
						string[]@ keys = dc.get_keys();
						for (uint ki = 0; ki < keys.length(); ki++) {
							total += get_json_int(dc, keys[ki], 0);
						}
					}
				}
				value = total;
			}

			if (value <= 0) continue;

			all_usernames.insert_last(acct.username);
			all_values.insert_last(value);
			string pt = get_prestige_title(get_json_int(prog, "prestige_rank", 0));
			all_prestige_titles.insert_last(pt);
		}

		// Sort descending by value (simple insertion sort for small sets)
		for (int si = 1; si < int(all_values.length()); si++) {
			int key_val = all_values[si];
			string key_name = all_usernames[si];
			string key_pt = all_prestige_titles[si];
			int sj = si - 1;
			while (sj >= 0 and all_values[sj] < key_val) {
				all_values[sj + 1] = all_values[sj];
				all_usernames[sj + 1] = all_usernames[sj];
				all_prestige_titles[sj + 1] = all_prestige_titles[sj];
				sj--;
			}
			all_values[sj + 1] = key_val;
			all_usernames[sj + 1] = key_name;
			all_prestige_titles[sj + 1] = key_pt;
		}

		// Build top 10 and find requesting player
		int limit = int(all_values.length());
		if (limit > 10) limit = 10;
		for (int ri = 0; ri < limit; ri++) {
			json_object entry;
			entry["rank"] = ri + 1;
			entry["username"] = all_usernames[ri];
			entry["value"] = all_values[ri];
			entry["prestige_title"] = all_prestige_titles[ri];
			leaderboard.add(entry);
		}

		// Find requesting player's rank
		for (int ri = 0; ri < int(all_values.length()); ri++) {
			if (all_usernames[ri] == my_username) {
				my_rank = ri + 1;
				my_value = all_values[ri];
				break;
			}
		}

		u.send({{"type", message_types::leaderboard_data}, {"category", category}, {"entries", leaderboard}, {"my_rank", my_rank}, {"my_value", my_value}});
	}

	// ---- Consumable Shop ----
	else if (msg_type == message_types::shop_list) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		init_consumable_catalog();
		json_array@ cons_inv = ensure_json_array_field(u.account.data, "adventure_consumables");

		json_array shop_arr;
		for (uint si = 0; si < CONSUMABLE_CATALOG.length(); si++) {
			consumable_def@ cd = CONSUMABLE_CATALOG[si];
			json_object entry;
			entry["id"] = cd.id;
			entry["name"] = cd.name;
			entry["type"] = cd.type;
			entry["type_name"] = CONS_TYPE_NAMES[cd.type];
			entry["action_type"] = cd.action_type;
			entry["description"] = cd.description;
			entry["gold_cost"] = cd.gold_cost;
			entry["owned"] = get_consumable_quantity(cons_inv, cd.id);
			entry["max_stack"] = MAX_CONSUMABLE_STACK;
			shop_arr.add(entry);
		}
		u.send({{"type", message_types::shop_list}, {"items", shop_arr}, {"gold", get_gold(u.account)}});
	}

	else if (msg_type == message_types::shop_buy and msg.exists("consumable_id")) {
		if (@u.account == null) return;
		ensure_account_progression(u.account);
		init_consumable_catalog();

		string buy_id = string(msg["consumable_id"]);
		consumable_def@ cd = find_consumable(buy_id);
		if (@cd == null) {
			u.send({{"type", message_types::error}, {"text", "Unknown item."}});
			return;
		}

		int current_gold = get_gold(u.account);
		if (current_gold < cd.gold_cost) {
			u.send({{"type", message_types::error}, {"text", "Not enough gold. Need " + cd.gold_cost + ", have " + current_gold + "."}});
			return;
		}

		json_array@ cons_inv = ensure_json_array_field(u.account.data, "adventure_consumables");
		int current_qty = get_consumable_quantity(cons_inv, buy_id);
		if (current_qty >= MAX_CONSUMABLE_STACK) {
			u.send({{"type", message_types::error}, {"text", "Already at max stack (" + MAX_CONSUMABLE_STACK + ") for " + cd.name + "."}});
			return;
		}

		if (!spend_gold(u.account, cd.gold_cost)) {
			u.send({{"type", message_types::error}, {"text", "Failed to deduct gold."}});
			return;
		}

		if (!add_consumable_to_inventory(cons_inv, buy_id)) {
			// Refund gold if inventory add fails
			add_gold(u.account, cd.gold_cost);
			u.send({{"type", message_types::error}, {"text", "Inventory full."}});
			return;
		}

		u.account.commit();
		int new_qty = get_consumable_quantity(cons_inv, buy_id);
		u.send({{"type", message_types::announce}, {"text", "Purchased " + cd.name + "! You now have " + new_qty + ". Gold remaining: " + get_gold(u.account) + "."}, {"interrupt", false}});
		// Send updated shop list
		json_array updated_shop;
		for (uint si = 0; si < CONSUMABLE_CATALOG.length(); si++) {
			consumable_def@ ucd = CONSUMABLE_CATALOG[si];
			json_object entry;
			entry["id"] = ucd.id;
			entry["name"] = ucd.name;
			entry["type"] = ucd.type;
			entry["type_name"] = CONS_TYPE_NAMES[ucd.type];
			entry["action_type"] = ucd.action_type;
			entry["description"] = ucd.description;
			entry["gold_cost"] = ucd.gold_cost;
			entry["owned"] = get_consumable_quantity(cons_inv, ucd.id);
			entry["max_stack"] = MAX_CONSUMABLE_STACK;
			updated_shop.add(entry);
		}
		u.send({{"type", message_types::shop_list}, {"items", updated_shop}, {"gold", get_gold(u.account)}});
	}

	else if (msg_type == message_types::use_consumable) {
		if (@u.room == null or @u.room.bm == null) {
			u.send({{"type", message_types::error}, {"text", "Not in a battle."}});
			return;
		}
		u.room.bm.handle_use_consumable(u, msg);
	}

	// ---- GUILD SYSTEM HANDLERS ----

	else if (msg_type == message_types::create_guild and msg.exists("name")) {
		string guild_name = string(msg["name"]).trim_whitespace();
		// Validate name length.
		if (guild_name.length() < 3 or guild_name.length() > 30) {
			u.speak("Guild name must be between 3 and 30 characters.");
			return;
		}
		// Validate characters (letters, numbers, spaces only).
		string allowed = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 ";
		for (uint i = 0; i < guild_name.length(); i++) {
			if (allowed.find(guild_name[i]) < 0) {
				u.speak("Guild name can only contain letters, numbers, and spaces.");
				return;
			}
		}
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild. Leave your current guild first.");
			return;
		}
		// Check if guild name is taken.
		if (@find_guild(guild_name) != null) {
			u.speak("A guild with that name already exists.");
			return;
		}
		// Create the guild.
		guild@ g = guild(guild_name, u.username);
		guilds.insert_last(g);
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = guild_name;
			progress["guild_leader"] = u.username;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " created guild '" + guild_name + "'");
		// Send guild info back to confirm.
		json_object info;
		info["type"] = message_types::guild_info;
		info["name"] = g.name;
		info["leader"] = g.leader;
		json_array member_arr;
		for (uint i = 0; i < g.members.length(); i++) member_arr.add(g.members[i]);
		info["members"] = member_arr;
		info["member_count"] = int(g.members.length());
		info["total_glory"] = get_glory(u.account);
		u.send(info);
		u.speak("Guild '" + guild_name + "' created! You are the guild leader.");
	}

	else if (msg_type == message_types::join_guild and msg.exists("name")) {
		string guild_name = string(msg["name"]);
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild.");
			return;
		}
		guild@ g = find_guild(guild_name);
		if (@g == null) {
			u.speak("No guild found with that name.");
			return;
		}
		if (g.members.length() >= 20) {
			u.speak("That guild is full.");
			return;
		}
		if (!g.add_member(u.username)) {
			u.speak("Could not join the guild.");
			return;
		}
		guild_cache_add(u.username, g);
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = g.name;
			progress["guild_leader"] = g.leader;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " joined guild '" + g.name + "'");
		u.speak("You joined the guild '" + g.name + "'!");
		// Notify online guild members.
		for (uint i = 0; i < g.members.length(); i++) {
			if (g.members[i] == u.username) continue;
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) {
				member.send({{"type", message_types::announce}, {"text", u.username + " has joined the guild!"}, {"interrupt", false}});
			}
		}
	}

	else if (msg_type == message_types::leave_guild) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		string old_guild_name = g.name;
		bool was_leader = (g.leader == u.username);
		g.remove_member(u.username);
		guild_cache_remove(u.username);
		// Clear from account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = "";
			progress["guild_leader"] = "";
		}
		u.account.commit();
		if (g.members.length() == 0) {
			// Disband guild.
			int idx = guilds.find_by_ref(g);
			if (idx >= 0) guilds.remove_at(idx);
			println("[GUILDS] Guild '" + old_guild_name + "' disbanded (last member left).");
		} else if (was_leader) {
			// Transfer leadership to first remaining member.
			g.leader = g.members[0];
			// Update the new leader's account.
			account@ new_leader_acct = get_account(g.leader);
			if (@new_leader_acct != null) {
				ensure_account_progression(new_leader_acct);
				json_object@ lp = get_adventure_progress(new_leader_acct);
				if (@lp != null) lp["guild_leader"] = g.leader;
				new_leader_acct.commit();
			}
			// Notify online guild members.
			for (uint i = 0; i < g.members.length(); i++) {
				user@ member = users.get_user_by_name(g.members[i]);
				if (@member != null) {
					member.send({{"type", message_types::announce}, {"text", u.username + " has left the guild. " + g.leader + " is the new leader."}, {"interrupt", false}});
				}
			}
			println("[GUILDS] " + u.username + " left guild '" + old_guild_name + "'. New leader: " + g.leader);
		} else {
			// Notify online guild members.
			for (uint i = 0; i < g.members.length(); i++) {
				user@ member = users.get_user_by_name(g.members[i]);
				if (@member != null) {
					member.send({{"type", message_types::announce}, {"text", u.username + " has left the guild."}, {"interrupt", false}});
				}
			}
			println("[GUILDS] " + u.username + " left guild '" + old_guild_name + "'.");
		}
		u.send({{"type", message_types::leave_guild}});
		u.speak("You left the guild '" + old_guild_name + "'.");
	}

	else if (msg_type == message_types::guild_chat and msg.exists("message")) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		string chat_text = string(msg["message"]);
		// Broadcast to all online guild members.
		json_object@ chat_msg = {{"type", message_types::guild_chat}, {"from", u.username}, {"message", chat_text}};
		for (uint i = 0; i < g.members.length(); i++) {
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) member.send(chat_msg);
		}
	}

	else if (msg_type == message_types::guild_info) {
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.send({{"type", message_types::guild_info}});
			return;
		}
		json_object info;
		info["type"] = message_types::guild_info;
		info["name"] = g.name;
		info["leader"] = g.leader;
		json_array member_arr;
		int total_glory = 0;
		for (uint i = 0; i < g.members.length(); i++) {
			member_arr.add(g.members[i]);
			account@ macct = get_account(g.members[i]);
			if (@macct != null) total_glory += get_glory(macct);
		}
		info["members"] = member_arr;
		info["member_count"] = int(g.members.length());
		info["total_glory"] = total_glory;
		u.send(info);
	}

	else if (msg_type == message_types::guild_invite and msg.exists("target")) {
		string target_name = string(msg["target"]);
		guild@ g = find_guild_for_user(u.username);
		if (@g == null) {
			u.speak("You are not in a guild.");
			return;
		}
		user@ target = users.get_user_by_name(target_name);
		if (@target == null) {
			u.speak(target_name + " is not online.");
			return;
		}
		if (@find_guild_for_user(target_name) != null) {
			u.speak(target_name + " is already in a guild.");
			return;
		}
		// Send invite to target.
		target.send({{"type", message_types::guild_invite_received}, {"from", u.username}, {"guild_name", g.name}});
		u.speak("Guild invite sent to " + target_name + ".");
		println("[GUILDS] " + u.username + " invited " + target_name + " to guild '" + g.name + "'");
	}

	else if (msg_type == message_types::guild_invite_response and msg.exists("accepted") and msg.exists("guild_name")) {
		bool accepted = bool(msg["accepted"]);
		string guild_name = string(msg["guild_name"]);
		if (!accepted) {
			u.speak("Guild invite declined.");
			return;
		}
		// Check if player is already in a guild.
		if (@find_guild_for_user(u.username) != null) {
			u.speak("You are already in a guild.");
			return;
		}
		guild@ g = find_guild(guild_name);
		if (@g == null) {
			u.speak("That guild no longer exists.");
			return;
		}
		if (g.members.length() >= 20) {
			u.speak("That guild is full.");
			return;
		}
		if (!g.add_member(u.username)) {
			u.speak("Could not join the guild.");
			return;
		}
		guild_cache_add(u.username, g);
		// Persist to account.
		ensure_account_progression(u.account);
		json_object@ progress = get_adventure_progress(u.account);
		if (@progress != null) {
			progress["guild_name"] = g.name;
			progress["guild_leader"] = g.leader;
		}
		u.account.commit();
		println("[GUILDS] " + u.username + " accepted guild invite to '" + g.name + "'");
		u.speak("You joined the guild '" + g.name + "'!");
		// Notify online guild members.
		for (uint i = 0; i < g.members.length(); i++) {
			if (g.members[i] == u.username) continue;
			user@ member = users.get_user_by_name(g.members[i]);
			if (@member != null) {
				member.send({{"type", message_types::announce}, {"text", u.username + " has joined the guild!"}, {"interrupt", false}});
			}
		}
	}

	// ---- Player Stats ----
	else if (msg_type == message_types::player_stats) {
		if (@u.account != null) {
			ensure_account_progression(u.account);
			json_object@ stats_msg = build_player_stats_message(u.account);
			if (@stats_msg != null) u.send(stats_msg);
		}
	}

	else if (msg_type == message_types::inspect_player and msg.exists("target")) {
		string target_name = string(msg["target"]);
		if (target_name == "") {
			u.speak("No player specified.");
			return;
		}
		account@ target_acct = get_account(target_name);
		if (@target_acct == null) {
			u.speak("Player not found.");
			return;
		}
		ensure_account_progression(target_acct);
		json_object@ inspect_msg = build_player_inspect_message(target_acct, target_name);
		if (@inspect_msg != null) {
			u.send(inspect_msg);
		} else {
			u.speak("Could not retrieve stats for that player.");
		}
	}
}
